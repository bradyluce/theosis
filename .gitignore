# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local ingestion artifacts / data (do not commit)
/_tmp_*.html
/get-diff.txt
/content/generated/
# Raw source material: ignore everything inside, but keep the directory tree
# and surface the README + PROVENANCE files so layout/license posture lives in git.
/content/raw/**
!/content/raw/**/
!/content/raw/**/README.md
!/content/raw/**/PROVENANCE.json
!/content/raw/.gitkeep

# Claude Code per-developer local config
/.claude/settings.local.json
