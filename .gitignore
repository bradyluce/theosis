# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local ingestion artifacts / data (do not commit)
/_tmp_*.html
/get-diff.txt
/get-log.txt
/content/generated/

# Chunked library index — a build-only input to the embeddings script
# (scripts/search/build-library-chunks.ts). Unlike library.json/commentary.json
# it is NOT imported at runtime; regenerate with `npm run build:library-chunks`.
/content/normalized/search/library-chunks.json

# Obsidian per-developer editor state inside docs/
/docs/.obsidian/
# External patristic corpus mirrored on demand for ingest only
/corpus/hcf-commentaries/
# Raw source material: ignore everything inside, but keep the directory tree
# and surface the README + PROVENANCE files so layout/license posture lives in git.
/content/raw/**
!/content/raw/**/
!/content/raw/**/README.md
!/content/raw/**/PROVENANCE.json
!/content/raw/.gitkeep

# Claude Code per-developer local config
/.claude/settings.local.json

# Claude Code internals (worktrees + preview launch config)
.claude/

# Claude Code agent workspace + skills lock (regenerated on demand)
/.agents/
/skills-lock.json

# Stray sample files (e.g. corpus snippets dumped at root)
/sample*.txt
# Stray root-level images dumped by tooling (e.g. an EAS/Expo screenshot, or a
# duplicated onboarding asset). Real images live under public/ or apps/mobile/;
# force-add with `git add -f` if a root-level image is ever genuinely needed.
/*.jpg
/*.jpeg
/*.png
/*.webp
# Accidental root-level Expo config stub: running `expo`/`eas` from the repo
# root (instead of apps/mobile/) drops a `{"expo":{}}` app.json here that can
# shadow the real config. The real Expo config lives at apps/mobile/app.json.
/app.json

# Temp test files
.tmp_*
tmp_test.txt

# OCR runtime artifacts (tesseract.js downloads + ingest logs)
/eng.traineddata
/*.traineddata
/ingest.log
/*.log

# Expo / React Native build artifacts (mobile app)
.expo/

# Python build artifacts (used by some ad-hoc ingest scripts)
**/__pycache__/

# Acquisition source PDFs — large source materials. Behave like content/raw/:
# directory layout is tracked, individual PDFs are not.
/content/acquisition/*.pdf
/content/acquisition/*.PDF
# Stray PDFs at repo root are never committed (they should be moved into
# content/acquisition/ or content/raw/).
/*.pdf

# Icon-audit scratch data (run /dev/icons + replacement picker to regenerate).
/.flagged-icons.json
/.flagged-icons-candidates.json

# clerk configuration (can include secrets)
/.clerk/

# Short-form clip output (downloaded YT video + rendered TikTok clips)
/content/clips/
