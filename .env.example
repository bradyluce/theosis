# Copy to .env.local for local dev. Vercel reads these directly from its
# project settings UI in production / preview — never commit a real .env.

# ---------------------------------------------------------------------------
# Clerk — auth (Phase 1+)
# ---------------------------------------------------------------------------
# Provision at https://dashboard.clerk.com and copy from the API Keys panel.
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Reserved for Phase 3 (user.deleted webhook). Empty in Phase 1.
CLERK_WEBHOOK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Vercel Postgres (Neon under the hood) — user data store (Phase 1+)
# ---------------------------------------------------------------------------
# Provision a Postgres database in the Vercel dashboard and "Connect" it to
# the project. Vercel auto-injects both URLs at build/runtime; for local dev
# pull them with `vercel env pull .env.local`.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL=

# ---------------------------------------------------------------------------
# Bible / content delivery (existing, repeated for completeness)
# ---------------------------------------------------------------------------
# Bible chapter JSON and (eventually) the big commentary tree live on R2 /
# S3. Empty endpoint = falls back to local content/normalized/* files.
BIBLE_S3_BUCKET=theosis-content
BIBLE_S3_REGION=us-east-1
BIBLE_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
