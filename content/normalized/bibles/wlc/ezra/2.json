      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ezra 2:20",
      "text": "בְּנֵ֥י גִבָּ֖ר תִּשְׁעִ֥ים וַחֲמִשָּֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.21",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ezra 2:21",
      "text": "בְּנֵ֣י בֵֽית ־ לָ֔חֶם מֵאָ֖ה עֶשְׂרִ֥ים וּשְׁלֹשָֽׁה ׃ ס",
      "paragraphStart": false
