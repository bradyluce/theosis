  },
  "verses": [
    {
      "id": "wlc:ezra.2.1",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ezra 2:1",
      "text": "וְאֵ֣לֶּה ׀ בְּנֵ֣י הַמְּדִינָ֗ה הָֽעֹלִים֙ מִשְּׁבִ֣י הַגּוֹלָ֔ה אֲשֶׁ֥ר הֶגְלָ֛ה נבוכדנצור מֶֽלֶךְ ־ בָּבֶ֖ל לְבָבֶ֑ל וַיָּשׁ֛וּבוּ לִירוּשָׁלִַ֥ם וִֽיהוּדָ֖ה אִ֥ישׁ לְעִירֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:ezra.2.2",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ezra 2:2",
      "text": "אֲשֶׁר ־ בָּ֣אוּ עִם ־ זְרֻבָּבֶ֗ל יֵשׁ֡וּעַ נְ֠חֶמְיָה שְׂרָיָ֨ה רְֽעֵלָיָ֜ה מָרְדֳּכַ֥י בִּלְשָׁ֛ן מִסְפָּ֥ר בִּגְוַ֖י רְח֣וּם בַּעֲנָ֑ה מִסְפַּ֕ר אַנְשֵׁ֖י עַ֥ם יִשְׂרָאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.3",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ezra 2:3",
      "text": "בְּנֵ֣י פַרְעֹ֔שׁ אַלְפַּ֕יִם מֵאָ֖ה שִׁבְעִ֥ים וּשְׁנָֽיִם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.4",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ezra 2:4",
      "text": "בְּנֵ֣י שְׁפַטְיָ֔ה שְׁלֹ֥שׁ מֵא֖וֹת שִׁבְעִ֥ים וּשְׁנָֽיִם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.5",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ezra 2:5",
      "text": "בְּנֵ֣י אָרַ֔ח שְׁבַ֥ע מֵא֖וֹת חֲמִשָּׁ֥ה וְשִׁבְעִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.6",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ezra 2:6",
      "text": "בְּנֵֽי ־ פַחַ֥ת מוֹאָ֛ב לִבְנֵ֥י יֵשׁ֖וּעַ יוֹאָ֑ב אַלְפַּ֕יִם שְׁמֹנֶ֥ה מֵא֖וֹת וּשְׁנֵ֥ים עָשָֽׂר ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.7",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ezra 2:7",
      "text": "בְּנֵ֣י עֵילָ֔ם אֶ֕לֶף מָאתַ֖יִם חֲמִשִּׁ֥ים וְאַרְבָּעָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.8",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ezra 2:8",
      "text": "בְּנֵ֣י זַתּ֔וּא תְּשַׁ֥ע מֵא֖וֹת וְאַרְבָּעִ֥ים וַחֲמִשָּֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.9",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ezra 2:9",
      "text": "בְּנֵ֣י זַכָּ֔י שְׁבַ֥ע מֵא֖וֹת וְשִׁשִּֽׁים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.10",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ezra 2:10",
      "text": "בְּנֵ֣י בָנִ֔י שֵׁ֥שׁ מֵא֖וֹת אַרְבָּעִ֥ים וּשְׁנָֽיִם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.11",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ezra 2:11",
      "text": "בְּנֵ֣י בֵבָ֔י שֵׁ֥שׁ מֵא֖וֹת עֶשְׂרִ֥ים וּשְׁלֹשָֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.12",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ezra 2:12",
      "text": "בְּנֵ֣י עַזְגָּ֔ד אֶ֕לֶף מָאתַ֖יִם עֶשְׂרִ֥ים וּשְׁנָֽיִם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.13",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ezra 2:13",
      "text": "בְּנֵי֙ אֲדֹ֣נִיקָ֔ם שֵׁ֥שׁ מֵא֖וֹת שִׁשִּׁ֥ים וְשִׁשָּֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.14",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ezra 2:14",
      "text": "בְּנֵ֣י בִגְוָ֔י אַלְפַּ֖יִם חֲמִשִּׁ֥ים וְשִׁשָּֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.15",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ezra 2:15",
      "text": "בְּנֵ֣י עָדִ֔ין אַרְבַּ֥ע מֵא֖וֹת חֲמִשִּׁ֥ים וְאַרְבָּעָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.16",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ezra 2:16",
      "text": "בְּנֵֽי ־ אָטֵ֥ר לִֽיחִזְקִיָּ֖ה תִּשְׁעִ֥ים וּשְׁמֹנָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.17",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ezra 2:17",
      "text": "בְּנֵ֣י בֵצָ֔י שְׁלֹ֥שׁ מֵא֖וֹת עֶשְׂרִ֥ים וּשְׁלֹשָֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.18",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ezra 2:18",
      "text": "בְּנֵ֣י יוֹרָ֔ה מֵאָ֖ה וּשְׁנֵ֥ים עָשָֽׂר ׃ ס",
      "paragraphStart": false
