    {
      "id": "wlc:ezra.2.22",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ezra 2:22",
      "text": "אַנְשֵׁ֥י נְטֹפָ֖ה חֲמִשִּׁ֥ים וְשִׁשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.23",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Ezra 2:23",
      "text": "אַנְשֵׁ֣י עֲנָת֔וֹת מֵאָ֖ה עֶשְׂרִ֥ים וּשְׁמֹנָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:ezra.2.24",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Ezra 2:24",
      "text": "בְּנֵ֥י עַזְמָ֖וֶת אַרְבָּעִ֥ים וּשְׁנָֽיִם ׃ ס",
      "paragraphStart": false
