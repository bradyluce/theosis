    {
      "id": "wlc:ezra.2.19",
      "translationId": "wlc",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ezra 2:19",
      "text": "בְּנֵ֣י חָשֻׁ֔ם מָאתַ֖יִם עֶשְׂרִ֥ים וּשְׁלֹשָֽׁה ׃ ס",
      "paragraphStart": false
