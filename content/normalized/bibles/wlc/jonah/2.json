    "translationId": "wlc",
    "bookSlug": "jonah",
    "chapterNumber": 2,
    "referenceLabel": "Jonah 2",
    "summary": "Source text for Jonah 2 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:jonah.2.1",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Jonah 2:1",
      "text": "וַיְמַ֤ן יְהוָה֙ דָּ֣ג גָּד֔וֹל לִבְלֹ֖עַ אֶת ־ יוֹנָ֑ה וַיְהִ֤י יוֹנָה֙ בִּמְעֵ֣י הַדָּ֔ג שְׁלֹשָׁ֥ה יָמִ֖ים וּשְׁלֹשָׁ֥ה לֵילֽוֹת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:jonah.2.2",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Jonah 2:2",
      "text": "וַיִּתְפַּלֵּ֣ל יוֹנָ֔ה אֶל ־ יְהוָ֖ה אֱלֹהָ֑יו מִמְּעֵ֖י הַדָּגָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.3",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Jonah 2:3",
      "text": "וַיֹּ֗אמֶר קָ֠רָאתִי מִצָּ֥רָה לִ֛י אֶל ־ יְהוָ֖ה וַֽיַּעֲנֵ֑נִי מִבֶּ֧טֶן שְׁא֛וֹל שִׁוַּ֖עְתִּי שָׁמַ֥עְתָּ קוֹלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.4",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Jonah 2:4",
      "text": "וַתַּשְׁלִיכֵ֤נִי מְצוּלָה֙ בִּלְבַ֣ב יַמִּ֔ים וְנָהָ֖ר יְסֹבְבֵ֑נִי כָּל ־ מִשְׁבָּרֶ֥יךָ וְגַלֶּ֖יךָ עָלַ֥י עָבָֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.5",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Jonah 2:5",
      "text": "וַאֲנִ֣י אָמַ֔רְתִּי נִגְרַ֖שְׁתִּי מִנֶּ֣גֶד עֵינֶ֑יךָ אַ֚ךְ אוֹסִ֣יף לְהַבִּ֔יט אֶל ־ הֵיכַ֖ל קָדְשֶֽׁךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.6",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Jonah 2:6",
      "text": "אֲפָפ֤וּנִי מַ֨יִם֙ עַד ־ נֶ֔פֶשׁ תְּה֖וֹם יְסֹבְבֵ֑נִי ס֖וּף חָב֥וּשׁ לְרֹאשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.7",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Jonah 2:7",
      "text": "לְקִצְבֵ֤י הָרִים֙ יָרַ֔דְתִּי הָאָ֛רֶץ בְּרִחֶ֥יהָ בַעֲדִ֖י לְעוֹלָ֑ם וַתַּ֧עַל מִשַּׁ֛חַת חַיַּ֖י יְהוָ֥ה אֱלֹהָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.8",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Jonah 2:8",
      "text": "בְּהִתְעַטֵּ֤ף עָלַי֙ נַפְשִׁ֔י אֶת ־ יְהוָ֖ה זָכָ֑רְתִּי וַתָּב֤וֹא אֵלֶ֨יךָ֙ תְּפִלָּתִ֔י אֶל ־ הֵיכַ֖ל קָדְשֶֽׁךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.9",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Jonah 2:9",
      "text": "מְשַׁמְּרִ֖ים הַבְלֵי ־ שָׁ֑וְא חַסְדָּ֖ם יַעֲזֹֽבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.10",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Jonah 2:10",
      "text": "וַאֲנִ֗י בְּק֤וֹל תּוֹדָה֙ אֶזְבְּחָה ־ לָּ֔ךְ אֲשֶׁ֥ר נָדַ֖רְתִּי אֲשַׁלֵּ֑מָה יְשׁוּעָ֖תָה לַיהוָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:jonah.2.11",
      "translationId": "wlc",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Jonah 2:11",
      "text": "וַיֹּ֥אמֶר יְהוָ֖ה לַדָּ֑ג וַיָּקֵ֥א אֶת ־ יוֹנָ֖ה אֶל ־ הַיַּבָּשָֽׁה ׃ פ",
      "paragraphStart": false
    }
  ]
}
