{
  "chapter": {
    "id": "wlc:first-chronicles.2",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 2,
    "referenceLabel": "1 Chronicles 2",
    "summary": "Source text for 1 Chronicles 2 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.2.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 2:1",
      "text": "אֵ֖לֶּה בְּנֵ֣י יִשְׂרָאֵ֑ל רְאוּבֵ֤ן שִׁמְעוֹן֙ לֵוִ֣י וִיהוּדָ֔ה יִשָׂשכָ֖ר וּזְבֻלֽוּן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.2.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 2:2",
      "text": "דָּ֚ן יוֹסֵ֣ף וּבִנְיָמִ֔ן נַפְתָּלִ֖י גָּ֥ד וְאָשֵֽׁר ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 2:3",
      "text": "בְּנֵ֣י יְהוּדָ֗ה עֵ֤ר וְאוֹנָן֙ וְשֵׁלָ֔ה שְׁלוֹשָׁה֙ נ֣וֹלַד ל֔וֹ מִבַּת ־ שׁ֖וּעַ הַֽכְּנַעֲנִ֑ית וַיְהִ֞י עֵ֣ר ׀ בְּכ֣וֹר יְהוּדָ֗ה רַ֛ע בְּעֵינֵ֥י יְהוָ֖ה וַיְמִיתֵֽהוּ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 2:4",
      "text": "וְתָמָר֙ כַּלָּת֔וֹ יָ֥לְדָה לּ֖וֹ אֶת ־ פֶּ֣רֶץ וְאֶת ־ זָ֑רַח כָּל ־ בְּנֵ֥י יְהוּדָ֖ה חֲמִשָּֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 2:5",
      "text": "בְּנֵי ־ פֶ֖רֶץ חֶצְר֥וֹן וְחָמֽוּל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 2:6",
      "text": "וּבְנֵ֣י זֶ֗רַח זִ֠מְרִי וְאֵיתָ֧ן וְהֵימָ֛ן וְכַלְכֹּ֥ל וָדָ֖רַע כֻּלָּ֥ם חֲמִשָּֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 2:7",
      "text": "וּבְנֵ֖י כַּרְמִ֑י עָכָר֙ עוֹכֵ֣ר יִשְׂרָאֵ֔ל אֲשֶׁ֥ר מָעַ֖ל בַּחֵֽרֶם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 2:8",
      "text": "וּבְנֵ֥י אֵיתָ֖ן עֲזַרְיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 2:9",
      "text": "וּבְנֵ֥י חֶצְר֖וֹן אֲשֶׁ֣ר נוֹלַד ־ ל֑וֹ אֶת ־ יְרַחְמְאֵ֥ל וְאֶת ־ רָ֖ם וְאֶת ־ כְּלוּבָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 2:10",
      "text": "וְרָ֖ם הוֹלִ֣יד אֶת ־ עַמִּינָדָ֑ב וְעַמִּינָדָב֙ הוֹלִ֣יד אֶת ־ נַחְשׁ֔וֹן נְשִׂ֖יא בְּנֵ֥י יְהוּדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 2:11",
      "text": "וְנַחְשׁוֹן֙ הוֹלִ֣יד אֶת ־ שַׂלְמָ֔א וְשַׂלְמָ֖א הוֹלִ֥יד אֶת ־ בֹּֽעַז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 2:12",
      "text": "וּבֹ֨עַז֙ הוֹלִ֣יד אֶת ־ עוֹבֵ֔ד וְעוֹבֵ֖ד הוֹלִ֥יד אֶת ־ יִשָֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 2:13",
      "text": "וְאִישַׁ֛י הוֹלִ֥יד אֶת ־ בְּכֹר֖וֹ אֶת ־ אֱלִיאָ֑ב וַאֲבִינָדָב֙ הַשֵּׁנִ֔י וְשִׁמְעָ֖א הַשְּׁלִישִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 2:14",
      "text": "נְתַנְאֵל֙ הָֽרְבִיעִ֔י רַדַּ֖י הַחֲמִישִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 2:15",
      "text": "אֹ֚צֶם הַשִּׁשִּׁ֔י דָּוִ֖יד הַשְּׁבִעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 2:16",
      "text": "ואחיתיהם צְרוּיָ֣ה וַאֲבִיגָ֑יִל וּבְנֵ֣י צְרוּיָ֗ה אַבְשַׁ֛י וְיוֹאָ֥ב וַעֲשָׂה ־ אֵ֖ל שְׁלֹשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 2:17",
      "text": "וַאֲבִיגַ֕יִל יָלְדָ֖ה אֶת ־ עֲמָשָׂ֑א וַאֲבִ֣י עֲמָשָׂ֔א יֶ֖תֶר הַיִּשְׁמְעֵאלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 2:18",
      "text": "וְכָלֵ֣ב בֶּן ־ חֶצְר֗וֹן הוֹלִ֛יד אֶת ־ עֲזוּבָ֥ה אִשָּׁ֖ה וְאֶת ־ יְרִיע֑וֹת וְאֵ֣לֶּה בָנֶ֔יהָ יֵ֥שֶׁר וְשׁוֹבָ֖ב וְאַרְדּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 2:19",
      "text": "וַתָּ֖מָת עֲזוּבָ֑ה וַיִּֽקַּֽח ־ ל֤וֹ כָלֵב֙ אֶת ־ אֶפְרָ֔ת וַתֵּ֥לֶד ל֖וֹ אֶת ־ חֽוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 2:20",
      "text": "וְחוּר֙ הוֹלִ֣יד אֶת ־ אוּרִ֔י וְאוּרִ֖י הוֹלִ֥יד אֶת ־ בְּצַלְאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 2:21",
      "text": "וְאַחַ֗ר בָּ֤א חֶצְרוֹן֙ אֶל ־ בַּת ־ מָכִיר֙ אֲבִ֣י גִלְעָ֔ד וְה֣וּא לְקָחָ֔הּ וְה֖וּא בֶּן ־ שִׁשִּׁ֣ים שָׁנָ֑ה וַתֵּ֥לֶד ל֖וֹ אֶת ־ שְׂגֽוּב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 2:22",
      "text": "וּשְׂג֖וּב הוֹלִ֣יד אֶת ־ יָאִ֑יר וַֽיְהִי ־ ל֗וֹ עֶשְׂרִ֤ים וְשָׁלוֹשׁ֙ עָרִ֔ים בְּאֶ֖רֶץ הַגִּלְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 2:23",
      "text": "וַיִּקַּ֣ח גְּשֽׁוּר ־ וַ֠אֲרָם אֶת ־ חַוֺּ֨ת יָאִ֧יר מֵאִתָּ֛ם אֶת ־ קְנָ֥ת וְאֶת ־ בְּנֹתֶ֖יהָ שִׁשִּׁ֣ים עִ֑יר כָּל ־ אֵ֕לֶּה בְּנֵ֖י מָכִ֥יר אֲבִי ־ גִלְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 2:24",
      "text": "וְאַחַ֥ר מוֹת ־ חֶצְר֖וֹן בְּכָלֵ֣ב אֶפְרָ֑תָה וְאֵ֤שֶׁת חֶצְרוֹן֙ אֲבִיָּ֔ה וַתֵּ֣לֶד ל֔וֹ אֶת ־ אַשְׁח֖וּר אֲבִ֥י תְקֽוֹעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 2:25",
      "text": "וַיִּהְי֧וּ בְנֵי ־ יְרַחְמְאֵ֛ל בְּכ֥וֹר חֶצְר֖וֹן הַבְּכ֣וֹר ׀ רָ֑ם וּבוּנָ֥ה וָאֹ֛רֶן וָאֹ֖צֶם אֲחִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 2:26",
      "text": "וַתְּהִ֨י אִשָּׁ֥ה אַחֶ֛רֶת לִֽירַחְמְאֵ֖ל וּשְׁמָ֣הּ עֲטָרָ֑ה הִ֖יא אֵ֥ם אוֹנָֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 2:27",
      "text": "וַיִּהְי֥וּ בְנֵי ־ רָ֖ם בְּכ֣וֹר יְרַחְמְאֵ֑ל מַ֥עַץ וְיָמִ֖ין וָעֵֽקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 2:28",
      "text": "וַיִּהְי֥וּ בְנֵי ־ אוֹנָ֖ם שַׁמַּ֣י וְיָדָ֑ע וּבְנֵ֣י שַׁמַּ֔י נָדָ֖ב וַאֲבִישֽׁוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 2:29",
      "text": "וְשֵׁ֛ם אֵ֥שֶׁת אֲבִישׁ֖וּר אֲבִיהָ֑יִל וַתֵּ֣לֶד ל֔וֹ אֶת ־ אַחְבָּ֖ן וְאֶת ־ מוֹלִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 2:30",
      "text": "וּבְנֵ֥י נָדָ֖ב סֶ֣לֶד וְאַפָּ֑יִם וַיָּ֥מָת סֶ֖לֶד לֹ֥א בָנִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 2:31",
      "text": "וּבְנֵ֥י אַפַּ֖יִם יִשְׁעִ֑י וּבְנֵ֤י יִשְׁעִי֙ שֵׁשָׁ֔ן וּבְנֵ֥י שֵׁשָׁ֖ן אַחְלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.32",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 2:32",
      "text": "וּבְנֵ֤י יָדָע֙ אֲחִ֣י שַׁמַּ֔י יֶ֖תֶר וְיוֹנָתָ֑ן וַיָּ֥מָת יֶ֖תֶר לֹ֥א בָנִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.33",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 2:33",
      "text": "וּבְנֵ֥י יוֹנָתָ֖ן פֶּ֣לֶת וְזָזָ֑א אֵ֥לֶּה הָי֖וּ בְּנֵ֥י יְרַחְמְאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.34",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 2:34",
      "text": "וְלֹֽא ־ הָיָ֧ה לְשֵׁשָׁ֛ן בָּנִ֖ים כִּ֣י אִם ־ בָּנ֑וֹת וּלְשֵׁשָׁ֛ן עֶ֥בֶד מִצְרִ֖י וּשְׁמ֥וֹ יַרְחָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.35",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 2:35",
      "text": "וַיִּתֵּ֨ן שֵׁשָׁ֧ן אֶת ־ בִּתּ֛וֹ לְיַרְחָ֥ע עַבְדּ֖וֹ לְאִשָּׁ֑ה וַתֵּ֥לֶד ל֖וֹ אֶת ־ עַתָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.2.36",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 2:36",
