{
  "chapter": {
    "id": "wlc:first-chronicles.14",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 14,
    "referenceLabel": "1 Chronicles 14",
    "summary": "Source text for 1 Chronicles 14 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.14.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 14:1",
      "text": "וַ֠יִּשְׁלַח חירם מֶֽלֶךְ ־ צֹ֥ר מַלְאָכִים֮ אֶל ־ דָּוִיד֒ וַעֲצֵ֣י אֲרָזִ֔ים וְחָרָשֵׁ֣י קִ֔יר וְחָרָשֵׁ֖י עֵצִ֑ים לִבְנ֥וֹת ל֖וֹ בָּֽיִת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.14.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 14:2",
      "text": "וַיֵּ֣דַע דָּוִ֔יד כִּֽי ־ הֱכִינ֧וֹ יְהוָ֛ה לְמֶ֖לֶךְ עַל ־ יִשְׂרָאֵ֑ל כִּֽי ־ נִשֵּׂ֤את לְמַ֨עְלָה֙ מַלְכוּת֔וֹ בַּעֲב֖וּר עַמּ֥וֹ יִשְׂרָאֵֽל ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 14:3",
      "text": "וַיִּקַּ֨ח דָּוִ֥יד ע֛וֹד נָשִׁ֖ים בִּירוּשָׁלִָ֑ם וַיּ֧וֹלֶד דָּוִ֛יד ע֖וֹד בָּנִ֥ים וּבָנֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 14:4",
      "text": "וְאֵ֨לֶּה֙ שְׁמ֣וֹת הַיְלוּדִ֔ים אֲשֶׁ֥ר הָיוּ ־ ל֖וֹ בִּירוּשָׁלִָ֑ם שַׁמּ֣וּעַ וְשׁוֹבָ֔ב נָתָ֖ן וּשְׁלֹמֹֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 14:5",
      "text": "וְיִבְחָ֥ר וֶאֱלִישׁ֖וּעַ וְאֶלְפָּֽלֶט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 14:6",
      "text": "וְנֹ֥גַהּ וְנֶ֖פֶג וְיָפִֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 14:7",
      "text": "וֶאֱלִישָׁמָ֥ע וּבְעֶלְיָדָ֖ע וֶאֱלִיפָֽלֶט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 14:8",
      "text": "וַיִּשְׁמְע֣וּ פְלִשְׁתִּ֗ים כִּי ־ נִמְשַׁ֨ח דָּוִ֤יד לְמֶ֨לֶךְ֙ עַל ־ כָּל ־ יִשְׂרָאֵ֔ל וַיַּעֲל֥וּ כָל ־ פְּלִשְׁתִּ֖ים לְבַקֵּ֣שׁ אֶת ־ דָּוִ֑יד וַיִּשְׁמַ֣ע דָּוִ֔יד וַיֵּצֵ֖א לִפְנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 14:9",
      "text": "וּפְלִשְׁתִּ֖ים בָּ֑אוּ וַֽיִּפְשְׁט֖וּ בְּעֵ֥מֶק רְפָאִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 14:10",
      "text": "וַיִּשְׁאַ֨ל דָּוִ֤יד בֵּאלֹהִים֙ לֵאמֹ֔ר הַאֶֽעֱלֶה֙ עַל ־ פלשתיים וּנְתַתָּ֖ם בְּיָדִ֑י וַיֹּ֨אמֶר ל֤וֹ יְהוָה֙ עֲלֵ֔ה וּנְתַתִּ֖ים בְּיָדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 14:11",
      "text": "וַיַּעֲל֥וּ בְּבַֽעַל ־ פְּרָצִים֮ וַיַּכֵּ֣ם שָׁ֣ם דָּוִיד֒ וַיֹּ֣אמֶר דָּוִ֔יד פָּרַ֨ץ הָֽאֱלֹהִ֧ים אֶת ־ אוֹיְבַ֛י בְּיָדִ֖י כְּפֶ֣רֶץ מָ֑יִם עַל ־ כֵּ֗ן קָֽרְא֛וּ שֵֽׁם ־ הַמָּק֥וֹם הַה֖וּא בַּ֥עַל פְּרָצִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 14:12",
      "text": "וַיַּעַזְבוּ ־ שָׁ֖ם אֶת ־ אֱלֹֽהֵיהֶ֑ם וַיֹּ֣אמֶר דָּוִ֔יד וַיִּשָּׂרְפ֖וּ בָּאֵֽשׁ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 14:13",
      "text": "וַיֹּסִ֤יפוּ עוֹד֙ פְּלִשְׁתִּ֔ים וַֽיִּפְשְׁט֖וּ בָּעֵֽמֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 14:14",
      "text": "וַיִּשְׁאַ֨ל ע֤וֹד דָּוִיד֙ בֵּֽאלֹהִ֔ים וַיֹּ֤אמֶר לוֹ֙ הָֽאֱלֹהִ֔ים לֹ֥א תַֽעֲלֶ֖ה אַֽחֲרֵיהֶ֑ם הָסֵב֙ מֵֽעֲלֵיהֶ֔ם וּבָ֥אתָ לָהֶ֖ם מִמּ֥וּל הַבְּכָאִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 14:15",
      "text": "וִ֠יהִי כְּֽשָׁמְעֲךָ֞ אֶת ־ ק֤וֹל הַצְּעָדָה֙ בְּרָאשֵׁ֣י הַבְּכָאִ֔ים אָ֖ז תֵּצֵ֣א בַמִּלְחָמָ֑ה כִּֽי ־ יָצָ֤א הָֽאֱלֹהִים֙ לְפָנֶ֔יךָ לְהַכּ֖וֹת אֶת ־ מַחֲנֵ֥ה פְלִשְׁתִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 14:16",
      "text": "וַיַּ֣עַשׂ דָּוִ֔יד כַּֽאֲשֶׁ֥ר צִוָּ֖הוּ הָֽאֱלֹהִ֑ים וַיַּכּוּ֙ אֶת ־ מַחֲנֵ֣ה פְלִשְׁתִּ֔ים מִגִּבְע֖וֹן וְעַד ־ גָּֽזְרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.14.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 14:17",
      "text": "וַיֵּצֵ֥א שֵׁם ־ דָּוִ֖יד בְּכָל ־ הָֽאֲרָצ֑וֹת וַֽיהוָ֛ה נָתַ֥ן אֶת ־ פַּחְדּ֖וֹ עַל ־ כָּל ־ הַגּוֹיִֽם ׃",
      "paragraphStart": false
    }
  ]
}
