  },
  "verses": [
    {
      "id": "wlc:first-chronicles.5.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 5:1",
      "text": "וּבְנֵ֨י רְאוּבֵ֥ן בְּכֽוֹר ־ יִשְׂרָאֵל֮ כִּ֣י ה֣וּא הַבְּכוֹר֒ וּֽבְחַלְּלוֹ֙ יְצוּעֵ֣י אָבִ֔יו נִתְּנָה֙ בְּכֹ֣רָת֔וֹ לִבְנֵ֥י יוֹסֵ֖ף בֶּן ־ יִשְׂרָאֵ֑ל וְלֹ֥א לְהִתְיַחֵ֖שׂ לַבְּכֹרָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.5.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 5:2",
      "text": "כִּ֤י יְהוּדָה֙ גָּבַ֣ר בְּאֶחָ֔יו וּלְנָגִ֖יד מִמֶּ֑נּוּ וְהַבְּכֹרָ֖ה לְיוֹסֵֽף ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 5:3",
      "text": "בְּנֵ֥י רְאוּבֵ֖ן בְּכ֣וֹר יִשְׂרָאֵ֑ל חֲנ֥וֹךְ וּפַלּ֖וּא חֶצְר֥וֹן וְכַרְמִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 5:4",
      "text": "בְּנֵ֖י יוֹאֵ֑ל שְׁמַֽעְיָ֥ה בְנ֛וֹ גּ֥וֹג בְּנ֖וֹ שִׁמְעִ֥י בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 5:5",
      "text": "מִיכָ֥ה בְנ֛וֹ רְאָיָ֥ה בְנ֖וֹ בַּ֥עַל בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 5:6",
      "text": "בְּאֵרָ֣ה בְנ֔וֹ אֲשֶׁ֣ר הֶגְלָ֔ה תִּלְּגַ֥ת פִּלְנְאֶ֖סֶר מֶ֣לֶךְ אַשֻּׁ֑ר ה֥וּא נָשִׂ֖יא לָרֽאוּבֵנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 5:7",
      "text": "וְאֶחָיו֙ לְמִשְׁפְּחֹתָ֔יו בְּהִתְיַחֵ֖שׂ לְתֹלְדוֹתָ֑ם הָרֹ֥אשׁ יְעִיאֵ֖ל וּזְכַרְיָֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 5:8",
      "text": "וּבֶ֨לַע֙ בֶּן ־ עָזָ֔ז בֶּן ־ שֶׁ֖מַע בֶּן ־ יוֹאֵ֑ל ה֚וּא יוֹשֵׁ֣ב בַּעֲרֹעֵ֔ר וְעַד ־ נְב֖וֹ וּבַ֥עַל מְעֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 5:9",
      "text": "וְלַמִּזְרָ֗ח יָשַׁב֙ עַד ־ לְב֣וֹא מִדְבָּ֔רָה לְמִן ־ הַנָּהָ֖ר פְּרָ֑ת כִּ֧י מִקְנֵיהֶ֛ם רָב֖וּ בְּאֶ֥רֶץ גִּלְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 5:10",
      "text": "וּבִימֵ֣י שָׁא֗וּל עָשׂ֤וּ מִלְחָמָה֙ עִם ־ הַֽהַגְרִאִ֔ים וַֽיִּפְּל֖וּ בְּיָדָ֑ם וַיֵּשְׁבוּ֙ בְּאָ֣הֳלֵיהֶ֔ם עַֽל ־ כָּל ־ פְּנֵ֖י מִזְרָ֥ח לַגִּלְעָֽד ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 5:11",
      "text": "וּבְנֵי ־ גָ֣ד לְנֶגְדָּ֗ם יָֽשְׁב֛וּ בְּאֶ֥רֶץ הַבָּשָׁ֖ן עַד ־ סַלְכָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 5:12",
      "text": "יוֹאֵ֣ל הָרֹ֔אשׁ וְשָׁפָ֖ם הַמִּשְׁנֶ֑ה וְיַעְנַ֥י וְשָׁפָ֖ט בַּבָּשָֽׁן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 5:13",
      "text": "וַאֲחֵיהֶ֞ם לְבֵ֣ית אֲבוֹתֵיהֶ֗ם מִֽיכָאֵ֡ל וּמְשֻׁלָּ֡ם וְ֠שֶׁבַע וְיוֹרַ֧י וְיַעְכָּ֛ן וְזִ֥יעַ וָעֵ֖בֶר שִׁבְעָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 5:14",
      "text": "אֵ֣לֶּה ׀ בְּנֵ֣י אֲבִיחַ֗יִל בֶּן ־ חוּרִ֡י בֶּן ־ יָ֠רוֹחַ בֶּן ־ גִּלְעָ֧ד בֶּן ־ מִיכָאֵ֛ל בֶּן ־ יְשִׁישַׁ֥י בֶּן ־ יַחְדּ֖וֹ בֶּן ־ בּֽוּז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 5:15",
      "text": "אֲחִי֙ בֶּן ־ עַבְדִּיאֵ֣ל בֶּן ־ גּוּנִ֔י רֹ֖אשׁ לְבֵ֥ית אֲבוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 5:16",
      "text": "וַיֵּֽשְׁב֛וּ בַּגִּלְעָ֥ד בַּבָּשָׁ֖ן וּבִבְנֹתֶ֑יהָ וּבְכָֽל ־ מִגְרְשֵׁ֥י שָׁר֖וֹן עַל ־ תּוֹצְאוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 5:17",
      "text": "כֻּלָּם֙ הִתְיַחְשׂ֔וּ בִּימֵ֖י יוֹתָ֣ם מֶֽלֶךְ ־ יְהוּדָ֑ה וּבִימֵ֖י יָרָבְעָ֥ם מֶֽלֶךְ ־ יִשְׂרָאֵֽל ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 5:18",
      "text": "בְּנֵֽי ־ רְאוּבֵ֨ן וְגָדִ֜י וַחֲצִ֥י שֵֽׁבֶט ־ מְנַשֶּׁה֮ מִן ־ בְּנֵי ־ חַיִל֒ אֲ֠נָשִׁים נֹשְׂאֵ֨י מָגֵ֤ן וְחֶ֨רֶב֙ וְדֹ֣רְכֵי קֶ֔שֶׁת וּלְמוּדֵ֖י מִלְחָמָ֑ה אַרְבָּעִ֨ים וְאַרְבָּעָ֥ה אֶ֛לֶף וּשְׁבַע ־ מֵא֥וֹת וְשִׁשִּׁ֖ים יֹצְאֵ֥י צָבָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 5:19",
      "text": "וַיַּעֲשׂ֥וּ מִלְחָמָ֖ה עִם ־ הַֽהַגְרִיאִ֑ים וִיט֥וּר וְנָפִ֖ישׁ וְנוֹדָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 5:20",
      "text": "וַיֵּעָזְר֣וּ עֲלֵיהֶ֔ם וַיִּנָּתְנ֤וּ בְיָדָם֙ הַֽהַגְרִיאִ֔ים וְכֹ֖ל שֶׁ֣עִמָּהֶ֑ם כִּ֠י לֵאלֹהִ֤ים זָעֲקוּ֙ בַּמִּלְחָמָ֔ה וְנַעְתּ֥וֹר לָהֶ֖ם כִּי ־ בָ֥טְחוּ בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 5:21",
      "text": "וַיִּשְׁבּ֣וּ מִקְנֵיהֶ֗ם גְּֽמַלֵּיהֶ֞ם חֲמִשִּׁ֥ים אֶ֨לֶף֙ וְצֹ֗אן מָאתַ֤יִם וַחֲמִשִּׁים֙ אֶ֔לֶף וַחֲמוֹרִ֖ים אַלְפָּ֑יִם וְנֶ֥פֶשׁ אָדָ֖ם מֵ֥אָה אָֽלֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 5:22",
      "text": "כִּֽי ־ חֲלָלִ֤ים רַבִּים֙ נָפָ֔לוּ כִּ֥י מֵהָאֱלֹהִ֖ים הַמִּלְחָמָ֑ה וַיֵּשְׁב֥וּ תַחְתֵּיהֶ֖ם עַד ־ הַגֹּלָֽה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 5:23",
      "text": "וּבְנֵ֗י חֲצִי֙ שֵׁ֣בֶט מְנַשֶּׁ֔ה יָשְׁב֖וּ בָּאָ֑רֶץ מִבָּשָׁ֞ן עַד ־ בַּ֧עַל חֶרְמ֛וֹן וּשְׂנִ֥יר וְהַר ־ חֶרְמ֖וֹן הֵ֥מָּה רָבֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 5:24",
      "text": "וְאֵ֖לֶּה רָאשֵׁ֣י בֵית ־ אֲבוֹתָ֑ם וְעֵ֡פֶר וְיִשְׁעִ֡י וֶאֱלִיאֵ֡ל וְ֠עַזְרִיאֵל וְיִרְמְיָ֨ה וְהוֹדַוְיָ֜ה וְיַחְדִּיאֵ֗ל אֲנָשִׁים֙ גִּבּ֣וֹרֵי חַ֔יִל אַנְשֵׁ֣י שֵׁמ֔וֹת רָאשִׁ֖ים לְבֵ֥ית אֲבוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 5:25",
      "text": "וַיִּֽמְעֲל֔וּ בֵּאלֹהֵ֖י אֲבוֹתֵיהֶ֑ם וַיִּזְנ֗וּ אַחֲרֵי֙ אֱלֹהֵ֣י עַמֵּי ־ הָאָ֔רֶץ אֲשֶׁר ־ הִשְׁמִ֥יד אֱלֹהִ֖ים מִפְּנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 5:26",
      "text": "וַיָּעַר֩ אֱלֹהֵ֨י יִשְׂרָאֵ֜ל אֶת ־ ר֣וּחַ ׀ פּ֣וּל מֶֽלֶךְ ־ אַשּׁ֗וּר וְאֶת ־ ר֨וּחַ֙ תִּלְּגַ֤ת פִּלְנֶ֨סֶר֙ מֶ֣לֶךְ אַשּׁ֔וּר וַיַּגְלֵם֙ לָראוּבֵנִ֣י וְלַגָּדִ֔י וְלַחֲצִ֖י שֵׁ֣בֶט מְנַשֶּׁ֑ה וַ֠יְבִיאֵם לַחְלַ֨ח וְחָב֤וֹר וְהָרָא֙ וּנְהַ֣ר גּוֹזָ֔ן עַ֖ד הַיּ֥וֹם הַזֶּֽה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 5:27",
      "text": "בְּנֵ֖י לֵוִ֑י גֵּרְשׁ֕וֹן קְהָ֖ת וּמְרָרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 5:28",
      "text": "וּבְנֵ֖י קְהָ֑ת עַמְרָ֣ם יִצְהָ֔ר וְחֶבְר֖וֹן וְעֻזִּיאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 5:29",
      "text": "וּבְנֵ֣י עַמְרָ֔ם אַהֲרֹ֥ן וּמֹשֶׁ֖ה וּמִרְיָ֑ם ס וּבְנֵ֣י אַהֲרֹ֔ן נָדָב֙ וַאֲבִיה֔וּא אֶלְעָזָ֖ר וְאִיתָמָֽר ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.5.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 5,
