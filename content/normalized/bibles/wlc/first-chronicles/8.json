{
  "chapter": {
    "id": "wlc:first-chronicles.8",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 8,
    "referenceLabel": "1 Chronicles 8",
    "summary": "Source text for 1 Chronicles 8 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.8.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 8:1",
      "text": "וּבִ֨נְיָמִ֔ן הוֹלִ֖יד אֶת ־ בֶּ֣לַע בְּכֹר֑וֹ אַשְׁבֵּל֙ הַשֵּׁנִ֔י וְאַחְרַ֖ח הַשְּׁלִישִֽׁי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.8.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 8:2",
      "text": "נוֹחָה֙ הָֽרְבִיעִ֔י וְרָפָ֖א הַחֲמִישִֽׁי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 8:3",
      "text": "וַיִּהְי֥וּ בָנִ֖ים לְבָ֑לַע אַדָּ֥ר וְגֵרָ֖א וַאֲבִיהֽוּד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 8:4",
      "text": "וַאֲבִישׁ֥וּעַ וְנַעֲמָ֖ן וַאֲחֽוֹחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 8:5",
      "text": "וְגֵרָ֥א וּשְׁפוּפָ֖ן וְחוּרָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 8:6",
      "text": "וְאֵ֖לֶּה בְּנֵ֣י אֵח֑וּד אֵ֣לֶּה הֵ֞ם רָאשֵׁ֤י אָבוֹת֙ לְי֣וֹשְׁבֵי גֶ֔בַע וַיַּגְל֖וּם אֶל ־ מָנָֽחַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 8:7",
      "text": "וְנַעֲמָ֧ן וַאֲחִיָּ֛ה וְגֵרָ֖א ה֣וּא הֶגְלָ֑ם וְהוֹלִ֥יד אֶת ־ עֻזָּ֖א וְאֶת ־ אֲחִיחֻֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 8:8",
      "text": "וְשַׁחֲרַ֗יִם הוֹלִיד֙ בִּשְׂדֵ֣ה מוֹאָ֔ב מִן ־ שִׁלְח֖וֹ אֹתָ֑ם חוּשִׁ֥ים וְאֶֽת ־ בַּעֲרָ֖א נָשָֽׁיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 8:9",
      "text": "וַיּ֖וֹלֶד מִן ־ חֹ֣דֶשׁ אִשְׁתּ֑וֹ אֶת ־ יוֹבָב֙ וְאֶת ־ צִבְיָ֔א וְאֶת ־ מֵישָׁ֖א וְאֶת ־ מַלְכָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 8:10",
      "text": "וְאֶת ־ יְע֥וּץ וְאֶת ־ שָֽׂכְיָ֖ה וְאֶת ־ מִרְמָ֑ה אֵ֥לֶּה בָנָ֖יו רָאשֵׁ֥י אָבֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 8:11",
      "text": "וּמֵחֻשִׁ֛ים הוֹלִ֥יד אֶת ־ אֲבִיט֖וּב וְאֶת ־ אֶלְפָּֽעַל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 8:12",
      "text": "וּבְנֵ֣י אֶלְפַּ֔עַל עֵ֥בֶר וּמִשְׁעָ֖ם וָשָׁ֑מֶד ה֚וּא בָּנָ֣ה אֶת ־ אוֹנ֔וֹ וְאֶת ־ לֹ֖ד וּבְנֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 8:13",
      "text": "וּבְרִעָ֣ה וָשֶׁ֔מַע הֵ֚מָּה רָאשֵׁ֣י הָאָב֔וֹת לְיוֹשְׁבֵ֖י אַיָּל֑וֹן הֵ֥מָּה הִבְרִ֖יחוּ אֶת ־ י֥וֹשְׁבֵי גַֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 8:14",
      "text": "וְאַחְי֥וֹ שָׁשָׁ֖ק וִירֵמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 8:15",
      "text": "וּזְבַדְיָ֥ה וַעֲרָ֖ד וָעָֽדֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 8:16",
      "text": "וּמִיכָאֵ֧ל וְיִשְׁפָּ֛ה וְיוֹחָ֖א בְּנֵ֥י בְרִיעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 8:17",
      "text": "וּזְבַדְיָ֥ה וּמְשֻׁלָּ֖ם וְחִזְקִ֥י וָחָֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 8:18",
      "text": "וְיִשְׁמְרַ֧י וְיִזְלִיאָ֛ה וְיוֹבָ֖ב בְּנֵ֥י אֶלְפָּֽעַל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 8:19",
      "text": "וְיָקִ֥ים וְזִכְרִ֖י וְזַבְדִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 8:20",
      "text": "וֶאֱלִיעֵנַ֥י וְצִלְּתַ֖י וֶאֱלִיאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 8:21",
      "text": "וַעֲדָיָ֧ה וּבְרָאיָ֛ה וְשִׁמְרָ֖ת בְּנֵ֥י שִׁמְעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 8:22",
      "text": "וְיִשְׁפָּ֥ן וָעֵ֖בֶר וֶאֱלִיאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 8:23",
      "text": "וְעַבְדּ֥וֹן וְזִכְרִ֖י וְחָנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 8:24",
      "text": "וַחֲנַנְיָ֥ה וְעֵילָ֖ם וְעַנְתֹתִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 8:25",
      "text": "וְיִפְדְיָ֥ה ופניאל בְּנֵ֥י שָׁשָֽׁק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 8:26",
      "text": "וְשַׁמְשְׁרַ֥י וּשְׁחַרְיָ֖ה וַעֲתַלְיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 8:27",
      "text": "וְיַעֲרֶשְׁיָ֧ה וְאֵלִיָּ֛ה וְזִכְרִ֖י בְּנֵ֥י יְרֹחָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 8:28",
      "text": "אֵ֣לֶּה רָאשֵׁ֥י אָב֛וֹת לְתֹלְדוֹתָ֖ם רָאשִׁ֑ים אֵ֖לֶּה יָשְׁב֥וּ בִירוּשָׁלִָֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 8:29",
      "text": "וּבְגִבְע֥וֹן יָשְׁב֖וּ אֲבִ֣י גִבְע֑וֹן וְשֵׁ֥ם אִשְׁתּ֖וֹ מַעֲכָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 8:30",
      "text": "וּבְנ֥וֹ הַבְּכ֖וֹר עַבְדּ֑וֹן וְצ֥וּר וְקִ֖ישׁ וּבַ֥עַל וְנָדָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 8:31",
      "text": "וּגְד֥וֹר וְאַחְי֖וֹ וָזָֽכֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.32",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 8:32",
      "text": "וּמִקְל֖וֹת הוֹלִ֣יד אֶת ־ שִׁמְאָ֑ה וְאַף ־ הֵ֗מָּה נֶ֧גֶד אֲחֵיהֶ֛ם יָשְׁב֥וּ בִירוּשָׁלִַ֖ם עִם ־ אֲחֵיהֶֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.33",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 8:33",
      "text": "וְנֵר֙ הוֹלִ֣יד אֶת ־ קִ֔ישׁ וְקִ֖ישׁ הוֹלִ֣יד אֶת ־ שָׁא֑וּל וְשָׁא֗וּל הוֹלִ֤יד אֶת ־ יְהֽוֹנָתָן֙ וְאֶת ־ מַלְכִּי ־ שׁ֔וּעַ וְאֶת ־ אֲבִֽינָדָ֖ב וְאֶת ־ אֶשְׁבָּֽעַל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.34",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 8:34",
      "text": "וּבֶן ־ יְהוֹנָתָ֖ן מְרִ֣יב בָּ֑עַל וּמְרִ֥יב בַּ֖עַל הוֹלִ֥יד אֶת ־ מִיכָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.35",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 8:35",
      "text": "וּבְנֵ֖י מִיכָ֑ה פִּית֥וֹן וָמֶ֖לֶךְ וְתַאְרֵ֥עַ וְאָחָֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.36",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 8:36",
      "text": "וְאָחָז֙ הוֹלִ֣יד אֶת ־ יְהוֹעַדָּ֔ה וִיהֽוֹעַדָּ֗ה הוֹלִ֛יד אֶת ־ עָלֶ֥מֶת וְאֶת ־ עַזְמָ֖וֶת וְאֶת ־ זִמְרִ֑י וְזִמְרִ֖י הוֹלִ֥יד אֶת ־ מוֹצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.37",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 8:37",
      "text": "וּמוֹצָ֖א הוֹלִ֣יד אֶת ־ בִּנְעָ֑א רָפָ֥ה בְנ֛וֹ אֶלְעָשָׂ֥ה בְנ֖וֹ אָצֵ֥ל בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.38",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 8:38",
      "text": "וּלְאָצֵל֮ שִׁשָּׁ֣ה בָנִים֒ וְאֵ֣לֶּה שְׁמוֹתָ֗ם עַזְרִיקָ֥ם ׀ בֹּ֨כְרוּ֙ וְיִשְׁמָעֵ֣אל וּשְׁעַרְיָ֔ה וְעֹבַדְיָ֖ה וְחָנָ֑ן כָּל ־ אֵ֖לֶּה בְּנֵ֥י אָצַֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.39",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 8:39",
      "text": "וּבְנֵ֖י עֵ֣שֶׁק אָחִ֑יו אוּלָ֣ם בְּכֹר֔וֹ יְעוּשׁ֙ הַשֵּׁנִ֔י וֶֽאֱלִיפֶ֖לֶט הַשְּׁלִשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.8.40",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 8:40",
