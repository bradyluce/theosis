{
  "chapter": {
    "id": "wlc:first-chronicles.1",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.1.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "אָדָ֥ם שֵׁ֖ת אֱנֽוֹשׁ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.1.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "קֵינָ֥ן מַהֲלַלְאֵ֖ל יָֽרֶד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "חֲנ֥וֹךְ מְתוּשֶׁ֖לַח לָֽמֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "נֹ֥חַ שֵׁ֖ם חָ֥ם וָיָֽפֶת ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "בְּנֵ֣י יֶ֔פֶת גֹּ֣מֶר וּמָג֔וֹג וּמָדַ֖י וְיָוָ֣ן וְתֻבָ֑ל וּמֶ֖שֶׁךְ וְתִירָֽס ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "וּבְנֵ֖י גֹּ֑מֶר אַשְׁכֲּנַ֥ז וְדִיפַ֖ת וְתוֹגַרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "וּבְנֵ֥י יָוָ֖ן אֱלִישָׁ֣ה וְתַרְשִׁ֑ישָׁה כִּתִּ֖ים וְרוֹדָנִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "בְּנֵ֖י חָ֑ם כּ֥וּשׁ וּמִצְרַ֖יִם פּ֥וּט וּכְנָֽעַן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "וּבְנֵ֣י כ֔וּשׁ סְבָא֙ וַחֲוִילָ֔ה וְסַבְתָּ֥א וְרַעְמָ֖א וְסַבְתְּכָ֑א וּבְנֵ֥י רַעְמָ֖א שְׁבָ֥א וּדְדָֽן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "וְכ֖וּשׁ יָלַ֣ד אֶת ־ נִמְר֑וֹד ה֣וּא הֵחֵ֔ל לִהְי֥וֹת גִּבּ֖וֹר בָּאָֽרֶץ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "וּמִצְרַ֡יִם יָלַ֞ד אֶת ־ לודיים וְאֶת ־ עֲנָמִ֛ים וְאֶת ־ לְהָבִ֖ים וְאֶת ־ נַפְתֻּחִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "וְֽאֶת ־ פַּתְרֻסִ֞ים וְאֶת ־ כַּסְלֻחִ֗ים אֲשֶׁ֨ר יָצְא֥וּ מִשָּׁ֛ם פְּלִשְׁתִּ֖ים וְאֶת ־ כַּפְתֹּרִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "וּכְנַ֗עַן יָלַ֛ד אֶת ־ צִיד֥וֹן בְּכֹר֖וֹ וְאֶת ־ חֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "וְאֶת ־ הַיְבוּסִי֙ וְאֶת ־ הָ֣אֱמֹרִ֔י וְאֵ֖ת הַגִּרְגָּשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "וְאֶת ־ הַחִוִּ֥י וְאֶת ־ הַֽעַרְקִ֖י וְאֶת ־ הַסִּינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "וְאֶת ־ הָאַרְוָדִ֥י וְאֶת ־ הַצְּמָרִ֖י וְאֶת ־ הַֽחֲמָתִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "בְּנֵ֣י שֵׁ֔ם עֵילָ֣ם וְאַשּׁ֔וּר וְאַרְפַּכְשַׁ֖ד וְל֣וּד וַאֲרָ֑ם וְע֥וּץ וְח֖וּל וְגֶ֥תֶר וָמֶֽשֶׁךְ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "וְאַרְפַּכְשַׁ֖ד יָלַ֣ד אֶת ־ שָׁ֑לַח וְשֶׁ֖לַח יָלַ֥ד אֶת ־ עֵֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "וּלְעֵ֥בֶר יֻלַּ֖ד שְׁנֵ֣י בָנִ֑ים שֵׁ֣ם הָאֶחָ֞ד פֶּ֗לֶג כִּ֤י בְיָמָיו֙ נִפְלְגָ֣ה הָאָ֔רֶץ וְשֵׁ֥ם אָחִ֖יו יָקְטָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "וְיָקְטָ֣ן יָלַ֔ד אֶת ־ אַלְמוֹדָ֖ד וְאֶת ־ שָׁ֑לֶף וְאֶת ־ חֲצַרְמָ֖וֶת וְאֶת ־ יָֽרַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "וְאֶת ־ הֲדוֹרָ֥ם וְאֶת ־ אוּזָ֖ל וְאֶת ־ דִּקְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "וְאֶת ־ עֵיבָ֥ל וְאֶת ־ אֲבִימָאֵ֖ל וְאֶת ־ שְׁבָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "וְאֶת ־ אוֹפִ֥יר וְאֶת ־ חֲוִילָ֖ה וְאֶת ־ יוֹבָ֑ב כָּל ־ אֵ֖לֶּה בְּנֵ֥י יָקְטָֽן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "שֵׁ֥ם ׀ אַרְפַּכְשַׁ֖ד שָֽׁלַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "עֵ֥בֶר פֶּ֖לֶג רְעֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "שְׂר֥וּג נָח֖וֹר תָּֽרַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "אַבְרָ֖ם ה֥וּא אַבְרָהָֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "בְּנֵי֙ אַבְרָהָ֔ם יִצְחָ֖ק וְיִשְׁמָעֵֽאל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "אֵ֖לֶּה תֹּלְדוֹתָ֑ם בְּכ֤וֹר יִשְׁמָעֵאל֙ נְבָי֔וֹת וְקֵדָ֥ר וְאַדְבְּאֵ֖ל וּמִבְשָֽׂם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "מִשְׁמָ֣ע וְדוּמָ֔ה מַשָּׂ֖א חֲדַ֥ד וְתֵימָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "יְט֥וּר נָפִ֖ישׁ וָקֵ֑דְמָה אֵ֥לֶּה הֵ֖ם בְּנֵ֥י יִשְׁמָעֵֽאל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.32",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "וּבְנֵ֨י קְטוּרָ֜ה פִּילֶ֣גֶשׁ אַבְרָהָ֗ם יָלְדָ֞ה אֶת ־ זִמְרָ֧ן וְיָקְשָׁ֛ן וּמְדָ֥ן וּמִדְיָ֖ן וְיִשְׁבָּ֣ק וְשׁ֑וּחַ וּבְנֵ֥י יָקְשָׁ֖ן שְׁבָ֥א וּדְדָֽן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.33",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "וּבְנֵ֣י מִדְיָ֗ן עֵיפָ֤ה וָעֵ֨פֶר֙ וַחֲנ֔וֹךְ וַאֲבִידָ֖ע וְאֶלְדָּעָ֑ה כָּל ־ אֵ֖לֶּה בְּנֵ֥י קְטוּרָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.34",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "וַיּ֥וֹלֶד אַבְרָהָ֖ם אֶת ־ יִצְחָ֑ק ס בְּנֵ֣י יִצְחָ֔ק עֵשָׂ֖ו וְיִשְׂרָאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.35",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "בְּנֵ֖י עֵשָׂ֑ו אֱלִיפַ֛ז רְעוּאֵ֥ל וִיע֖וּשׁ וְיַעְלָ֥ם וְקֹֽרַח ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.36",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "בְּנֵ֖י אֱלִיפָ֑ז תֵּימָ֤ן וְאוֹמָר֙ צְפִ֣י וְגַעְתָּ֔ם קְנַ֖ז וְתִמְנָ֥ע וַעֲמָלֵֽק ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.37",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "בְּנֵ֖י רְעוּאֵ֑ל נַ֥חַת זֶ֖רַח שַׁמָּ֥ה וּמִזָּֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.38",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "וּבְנֵ֣י שֵׂעִ֔יר לוֹטָ֥ן וְשׁוֹבָ֖ל וְצִבְע֣וֹן וַֽעֲנָ֑ה וְדִישֹׁ֥ן וְאֵ֖צֶר וְדִישָֽׁן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.39",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "וּבְנֵ֥י לוֹטָ֖ן חֹרִ֣י וְהוֹמָ֑ם וַאֲח֥וֹת לוֹטָ֖ן תִּמְנָֽע ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.40",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "בְּנֵ֣י שׁוֹבָ֔ל עַלְיָ֧ן וּמָנַ֛חַת וְעֵיבָ֖ל שְׁפִ֣י וְאוֹנָ֑ם ס וּבְנֵ֥י צִבְע֖וֹן אַיָּ֥ה וַעֲנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.1.41",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
