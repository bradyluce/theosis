    },
    {
      "id": "wlc:first-chronicles.25.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 25:28",
      "text": "לְאֶחָ֤ד וְעֶשְׂרִים֙ לְהוֹתִ֔יר בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 25:29",
      "text": "לִשְׁנַ֤יִם וְעֶשְׂרִים֙ לְגִדַּ֔לְתִּי בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
