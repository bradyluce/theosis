    "summary": "Source text for 1 Chronicles 25 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.25.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 25:1",
      "text": "וַיַּבְדֵּ֣ל דָּוִיד֩ וְשָׂרֵ֨י הַצָּבָ֜א לַעֲבֹדָ֗ה לִבְנֵ֤י אָסָף֙ וְהֵימָ֣ן וִֽידוּת֔וּן הנביאים בְּכִנֹּר֥וֹת בִּנְבָלִ֖ים וּבִמְצִלְתָּ֑יִם וַֽיְהִי֙ מִסְפָּרָ֔ם אַנְשֵׁ֥י מְלָאכָ֖ה לַעֲבֹדָתָֽם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.25.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 25:2",
      "text": "לִבְנֵ֣י אָסָ֗ף זַכּ֧וּר וְיוֹסֵ֛ף וּנְתַנְיָ֥ה וַאֲשַׂרְאֵ֖לָה בְּנֵ֣י אָסָ֑ף עַ֚ל יַד ־ אָסָ֔ף הַנִּבָּ֖א עַל ־ יְדֵ֥י הַמֶּֽלֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 25:3",
      "text": "לִידוּת֑וּן בְּנֵ֣י יְדוּת֡וּן גְּדַלְיָ֡הוּ וּצְרִ֡י וִֽ֠ישַׁעְיָהוּ חֲשַׁבְיָ֨הוּ וּמַתִּתְיָ֜הוּ שִׁשָּׁ֗ה עַל֩ יְדֵ֨י אֲבִיהֶ֤ם יְדוּתוּן֙ בַּכִּנּ֔וֹר הַנִּבָּ֕א עַל ־ הֹד֥וֹת וְהַלֵּ֖ל לַיהוָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 25:4",
      "text": "לְהֵימָ֑ן בְּנֵ֣י הֵימָ֡ן בֻּקִּיָּ֡הוּ מַתַּנְיָ֡הוּ עֻ֠זִּיאֵל שְׁבוּאֵ֨ל וִֽירִימ֜וֹת חֲנַנְיָ֣ה חֲנָ֗נִי אֱלִיאָ֤תָה גִדַּ֨לְתִּי֙ וְרֹמַ֣מְתִּי עֶ֔זֶר יָשְׁבְּקָ֣שָׁה מַלּ֔וֹתִי הוֹתִ֖יר מַחֲזִיאֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 25:5",
      "text": "כָּל ־ אֵ֨לֶּה בָנִ֜ים לְהֵימָ֗ן חֹזֵ֥ה הַמֶּ֛לֶךְ בְּדִבְרֵ֥י הָאֱלֹהִ֖ים לְהָרִ֣ים קָ֑רֶן וַיִּתֵּ֨ן הָאֱלֹהִ֜ים לְהֵימָ֗ן בָּנִ֛ים אַרְבָּעָ֥ה עָשָׂ֖ר וּבָנ֥וֹת שָׁלֽוֹשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 25:6",
      "text": "כָּל ־ אֵ֣לֶּה עַל ־ יְדֵי֩ אֲבִיהֶ֨ם בַּשִּׁ֜יר בֵּ֣ית יְהוָ֗ה בִּמְצִלְתַּ֨יִם֙ נְבָלִ֣ים וְכִנֹּר֔וֹת לַעֲבֹדַ֖ת בֵּ֣ית הָאֱלֹהִ֑ים עַ֚ל יְדֵ֣י הַמֶּ֔לֶךְ ס אָסָ֥ף וִידוּת֖וּן וְהֵימָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 25:7",
      "text": "וַיְהִ֤י מִסְפָּרָם֙ עִם ־ אֲחֵיהֶ֔ם מְלֻמְּדֵי ־ שִׁ֖יר לַיהוָ֑ה כָּל ־ הַ֨מֵּבִ֔ין מָאתַ֖יִם שְׁמוֹנִ֥ים וּשְׁמוֹנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 25:8",
      "text": "וַיַּפִּ֜ילוּ גּוֹרָל֣וֹת מִשְׁמֶ֗רֶת לְעֻמַּת֙ כַּקָּטֹ֣ן כַּגָּד֔וֹל מֵבִ֖ין עִם ־ תַּלְמִֽיד ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 25:9",
      "text": "וַיֵּצֵ֞א הַגּוֹרָ֧ל הָרִאשׁ֛וֹן לְאָסָ֖ף לְיוֹסֵ֑ף גְּדַלְיָ֨הוּ֙ הַשֵּׁנִ֔י הֽוּא ־ וְאֶחָ֥יו וּבָנָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 25:10",
      "text": "הַשְּׁלִשִׁ֣י זַכּ֔וּר בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 25:11",
      "text": "הָרְבִיעִי֙ לַיִּצְרִ֔י בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 25:12",
      "text": "הַחֲמִישִׁ֣י נְתַנְיָ֔הוּ בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 25:13",
      "text": "הַשִּׁשִּׁ֣י בֻקִּיָּ֔הוּ בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 25:14",
      "text": "הַשְּׁבִעִ֣י יְשַׂרְאֵ֔לָה בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 25:15",
      "text": "הַשְּׁמִינִ֣י יְשַֽׁעְיָ֔הוּ בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 25:16",
      "text": "הַתְּשִׁיעִ֣י מַתַּנְיָ֔הוּ בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 25:17",
      "text": "הָעֲשִׂירִ֣י שִׁמְעִ֔י בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 25:18",
      "text": "עַשְׁתֵּֽי ־ עָשָׂ֣ר עֲזַרְאֵ֔ל בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 25:19",
      "text": "הַשְּׁנֵ֤ים עָשָׂר֙ לַחֲשַׁבְיָ֔ה בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 25:20",
      "text": "לִשְׁלֹשָׁ֤ה עָשָׂר֙ שֽׁוּבָאֵ֔ל בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 25:21",
      "text": "לְאַרְבָּעָ֤ה עָשָׂר֙ מַתִּתְיָ֔הוּ בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 25:22",
      "text": "לַחֲמִשָּׁ֤ה עָשָׂר֙ לִֽירֵמ֔וֹת בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 25:23",
      "text": "לְשִׁשָּׁ֤ה עָשָׂר֙ לַחֲנַנְיָ֔הוּ בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 25:24",
      "text": "לְשִׁבְעָ֤ה עָשָׂר֙ לְיָשְׁבְּקָ֔שָׁה בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 25:25",
      "text": "לִשְׁמוֹנָ֤ה עָשָׂר֙ לַחֲנָ֔נִי בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 25:26",
      "text": "לְתִשְׁעָ֤ה עָשָׂר֙ לְמַלּ֔וֹתִי בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.25.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 25:27",
      "text": "לְעֶשְׂרִים֙ לֶֽאֱלִיָּ֔תָה בָּנָ֥יו וְאֶחָ֖יו שְׁנֵ֥ים עָשָֽׂר ׃",
