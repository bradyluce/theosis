{
  "chapter": {
    "id": "wlc:first-chronicles.24",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 24,
    "referenceLabel": "1 Chronicles 24",
    "summary": "Source text for 1 Chronicles 24 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.24.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 24:1",
      "text": "וְלִבְנֵ֥י אַהֲרֹ֖ן מַחְלְקוֹתָ֑ם בְּנֵ֣י אַהֲרֹ֔ן נָדָב֙ וַאֲבִיה֔וּא אֶלְעָזָ֖ר וְאִיתָמָֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.24.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 24:2",
      "text": "וַיָּ֨מָת נָדָ֤ב וַאֲבִיהוּא֙ לִפְנֵ֣י אֲבִיהֶ֔ם וּבָנִ֖ים לֹא ־ הָי֣וּ לָהֶ֑ם וַֽיְכַהֲנ֔וּ אֶלְעָזָ֖ר וְאִיתָמָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 24:3",
      "text": "וַיֶּֽחָלְקֵ֣ם דָּוִ֔יד וְצָדוֹק֙ מִן ־ בְּנֵ֣י אֶלְעָזָ֔ר וַאֲחִימֶ֖לֶךְ מִן ־ בְּנֵ֣י אִיתָמָ֑ר לִפְקֻדָּתָ֖ם בַּעֲבֹדָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 24:4",
      "text": "וַיִּמָּצְא֣וּ בְֽנֵי ־ אֶלְעָזָ֡ר רַבִּ֞ים לְרָאשֵׁ֧י הַגְּבָרִ֛ים מִן ־ בְּנֵ֥י אִיתָמָ֖ר וַֽיַּחְלְק֑וּם לִבְנֵ֨י אֶלְעָזָ֜ר רָאשִׁ֤ים לְבֵית ־ אָבוֹת֙ שִׁשָּׁ֣ה עָשָׂ֔ר וְלִבְנֵ֧י אִיתָמָ֛ר לְבֵ֥ית אֲבוֹתָ֖ם שְׁמוֹנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 24:5",
      "text": "וַיַּחְלְק֥וּם בְּגוֹרָל֖וֹת אֵ֣לֶּה עִם ־ אֵ֑לֶּה כִּי ־ הָי֤וּ שָֽׂרֵי ־ קֹ֨דֶשׁ֙ וְשָׂרֵ֣י הָאֱלֹהִ֔ים מִבְּנֵ֥י אֶלְעָזָ֖ר וּבִבְנֵ֥י אִיתָמָֽר ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 24:6",
      "text": "וַֽיִּכְתְּבֵ֡ם שְֽׁמַֽעְיָה֩ בֶן ־ נְתַנְאֵ֨ל הַסּוֹפֵ֜ר מִן ־ הַלֵּוִ֗י לִפְנֵ֨י הַמֶּ֤לֶךְ וְהַשָּׂרִים֙ וְצָד֣וֹק הַכֹּהֵ֗ן וַאֲחִימֶ֨לֶךְ֙ בֶּן ־ אֶבְיָתָ֔ר וְרָאשֵׁי֙ הָֽאָב֔וֹת לַכֹּהֲנִ֖ים וְלַלְוִיִּ֑ם בֵּֽית ־ אָ֣ב אֶחָ֗ד אָחֻז֙ לְאֶלְעָזָ֔ר וְאָחֻ֥ז ׀ אָחֻ֖ז לְאִיתָמָֽר ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 24:7",
      "text": "וַיֵּצֵ֞א הַגּוֹרָ֤ל הָרִאשׁוֹן֙ לִיה֣וֹיָרִ֔יב לִֽידַעְיָ֖ה הַשֵּׁנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 24:8",
      "text": "לְחָרִם֙ הַשְּׁלִישִׁ֔י לִשְׂעֹרִ֖ים הָרְבִעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 24:9",
      "text": "לְמַלְכִּיָּה֙ הַחֲמִישִׁ֔י לְמִיָּמִ֖ן הַשִּׁשִּֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 24:10",
      "text": "לְהַקּוֹץ֙ הַשְּׁבִעִ֔י לַאֲבִיָּ֖ה הַשְּׁמִינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 24:11",
      "text": "לְיֵשׁ֨וּעַ֙ הַתְּשִׁעִ֔י לִשְׁכַנְיָ֖הוּ הָעֲשִׂרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 24:12",
      "text": "לְאֶלְיָשִׁיב֙ עַשְׁתֵּ֣י עָשָׂ֔ר לְיָקִ֖ים שְׁנֵ֥ים עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 24:13",
      "text": "לְחֻפָּה֙ שְׁלֹשָׁ֣ה עָשָׂ֔ר לְיֶֽשֶׁבְאָ֖ב אַרְבָּעָ֥ה עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 24:14",
      "text": "לְבִלְגָּה֙ חֲמִשָּׁ֣ה עָשָׂ֔ר לְאִמֵּ֖ר שִׁשָּׁ֥ה עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 24:15",
      "text": "לְחֵזִיר֙ שִׁבְעָ֣ה עָשָׂ֔ר לְהַפִּצֵּ֖ץ שְׁמוֹנָ֥ה עָשָֽׂר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 24:16",
      "text": "לִֽפְתַחְיָה֙ תִּשְׁעָ֣ה עָשָׂ֔ר לִֽיחֶזְקֵ֖אל הָעֶשְׂרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 24:17",
      "text": "לְיָכִין֙ אֶחָ֣ד וְעֶשְׂרִ֔ים לְגָמ֖וּל שְׁנַ֥יִם וְעֶשְׂרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 24:18",
      "text": "לִדְלָיָ֨הוּ֙ שְׁלֹשָׁ֣ה וְעֶשְׂרִ֔ים לְמַֽעַזְיָ֖הוּ אַרְבָּעָ֥ה וְעֶשְׂרִֽים ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 24:19",
      "text": "אֵ֣לֶּה פְקֻדָּתָ֞ם לַעֲבֹדָתָ֗ם לָב֤וֹא לְבֵית ־ יְהוָה֙ כְּמִשְׁפָּטָ֔ם בְּיַ֖ד אַהֲרֹ֣ן אֲבִיהֶ֑ם כַּאֲשֶׁ֣ר צִוָּ֔הוּ יְהוָ֖ה אֱלֹהֵ֥י יִשְׂרָאֵֽל ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 24:20",
      "text": "וְלִבְנֵ֥י לֵוִ֖י הַנּוֹתָרִ֑ים לִבְנֵ֤י עַמְרָם֙ שֽׁוּבָאֵ֔ל לִבְנֵ֥י שׁוּבָאֵ֖ל יֶחְדְּיָֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 24:21",
      "text": "לִרְחַבְיָ֑הוּ לִבְנֵ֣י רְחַבְיָ֔הוּ הָרֹ֖אשׁ יִשִּׁיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 24:22",
      "text": "לַיִּצְהָרִ֣י שְׁלֹמ֔וֹת לִבְנֵ֥י שְׁלֹמ֖וֹת יָֽחַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 24:23",
      "text": "וּבְנָ֖י יְרִיָּ֑הוּ אֲמַרְיָ֨הוּ֙ הַשֵּׁנִ֔י יַחֲזִיאֵל֙ הַשְּׁלִישִׁ֔י יְקַמְעָ֖ם הָרְבִיעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 24:24",
      "text": "בְּנֵ֤י עֻזִּיאֵל֙ מִיכָ֔ה לִבְנֵ֥י מִיכָ֖ה שמור ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 24:25",
      "text": "אֲחִ֤י מִיכָה֙ יִשִּׁיָּ֔ה לִבְנֵ֥י יִשִּׁיָּ֖ה זְכַרְיָֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 24:26",
      "text": "בְּנֵ֤י מְרָרִי֙ מַחְלִ֣י וּמוּשִׁ֔י בְּנֵ֖י יַעֲזִיָּ֥הֽוּ בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 24:27",
      "text": "בְּנֵ֖י מְרָרִ֑י לְיַֽעֲזִיָּ֣הֽוּ בְנ֔וֹ וְשֹׁ֥הַם וְזַכּ֖וּר וְעִבְרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 24:28",
      "text": "לְמַחְלִי֙ אֶלְעָזָ֔ר וְלֹא ־ הָ֥יָה ל֖וֹ בָּנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 24:29",
      "text": "לְקִ֖ישׁ בְּנֵי ־ קִ֥ישׁ יְרַחְמְאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 24:30",
      "text": "וּבְנֵ֣י מוּשִׁ֔י מַחְלִ֥י וְעֵ֖דֶר וִירִימ֑וֹת אֵ֛לֶּה בְּנֵ֥י הַלְוִיִּ֖ם לְבֵ֥ית אֲבֹתֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.24.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 24:31",
      "text": "וַיַּפִּילוּ֩ גַם ־ הֵ֨ם גּוֹרָל֜וֹת לְעֻמַּ֣ת ׀ אֲחֵיהֶ֣ם בְּנֵֽי ־ אַהֲרֹ֗ן לִפְנֵ֨י דָוִ֤יד הַמֶּ֨לֶךְ֙ וְצָד֣וֹק וַאֲחִימֶ֔לֶךְ וְרָאשֵׁי֙ הָֽאָב֔וֹת לַכֹּהֲנִ֖ים וְלַלְוִיִּ֑ם אָב֣וֹת הָרֹ֔אשׁ לְעֻמַּ֖ת אָחִ֥יו הַקָּטָֽן ׃ ס",
      "paragraphStart": false
    }
  ]
}
