{
  "chapter": {
    "id": "wlc:first-chronicles.3",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 3,
    "referenceLabel": "1 Chronicles 3",
    "summary": "Source text for 1 Chronicles 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.3.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 3:1",
      "text": "וְאֵ֤לֶּה הָיוּ֙ בְּנֵ֣י דָויִ֔ד אֲשֶׁ֥ר נֽוֹלַד ־ ל֖וֹ בְּחֶבְר֑וֹן הַבְּכ֣וֹר ׀ אַמְנֹ֗ן לַאֲחִינֹ֨עַם֙ הַיִּזְרְעֵאלִ֔ית שֵׁנִי֙ דָּנִיֵּ֔אל לַאֲבִיגַ֖יִל הַֽכַּרְמְלִֽית ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.3.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 3:2",
      "text": "הַשְּׁלִשִׁי֙ לְאַבְשָׁל֣וֹם בֶּֽן ־ מַעֲכָ֔ה בַּת ־ תַּלְמַ֖י מֶ֣לֶךְ גְּשׁ֑וּר הָרְבִיעִ֖י אֲדֹנִיָּ֥ה בֶן ־ חַגִּֽית ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 3:3",
      "text": "הַחֲמִישִׁ֥י שְׁפַטְיָ֖ה לַאֲבִיטָ֑ל הַשִּׁשִּׁ֥י יִתְרְעָ֖ם לְעֶגְלָ֥ה אִשְׁתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 3:4",
      "text": "שִׁשָּׁה֙ נֽוֹלַד ־ ל֣וֹ בְחֶבְר֔וֹן וַיִּ֨מְלָךְ ־ שָׁ֔ם שֶׁ֥בַע שָׁנִ֖ים וְשִׁשָּׁ֣ה חֳדָשִׁ֑ים וּשְׁלֹשִׁ֤ים וְשָׁלוֹשׁ֙ שָׁנָ֔ה מָלַ֖ךְ בִּירוּשָׁלִָֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 3:5",
      "text": "וְאֵ֥לֶּה נוּלְּדוּ ־ ל֖וֹ בִּירוּשָׁלָ֑יִם שִׁ֠מְעָא וְשׁוֹבָ֞ב וְנָתָ֤ן וּשְׁלֹמֹה֙ אַרְבָּעָ֔ה לְבַת ־ שׁ֖וּעַ בַּת ־ עַמִּיאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 3:6",
      "text": "וְיִבְחָ֥ר וֶאֱלִישָׁמָ֖ע וֶאֱלִיפָֽלֶט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 3:7",
      "text": "וְנֹ֥גַהּ וְנֶ֖פֶג וְיָפִֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 3:8",
      "text": "וֶאֱלִישָׁמָ֧ע וְאֶלְיָדָ֛ע וֶאֱלִיפֶ֖לֶט תִּשְׁעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 3:9",
      "text": "כֹּ֖ל בְּנֵ֣י דָוִ֑יד מִלְּבַ֥ד בְּֽנֵי ־ פִֽילַגְשִׁ֖ים וְתָמָ֥ר אֲחוֹתָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 3:10",
      "text": "וּבֶן ־ שְׁלֹמֹ֖ה רְחַבְעָ֑ם אֲבִיָּ֥ה בְנ֛וֹ אָסָ֥א בְנ֖וֹ יְהוֹשָׁפָ֥ט בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 3:11",
      "text": "יוֹרָ֥ם בְּנ֛וֹ אֲחַזְיָ֥הוּ בְנ֖וֹ יוֹאָ֥שׁ בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 3:12",
      "text": "אֲמַצְיָ֧הוּ בְנ֛וֹ עֲזַרְיָ֥ה בְנ֖וֹ יוֹתָ֥ם בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 3:13",
      "text": "אָחָ֥ז בְּנ֛וֹ חִזְקִיָּ֥הוּ בְנ֖וֹ מְנַשֶּׁ֥ה בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 3:14",
      "text": "אָמ֥וֹן בְּנ֖וֹ יֹאשִׁיָּ֥הוּ בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 3:15",
      "text": "וּבְנֵי֙ יֹאשִׁיָּ֔הוּ הַבְּכוֹר֙ יוֹחָנָ֔ן הַשֵּׁנִ֖י יְהוֹיָקִ֑ים הַשְּׁלִשִׁי֙ צִדְקִיָּ֔הוּ הָרְבִיעִ֖י שַׁלּֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 3:16",
      "text": "וּבְנֵ֖י יְהוֹיָקִ֑ים יְכָנְיָ֥ה בְנ֖וֹ צִדְקִיָּ֥ה בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 3:17",
      "text": "וּבְנֵי֙ יְכָנְיָ֣ה אַסִּ֔ר שְׁאַלְתִּיאֵ֖ל בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 3:18",
      "text": "וּמַלְכִּירָ֥ם וּפְדָיָ֖ה וְשֶׁנְאַצַּ֑ר יְקַמְיָ֥ה הוֹשָׁמָ֖ע וּנְדַבְיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 3:19",
      "text": "וּבְנֵ֣י פְדָיָ֔ה זְרֻבָּבֶ֖ל וְשִׁמְעִ֑י וּבֶן ־ זְרֻבָּבֶל֙ מְשֻׁלָּ֣ם וַחֲנַנְיָ֔ה וּשְׁלֹמִ֖ית אֲחוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 3:20",
      "text": "וַחֲשֻׁבָ֡ה וָ֠אֹהֶל וּבֶרֶכְיָ֧ה וַֽחֲסַדְיָ֛ה י֥וּשַׁב חֶ֖סֶד חָמֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 3:21",
      "text": "וּבֶן ־ חֲנַנְיָ֖ה פְּלַטְיָ֣ה וִישַֽׁעְיָ֑ה בְּנֵ֤י רְפָיָה֙ בְּנֵ֣י אַרְנָ֔ן בְּנֵ֥י עֹבַדְיָ֖ה בְּנֵ֥י שְׁכַנְיָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 3:22",
      "text": "וּבְנֵ֥י שְׁכַנְיָ֖ה שְׁמַעְיָ֑ה וּבְנֵ֣י שְׁמַעְיָ֗ה חַטּ֡וּשׁ וְ֠יִגְאָל וּבָרִ֧יחַ וּנְעַרְיָ֛ה וְשָׁפָ֖ט שִׁשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 3:23",
      "text": "וּבֶן ־ נְעַרְיָ֗ה אֶלְיוֹעֵינַ֧י וְחִזְקִיָּ֛ה וְעַזְרִיקָ֖ם שְׁלֹשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.3.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 3:24",
      "text": "וּבְנֵ֣י אֶלְיוֹעֵינַ֗י הדיוהו וְאֶלְיָשִׁ֡יב וּפְלָיָ֡ה וְ֠עַקּוּב וְיוֹחָנָ֧ן וּדְלָיָ֛ה וַעֲנָ֖נִי שִׁבְעָֽה ׃ ס",
      "paragraphStart": false
    }
  ]
}
