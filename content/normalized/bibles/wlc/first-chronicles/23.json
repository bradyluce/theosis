{
  "chapter": {
    "id": "wlc:first-chronicles.23",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 23,
    "referenceLabel": "1 Chronicles 23",
    "summary": "Source text for 1 Chronicles 23 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.23.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 23:1",
      "text": "וְדָוִ֥יד זָקֵ֖ן וְשָׂבַ֣ע יָמִ֑ים וַיַּמְלֵ֛ךְ אֶת ־ שְׁלֹמֹ֥ה בְנ֖וֹ עַל ־ יִשְׂרָאֵֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.23.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 23:2",
      "text": "וַיֶּאֱסֹף֙ אֶת ־ כָּל ־ שָׂרֵ֣י יִשְׂרָאֵ֔ל וְהַכֹּהֲנִ֖ים וְהַלְוִיִּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 23:3",
      "text": "וַיִּסָּֽפְרוּ֙ הַלְוִיִּ֔ם מִבֶּ֛ן שְׁלֹשִׁ֥ים שָׁנָ֖ה וָמָ֑עְלָה וַיְהִ֨י מִסְפָּרָ֤ם לְגֻלְגְּלֹתָם֙ לִגְבָרִ֔ים שְׁלֹשִׁ֥ים וּשְׁמוֹנָ֖ה אָֽלֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 23:4",
      "text": "מֵאֵ֗לֶּה לְנַצֵּ֨חַ֙ עַל ־ מְלֶ֣אכֶת בֵּית ־ יְהוָ֔ה עֶשְׂרִ֥ים וְאַרְבָּעָ֖ה אָ֑לֶף וְשֹׁטְרִ֥ים וְשֹׁפְטִ֖ים שֵׁ֥שֶׁת אֲלָפִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 23:5",
      "text": "וְאַרְבַּ֥עַת אֲלָפִ֖ים שֹׁעֲרִ֑ים וְאַרְבַּ֤עַת אֲלָפִים֙ מְהַֽלְלִ֣ים לַיהוָ֔ה בַּכֵּלִ֕ים אֲשֶׁ֥ר עָשִׂ֖יתִי לְהַלֵּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 23:6",
      "text": "וַיֶּֽחָלְקֵ֥ם דָּוִ֖יד מַחְלְק֑וֹת ס לִבְנֵ֣י לֵוִ֔י לְגֵרְשׁ֖וֹן קְהָ֥ת וּמְרָרִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 23:7",
      "text": "לַגֵּרְשֻׁנִּ֖י לַעְדָּ֥ן וְשִׁמְעִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 23:8",
      "text": "בְּנֵ֣י לַעְדָּ֗ן הָרֹ֧אשׁ יְחִיאֵ֛ל וְזֵתָ֥ם וְיוֹאֵ֖ל שְׁלֹשָֽׁה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 23:9",
      "text": "בְּנֵ֣י שִׁמְעִ֗י שלמות וַחֲזִיאֵ֛ל וְהָרָ֖ן שְׁלֹשָׁ֑ה אֵ֛לֶּה רָאשֵׁ֥י הָאָב֖וֹת לְלַעְדָּֽן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 23:10",
      "text": "וּבְנֵ֣י שִׁמְעִ֔י יַ֣חַת זִינָ֔א וִיע֖וּשׁ וּבְרִיעָ֑ה אֵ֥לֶּה בְנֵי ־ שִׁמְעִ֖י אַרְבָּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 23:11",
      "text": "וַֽיְהִי ־ יַ֣חַת הָרֹ֔אשׁ וְזִיזָ֖ה הַשֵּׁנִ֑י וִיע֤וּשׁ וּבְרִיעָה֙ לֹֽא ־ הִרְבּ֣וּ בָנִ֔ים וַיִּֽהְיוּ֙ לְבֵ֣ית אָ֔ב לִפְקֻדָּ֖ה אֶחָֽת ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 23:12",
      "text": "בְּנֵ֣י קְהָ֗ת עַמְרָ֥ם יִצְהָ֛ר חֶבְר֥וֹן וְעֻזִּיאֵ֖ל אַרְבָּעָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 23:13",
      "text": "בְּנֵ֥י עַמְרָ֖ם אַהֲרֹ֣ן וּמֹשֶׁ֑ה וַיִּבָּדֵ֣ל אַהֲרֹ֡ן לְֽהַקְדִּישׁוֹ֩ קֹ֨דֶשׁ קָֽדָשִׁ֤ים הֽוּא ־ וּבָנָיו֙ עַד ־ עוֹלָ֔ם לְהַקְטִיר֩ לִפְנֵ֨י יְהוָ֧ה לְשָׁרְת֛וֹ וּלְבָרֵ֥ךְ בִּשְׁמ֖וֹ עַד ־ עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 23:14",
      "text": "וּמֹשֶׁ֖ה אִ֣ישׁ הָאֱלֹהִ֑ים בָּנָ֕יו יִקָּרְא֖וּ עַל ־ שֵׁ֥בֶט הַלֵּוִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 23:15",
      "text": "בְּנֵ֣י מֹשֶׁ֔ה גֵּרְשֹׁ֖ם וֶאֱלִיעֶֽזֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 23:16",
      "text": "בְּנֵ֥י גֵרְשׁ֖וֹם שְׁבוּאֵ֥ל הָרֹֽאשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 23:17",
      "text": "וַיִּֽהְי֥וּ בְנֵי ־ אֱלִיעֶ֖זֶר רְחַבְיָ֣ה הָרֹ֑אשׁ וְלֹא ־ הָיָ֤ה לֶאֱלִיעֶ֨זֶר֙ בָּנִ֣ים אֲחֵרִ֔ים וּבְנֵ֥י רְחַבְיָ֖ה רָב֥וּ לְמָֽעְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 23:18",
      "text": "בְּנֵ֥י יִצְהָ֖ר שְׁלֹמִ֥ית הָרֹֽאשׁ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 23:19",
      "text": "בְּנֵ֖י חֶבְר֑וֹן יְרִיָּ֤הוּ הָרֹאשׁ֙ אֲמַרְיָ֣ה הַשֵּׁנִ֔י יַחֲזִיאֵל֙ הַשְּׁלִישִׁ֔י וִֽיקַמְעָ֖ם הָרְבִיעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 23:20",
      "text": "בְּנֵ֖י עֻזִּיאֵ֑ל מִיכָ֣ה הָרֹ֔אשׁ וְיִשִּׁיָּ֖ה הַשֵּׁנִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 23:21",
      "text": "בְּנֵ֤י מְרָרִי֙ מַחְלִ֣י וּמוּשִׁ֔י בְּנֵ֥י מַחְלִ֖י אֶלְעָזָ֥ר וְקִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 23:22",
      "text": "וַיָּ֨מָת֙ אֶלְעָזָ֔ר וְלֹא ־ הָ֥יוּ ל֛וֹ בָּנִ֖ים כִּ֣י אִם ־ בָּנ֑וֹת וַיִּשָּׂא֥וּם בְּנֵי ־ קִ֖ישׁ אֲחֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 23:23",
      "text": "בְּנֵ֣י מוּשִׁ֗י מַחְלִ֥י וְעֵ֛דֶר וִירֵמ֖וֹת שְׁלֹשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 23:24",
      "text": "אֵ֣לֶּה בְנֵֽי ־ לֵוִי֩ לְבֵ֨ית אֲבֹתֵיהֶ֜ם רָאשֵׁ֧י הָאָב֣וֹת לִפְקוּדֵיהֶ֗ם בְּמִסְפַּ֤ר שֵׁמוֹת֙ לְגֻלְגְּלֹתָ֔ם עֹשֵׂה֙ הַמְּלָאכָ֔ה לַעֲבֹדַ֖ת בֵּ֣ית יְהוָ֑ה מִבֶּ֛ן עֶשְׂרִ֥ים שָׁנָ֖ה וָמָֽעְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 23:25",
      "text": "כִּ֚י אָמַ֣ר דָּוִ֔יד הֵנִ֛יחַ יְהוָ֥ה אֱלֹהֵֽי ־ יִשְׂרָאֵ֖ל לְעַמּ֑וֹ וַיִּשְׁכֹּ֥ן בִּירוּשָׁלִַ֖ם עַד ־ לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 23:26",
      "text": "וְגַ֖ם לַלְוִיִּ֑ם אֵין ־ לָשֵׂ֧את אֶת ־ הַמִּשְׁכָּ֛ן וְאֶת ־ כָּל ־ כֵּלָ֖יו לַעֲבֹדָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 23:27",
      "text": "כִּ֣י בְדִבְרֵ֤י דָוִיד֙ הָאַ֣חֲרֹנִ֔ים הֵ֖מָּה מִסְפַּ֣ר בְּנֵי ־ לֵוִ֑י מִבֶּ֛ן עֶשְׂרִ֥ים שָׁנָ֖ה וּלְמָֽעְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 23:28",
      "text": "כִּ֣י מַעֲמָדָ֞ם לְיַד ־ בְּנֵ֣י אַהֲרֹ֗ן לַעֲבֹדַת֙ בֵּ֣ית יְהוָ֔ה עַל ־ הַחֲצֵרוֹת֙ וְעַל ־ הַלְּשָׁכ֔וֹת וְעַֽל ־ טָהֳרַ֖ת לְכָל ־ קֹ֑דֶשׁ וּמַֽעֲשֵׂ֔ה עֲבֹדַ֖ת בֵּ֥ית הָאֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 23:29",
      "text": "וּלְלֶ֨חֶם הַֽמַּעֲרֶ֜כֶת וּלְסֹ֤לֶת לְמִנְחָה֙ וְלִרְקִיקֵ֣י הַמַּצּ֔וֹת וְלַֽמַּחֲבַ֖ת וְלַמֻּרְבָּ֑כֶת וּלְכָל ־ מְשׂוּרָ֖ה וּמִדָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 23:30",
      "text": "וְלַעֲמֹד֙ בַּבֹּ֣קֶר בַּבֹּ֔קֶר לְהֹד֥וֹת וּלְהַלֵּ֖ל לַיהוָ֑ה וְכֵ֖ן לָעָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 23:31",
      "text": "וּלְכֹ֨ל הַעֲל֤וֹת עֹלוֹת֙ לַיהוָ֔ה לַשַּׁבָּת֔וֹת לֶחֳדָשִׁ֖ים וְלַמֹּעֲדִ֑ים בְּמִסְפָּ֨ר כְּמִשְׁפָּ֧ט עֲלֵיהֶ֛ם תָּמִ֖יד לִפְנֵ֥י יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.23.32",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 23:32",
      "text": "וְשָׁמְר֞וּ אֶת ־ מִשְׁמֶ֣רֶת אֹֽהֶל ־ מוֹעֵ֗ד וְאֵת֙ מִשְׁמֶ֣רֶת הַקֹּ֔דֶשׁ וּמִשְׁמֶ֕רֶת בְּנֵ֥י אַהֲרֹ֖ן אֲחֵיהֶ֑ם לַעֲבֹדַ֖ת בֵּ֥ית יְהוָֽה ׃ פ",
      "paragraphStart": false
    }
  ]
}
