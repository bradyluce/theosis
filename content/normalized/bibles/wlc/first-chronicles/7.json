{
  "chapter": {
    "id": "wlc:first-chronicles.7",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 7,
    "referenceLabel": "1 Chronicles 7",
    "summary": "Source text for 1 Chronicles 7 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.7.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 7:1",
      "text": "וְלִבְנֵ֣י יִשָׂשכָ֗ר תּוֹלָ֧ע וּפוּאָ֛ה ישיב וְשִׁמְר֖וֹן אַרְבָּעָֽה ׃ ס",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.7.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 7:2",
      "text": "וּבְנֵ֣י תוֹלָ֗ע עֻזִּ֡י וּרְפָיָ֡ה וִֽ֠ירִיאֵל וְיַחְמַ֨י וְיִבְשָׂ֜ם וּשְׁמוּאֵ֗ל רָאשִׁ֤ים לְבֵית ־ אֲבוֹתָם֙ לְתוֹלָ֔ע גִּבּ֥וֹרֵי חַ֖יִל לְתֹלְדוֹתָ֑ם מִסְפָּרָם֙ בִּימֵ֣י דָוִ֔יד עֶשְׂרִֽים ־ וּשְׁנַ֥יִם אֶ֖לֶף וְשֵׁ֥שׁ מֵאֽוֹת ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 7:3",
      "text": "וּבְנֵ֥י עֻזִּ֖י יִֽזְרַֽחְיָ֑ה וּבְנֵ֣י יִֽזְרַֽחְיָ֗ה מִֽיכָאֵ֡ל וְ֠עֹבַדְיָה וְיוֹאֵ֧ל יִשִּׁיָּ֛ה חֲמִשָּׁ֖ה רָאשִׁ֥ים כֻּלָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 7:4",
      "text": "וַעֲלֵיהֶ֨ם לְתֹלְדוֹתָ֜ם לְבֵ֣ית אֲבוֹתָ֗ם גְּדוּדֵי֙ צְבָ֣א מִלְחָמָ֔ה שְׁלֹשִׁ֥ים וְשִׁשָּׁ֖ה אָ֑לֶף כִּֽי ־ הִרְבּ֥וּ נָשִׁ֖ים וּבָנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 7:5",
      "text": "וַאֲחֵיהֶ֗ם לְכֹל֙ מִשְׁפְּח֣וֹת יִשָׂשכָ֔ר גִּבּוֹרֵ֖י חֲיָלִ֑ים שְׁמוֹנִ֤ים וְשִׁבְעָה֙ אֶ֔לֶף הִתְיַחְשָׂ֖ם לַכֹּֽל ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 7:6",
      "text": "בִּנְיָמִ֗ן בֶּ֧לַע וָבֶ֛כֶר וִידִֽיעֲאֵ֖ל שְׁלֹשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 7:7",
      "text": "וּבְנֵ֣י בֶ֗לַע אֶצְבּ֡וֹן וְעֻזִּ֡י וְ֠עֻזִּיאֵל וִירִימ֨וֹת וְעִירִ֜י חֲמִשָּׁ֗ה רָאשֵׁי֙ בֵּ֣ית אָב֔וֹת גִּבּוֹרֵ֖י חֲיָלִ֑ים וְהִתְיַחְשָׂ֗ם עֶשְׂרִ֤ים וּשְׁנַ֨יִם֙ אֶ֔לֶף וּשְׁלֹשִׁ֖ים וְאַרְבָּעָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 7:8",
      "text": "וּבְנֵ֣י בֶ֗כֶר זְמִירָ֡ה וְיוֹעָ֡שׁ וֶ֠אֱלִיעֶזֶר וְאֶלְיוֹעֵינַ֤י וְעָמְרִי֙ וִירֵמ֣וֹת וַאֲבִיָּ֔ה וַעֲנָת֖וֹת וְעָלָ֑מֶת כָּל ־ אֵ֖לֶּה בְּנֵי ־ בָֽכֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 7:9",
      "text": "וְהִתְיַחְשָׂ֣ם לְתֹלְדוֹתָ֗ם רָאשֵׁי֙ בֵּ֣ית אֲבוֹתָ֔ם גִּבּוֹרֵ֖י חָ֑יִל עֶשְׂרִ֥ים אֶ֖לֶף וּמָאתָֽיִם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 7:10",
      "text": "וּבְנֵ֥י יְדִיעֲאֵ֖ל בִּלְהָ֑ן וּבְנֵ֣י בִלְהָ֗ן יעיש וּ֠בִנְיָמִן וְאֵה֤וּד וּֽכְנַעֲנָה֙ וְזֵיתָ֔ן וְתַרְשִׁ֖ישׁ וַאֲחִישָֽׁחַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 7:11",
      "text": "כָּל ־ אֵ֜לֶּה בְּנֵ֤י יְדִֽיעֲאֵל֙ לְרָאשֵׁ֣י הָאָב֔וֹת גִּבּוֹרֵ֖י חֲיָלִ֑ים שִׁבְעָֽה ־ עָשָׂ֥ר אֶ֨לֶף֙ וּמָאתַ֔יִם יֹצְאֵ֥י צָבָ֖א לַמִּלְחָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 7:12",
      "text": "וְשֻׁפִּ֤ם וְחֻפִּם֙ בְּנֵ֣י עִ֔יר חֻשִׁ֖ם בְּנֵ֥י אַחֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 7:13",
      "text": "בְּנֵ֣י נַפְתָּלִ֗י יַחֲצִיאֵ֧ל וְגוּנִ֛י וְיֵ֥צֶר וְשַׁלּ֖וּם בְּנֵ֥י בִלְהָֽה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 7:14",
      "text": "בְּנֵ֣י מְנַשֶּׁ֔ה אַשְׂרִיאֵ֖ל אֲשֶׁ֣ר יָלָ֑דָה פִּֽילַגְשׁוֹ֙ הָֽאֲרַמִּיָּ֔ה יָלְדָ֕ה אֶת ־ מָכִ֖יר אֲבִ֥י גִלְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 7:15",
      "text": "וּמָכִ֞יר לָקַ֤ח אִשָּׁה֙ לְחֻפִּ֣ים וּלְשֻׁפִּ֔ים וְשֵׁ֤ם אֲחֹתוֹ֙ מַעֲכָ֔ה וְשֵׁ֥ם הַשֵּׁנִ֖י צְלָפְחָ֑ד וַתִּהְיֶ֥נָה לִצְלָפְחָ֖ד בָּנֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 7:16",
      "text": "וַתֵּ֨לֶד מַעֲכָ֤ה אֵֽשֶׁת ־ מָכִיר֙ בֵּ֔ן וַתִּקְרָ֤א שְׁמוֹ֙ פֶּ֔רֶשׁ וְשֵׁ֥ם אָחִ֖יו שָׁ֑רֶשׁ וּבָנָ֖יו אוּלָ֥ם וָרָֽקֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 7:17",
      "text": "וּבְנֵ֥י אוּלָ֖ם בְּדָ֑ן אֵ֚לֶּה בְּנֵ֣י גִלְעָ֔ד בֶּן ־ מָכִ֖יר בֶּן ־ מְנַשֶּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 7:18",
      "text": "וַאֲחֹת֖וֹ הַמֹּלֶ֑כֶת יָלְדָה֙ אֶת ־ אִישְׁה֔וֹד וְאֶת ־ אֲבִיעֶ֖זֶר וְאֶת ־ מַחְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 7:19",
      "text": "וַיִּהְי֖וּ בְּנֵ֣י שְׁמִידָ֑ע אַחְיָ֣ן וָשֶׁ֔כֶם וְלִקְחִ֖י וַאֲנִיעָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 7:20",
      "text": "וּבְנֵ֥י אֶפְרַ֖יִם שׁוּתָ֑לַח וּבֶ֤רֶד בְּנוֹ֙ וְתַ֣חַת בְּנ֔וֹ וְאֶלְעָדָ֥ה בְנ֖וֹ וְתַ֥חַת בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 7:21",
      "text": "וְזָבָ֥ד בְּנ֛וֹ וְשׁוּתֶ֥לַח בְּנ֖וֹ וְעֵ֣זֶר וְאֶלְעָ֑ד וַהֲרָג֗וּם אַנְשֵׁי ־ גַת֙ הַנּוֹלָדִ֣ים בָּאָ֔רֶץ כִּ֣י יָרְד֔וּ לָקַ֖חַת אֶת ־ מִקְנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 7:22",
      "text": "וַיִּתְאַבֵּ֛ל אֶפְרַ֥יִם אֲבִיהֶ֖ם יָמִ֣ים רַבִּ֑ים וַיָּבֹ֥אוּ אֶחָ֖יו לְנַחֲמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 7:23",
      "text": "וַיָּבֹא֙ אֶל ־ אִשְׁתּ֔וֹ וַתַּ֖הַר וַתֵּ֣לֶד בֵּ֑ן וַיִּקְרָ֤א אֶת ־ שְׁמוֹ֙ בְּרִיעָ֔ה כִּ֥י בְרָעָ֖ה הָיְתָ֥ה בְּבֵיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 7:24",
      "text": "וּבִתּ֣וֹ שֶׁאֱרָ֔ה וַתִּ֧בֶן אֶת ־ בֵּית ־ חוֹר֛וֹן הַתַּחְתּ֖וֹן וְאֶת ־ הָעֶלְי֑וֹן וְאֵ֖ת אֻזֵּ֥ן שֶׁאֱרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 7:25",
      "text": "וְרֶ֣פַח בְּנ֗וֹ וְרֶ֧שֶׁף וְתֶ֛לַח בְּנ֖וֹ וְתַ֥חַן בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 7:26",
      "text": "לַעְדָּ֥ן בְּנ֛וֹ עַמִּיה֥וּד בְּנ֖וֹ אֱלִישָׁמָ֥ע בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 7:27",
      "text": "נ֥וֹן בְּנ֖וֹ יְהוֹשֻׁ֥עַ בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 7:28",
      "text": "וַאֲחֻזָּתָם֙ וּמֹ֣שְׁבוֹתָ֔ם בֵּֽית ־ אֵ֖ל וּבְנֹתֶ֑יהָ וְלַמִּזְרָ֣ח נַעֲרָ֔ן וְלַֽמַּעֲרָ֗ב גֶּ֤זֶר וּבְנֹתֶ֨יהָ֙ וּשְׁכֶ֣ם וּבְנֹתֶ֔יהָ עַד ־ עַיָּ֖ה וּבְנֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 7:29",
      "text": "וְעַל ־ יְדֵ֣י בְנֵי ־ מְנַשֶּׁ֗ה בֵּית ־ שְׁאָ֤ן וּבְנֹתֶ֨יהָ֙ תַּעְנַ֣ךְ וּבְנֹתֶ֔יהָ מְגִדּ֥וֹ וּבְנוֹתֶ֖יהָ דּ֣וֹר וּבְנוֹתֶ֑יהָ בְּאֵ֨לֶּה֙ יָשְׁב֔וּ בְּנֵ֥י יוֹסֵ֖ף בֶּן ־ יִשְׂרָאֵֽל ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 7:30",
      "text": "בְּנֵ֣י אָשֵׁ֗ר יִמְנָ֧ה וְיִשְׁוָ֛ה וְיִשְׁוִ֥י וּבְרִיעָ֖ה וְשֶׂ֥רַח אֲחוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.7.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
