{
  "chapter": {
    "id": "wlc:first-chronicles.4",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 4,
    "referenceLabel": "1 Chronicles 4",
    "summary": "Source text for 1 Chronicles 4 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.4.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 4:1",
      "text": "בְּנֵ֖י יְהוּדָ֑ה פֶּ֧רֶץ חֶצְר֛וֹן וְכַרְמִ֖י וְח֥וּר וְשׁוֹבָֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.4.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 4:2",
      "text": "וּרְאָיָ֤ה בֶן ־ שׁוֹבָל֙ הוֹלִ֣יד אֶת ־ יַ֔חַת וְיַ֣חַת הֹלִ֔יד אֶת ־ אֲחוּמַ֖י וְאֶת ־ לָ֑הַד אֵ֖לֶּה מִשְׁפְּח֥וֹת הַצָּֽרְעָתִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 4:3",
      "text": "וְאֵ֨לֶּה֙ אֲבִ֣י עֵיטָ֔ם יִזְרְעֶ֥אל וְיִשְׁמָ֖א וְיִדְבָּ֑שׁ וְשֵׁ֥ם אֲחוֹתָ֖ם הַצְלֶלְפּֽוֹנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 4:4",
      "text": "וּפְנוּאֵל֙ אֲבִ֣י גְדֹ֔ר וְעֵ֖זֶר אֲבִ֣י חוּשָׁ֑ה אֵ֤לֶּה בְנֵי ־ חוּר֙ בְּכ֣וֹר אֶפְרָ֔תָה אֲבִ֖י בֵּ֥ית לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 4:5",
      "text": "וּלְאַשְׁחוּר֙ אֲבִ֣י תְק֔וֹעַ הָי֖וּ שְׁתֵּ֣י נָשִׁ֑ים חֶלְאָ֖ה וְנַעֲרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 4:6",
      "text": "וַתֵּ֨לֶד ל֤וֹ נַעֲרָה֙ אֶת ־ אֲחֻזָּ֣ם וְאֶת ־ חֵ֔פֶר וְאֶת ־ תֵּימְנִ֖י וְאֶת ־ הָאֲחַשְׁתָּרִ֑י אֵ֖לֶּה בְּנֵ֥י נַעֲרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 4:7",
      "text": "וּבְנֵ֖י חֶלְאָ֑ה צֶ֥רֶת יצחר וְאֶתְנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 4:8",
      "text": "וְק֣וֹץ הוֹלִ֔יד אֶת ־ עָנ֖וּב וְאֶת ־ הַצֹּבֵבָ֑ה וּמִשְׁפְּח֥וֹת אֲחַרְחֵ֖ל בֶּן ־ הָרֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 4:9",
      "text": "וַיְהִ֣י יַעְבֵּ֔ץ נִכְבָּ֖ד מֵאֶחָ֑יו וְאִמּ֗וֹ קָרְאָ֨ה שְׁמ֤וֹ יַעְבֵּץ֙ לֵאמֹ֔ר כִּ֥י יָלַ֖דְתִּי בְּעֹֽצֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 4:10",
      "text": "וַיִּקְרָ֣א יַ֠עְבֵּץ לֵאלֹהֵ֨י יִשְׂרָאֵ֜ל לֵאמֹ֗ר אִם ־ בָּרֵ֨ךְ תְּבָרֲכֵ֜נִי וְהִרְבִּ֤יתָ אֶת ־ גְּבוּלִי֙ וְהָיְתָ֤ה יָדְךָ֙ עִמִּ֔י וְעָשִׂ֥יתָ מֵּרָעָ֖ה לְבִלְתִּ֣י עָצְבִּ֑י וַיָּבֵ֥א אֱלֹהִ֖ים אֵ֥ת אֲשֶׁר ־ שָׁאָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 4:11",
      "text": "וּכְל֥וּב אֲחִֽי ־ שׁוּחָ֖ה הוֹלִ֣יד אֶת ־ מְחִ֑יר ה֖וּא אֲבִ֥י אֶשְׁתּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 4:12",
      "text": "וְאֶשְׁתּ֗וֹן הוֹלִ֞יד אֶת ־ בֵּ֤ית רָפָא֙ וְאֶת ־ פָּסֵ֔חַ וְאֶת ־ תְּחִנָּ֖ה אֲבִ֣י עִ֣יר נָחָ֑שׁ אֵ֖לֶּה אַנְשֵׁ֥י רֵכָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 4:13",
      "text": "וּבְנֵ֣י קְנַ֔ז עָתְנִיאֵ֖ל וּשְׂרָיָ֑ה וּבְנֵ֥י עָתְנִיאֵ֖ל חֲתַֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 4:14",
      "text": "וּמְעוֹנֹתַ֖י הוֹלִ֣יד אֶת ־ עָפְרָ֑ה וּשְׂרָיָ֗ה הוֹלִ֤יד אֶת ־ יוֹאָב֙ אֲבִי֙ גֵּ֣יא חֲרָשִׁ֔ים כִּ֥י חֲרָשִׁ֖ים הָיֽוּ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 4:15",
      "text": "וּבְנֵי֙ כָּלֵ֣ב בֶּן ־ יְפֻנֶּ֔ה עִ֥ירוּ אֵלָ֖ה וָנָ֑עַם וּבְנֵ֥י אֵלָ֖ה וּקְנַֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 4:16",
      "text": "וּבְנֵ֖י יְהַלֶּלְאֵ֑ל זִ֣יף וְזִיפָ֔ה תִּירְיָ֖א וַאֲשַׂרְאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 4:17",
      "text": "וּבֶן ־ עֶזְרָ֔ה יֶ֥תֶר וּמֶ֖רֶד וְעֵ֣פֶר וְיָל֑וֹן וַתַּ֨הַר֙ אֶת ־ מִרְיָ֣ם וְאֶת ־ שַׁמַּ֔י וְאֶת ־ יִשְׁבָּ֖ח אֲבִ֥י אֶשְׁתְּמֹֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 4:18",
      "text": "וְאִשְׁתּ֣וֹ הַיְהֻדִיָּ֗ה יָלְדָ֞ה אֶת ־ יֶ֨רֶד אֲבִ֤י גְדוֹר֙ וְאֶת ־ חֶ֨בֶר֙ אֲבִ֣י שׂוֹכ֔וֹ וְאֶת ־ יְקֽוּתִיאֵ֖ל אֲבִ֣י זָנ֑וֹחַ וְאֵ֗לֶּה בְּנֵי֙ בִּתְיָ֣ה בַת ־ פַּרְעֹ֔ה אֲשֶׁ֥ר לָקַ֖ח מָֽרֶד ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 4:19",
      "text": "וּבְנֵי֙ אֵ֣שֶׁת הֽוֹדִיָּ֔ה אֲח֣וֹת נַ֔חַם אֲבִ֥י קְעִילָ֖ה הַגַּרְמִ֑י וְאֶשְׁתְּמֹ֖עַ הַמַּעֲכָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 4:20",
      "text": "וּבְנֵ֣י שִׁימ֔וֹן אַמְנ֣וֹן וְרִנָּ֔ה בֶּן ־ חָנָ֖ן ותולון וּבְנֵ֣י יִשְׁעִ֔י זוֹחֵ֖ת וּבֶן ־ זוֹחֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 4:21",
      "text": "בְּנֵי֙ שֵׁלָ֣ה בֶן ־ יְהוּדָ֔ה עֵ֚ר אֲבִ֣י לֵכָ֔ה וְלַעְדָּ֖ה אֲבִ֣י מָרֵשָׁ֑ה וּמִשְׁפְּח֛וֹת בֵּית ־ עֲבֹדַ֥ת הַבֻּ֖ץ לְבֵ֥ית אַשְׁבֵּֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 4:22",
      "text": "וְיוֹקִ֞ים וְאַנְשֵׁ֣י כֹזֵבָ֗א וְיוֹאָ֧שׁ וְשָׂרָ֛ף אֲשֶׁר ־ בָּעֲל֥וּ לְמוֹאָ֖ב וְיָשֻׁ֣בִי לָ֑חֶם וְהַדְּבָרִ֖ים עַתִּיקִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 4:23",
      "text": "הֵ֚מָּה הַיּ֣וֹצְרִ֔ים וְיֹשְׁבֵ֥י נְטָעִ֖ים וּגְדֵרָ֑ה עִם ־ הַמֶּ֥לֶךְ בִּמְלַאכְתּ֖וֹ יָ֥שְׁבוּ שָֽׁם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 4:24",
      "text": "בְּנֵ֖י שִׁמְע֑וֹן נְמוּאֵ֣ל וְיָמִ֔ין יָרִ֖יב זֶ֥רַח שָׁאֽוּל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 4:25",
      "text": "שַׁלֻּ֥ם בְּנ֛וֹ מִבְשָׂ֥ם בְּנ֖וֹ מִשְׁמָ֥ע בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 4:26",
      "text": "וּבְנֵ֖י מִשְׁמָ֑ע חַמּוּאֵ֥ל בְּנ֛וֹ זַכּ֥וּר בְּנ֖וֹ שִׁמְעִ֥י בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 4:27",
      "text": "וּלְשִׁמְעִ֞י בָּנִ֨ים שִׁשָּׁ֤ה עָשָׂר֙ וּבָנ֣וֹת שֵׁ֔שׁ וּלְאֶחָ֕יו אֵ֖ין בָּנִ֣ים רַבִּ֑ים וְכֹל֙ מִשְׁפַּחְתָּ֔ם לֹ֥א הִרְבּ֖וּ עַד ־ בְּנֵ֥י יְהוּדָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 4:28",
      "text": "וַיֵּֽשְׁב֛וּ בִּבְאֵֽר ־ שֶׁ֥בַע וּמוֹלָדָ֖ה וַחֲצַ֥ר שׁוּעָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 4:29",
      "text": "וּבְבִלְהָ֥ה וּבְעֶ֖צֶם וּבְתוֹלָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 4:30",
      "text": "וּבִבְתוּאֵ֥ל וּבְחָרְמָ֖ה וּבְצִֽיקְלָֽג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 4:31",
      "text": "וּבְבֵ֤ית מַרְכָּבוֹת֙ וּבַחֲצַ֣ר סוּסִ֔ים וּבְבֵ֥ית בִּרְאִ֖י וּֽבְשַׁעֲרָ֑יִם אֵ֥לֶּה עָרֵיהֶ֖ם עַד ־ מְלֹ֥ךְ דָּוִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.32",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 4:32",
      "text": "וְחַצְרֵיהֶם֙ עֵיטָ֣ם וָעַ֔יִן רִמּ֥וֹן וְתֹ֖כֶן וְעָשָׁ֑ן עָרִ֖ים חָמֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.4.33",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 4:33",
      "text": "וְכָל ־ חַצְרֵיהֶ֗ם אֲשֶׁ֧ר סְבִיב֛וֹת הֶעָרִ֥ים הָאֵ֖לֶּה עַד ־ בָּ֑עַל זֹ֚את מוֹשְׁבֹתָ֔ם וְהִתְיַחְשָׂ֖ם לָהֶֽם ׃",
