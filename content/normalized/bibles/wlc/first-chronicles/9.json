    "chapterNumber": 9,
    "referenceLabel": "1 Chronicles 9",
    "summary": "Source text for 1 Chronicles 9 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.9.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 9:1",
      "text": "וְכָל ־ יִשְׂרָאֵל֙ הִתְיַחְשׂ֔וּ וְהִנָּ֣ם כְּתוּבִ֔ים עַל ־ סֵ֖פֶר מַלְכֵ֣י יִשְׂרָאֵ֑ל וִיהוּדָ֛ה הָגְל֥וּ לְבָבֶ֖ל בְּמַעֲלָֽם ׃ ס",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.9.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 9:2",
      "text": "וְהַיּוֹשְׁבִים֙ הָרִ֣אשֹׁנִ֔ים אֲשֶׁ֥ר בַּאֲחֻזָּתָ֖ם בְּעָרֵיהֶ֑ם יִשְׂרָאֵל֙ הַכֹּ֣הֲנִ֔ים הַלְוִיִּ֖ם וְהַנְּתִינִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 9:3",
      "text": "וּבִירוּשָׁלִַ֨ם֙ יָשְׁב֔וּ מִן ־ בְּנֵ֥י יְהוּדָ֖ה וּמִן ־ בְּנֵ֣י בִנְיָמִ֑ן וּמִן ־ בְּנֵ֥י אֶפְרַ֖יִם וּמְנַשֶּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 9:4",
      "text": "עוּתַ֨י בֶּן ־ עַמִּיה֤וּד בֶּן ־ עָמְרִי֙ בֶּן ־ אִמְרִ֣י בֶן ־ בנימן ־ בְּנֵי ־ פֶ֖רֶץ בֶּן ־ יְהוּדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 9:5",
      "text": "וּמִן ־ הַשִּׁ֣ילוֹנִ֔י עֲשָׂיָ֥ה הַבְּכ֖וֹר וּבָנָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 9:6",
      "text": "וּמִן ־ בְּנֵי ־ זֶ֖רַח יְעוּאֵ֑ל וַאֲחֵיהֶ֖ם שֵׁשׁ ־ מֵא֥וֹת וְתִשְׁעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 9:7",
      "text": "וּמִן ־ בְּנֵ֖י בִּנְיָמִ֑ן סַלּוּא֙ בֶּן ־ מְשֻׁלָּ֔ם בֶּן ־ הוֹדַוְיָ֖ה בֶּן ־ הַסְּנֻאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 9:8",
      "text": "וְיִבְנְיָה֙ בֶּן ־ יְרֹחָ֔ם וְאֵלָ֥ה בֶן ־ עֻזִּ֖י בֶּן ־ מִכְרִ֑י וּמְשֻׁלָּם֙ בֶּן ־ שְׁפַטְיָ֔ה בֶּן ־ רְעוּאֵ֖ל בֶּן ־ יִבְנִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 9:9",
      "text": "וַאֲחֵיהֶם֙ לְתֹ֣לְדוֹתָ֔ם תְּשַׁ֥ע מֵא֖וֹת וַחֲמִשִּׁ֣ים וְשִׁשָּׁ֑ה כָּל ־ אֵ֣לֶּה אֲנָשִׁ֔ים רָאשֵׁ֥י אָב֖וֹת לְבֵ֥ית אֲבֹתֵיהֶֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 9:10",
      "text": "וּמִן ־ הַֽכֹּהֲנִ֑ים יְדַֽעְיָ֥ה וִיהוֹיָרִ֖יב וְיָכִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 9:11",
      "text": "וַעֲזַרְיָ֨ה בֶן ־ חִלְקִיָּ֜ה בֶּן ־ מְשֻׁלָּ֣ם בֶּן ־ צָד֗וֹק בֶּן ־ מְרָיוֹת֙ בֶּן ־ אֲחִיט֔וּב נְגִ֖יד בֵּ֥ית הָאֱלֹהִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 9:12",
      "text": "וַעֲדָיָה֙ בֶּן ־ יְרֹחָ֔ם בֶּן ־ פַּשְׁח֖וּר בֶּן ־ מַלְכִּיָּ֑ה וּמַעְשַׂ֨י בֶּן ־ עֲדִיאֵ֧ל בֶּן ־ יַחְזֵ֛רָה בֶּן ־ מְשֻׁלָּ֥ם בֶּן ־ מְשִׁלֵּמִ֖ית בֶּן ־ אִמֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 9:13",
      "text": "וַאֲחֵיהֶ֗ם רָאשִׁים֙ לְבֵ֣ית אֲבוֹתָ֔ם אֶ֕לֶף וּשְׁבַ֥ע מֵא֖וֹת וְשִׁשִּׁ֑ים גִּבּ֣וֹרֵי חֵ֔יל מְלֶ֖אכֶת עֲבוֹדַ֥ת בֵּית ־ הָאֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 9:14",
      "text": "וּמִֽן ־ הַלְוִיִּ֑ם שְׁמַֽעְיָ֧ה בֶן ־ חַשּׁ֛וּב בֶּן ־ עַזְרִיקָ֥ם בֶּן ־ חֲשַׁבְיָ֖ה מִן ־ בְּנֵ֥י מְרָרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 9:15",
      "text": "וּבַקְבַּקַּ֥ר חֶ֖רֶשׁ וְגָלָ֑ל וּמַתַּנְיָה֙ בֶּן ־ מִיכָ֔א בֶּן ־ זִכְרִ֖י בֶּן ־ אָסָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 9:16",
      "text": "וְעֹבַדְיָה֙ בֶּֽן ־ שְׁמַֽעְיָ֔ה בֶּן ־ גָּלָ֖ל בֶּן ־ יְדוּת֑וּן וּבֶרֶכְיָ֤ה בֶן ־ אָסָא֙ בֶּן ־ אֶלְקָנָ֔ה הַיּוֹשֵׁ֖ב בְּחַצְרֵ֥י נְטוֹפָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 9:17",
      "text": "וְהַשֹּׁעֲרִים֙ שַׁלּ֣וּם וְעַקּ֔וּב וְטַלְמֹ֖ן וַאֲחִימָ֑ן וַאֲחִיהֶ֥ם שַׁלּ֖וּם הָרֹֽאשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 9:18",
      "text": "וְֽעַד ־ הֵ֔נָּה בְּשַׁ֥עַר הַמֶּ֖לֶךְ מִזְרָ֑חָה הֵ֚מָּה הַשֹּׁ֣עֲרִ֔ים לְמַחֲנ֖וֹת בְּנֵ֥י לֵוִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 9:19",
      "text": "וְשַׁלּ֣וּם בֶּן ־ ק֠וֹרֵא בֶּן ־ אֶבְיָסָ֨ף בֶּן ־ קֹ֜רַח וְֽאֶחָ֧יו לְבֵית ־ אָבִ֣יו הַקָּרְחִ֗ים עַ֚ל מְלֶ֣אכֶת הָעֲבוֹדָ֔ה שֹׁמְרֵ֥י הַסִּפִּ֖ים לָאֹ֑הֶל וַאֲבֹֽתֵיהֶם֙ עַל ־ מַחֲנֵ֣ה יְהוָ֔ה שֹׁמְרֵ֖י הַמָּבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 9:20",
      "text": "וּפִֽינְחָ֣ס בֶּן ־ אֶלְעָזָ֗ר נָגִ֨יד הָיָ֧ה עֲלֵיהֶ֛ם לְפָנִ֖ים יְהוָ֥ה ׀ עִמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 9:21",
      "text": "זְכַרְיָה֙ בֶּ֣ן מְשֶֽׁלֶמְיָ֔ה שֹׁעֵ֥ר פֶּ֖תַח לְאֹ֥הֶל מוֹעֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 9:22",
      "text": "כֻּלָּ֤ם הַבְּרוּרִים֙ לְשֹׁעֲרִ֣ים בַּסִּפִּ֔ים מָאתַ֖יִם וּשְׁנֵ֣ים עָשָׂ֑ר הֵ֤מָּה בְחַצְרֵיהֶם֙ הִתְיַחְשָׂ֔ם הֵ֣מָּה יִסַּ֥ד דָּוִ֛יד וּשְׁמוּאֵ֥ל הָרֹאֶ֖ה בֶּאֱמוּנָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 9:23",
      "text": "וְהֵ֨ם וּבְנֵיהֶ֜ם עַל ־ הַשְּׁעָרִ֧ים לְבֵית ־ יְהוָ֛ה לְבֵ֥ית ־ הָאֹ֖הֶל לְמִשְׁמָרֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 9:24",
      "text": "לְאַרְבַּ֣ע רוּח֔וֹת יִהְי֖וּ הַשֹּׁעֲרִ֑ים מִזְרָ֥ח יָ֖מָּה צָפ֥וֹנָה וָנֶֽגְבָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 9:25",
      "text": "וַאֲחֵיהֶ֨ם בְּחַצְרֵיהֶ֜ם לָב֨וֹא לְשִׁבְעַ֧ת הַיָּמִ֛ים מֵעֵ֥ת אֶל ־ עֵ֖ת עִם ־ אֵֽלֶּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 9:26",
      "text": "כִּ֣י בֶאֱמוּנָ֞ה הֵ֗מָּה אַרְבַּ֨עַת֙ גִּבֹּרֵ֣י הַשֹּׁעֲרִ֔ים הֵ֖ם הַלְוִיִּ֑ם וְהָיוּ֙ עַל ־ הַלְּשָׁכ֔וֹת וְעַ֥ל הָאֹצְר֖וֹת בֵּ֥ית הָאֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 9:27",
      "text": "וּסְבִיב֥וֹת בֵּית ־ הָאֱלֹהִ֖ים יָלִ֑ינוּ כִּֽי ־ עֲלֵיהֶ֣ם מִשְׁמֶ֔רֶת וְהֵ֥ם עַל ־ הַמַּפְתֵּ֖חַ וְלַבֹּ֥קֶר לַבֹּֽקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 9:28",
      "text": "וּמֵהֶ֖ם עַל ־ כְּלֵ֣י הָעֲבוֹדָ֑ה כִּֽי ־ בְמִסְפָּ֣ר יְבִיא֔וּם וּבְמִסְפָּ֖ר יוֹצִיאֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 9:29",
      "text": "וּמֵהֶ֗ם מְמֻנִּים֙ עַל ־ הַכֵּלִ֔ים וְעַ֖ל כָּל ־ כְּלֵ֣י הַקֹּ֑דֶשׁ וְעַל ־ הַסֹּ֨לֶת֙ וְהַיַּ֣יִן וְהַשֶּׁ֔מֶן וְהַלְּבוֹנָ֖ה וְהַבְּשָׂמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 9:30",
      "text": "וּמִן ־ בְּנֵי֙ הַכֹּ֣הֲנִ֔ים רֹקְחֵ֥י הַמִּרְקַ֖חַת לַבְּשָׂמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.9.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
