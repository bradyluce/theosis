      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 11:17",
      "text": "ויתאו דָּוִ֖יד וַיֹּאמַ֑ר מִ֚י יַשְׁקֵ֣נִי מַ֔יִם מִבּ֥וֹר בֵּֽית ־ לֶ֖חֶם אֲשֶׁ֥ר בַּשָּֽׁעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 11:18",
      "text": "וַיִּבְקְע֨וּ הַשְּׁלֹשָׁ֜ה בְּמַחֲנֵ֣ה פְלִשְׁתִּ֗ים וַיִּֽשְׁאֲבוּ ־ מַ֨יִם֙ מִבּ֤וֹר בֵּֽית ־ לֶ֨חֶם֙ אֲשֶׁ֣ר בַּשַּׁ֔עַר וַיִּשְׂא֖וּ וַיָּבִ֣אוּ אֶל ־ דָּוִ֑יד וְלֹֽא ־ אָבָ֤ה דָוִיד֙ לִשְׁתּוֹתָ֔ם וַיְנַסֵּ֥ךְ אֹתָ֖ם לַיהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 11:19",
      "text": "וַיֹּ֡אמֶר חָלִילָה֩ לִּ֨י מֵאֱלֹהַ֜י מֵעֲשׂ֣וֹת זֹ֗את הֲדַ֣ם הָאֲנָשִׁים֩ הָאֵ֨לֶּה אֶשְׁתֶּ֤ה בְנַפְשׁוֹתָם֙ כִּ֣י בְנַפְשׁוֹתָ֣ם הֱבִיא֔וּם וְלֹ֥א אָבָ֖ה לִשְׁתּוֹתָ֑ם אֵ֣לֶּה עָשׂ֔וּ שְׁלֹ֖שֶׁת הַגִּבּוֹרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 11:20",
      "text": "וְאַבְשַׁ֣י אֲחִֽי ־ יוֹאָ֗ב ה֤וּא הָיָה֙ רֹ֣אשׁ הַשְּׁלוֹשָׁ֔ה וְהוּא֙ עוֹרֵ֣ר אֶת ־ חֲנִית֔וֹ עַל ־ שְׁלֹ֥שׁ מֵא֖וֹת חָלָ֑ל ולא ־ שֵׁ֖ם בַּשְּׁלוֹשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 11:21",
      "text": "מִן ־ הַשְּׁלוֹשָׁ֤ה בַשְּׁנַ֨יִם֙ נִכְבָּ֔ד וַיְהִ֥י לָהֶ֖ם לְשָׂ֑ר וְעַד ־ הַשְּׁלוֹשָׁ֖ה לֹֽא ־ בָֽא ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 11:22",
      "text": "בְּנָיָ֨ה בֶן ־ יְהוֹיָדָ֧ע בֶּן ־ אִֽישׁ ־ חַ֛יִל רַב ־ פְּעָלִ֖ים מִֽן ־ קַבְצְאֵ֑ל ה֣וּא הִכָּ֗ה אֵ֣ת שְׁנֵ֤י אֲרִיאֵל֙ מוֹאָ֔ב וְ֠הוּא יָרַ֞ד וְהִכָּ֧ה אֶֽת ־ הָאֲרִ֛י בְּת֥וֹךְ הַבּ֖וֹר בְּי֥וֹם הַשָּֽׁלֶג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 11:23",
      "text": "וְהֽוּא ־ הִכָּה֩ אֶת ־ הָאִ֨ישׁ הַמִּצְרִ֜י אִ֥ישׁ מִדָּ֣ה ׀ חָמֵ֣שׁ בָּאַמָּ֗ה וּבְיַ֨ד הַמִּצְרִ֤י חֲנִית֙ כִּמְנ֣וֹר אֹרְגִ֔ים וַיֵּ֥רֶד אֵלָ֖יו בַּשָּׁ֑בֶט וַיִּגְזֹ֤ל אֶֽת ־ הַחֲנִית֙ מִיַּ֣ד הַמִּצְרִ֔י וַיַּהַרְגֵ֖הוּ בַּחֲנִיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 11:24",
      "text": "אֵ֣לֶּה עָשָׂ֔ה בְּנָיָ֖הוּ בֶּן ־ יְהוֹיָדָ֑ע וְלוֹ ־ שֵׁ֖ם בִּשְׁלוֹשָׁ֥ה הַגִּבֹּרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 11:25",
      "text": "מִן ־ הַשְּׁלוֹשִׁ֗ים הִנּ֤וֹ נִכְבָּד֙ ה֔וּא וְאֶל ־ הַשְּׁלוֹשָׁ֖ה לֹא ־ בָ֑א וַיְשִׂימֵ֥הוּ דָוִ֖יד עַל ־ מִשְׁמַעְתּֽוֹ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 11:26",
      "text": "וְגִבּוֹרֵ֖י הַחֲיָלִ֑ים עֲשָׂה ־ אֵל֙ אֲחִ֣י יוֹאָ֔ב אֶלְחָנָ֥ן בֶּן ־ דּוֹד֖וֹ מִבֵּ֥ית לָֽחֶם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.27",
