  "verses": [
    {
      "id": "wlc:first-chronicles.11.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 11:1",
      "text": "וַיִּקָּבְצ֧וּ כָֽל ־ יִשְׂרָאֵ֛ל אֶל ־ דָּוִ֖יד חֶבְר֣וֹנָה לֵאמֹ֑ר הִנֵּ֛ה עַצְמְךָ֥ וּֽבְשָׂרְךָ֖ אֲנָֽחְנוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.11.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 11:2",
      "text": "גַּם ־ תְּמ֣וֹל גַּם ־ שִׁלְשׁ֗וֹם גַּ֚ם בִּהְי֣וֹת שָׁא֣וּל מֶ֔לֶךְ אַתָּ֛ה הַמּוֹצִ֥יא וְהַמֵּבִ֖יא אֶת ־ יִשְׂרָאֵ֑ל וַיֹּאמֶר֩ יְהוָ֨ה אֱלֹהֶ֜יךָ לְךָ֗ אַתָּ֨ה תִרְעֶ֤ה אֶת ־ עַמִּי֙ אֶת ־ יִשְׂרָאֵ֔ל וְאַתָּה֙ תִּהְיֶ֣ה נָגִ֔יד עַ֖ל עַמִּ֥י יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 11:3",
      "text": "וַ֠יָּבֹאוּ כָּל ־ זִקְנֵ֨י יִשְׂרָאֵ֤ל אֶל ־ הַמֶּ֨לֶךְ֙ חֶבְר֔וֹנָה וַיִּכְרֹת֩ לָהֶ֨ם דָּוִ֥יד בְּרִ֛ית בְּחֶבְר֖וֹן לִפְנֵ֣י יְהוָ֑ה וַיִּמְשְׁח֨וּ אֶת ־ דָּוִ֤יד לְמֶ֨לֶךְ֙ עַל ־ יִשְׂרָאֵ֔ל כִּדְבַ֥ר יְהוָ֖ה בְּיַד ־ שְׁמוּאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 11:4",
      "text": "וַיֵּ֨לֶךְ דָּוִ֧יד וְכָל ־ יִשְׂרָאֵ֛ל יְרוּשָׁלִַ֖ם הִ֣יא יְב֑וּס וְשָׁם֙ הַיְבוּסִ֔י יֹשְׁבֵ֖י הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 11:5",
      "text": "וַיֹּ֨אמְר֜וּ יֹשְׁבֵ֤י יְבוּס֙ לְדָוִ֔יד לֹ֥א תָב֖וֹא הֵ֑נָּה וַיִּלְכֹּ֤ד דָּוִיד֙ אֶת ־ מְצֻדַ֣ת צִיּ֔וֹן הִ֖יא עִ֥יר דָּוִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 11:6",
      "text": "וַיֹּ֣אמֶר דָּוִ֔יד כָּל ־ מַכֵּ֤ה יְבוּסִי֙ בָּרִ֣אשׁוֹנָ֔ה יִהְיֶ֥ה לְרֹ֖אשׁ וּלְשָׂ֑ר וַיַּ֧עַל בָּרִאשׁוֹנָ֛ה יוֹאָ֥ב בֶּן ־ צְרוּיָ֖ה וַיְהִ֥י לְרֹֽאשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 11:7",
      "text": "וַיֵּ֥שֶׁב דָּוִ֖יד בַּמְצָ֑ד עַל ־ כֵּ֥ן קָרְאוּ ־ ל֖וֹ עִ֥יר דָּוִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 11:8",
      "text": "וַיִּ֤בֶן הָעִיר֙ מִסָּבִ֔יב מִן ־ הַמִּלּ֖וֹא וְעַד ־ הַסָּבִ֑יב וְיוֹאָ֕ב יְחַיֶּ֖ה אֶת ־ שְׁאָ֥ר הָעִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 11:9",
      "text": "וַיֵּ֥לֶךְ דָּוִ֖יד הָל֣וֹךְ וְגָד֑וֹל וַיהוָ֥ה צְבָא֖וֹת עִמּֽוֹ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 11:10",
      "text": "וְאֵ֨לֶּה רָאשֵׁ֤י הַגִּבּוֹרִים֙ אֲשֶׁ֣ר לְדָוִ֔יד הַמִּתְחַזְּקִ֨ים עִמּ֧וֹ בְמַלְכוּת֛וֹ עִם ־ כָּל ־ יִשְׂרָאֵ֖ל לְהַמְלִיכ֑וֹ כִּדְבַ֥ר יְהוָ֖ה עַל ־ יִשְׂרָאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 11:11",
      "text": "וְאֵ֛לֶּה מִסְפַּ֥ר הַגִּבֹּרִ֖ים אֲשֶׁ֣ר לְדָוִ֑יד יָשָׁבְעָ֣ם בֶּן ־ חַכְמוֹנִ֗י רֹ֚אשׁ השלושים הֽוּא ־ עוֹרֵ֧ר אֶת ־ חֲנִית֛וֹ עַל ־ שְׁלֹשׁ ־ מֵא֥וֹת חָלָ֖ל בְּפַ֥עַם אֶחָֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 11:12",
      "text": "וְאַחֲרָ֛יו אֶלְעָזָ֥ר בֶּן ־ דּוֹד֖וֹ הָאֲחוֹחִ֑י ה֖וּא בִּשְׁלוֹשָׁ֥ה הַגִּבֹּרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 11:13",
      "text": "הֽוּא ־ הָיָ֨ה עִם ־ דָּוִ֜יד בַּפַּ֣ס דַּמִּ֗ים וְהַפְּלִשְׁתִּים֙ נֶאֱסְפוּ ־ שָׁ֣ם לַמִּלְחָמָ֔ה וַתְּהִ֛י חֶלְקַ֥ת הַשָּׂדֶ֖ה מְלֵאָ֣ה שְׂעוֹרִ֑ים וְהָעָ֥ם נָ֖סוּ מִפְּנֵ֥י פְלִשְׁתִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 11:14",
      "text": "וַיִּֽתְיַצְּב֤וּ בְתוֹךְ ־ הַחֶלְקָה֙ וַיַּצִּיל֔וּהָ וַיַּכּ֖וּ אֶת ־ פְּלִשְׁתִּ֑ים וַיּ֥וֹשַׁע יְהוָ֖ה תְּשׁוּעָ֥ה גְדוֹלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 11:15",
      "text": "וַיֵּרְד֡וּ שְֽׁלוֹשָׁה֩ מִן ־ הַשְּׁלוֹשִׁ֨ים רֹ֤אשׁ עַל ־ הַצֻּר֙ אֶל ־ דָּוִ֔יד אֶל ־ מְעָרַ֖ת עֲדֻלָּ֑ם וּמַחֲנֵ֣ה פְלִשְׁתִּ֔ים חֹנָ֖ה בְּעֵ֥מֶק רְפָאִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 11:16",
      "text": "וְדָוִ֖יד אָ֣ז בַּמְּצוּדָ֑ה וּנְצִ֣יב פְּלִשְׁתִּ֔ים אָ֖ז בְּבֵ֥ית לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.11.17",
