{
  "chapter": {
    "id": "wlc:first-chronicles.6",
    "translationId": "wlc",
    "bookSlug": "first-chronicles",
    "chapterNumber": 6,
    "referenceLabel": "1 Chronicles 6",
    "summary": "Source text for 1 Chronicles 6 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:first-chronicles.6.1",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 6:1",
      "text": "בְּנֵ֖י לֵוִ֑י גֵּרְשֹׁ֕ם קְהָ֖ת וּמְרָרִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:first-chronicles.6.2",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 6:2",
      "text": "וְאֵ֛לֶּה שְׁמ֥וֹת בְּֽנֵי ־ גֵרְשׁ֖וֹם לִבְנִ֥י וְשִׁמְעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.3",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 6:3",
      "text": "וּבְנֵ֖י קְהָ֑ת עַמְרָ֣ם וְיִצְהָ֔ר וְחֶבְר֖וֹן וְעֻזִּיאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.4",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 6:4",
      "text": "בְּנֵ֥י מְרָרִ֖י מַחְלִ֣י וּמֻשִׁ֑י וְאֵ֛לֶּה מִשְׁפְּח֥וֹת הַלֵּוִ֖י לַאֲבוֹתֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.5",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 6:5",
      "text": "לְֽגֵרְשׁ֑וֹם לִבְנִ֥י בְנ֛וֹ יַ֥חַת בְּנ֖וֹ זִמָּ֥ה בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.6",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 6:6",
      "text": "יוֹאָ֤ח בְּנוֹ֙ עִדּ֣וֹ בְנ֔וֹ זֶ֥רַח בְּנ֖וֹ יְאָתְרַ֥י בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.7",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 6:7",
      "text": "בְּנֵ֖י קְהָ֑ת עַמִּינָדָ֣ב בְּנ֔וֹ קֹ֥רַח בְּנ֖וֹ אַסִּ֥יר בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.8",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 6:8",
      "text": "אֶלְקָנָ֥ה בְנ֛וֹ וְאֶבְיָסָ֥ף בְּנ֖וֹ וְאַסִּ֥יר בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.9",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 6:9",
      "text": "תַּ֤חַת בְּנוֹ֙ אוּרִיאֵ֣ל בְּנ֔וֹ עֻזִּיָּ֥ה בְנ֖וֹ וְשָׁא֥וּל בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.10",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 6:10",
      "text": "וּבְנֵי֙ אֶלְקָנָ֔ה עֲמָשַׂ֖י וַאֲחִימֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.11",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 6:11",
      "text": "אֶלְקָנָ֑ה בנו אֶלְקָנָ֔ה צוֹפַ֥י בְּנ֖וֹ וְנַ֥חַת בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.12",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 6:12",
      "text": "אֱלִיאָ֥ב בְּנ֛וֹ יְרֹחָ֥ם בְּנ֖וֹ אֶלְקָנָ֥ה בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.13",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 6:13",
      "text": "וּבְנֵ֧י שְׁמוּאֵ֛ל הַבְּכֹ֥ר וַשְׁנִ֖י וַאֲבִיָּֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.14",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 6:14",
      "text": "בְּנֵ֥י מְרָרִ֖י מַחְלִ֑י לִבְנִ֥י בְנ֛וֹ שִׁמְעִ֥י בְנ֖וֹ עֻזָּ֥ה בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.15",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 6:15",
      "text": "שִׁמְעָ֥א בְנ֛וֹ חַגִּיָּ֥ה בְנ֖וֹ עֲשָׂיָ֥ה בְנֽוֹ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.16",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 6:16",
      "text": "וְאֵ֗לֶּה אֲשֶׁ֨ר הֶעֱמִ֥יד דָּוִ֛יד עַל ־ יְדֵי ־ שִׁ֖יר בֵּ֣ית יְהוָ֑ה מִמְּנ֖וֹחַ הָאָרֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.17",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 6:17",
      "text": "וַיִּהְי֨וּ מְשָׁרְתִ֜ים לִפְנֵ֨י מִשְׁכַּ֤ן אֹֽהֶל ־ מוֹעֵד֙ בַּשִּׁ֔יר עַד ־ בְּנ֧וֹת שְׁלֹמֹ֛ה אֶת ־ בֵּ֥ית יְהוָ֖ה בִּירוּשָׁלִָ֑ם וַיַּעַמְד֥וּ כְמִשְׁפָּטָ֖ם עַל ־ עֲבוֹדָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.18",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 6:18",
      "text": "וְאֵ֥לֶּה הָעֹמְדִ֖ים וּבְנֵיהֶ֑ם מִבְּנֵי֙ הַקְּהָתִ֔י הֵימָן֙ הַמְשׁוֹרֵ֔ר בֶּן ־ יוֹאֵ֖ל בֶּן ־ שְׁמוּאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.19",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 6:19",
      "text": "בֶּן ־ אֶלְקָנָה֙ בֶּן ־ יְרֹחָ֔ם בֶּן ־ אֱלִיאֵ֖ל בֶּן ־ תּֽוֹחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.20",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 6:20",
      "text": "בֶּן ־ ציף בֶּן ־ אֶלְקָנָ֔ה בֶּן ־ מַ֖חַת בֶּן ־ עֲמָשָֽׂי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.21",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 6:21",
      "text": "בֶּן ־ אֶלְקָנָה֙ בֶּן ־ יוֹאֵ֔ל בֶּן ־ עֲזַרְיָ֖ה בֶּן ־ צְפַנְיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.22",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 6:22",
      "text": "בֶּן ־ תַּ֨חַת֙ בֶּן ־ אַסִּ֔יר בֶּן ־ אֶבְיָסָ֖ף בֶּן ־ קֹֽרַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.23",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 6:23",
      "text": "בֶּן ־ יִצְהָ֣ר בֶּן ־ קְהָ֔ת בֶּן ־ לֵוִ֖י בֶּן ־ יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.24",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 6:24",
      "text": "וְאָחִ֣יו אָסָ֔ף הָעֹמֵ֖ד עַל ־ יְמִינ֑וֹ אָסָ֥ף בֶּן ־ בֶּרֶכְיָ֖הוּ בֶּן ־ שִׁמְעָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.25",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 6:25",
      "text": "בֶּן ־ מִיכָאֵ֥ל בֶּן ־ בַּעֲשֵׂיָ֖ה בֶּן ־ מַלְכִּיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.26",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 6:26",
      "text": "בֶּן ־ אֶתְנִ֥י בֶן ־ זֶ֖רַח בֶּן ־ עֲדָיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.27",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 6:27",
      "text": "בֶּן ־ אֵיתָ֥ן בֶּן ־ זִמָּ֖ה בֶּן ־ שִׁמְעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.28",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 6:28",
      "text": "בֶּן ־ יַ֥חַת בֶּן ־ גֵּרְשֹׁ֖ם בֶּן ־ לֵוִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.29",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 6:29",
      "text": "וּבְנֵ֧י מְרָרִ֛י אֲחֵיהֶ֖ם עַֽל ־ הַשְּׂמֹ֑אול אֵיתָן֙ בֶּן ־ קִישִׁ֔י בֶּן ־ עַבְדִּ֖י בֶּן ־ מַלּֽוּךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.30",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 6:30",
      "text": "בֶּן ־ חֲשַׁבְיָ֥ה בֶן ־ אֲמַצְיָ֖ה בֶּן ־ חִלְקִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.31",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 6:31",
      "text": "בֶּן ־ אַמְצִ֥י בֶן ־ בָּנִ֖י בֶּן ־ שָֽׁמֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.32",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 6:32",
      "text": "בֶּן ־ מַחְלִי֙ בֶּן ־ מוּשִׁ֔י בֶּן ־ מְרָרִ֖י בֶּן ־ לֵוִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.33",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 6:33",
      "text": "וַאֲחֵיהֶ֖ם הַלְוִיִּ֑ם נְתוּנִ֕ים לְכָ֨ל ־ עֲבוֹדַ֔ת מִשְׁכַּ֖ן בֵּ֥ית הָאֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.34",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 6:34",
      "text": "וְֽאַהֲרֹ֨ן וּבָנָ֜יו מַקְטִירִ֨ים עַל ־ מִזְבַּ֤ח הָֽעוֹלָה֙ וְעַל ־ מִזְבַּ֣ח הַקְּטֹ֔רֶת לְכֹ֕ל מְלֶ֖אכֶת קֹ֣דֶשׁ הַקֳּדָשִׁ֑ים וּלְכַפֵּר֙ עַל ־ יִשְׂרָאֵ֔ל כְּכֹל֙ אֲשֶׁ֣ר צִוָּ֔ה מֹשֶׁ֖ה עֶ֥בֶד הָאֱלֹהִֽים ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.35",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 6:35",
      "text": "וְאֵ֖לֶּה בְּנֵ֣י אַהֲרֹ֑ן אֶלְעָזָ֥ר בְּנ֛וֹ פִּֽינְחָ֥ס בְּנ֖וֹ אֲבִישׁ֥וּעַ בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.36",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 6:36",
      "text": "בֻּקִּ֥י בְנ֛וֹ עֻזִּ֥י בְנ֖וֹ זְרַֽחְיָ֥ה בְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.37",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 6:37",
      "text": "מְרָי֥וֹת בְּנ֛וֹ אֲמַרְיָ֥ה בְנ֖וֹ אֲחִיט֥וּב בְּנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.38",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 6:38",
      "text": "צָד֥וֹק בְּנ֖וֹ אֲחִימַ֥עַץ בְּנֽוֹ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.39",
      "translationId": "wlc",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 6:39",
      "text": "וְאֵ֨לֶּה֙ מוֹשְׁבוֹתָ֔ם לְטִירוֹתָ֖ם בִּגְבוּלָ֑ם לִבְנֵ֤י אַהֲרֹן֙ לְמִשְׁפַּחַ֣ת הַקְּהָתִ֔י כִּ֥י לָהֶ֖ם הָיָ֥ה הַגּוֹרָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:first-chronicles.6.40",
      "translationId": "wlc",
