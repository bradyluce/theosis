{
  "chapter": {
    "id": "wlc:proverbs.21",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 21,
    "referenceLabel": "Proverbs 21",
    "summary": "Source text for Proverbs 21 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.21.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 21:1",
      "text": "פַּלְגֵי ־ מַ֣יִם לֶב ־ מֶ֭לֶךְ בְּיַד ־ יְהוָ֑ה עַֽל ־ כָּל ־ אֲשֶׁ֖ר יַחְפֹּ֣ץ יַטֶּֽנּוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.21.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 21:2",
      "text": "כָּֽל ־ דֶּרֶךְ ־ אִ֭ישׁ יָשָׁ֣ר בְּעֵינָ֑יו וְתֹכֵ֖ן לִבּ֣וֹת יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 21:3",
      "text": "עֲ֭שֹׂה צְדָקָ֣ה וּמִשְׁפָּ֑ט נִבְחָ֖ר לַיהוָ֣ה מִזָּֽבַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 21:4",
      "text": "רוּם ־ עֵ֭ינַיִם וּרְחַב ־ לֵ֑ב נִ֖ר רְשָׁעִ֣ים חַטָּֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 21:5",
      "text": "מַחְשְׁב֣וֹת חָ֭רוּץ אַךְ ־ לְמוֹתָ֑ר וְכָל ־ אָ֝֗ץ אַךְ ־ לְמַחְסֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 21:6",
      "text": "פֹּ֣עַל א֭וֹצָרוֹת בִּלְשׁ֣וֹן שָׁ֑קֶר הֶ֥בֶל נִ֝דָּ֗ף מְבַקְשֵׁי ־ מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 21:7",
      "text": "שֹׁד ־ רְשָׁעִ֥ים יְגוֹרֵ֑ם כִּ֥י מֵ֝אֲנ֗וּ לַעֲשׂ֥וֹת מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 21:8",
      "text": "הֲפַכְפַּ֬ךְ דֶּ֣רֶךְ אִ֣ישׁ וָזָ֑ר וְ֝זַ֗ךְ יָשָׁ֥ר פָּעֳלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 21:9",
      "text": "ט֗וֹב לָשֶׁ֥בֶת עַל ־ פִּנַּת ־ גָּ֑ג מֵאֵ֥שֶׁת מִ֝דְיָנִ֗ים וּבֵ֥ית חָֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 21:10",
      "text": "נֶ֣פֶשׁ רָ֭שָׁע אִוְּתָה ־ רָ֑ע לֹא ־ יֻחַ֖ן בְּעֵינָ֣יו רֵעֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 21:11",
      "text": "בַּעְנָשׁ ־ לֵ֭ץ יֶחְכַּם ־ פֶּ֑תִי וּבְהַשְׂכִּ֥יל לְ֝חָכָ֗ם יִקַּח ־ דָּֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 21:12",
      "text": "מַשְׂכִּ֣יל צַ֭דִּיק לְבֵ֣ית רָשָׁ֑ע מְסַלֵּ֖ף רְשָׁעִ֣ים לָרָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 21:13",
      "text": "אֹטֵ֣ם אָ֭זְנוֹ מִזַּעֲקַת ־ דָּ֑ל גַּֽם ־ ה֥וּא יִ֝קְרָ֗א וְלֹ֣א יֵעָנֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 21:14",
      "text": "מַתָּ֣ן בַּ֭סֵּתֶר יִכְפֶּה ־ אָ֑ף וְשֹׁ֥חַד בַּ֝חֵ֗ק חֵמָ֥ה עַזָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 21:15",
      "text": "שִׂמְחָ֣ה לַ֭צַּדִּיק עֲשׂ֣וֹת מִשְׁפָּ֑ט וּ֝מְחִתָּ֗ה לְפֹ֣עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 21:16",
      "text": "אָדָ֗ם תּ֭וֹעֶה מִדֶּ֣רֶךְ הַשְׂכֵּ֑ל בִּקְהַ֖ל רְפָאִ֣ים יָנֽוּחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 21:17",
      "text": "אִ֣ישׁ מַ֭חְסוֹר אֹהֵ֣ב שִׂמְחָ֑ה אֹהֵ֥ב יַֽיִן ־ וָ֝שֶׁ֗מֶן לֹ֣א יַעֲשִֽׁיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 21:18",
      "text": "כֹּ֣פֶר לַצַּדִּ֣יק רָשָׁ֑ע וְתַ֖חַת יְשָׁרִ֣ים בּוֹגֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 21:19",
      "text": "ט֗וֹב שֶׁ֥בֶת בְּאֶֽרֶץ ־ מִדְבָּ֑ר מֵאֵ֖שֶׁת מדונים וָכָֽעַס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 21:20",
      "text": "אוֹצָ֤ר ׀ נֶחְמָ֣ד וָ֭שֶׁמֶן בִּנְוֵ֣ה חָכָ֑ם וּכְסִ֖יל אָדָ֣ם יְבַלְּעֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 21:21",
      "text": "רֹ֭דֵף צְדָקָ֣ה וָחָ֑סֶד יִמְצָ֥א חַ֝יִּ֗ים צְדָקָ֥ה וְכָבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 21:22",
      "text": "עִ֣יר גִּ֭בֹּרִים עָלָ֣ה חָכָ֑ם וַ֝יֹּ֗רֶד עֹ֣ז מִבְטֶחָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 21:23",
      "text": "שֹׁמֵ֣ר פִּ֭יו וּלְשׁוֹנ֑וֹ שֹׁמֵ֖ר מִצָּר֣וֹת נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 21:24",
      "text": "זֵ֣ד יָ֭הִיר לֵ֣ץ שְׁמ֑וֹ ע֝וֹשֶׂ֗ה בְּעֶבְרַ֥ת זָדֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 21:25",
      "text": "תַּאֲוַ֣ת עָצֵ֣ל תְּמִיתֶ֑נּוּ כִּֽי ־ מֵאֲנ֖וּ יָדָ֣יו לַעֲשֽׂוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 21:26",
      "text": "כָּל ־ הַ֭יּוֹם הִתְאַוָּ֣ה תַאֲוָ֑ה וְצַדִּ֥יק יִ֝תֵּ֗ן וְלֹ֣א יַחְשֹֽׂךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 21:27",
      "text": "זֶ֣בַח רְ֭שָׁעִים תּוֹעֵבָ֑ה אַ֝֗ף כִּֽי ־ בְזִמָּ֥ה יְבִיאֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 21:28",
      "text": "עֵד ־ כְּזָבִ֥ים יֹאבֵ֑ד וְאִ֥ישׁ שׁ֝וֹמֵ֗עַ לָנֶ֥צַח יְדַבֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 21:29",
      "text": "הֵעֵ֬ז אִ֣ישׁ רָשָׁ֣ע בְּפָנָ֑יו וְ֝יָשָׁ֗ר ה֤וּא ׀ יכין דרכיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 21:30",
      "text": "אֵ֣ין חָ֭כְמָה וְאֵ֣ין תְּבוּנָ֑ה וְאֵ֥ין עֵ֝צָ֗ה לְנֶ֣גֶד יְהוָֽה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.21.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 21:31",
      "text": "ס֗וּס מ֭וּכָן לְי֣וֹם מִלְחָמָ֑ה וְ֝לַֽיהוָ֗ה הַתְּשׁוּעָֽה ׃",
      "paragraphStart": false
    }
  ]
}
