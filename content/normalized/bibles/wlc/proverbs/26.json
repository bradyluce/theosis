{
  "chapter": {
    "id": "wlc:proverbs.26",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 26,
    "referenceLabel": "Proverbs 26",
    "summary": "Source text for Proverbs 26 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.26.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 26:1",
      "text": "כַּשֶּׁ֤לֶג ׀ בַּקַּ֗יִץ וְכַמָּטָ֥ר בַּקָּצִ֑יר כֵּ֤ן לֹא ־ נָאוֶ֖ה לִכְסִ֣יל כָּבֽוֹד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.26.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 26:2",
      "text": "כַּצִּפּ֣וֹר לָ֭נוּד כַּדְּר֣וֹר לָע֑וּף כֵּ֥ן קִֽלְלַ֥ת חִ֝נָּ֗ם לא תָבֹֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 26:3",
      "text": "שׁ֣וֹט לַ֭סּוּס מֶ֣תֶג לַחֲמ֑וֹר וְ֝שֵׁ֗בֶט לְגֵ֣ו כְּסִילִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 26:4",
      "text": "אַל ־ תַּ֣עַן כְּ֭סִיל כְּאִוַּלְתּ֑וֹ פֶּֽן ־ תִּשְׁוֶה ־ לּ֥וֹ גַם ־ אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 26:5",
      "text": "עֲנֵ֣ה כְ֭סִיל כְּאִוַּלְתּ֑וֹ פֶּן ־ יִהְיֶ֖ה חָכָ֣ם בְּעֵינָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 26:6",
      "text": "מְקַצֶּ֣ה רַ֭גְלַיִם חָמָ֣ס שֹׁתֶ֑ה שֹׁלֵ֖חַ דְּבָרִ֣ים בְּיַד ־ כְּסִֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 26:7",
      "text": "דַּלְי֣וּ שֹׁ֭קַיִם מִפִּסֵּ֑חַ וּ֝מָשָׁ֗ל בְּפִ֣י כְסִילִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 26:8",
      "text": "כִּצְר֣וֹר אֶ֭בֶן בְּמַרְגֵּמָ֑ה כֵּן ־ נוֹתֵ֖ן לִכְסִ֣יל כָּבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 26:9",
      "text": "ח֭וֹחַ עָלָ֣ה בְיַד ־ שִׁכּ֑וֹר וּ֝מָשָׁ֗ל בְּפִ֣י כְסִילִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 26:10",
      "text": "רַ֥ב מְחֽוֹלֵֽל ־ כֹּ֑ל וְשֹׂכֵ֥ר כְּ֝סִ֗יל וְשֹׂכֵ֥ר עֹבְרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 26:11",
      "text": "כְּ֭כֶלֶב שָׁ֣ב עַל ־ קֵא֑וֹ כְּ֝סִ֗יל שׁוֹנֶ֥ה בְאִוַּלְתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 26:12",
      "text": "רָאִ֗יתָ אִ֭ישׁ חָכָ֣ם בְּעֵינָ֑יו תִּקְוָ֖ה לִכְסִ֣יל מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 26:13",
      "text": "אָמַ֣ר עָ֭צֵל שַׁ֣חַל בַּדָּ֑רֶךְ אֲ֝רִ֗י בֵּ֣ין הָרְחֹבֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 26:14",
      "text": "הַ֭דֶּלֶת תִּסּ֣וֹב עַל ־ צִירָ֑הּ וְ֝עָצֵ֗ל עַל ־ מִטָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 26:15",
      "text": "טָ֘מַ֤ן עָצֵ֣ל יָ֭דוֹ בַּצַּלָּ֑חַת נִ֝לְאָ֗ה לַֽהֲשִׁיבָ֥הּ אֶל ־ פִּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 26:16",
      "text": "חָכָ֣ם עָצֵ֣ל בְּעֵינָ֑יו מִ֝שִּׁבְעָ֗ה מְשִׁ֣יבֵי טָֽעַם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 26:17",
      "text": "מַחֲזִ֥יק בְּאָזְנֵי ־ כָ֑לֶב עֹבֵ֥ר מִ֝תְעַבֵּ֗ר עַל ־ רִ֥יב לֹּֽא ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 26:18",
      "text": "כְּֽ֭מִתְלַהְלֵהַּ הַיֹּרֶ֥ה זִקִּ֗ים חִצִּ֥ים וָמָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 26:19",
      "text": "כֵּֽן ־ אִ֭ישׁ רִמָּ֣ה אֶת ־ רֵעֵ֑הוּ וְ֝אָמַ֗ר הֲֽלֹא ־ מְשַׂחֵ֥ק אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 26:20",
      "text": "בְּאֶ֣פֶס עֵ֭צִים תִּכְבֶּה ־ אֵ֑שׁ וּבְאֵ֥ין נִ֝רְגָּ֗ן יִשְׁתֹּ֥ק מָדֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 26:21",
      "text": "פֶּחָ֣ם לְ֭גֶחָלִים וְעֵצִ֣ים לְאֵ֑שׁ וְאִ֥ישׁ מדונים לְחַרְחַר ־ רִֽיב ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 26:22",
      "text": "דִּבְרֵ֣י נִ֭רְגָּן כְּמִֽתְלַהֲמִ֑ים וְ֝הֵ֗ם יָרְד֥וּ חַדְרֵי ־ בָֽטֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 26:23",
      "text": "כֶּ֣סֶף סִ֭יגִים מְצֻפֶּ֣ה עַל ־ חָ֑רֶשׂ שְׂפָתַ֖יִם דֹּלְקִ֣ים וְלֶב ־ רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 26:24",
      "text": "בשפתו יִנָּכֵ֣ר שׂוֹנֵ֑א וּ֝בְקִרְבּ֗וֹ יָשִׁ֥ית מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 26:25",
      "text": "כִּֽי ־ יְחַנֵּ֣ן ק֭וֹלוֹ אַל ־ תַּֽאֲמֶן ־ בּ֑וֹ כִּ֤י שֶׁ֖בַע תּוֹעֵב֣וֹת בְּלִבּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 26:26",
      "text": "תִּכַּסֶּ֣ה שִׂ֭נְאָה בְּמַשָּׁא֑וֹן תִּגָּלֶ֖ה רָעָת֣וֹ בְקָהָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 26:27",
      "text": "כֹּֽרֶה ־ שַּׁ֭חַת בָּ֣הּ יִפֹּ֑ל וְגֹ֥לֵ֥ל אֶ֝בֶן אֵלָ֥יו תָּשֽׁוּב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.26.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 26:28",
      "text": "לְֽשׁוֹן ־ שֶׁ֭קֶר יִשְׂנָ֣א דַכָּ֑יו וּפֶ֥ה חָ֝לָ֗ק יַעֲשֶׂ֥ה מִדְחֶֽה ׃",
      "paragraphStart": false
    }
  ]
}
