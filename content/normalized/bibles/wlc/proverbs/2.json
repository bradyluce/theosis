{
  "chapter": {
    "id": "wlc:proverbs.2",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 2,
    "referenceLabel": "Proverbs 2",
    "summary": "Source text for Proverbs 2 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.2.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 2:1",
      "text": "בְּ֭נִי אִם ־ תִּקַּ֣ח אֲמָרָ֑י וּ֝מִצְוֺתַ֗י תִּצְפֹּ֥ן אִתָּֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.2.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 2:2",
      "text": "לְהַקְשִׁ֣יב לַֽחָכְמָ֣ה אָזְנֶ֑ךָ תַּטֶּ֥ה לִ֝בְּךָ֗ לַתְּבוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 2:3",
      "text": "כִּ֤י אִ֣ם לַבִּינָ֣ה תִקְרָ֑א לַ֝תְּבוּנָ֗ה תִּתֵּ֥ן קוֹלֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 2:4",
      "text": "אִם ־ תְּבַקְשֶׁ֥נָּה כַכָּ֑סֶף וְֽכַמַּטְמוֹנִ֥ים תַּחְפְּשֶֽׂנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 2:5",
      "text": "אָ֗ז תָּ֭בִין יִרְאַ֣ת יְהוָ֑ה וְדַ֖עַת אֱלֹהִ֣ים תִּמְצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 2:6",
      "text": "כִּֽי ־ יְ֭הוָה יִתֵּ֣ן חָכְמָ֑ה מִ֝פִּ֗יו דַּ֣עַת וּתְבוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 2:7",
      "text": "וצפן לַ֭יְשָׁרִים תּוּשִׁיָּ֑ה מָ֝גֵ֗ן לְהֹ֣לְכֵי תֹֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 2:8",
      "text": "לִ֭נְצֹר אָרְח֣וֹת מִשְׁפָּ֑ט וְדֶ֖רֶךְ חסידו יִשְׁמֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 2:9",
      "text": "אָ֗ז תָּ֭בִין צֶ֣דֶק וּמִשְׁפָּ֑ט וּ֝מֵישָׁרִ֗ים כָּל ־ מַעְגַּל ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 2:10",
      "text": "כִּֽי ־ תָב֣וֹא חָכְמָ֣ה בְלִבֶּ֑ךָ וְ֝דַ֗עַת לְֽנַפְשְׁךָ֥ יִנְעָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 2:11",
      "text": "מְ֭זִמָּה תִּשְׁמֹ֥ר עָלֶ֗יךָ תְּבוּנָ֥ה תִנְצְרֶֽכָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 2:12",
      "text": "לְ֭הַצִּ֣ילְךָ מִדֶּ֣רֶךְ רָ֑ע מֵ֝אִ֗ישׁ מְדַבֵּ֥ר תַּהְפֻּכֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 2:13",
      "text": "הַ֭עֹ֣זְבִים אָרְח֣וֹת יֹ֑שֶׁר לָ֝לֶ֗כֶת בְּדַרְכֵי ־ חֹֽשֶׁךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 2:14",
      "text": "הַ֭שְּׂמֵחִים לַעֲשׂ֥וֹת רָ֑ע יָ֝גִ֗ילוּ בְּֽתַהְפֻּכ֥וֹת רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 2:15",
      "text": "אֲשֶׁ֣ר אָרְחֹתֵיהֶ֣ם עִקְּשִׁ֑ים וּ֝נְלוֹזִ֗ים בְּמַעְגְּלוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 2:16",
      "text": "לְ֭הַצִּ֣ילְךָ מֵאִשָּׁ֣ה זָרָ֑ה מִ֝נָּכְרִיָּ֗ה אֲמָרֶ֥יהָ הֶחֱלִֽיקָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 2:17",
      "text": "הַ֭עֹזֶבֶת אַלּ֣וּף נְעוּרֶ֑יהָ וְאֶת ־ בְּרִ֖ית אֱלֹהֶ֣יהָ שָׁכֵֽחָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 2:18",
      "text": "כִּ֤י שָׁ֣חָה אֶל ־ מָ֣וֶת בֵּיתָ֑הּ וְאֶל ־ רְ֝פָאִ֗ים מַעְגְּלֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 2:19",
      "text": "כָּל ־ בָּ֭אֶיהָ לֹ֣א יְשׁוּב֑וּן וְלֹֽא ־ יַ֝שִּׂ֗יגוּ אָרְח֥וֹת חַיִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 2:20",
      "text": "לְמַ֗עַן תֵּ֭לֵךְ בְּדֶ֣רֶךְ טוֹבִ֑ים וְאָרְח֖וֹת צַדִּיקִ֣ים תִּשְׁמֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 2:21",
      "text": "כִּֽי ־ יְשָׁרִ֥ים יִשְׁכְּנוּ אָ֑רֶץ וּ֝תְמִימִ֗ים יִוָּ֥תְרוּ בָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.2.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 2:22",
      "text": "וּ֭רְשָׁעִים מֵאֶ֣רֶץ יִכָּרֵ֑תוּ וּ֝בוֹגְדִ֗ים יִסְּח֥וּ מִמֶּֽנָּה ׃ פ",
      "paragraphStart": false
    }
  ]
}
