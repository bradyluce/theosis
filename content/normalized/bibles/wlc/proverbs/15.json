{
  "chapter": {
    "id": "wlc:proverbs.15",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.15.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "מַֽעֲנֶה ־ רַּ֭ךְ יָשִׁ֣יב חֵמָ֑ה וּדְבַר ־ עֶ֝֗צֶב יַעֲלֶה ־ אָֽף ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.15.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "לְשׁ֣וֹן חֲ֭כָמִים תֵּיטִ֣יב דָּ֑עַת וּפִ֥י כְ֝סִילִ֗ים יַבִּ֥יעַ אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "בְּֽכָל ־ מָ֭קוֹם עֵינֵ֣י יְהוָ֑ה צֹ֝פ֗וֹת רָעִ֥ים וטוֹבִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "מַרְפֵּ֣א לָ֭שׁוֹן עֵ֣ץ חַיִּ֑ים וְסֶ֥לֶף בָּ֝֗הּ שֶׁ֣בֶר בְּרֽוּחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "אֱוִ֗יל יִ֭נְאַץ מוּסַ֣ר אָבִ֑יו וְשֹׁמֵ֖ר תּוֹכַ֣חַת יַעְרִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "בֵּ֣ית צַ֭דִּיק חֹ֣סֶן רָ֑ב וּבִתְבוּאַ֖ת רָשָׁ֣ע נֶעְכָּֽרֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "שִׂפְתֵ֣י חֲ֭כָמִים יְזָ֣רוּ דָ֑עַת וְלֵ֖ב כְּסִילִ֣ים לֹא ־ כֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "זֶ֣בַח רְ֭שָׁעִים תּוֹעֲבַ֣ת יְהוָ֑ה וּתְפִלַּ֖ת יְשָׁרִ֣ים רְצוֹנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "תּוֹעֲבַ֣ת יְ֭הוָה דֶּ֣רֶךְ רָשָׁ֑ע וּמְרַדֵּ֖ף צְדָקָ֣ה יֶאֱהָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "מוּסָ֣ר רָ֭ע לְעֹזֵ֣ב אֹ֑רַח שׂוֹנֵ֖א תוֹכַ֣חַת יָמֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "שְׁא֣וֹל וַ֭אֲבַדּוֹן נֶ֣גֶד יְהוָ֑ה אַ֝֗ף כִּֽי ־ לִבּ֥וֹת בְּֽנֵי ־ אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "לֹ֣א יֶאֱהַב ־ לֵ֭ץ הוֹכֵ֣חַֽ ל֑וֹ אֶל ־ חֲ֝כָמִ֗ים לֹ֣א יֵלֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "לֵ֣ב שָׂ֭מֵחַ יֵיטִ֣ב פָּנִ֑ים וּבְעַצְּבַת ־ לֵ֝ב ר֣וּחַ נְכֵאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "לֵ֣ב נָ֭בוֹן יְבַקֶּשׁ ־ דָּ֑עַת ופני כְ֝סִילִ֗ים יִרְעֶ֥ה אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "כָּל ־ יְמֵ֣י עָנִ֣י רָעִ֑ים וְטֽוֹב ־ לֵ֝֗ב מִשְׁתֶּ֥ה תָמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "טוֹב ־ מְ֭עַט בְּיִרְאַ֣ת יְהוָ֑ה מֵאוֹצָ֥ר רָ֝֗ב וּמְה֥וּמָה בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "ט֤וֹב אֲרֻחַ֣ת יָ֭רָק וְאַהֲבָה ־ שָׁ֑ם מִשּׁ֥וֹר אָ֝ב֗וּס וְשִׂנְאָה ־ בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "אִ֣ישׁ חֵ֭מָה יְגָרֶ֣ה מָד֑וֹן וְאֶ֥רֶך אַ֝פַּ֗יִם יַשְׁקִ֥יט רִֽיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "דֶּ֣רֶךְ עָ֭צֵל כִּמְשֻׂ֣כַת חָ֑דֶק וְאֹ֖רַח יְשָׁרִ֣ים סְלֻלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "בֵּ֣ן חָ֭כָם יְשַׂמַּח ־ אָ֑ב וּכְסִ֥יל אָ֝דָ֗ם בּוֹזֶ֥ה אִמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "אִ֭וֶּלֶת שִׂמְחָ֣ה לַחֲסַר ־ לֵ֑ב וְאִ֥ישׁ תְּ֝בוּנָ֗ה יְיַשֶׁר ־ לָֽכֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "הָפֵ֣ר מַ֭חֲשָׁבוֹת בְּאֵ֣ין ס֑וֹד וּבְרֹ֖ב יוֹעֲצִ֣ים תָּקֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "שִׂמְחָ֣ה לָ֭אִישׁ בְּמַעֲנֵה ־ פִ֑יו וְדָבָ֖ר בְּעִתּ֣וֹ מַה ־ טּֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "אֹ֣רַח חַ֭יִּים לְמַ֣עְלָה לְמַשְׂכִּ֑יל לְמַ֥עַן ס֝֗וּר מִשְּׁא֥וֹל מָֽטָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "בֵּ֣ית גֵּ֭אִים יִסַּ֥ח ׀ יְהוָ֑ה וְ֝יַצֵּ֗ב גְּב֣וּל אַלְמָנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "תּוֹעֲבַ֣ת יְ֭הוָה מַחְשְׁב֣וֹת רָ֑ע וּ֝טְהֹרִ֗ים אִמְרֵי ־ נֹֽעַם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "עֹכֵ֣ר בֵּ֭יתוֹ בּוֹצֵ֣עַ בָּ֑צַע וְשׂוֹנֵ֖א מַתָּנֹ֣ת יִחְיֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "לֵ֣ב צַ֭דִּיק יֶהְגֶּ֣ה לַעֲנ֑וֹת וּפִ֥י רְ֝שָׁעִ֗ים יַבִּ֥יעַ רָעֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "רָח֣וֹק יְ֭הוָה מֵרְשָׁעִ֑ים וּתְפִלַּ֖ת צַדִּיקִ֣ים יִשְׁמָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "מְֽאוֹר ־ עֵ֭ינַיִם יְשַׂמַּֽח ־ לֵ֑ב שְׁמוּעָ֥ה ט֝וֹבָ֗ה תְּדַשֶּׁן ־ עָֽצֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "אֹ֗זֶן שֹׁ֭מַעַת תּוֹכַ֣חַת חַיִּ֑ים בְּקֶ֖רֶב חֲכָמִ֣ים תָּלִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "פּוֹרֵ֣עַ מ֭וּסָר מוֹאֵ֣ס נַפְשׁ֑וֹ וְשׁוֹמֵ֥עַ תּ֝וֹכַ֗חַת ק֣וֹנֶה לֵּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.15.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "יִרְאַ֣ת יְ֭הוָה מוּסַ֣ר חָכְמָ֑ה וְלִפְנֵ֖י כָב֣וֹד עֲנָוָֽה ׃",
      "paragraphStart": false
    }
  ]
}
