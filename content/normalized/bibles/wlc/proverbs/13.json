{
  "chapter": {
    "id": "wlc:proverbs.13",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.13.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "בֵּ֣ן חָ֭כָם מ֣וּסַר אָ֑ב וְ֝לֵ֗ץ לֹא ־ שָׁמַ֥ע גְּעָרָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.13.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "מִפְּרִ֣י פִי ־ אִ֭ישׁ יֹ֣אכַל ט֑וֹב וְנֶ֖פֶשׁ בֹּגְדִ֣ים חָמָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "נֹצֵ֣ר פִּ֭יו שֹׁמֵ֣ר נַפְשׁ֑וֹ פֹּשֵׂ֥ק שְׂ֝פָתָ֗יו מְחִתָּה ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "מִתְאַוָּ֣ה וָ֭אַיִן נַפְשׁ֣וֹ עָצֵ֑ל וְנֶ֖פֶשׁ חָרֻצִ֣ים תְּדֻשָּֽׁן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "דְּבַר ־ שֶׁ֭קֶר יִשְׂנָ֣א צַדִּ֑יק וְ֝רָשָׁ֗ע יַבְאִ֥ישׁ וְיַחְפִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "צְ֭דָקָה תִּצֹּ֣ר תָּם ־ דָּ֑רֶךְ וְ֝רִשְׁעָ֗ה תְּסַלֵּ֥ף חַטָּֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "יֵ֣שׁ מִ֭תְעַשֵּׁר וְאֵ֣ין כֹּ֑ל מִ֝תְרוֹשֵׁ֗שׁ וְה֣וֹן רָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "כֹּ֣פֶר נֶֽפֶשׁ ־ אִ֣ישׁ עָשְׁר֑וֹ וְ֝רָ֗שׁ לֹא ־ שָׁמַ֥ע גְּעָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "אוֹר ־ צַדִּיקִ֥ים יִשְׂמָ֑ח וְנֵ֖ר רְשָׁעִ֣ים יִדְעָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "רַק ־ בְּ֭זָדוֹן יִתֵּ֣ן מַצָּ֑ה וְאֶת ־ נ֖וֹעָצִ֣ים חָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "ה֭וֹן מֵהֶ֣בֶל יִמְעָ֑ט וְקֹבֵ֖ץ עַל ־ יָ֣ד יַרְבֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "תּוֹחֶ֣לֶת מְ֭מֻשָּׁכָה מַחֲלָה ־ לֵ֑ב וְעֵ֥ץ חַ֝יִּ֗ים תַּאֲוָ֥ה בָאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "בָּ֣ז לְ֭דָבָר יֵחָ֣בֶל ל֑וֹ וִירֵ֥א מִ֝צְוָ֗ה ה֣וּא יְשֻׁלָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "תּוֹרַ֣ת חָ֭כָם מְק֣וֹר חַיִּ֑ים לָ֝ס֗וּר מִמֹּ֥קְשֵׁי מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "שֵֽׂכֶל ־ ט֭וֹב יִתֶּן ־ חֵ֑ן וְדֶ֖רֶךְ בֹּגְדִ֣ים אֵיתָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "כָּל ־ עָ֭רוּם יַעֲשֶׂ֣ה בְדָ֑עַת וּ֝כְסִ֗יל יִפְרֹ֥שׂ אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "מַלְאָ֣ךְ רָ֭שָׁע יִפֹּ֣ל בְּרָ֑ע וְצִ֖יר אֱמוּנִ֣ים מַרְפֵּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "רֵ֣ישׁ וְ֭קָלוֹן פּוֹרֵ֣עַ מוּסָ֑ר וְשׁוֹמֵ֖ר תּוֹכַ֣חַת יְכֻבָּֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "תַּאֲוָ֣ה נִ֭הְיָה תֶּעֱרַ֣ב לְנָ֑פֶשׁ וְתוֹעֲבַ֥ת כְּ֝סִילִ֗ים ס֣וּר מֵרָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "הלוך אֶת ־ חֲכָמִ֣ים וחכם וְרֹעֶ֖ה כְסִילִ֣ים יֵרֽוֹעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "חַ֭טָּאִים תְּרַדֵּ֣ף רָעָ֑ה וְאֶת ־ צַ֝דִּיקִ֗ים יְשַׁלֶּם ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "ט֗וֹב יַנְחִ֥יל בְּנֵֽי ־ בָנִ֑ים וְצָפ֥וּן לַ֝צַּדִּ֗יק חֵ֣יל חוֹטֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "רָב ־ אֹ֭כֶל נִ֣יר רָאשִׁ֑ים וְיֵ֥שׁ נִ֝סְפֶּ֗ה בְּלֹ֣א מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "חוֹשֵׂ֣ךְ שִׁ֭בְטוֹ שׂוֹנֵ֣א בְנ֑וֹ וְ֝אֹהֲב֗וֹ שִֽׁחֲר֥וֹ מוּסָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.13.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "צַדִּ֗יק אֹ֭כֵל לְשֹׂ֣בַע נַפְשׁ֑וֹ וּבֶ֖טֶן רְשָׁעִ֣ים תֶּחְסָֽר ׃ פ",
      "paragraphStart": false
    }
  ]
}
