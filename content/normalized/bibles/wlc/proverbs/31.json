{
  "chapter": {
    "id": "wlc:proverbs.31",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 31,
    "referenceLabel": "Proverbs 31",
    "summary": "Source text for Proverbs 31 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.31.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 31:1",
      "text": "דִּ֭בְרֵי לְמוּאֵ֣ל מֶ֑לֶךְ מַ֝שָּׂ֗א אֲֽשֶׁר ־ יִסְּרַ֥תּוּ אִמּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.31.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 31:2",
      "text": "מַה ־ בְּ֭רִי וּמַֽה ־ בַּר ־ בִּטְנִ֑י וּ֝מֶה בַּר ־ נְדָרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 31:3",
      "text": "אַל ־ תִּתֵּ֣ן לַנָּשִׁ֣ים חֵילֶ֑ךָ וּ֝דְרָכֶ֗יךָ לַֽמְח֥וֹת מְלָכִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 31:4",
      "text": "אַ֤ל לַֽמְלָכִ֨ים ׀ לְֽמוֹאֵ֗ל אַ֣ל לַֽמְלָכִ֣ים שְׁתוֹ ־ יָ֑יִן וּ֝לְרוֹזְנִ֗ים או שֵׁכָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 31:5",
      "text": "פֶּן ־ יִ֭שְׁתֶּה וְיִשְׁכַּ֣ח מְחֻקָּ֑ק וִֽ֝ישַׁנֶּה דִּ֣ין כָּל ־ בְּנֵי ־ עֹֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 31:6",
      "text": "תְּנוּ ־ שֵׁכָ֣ר לְאוֹבֵ֑ד וְ֝יַיִן לְמָ֣רֵי נָֽפֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 31:7",
      "text": "יִ֭שְׁתֶּה וְיִשְׁכַּ֣ח רִישׁ֑וֹ וַ֝עֲמָל֗וֹ לֹ֣א יִזְכָּר ־ עֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 31:8",
      "text": "פְּתַח ־ פִּ֥יךָ לְאִלֵּ֑ם אֶל ־ דִּ֝֗ין כָּל ־ בְּנֵ֥י חֲלֽוֹף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 31:9",
      "text": "פְּתַח ־ פִּ֥יךָ שְׁפָט ־ צֶ֑דֶק וְ֝דִ֗ין עָנִ֥י וְאֶבְיֽוֹן ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 31:10",
      "text": "אֵֽשֶׁת ־ חַ֭יִל מִ֣י יִמְצָ֑א וְרָחֹ֖ק מִפְּנִינִ֣ים מִכְרָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 31:11",
      "text": "בָּ֣טַח בָּ֭הּ לֵ֣ב בַּעְלָ֑הּ וְ֝שָׁלָ֗ל לֹ֣א יֶחְסָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 31:12",
      "text": "גְּמָלַ֣תְהוּ ט֣וֹב וְלֹא ־ רָ֑ע כֹּ֝֗ל יְמֵ֣י חַיֶּֽיה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 31:13",
      "text": "דָּ֭רְשָׁה צֶ֣מֶר וּפִשְׁתִּ֑ים וַ֝תַּ֗עַשׂ בְּחֵ֣פֶץ כַּפֶּֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 31:14",
      "text": "הָ֭יְתָה כָּאֳנִיּ֣וֹת סוֹחֵ֑ר מִ֝מֶּרְחָ֗ק תָּבִ֥יא לַחְמָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 31:15",
      "text": "וַתָּ֤קָם ׀ בְּע֬וֹד לַ֗יְלָה וַתִּתֵּ֣ן טֶ֣רֶף לְבֵיתָ֑הּ וְ֝חֹ֗ק לְנַעֲרֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 31:16",
      "text": "זָמְמָ֣ה שָׂ֭דֶה וַתִּקָּחֵ֑הוּ מִפְּרִ֥י כַ֝פֶּ֗יהָ נטע כָּֽרֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 31:17",
      "text": "חָֽגְרָ֣ה בְע֣וֹז מָתְנֶ֑יהָ וַ֝תְּאַמֵּ֗ץ זְרֹעוֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 31:18",
      "text": "טָ֭עֲמָה כִּי ־ ט֣וֹב סַחְרָ֑הּ לֹֽא ־ יִכְבֶּ֖ה בליל נֵרָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 31:19",
      "text": "יָ֭דֶיהָ שִׁלְּחָ֣ה בַכִּישׁ֑וֹר וְ֝כַפֶּ֗יהָ תָּ֣מְכוּ פָֽלֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 31:20",
      "text": "כַּ֭פָּהּ פָּרְשָׂ֣ה לֶעָנִ֑י וְ֝יָדֶ֗יהָ שִׁלְּחָ֥ה לָֽאֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 31:21",
      "text": "לֹא ־ תִירָ֣א לְבֵיתָ֣הּ מִשָּׁ֑לֶג כִּ֥י כָל ־ בֵּ֝יתָ֗הּ לָבֻ֥שׁ שָׁנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 31:22",
      "text": "מַרְבַדִּ֥ים עָֽשְׂתָה ־ לָּ֑הּ שֵׁ֖שׁ וְאַרְגָּמָ֣ן לְבוּשָֽׁהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 31:23",
      "text": "נוֹדָ֣ע בַּשְּׁעָרִ֣ים בַּעְלָ֑הּ בְּ֝שִׁבְתּ֗וֹ עִם ־ זִקְנֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 31:24",
      "text": "סָדִ֣ין עָ֭שְׂתָה וַתִּמְכֹּ֑ר וַ֝חֲג֗וֹר נָתְנָ֥ה לַֽכְּנַעֲנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 31:25",
      "text": "עֹז ־ וְהָדָ֥ר לְבוּשָׁ֑הּ וַ֝תִּשְׂחַ֗ק לְי֣וֹם אַחֲרֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 31:26",
      "text": "פִּ֭יהָ פָּתְחָ֣ה בְחָכְמָ֑ה וְתֽוֹרַת ־ חֶ֝֗סֶד עַל ־ לְשׁוֹנָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 31:27",
      "text": "צ֭וֹפִיָּה הֲלִיכ֣וֹת בֵּיתָ֑הּ וְלֶ֥חֶם עַ֝צְל֗וּת לֹ֣א תֹאכֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 31:28",
      "text": "קָ֣מוּ בָ֭נֶיהָ וַֽיְאַשְּׁר֑וּהָ בַּ֝עְלָ֗הּ וַֽיְהַֽלְלָהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 31:29",
      "text": "רַבּ֣וֹת בָּ֭נוֹת עָ֣שׂוּ חָ֑יִל וְ֝אַ֗תְּ עָלִ֥ית עַל ־ כֻּלָּֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 31:30",
      "text": "שֶׁ֣קֶר הַ֭חֵן וְהֶ֣בֶל הַיֹּ֑פִי אִשָּׁ֥ה יִרְאַת ־ יְ֝הוָ֗ה הִ֣יא תִתְהַלָּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.31.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 31:31",
      "text": "תְּנוּ ־ לָ֭הּ מִפְּרִ֣י יָדֶ֑יהָ וִֽיהַלְל֖וּהָ בַשְּׁעָרִ֣ים מַעֲשֶֽׂיהָ ׃",
      "paragraphStart": false
    }
  ]
}
