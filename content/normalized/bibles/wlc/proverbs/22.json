{
  "chapter": {
    "id": "wlc:proverbs.22",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 22,
    "referenceLabel": "Proverbs 22",
    "summary": "Source text for Proverbs 22 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.22.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 22:1",
      "text": "נִבְחָ֣ר שֵׁ֭ם מֵעֹ֣שֶׁר רָ֑ב מִכֶּ֥סֶף וּ֝מִזָּהָ֗ב חֵ֣ן טֽוֹב ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.22.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 22:2",
      "text": "עָשִׁ֣יר וָרָ֣שׁ נִפְגָּ֑שׁוּ עֹשֵׂ֖ה כֻלָּ֣ם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 22:3",
      "text": "עָר֤וּם ׀ רָאָ֣ה רָעָ֣ה ויסתר וּ֝פְתָיִ֗ים עָבְר֥וּ וְֽנֶעֱנָֽשׁוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 22:4",
      "text": "עֵ֣קֶב עֲ֭נָוָה יִרְאַ֣ת יְהוָ֑ה עֹ֖שֶׁר וְכָב֣וֹד וְחַיִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 22:5",
      "text": "צִנִּ֣ים פַּ֭חִים בְּדֶ֣רֶךְ עִקֵּ֑שׁ שׁוֹמֵ֥ר נַ֝פְשׁ֗וֹ יִרְחַ֥ק מֵהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 22:6",
      "text": "חֲנֹ֣ךְ לַ֭נַּעַר עַל ־ פִּ֣י דַרְכּ֑וֹ גַּ֥ם כִּֽי ־ יַ֝זְקִ֗ין לֹֽא ־ יָס֥וּר מִמֶּֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 22:7",
      "text": "עָ֭שִׁיר בְּרָשִׁ֣ים יִמְשׁ֑וֹל וְעֶ֥בֶד לֹ֝וֶ֗ה לְאִ֣ישׁ מַלְוֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 22:8",
      "text": "זוֹרֵ֣עַ עַ֭וְלָה יקצור ־ אָ֑וֶן וְשֵׁ֖בֶט עֶבְרָת֣וֹ יִכְלֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 22:9",
      "text": "טֽוֹב ־ עַ֭יִן ה֣וּא יְבֹרָ֑ךְ כִּֽי ־ נָתַ֖ן מִלַּחְמ֣וֹ לַדָּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 22:10",
      "text": "גָּ֣רֵֽשׁ לֵ֭ץ וְיֵצֵ֣א מָד֑וֹן וְ֝יִשְׁבֹּ֗ת דִּ֣ין וְקָלֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 22:11",
      "text": "אֹהֵ֥ב טהור ־ לֵ֑ב חֵ֥ן שְׂ֝פָתָ֗יו רֵעֵ֥הוּ מֶֽלֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 22:12",
      "text": "עֵינֵ֣י יְ֭הוָה נָ֣צְרוּ דָ֑עַת וַ֝יְסַלֵּ֗ף דִּבְרֵ֥י בֹגֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 22:13",
      "text": "אָמַ֣ר עָ֭צֵל אֲרִ֣י בַח֑וּץ בְּת֥וֹךְ רְ֝חֹב֗וֹת אֵֽרָצֵֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 22:14",
      "text": "שׁוּחָ֣ה עֲ֭מֻקָּה פִּ֣י זָר֑וֹת זְע֥וּם יְ֝הוָ֗ה יפול ־ שָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 22:15",
      "text": "אִ֭וֶּלֶת קְשׁוּרָ֣ה בְלֶב ־ נָ֑עַר שֵׁ֥בֶט מ֝וּסָ֗ר יַרְחִיקֶ֥נָּה מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 22:16",
      "text": "עֹ֣שֵֽׁק דָּ֭ל לְהַרְבּ֣וֹת ל֑וֹ נֹתֵ֥ן לְ֝עָשִׁ֗יר אַךְ ־ לְמַחְסֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 22:17",
      "text": "הַ֥ט אָזְנְךָ֗ וּ֭שְׁמַע דִּבְרֵ֣י חֲכָמִ֑ים וְ֝לִבְּךָ֗ תָּשִׁ֥ית לְדַעְתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 22:18",
      "text": "כִּֽי ־ נָ֭עִים כִּֽי ־ תִשְׁמְרֵ֣ם בְּבִטְנֶ֑ךָ יִכֹּ֥נוּ יַ֝חְדָּ֗ו עַל ־ שְׂפָתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 22:19",
      "text": "לִהְי֣וֹת בַּ֭יהוָה מִבְטַחֶ֑ךָ הוֹדַעְתִּ֖יךָ הַיּ֣וֹם אַף ־ אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 22:20",
      "text": "הֲלֹ֤א כָתַ֣בְתִּי לְ֭ךָ שלשום בְּמ֖וֹעֵצֹ֣ת וָדָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 22:21",
      "text": "לְהוֹדִֽיעֲךָ֗ קֹ֭שְׁטְ אִמְרֵ֣י אֱמֶ֑ת לְהָשִׁ֥יב אֲמָרִ֥ים אֱ֝מֶ֗ת לְשֹׁלְחֶֽיךָ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 22:22",
      "text": "אַֽל ־ תִּגְזָל ־ דָּ֭ל כִּ֣י דַל ־ ה֑וּא וְאַל ־ תְּדַכֵּ֖א עָנִ֣י בַשָּֽׁעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 22:23",
      "text": "כִּֽי ־ יְ֭הוָה יָרִ֣יב רִיבָ֑ם וְקָבַ֖ע אֶת ־ קֹבְעֵיהֶ֣ם נָֽפֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 22:24",
      "text": "אַל ־ תִּ֭תְרַע אֶת ־ בַּ֣עַל אָ֑ף וְאֶת ־ אִ֥ישׁ חֵ֝מוֹת לֹ֣א תָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 22:25",
      "text": "פֶּן ־ תֶּאֱלַ֥ף ארחתו וְלָקַחְתָּ֖ מוֹקֵ֣שׁ לְנַפְשֶֽׁךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 22:26",
      "text": "אַל ־ תְּהִ֥י בְתֹֽקְעֵי ־ כָ֑ף בַּ֝עֹרְבִ֗ים מַשָּׁאֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 22:27",
      "text": "אִם ־ אֵֽין ־ לְךָ֥ לְשַׁלֵּ֑ם לָ֥מָּה יִקַּ֥ח מִ֝שְׁכָּבְךָ֗ מִתַּחְתֶּֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 22:28",
      "text": "אַל ־ תַּ֭סֵּג גְּב֣וּל עוֹלָ֑ם אֲשֶׁ֖ר עָשׂ֣וּ אֲבוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.22.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 22:29",
      "text": "חָזִ֡יתָ אִ֤ישׁ ׀ מָ֘הִ֤יר בִּמְלַאכְתּ֗וֹ לִֽפְנֵֽי ־ מְלָכִ֥ים יִתְיַצָּ֑ב בַּל ־ יִ֝תְיַצֵּב לִפְנֵ֥י חֲשֻׁכִּֽים ׃ פ",
      "paragraphStart": false
    }
  ]
}
