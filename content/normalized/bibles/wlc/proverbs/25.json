{
  "chapter": {
    "id": "wlc:proverbs.25",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 25,
    "referenceLabel": "Proverbs 25",
    "summary": "Source text for Proverbs 25 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.25.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 25:1",
      "text": "גַּם ־ אֵ֭לֶּה מִשְׁלֵ֣י שְׁלֹמֹ֑ה אֲשֶׁ֥ר הֶ֝עְתִּ֗יקוּ אַנְשֵׁ֤י ׀ חִזְקִיָּ֬ה מֶֽלֶךְ ־ יְהוּדָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.25.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 25:2",
      "text": "כְּבֹ֣ד אֱ֭לֹהִים הַסְתֵּ֣ר דָּבָ֑ר וּכְבֹ֥ד מְ֝לָכִ֗ים חֲקֹ֣ר דָּבָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 25:3",
      "text": "שָׁמַ֣יִם לָ֭רוּם וָאָ֣רֶץ לָעֹ֑מֶק וְלֵ֥ב מְ֝לָכִ֗ים אֵ֣ין חֵֽקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 25:4",
      "text": "הָג֣וֹ סִיגִ֣ים מִכָּ֑סֶף וַיֵּצֵ֖א לַצֹּרֵ֣ף כֶּֽלִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 25:5",
      "text": "הָג֣וֹ רָ֭שָׁע לִפְנֵי ־ מֶ֑לֶךְ וְיִכּ֖וֹן בַּצֶּ֣דֶק כִּסְאֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 25:6",
      "text": "אַל ־ תִּתְהַדַּ֥ר לִפְנֵי ־ מֶ֑לֶךְ וּבִמְק֥וֹם גְּ֝דֹלִ֗ים אַֽל ־ תַּעֲמֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 25:7",
      "text": "כִּ֤י ט֥וֹב אֲמָר ־ לְךָ֗ עֲֽלֵ֫ה הֵ֥נָּה מֵֽ֭הַשְׁפִּ֣ילְךָ לִפְנֵ֣י נָדִ֑יב אֲשֶׁ֖ר רָא֣וּ עֵינֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 25:8",
      "text": "אַל ־ תֵּצֵ֥א לָרִ֗ב מַ֫הֵ֥ר פֶּ֣ן מַה ־ תַּ֭עֲשֶׂה בְּאַחֲרִיתָ֑הּ בְּהַכְלִ֖ים אֹתְךָ֣ רֵעֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 25:9",
      "text": "רִֽ֭יבְךָ רִ֣יב אֶת ־ רֵעֶ֑ךָ וְס֖וֹד אַחֵ֣ר אַל ־ תְּגָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 25:10",
      "text": "פֶּֽן ־ יְחַסֶּדְךָ֥ שֹׁמֵ֑עַ וְ֝דִבָּתְךָ֗ לֹ֣א תָשֽׁוּב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 25:11",
      "text": "תַּפּוּחֵ֣י זָ֭הָב בְּמַשְׂכִּיּ֥וֹת כָּ֑סֶף דָּ֝בָ֗ר דָּבֻ֥ר עַל ־ אָפְנָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 25:12",
      "text": "נֶ֣זֶם זָ֭הָב וַחֲלִי ־ כָ֑תֶם מוֹכִ֥יחַ חָ֝כָ֗ם עַל ־ אֹ֥זֶן שֹׁמָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 25:13",
      "text": "כְּצִנַּת ־ שֶׁ֨לֶג ׀ בְּי֬וֹם קָצִ֗יר צִ֣יר נֶ֭אֱמָן לְשֹׁלְחָ֑יו וְנֶ֖פֶשׁ אֲדֹנָ֣יו יָשִֽׁיב ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 25:14",
      "text": "נְשִׂיאִ֣ים וְ֭רוּחַ וְגֶ֣שֶׁם אָ֑יִן אִ֥ישׁ מִ֝תְהַלֵּ֗ל בְּמַתַּת ־ שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 25:15",
      "text": "בְּאֹ֣רֶךְ אַ֭פַּיִם יְפֻתֶּ֣ה קָצִ֑ין וְלָשׁ֥וֹן רַ֝כָּ֗ה תִּשְׁבָּר ־ גָּֽרֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 25:16",
      "text": "דְּבַ֣שׁ מָ֭צָאתָ אֱכֹ֣ל דַּיֶּ֑ךָּ פֶּן ־ תִּ֝שְׂבָּעֶ֗נּוּ וַהֲקֵֽאתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 25:17",
      "text": "הֹקַ֣ר רַ֭גְלְךָ מִבֵּ֣ית רֵעֶ֑ךָ פֶּן ־ יִ֝שְׂבָּעֲךָ֗ וּשְׂנֵאֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 25:18",
      "text": "מֵפִ֣יץ וְ֭חֶרֶב וְחֵ֣ץ שָׁנ֑וּן אִ֥ישׁ עֹנֶ֥ה בְ֝רֵעֵ֗הוּ עֵ֣ד שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 25:19",
      "text": "שֵׁ֣ן רֹ֭עָה וְרֶ֣גֶל מוּעָ֑דֶת מִבְטָ֥ח בּ֝וֹגֵ֗ד בְּי֣וֹם צָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 25:20",
      "text": "מַ֥עֲדֶה בֶּ֨גֶד ׀ בְּי֣וֹם קָ֭רָה חֹ֣מֶץ עַל ־ נָ֑תֶר וְשָׁ֥ר בַּ֝שִּׁרִ֗ים עַ֣ל לֶב ־ רָֽע ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 25:21",
      "text": "אִם ־ רָעֵ֣ב שֹׂ֭נַאֲךָ הַאֲכִלֵ֣הוּ לָ֑חֶם וְאִם ־ צָ֝מֵ֗א הַשְׁקֵ֥הוּ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 25:22",
      "text": "כִּ֤י גֶֽחָלִ֗ים אַ֭תָּה חֹתֶ֣ה עַל ־ רֹאשׁ֑וֹ וַֽ֝יהוָ֗ה יְשַׁלֶּם ־ לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 25:23",
      "text": "ר֣וּחַ צָ֭פוֹן תְּח֣וֹלֵֽל גָּ֑שֶׁם וּפָנִ֥ים נִ֝זְעָמִ֗ים לְשׁ֣וֹן סָֽתֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 25:24",
      "text": "ט֗וֹב שֶׁ֥בֶת עַל ־ פִּנַּת ־ גָּ֑ג מֵאֵ֥שֶׁת מדונים וּבֵ֥ית חָֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 25:25",
      "text": "מַ֣יִם קָ֭רִים עַל ־ נֶ֣פֶשׁ עֲיֵפָ֑ה וּשְׁמוּעָ֥ה ט֝וֹבָ֗ה מֵאֶ֥רֶץ מֶרְחָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 25:26",
      "text": "מַעְיָ֣ן נִ֭רְפָּשׂ וּמָק֣וֹר מָשְׁחָ֑ת צַ֝דִּ֗יק מָ֣ט לִפְנֵֽי ־ רָשָֽׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 25:27",
      "text": "אָ֘כֹ֤ל דְּבַ֣שׁ הַרְבּ֣וֹת לֹא ־ ט֑וֹב וְחֵ֖קֶר כְּבֹדָ֣ם כָּבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.25.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 25:28",
      "text": "עִ֣יר פְּ֭רוּצָה אֵ֣ין חוֹמָ֑ה אִ֝֗ישׁ אֲשֶׁ֤ר אֵ֖ין מַעְצָ֣ר לְרוּחֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
