{
  "chapter": {
    "id": "wlc:proverbs.10",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.10.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "מִשְׁלֵ֗י שְׁלֹ֫מֹ֥ה פ בֵּ֣ן חָ֭כָם יְשַׂמַּח ־ אָ֑ב וּבֵ֥ן כְּ֝סִ֗יל תּוּגַ֥ת אִמּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.10.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "לֹא ־ י֭וֹעִילוּ אוֹצְר֣וֹת רֶ֑שַׁע וּ֝צְדָקָ֗ה תַּצִּ֥יל מִמָּֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "לֹֽא ־ יַרְעִ֣יב יְ֭הוָה נֶ֣פֶשׁ צַדִּ֑יק וְהַוַּ֖ת רְשָׁעִ֣ים יֶהְדֹּֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "רָ֗אשׁ עֹשֶׂ֥ה כַף ־ רְמִיָּ֑ה וְיַ֖ד חָרוּצִ֣ים תַּעֲשִֽׁיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "אֹגֵ֣ר בַּ֭קַּיִץ בֵּ֣ן מַשְׂכִּ֑יל נִרְדָּ֥ם בַּ֝קָּצִ֗יר בֵּ֣ן מֵבִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "בְּ֭רָכוֹת לְרֹ֣אשׁ צַדִּ֑יק וּפִ֥י רְ֝שָׁעִ֗ים יְכַסֶּ֥ה חָמָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "זֵ֣כֶר צַ֭דִּיק לִבְרָכָ֑ה וְשֵׁ֖ם רְשָׁעִ֣ים יִרְקָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "חֲכַם ־ לֵ֭ב יִקַּ֣ח מִצְוֺ֑ת וֶאֱוִ֥יל שְׂ֝פָתַ֗יִם יִלָּבֵֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "הוֹלֵ֣ךְ בַּ֭תֹּם יֵ֣לֶךְ בֶּ֑טַח וּמְעַקֵּ֥שׁ דְּ֝רָכָ֗יו יִוָּדֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "קֹ֣רֵֽץ עַ֭יִן יִתֵּ֣ן עַצָּ֑בֶת וֶאֱוִ֥יל שְׂ֝פָתַ֗יִם יִלָּבֵֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "מְק֣וֹר חַ֭יִּים פִּ֣י צַדִּ֑יק וּפִ֥י רְ֝שָׁעִ֗ים יְכַסֶּ֥ה חָמָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "שִׂ֭נְאָה תְּעוֹרֵ֣ר מְדָנִ֑ים וְעַ֥ל כָּל ־ פְּ֝שָׁעִ֗ים תְּכַסֶּ֥ה אַהֲבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "בְּשִׂפְתֵ֣י נָ֭בוֹן תִּמָּצֵ֣א חָכְמָ֑ה וְ֝שֵׁ֗בֶט לְגֵ֣ו חֲסַר ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "חֲכָמִ֥ים יִצְפְּנוּ ־ דָ֑עַת וּפִֽי ־ אֱ֝וִיל מְחִתָּ֥ה קְרֹבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "ה֣וֹן עָ֭שִׁיר קִרְיַ֣ת עֻזּ֑וֹ מְחִתַּ֖ת דַּלִּ֣ים רֵישָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "פְּעֻלַּ֣ת צַדִּ֣יק לְחַיִּ֑ים תְּבוּאַ֖ת רָשָׁ֣ע לְחַטָּֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "אֹ֣רַח לְ֭חַיִּים שׁוֹמֵ֣ר מוּסָ֑ר וְעוֹזֵ֖ב תּוֹכַ֣חַת מַתְעֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "מְכַסֶּ֣ה שִׂ֭נְאָה שִׂפְתֵי ־ שָׁ֑קֶר וּמוֹצִ֥א דִ֝בָּ֗ה ה֣וּא כְסִֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "בְּרֹ֣ב דְּ֭בָרִים לֹ֣א יֶחְדַּל ־ פָּ֑שַׁע וְחֹשֵׂ֖ךְ שְׂפָתָ֣יו מַשְׂכִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "כֶּ֣סֶף נִ֭בְחָר לְשׁ֣וֹן צַדִּ֑יק לֵ֖ב רְשָׁעִ֣ים כִּמְעָֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "שִׂפְתֵ֣י צַ֭דִּיק יִרְע֣וּ רַבִּ֑ים וֶֽ֝אֱוִילִ֗ים בַּחֲסַר ־ לֵ֥ב יָמֽוּתוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "בִּרְכַּ֣ת יְ֭הוָה הִ֣יא תַעֲשִׁ֑יר וְלֹֽא ־ יוֹסִ֖ף עֶ֣צֶב עִמָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "כִּשְׂח֣וֹק לִ֭כְסִיל עֲשׂ֣וֹת זִמָּ֑ה וְ֝חָכְמָ֗ה לְאִ֣ישׁ תְּבוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "מְגוֹרַ֣ת רָ֭שָׁע הִ֣יא תְבוֹאֶ֑נּוּ וְתַאֲוַ֖ת צַדִּיקִ֣ים יִתֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "כַּעֲב֣וֹר ס֭וּפָה וְאֵ֣ין רָשָׁ֑ע וְ֝צַדִּ֗יק יְס֣וֹד עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "כַּחֹ֤מֶץ ׀ לַשִּׁנַּ֗יִם וְכֶעָשָׁ֥ן לָעֵינָ֑יִם כֵּ֥ן הֶ֝עָצֵ֗ל לְשֹׁלְחָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "יִרְאַ֣ת יְ֭הוָה תּוֹסִ֣יף יָמִ֑ים וּשְׁנ֖וֹת רְשָׁעִ֣ים תִּקְצֹֽרְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "תּוֹחֶ֣לֶת צַדִּיקִ֣ים שִׂמְחָ֑ה וְתִקְוַ֖ת רְשָׁעִ֣ים תֹּאבֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "מָע֣וֹז לַ֭תֹּם דֶּ֣רֶךְ יְהוָ֑ה וּ֝מְחִתָּ֗ה לְפֹ֣עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "צַדִּ֣יק לְעוֹלָ֣ם בַּל ־ יִמּ֑וֹט וּ֝רְשָׁעִ֗ים לֹ֣א יִשְׁכְּנוּ ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "פִּֽי ־ צַ֭דִּיק יָנ֣וּב חָכְמָ֑ה וּלְשׁ֥וֹן תַּ֝הְפֻּכ֗וֹת תִּכָּרֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.10.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "שִׂפְתֵ֣י צַ֭דִּיק יֵדְע֣וּן רָצ֑וֹן וּפִ֥י רְ֝שָׁעִ֗ים תַּהְפֻּכֽוֹת ׃",
      "paragraphStart": false
    }
  ]
}
