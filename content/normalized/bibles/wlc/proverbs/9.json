{
  "chapter": {
    "id": "wlc:proverbs.9",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.9.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "חָ֭כְמוֹת בָּנְתָ֣ה בֵיתָ֑הּ חָצְבָ֖ה עַמּוּדֶ֣יהָ שִׁבְעָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.9.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "טָבְחָ֣ה טִ֭בְחָהּ מָסְכָ֣ה יֵינָ֑הּ אַ֝֗ף עָֽרְכָ֥ה שֻׁלְחָנָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "שָֽׁלְחָ֣ה נַעֲרֹתֶ֣יהָ תִקְרָ֑א עַל ־ גַּ֝פֵּ֗י מְרֹ֣מֵי קָֽרֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "מִי ־ פֶ֭תִי יָסֻ֣ר הֵ֑נָּה חֲסַר ־ לֵ֝֗ב אָ֣מְרָה לּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "לְ֭כוּ לַחֲמ֣וּ בְֽלַחֲמִ֑י וּ֝שְׁת֗וּ בְּיַ֣יִן מָסָֽכְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "עִזְב֣וּ פְתָאיִ֣ם וִֽחְי֑וּ וְ֝אִשְׁר֗וּ בְּדֶ֣רֶךְ בִּינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "יֹ֤סֵ֨ר ׀ לֵ֗ץ לֹקֵ֣חַֽ ל֣וֹ קָל֑וֹן וּמוֹכִ֖יחַ לְרָשָׁ֣ע מוּמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "אַל ־ תּ֣וֹכַח לֵ֭ץ פֶּן ־ יִשְׂנָאֶ֑ךָּ הוֹכַ֥ח לְ֝חָכָ֗ם וְיֶאֱהָבֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "תֵּ֣ן לְ֭חָכָם וְיֶחְכַּם ־ ע֑וֹד הוֹדַ֥ע לְ֝צַדִּ֗יק וְי֣וֹסֶף לֶֽקַח ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "תְּחִלַּ֣ת חָ֭כְמָה יִרְאַ֣ת יְהוָ֑ה וְדַ֖עַת קְדֹשִׁ֣ים בִּינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "כִּי ־ בִ֭י יִרְבּ֣וּ יָמֶ֑יךָ וְיוֹסִ֥יפוּ לְּ֝ךָ֗ שְׁנ֣וֹת חַיִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "אִם ־ חָ֭כַמְתָּ חָכַ֣מְתָּ לָּ֑ךְ וְ֝לַ֗צְתָּ לְֽבַדְּךָ֥ תִשָּֽׂא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "אֵ֣שֶׁת כְּ֭סִילוּת הֹֽמִיָּ֑ה פְּ֝תַיּ֗וּת וּבַל ־ יָ֥דְעָה מָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "וְֽ֭יָשְׁבָה לְפֶ֣תַח בֵּיתָ֑הּ עַל ־ כִּ֝סֵּ֗א מְרֹ֣מֵי קָֽרֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "לִקְרֹ֥א לְעֹֽבְרֵי ־ דָ֑רֶךְ הַֽ֝מְיַשְּׁרִ֗ים אֹֽרְחוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "מִי ־ פֶ֭תִי יָסֻ֣ר הֵ֑נָּה וַחֲסַר ־ לֵ֝֗ב וְאָ֣מְרָה לּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "מַֽיִם ־ גְּנוּבִ֥ים יִמְתָּ֑קוּ וְלֶ֖חֶם סְתָרִ֣ים יִנְעָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.9.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "וְֽלֹא ־ יָ֭דַע כִּֽי ־ רְפָאִ֣ים שָׁ֑ם בְּעִמְקֵ֖י שְׁא֣וֹל קְרֻאֶֽיהָ ׃ פ",
      "paragraphStart": false
    }
  ]
}
