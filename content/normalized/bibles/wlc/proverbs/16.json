{
  "chapter": {
    "id": "wlc:proverbs.16",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.16.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "לְאָדָ֥ם מַֽעַרְכֵי ־ לֵ֑ב וּ֝מֵיְהוָ֗ה מַעֲנֵ֥ה לָשֽׁוֹן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.16.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 16:2",
      "text": "כָּֽל ־ דַּרְכֵי ־ אִ֭ישׁ זַ֣ךְ בְּעֵינָ֑יו וְתֹכֵ֖ן רוּח֣וֹת יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "גֹּ֣ל אֶל ־ יְהוָ֣ה מַעֲשֶׂ֑יךָ וְ֝יִכֹּ֗נוּ מַחְשְׁבֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 16:4",
      "text": "כֹּ֤ל פָּעַ֣ל יְ֭הוָה לַֽמַּעֲנֵ֑הוּ וְגַם ־ רָ֝שָׁ֗ע לְי֣וֹם רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 16:5",
      "text": "תּוֹעֲבַ֣ת יְ֭הוָה כָּל ־ גְּבַהּ ־ לֵ֑ב יָ֥ד לְ֝יָ֗ד לֹ֣א יִנָּקֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "בְּחֶ֣סֶד וֶ֭אֱמֶת יְכֻפַּ֣ר עָוֺ֑ן וּבְיִרְאַ֥ת יְ֝הוָ֗ה ס֣וּר מֵרָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 16:7",
      "text": "בִּרְצ֣וֹת יְ֭הוָה דַּרְכֵי ־ אִ֑ישׁ גַּם ־ א֝וֹיְבָ֗יו יַשְׁלִ֥ם אִתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "טוֹב ־ מְ֭עַט בִּצְדָקָ֑ה מֵרֹ֥ב תְּ֝בוּא֗וֹת בְּלֹ֣א מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "לֵ֣ב אָ֭דָם יְחַשֵּׁ֣ב דַּרְכּ֑וֹ וַֽ֝יהוָ֗ה יָכִ֥ין צַעֲדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "קֶ֤סֶם ׀ עַֽל ־ שִׂפְתֵי ־ מֶ֑לֶךְ בְּ֝מִשְׁפָּ֗ט לֹ֣א יִמְעַל ־ פִּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "פֶּ֤לֶס ׀ וּמֹאזְנֵ֣י מִ֭שְׁפָּט לַֽיהוָ֑ה מַ֝עֲשֵׂ֗הוּ כָּל ־ אַבְנֵי ־ כִֽיס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "תּוֹעֲבַ֣ת מְ֭לָכִים עֲשׂ֣וֹת רֶ֑שַׁע כִּ֥י בִ֝צְדָקָ֗ה יִכּ֥וֹן כִּסֵּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "רְצ֣וֹן מְ֭לָכִים שִׂפְתֵי ־ צֶ֑דֶק וְדֹבֵ֖ר יְשָׁרִ֣ים יֶאֱהָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "חֲמַת ־ מֶ֥לֶךְ מַלְאֲכֵי ־ מָ֑וֶת וְאִ֖ישׁ חָכָ֣ם יְכַפְּרֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "בְּאוֹר ־ פְּנֵי ־ מֶ֥לֶךְ חַיִּ֑ים וּ֝רְצוֹנ֗וֹ כְּעָ֣ב מַלְקֽוֹשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "קְֽנֹה ־ חָכְמָ֗ה מַה ־ טּ֥וֹב מֵחָר֑וּץ וּקְנ֥וֹת בִּ֝ינָ֗ה נִבְחָ֥ר מִכָּֽסֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "מְסִלַּ֣ת יְ֭שָׁרִים ס֣וּר מֵרָ֑ע שֹׁמֵ֥ר נַ֝פְשׁ֗וֹ נֹצֵ֥ר דַּרְכּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "לִפְנֵי ־ שֶׁ֥בֶר גָּא֑וֹן וְלִפְנֵ֥י כִ֝שָּׁל֗וֹן גֹּ֣בַהּ רֽוּחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "ט֣וֹב שְׁפַל ־ ר֭וּחַ אֶת ־ עניים מֵֽחַלֵּ֥ק שָׁ֝לָ֗ל אֶת ־ גֵּאִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "מַשְׂכִּ֣יל עַל ־ דָּ֭בָר יִמְצָא ־ ט֑וֹב וּבוֹטֵ֖חַ בַּיהוָ֣ה אַשְׁרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "לַחֲכַם ־ לֵ֭ב יִקָּרֵ֣א נָב֑וֹן וּמֶ֥תֶק שְׂ֝פָתַ֗יִם יֹסִ֥יף לֶֽקַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "מְק֣וֹר חַ֭יִּים שֵׂ֣כֶל בְּעָלָ֑יו וּמוּסַ֖ר אֱוִלִ֣ים אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "לֵ֣ב חָ֭כָם יַשְׂכִּ֣יל פִּ֑יהוּ וְעַל ־ שְׂ֝פָתָ֗יו יֹסִ֥יף לֶֽקַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "צוּף ־ דְּ֭בַשׁ אִמְרֵי ־ נֹ֑עַם מָת֥וֹק לַ֝נֶּפֶשׁ וּמַרְפֵּ֥א לָעָֽצֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "יֵ֤שׁ דֶּ֣רֶךְ יָ֭שָׁר לִפְנֵי ־ אִ֑ישׁ וְ֝אַחֲרִיתָ֗הּ דַּרְכֵי ־ מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "נֶ֣פֶשׁ עָ֭מֵל עָ֣מְלָה לּ֑וֹ כִּֽי ־ אָכַ֖ף עָלָ֣יו פִּֽיהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "אִ֣ישׁ בְּ֭לִיַּעַל כֹּרֶ֣ה רָעָ֑ה וְעַל ־ שפתיו כְּאֵ֣שׁ צָרָֽבֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "אִ֣ישׁ תַּ֭הְפֻּכוֹת יְשַׁלַּ֣ח מָד֑וֹן וְ֝נִרְגָּ֗ ן מַפְרִ֥יד אַלּֽוּף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "אִ֣ישׁ חָ֭מָס יְפַתֶּ֣ה רֵעֵ֑הוּ וְ֝הוֹלִיכ֗וֹ בְּדֶ֣רֶךְ לֹא ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "עֹצֶ֣ה עֵ֭ינָיו לַחְשֹׁ֣ב תַּהְפֻּכ֑וֹת קֹרֵ֥ץ שְׂ֝פָתָ֗יו כִּלָּ֥ה רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "עֲטֶ֣רֶת תִּפְאֶ֣רֶת שֵׂיבָ֑ה בְּדֶ֥רֶךְ צְ֝דָקָ֗ה תִּמָּצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "ט֤וֹב אֶ֣רֶךְ אַ֭פַּיִם מִגִּבּ֑וֹר וּמֹשֵׁ֥ל בְּ֝רוּח֗וֹ מִלֹּכֵ֥ד עִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.16.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "בַּ֭חֵיק יוּטַ֣ל אֶת ־ הַגּוֹרָ֑ל וּ֝מֵיְהוָ֗ה כָּל ־ מִשְׁפָּטֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
