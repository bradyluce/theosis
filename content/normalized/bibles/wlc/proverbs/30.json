{
  "chapter": {
    "id": "wlc:proverbs.30",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 30,
    "referenceLabel": "Proverbs 30",
    "summary": "Source text for Proverbs 30 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.30.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 30:1",
      "text": "דִּבְרֵ֤י ׀ אָג֥וּר בִּן ־ יָקֶ֗ה הַמַּ֫שָּׂ֥א נְאֻ֣ם הַ֭גֶּבֶר לְאִֽיתִיאֵ֑ל לְאִ֖יתִיאֵ֣ל וְאֻכָֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.30.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 30:2",
      "text": "כִּ֤י בַ֣עַר אָנֹכִ֣י מֵאִ֑ישׁ וְלֹֽא ־ בִינַ֖ת אָדָ֣ם לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 30:3",
      "text": "וְלֹֽא ־ לָמַ֥דְתִּי חָכְמָ֑ה וְדַ֖עַת קְדֹשִׁ֣ים אֵדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 30:4",
      "text": "מִ֤י עָלָֽה ־ שָׁמַ֨יִם ׀ וַיֵּרַ֡ד מִ֤י אָֽסַף ־ ר֨וּחַ ׀ בְּחָפְנָ֡יו מִ֤י צָֽרַר ־ מַ֨יִם ׀ בַּשִּׂמְלָ֗ה מִ֭י הֵקִ֣ים כָּל ־ אַפְסֵי ־ אָ֑רֶץ מַה ־ שְּׁמ֥וֹ וּמַֽה ־ שֶּׁם ־ בְּ֝נ֗וֹ כִּ֣י תֵדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 30:5",
      "text": "כָּל ־ אִמְרַ֣ת אֱל֣וֹהַּ צְרוּפָ֑ה מָגֵ֥ן ה֝֗וּא לַֽחֹסִ֥ים בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 30:6",
      "text": "אַל ־ תּ֥וֹסְףְּ עַל ־ דְּבָרָ֑יו פֶּן ־ יוֹכִ֖יחַ בְּךָ֣ וְנִכְזָֽבְתָּ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 30:7",
      "text": "שְׁ֭תַּיִם שָׁאַ֣לְתִּי מֵאִתָּ֑ךְ אַל ־ תִּמְנַ֥ע מִ֝מֶּ֗נִּי בְּטֶ֣רֶם אָמֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 30:8",
      "text": "שָׁ֤וְא ׀ וּֽדְבַר ־ כָּזָ֡ב הַרְחֵ֬ק מִמֶּ֗נִּי רֵ֣אשׁ וָ֭עֹשֶׁר אַל ־ תִּֽתֶּן ־ לִ֑י הַ֝טְרִיפֵ֗נִי לֶ֣חֶם חֻקִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 30:9",
      "text": "פֶּ֥ן אֶשְׂבַּ֨ע ׀ וְכִחַשְׁתִּי֮ וְאָמַ֗רְתִּי מִ֥י יְה֫וָ֥ה וּפֶֽן ־ אִוָּרֵ֥שׁ וְגָנַ֑בְתִּי וְ֝תָפַ֗שְׂתִּי שֵׁ֣ם אֱלֹהָֽי ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 30:10",
      "text": "אַל ־ תַּלְשֵׁ֣ן עֶ֭בֶד אֶל ־ אדנו פֶּֽן ־ יְקַלֶּלְךָ֥ וְאָשָֽׁמְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 30:11",
      "text": "דּ֭וֹר אָבִ֣יו יְקַלֵּ֑ל וְאֶת ־ אִ֝מּ֗וֹ לֹ֣א יְבָרֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 30:12",
      "text": "דּ֭וֹר טָה֣וֹר בְּעֵינָ֑יו וּ֝מִצֹּאָת֗וֹ לֹ֣א רֻחָֽץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 30:13",
      "text": "דּ֭וֹר מָה ־ רָמ֣וּ עֵינָ֑יו וְ֝עַפְעַפָּ֗יו יִנָּשֵֽׂאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 30:14",
      "text": "דּ֤וֹר ׀ חֲרָב֣וֹת שִׁנָּיו֮ וּֽמַאֲכָל֪וֹת מְֽתַלְּעֹ֫תָ֥יו לֶאֱכֹ֣ל עֲנִיִּ֣ים מֵאֶ֑רֶץ וְ֝אֶבְיוֹנִ֗ים מֵאָדָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 30:15",
      "text": "לַֽעֲלוּקָ֨ה ׀ שְׁתֵּ֥י בָנוֹת֮ הַ֤ב ׀ הַ֥ב שָׁל֣וֹשׁ הֵ֭נָּה לֹ֣א תִשְׂבַּ֑עְנָה אַ֝רְבַּ֗ע לֹא ־ אָ֥מְרוּ הֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 30:16",
      "text": "שְׁאוֹל֮ וְעֹ֪צֶ֫ר רָ֥חַם אֶ֭רֶץ לֹא ־ שָׂ֣בְעָה מַּ֑יִם וְ֝אֵ֗שׁ לֹא ־ אָ֥מְרָה הֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 30:17",
      "text": "עַ֤יִן ׀ תִּֽלְעַ֣ג לְאָב֮ וְתָב֪וּז לִֽיקֲּהַ֫ת ־ אֵ֥ם יִקְּר֥וּהָ עֹרְבֵי ־ נַ֑חַל וְֽיֹאכְל֥וּהָ בְנֵי ־ נָֽשֶׁר ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 30:18",
      "text": "שְׁלֹשָׁ֣ה הֵ֭מָּה נִפְלְא֣וּ מִמֶּ֑נִּי וארבע לֹ֣א יְדַעְתִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 30:19",
      "text": "דֶּ֤רֶךְ הַנֶּ֨שֶׁר ׀ בַּשָּׁמַיִם֮ דֶּ֥רֶךְ נָחָ֗שׁ עֲלֵ֫י צ֥וּר דֶּֽרֶךְ ־ אֳנִיָּ֥ה בְלֶב ־ יָ֑ם וְדֶ֖רֶךְ גֶּ֣בֶר בְּעַלְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 30:20",
      "text": "כֵּ֤ן ׀ דֶּ֥רֶךְ אִשָּׁ֗ה מְנָ֫אָ֥פֶת אָ֭כְלָה וּמָ֣חֲתָה פִ֑יהָ וְ֝אָמְרָ֗ה לֹֽא ־ פָעַ֥לְתִּי אָֽוֶן ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 30:21",
      "text": "תַּ֣חַת שָׁ֭לוֹשׁ רָ֣גְזָה אֶ֑רֶץ וְתַ֥חַת אַ֝רְבַּ֗ע לֹא ־ תוּכַ֥ל שְׂאֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 30:22",
      "text": "תַּֽחַת ־ עֶ֭בֶד כִּ֣י יִמְל֑וֹךְ וְ֝נָבָ֗ל כִּ֣י יִֽשְׂבַּֽע ־ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 30:23",
      "text": "תַּ֣חַת שְׂ֭נוּאָה כִּ֣י תִבָּעֵ֑ל וְ֝שִׁפְחָ֗ה כִּֽי ־ תִירַ֥שׁ גְּבִרְתָּֽהּ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 30:24",
      "text": "אַרְבָּ֣עָה הֵ֭ם קְטַנֵּי ־ אָ֑רֶץ וְ֝הֵ֗מָּה חֲכָמִ֥ים מְחֻכָּמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 30:25",
      "text": "הַ֭נְּמָלִים עַ֣ם לֹא ־ עָ֑ז וַיָּכִ֖ינוּ בַקַּ֣יִץ לַחְמָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 30:26",
      "text": "שְׁ֭פַנִּים עַ֣ם לֹא ־ עָצ֑וּם וַיָּשִׂ֖ימוּ בַסֶּ֣לַע בֵּיתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 30:27",
      "text": "מֶ֭לֶךְ אֵ֣ין לָאַרְבֶּ֑ה וַיֵּצֵ֖א חֹצֵ֣ץ כֻּלּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 30:28",
      "text": "שְׂ֭מָמִית בְּיָדַ֣יִם תְּתַפֵּ֑שׂ וְ֝הִ֗יא בְּהֵ֣יכְלֵי מֶֽלֶךְ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 30:29",
      "text": "שְׁלֹשָׁ֣ה הֵ֭מָּה מֵיטִ֣יבֵי צָ֑עַד וְ֝אַרְבָּעָ֗ה מֵיטִ֥בֵי לָֽכֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 30:30",
      "text": "לַ֭יִשׁ גִּבּ֣וֹר בַּבְּהֵמָ֑ה וְלֹא ־ יָ֝שׁ֗וּב מִפְּנֵי ־ כֹֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 30:31",
      "text": "זַרְזִ֣יר מָתְנַ֣יִם אוֹ ־ תָ֑יִשׁ וּ֝מֶ֗לֶךְ אַלְק֥וּם עִמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 30:32",
      "text": "אִם ־ נָבַ֥לְתָּ בְהִתְנַשֵּׂ֑א וְאִם ־ זַ֝מּ֗וֹתָ יָ֣ד לְפֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.30.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 30:33",
      "text": "כִּ֤י מִ֪יץ חָלָ֡ב י֘וֹצִ֤יא חֶמְאָ֗ה וּֽמִיץ ־ אַ֭ף י֣וֹצִיא דָ֑ם וּמִ֥יץ אַ֝פַּ֗יִם י֣וֹצִיא רִֽיב ׃ פ",
      "paragraphStart": false
    }
  ]
}
