{
  "chapter": {
    "id": "wlc:proverbs.12",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.12.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "אֹהֵ֣ב מ֭וּסָר אֹ֣הֵֽב דָּ֑עַת וְשֹׂנֵ֖א תוֹכַ֣חַת בָּֽעַר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.12.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "ט֗וֹב יָפִ֣יק רָ֭צוֹן מֵיְהוָ֑ה וְאִ֖ישׁ מְזִמּ֣וֹת יַרְשִֽׁיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "לֹא ־ יִכּ֣וֹן אָדָ֣ם בְּרֶ֑שַׁע וְשֹׁ֥רֶשׁ צַ֝דִּיקִ֗ים בַּל ־ יִמּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "אֵֽשֶׁת ־ חַ֭יִל עֲטֶ֣רֶת בַּעְלָ֑הּ וּכְרָקָ֖ב בְּעַצְמוֹתָ֣יו מְבִישָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "מַחְשְׁב֣וֹת צַדִּיקִ֣ים מִשְׁפָּ֑ט תַּחְבֻּל֖וֹת רְשָׁעִ֣ים מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "דִּבְרֵ֣י רְשָׁעִ֣ים אֱרָב ־ דָּ֑ם וּפִ֥י יְ֝שָׁרִ֗ים יַצִּילֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "הָפ֣וֹךְ רְשָׁעִ֣ים וְאֵינָ֑ם וּבֵ֖ית צַדִּיקִ֣ים יַעֲמֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "לְֽפִי ־ שִׂ֭כְלוֹ יְהֻלַּל ־ אִ֑ישׁ וְנַעֲוֵה ־ לֵ֝֗ב יִהְיֶ֥ה לָבֽוּז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "ט֣וֹב נִ֭קְלֶה וְעֶ֣בֶד ל֑וֹ מִ֝מְּתַכַּבֵּ֗ד וַחֲסַר ־ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "יוֹדֵ֣עַ צַ֭דִּיק נֶ֣פֶשׁ בְּהֶמְתּ֑וֹ וְֽרַחֲמֵ֥י רְ֝שָׁעִ֗ים אַכְזָרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "עֹבֵ֣ד אַ֭דְמָתוֹ יִֽשְׂבַּֽע ־ לָ֑חֶם וּמְרַדֵּ֖ף רֵיקִ֣ים חֲסַר ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "חָמַ֣ד רָ֭שָׁע מְצ֣וֹד רָעִ֑ים וְשֹׁ֖רֶשׁ צַדִּיקִ֣ים יִתֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "בְּפֶ֣שַׁע שְׂ֭פָתַיִם מוֹקֵ֣שׁ רָ֑ע וַיֵּצֵ֖א מִצָּרָ֣ה צַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "מִפְּרִ֣י פִי ־ אִ֭ישׁ יִשְׂבַּע ־ ט֑וֹב וּגְמ֥וּל יְדֵי ־ אָ֝דָ֗ם ישוב לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "דֶּ֣רֶךְ אֱ֭וִיל יָשָׁ֣ר בְּעֵינָ֑יו וְשֹׁמֵ֖עַ לְעֵצָ֣ה חָכָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "אֱוִ֗יל בַּ֭יּוֹם יִוָּדַ֣ע כַּעְס֑וֹ וְכֹסֶ֖ה קָל֣וֹן עָרֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "יָפִ֣יחַ אֱ֭מוּנָה יַגִּ֣יד צֶ֑דֶק וְעֵ֖ד שְׁקָרִ֣ים מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "יֵ֣שׁ בּ֭וֹטֶה כְּמַדְקְר֣וֹת חָ֑רֶב וּלְשׁ֖וֹן חֲכָמִ֣ים מַרְפֵּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "שְֽׂפַת ־ אֱ֭מֶת תִּכּ֣וֹן לָעַ֑ד וְעַד ־ אַ֝רְגִּ֗יעָה לְשׁ֣וֹן שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "מִ֭רְמָה בְּלֶב ־ חֹ֣רְשֵׁי רָ֑ע וּֽלְיֹעֲצֵ֖י שָׁל֣וֹם שִׂמְחָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "לֹא ־ יְאֻנֶּ֣ה לַצַּדִּ֣יק כָּל ־ אָ֑וֶן וּ֝רְשָׁעִ֗ים מָ֣לְאוּ רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "תּוֹעֲבַ֣ת יְ֭הוָה שִׂפְתֵי ־ שָׁ֑קֶר וְעֹשֵׂ֖י אֱמוּנָ֣ה רְצוֹנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "אָדָ֣ם עָ֭רוּם כֹּ֣סֶה דָּ֑עַת וְלֵ֥ב כְּ֝סִילִ֗ים יִקְרָ֥א אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "יַד ־ חָרוּצִ֥ים תִּמְשׁ֑וֹל ו֝רְמִיָּ֗ה תִּהְיֶ֥ה לָמַֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "דְּאָגָ֣ה בְלֶב ־ אִ֣ישׁ יַשְׁחֶ֑נָּה וְדָבָ֖ר ט֣וֹב יְשַׂמְּחֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "יָתֵ֣ר מֵרֵעֵ֣הוּ צַדִּ֑יק וְדֶ֖רֶךְ רְשָׁעִ֣ים תַּתְעֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "לֹא ־ יַחֲרֹ֣ךְ רְמִיָּ֣ה צֵיד֑וֹ וְהוֹן ־ אָדָ֖ם יָקָ֣ר חָרֽוּץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.12.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "בְּאֹֽרַח ־ צְדָקָ֥ה חַיִּ֑ים וְדֶ֖רֶךְ נְתִיבָ֣ה אַל ־ מָֽוֶת ׃",
      "paragraphStart": false
    }
  ]
}
