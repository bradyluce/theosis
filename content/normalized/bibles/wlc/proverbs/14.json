{
  "chapter": {
    "id": "wlc:proverbs.14",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.14.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "חַכְמ֣וֹת נָ֭שִׁים בָּנְתָ֣ה בֵיתָ֑הּ וְ֝אִוֶּ֗לֶת בְּיָדֶ֥יהָ תֶהֶרְסֶֽנּוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.14.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "הוֹלֵ֣ךְ בְּ֭יָשְׁרוֹ יְרֵ֣א יְהוָ֑ה וּנְל֖וֹז דְּרָכָ֣יו בּוֹזֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "בְּֽפִי ־ אֱ֭וִיל חֹ֣טֶר גַּאֲוָ֑ה וְשִׂפְתֵ֥י חֲ֝כָמִ֗ים תִּשְׁמוּרֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "בְּאֵ֣ין אֲ֭לָפִים אֵב֣וּס בָּ֑ר וְרָב ־ תְּ֝בוּא֗וֹת בְּכֹ֣חַ שֽׁוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "עֵ֣ד אֱ֭מוּנִים לֹ֣א יְכַזֵּ֑ב וְיָפִ֥יחַ כְּ֝זָבִ֗ים עֵ֣ד שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "בִּקֶּשׁ ־ לֵ֣ץ חָכְמָ֣ה וָאָ֑יִן וְדַ֖עַת לְנָב֣וֹן נָקָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "לֵ֣ךְ מִ֭נֶּגֶד לְאִ֣ישׁ כְּסִ֑יל וּבַל ־ יָ֝דַ֗עְתָּ שִׂפְתֵי ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "חָכְמַ֣ת עָ֭רוּם הָבִ֣ין דַּרְכּ֑וֹ וְאִוֶּ֖לֶת כְּסִילִ֣ים מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "אֱ֭וִלִים יָלִ֣יץ אָשָׁ֑ם וּבֵ֖ין יְשָׁרִ֣ים רָצֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "לֵ֗ב י֭וֹדֵעַ מָרַּ֣ת נַפְשׁ֑וֹ וּ֝בְשִׂמְחָת֗וֹ לֹא ־ יִתְעָ֥רַב זָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "בֵּ֣ית רְ֭שָׁעִים יִשָּׁמֵ֑ד וְאֹ֖הֶל יְשָׁרִ֣ים יַפְרִֽיחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "יֵ֤שׁ דֶּ֣רֶךְ יָ֭שָׁר לִפְנֵי ־ אִ֑ישׁ וְ֝אַחֲרִיתָ֗הּ דַּרְכֵי ־ מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "גַּם ־ בִּשְׂח֥וֹק יִכְאַב ־ לֵ֑ב וְאַחֲרִיתָ֖הּ שִׂמְחָ֣ה תוּגָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "מִדְּרָכָ֣יו יִ֭שְׂבַּע ס֣וּג לֵ֑ב וּ֝מֵעָלָ֗יו אִ֣ישׁ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "פֶּ֭תִי יַאֲמִ֣ין לְכָל ־ דָּבָ֑ר וְ֝עָר֗וּם יָבִ֥ין לַאֲשֻׁרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "חָכָ֣ם יָ֭רֵא וְסָ֣ר מֵרָ֑ע וּ֝כְסִ֗יל מִתְעַבֵּ֥ר וּבוֹטֵֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "קְֽצַר ־ אַ֭פַּיִם יַעֲשֶׂ֣ה אִוֶּ֑לֶת וְאִ֥ישׁ מְ֝זִמּ֗וֹת יִשָּׂנֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "נָחֲל֣וּ פְתָאיִ֣ם אִוֶּ֑לֶת וַֽ֝עֲרוּמִ֗ים יַכְתִּ֥רוּ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "שַׁח֣וּ רָ֭עִים לִפְנֵ֣י טוֹבִ֑ים וּ֝רְשָׁעִ֗ים עַֽל ־ שַׁעֲרֵ֥י צַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "גַּם ־ לְ֭רֵעֵהוּ יִשָּׂ֣נֵא רָ֑שׁ וְאֹהֲבֵ֖י עָשִׁ֣יר רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "בָּז ־ לְרֵעֵ֥הוּ חוֹטֵ֑א וּמְחוֹנֵ֖ן עניים אַשְׁרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "הֲֽלוֹא ־ יִ֭תְעוּ חֹ֣רְשֵׁי רָ֑ע וְחֶ֥סֶד וֶ֝אֱמֶ֗ת חֹ֣רְשֵׁי טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "בְּכָל ־ עֶ֭צֶב יִהְיֶ֣ה מוֹתָ֑ר וּדְבַר ־ שְׂ֝פָתַ֗יִם אַךְ ־ לְמַחְסֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "עֲטֶ֣רֶת חֲכָמִ֣ים עָשְׁרָ֑ם אִוֶּ֖לֶת כְּסִילִ֣ים אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "מַצִּ֣יל נְ֭פָשׁוֹת עֵ֣ד אֱמֶ֑ת וְיָפִ֖חַ כְּזָבִ֣ים מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "בְּיִרְאַ֣ת יְ֭הוָה מִבְטַח ־ עֹ֑ז וּ֝לְבָנָ֗יו יִהְיֶ֥ה מַחְסֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "יִרְאַ֣ת יְ֭הוָה מְק֣וֹר חַיִּ֑ים לָ֝ס֗וּר מִמֹּ֥קְשֵׁי מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "בְּרָב ־ עָ֥ם הַדְרַת ־ מֶ֑לֶךְ וּבְאֶ֥פֶס לְ֝אֹ֗ם מְחִתַּ֥ת רָזֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "אֶ֣רֶךְ אַ֭פַּיִם רַב ־ תְּבוּנָ֑ה וּקְצַר ־ ר֝֗וּחַ מֵרִ֥ים אִוֶּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "חַיֵּ֣י בְ֭שָׂרִים לֵ֣ב מַרְפֵּ֑א וּרְקַ֖ב עֲצָמ֣וֹת קִנְאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "עֹ֣שֵֽׁק דָּ֭ל חֵרֵ֣ף עֹשֵׂ֑הוּ וּ֝מְכַבְּד֗וֹ חֹנֵ֥ן אֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "בְּֽ֭רָעָתוֹ יִדָּחֶ֣ה רָשָׁ֑ע וְחֹסֶ֖ה בְמוֹת֣וֹ צַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "בְּלֵ֣ב נָ֭בוֹן תָּנ֣וּחַ חָכְמָ֑ה וּבְקֶ֥רֶב כְּ֝סִילִ֗ים תִּוָּדֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.34",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "צְדָקָ֥ה תְרֽוֹמֵֽם ־ גּ֑וֹי וְחֶ֖סֶד לְאֻמִּ֣ים חַטָּֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.14.35",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "רְֽצוֹן ־ מֶ֭לֶךְ לְעֶ֣בֶד מַשְׂכִּ֑יל וְ֝עֶבְרָת֗וֹ תִּהְיֶ֥ה מֵבִֽישׁ ׃",
      "paragraphStart": false
    }
  ]
}
