{
  "chapter": {
    "id": "wlc:proverbs.7",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 7,
    "referenceLabel": "Proverbs 7",
    "summary": "Source text for Proverbs 7 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.7.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 7:1",
      "text": "בְּ֭נִי שְׁמֹ֣ר אֲמָרָ֑י וּ֝מִצְוֺתַ֗י תִּצְפֹּ֥ן אִתָּֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.7.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 7:2",
      "text": "שְׁמֹ֣ר מִצְוֺתַ֣י וֶחְיֵ֑ה וְ֝תוֹרָתִ֗י כְּאִישׁ֥וֹן עֵינֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 7:3",
      "text": "קָשְׁרֵ֥ם עַל ־ אֶצְבְּעֹתֶ֑יךָ כָּ֝תְבֵ֗ם עַל ־ ל֥וּחַ לִבֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 7:4",
      "text": "אֱמֹ֣ר לַֽ֭חָכְמָה אֲחֹ֣תִי אָ֑תְּ וּ֝מֹדָ֗ע לַבִּינָ֥ה תִקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 7:5",
      "text": "לִ֭שְׁמָרְךָ מֵאִשָּׁ֣ה זָרָ֑ה מִ֝נָּכְרִיָּ֗ה אֲמָרֶ֥יהָ הֶחֱלִֽיקָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 7:6",
      "text": "כִּ֭י בְּחַלּ֣וֹן בֵּיתִ֑י בְּעַ֖ד אֶשְׁנַבִּ֣י נִשְׁקָֽפְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 7:7",
      "text": "וָאֵ֤רֶא בַפְּתָאיִ֗ם אָ֘בִ֤ינָה בַבָּנִ֗ים נַ֣עַר חֲסַר ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 7:8",
      "text": "עֹבֵ֣ר בַּ֭שּׁוּק אֵ֣צֶל פִּנָּ֑הּ וְדֶ֖רֶךְ בֵּיתָ֣הּ יִצְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 7:9",
      "text": "בְּנֶֽשֶׁף ־ בְּעֶ֥רֶב י֑וֹם בְּאִישׁ֥וֹן לַ֝֗יְלָה וַאֲפֵלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 7:10",
      "text": "וְהִנֵּ֣ה אִ֭שָּׁה לִקְרָאת֑וֹ שִׁ֥ית ז֝וֹנָ֗ה וּנְצֻ֥רַת לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 7:11",
      "text": "הֹמִיָּ֣ה הִ֣יא וְסֹרָ֑רֶת בְּ֝בֵיתָ֗הּ לֹא ־ יִשְׁכְּנ֥וּ רַגְלֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 7:12",
      "text": "פַּ֤עַם ׀ בַּח֗וּץ פַּ֥עַם בָּרְחֹב֑וֹת וְאֵ֖צֶל כָּל ־ פִּנָּ֣ה תֶאֱרֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 7:13",
      "text": "וְהֶחֱזִ֣יקָה בּ֭וֹ וְנָ֣שְׁקָה ־ לּ֑וֹ הֵעֵ֥זָה פָ֝נֶ֗יהָ וַתֹּ֣אמַר לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 7:14",
      "text": "זִבְחֵ֣י שְׁלָמִ֣ים עָלָ֑י הַ֝יּ֗וֹם שִׁלַּ֥מְתִּי נְדָרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 7:15",
      "text": "עַל ־ כֵּ֭ן יָצָ֣אתִי לִקְרָאתֶ֑ךָ לְשַׁחֵ֥ר פָּ֝נֶ֗יךָ וָאֶמְצָאֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 7:16",
      "text": "מַ֭רְבַדִּים רָבַ֣דְתִּי עַרְשִׂ֑י חֲ֝טֻב֗וֹת אֵט֥וּן מִצְרָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 7:17",
      "text": "נַ֥פְתִּי מִשְׁכָּבִ֑י מֹ֥ר אֲ֝הָלִ֗ים וְקִנָּמֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 7:18",
      "text": "לְכָ֤ה נִרְוֶ֣ה דֹ֭דִים עַד ־ הַבֹּ֑קֶר נִ֝תְעַלְּסָ֗ה בָּאֳהָבִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 7:19",
      "text": "כִּ֤י אֵ֣ין הָאִ֣ישׁ בְּבֵית֑וֹ הָ֝לַ֗ךְ בְּדֶ֣רֶךְ מֵרָחֽוֹק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 7:20",
      "text": "צְֽרוֹר ־ הַ֭כֶּסֶף לָקַ֣ח בְּיָד֑וֹ לְי֥וֹם הַ֝כֵּ֗סֶא יָבֹ֥א בֵיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 7:21",
      "text": "הִ֭טַּתּוּ בְּרֹ֣ב לִקְחָ֑הּ בְּחֵ֥לֶק שְׂ֝פָתֶ֗יהָ תַּדִּיחֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 7:22",
      "text": "ה֤וֹלֵ֥ךְ אַחֲרֶ֗יהָ פִּ֫תְאֹ֥ם כְּ֭שׁוֹר אֶל ־ טָ֣בַח יָב֑וֹא וּ֝כְעֶ֗כֶס אֶל ־ מוּסַ֥ר אֱוִֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 7:23",
      "text": "עַ֤ד יְפַלַּ֪ח חֵ֡ץ כְּֽבֵד֗וֹ כְּמַהֵ֣ר צִפּ֣וֹר אֶל ־ פָּ֑ח וְלֹֽא ־ יָ֝דַ֗ע כִּֽי ־ בְנַפְשׁ֥וֹ הֽוּא ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 7:24",
      "text": "וְעַתָּ֣ה בָ֭נִים שִׁמְעוּ ־ לִ֑י וְ֝הַקְשִׁ֗יבוּ לְאִמְרֵי ־ פִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 7:25",
      "text": "אַל ־ יֵ֣שְׂטְ אֶל ־ דְּרָכֶ֣יהָ לִבֶּ֑ךָ אַל ־ תֵּ֝תַע בִּנְתִיבוֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 7:26",
      "text": "כִּֽי ־ רַבִּ֣ים חֲלָלִ֣ים הִפִּ֑ילָה וַ֝עֲצֻמִ֗ים כָּל ־ הֲרֻגֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.7.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 7:27",
      "text": "דַּרְכֵ֣י שְׁא֣וֹל בֵּיתָ֑הּ יֹ֝רְד֗וֹת אֶל ־ חַדְרֵי ־ מָֽוֶת ׃ פ",
      "paragraphStart": false
    }
  ]
}
