{
  "chapter": {
    "id": "wlc:proverbs.8",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 8,
    "referenceLabel": "Proverbs 8",
    "summary": "Source text for Proverbs 8 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.8.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 8:1",
      "text": "הֲלֹֽא ־ חָכְמָ֥ה תִקְרָ֑א וּ֝תְבוּנָ֗ה תִּתֵּ֥ן קוֹלָֽהּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.8.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 8:2",
      "text": "בְּרֹאשׁ ־ מְרוֹמִ֥ים עֲלֵי ־ דָ֑רֶךְ בֵּ֖ית נְתִיב֣וֹת נִצָּֽבָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 8:3",
      "text": "לְיַד ־ שְׁעָרִ֥ים לְפִי ־ קָ֑רֶת מְב֖וֹא פְתָחִ֣ים תָּרֹֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 8:4",
      "text": "אֲלֵיכֶ֣ם אִישִׁ֣ים אֶקְרָ֑א וְ֝קוֹלִ֗י אֶל ־ בְּנֵ֥י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 8:5",
      "text": "הָבִ֣ינוּ פְתָאיִ֣ם עָרְמָ֑ה וּ֝כְסִילִ֗ים הָבִ֥ינוּ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 8:6",
      "text": "שִׁ֭מְעוּ כִּֽי ־ נְגִידִ֣ים אֲדַבֵּ֑ר וּמִפְתַּ֥ח שְׂ֝פָתַ֗י מֵישָׁרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 8:7",
      "text": "כִּֽי ־ אֱ֭מֶת יֶהְגֶּ֣ה חִכִּ֑י וְתוֹעֲבַ֖ת שְׂפָתַ֣י רֶֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 8:8",
      "text": "בְּצֶ֥דֶק כָּל ־ אִמְרֵי ־ פִ֑י אֵ֥ין בָּ֝הֶ֗ם נִפְתָּ֥ל וְעִקֵּֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 8:9",
      "text": "כֻּלָּ֣ם נְ֭כֹחִים לַמֵּבִ֑ין וִֽ֝ישָׁרִ֗ים לְמֹ֣צְאֵי דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 8:10",
      "text": "קְחֽוּ ־ מוּסָרִ֥י וְאַל ־ כָּ֑סֶף וְ֝דַ֗עַת מֵחָר֥וּץ נִבְחָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 8:11",
      "text": "כִּֽי ־ טוֹבָ֣ה חָ֭כְמָה מִפְּנִינִ֑ים וְכָל ־ חֲ֝פָצִ֗ים לֹ֣א יִֽשְׁווּ ־ בָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 8:12",
      "text": "אֲֽנִי ־ חָ֭כְמָה שָׁכַ֣נְתִּי עָרְמָ֑ה וְדַ֖עַת מְזִמּ֣וֹת אֶמְצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 8:13",
      "text": "יִֽרְאַ֣ת יְהוָה֮ שְֽׂנֹ֫את רָ֥ע גֵּ֘אָ֤ה וְגָא֨וֹן ׀ וְדֶ֣רֶךְ רָ֭ע וּפִ֨י תַהְפֻּכ֬וֹת שָׂנֵֽאתִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 8:14",
      "text": "לִֽי ־ עֵ֭צָה וְתוּשִׁיָּ֑ה אֲנִ֥י בִ֝ינָ֗ה לִ֣י גְבוּרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 8:15",
      "text": "בִּ֭י מְלָכִ֣ים יִמְלֹ֑כוּ וְ֝רוֹזְנִ֗ים יְחֹ֣קְקוּ צֶֽדֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 8:16",
      "text": "בִּ֭י שָׂרִ֣ים יָשֹׂ֑רוּ וּ֝נְדִיבִ֗ים כָּל ־ שֹׁ֥פְטֵי צֶֽדֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 8:17",
      "text": "אֲ֭נִי אהביה אֵהָ֑ב וּ֝מְשַׁחֲרַ֗י יִמְצָאֻֽנְנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 8:18",
      "text": "עֹֽשֶׁר ־ וְכָב֥וֹד אִתִּ֑י ה֥וֹן עָ֝תֵ֗ק וּצְדָקָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 8:19",
      "text": "ט֣וֹב פִּ֭רְיִי מֵחָר֣וּץ וּמִפָּ֑ז וּ֝תְבוּאָתִ֗י מִכֶּ֥סֶף נִבְחָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 8:20",
      "text": "בְּאֹֽרַח ־ צְדָקָ֥ה אֲהַלֵּ֑ך בְּ֝ת֗וֹךְ נְתִיב֥וֹת מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 8:21",
      "text": "לְהַנְחִ֖יל אֹהֲבַ֥י ׀ יֵ֑שׁ וְאֹצְרֹ֖תֵיהֶ֣ם אֲמַלֵּֽא ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 8:22",
      "text": "יְֽהוָ֗ה קָ֭נָנִי רֵאשִׁ֣ית דַּרְכּ֑וֹ קֶ֖דֶם מִפְעָלָ֣יו מֵאָֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 8:23",
      "text": "מֵ֭עוֹלָם נִסַּ֥כְתִּי מֵרֹ֗אשׁ מִקַּדְמֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 8:24",
      "text": "בְּאֵין ־ תְּהֹמ֥וֹת חוֹלָ֑לְתִּי בְּאֵ֥ין מַ֝עְיָנ֗וֹת נִכְבַּדֵּי ־ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 8:25",
      "text": "בְּטֶ֣רֶם הָרִ֣ים הָטְבָּ֑עוּ לִפְנֵ֖י גְבָע֣וֹת חוֹלָֽלְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 8:26",
      "text": "עַד ־ לֹ֣א עָ֭שָׂה אֶ֣רֶץ וְחוּצ֑וֹת וְ֝רֹ֗אשׁ עָפְר֥וֹת תֵּבֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 8:27",
      "text": "בַּהֲכִינ֣וֹ שָׁ֭מַיִם שָׁ֣ם אָ֑נִי בְּח֥וּקוֹ ח֝֗וּג עַל ־ פְּנֵ֥י תְהֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 8:28",
      "text": "בְּאַמְּצ֣וֹ שְׁחָקִ֣ים מִמָּ֑עַל בַּ֝עֲז֗וֹז עִינ֥וֹת תְּהוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 8:29",
      "text": "בְּשׂ֘וּמ֤וֹ לַיָּ֨ם ׀ חֻקּ֗וֹ וּ֭מַיִם לֹ֣א יַֽעַבְרוּ ־ פִ֑יו בְּ֝חוּק֗וֹ מ֣וֹסְדֵי אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 8:30",
      "text": "וָֽאֶהְיֶ֥ה אֶצְל֗וֹ אָ֫מ֥וֹן וָֽאֶהְיֶ֣ה שַׁ֭עֲשֻׁעִים י֤וֹם ׀ י֑וֹם מְשַׂחֶ֖קֶת לְפָנָ֣יו בְּכָל ־ עֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 8:31",
      "text": "מְ֭שַׂחֶקֶת בְּתֵבֵ֣ל אַרְצ֑וֹ וְ֝שַׁעֲשֻׁעַ֗י אֶת ־ בְּנֵ֥י אָדָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 8:32",
      "text": "וְעַתָּ֣ה בָ֭נִים שִׁמְעוּ ־ לִ֑י וְ֝אַשְׁרֵ֗י דְּרָכַ֥י יִשְׁמֹֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 8:33",
      "text": "שִׁמְע֖וּ מוּסָ֥ר וַחֲכָ֗מוּ וְאַל ־ תִּפְרָֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.34",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 8:34",
      "text": "אַ֥שְֽׁרֵי אָדָם֮ שֹׁמֵ֪עַֽ֫ לִ֥י לִשְׁקֹ֣ד עַל ־ דַּ֭לְתֹתַי י֤וֹם ׀ י֑וֹם לִ֝שְׁמֹ֗ר מְזוּזֹ֥ת פְּתָחָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.35",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 8:35",
      "text": "כִּ֣י מֹ֭צְאִי מצאי חַיִּ֑ים וַיָּ֥פֶק רָ֝צ֗וֹן מֵיְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.8.36",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Proverbs 8:36",
      "text": "וְֽ֭חֹטְאִי חֹמֵ֣ס נַפְשׁ֑וֹ כָּל ־ מְ֝שַׂנְאַ֗י אָ֣הֲבוּ מָֽוֶת ׃ פ",
      "paragraphStart": false
    }
  ]
}
