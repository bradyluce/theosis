{
  "chapter": {
    "id": "wlc:proverbs.3",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 3,
    "referenceLabel": "Proverbs 3",
    "summary": "Source text for Proverbs 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.3.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 3:1",
      "text": "בְּ֭נִי תּוֹרָתִ֣י אַל ־ תִּשְׁכָּ֑ח וּ֝מִצְוֺתַ֗י יִצֹּ֥ר לִבֶּֽךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.3.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 3:2",
      "text": "כִּ֤י אֹ֣רֶךְ יָ֭מִים וּשְׁנ֣וֹת חַיִּ֑ים וְ֝שָׁל֗וֹם יוֹסִ֥יפוּ לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 3:3",
      "text": "חֶ֥סֶד וֶאֱמֶ֗ת אַֽל ־ יַעַ֫זְבֻ֥ךָ קָשְׁרֵ֥ם עַל ־ גַּרְגְּרוֹתֶ֑יךָ כָּ֝תְבֵ֗ם עַל ־ ל֥וּחַ לִבֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 3:4",
      "text": "וּמְצָא ־ חֵ֖ן וְשֵֽׂכֶל ־ ט֑וֹב בְּעֵינֵ֖י אֱלֹהִ֣ים וְאָדָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 3:5",
      "text": "בְּטַ֣ח אֶל ־ יְ֭הוָה בְּכָל ־ לִבֶּ֑ךָ וְאֶל ־ בִּֽ֝ינָתְךָ֗ אַל ־ תִּשָּׁעֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 3:6",
      "text": "בְּכָל ־ דְּרָכֶ֥יךָ דָעֵ֑הוּ וְ֝ה֗וּא יְיַשֵּׁ֥ר אֹֽרְחֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 3:7",
      "text": "אַל ־ תְּהִ֣י חָכָ֣ם בְּעֵינֶ֑יךָ יְרָ֥א אֶת ־ יְ֝הוָ֗ה וְס֣וּר מֵרָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 3:8",
      "text": "רִ֭פְאוּת תְּהִ֣י לְשָׁרֶּ֑ךָ וְ֝שִׁקּ֗וּי לְעַצְמוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 3:9",
      "text": "כַּבֵּ֣ד אֶת ־ יְ֭הוָה מֵהוֹנֶ֑ךָ וּ֝מֵרֵאשִׁ֗ית כָּל ־ תְּבוּאָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 3:10",
      "text": "וְיִמָּלְא֣וּ אֲסָמֶ֣יךָ שָׂבָ֑ע וְ֝תִיר֗וֹשׁ יְקָבֶ֥יךָ יִפְרֹֽצוּ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 3:11",
      "text": "מוּסַ֣ר יְ֭הוָה בְּנִ֣י אַל ־ תִּמְאָ֑ס וְאַל ־ תָּ֝קֹ֗ץ בְּתוֹכַחְתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 3:12",
      "text": "כִּ֤י אֶ֥ת אֲשֶׁ֣ר יֶאֱהַ֣ב יְהוָ֣ה יוֹכִ֑יחַ וּ֝כְאָ֗ב אֶת ־ בֵּ֥ן יִרְצֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 3:13",
      "text": "אַשְׁרֵ֣י אָ֭דָם מָצָ֣א חָכְמָ֑ה וְ֝אָדָ֗ם יָפִ֥יק תְּבוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 3:14",
      "text": "כִּ֤י ט֣וֹב סַ֭חְרָהּ מִסְּחַר ־ כָּ֑סֶף וּ֝מֵחָר֗וּץ תְּבוּאָתָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 3:15",
      "text": "יְקָ֣רָה הִ֭יא מפניים וְכָל ־ חֲ֝פָצֶ֗יךָ לֹ֣א יִֽשְׁווּ ־ בָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 3:16",
      "text": "אֹ֣רֶךְ יָ֭מִים בִּֽימִינָ֑הּ בִּ֝שְׂמֹאולָ֗הּ עֹ֣שֶׁר וְכָבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 3:17",
      "text": "דְּרָכֶ֥יהָ דַרְכֵי ־ נֹ֑עַם וְֽכָל ־ נְתִ֖יבוֹתֶ֣יהָ שָׁלֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 3:18",
      "text": "עֵץ ־ חַיִּ֣ים הִ֭יא לַמַּחֲזִיקִ֣ים בָּ֑הּ וְֽתֹמְכֶ֥יהָ מְאֻשָּֽׁר ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 3:19",
      "text": "יְֽהוָ֗ה בְּחָכְמָ֥ה יָֽסַד ־ אָ֑רֶץ כּוֹנֵ֥ן שָׁ֝מַ֗יִם בִּתְבוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 3:20",
      "text": "בְּ֭דַעְתּוֹ תְּהוֹמ֣וֹת נִבְקָ֑עוּ וּ֝שְׁחָקִ֗ים יִרְעֲפוּ ־ טָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 3:21",
      "text": "בְּ֭נִי אַל ־ יָלֻ֣זוּ מֵעֵינֶ֑יךָ נְצֹ֥ר תֻּ֝שִׁיָּ֗ה וּמְזִמָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 3:22",
      "text": "וְיִֽהְי֣וּ חַיִּ֣ים לְנַפְשֶׁ֑ךָ וְ֝חֵ֗ן לְגַרְגְּרֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 3:23",
      "text": "אָ֤ז תֵּלֵ֣ךְ לָבֶ֣טַח דַּרְכֶּ֑ךָ וְ֝רַגְלְךָ֗ לֹ֣א תִגּֽוֹף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 3:24",
      "text": "אִם ־ תִּשְׁכַּ֥ב לֹֽא ־ תִפְחָ֑ד וְ֝שָׁכַבְתָּ֗ וְֽעָרְבָ֥ה שְׁנָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 3:25",
      "text": "אַל ־ תִּ֭ירָא מִפַּ֣חַד פִּתְאֹ֑ם וּמִשֹּׁאַ֥ת רְ֝שָׁעִ֗ים כִּ֣י תָבֹֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 3:26",
      "text": "כִּֽי ־ יְ֭הוָה יִהְיֶ֣ה בְכִסְלֶ֑ךָ וְשָׁמַ֖ר רַגְלְךָ֣ מִלָּֽכֶד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 3:27",
      "text": "אַל ־ תִּמְנַע ־ ט֥וֹב מִבְּעָלָ֑יו בִּהְי֨וֹת לְאֵ֖ל ידיך לַעֲשֽׂוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 3:28",
      "text": "אַל ־ תֹּ֘אמַ֤ר לרעיך ׀ לֵ֣ךְ וָ֭שׁוּב וּמָחָ֥ר אֶתֵּ֗ן וְיֵ֣שׁ אִתָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 3:29",
      "text": "אַל ־ תַּחֲרֹ֣שׁ עַל ־ רֵעֲךָ֣ רָעָ֑ה וְהֽוּא ־ יוֹשֵׁ֖ב לָבֶ֣טַח אִתָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 3:30",
      "text": "אַל ־ תרוב עִם ־ אָדָ֣ם חִנָּ֑ם אִם ־ לֹ֖א גְמָלְךָ֣ רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 3:31",
      "text": "אַל ־ תְּ֭קַנֵּא בְּאִ֣ישׁ חָמָ֑ס וְאַל ־ תִּ֝בְחַ֗ר בְּכָל ־ דְּרָכָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 3:32",
      "text": "כִּ֤י תוֹעֲבַ֣ת יְהוָ֣ה נָל֑וֹז וְֽאֶת ־ יְשָׁרִ֥ים סוֹדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 3:33",
      "text": "מְאֵרַ֣ת יְ֭הוָה בְּבֵ֣ית רָשָׁ֑ע וּנְוֵ֖ה צַדִּיקִ֣ים יְבָרֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.34",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 3:34",
      "text": "אִם ־ לַלֵּצִ֥ים הֽוּא ־ יָלִ֑יץ ולעניים יִתֶּן ־ חֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.3.35",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 3:35",
      "text": "כָּ֭בוֹד חֲכָמִ֣ים יִנְחָ֑לוּ וּ֝כְסִילִ֗ים מֵרִ֥ים קָלֽוֹן ׃ פ",
      "paragraphStart": false
    }
  ]
}
