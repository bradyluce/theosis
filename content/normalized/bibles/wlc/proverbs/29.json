{
  "chapter": {
    "id": "wlc:proverbs.29",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.29.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "אִ֣ישׁ תּ֭וֹכָחוֹת מַקְשֶׁה ־ עֹ֑רֶף פֶּ֥תַע יִ֝שָּׁבֵ֗ר וְאֵ֣ין מַרְפֵּֽא ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.29.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "בִּרְב֣וֹת צַ֭דִּיקִים יִשְׂמַ֣ח הָעָ֑ם וּבִמְשֹׁ֥ל רָ֝שָׁ֗ע יֵאָ֥נַֽח עָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "אִֽישׁ ־ אֹהֵ֣ב חָ֭כְמָה יְשַׂמַּ֣ח אָבִ֑יו וְרֹעֶ֥ה ז֝וֹנ֗וֹת יְאַבֶּד ־ הֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "מֶ֗לֶךְ בְּ֭מִשְׁפָּט יַעֲמִ֣יד אָ֑רֶץ וְאִ֖ישׁ תְּרוּמ֣וֹת יֶֽהֶרְסֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "גֶּ֭בֶר מַחֲלִ֣יק עַל ־ רֵעֵ֑הוּ רֶ֝֗שֶׁת פּוֹרֵ֥שׂ עַל ־ פְּעָמָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "בְּפֶ֤שַֽׁע אִ֣ישׁ רָ֣ע מוֹקֵ֑שׁ וְ֝צַדִּ֗יק יָר֥וּן וְשָׂמֵֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "יֹדֵ֣עַ צַ֭דִּיק דִּ֣ין דַּלִּ֑ים רָ֝שָׁ֗ע לֹא ־ יָבִ֥ין דָּֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "אַנְשֵׁ֣י לָ֭צוֹן יָפִ֣יחוּ קִרְיָ֑ה וַ֝חֲכָמִ֗ים יָשִׁ֥יבוּ אָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "אִֽישׁ ־ חָכָ֗ם נִ֭שְׁפָּט אֶת ־ אִ֣ישׁ אֱוִ֑יל וְרָגַ֥ז וְ֝שָׂחַ֗ק וְאֵ֣ין נָֽחַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "אַנְשֵׁ֣י דָ֭מִים יִשְׂנְאוּ ־ תָ֑ם וִֽ֝ישָׁרִ֗ים יְבַקְשׁ֥וּ נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "כָּל ־ ר֭וּחוֹ יוֹצִ֣יא כְסִ֑יל וְ֝חָכָ֗ם בְּאָח֥וֹר יְשַׁבְּחֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "מֹ֭שֵׁל מַקְשִׁ֣יב עַל ־ דְּבַר ־ שָׁ֑קֶר כָּֽל ־ מְשָׁרְתָ֥יו רְשָׁעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "רָ֤שׁ וְאִ֣ישׁ תְּכָכִ֣ים נִפְגָּ֑שׁוּ מֵ֤אִיר ־ עֵינֵ֖י שְׁנֵיהֶ֣ם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "מֶ֤לֶךְ שׁוֹפֵ֣ט בֶּֽאֱמֶ֣ת דַּלִּ֑ים כִּ֝סְא֗וֹ לָעַ֥ד יִכּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "שֵׁ֣בֶט וְ֭תוֹכַחַת יִתֵּ֣ן חָכְמָ֑ה וְנַ֥עַר מְ֝שֻׁלָּ֗ח מֵבִ֥ישׁ אִמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "בִּרְב֣וֹת רְ֭שָׁעִים יִרְבֶּה ־ פָּ֑שַׁע וְ֝צַדִּיקִ֗ים בְּֽמַפַּלְתָּ֥ם יִרְאֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "יַסֵּ֣ר בִּ֭נְךָ וִֽינִיחֶ֑ךָ וְיִתֵּ֖ן מַעֲדַנִּ֣ים לְנַפְשֶֽׁךָ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "בְּאֵ֣ין חָ֭זוֹן יִפָּ֣רַֽע עָ֑ם וְשֹׁמֵ֖ר תּוֹרָ֣ה אַשְׁרֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "בִּ֭דְבָרִים לֹא ־ יִוָּ֣סֶר עָ֑בֶד כִּֽי ־ יָ֝בִ֗ין וְאֵ֣ין מַעֲנֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "חָזִ֗יתָ אִ֭ישׁ אָ֣ץ בִּדְבָרָ֑יו תִּקְוָ֖ה לִכְסִ֣יל מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "מְפַנֵּ֣ק מִנֹּ֣עַר עַבְדּ֑וֹ וְ֝אַחֲרִית֗וֹ יִהְיֶ֥ה מָנֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "אִֽישׁ ־ אַ֭ף יְגָרֶ֣ה מָד֑וֹן וּבַ֖עַל חֵמָ֣ה רַב ־ פָּֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "גַּאֲוַ֣ת אָ֭דָם תַּשְׁפִּילֶ֑נּוּ וּשְׁפַל ־ ר֝֗וּחַ יִתְמֹ֥ךְ כָּבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "חוֹלֵ֣ק עִם ־ גַּ֭נָּב שׂוֹנֵ֣א נַפְשׁ֑וֹ אָלָ֥ה יִ֝שְׁמַ֗ע וְלֹ֣א יַגִּֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "חֶרְדַּ֣ת אָ֭דָם יִתֵּ֣ן מוֹקֵ֑שׁ וּבוֹטֵ֖חַ בַּיהוָ֣ה יְשֻׂגָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "רַ֭בִּים מְבַקְשִׁ֣ים פְּנֵי ־ מוֹשֵׁ֑ל וּ֝מֵיְהוָ֗ה מִשְׁפַּט ־ אִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.29.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "תּוֹעֲבַ֣ת צַ֭דִּיקִים אִ֣ישׁ עָ֑וֶל וְתוֹעֲבַ֖ת רָשָׁ֣ע יְשַׁר ־ דָּֽרֶךְ ׃ פ",
      "paragraphStart": false
    }
  ]
}
