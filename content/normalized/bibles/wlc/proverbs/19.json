{
  "chapter": {
    "id": "wlc:proverbs.19",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 19,
    "referenceLabel": "Proverbs 19",
    "summary": "Source text for Proverbs 19 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.19.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 19:1",
      "text": "טֽוֹב ־ רָ֭שׁ הוֹלֵ֣ךְ בְּתֻמּ֑וֹ מֵעִקֵּ֥שׁ שְׂ֝פָתָ֗יו וְה֣וּא כְסִֽיל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.19.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 19:2",
      "text": "גַּ֤ם בְּלֹא ־ דַ֣עַת נֶ֣פֶשׁ לֹא ־ ט֑וֹב וְאָ֖ץ בְּרַגְלַ֣יִם חוֹטֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 19:3",
      "text": "אִוֶּ֣לֶת אָ֭דָם תְּסַלֵּ֣ף דַּרְכּ֑וֹ וְעַל ־ יְ֝הוָ֗ה יִזְעַ֥ף לִבּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 19:4",
      "text": "ה֗וֹן יֹ֭סִיף רֵעִ֣ים רַבִּ֑ים וְ֝דָ֗ל מֵרֵ֥עהוּ יִפָּרֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 19:5",
      "text": "עֵ֣ד שְׁ֭קָרִים לֹ֣א יִנָּקֶ֑ה וְיָפִ֥יחַ כְּ֝זָבִ֗ים לֹ֣א יִמָּלֵֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 19:6",
      "text": "רַ֭בִּים יְחַלּ֣וּ פְנֵֽי ־ נָדִ֑יב וְכָל ־ הָ֝רֵ֗עַ לְאִ֣ישׁ מַתָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 19:7",
      "text": "כָּ֥ל אֲחֵי ־ רָ֨שׁ ׀ שְֽׂנֵאֻ֗הוּ אַ֤ף כִּ֣י מְ֭רֵעֵהוּ רָחֲק֣וּ מִמֶּ֑נּוּ מְרַדֵּ֖ף אֲמָרִ֣ים לא ־ הֵֽמָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 19:8",
      "text": "קֹֽנֶה ־ לֵּ֭ב אֹהֵ֣ב נַפְשׁ֑וֹ שֹׁמֵ֥ר תְּ֝בוּנָ֗ה לִמְצֹא ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 19:9",
      "text": "עֵ֣ד שְׁ֭קָרִים לֹ֣א יִנָּקֶ֑ה וְיָפִ֖יחַ כְּזָבִ֣ים יֹאבֵֽד ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 19:10",
      "text": "לֹֽא ־ נָאוֶ֣ה לִכְסִ֣יל תַּעֲנ֑וּג אַ֝֗ף כִּֽי ־ לְעֶ֤בֶד ׀ מְשֹׁ֬ל בְּשָׂרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 19:11",
      "text": "שֵׂ֣כֶל אָ֭דָם הֶאֱרִ֣יךְ אַפּ֑וֹ וְ֝תִפאַרְתּ֗וֹ עֲבֹ֣ר עַל ־ פָּֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 19:12",
      "text": "נַ֣הַם כַּ֭כְּפִיר זַ֣עַף מֶ֑לֶךְ וּכְטַ֖ל עַל ־ עֵ֣שֶׂב רְצוֹנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 19:13",
      "text": "הַוֺּ֣ת לְ֭אָבִיו בֵּ֣ן כְּסִ֑יל וְדֶ֥לֶף טֹ֝רֵ֗ד מִדְיְנֵ֥י אִשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 19:14",
      "text": "בַּ֣יִת וָ֭הוֹן נַחֲלַ֣ת אָב֑וֹת וּ֝מֵיְהוָ֗ה אִשָּׁ֥ה מַשְׂכָּֽלֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 19:15",
      "text": "עַ֭צְלָה תַּפִּ֣יל תַּרְדֵּמָ֑ה וְנֶ֖פֶשׁ רְמִיָּ֣ה תִרְעָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 19:16",
      "text": "שֹׁמֵ֣ר מִ֭צְוָה שֹׁמֵ֣ר נַפְשׁ֑וֹ בּוֹזֵ֖ה דְרָכָ֣יו יומת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 19:17",
      "text": "מַלְוֵ֣ה יְ֭הוָה ח֣וֹנֵֽן דָּ֑ל וּ֝גְמֻל֗וֹ יְשַׁלֶּם ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 19:18",
      "text": "יַסֵּ֣ר בִּ֭נְךָ כִּי ־ יֵ֣שׁ תִּקְוָ֑ה וְאֶל ־ הֲ֝מִית֗וֹ אַל ־ תִּשָּׂ֥א נַפְשֶֽׁךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 19:19",
      "text": "גרל ־ חֵ֭מָה נֹ֣שֵׂא עֹ֑נֶשׁ כִּ֥י אִם ־ תַּ֝צִּ֗יל וְע֣וֹד תּוֹסִֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 19:20",
      "text": "שְׁמַ֣ע עֵ֭צָה וְקַבֵּ֣ל מוּסָ֑ר לְ֝מַ֗עַן תֶּחְכַּ֥ם בְּאַחֲרִיתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 19:21",
      "text": "רַבּ֣וֹת מַחֲשָׁב֣וֹת בְּלֶב ־ אִ֑ישׁ וַעֲצַ֥ת יְ֝הוָ֗ה הִ֣יא תָקֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 19:22",
      "text": "תַּאֲוַ֣ת אָדָ֣ם חַסְדּ֑וֹ וְטֽוֹב ־ רָ֝שׁ מֵאִ֥ישׁ כָּזָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 19:23",
      "text": "יִרְאַ֣ת יְהוָ֣ה לְחַיִּ֑ים וְשָׂבֵ֥עַ יָ֝לִ֗ין בַּל ־ יִפָּ֥קֶד רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 19:24",
      "text": "טָ֘מַ֤ן עָצֵ֣ל יָ֭דוֹ בַּצַּלָּ֑חַת גַּם ־ אֶל ־ פִּ֝֗יהוּ לֹ֣א יְשִׁיבֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 19:25",
      "text": "לֵ֣ץ תַּ֭כֶּה וּפֶ֣תִי יַעְרִ֑ם וְהוֹכִ֥יחַ לְ֝נָב֗וֹן יָבִ֥ין דָּֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 19:26",
      "text": "מְֽשַׁדֶּד ־ אָ֭ב יַבְרִ֣יחַ אֵ֑ם בֵּ֝֗ן מֵבִ֥ישׁ וּמַחְפִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 19:27",
      "text": "חַֽדַל ־ בְּ֭נִי לִשְׁמֹ֣עַ מוּסָ֑ר לִ֝שְׁג֗וֹת מֵֽאִמְרֵי ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 19:28",
      "text": "עֵ֣ד בְּ֭לִיַּעַל יָלִ֣יץ מִשְׁפָּ֑ט וּפִ֥י רְ֝שָׁעִ֗ים יְבַלַּע ־ אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.19.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 19:29",
      "text": "נָכ֣וֹנוּ לַלֵּצִ֣ים שְׁפָטִ֑ים וּ֝מַהֲלֻמ֗וֹת לְגֵ֣ו כְּסִילִֽים ׃",
      "paragraphStart": false
    }
  ]
}
