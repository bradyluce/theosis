{
  "chapter": {
    "id": "wlc:proverbs.27",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 27,
    "referenceLabel": "Proverbs 27",
    "summary": "Source text for Proverbs 27 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.27.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 27:1",
      "text": "אַֽל ־ תִּ֭תְהַלֵּל בְּי֣וֹם מָחָ֑ר כִּ֤י לֹא ־ תֵ֝דַ֗ע מַה ־ יֵּ֥לֶד יֽוֹם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.27.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 27:2",
      "text": "יְהַלֶּלְךָ֣ זָ֣ר וְלֹא ־ פִ֑יךָ נָ֝כְרִ֗י וְאַל ־ שְׂפָתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 27:3",
      "text": "כֹּֽבֶד ־ אֶ֭בֶן וְנֵ֣טֶל הַח֑וֹל וְכַ֥עַס אֱ֝וִ֗יל כָּבֵ֥ד מִשְּׁנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 27:4",
      "text": "אַכְזְרִיּ֣וּת חֵ֭מָה וְשֶׁ֣טֶף אָ֑ף וּמִ֥י יַ֝עֲמֹד לִפְנֵ֥י קִנְאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 27:5",
      "text": "ט֭וֹבָה תּוֹכַ֣חַת מְגֻלָּ֑ה מֵֽאַהֲבָ֥ה מְסֻתָּֽרֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 27:6",
      "text": "נֶ֭אֱמָנִים פִּצְעֵ֣י אוֹהֵ֑ב וְ֝נַעְתָּר֗וֹת נְשִׁיק֥וֹת שׂוֹנֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 27:7",
      "text": "נֶ֣פֶשׁ שְׂ֭בֵעָה תָּב֣וּס נֹ֑פֶת וְנֶ֥פֶשׁ רְ֝עֵבָ֗ה כָּל ־ מַ֥ר מָתֽוֹק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 27:8",
      "text": "כְּ֭צִפּוֹר נוֹדֶ֣דֶת מִן ־ קִנָּ֑הּ כֵּֽן ־ אִ֝֗ישׁ נוֹדֵ֥ד מִמְּקוֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 27:9",
      "text": "שֶׁ֣מֶן וּ֭קְטֹרֶת יְשַׂמַּֽח ־ לֵ֑ב וּמֶ֥תֶק רֵ֝עֵ֗הוּ מֵֽעֲצַת ־ נָֽפֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 27:10",
      "text": "רֵֽעֲךָ֨ ורעה אָבִ֡יךָ אַֽל ־ תַּעֲזֹ֗ב וּבֵ֥ית אָחִ֗יךָ אַל ־ תָּ֭בוֹא בְּי֣וֹם אֵידֶ֑ךָ ט֥וֹב שָׁכֵ֥ן קָ֝ר֗וֹב מֵאָ֥ח רָחֽוֹק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 27:11",
      "text": "חֲכַ֣ם בְּ֭נִי וְשַׂמַּ֣ח לִבִּ֑י וְאָשִׁ֖יבָה חֹרְפִ֣י דָבָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 27:12",
      "text": "עָר֤וּם רָאָ֣ה רָעָ֣ה נִסְתָּ֑ר פְּ֝תָאיִ֗ם עָבְר֥וּ נֶעֱנָֽשׁוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 27:13",
      "text": "קַח ־ בִּ֭גְדוֹ כִּי ־ עָ֣רַב זָ֑ר וּבְעַ֖ד נָכְרִיָּ֣ה חַבְלֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 27:14",
      "text": "מְבָ֘רֵ֤ךְ רֵעֵ֨הוּ ׀ בְּק֣וֹל גָּ֭דוֹל בַּבֹּ֣קֶר הַשְׁכֵּ֑ים קְ֝לָלָ֗ה תֵּחָ֥שֶׁב לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 27:15",
      "text": "דֶּ֣לֶף ט֭וֹרֵד בְּי֣וֹם סַגְרִ֑יר וְאֵ֥שֶׁת מדונים נִשְׁתָּוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 27:16",
      "text": "צֹפְנֶ֥יהָ צָֽפַן ־ ר֑וּחַ וְשֶׁ֖מֶן יְמִינ֣וֹ יִקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 27:17",
      "text": "בַּרְזֶ֣ל בְּבַרְזֶ֣ל יָ֑חַד וְ֝אִ֗ישׁ יַ֣חַד פְּנֵֽי ־ רֵעֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 27:18",
      "text": "נֹצֵ֣ר תְּ֭אֵנָה יֹאכַ֣ל פִּרְיָ֑הּ וְשֹׁמֵ֖ר אֲדֹנָ֣יו יְכֻבָּֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 27:19",
      "text": "כַּ֭מַּיִם הַפָּנִ֣ים לַפָּנִ֑ים כֵּ֤ן לֵֽב ־ הָ֝אָדָ֗ם לָאָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 27:20",
      "text": "שְׁא֣וֹל ואבדה לֹ֣א תִשְׂבַּ֑עְנָה וְעֵינֵ֥י הָ֝אָדָ֗ם לֹ֣א תִשְׂבַּֽעְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 27:21",
      "text": "מַצְרֵ֣ף לַ֭כֶּסֶף וְכ֣וּר לַזָּהָ֑ב וְ֝אִ֗ישׁ לְפִ֣י מַהֲלָלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 27:22",
      "text": "אִ֥ם תִּכְתּֽוֹשׁ ־ אֶת ־ הָאֱוִ֨יל ׀ בַּֽמַּכְתֵּ֡שׁ בְּת֣וֹךְ הָ֭רִיפוֹת בַּֽעֱלִ֑י לֹא ־ תָס֥וּר מֵ֝עָלָ֗יו אִוַּלְתּֽוֹ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 27:23",
      "text": "יָדֹ֣עַ תֵּ֭דַע פְּנֵ֣י צֹאנֶ֑ךָ שִׁ֥ית לִ֝בְּךָ֗ לַעֲדָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 27:24",
      "text": "כִּ֤י לֹ֣א לְעוֹלָ֣ם חֹ֑סֶן וְאִם ־ נֵ֝֗זֶר לְד֣וֹר דור ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 27:25",
      "text": "גָּלָ֣ה חָ֭צִיר וְנִרְאָה ־ דֶ֑שֶׁא וְ֝נֶאֶסְפ֗וּ עִשְּׂב֥וֹת הָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 27:26",
      "text": "כְּבָשִׂ֥ים לִלְבוּשֶׁ֑ךָ וּמְחִ֥יר שָׂ֝דֶ֗ה עַתּוּדִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.27.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 27:27",
      "text": "וְדֵ֤י ׀ חֲלֵ֬ב עִזִּ֗ים לְֽ֭לַחְמְךָ לְלֶ֣חֶם בֵּיתֶ֑ךָ וְ֝חַיִּ֗ים לְנַעֲרוֹתֶֽיךָ ׃",
      "paragraphStart": false
    }
  ]
}
