{
  "chapter": {
    "id": "wlc:proverbs.1",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 1,
    "referenceLabel": "Proverbs 1",
    "summary": "Source text for Proverbs 1 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.1.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 1:1",
      "text": "מִ֭שְׁלֵי שְׁלֹמֹ֣ה בֶן ־ דָּוִ֑ד מֶ֝֗לֶךְ יִשְׂרָאֵֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.1.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 1:2",
      "text": "לָדַ֣עַת חָכְמָ֣ה וּמוּסָ֑ר לְ֝הָבִ֗ין אִמְרֵ֥י בִינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 1:3",
      "text": "לָ֭קַחַת מוּסַ֣ר הַשְׂכֵּ֑ל צֶ֥דֶק וּ֝מִשְׁפָּ֗ט וּמֵישָׁרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 1:4",
      "text": "לָתֵ֣ת לִפְתָאיִ֣ם עָרְמָ֑ה לְ֝נַ֗עַר דַּ֣עַת וּמְזִמָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 1:5",
      "text": "יִשְׁמַ֣ע חָ֭כָם וְי֣וֹסֶף לֶ֑קַח וְ֝נָב֗וֹן תַּחְבֻּל֥וֹת יִקְנֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 1:6",
      "text": "לְהָבִ֣ין מָ֭שָׁל וּמְלִיצָ֑ה דִּבְרֵ֥י חֲ֝כָמִ֗ים וְחִידֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 1:7",
      "text": "יִרְאַ֣ת יְ֭הוָה רֵאשִׁ֣ית דָּ֑עַת חָכְמָ֥ה וּ֝מוּסָ֗ר אֱוִילִ֥ים בָּֽזוּ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 1:8",
      "text": "שְׁמַ֣ע בְּ֭נִי מוּסַ֣ר אָבִ֑יךָ וְאַל ־ תִּ֝טֹּ֗שׁ תּוֹרַ֥ת אִמֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 1:9",
      "text": "כִּ֤י ׀ לִוְיַ֤ת חֵ֓ן הֵ֬ם לְרֹאשֶׁ֑ךָ וַ֝עֲנָקִ֗ים לְגַרְגְּרֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 1:10",
      "text": "בְּנִ֡י אִם ־ יְפַתּ֥וּךָ חַ֝טָּאִ֗ים אַל ־ תֹּבֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 1:11",
      "text": "אִם ־ יֹאמְרוּ֮ לְכָ֪ה אִ֫תָּ֥נוּ נֶאֶרְבָ֥ה לְדָ֑ם נִצְפְּנָ֖ה לְנָקִ֣י חִנָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 1:12",
      "text": "נִ֭בְלָעֵם כִּשְׁא֣וֹל חַיִּ֑ים וּ֝תְמִימִ֗ים כְּי֣וֹרְדֵי בֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 1:13",
      "text": "כָּל ־ ה֣וֹן יָקָ֣ר נִמְצָ֑א נְמַלֵּ֖א בָתֵּ֣ינוּ שָׁלָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 1:14",
      "text": "גּ֭וֹרָ֣לְךָ תַּפִּ֣יל בְּתוֹכֵ֑נוּ כִּ֥יס אֶ֝חָ֗ד יִהְיֶ֥ה לְכֻלָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 1:15",
      "text": "בְּנִ֗י אַל ־ תֵּלֵ֣ךְ בְּדֶ֣רֶךְ אִתָּ֑ם מְנַ֥ע רַ֝גְלְךָ֗ מִנְּתִיבָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 1:16",
      "text": "כִּ֣י רַ֭גְלֵיהֶם לָרַ֣ע יָר֑וּצוּ וִֽ֝ימַהֲר֗וּ לִשְׁפָּךְ ־ דָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 1:17",
      "text": "כִּֽי ־ חִ֭נָּם מְזֹרָ֣ה הָרָ֑שֶׁת בְּ֝עֵינֵ֗י כָל ־ בַּ֥עַל כָּנָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 1:18",
      "text": "וְ֭הֵם לְדָמָ֣ם יֶאֱרֹ֑בוּ יִ֝צְפְּנ֗וּ לְנַפְשֹׁתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 1:19",
      "text": "כֵּ֗ן אָ֭רְחוֹת כָּל ־ בֹּ֣צֵֽעַ בָּ֑צַע אֶת ־ נֶ֖פֶשׁ בְּעָלָ֣יו יִקָּֽח ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 1:20",
      "text": "חָ֭כְמוֹת בַּח֣וּץ תָּרֹ֑נָּה בָּ֝רְחֹב֗וֹת תִּתֵּ֥ן קוֹלָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 1:21",
      "text": "בְּרֹ֥אשׁ הֹמִיּ֗וֹת תִּ֫קְרָ֥א בְּפִתְחֵ֖י שְׁעָרִ֥ים בָּעִ֗יר אֲמָרֶ֥יהָ תֹאמֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 1:22",
      "text": "עַד ־ מָתַ֣י ׀ פְּתָיִם֮ תְּֽאֵהֲב֫וּ פֶ֥תִי וְלֵצִ֗ים לָ֭צוֹן חָמְד֣וּ לָהֶ֑ם וּ֝כְסִילִ֗ים יִשְׂנְאוּ ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 1:23",
      "text": "תָּשׁ֗וּבוּ לְֽת֫וֹכַחְתִּ֥י הִנֵּ֤ה אַבִּ֣יעָה לָכֶ֣ם רוּחִ֑י אוֹדִ֖יעָה דְבָרַ֣י אֶתְכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 1:24",
      "text": "יַ֣עַן קָ֭רָאתִי וַתְּמָאֵ֑נוּ נָטִ֥יתִי יָ֝דִ֗י וְאֵ֣ין מַקְשִֽׁיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 1:25",
      "text": "וַתִּפְרְע֥וּ כָל ־ עֲצָתִ֑י וְ֝תוֹכַחְתִּ֗י לֹ֣א אֲבִיתֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 1:26",
      "text": "גַּם ־ אֲ֭נִי בְּאֵידְכֶ֣ם אֶשְׂחָ֑ק אֶ֝לְעַ֗ג בְּבֹ֣א פַחְדְּכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 1:27",
      "text": "בְּבֹ֤א כשאוה ׀ פַּחְדְּכֶ֗ם וְֽ֭אֵידְכֶם כְּסוּפָ֣ה יֶאֱתֶ֑ה בְּבֹ֥א עֲ֝לֵיכֶ֗ם צָרָ֥ה וְצוּקָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 1:28",
      "text": "אָ֣ז יִ֭קְרָאֻנְנִי וְלֹ֣א אֶֽעֱנֶ֑ה יְ֝שַׁחֲרֻ֗נְנִי וְלֹ֣א יִמְצָאֻֽנְנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 1:29",
      "text": "תַּ֭חַת כִּי ־ שָׂ֣נְאוּ דָ֑עַת וְיִרְאַ֥ת יְ֝הֹוָ֗ה לֹ֣א בָחָֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 1:30",
      "text": "לֹא ־ אָב֥וּ לַעֲצָתִ֑י נָ֝אֲצ֗וּ כָּל ־ תּוֹכַחְתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 1:31",
      "text": "וְֽ֭יֹאכְלוּ מִפְּרִ֣י דַרְכָּ֑ם וּֽמִמֹּעֲצֹ֖תֵיהֶ֣ם יִשְׂבָּֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 1:32",
      "text": "כִּ֤י מְשׁוּבַ֣ת פְּתָיִ֣ם תַּֽהַרְגֵ֑ם וְשַׁלְוַ֖ת כְּסִילִ֣ים תְּאַבְּדֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.1.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 1:33",
      "text": "וְשֹׁמֵ֣עַֽ לִ֭י יִשְׁכָּן ־ בֶּ֑טַח וְ֝שַׁאֲנַ֗ן מִפַּ֥חַד רָעָֽה ׃ פ",
      "paragraphStart": false
    }
  ]
}
