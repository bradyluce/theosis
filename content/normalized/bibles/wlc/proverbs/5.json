{
  "chapter": {
    "id": "wlc:proverbs.5",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 5,
    "referenceLabel": "Proverbs 5",
    "summary": "Source text for Proverbs 5 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.5.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 5:1",
      "text": "בְּ֭נִי לְחָכְמָתִ֣י הַקְשִׁ֑יבָה לִ֝תְבוּנָתִ֗י הַט ־ אָזְנֶֽךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.5.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 5:2",
      "text": "לִשְׁמֹ֥ר מְזִמּ֑וֹת וְ֝דַ֗עַת שְׂפָתֶ֥יךָ יִנְצֹֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 5:3",
      "text": "כִּ֤י נֹ֣פֶת תִּ֭טֹּפְנָה שִׂפְתֵ֣י זָרָ֑ה וְחָלָ֖ק מִשֶּׁ֣מֶן חִכָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 5:4",
      "text": "וְֽ֭אַחֲרִיתָהּ מָרָ֣ה כַֽלַּעֲנָ֑ה חַ֝דָּ֗ה כְּחֶ֣רֶב פִּיּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 5:5",
      "text": "רַ֭גְלֶיהָ יֹרְד֣וֹת מָ֑וֶת שְׁ֝א֗וֹל צְעָדֶ֥יהָ יִתְמֹֽכוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 5:6",
      "text": "אֹ֣רַח חַ֭יִּים פֶּן ־ תְּפַלֵּ֑ס נָע֥וּ מַ֝עְגְּלֹתֶ֗יהָ לֹ֣א תֵדָֽע ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 5:7",
      "text": "וְעַתָּ֣ה בָ֭נִים שִׁמְעוּ ־ לִ֑י וְאַל ־ תָּ֝ס֗וּרוּ מֵאִמְרֵי ־ פִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 5:8",
      "text": "הַרְחֵ֣ק מֵעָלֶ֣יהָ דַרְכֶּ֑ךָ וְאַל ־ תִּ֝קְרַ֗ב אֶל ־ פֶּ֥תַח בֵּיתָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 5:9",
      "text": "פֶּן ־ תִּתֵּ֣ן לַאֲחֵרִ֣ים הוֹדֶ֑ךָ וּ֝שְׁנֹתֶ֗יךָ לְאַכְזָרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 5:10",
      "text": "פֶּֽן ־ יִשְׂבְּע֣וּ זָרִ֣ים כֹּחֶ֑ךָ וַ֝עֲצָבֶ֗יךָ בְּבֵ֣ית נָכְרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 5:11",
      "text": "וְנָהַמְתָּ֥ בְאַחֲרִיתֶ֑ךָ בִּכְל֥וֹת בְּ֝שָׂרְךָ֗ וּשְׁאֵרֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 5:12",
      "text": "וְֽאָמַרְתָּ֗ אֵ֭יךְ שָׂנֵ֣אתִי מוּסָ֑ר וְ֝תוֹכַ֗חַת נָאַ֥ץ לִבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 5:13",
      "text": "וְֽלֹא ־ שָׁ֭מַעְתִּי בְּק֣וֹל מוֹרָ֑י וְ֝לִֽמְלַמְּדַ֗י לֹא ־ הִטִּ֥יתִי אָזְנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 5:14",
      "text": "כִּ֭מְעַט הָיִ֣יתִי בְכָל ־ רָ֑ע בְּת֖וֹךְ קָהָ֣ל וְעֵדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 5:15",
      "text": "שְׁתֵה ־ מַ֥יִם מִבּוֹרֶ֑ךָ וְ֝נֹזְלִ֗ים מִתּ֥וֹךְ בְּאֵרֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 5:16",
      "text": "יָפ֣וּצוּ מַעְיְנֹתֶ֣יךָ ח֑וּצָה בָּ֝רְחֹב֗וֹת פַּלְגֵי ־ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 5:17",
      "text": "יִֽהְיוּ ־ לְךָ֥ לְבַדֶּ֑ךָ וְאֵ֖ין לְזָרִ֣ים אִתָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 5:18",
      "text": "יְהִֽי ־ מְקוֹרְךָ֥ בָר֑וּךְ וּ֝שְׂמַ֗ח מֵאֵ֥שֶׁת נְעוּרֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 5:19",
      "text": "אַיֶּ֥לֶת אֲהָבִ֗ים וְֽיַעֲלַ֫ת ־ חֵ֥ן דַּ֭דֶּיהָ יְרַוֻּ֣ךָ בְכָל ־ עֵ֑ת בְּ֝אַהֲבָתָ֗הּ תִּשְׁגֶּ֥ה תָמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 5:20",
      "text": "וְלָ֤מָּה תִשְׁגֶּ֣ה בְנִ֣י בְזָרָ֑ה וּ֝תְחַבֵּ֗ק חֵ֣ק נָכְרִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 5:21",
      "text": "כִּ֤י נֹ֨כַח ׀ עֵינֵ֣י יְ֭הוָה דַּרְכֵי ־ אִ֑ישׁ וְֽכָל ־ מַעְגְּלֹתָ֥יו מְפַלֵּֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 5:22",
      "text": "עַֽווֹנוֹתָ֗יו יִלְכְּדֻנ֥וֹ אֶת ־ הָרָשָׁ֑ע וּבְחַבְלֵ֥י חַ֝טָּאת֗וֹ יִתָּמֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.5.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 5:23",
      "text": "ה֗וּא יָ֭מוּת בְּאֵ֣ין מוּסָ֑ר וּבְרֹ֖ב אִוַּלְתּ֣וֹ יִשְׁגֶּֽה ׃ פ",
      "paragraphStart": false
    }
  ]
}
