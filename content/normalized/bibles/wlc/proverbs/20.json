{
  "chapter": {
    "id": "wlc:proverbs.20",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 20,
    "referenceLabel": "Proverbs 20",
    "summary": "Source text for Proverbs 20 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.20.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 20:1",
      "text": "לֵ֣ץ הַ֭יַּין הֹמֶ֣ה שֵׁכָ֑ר וְכָל ־ שֹׁ֥גֶה בּ֝֗וֹ לֹ֣א יֶחְכָּֽם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.20.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 20:2",
      "text": "נַ֣הַם כַּ֭כְּפִיר אֵ֣ימַת מֶ֑לֶךְ מִ֝תְעַבְּר֗וֹ חוֹטֵ֥א נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 20:3",
      "text": "כָּב֣וֹד לָ֭אִישׁ שֶׁ֣בֶת מֵרִ֑יב וְכָל ־ אֱ֝וִ֗יל יִתְגַּלָּֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 20:4",
      "text": "מֵ֭חֹרֶף עָצֵ֣ל לֹא ־ יַחֲרֹ֑שׁ ישאל בַּקָּצִ֣יר וָאָֽיִן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 20:5",
      "text": "מַ֣יִם עֲ֭מֻקִּים עֵצָ֣ה בְלֶב ־ אִ֑ישׁ וְאִ֖ישׁ תְּבוּנָ֣ה יִדְלֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 20:6",
      "text": "רָב ־ אָדָ֗ם יִ֭קְרָא אִ֣ישׁ חַסְדּ֑וֹ וְאִ֥ישׁ אֱ֝מוּנִ֗ים מִ֣י יִמְצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 20:7",
      "text": "מִתְהַלֵּ֣ךְ בְּתֻמּ֣וֹ צַדִּ֑יק אַשְׁרֵ֖י בָנָ֣יו אַחֲרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 20:8",
      "text": "מֶ֗לֶךְ יוֹשֵׁ֥ב עַל ־ כִּסֵּא ־ דִ֑ין מְזָרֶ֖ה בְעֵינָ֣יו כָּל ־ רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 20:9",
      "text": "מִֽי ־ יֹ֭אמַר זִכִּ֣יתִי לִבִּ֑י טָ֝הַ֗רְתִּי מֵחַטָּאתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 20:10",
      "text": "אֶ֣בֶן וָ֭אֶבֶן אֵיפָ֣ה וְאֵיפָ֑ה תּוֹעֲבַ֥ת יְ֝הוָ֗ה גַּם ־ שְׁנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 20:11",
      "text": "גַּ֣ם בְּ֭מַעֲלָלָיו יִתְנַכֶּר ־ נָ֑עַר אִם ־ זַ֖ךְ וְאִם ־ יָשָׁ֣ר פָּעֳלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 20:12",
      "text": "אֹ֣זֶן שֹׁ֭מַעַת וְעַ֣יִן רֹאָ֑ה יְ֝הוָ֗ה עָשָׂ֥ה גַם ־ שְׁנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 20:13",
      "text": "אַל ־ תֶּֽאֱהַ֣ב שֵׁ֭נָה פֶּן ־ תִּוָּרֵ֑שׁ פְּקַ֖ח עֵינֶ֣יךָ שְֽׂבַֽע ־ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 20:14",
      "text": "רַ֣ע רַ֭ע יֹאמַ֣ר הַקּוֹנֶ֑ה וְאֹזֵ֥ל ל֝֗וֹ אָ֣ז יִתְהַלָּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 20:15",
      "text": "יֵ֣שׁ זָ֭הָב וְרָב ־ פְּנִינִ֑ים וּכְלִ֥י יְ֝קָ֗ר שִׂפְתֵי ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 20:16",
      "text": "לְֽקַח ־ בִּ֭גְדוֹ כִּי ־ עָ֣רַב זָ֑ר וּבְעַ֖ד נכרים חַבְלֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 20:17",
      "text": "עָרֵ֣ב לָ֭אִישׁ לֶ֣חֶם שָׁ֑קֶר וְ֝אַחַ֗ר יִמָּֽלֵא ־ פִ֥יהוּ חָצָֽץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 20:18",
      "text": "מַ֭חֲשָׁבוֹת בְּעֵצָ֣ה תִכּ֑וֹן וּ֝בְתַחְבֻּל֗וֹת עֲשֵׂ֣ה מִלְחָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 20:19",
      "text": "גּֽוֹלֶה ־ סּ֭וֹד הוֹלֵ֣ךְ רָכִ֑יל וּלְפֹתֶ֥ה שְׂ֝פָתָ֗יו לֹ֣א תִתְעָרָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 20:20",
      "text": "מְ֭קַלֵּל אָבִ֣יו וְאִמּ֑וֹ יִֽדְעַ֥ךְ נֵ֝ר֗וֹ באישון חֹֽשֶׁךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 20:21",
      "text": "נַ֭חֲלָה מבחלת בָּרִאשֹׁנָ֑ה וְ֝אַחֲרִיתָ֗הּ לֹ֣א תְבֹרָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 20:22",
      "text": "אַל ־ תֹּאמַ֥ר אֲשַׁלְּמָה ־ רָ֑ע קַוֵּ֥ה לַֽ֝יהוָ֗ה וְיֹ֣שַֽׁע לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 20:23",
      "text": "תּוֹעֲבַ֣ת יְ֭הוָה אֶ֣בֶן וָאָ֑בֶן וּמֹאזְנֵ֖י מִרְמָ֣ה לֹא ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 20:24",
      "text": "מֵיהוָ֥ה מִצְעֲדֵי ־ גָ֑בֶר וְ֝אָדָ֗ם מַה ־ יָּבִ֥ין דַּרְכּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 20:25",
      "text": "מוֹקֵ֣שׁ אָ֭דָם יָ֣לַע קֹ֑דֶשׁ וְאַחַ֖ר נְדָרִ֣ים לְבַקֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 20:26",
      "text": "מְזָרֶ֣ה רְ֭שָׁעִים מֶ֣לֶךְ חָכָ֑ם וַיָּ֖שֶׁב עֲלֵיהֶ֣ם אוֹפָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 20:27",
      "text": "נֵ֣ר יְ֭הוָה נִשְׁמַ֣ת אָדָ֑ם חֹ֝פֵ֗שׂ כָּל ־ חַדְרֵי ־ בָֽטֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 20:28",
      "text": "חֶ֣סֶד וֶ֭אֱמֶת יִצְּרוּ ־ מֶ֑לֶךְ וְסָעַ֖ד בַּחֶ֣סֶד כִּסְאֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 20:29",
      "text": "תִּפְאֶ֣רֶת בַּחוּרִ֣ים כֹּחָ֑ם וַהֲדַ֖ר זְקֵנִ֣ים שֵׂיבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.20.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 20:30",
      "text": "חַבֻּר֣וֹת פֶּ֭צַע תמריק בְּרָ֑ע וּ֝מַכּ֗וֹת חַדְרֵי ־ בָֽטֶן ׃",
      "paragraphStart": false
    }
  ]
}
