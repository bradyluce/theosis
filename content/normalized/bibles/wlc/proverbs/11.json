{
  "chapter": {
    "id": "wlc:proverbs.11",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 11,
    "referenceLabel": "Proverbs 11",
    "summary": "Source text for Proverbs 11 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.11.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 11:1",
      "text": "מֹאזְנֵ֣י מִ֭רְמָה תּוֹעֲבַ֣ת יְהוָ֑ה וְאֶ֖בֶן שְׁלֵמָ֣ה רְצוֹנֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.11.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 11:2",
      "text": "בָּֽא ־ זָ֭דוֹן וַיָּבֹ֣א קָל֑וֹן וְֽאֶת ־ צְנוּעִ֥ים חָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 11:3",
      "text": "תֻּמַּ֣ת יְשָׁרִ֣ים תַּנְחֵ֑ם וְסֶ֖לֶף בּוֹגְדִ֣ים ושדם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 11:4",
      "text": "לֹא ־ יוֹעִ֣יל ה֭וֹן בְּי֣וֹם עֶבְרָ֑ה וּ֝צְדָקָ֗ה תַּצִּ֥יל מִמָּֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 11:5",
      "text": "צִדְקַ֣ת תָּ֭מִים תְּיַשֵּׁ֣ר דַּרְכּ֑וֹ וּ֝בְרִשְׁעָת֗וֹ יִפֹּ֥ל רָשָֽׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 11:6",
      "text": "צִדְקַ֣ת יְ֭שָׁרִים תַּצִּילֵ֑ם וּ֝בְהַוַּ֗ת בֹּגְדִ֥ים יִלָּכֵֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 11:7",
      "text": "בְּמ֤וֹת אָדָ֣ם רָ֭שָׁע תֹּאבַ֣ד תִּקְוָ֑ה וְתוֹחֶ֖לֶת אוֹנִ֣ים אָבָֽדָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 11:8",
      "text": "צַ֭דִּיק מִצָּרָ֣ה נֶחֱלָ֑ץ וַיָּבֹ֖א רָשָׁ֣ע תַּחְתָּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 11:9",
      "text": "בְּפֶ֗ה חָ֭נֵף יַשְׁחִ֣ת רֵעֵ֑הוּ וּ֝בְדַ֗עַת צַדִּיקִ֥ים יֵחָלֵֽצוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 11:10",
      "text": "בְּט֣וּב צַ֭דִּיקִים תַּעֲלֹ֣ץ קִרְיָ֑ה וּבַאֲבֹ֖ד רְשָׁעִ֣ים רִנָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 11:11",
      "text": "בְּבִרְכַּ֣ת יְ֭שָׁרִים תָּר֣וּם קָ֑רֶת וּבְפִ֥י רְ֝שָׁעִ֗ים תֵּהָרֵֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 11:12",
      "text": "בָּז ־ לְרֵעֵ֥הוּ חֲסַר ־ לֵ֑ב וְאִ֖ישׁ תְּבוּנ֣וֹת יַחֲרִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 11:13",
      "text": "הוֹלֵ֣ךְ רָ֭כִיל מְגַלֶּה ־ סּ֑וֹד וְנֶאֱמַן ־ ר֝֗וּחַ מְכַסֶּ֥ה דָבָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 11:14",
      "text": "בְּאֵ֣ין תַּ֭חְבֻּלוֹת יִפָּל ־ עָ֑ם וּ֝תְשׁוּעָ֗ה בְּרֹ֣ב יוֹעֵֽץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 11:15",
      "text": "רַע ־ יֵ֭רוֹעַ כִּי ־ עָ֣רַב זָ֑ר וְשֹׂנֵ֖א תֹקְעִ֣ים בּוֹטֵֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 11:16",
      "text": "אֵֽשֶׁת ־ חֵ֭ן תִּתְמֹ֣ךְ כָּב֑וֹד וְ֝עָרִיצִ֗ים יִתְמְכוּ ־ עֹֽשֶׁר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 11:17",
      "text": "גֹּמֵ֣ל נַ֭פְשׁוֹ אִ֣ישׁ חָ֑סֶד וְעֹכֵ֥ר שְׁ֝אֵר֗וֹ אַכְזָרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 11:18",
      "text": "רָשָׁ֗ע עֹשֶׂ֥ה פְעֻלַּת ־ שָׁ֑קֶר וְזֹרֵ֥עַ צְ֝דָקָ֗ה שֶׂ֣כֶר אֱמֶֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 11:19",
      "text": "כֵּן ־ צְדָקָ֥ה לְחַיִּ֑ים וּמְרַדֵּ֖ף רָעָ֣ה לְמוֹתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 11:20",
      "text": "תּוֹעֲבַ֣ת יְ֭הוָה עִקְּשֵׁי ־ לֵ֑ב וּ֝רְצוֹנ֗וֹ תְּמִ֣ימֵי דָֽרֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 11:21",
      "text": "יָ֣ד לְ֭יָד לֹא ־ יִנָּ֣קֶה רָּ֑ע וְזֶ֖רַע צַדִּיקִ֣ים נִמְלָֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 11:22",
      "text": "נֶ֣זֶם זָ֭הָב בְּאַ֣ף חֲזִ֑יר אִשָּׁ֥ה יָ֝פָ֗ה וְסָ֣רַת טָֽעַם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 11:23",
      "text": "תַּאֲוַ֣ת צַדִּיקִ֣ים אַךְ ־ ט֑וֹב תִּקְוַ֖ת רְשָׁעִ֣ים עֶבְרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 11:24",
      "text": "יֵ֣שׁ מְ֭פַזֵּר וְנוֹסָ֥ף ע֑וֹד וְחוֹשֵׂ֥ךְ מִ֝יֹּ֗שֶׁר אַךְ ־ לְמַחְסֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 11:25",
      "text": "נֶֽפֶשׁ ־ בְּרָכָ֥ה תְדֻשָּׁ֑ן וּ֝מַרְוֶ֗ה גַּם ־ ה֥וּא יוֹרֶֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 11:26",
      "text": "מֹ֣נֵֽעַ בָּ֭ר יִקְּבֻ֣הוּ לְא֑וֹם וּ֝בְרָכָ֗ה לְרֹ֣אשׁ מַשְׁבִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 11:27",
      "text": "שֹׁ֣חֵֽר ט֭וֹב יְבַקֵּ֣שׁ רָצ֑וֹן וְדֹרֵ֖שׁ רָעָ֣ה תְבוֹאֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 11:28",
      "text": "בּוֹטֵ֣חַ בְּ֭עָשְׁרוֹ ה֣וּא יִפֹּ֑ל וְ֝כֶעָלֶ֗ה צַדִּיקִ֥ים יִפְרָֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 11:29",
      "text": "עוֹכֵ֣ר בֵּ֭יתוֹ יִנְחַל ־ ר֑וּחַ וְעֶ֥בֶד אֱ֝וִ֗יל לַחֲכַם ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 11:30",
      "text": "פְּֽרִי ־ צַ֭דִּיק עֵ֣ץ חַיִּ֑ים וְלֹקֵ֖חַ נְפָשׂ֣וֹת חָכָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.11.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 11:31",
      "text": "הֵ֣ן צַ֭דִּיק בָּאָ֣רֶץ יְשֻׁלָּ֑ם אַ֝֗ף כִּֽי ־ רָשָׁ֥ע וְחוֹטֵֽא ׃",
      "paragraphStart": false
    }
  ]
}
