{
  "chapter": {
    "id": "wlc:proverbs.6",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 6,
    "referenceLabel": "Proverbs 6",
    "summary": "Source text for Proverbs 6 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.6.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 6:1",
      "text": "בְּ֭נִי אִם ־ עָרַ֣בְתָּ לְרֵעֶ֑ךָ תָּקַ֖עְתָּ לַזָּ֣ר כַּפֶּֽיךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.6.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 6:2",
      "text": "נוֹקַ֥שְׁתָּ בְאִמְרֵי ־ פִ֑יךָ נִ֝לְכַּ֗דְתָּ בְּאִמְרֵי ־ פִֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 6:3",
      "text": "עֲשֵׂ֨ה זֹ֥את אֵפ֪וֹא ׀ בְּנִ֡י וְֽהִנָּצֵ֗ל כִּ֘י בָ֤אתָ בְכַף ־ רֵעֶ֑ךָ לֵ֥ךְ הִ֝תְרַפֵּ֗ס וּרְהַ֥ב רֵעֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 6:4",
      "text": "אַל ־ תִּתֵּ֣ן שֵׁנָ֣ה לְעֵינֶ֑יךָ וּ֝תְנוּמָ֗ה לְעַפְעַפֶּֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 6:5",
      "text": "הִ֭נָּצֵל כִּצְבִ֣י מִיָּ֑ד וּ֝כְצִפּ֗וֹר מִיַּ֥ד יָקֽוּשׁ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 6:6",
      "text": "לֵֽךְ ־ אֶל ־ נְמָלָ֥ה עָצֵ֑ל רְאֵ֖ה דְרָכֶ֣יהָ וַחֲכָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 6:7",
      "text": "אֲשֶׁ֖ר אֵֽין ־ לָ֥הּ קָצִ֗ין שֹׁטֵ֥ר וּמֹשֵֽׁל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 6:8",
      "text": "תָּכִ֣ין בַּקַּ֣יִץ לַחְמָ֑הּ אָגְרָ֥ה בַ֝קָּצִ֗יר מַאֲכָלָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 6:9",
      "text": "עַד ־ מָתַ֖י עָצֵ֥ל ׀ תִּשְׁכָּ֑ב מָ֝תַ֗י תָּק֥וּם מִשְּׁנָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 6:10",
      "text": "מְעַ֣ט שֵׁ֭נוֹת מְעַ֣ט תְּנוּמ֑וֹת מְעַ֓ט ׀ חִבֻּ֖ק יָדַ֣יִם לִשְׁכָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 6:11",
      "text": "וּבָֽא ־ כִמְהַלֵּ֥ךְ רֵאשֶׁ֑ךָ וּ֝מַחְסֹֽרְךָ֗ כְּאִ֣ישׁ מָגֵֽן ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 6:12",
      "text": "אָדָ֣ם בְּ֭לִיַּעַל אִ֣ישׁ אָ֑וֶן ה֝וֹלֵ֗ךְ עִקְּשׁ֥וּת פֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 6:13",
      "text": "קֹרֵ֣ץ בְּ֭עֵינָו מֹלֵ֣ל בְּרַגְלָ֑ו מֹ֝רֶ֗ה בְּאֶצְבְּעֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 6:14",
      "text": "תַּֽהְפֻּכ֨וֹת ׀ בְּלִבּ֗וֹ חֹרֵ֣שׁ רָ֣ע בְּכָל ־ עֵ֑ת מדנים יְשַׁלֵּֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 6:15",
      "text": "עַל ־ כֵּ֗ן פִּ֭תְאֹם יָב֣וֹא אֵיד֑וֹ פֶּ֥תַע יִ֝שָּׁבֵ֗ר וְאֵ֣ין מַרְפֵּֽא ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 6:16",
      "text": "שֶׁשׁ ־ הֵ֭נָּה שָׂנֵ֣א יְהוָ֑ה וְ֝שֶׁ֗בַע תועבות נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 6:17",
      "text": "עֵינַ֣יִם רָ֭מוֹת לְשׁ֣וֹן שָׁ֑קֶר וְ֝יָדַ֗יִם שֹׁפְכ֥וֹת דָּם ־ נָקִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 6:18",
      "text": "לֵ֗ב חֹ֭רֵשׁ מַחְשְׁב֣וֹת אָ֑וֶן רַגְלַ֥יִם מְ֝מַהֲר֗וֹת לָר֥וּץ לָֽרָעָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 6:19",
      "text": "יָפִ֣יחַ כְּ֭זָבִים עֵ֣ד שָׁ֑קֶר וּמְשַׁלֵּ֥חַ מְ֝דָנִ֗ים בֵּ֣ין אַחִֽים ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 6:20",
      "text": "נְצֹ֣ר בְּ֭נִי מִצְוַ֣ת אָבִ֑יךָ וְאַל ־ תִּ֝טֹּ֗שׁ תּוֹרַ֥ת אִמֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 6:21",
      "text": "קָשְׁרֵ֣ם עַל ־ לִבְּךָ֣ תָמִ֑יד עָ֝נְדֵ֗ם עַל ־ גַּרְגְּרֹתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 6:22",
      "text": "בְּהִתְהַלֶּכְךָ֨ ׀ תַּנְחֶ֬ה אֹתָ֗ךְ בְּֽ֭שָׁכְבְּךָ תִּשְׁמֹ֣ר עָלֶ֑יךָ וַ֝הֲקִיצ֗וֹתָ הִ֣יא תְשִׂיחֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 6:23",
      "text": "כִּ֤י נֵ֣ר מִ֭צְוָה וְת֣וֹרָה א֑וֹר וְדֶ֥רֶךְ חַ֝יִּ֗ים תּוֹכְח֥וֹת מוּסָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 6:24",
      "text": "לִ֭שְׁמָרְךָ מֵאֵ֣שֶׁת רָ֑ע מֵֽ֝חֶלְקַ֗ת לָשׁ֥וֹן נָכְרִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 6:25",
      "text": "אַל ־ תַּחְמֹ֣ד יָ֭פְיָהּ בִּלְבָבֶ֑ךָ וְאַל ־ תִּ֝קָּֽחֲךָ֗ בְּעַפְעַפֶּֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 6:26",
      "text": "כִּ֤י בְעַד ־ אִשָּׁ֥ה זוֹנָ֗ה עַֽד ־ כִּכַּ֫ר לָ֥חֶם וְאֵ֥שֶׁת אִ֑ישׁ נֶ֖פֶשׁ יְקָרָ֣ה תָצֽוּד ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 6:27",
      "text": "הֲיַחְתֶּ֤ה אִ֓ישׁ אֵ֬שׁ בְּחֵיק֑וֹ וּ֝בְגָדָ֗יו לֹ֣א תִשָּׂרַֽפְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 6:28",
      "text": "אִם ־ יְהַלֵּ֣ךְ אִ֭ישׁ עַל ־ הַגֶּחָלִ֑ים וְ֝רַגְלָ֗יו לֹ֣א תִכָּוֶֽינָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 6:29",
      "text": "כֵּ֗ן הַ֭בָּא אֶל ־ אֵ֣שֶׁת רֵעֵ֑הוּ לֹ֥א יִ֝נָּקֶ֗ה כָּֽל ־ הַנֹּגֵ֥עַ בָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 6:30",
      "text": "לֹא ־ יָב֣וּזוּ לַ֭גַּנָּב כִּ֣י יִגְנ֑וֹב לְמַלֵּ֥א נַ֝פְשׁ֗וֹ כִּ֣י יִרְעָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 6:31",
      "text": "וְ֭נִמְצָא יְשַׁלֵּ֣ם שִׁבְעָתָ֑יִם אֶת ־ כָּל ־ ה֖וֹן בֵּית֣וֹ יִתֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 6:32",
      "text": "נֹאֵ֣ף אִשָּׁ֣ה חֲסַר ־ לֵ֑ב מַֽשְׁחִ֥ית נַ֝פְשׁ֗וֹ ה֣וּא יַעֲשֶֽׂנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 6:33",
      "text": "נֶֽגַע ־ וְקָל֥וֹן יִמְצָ֑א וְ֝חֶרְפָּת֗וֹ לֹ֣א תִמָּחֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.34",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 6:34",
      "text": "כִּֽי ־ קִנְאָ֥ה חֲמַת ־ גָּ֑בֶר וְלֹֽא ־ יַ֝חְמ֗וֹל בְּי֣וֹם נָקָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.6.35",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 6:35",
      "text": "לֹא ־ יִ֭שָּׂא פְּנֵ֣י כָל ־ כֹּ֑פֶר וְלֹֽא ־ יֹ֝אבֶ֗ה כִּ֣י תַרְבֶּה ־ שֹֽׁחַד ׃ פ",
      "paragraphStart": false
    }
  ]
}
