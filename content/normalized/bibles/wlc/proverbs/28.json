{
  "chapter": {
    "id": "wlc:proverbs.28",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 28,
    "referenceLabel": "Proverbs 28",
    "summary": "Source text for Proverbs 28 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.28.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 28:1",
      "text": "נָ֣סוּ וְאֵין ־ רֹדֵ֣ף רָשָׁ֑ע וְ֝צַדִּיקִ֗ים כִּכְפִ֥יר יִבְטָֽח ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.28.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 28:2",
      "text": "בְּפֶ֣שַֽׁע אֶ֭רֶץ רַבִּ֣ים שָׂרֶ֑יהָ וּבְאָדָ֥ם מֵבִ֥ין יֹ֝דֵ֗עַ כֵּ֣ן יַאֲרִֽיךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 28:3",
      "text": "גֶּ֣בֶר רָ֭שׁ וְעֹשֵׁ֣ק דַּלִּ֑ים מָטָ֥ר סֹ֝חֵ֗ף וְאֵ֣ין לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 28:4",
      "text": "עֹזְבֵ֣י ת֭וֹרָה יְהַֽלְל֣וּ רָשָׁ֑ע וְשֹׁמְרֵ֥י ת֝וֹרָ֗ה יִתְגָּ֥רוּ בָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 28:5",
      "text": "אַנְשֵׁי ־ רָ֭ע לֹא ־ יָבִ֣ינוּ מִשְׁפָּ֑ט וּמְבַקְשֵׁ֥י יְ֝הוָ֗ה יָבִ֥ינוּ כֹֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 28:6",
      "text": "טֽוֹב ־ רָ֭שׁ הוֹלֵ֣ךְ בְּתֻמּ֑וֹ מֵעִקֵּ֥שׁ דְּ֝רָכַ֗יִם וְה֣וּא עָשִֽׁיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 28:7",
      "text": "נוֹצֵ֣ר תּ֭וֹרָה בֵּ֣ן מֵבִ֑ין וְרֹעֶה זֽ֝וֹלְלִ֗ים יַכְלִ֥ים אָבִֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 28:8",
      "text": "מַרְבֶּ֣ה ה֭וֹנוֹ בְּנֶ֣שֶׁךְ ובתרבית לְחוֹנֵ֖ן דַּלִּ֣ים יִקְבְּצֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 28:9",
      "text": "מֵסִ֣יר אָ֭זְנוֹ מִשְּׁמֹ֣עַ תּוֹרָ֑ה גַּֽם ־ תְּ֝פִלָּת֗וֹ תּוֹעֵבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 28:10",
      "text": "מַשְׁגֶּ֤ה יְשָׁרִ֨ים ׀ בְּדֶ֥רֶךְ רָ֗ע בִּשְׁחוּת֥וֹ הֽוּא ־ יִפּ֑וֹל וּ֝תְמִימִ֗ים יִנְחֲלוּ ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 28:11",
      "text": "חָכָ֣ם בְּ֭עֵינָיו אִ֣ישׁ עָשִׁ֑יר וְדַ֖ל מֵבִ֣ין יַחְקְרֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 28:12",
      "text": "בַּעֲלֹ֣ץ צַ֭דִּיקִים רַבָּ֣ה תִפְאָ֑רֶת וּבְק֥וּם רְ֝שָׁעִ֗ים יְחֻפַּ֥שׂ אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 28:13",
      "text": "מְכַסֶּ֣ה פְ֭שָׁעָיו לֹ֣א יַצְלִ֑יחַ וּמוֹדֶ֖ה וְעֹזֵ֣ב יְרֻחָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 28:14",
      "text": "אַשְׁרֵ֣י אָ֭דָם מְפַחֵ֣ד תָּמִ֑יד וּמַקְשֶׁ֥ה לִ֝בּ֗וֹ יִפּ֥וֹל בְּרָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 28:15",
      "text": "אֲרִי ־ נֹ֭הֵם וְדֹ֣ב שׁוֹקֵ֑ק מֹשֵׁ֥ל רָ֝שָׁ֗ע עַ֣ל עַם ־ דָּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 28:16",
      "text": "נָגִ֗יד חֲסַ֣ר תְּ֭בוּנוֹת וְרַ֥ב מַעֲשַׁקּ֑וֹת שנאי בֶ֝֗צַע יַאֲרִ֥יךְ יָמִֽים ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 28:17",
      "text": "אָ֭דָם עָשֻׁ֣ק בְּדַם ־ נָפֶשׁ עַד ־ בּ֥וֹר יָ֝נ֗וּס אַל ־ יִתְמְכוּ ־ בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 28:18",
      "text": "הוֹלֵ֣ךְ תָּ֭מִים יִוָּשֵׁ֑עַ וְנֶעְקַ֥שׁ דְּ֝רָכַ֗יִם יִפּ֥וֹל בְּאֶחָֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 28:19",
      "text": "עֹבֵ֣ד אַ֭דְמָתוֹ יִֽשְׂבַּֽע ־ לָ֑חֶם וּמְרַדֵּ֥ף רֵ֝קִ֗ים יִֽשְׂבַּֽע ־ רִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 28:20",
      "text": "אִ֣ישׁ אֱ֭מוּנוֹת רַב ־ בְּרָכ֑וֹת וְאָ֥ץ לְ֝הַעֲשִׁ֗יר לֹ֣א יִנָּקֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 28:21",
      "text": "הַֽכֵּר ־ פָּנִ֥ים לֹא ־ ט֑וֹב וְעַל ־ פַּת ־ לֶ֝֗חֶם יִפְשַׁע ־ גָּֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 28:22",
      "text": "נִֽבֳהָ֥ל לַה֗וֹן אִ֭ישׁ רַ֣ע עָ֑יִן וְלֹֽא ־ יֵ֝דַע כִּי ־ חֶ֥סֶר יְבֹאֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 28:23",
      "text": "מ֘וֹכִ֤יחַ אָדָ֣ם אַ֭חֲרַי חֵ֣ן יִמְצָ֑א מִֽמַּחֲלִ֥יק לָשֽׁוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 28:24",
      "text": "גּוֹזֵ֤ל ׀ אָ֘בִ֤יו וְאִמּ֗וֹ וְאֹמֵ֥ר אֵֽין ־ פָּ֑שַׁע חָבֵ֥ר ה֝֗וּא לְאִ֣ישׁ מַשְׁחִֽית ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 28:25",
      "text": "רְחַב ־ נֶ֭פֶשׁ יְגָרֶ֣ה מָד֑וֹן וּבוֹטֵ֖חַ עַל ־ יְהוָ֣ה יְדֻשָּֽׁן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 28:26",
      "text": "בּוֹטֵ֣חַ בְּ֭לִבּוֹ ה֣וּא כְסִ֑יל וְהוֹלֵ֥ךְ בְּ֝חָכְמָ֗ה ה֣וּא יִמָּלֵֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 28:27",
      "text": "נוֹתֵ֣ן לָ֭רָשׁ אֵ֣ין מַחְס֑וֹר וּמַעְלִ֥ים עֵ֝ינָ֗יו רַב ־ מְאֵרֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.28.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 28:28",
      "text": "בְּק֣וּם רְ֭שָׁעִים יִסָּתֵ֣ר אָדָ֑ם וּ֝בְאָבְדָ֗ם יִרְבּ֥וּ צַדִּיקִֽים ׃",
      "paragraphStart": false
    }
  ]
}
