{
  "chapter": {
    "id": "wlc:proverbs.23",
    "translationId": "wlc",
    "bookSlug": "proverbs",
    "chapterNumber": 23,
    "referenceLabel": "Proverbs 23",
    "summary": "Source text for Proverbs 23 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:proverbs.23.1",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 23:1",
      "text": "כִּֽי ־ תֵ֭שֵׁב לִלְח֣וֹם אֶת ־ מוֹשֵׁ֑ל בִּ֥ין תָּ֝בִ֗ין אֶת ־ אֲשֶׁ֥ר לְפָנֶֽיךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:proverbs.23.2",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 23:2",
      "text": "וְשַׂמְתָּ֣ שַׂכִּ֣ין בְּלֹעֶ֑ךָ אִם ־ בַּ֖עַל נֶ֣פֶשׁ אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.3",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 23:3",
      "text": "אַל ־ תִּ֭תְאָו לְמַטְעַמּוֹתָ֑יו וְ֝ה֗וּא לֶ֣חֶם כְּזָבִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.4",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 23:4",
      "text": "אַל ־ תִּיגַ֥ע לְֽהַעֲשִׁ֑יר מִֽבִּינָתְךָ֥ חֲדָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.5",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 23:5",
      "text": "התעוף עֵינֶ֥יךָ בּ֗וֹ וְֽאֵ֫ינֶ֥נּוּ כִּ֤י עָשֹׂ֣ה יַעֲשֶׂה ־ לּ֣וֹ כְנָפַ֑יִם כְּ֝נֶ֗שֶׁר ועיף הַשָּׁמָֽיִם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.6",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 23:6",
      "text": "אַל ־ תִּלְחַ֗ם אֶת ־ לֶ֭חֶם רַ֣ע עָ֑יִן וְאַל ־ תתאו לְמַטְעַמֹּתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.7",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 23:7",
      "text": "כִּ֤י ׀ כְּמוֹ ־ שָׁעַ֥ר בְּנַפְשׁ֗וֹ כֶּ֫ן ־ ה֥וּא אֱכֹ֣ל וּ֭שְׁתֵה יֹ֣אמַר לָ֑ךְ וְ֝לִבּ֗וֹ בַּל ־ עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.8",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 23:8",
      "text": "פִּֽתְּךָ ־ אָכַ֥לְתָּ תְקִיאֶ֑נָּה וְ֝שִׁחַ֗תָּ דְּבָרֶ֥יךָ הַנְּעִימִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.9",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 23:9",
      "text": "בְּאָזְנֵ֣י כְ֭סִיל אַל ־ תְּדַבֵּ֑ר כִּֽי ־ יָ֝ב֗וּז לְשֵׂ֣כֶל מִלֶּֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.10",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 23:10",
      "text": "אַל ־ תַּ֭סֵּג גְּב֣וּל עוֹלָ֑ם וּבִשְׂדֵ֥י יְ֝תוֹמִ֗ים אַל ־ תָּבֹֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.11",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 23:11",
      "text": "כִּֽי ־ גֹאֲלָ֥ם חָזָ֑ק הֽוּא ־ יָרִ֖יב אֶת ־ רִיבָ֣ם אִתָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.12",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 23:12",
      "text": "הָבִ֣יאָה לַמּוּסָ֣ר לִבֶּ֑ךָ וְ֝אָזְנֶ֗ךָ לְאִמְרֵי ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.13",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 23:13",
      "text": "אַל ־ תִּמְנַ֣ע מִנַּ֣עַר מוּסָ֑ר כִּֽי ־ תַכֶּ֥נּוּ בַ֝שֵּׁ֗בֶט לֹ֣א יָמֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.14",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 23:14",
      "text": "אַ֭תָּה בַּשֵּׁ֣בֶט תַּכֶּ֑נּוּ וְ֝נַפְשׁ֗וֹ מִשְּׁא֥וֹל תַּצִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.15",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 23:15",
      "text": "בְּ֭נִי אִם ־ חָכַ֣ם לִבֶּ֑ךָ יִשְׂמַ֖ח לִבִּ֣י גַם ־ אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.16",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 23:16",
      "text": "וְתַעְלֹ֥זְנָה כִלְיוֹתָ֑י בְּדַבֵּ֥ר שְׂ֝פָתֶ֗יךָ מֵישָׁרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.17",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 23:17",
      "text": "אַל ־ יְקַנֵּ֣א לִ֭בְּךָ בַּֽחַטָּאִ֑ים כִּ֥י אִם ־ בְּיִרְאַת ־ יְ֝הוָ֗ה כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.18",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 23:18",
      "text": "כִּ֭י אִם ־ יֵ֣שׁ אַחֲרִ֑ית וְ֝תִקְוָתְךָ֗ לֹ֣א תִכָּרֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.19",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 23:19",
      "text": "שְׁמַע ־ אַתָּ֣ה בְנִ֣י וַחֲכָ֑ם וְאַשֵּׁ֖ר בַּדֶּ֣רֶךְ לִבֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.20",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 23:20",
      "text": "אַל ־ תְּהִ֥י בְסֹֽבְאֵי ־ יָ֑יִן בְּזֹלֲלֵ֖י בָשָׂ֣ר לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.21",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 23:21",
      "text": "כִּי ־ סֹבֵ֣א וְ֭זוֹלֵל יִוָּרֵ֑שׁ וּ֝קְרָעִ֗ים תַּלְבִּ֥ישׁ נוּמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.22",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 23:22",
      "text": "שְׁמַ֣ע לְ֭אָבִיךָ זֶ֣ה יְלָדֶ֑ךָ וְאַל ־ תָּ֝ב֗וּז כִּֽי ־ זָקְנָ֥ה אִמֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.23",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 23:23",
      "text": "אֱמֶ֣ת קְ֭נֵה וְאַל ־ תִּמְכֹּ֑ר חָכְמָ֖ה וּמוּסָ֣ר וּבִינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.24",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 23:24",
      "text": "גול יגול אֲבִ֣י צַדִּ֑יק יולד חָ֝כָ֗ם וישמח ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.25",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 23:25",
      "text": "יִֽשְׂמַח ־ אָבִ֥יךָ וְאִמֶּ֑ךָ וְ֝תָגֵ֗ל יֽוֹלַדְתֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.26",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 23:26",
      "text": "תְּנָֽה ־ בְנִ֣י לִבְּךָ֣ לִ֑י וְ֝עֵינֶ֗יךָ דְּרָכַ֥י תרצנה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.27",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 23:27",
      "text": "כִּֽי ־ שׁוּחָ֣ה עֲמֻקָּ֣ה זוֹנָ֑ה וּבְאֵ֥ר צָ֝רָ֗ה נָכְרִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.28",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 23:28",
      "text": "אַף ־ הִ֭יא כְּחֶ֣תֶף תֶּֽאֱרֹ֑ב וּ֝בוֹגְדִ֗ים בְּאָדָ֥ם תּוֹסִֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.29",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 23:29",
      "text": "לְמִ֨י א֥וֹי לְמִ֪י אֲב֡וֹי לְמִ֤י מדונים ׀ לְמִ֥י שִׂ֗יחַ לְ֭מִי פְּצָעִ֣ים חִנָּ֑ם לְ֝מִ֗י חַכְלִל֥וּת עֵינָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.30",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 23:30",
      "text": "לַֽמְאַחֲרִ֥ים עַל ־ הַיָּ֑יִן לַ֝בָּאִ֗ים לַחְקֹ֥ר מִמְסָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.31",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 23:31",
      "text": "אַל ־ תֵּ֥רֶא יַיִן֮ כִּ֪י יִתְאַ֫דָּ֥ם כִּֽי ־ יִתֵּ֣ן בכיס עֵינ֑וֹ יִ֝תְהַלֵּ֗ךְ בְּמֵישָׁרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.32",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 23:32",
      "text": "אַ֭חֲרִיתוֹ כְּנָחָ֣שׁ יִשָּׁ֑ךְ וּֽכְצִפְעֹנִ֥י יַפְרִֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.33",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 23:33",
      "text": "עֵ֭ינֶיךָ יִרְא֣וּ זָר֑וֹת וְ֝לִבְּךָ֗ יְדַבֵּ֥ר תַּהְפֻּכֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.34",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 23:34",
      "text": "וְ֭הָיִיתָ כְּשֹׁכֵ֣ב בְּלֶב ־ יָ֑ם וּ֝כְשֹׁכֵ֗ב בְּרֹ֣אשׁ חִבֵּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:proverbs.23.35",
      "translationId": "wlc",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 23:35",
      "text": "הִכּ֥וּנִי בַל ־ חָלִיתִי֮ הֲלָמ֗וּנִי בַּל ־ יָ֫דָ֥עְתִּי מָתַ֥י אָקִ֑יץ א֝וֹסִ֗יף אֲבַקְשֶׁ֥נּוּ עֽוֹד ׃",
      "paragraphStart": false
    }
  ]
}
