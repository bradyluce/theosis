{
  "chapter": {
    "id": "wlc:habakkuk.3",
    "translationId": "wlc",
    "bookSlug": "habakkuk",
    "chapterNumber": 3,
    "referenceLabel": "Habakkuk 3",
    "summary": "Source text for Habakkuk 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:habakkuk.3.1",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Habakkuk 3:1",
      "text": "תְּפִלָּ֖ה לַחֲבַקּ֣וּק הַנָּבִ֑יא עַ֖ל שִׁגְיֹנֽוֹת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:habakkuk.3.2",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Habakkuk 3:2",
      "text": "יְהוָ֗ה שָׁמַ֣עְתִּי שִׁמְעֲךָ֮ יָרֵאתִי֒ יְהוָ֗ה פָּֽעָלְךָ֙ בְּקֶ֤רֶב שָׁנִים֙ חַיֵּ֔יהוּ בְּקֶ֥רֶב שָׁנִ֖ים תּוֹדִ֑יעַ בְּרֹ֖גֶז רַחֵ֥ם תִּזְכּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.3",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Habakkuk 3:3",
      "text": "אֱל֨וֹהַ֙ מִתֵּימָ֣ן יָב֔וֹא וְקָד֥וֹשׁ מֵֽהַר ־ פָּארָ֖ן סֶ֑לָה כִּסָּ֤ה שָׁמַ֨יִם֙ הוֹד֔וֹ וּתְהִלָּת֖וֹ מָלְאָ֥ה הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.4",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Habakkuk 3:4",
      "text": "וְנֹ֨גַהּ֙ כָּא֣וֹר תִּֽהְיֶ֔ה קַרְנַ֥יִם מִיָּד֖וֹ ל֑וֹ וְשָׁ֖ם חֶבְי֥וֹן עֻזֹּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.5",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Habakkuk 3:5",
      "text": "לְפָנָ֖יו יֵ֣לֶךְ דָּ֑בֶר וְיֵצֵ֥א רֶ֖שֶׁף לְרַגְלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.6",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Habakkuk 3:6",
      "text": "עָמַ֣ד ׀ וַיְמֹ֣דֶד אֶ֗רֶץ רָאָה֙ וַיַּתֵּ֣ר גּוֹיִ֔ם וַיִּתְפֹּֽצְצוּ֙ הַרְרֵי ־ עַ֔ד שַׁח֖וּ גִּבְע֣וֹת עוֹלָ֑ם הֲלִיכ֥וֹת עוֹלָ֖ם לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.7",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Habakkuk 3:7",
      "text": "תַּ֣חַת אָ֔וֶן רָאִ֖יתִי אָהֳלֵ֣י כוּשָׁ֑ן יִרְגְּז֕וּן יְרִיע֖וֹת אֶ֥רֶץ מִדְיָֽן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.8",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Habakkuk 3:8",
      "text": "הֲבִנְהָרִים֙ חָרָ֣ה יְהוָ֔ה אִ֤ם בַּנְּהָרִים֙ אַפֶּ֔ךָ אִם ־ בַּיָּ֖ם עֶבְרָתֶ֑ךָ כִּ֤י תִרְכַּב֙ עַל ־ סוּסֶ֔יךָ מַרְכְּבֹתֶ֖יךָ יְשׁוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.9",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Habakkuk 3:9",
      "text": "עֶרְיָ֤ה תֵעוֹר֙ קַשְׁתֶּ֔ךָ שְׁבֻע֥וֹת מַטּ֖וֹת אֹ֣מֶר סֶ֑לָה נְהָר֖וֹת תְּבַקַּע ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.10",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Habakkuk 3:10",
      "text": "רָא֤וּךָ יָחִ֨ילוּ֙ הָרִ֔ים זֶ֥רֶם מַ֖יִם עָבָ֑ר נָתַ֤ן תְּהוֹם֙ קוֹל֔וֹ ר֖וֹם יָדֵ֥יהוּ נָשָֽׂא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.11",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Habakkuk 3:11",
      "text": "שֶׁ֥מֶשׁ יָרֵ֖חַ עָ֣מַד זְבֻ֑לָה לְא֤וֹר חִצֶּ֨יךָ֙ יְהַלֵּ֔כוּ לְנֹ֖גַהּ בְּרַ֥ק חֲנִיתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.12",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Habakkuk 3:12",
      "text": "בְּזַ֖עַם תִּצְעַד ־ אָ֑רֶץ בְּאַ֖ף תָּד֥וּשׁ גּוֹיִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.13",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Habakkuk 3:13",
      "text": "יָצָ֨אתָ֙ לְיֵ֣שַׁע עַמֶּ֔ךָ לְיֵ֖שַׁע אֶת ־ מְשִׁיחֶ֑ךָ מָחַ֤צְתָּ רֹּאשׁ֙ מִבֵּ֣ית רָשָׁ֔ע עָר֛וֹת יְס֥וֹד עַד ־ צַוָּ֖אר סֶֽלָה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.14",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Habakkuk 3:14",
      "text": "נָקַ֤בְתָּ בְמַטָּיו֙ רֹ֣אשׁ פרזו יִסְעֲר֖וּ לַהֲפִיצֵ֑נִי עֲלִ֣יצֻתָ֔ם כְּמוֹ ־ לֶאֱכֹ֥ל עָנִ֖י בַּמִּסְתָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.15",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Habakkuk 3:15",
      "text": "דָּרַ֥כְתָּ בַיָּ֖ם סוּסֶ֑יךָ חֹ֖מֶר מַ֥יִם רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.16",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Habakkuk 3:16",
      "text": "שָׁמַ֣עְתִּי ׀ וַתִּרְגַּ֣ז בִּטְנִ֗י לְקוֹל֙ צָלֲל֣וּ שְׂפָתַ֔י יָב֥וֹא רָקָ֛ב בַּעֲצָמַ֖י וְתַחְתַּ֣י אֶרְגָּ֑ז אֲשֶׁ֤ר אָנ֨וּחַ֙ לְי֣וֹם צָרָ֔ה לַעֲל֖וֹת לְעַ֥ם יְגוּדֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.17",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Habakkuk 3:17",
      "text": "כִּֽי ־ תְאֵנָ֣ה לֹֽא ־ תִפְרָ֗ח וְאֵ֤ין יְבוּל֙ בַּגְּפָנִ֔ים כִּחֵשׁ֙ מַעֲשֵׂה ־ זַ֔יִת וּשְׁדֵמ֖וֹת לֹא ־ עָ֣שָׂה אֹ֑כֶל גָּזַ֤ר מִמִּכְלָה֙ צֹ֔אן וְאֵ֥ין בָּקָ֖ר בָּרְפָתִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.18",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Habakkuk 3:18",
      "text": "וַאֲנִ֖י בַּיהוָ֣ה אֶעְל֑וֹזָה אָגִ֖ילָה בֵּאלֹהֵ֥י יִשְׁעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:habakkuk.3.19",
      "translationId": "wlc",
      "bookSlug": "habakkuk",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Habakkuk 3:19",
      "text": "יְהוִ֤הּ אֲדֹנָי֙ חֵילִ֔י וַיָּ֤שֶׂם רַגְלַי֙ כָּֽאַיָּל֔וֹת וְעַ֥ל בָּמוֹתַ֖י יַדְרִכֵ֑נִי לַמְנַצֵּ֖חַ בִּנְגִינוֹתָֽי ׃",
      "paragraphStart": false
    }
  ]
}
