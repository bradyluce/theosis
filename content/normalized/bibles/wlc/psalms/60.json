{
  "chapter": {
    "id": "wlc:psalms.60",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.60.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "לַ֭מְנַצֵּחַ עַל ־ שׁוּשַׁ֣ן עֵד֑וּת מִכְתָּ֖ם לְדָוִ֣ד לְלַמֵּֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.60.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "בְּהַצּוֹת֨וֹ ׀ אֶ֥ת אֲרַ֣ם נַהֲרַיִם֮ וְאֶת ־ אֲרַ֪ם צ֫וֹבָ֥ה וַיָּ֤שָׁב יוֹאָ֗ב וַיַּ֣ךְ אֶת ־ אֱד֣וֹם בְּגֵיא ־ מֶ֑לַח שְׁנֵ֖ים עָשָׂ֣ר אָֽלֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "אֱ֭לֹהִים זְנַחְתָּ֣נוּ פְרַצְתָּ֑נוּ אָ֝נַ֗פְתָּ תְּשׁ֣וֹבֵ֥ב לָֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "הִרְעַ֣שְׁתָּה אֶ֣רֶץ פְּצַמְתָּ֑הּ רְפָ֖ה שְׁבָרֶ֣יהָ כִי ־ מָֽטָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "הִרְאִ֣יתָה עַמְּךָ֣ קָשָׁ֑ה הִ֝שְׁקִיתָ֗נוּ יַ֣יִן תַּרְעֵלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "נָ֘תַ֤תָּה לִּירֵאֶ֣יךָ נֵּ֭ס לְהִתְנוֹסֵ֑ס מִ֝פְּנֵ֗י קֹ֣שֶׁט סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "לְ֭מַעַן יֵחָלְצ֣וּן יְדִידֶ֑יךָ הוֹשִׁ֖יעָה יְמִֽינְךָ֣ ועננו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "אֱלֹהִ֤ים ׀ דִּבֶּ֥ר בְּקָדְשׁ֗וֹ אֶ֫עְלֹ֥זָה אֲחַלְּקָ֥ה שְׁכֶ֑ם וְעֵ֖מֶק סֻכּ֣וֹת אֲמַדֵּֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "לִ֤י גִלְעָ֨ד ׀ וְלִ֬י מְנַשֶּׁ֗ה וְ֭אֶפְרַיִם מָע֣וֹז רֹאשִׁ֑י יְ֝הוּדָ֗ה מְחֹֽקְקִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 10,
      "referenceLabel": "Psalms 60:10",
      "text": "מוֹאָ֤ב ׀ סִ֬יר רַחְצִ֗י עַל ־ אֱ֭דוֹם אַשְׁלִ֣יךְ נַעֲלִ֑י עָ֝לַ֗י פְּלֶ֣שֶׁת הִתְרֹעָֽעִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 11,
      "referenceLabel": "Psalms 60:11",
      "text": "מִ֣י יֹ֭בִלֵנִי עִ֣יר מָצ֑וֹר מִ֖י נָחַ֣נִי עַד ־ אֱדֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 12,
      "referenceLabel": "Psalms 60:12",
      "text": "הֲלֹֽא ־ אַתָּ֣ה אֱלֹהִ֣ים זְנַחְתָּ֑נוּ וְֽלֹא ־ תֵצֵ֥א אֱ֝לֹהִ֗ים בְּצִבְאוֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 13,
      "referenceLabel": "Psalms 60:13",
      "text": "הָֽבָה ־ לָּ֣נוּ עֶזְרָ֣ת מִצָּ֑ר וְ֝שָׁ֗וְא תְּשׁוּעַ֥ת אָדָם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.60.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 14,
      "referenceLabel": "Psalms 60:14",
      "text": "בֵּֽאלֹהִ֥ים נַעֲשֶׂה ־ חָ֑יִל וְ֝ה֗וּא יָב֥וּס צָרֵֽינוּ ׃",
      "paragraphStart": false
    }
  ]
}
