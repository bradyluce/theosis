{
  "chapter": {
    "id": "wlc:psalms.105",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 105,
    "referenceLabel": "Psalms 105",
    "summary": "Source text for Psalms 105 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.105.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 1,
      "referenceLabel": "Psalms 105:1",
      "text": "הוֹד֣וּ לַ֭יהוָה קִרְא֣וּ בִּשְׁמ֑וֹ הוֹדִ֥יעוּ בָ֝עַמִּ֗ים עֲלִילוֹתָֽיו ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.105.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 2,
      "referenceLabel": "Psalms 105:2",
      "text": "שִֽׁירוּ ־ ל֭וֹ זַמְּרוּ ־ ל֑וֹ שִׂ֝֗יחוּ בְּכָל ־ נִפְלְאוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 3,
      "referenceLabel": "Psalms 105:3",
      "text": "הִֽ֭תְהַלְלוּ בְּשֵׁ֣ם קָדְשׁ֑וֹ יִ֝שְׂמַ֗ח לֵ֤ב ׀ מְבַקְשֵׁ֬י יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 4,
      "referenceLabel": "Psalms 105:4",
      "text": "דִּרְשׁ֣וּ יְהוָ֣ה וְעֻזּ֑וֹ בַּקְּשׁ֖וּ פָנָ֣יו תָּמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 5,
      "referenceLabel": "Psalms 105:5",
      "text": "זִכְר֗וּ נִפְלְאוֹתָ֥יו אֲשֶׁר ־ עָשָׂ֑ה מֹ֝פְתָ֗יו וּמִשְׁפְּטֵי ־ פִֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 6,
      "referenceLabel": "Psalms 105:6",
      "text": "זֶ֭רַע אַבְרָהָ֣ם עַבְדּ֑וֹ בְּנֵ֖י יַעֲקֹ֣ב בְּחִירָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 7,
      "referenceLabel": "Psalms 105:7",
      "text": "ה֭וּא יְהוָ֣ה אֱלֹהֵ֑ינוּ בְּכָל ־ הָ֝אָ֗רֶץ מִשְׁפָּטָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 8,
      "referenceLabel": "Psalms 105:8",
      "text": "זָכַ֣ר לְעוֹלָ֣ם בְּרִית֑וֹ דָּבָ֥ר צִ֝וָּ֗ה לְאֶ֣לֶף דּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 9,
      "referenceLabel": "Psalms 105:9",
      "text": "אֲשֶׁ֣ר כָּ֭רַת אֶת ־ אַבְרָהָ֑ם וּשְׁב֖וּעָת֣וֹ לְיִשְׂחָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 10,
      "referenceLabel": "Psalms 105:10",
      "text": "וַיַּֽעֲמִידֶ֣הָ לְיַעֲקֹ֣ב לְחֹ֑ק לְ֝יִשְׂרָאֵ֗ל בְּרִ֣ית עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 11,
      "referenceLabel": "Psalms 105:11",
      "text": "לֵאמֹ֗ר לְךָ֗ אֶתֵּ֥ן אֶת ־ אֶֽרֶץ ־ כְּנָ֑עַן חֶ֝֗בֶל נַחֲלַתְכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 12,
      "referenceLabel": "Psalms 105:12",
      "text": "בִּֽ֭הְיוֹתָם מְתֵ֣י מִסְפָּ֑ר כִּ֝מְעַ֗ט וְגָרִ֥ים בָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 13,
      "referenceLabel": "Psalms 105:13",
      "text": "וַֽ֭יִּתְהַלְּכוּ מִגּ֣וֹי אֶל ־ גּ֑וֹי מִ֝מַּמְלָכָ֗ה אֶל ־ עַ֥ם אַחֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 14,
      "referenceLabel": "Psalms 105:14",
      "text": "לֹֽא ־ הִנִּ֣יחַ אָדָ֣ם לְעָשְׁקָ֑ם וַיּ֖וֹכַח עֲלֵיהֶ֣ם מְלָכִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 15,
      "referenceLabel": "Psalms 105:15",
      "text": "אַֽל ־ תִּגְּע֥וּ בִמְשִׁיחָ֑י וְ֝לִנְבִיאַי אַל ־ תָּרֵֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 16,
      "referenceLabel": "Psalms 105:16",
      "text": "וַיִּקְרָ֣א רָ֭עָב עַל ־ הָאָ֑רֶץ כָּֽל ־ מַטֵּה ־ לֶ֥חֶם שָׁבָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 17,
      "referenceLabel": "Psalms 105:17",
      "text": "שָׁלַ֣ח לִפְנֵיהֶ֣ם אִ֑ישׁ לְ֝עֶ֗בֶד נִמְכַּ֥ר יוֹסֵֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 18,
      "referenceLabel": "Psalms 105:18",
      "text": "עִנּ֣וּ בַכֶּ֣בֶל רגליו בַּ֝רְזֶ֗ל בָּ֣אָה נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 19,
      "referenceLabel": "Psalms 105:19",
      "text": "עַד ־ עֵ֥ת בֹּֽא ־ דְבָר֑וֹ אִמְרַ֖ת יְהוָ֣ה צְרָפָֽתְהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 20,
      "referenceLabel": "Psalms 105:20",
      "text": "שָׁ֣לַח מֶ֭לֶךְ וַיַּתִּירֵ֑הוּ מֹשֵׁ֥ל עַ֝מִּ֗ים וַֽיְפַתְּחֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 21,
      "referenceLabel": "Psalms 105:21",
      "text": "שָׂמ֣וֹ אָד֣וֹן לְבֵית֑וֹ וּ֝מֹשֵׁ֗ל בְּכָל ־ קִנְיָנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 22,
      "referenceLabel": "Psalms 105:22",
      "text": "לֶאְסֹ֣ר שָׂרָ֣יו בְּנַפְשׁ֑וֹ וּזְקֵנָ֥יו יְחַכֵּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 23,
      "referenceLabel": "Psalms 105:23",
      "text": "וַיָּבֹ֣א יִשְׂרָאֵ֣ל מִצְרָ֑יִם וְ֝יַעֲקֹ֗ב גָּ֣ר בְּאֶֽרֶץ ־ חָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 24,
      "referenceLabel": "Psalms 105:24",
      "text": "וַיֶּ֣פֶר אֶת ־ עַמּ֣וֹ מְאֹ֑ד וַ֝יַּֽעֲצִמֵהוּ מִצָּרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 25,
      "referenceLabel": "Psalms 105:25",
      "text": "הָפַ֣ךְ לִ֭בָּם לִשְׂנֹ֣א עַמּ֑וֹ לְ֝הִתְנַכֵּ֗ל בַּעֲבָדָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 26,
      "referenceLabel": "Psalms 105:26",
      "text": "שָׁ֭לַח מֹשֶׁ֣ה עַבְדּ֑וֹ אַ֝הֲרֹ֗ן אֲשֶׁ֣ר בָּֽחַר ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 27,
      "referenceLabel": "Psalms 105:27",
      "text": "שָֽׂמוּ ־ בָ֭ם דִּבְרֵ֣י אֹתוֹתָ֑יו וּ֝מֹפְתִ֗ים בְּאֶ֣רֶץ חָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 28,
      "referenceLabel": "Psalms 105:28",
      "text": "שָׁ֣לַֽח חֹ֭שֶׁךְ וַיַּחְשִׁ֑ךְ וְלֹֽא ־ מָ֝ר֗וּ אֶת ־ דברוו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 29,
      "referenceLabel": "Psalms 105:29",
      "text": "הָפַ֣ךְ אֶת ־ מֵימֵיהֶ֣ם לְדָ֑ם וַ֝יָּ֗מֶת אֶת ־ דְּגָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 30,
      "referenceLabel": "Psalms 105:30",
      "text": "שָׁרַ֣ץ אַרְצָ֣ם צְפַרְדְּעִ֑ים בְּ֝חַדְרֵ֗י מַלְכֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 31,
      "referenceLabel": "Psalms 105:31",
      "text": "אָ֭מַר וַיָּבֹ֣א עָרֹ֑ב כִּ֝נִּ֗ים בְּכָל ־ גְּבוּלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 32,
      "referenceLabel": "Psalms 105:32",
      "text": "נָתַ֣ן גִּשְׁמֵיהֶ֣ם בָּרָ֑ד אֵ֖שׁ לֶהָב֣וֹת בְּאַרְצָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 33,
      "referenceLabel": "Psalms 105:33",
      "text": "וַיַּ֣ךְ גַּ֭פְנָם וּתְאֵנָתָ֑ם וַ֝יְשַׁבֵּ֗ר עֵ֣ץ גְּבוּלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 34,
      "referenceLabel": "Psalms 105:34",
      "text": "אָ֭מַר וַיָּבֹ֣א אַרְבֶּ֑ה וְ֝יֶ֗לֶק וְאֵ֣ין מִסְפָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 35,
      "referenceLabel": "Psalms 105:35",
      "text": "וַיֹּ֣אכַל כָּל ־ עֵ֣שֶׂב בְּאַרְצָ֑ם וַ֝יֹּ֗אכַל פְּרִ֣י אַדְמָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 36,
      "referenceLabel": "Psalms 105:36",
      "text": "וַיַּ֣ךְ כָּל ־ בְּכ֣וֹר בְּאַרְצָ֑ם רֵ֝אשִׁ֗ית לְכָל ־ אוֹנָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 37,
      "referenceLabel": "Psalms 105:37",
      "text": "וַֽ֭יּוֹצִיאֵם בְּכֶ֣סֶף וְזָהָ֑ב וְאֵ֖ין בִּשְׁבָטָ֣יו כּוֹשֵֽׁל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.38",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 38,
      "referenceLabel": "Psalms 105:38",
      "text": "שָׂמַ֣ח מִצְרַ֣יִם בְּצֵאתָ֑ם כִּֽי ־ נָפַ֖ל פַּחְדָּ֣ם עֲלֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.39",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 39,
      "referenceLabel": "Psalms 105:39",
      "text": "פָּרַ֣שׂ עָנָ֣ן לְמָסָ֑ךְ וְ֝אֵ֗שׁ לְהָאִ֥יר לָֽיְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.40",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 40,
      "referenceLabel": "Psalms 105:40",
      "text": "שָׁאַ֣ל וַיָּבֵ֣א שְׂלָ֑ו וְלֶ֥חֶם שָׁ֝מַ֗יִם יַשְׂבִּיעֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.41",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 41,
      "referenceLabel": "Psalms 105:41",
      "text": "פָּ֣תַח צ֭וּר וַיָּז֣וּבוּ מָ֑יִם הָ֝לְכ֗וּ בַּצִּיּ֥וֹת נָהָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.42",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 42,
      "referenceLabel": "Psalms 105:42",
      "text": "כִּֽי ־ זָ֭כַר אֶת ־ דְּבַ֣ר קָדְשׁ֑וֹ אֶֽת ־ אַבְרָהָ֥ם עַבְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.105.43",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 43,
      "referenceLabel": "Psalms 105:43",
