{
  "chapter": {
    "id": "wlc:psalms.26",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.26.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "לְדָוִ֨ד ׀ שָׁפְטֵ֤נִי יְהוָ֗ה כִּֽי ־ אֲ֭נִי בְּתֻמִּ֣י הָלַ֑כְתִּי וּבַיהוָ֥ה בָּ֝טַ֗חְתִּי לֹ֣א אֶמְעָֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.26.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "בְּחָנֵ֣נִי יְהוָ֣ה וְנַסֵּ֑נִי צרופה כִלְיוֹתַ֣י וְלִבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "כִּֽי ־ חַ֭סְדְּךָ לְנֶ֣גֶד עֵינָ֑י וְ֝הִתְהַלַּ֗כְתִּי בַּאֲמִתֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "לֹא ־ יָ֭שַׁבְתִּי עִם ־ מְתֵי ־ שָׁ֑וְא וְעִ֥ם נַ֝עֲלָמִ֗ים לֹ֣א אָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "שָׂ֭נֵאתִי קְהַ֣ל מְרֵעִ֑ים וְעִם ־ רְ֝שָׁעִ֗ים לֹ֣א אֵשֵֽׁב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "אֶרְחַ֣ץ בְּנִקָּי֣וֹן כַּפָּ֑י וַאֲסֹבְבָ֖ה אֶת ־ מִזְבַּחֲךָ֣ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "לַ֭שְׁמִעַ בְּק֣וֹל תּוֹדָ֑ה וּ֝לְסַפֵּ֗ר כָּל ־ נִפְלְאוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "יְֽהוָ֗ה אָ֭הַבְתִּי מְע֣וֹן בֵּיתֶ֑ךָ וּ֝מְק֗וֹם מִשְׁכַּ֥ן כְּבוֹדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "אַל ־ תֶּאֱסֹ֣ף עִם ־ חַטָּאִ֣ים נַפְשִׁ֑י וְעִם ־ אַנְשֵׁ֖י דָמִ֣ים חַיָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "אֲשֶׁר ־ בִּידֵיהֶ֥ם זִמָּ֑ה וִֽ֝ימִינָ֗ם מָ֣לְאָה שֹּֽׁחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "וַ֭אֲנִי בְּתֻמִּ֥י אֵלֵ֗ךְ פְּדֵ֣נִי וְחָנֵּֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.26.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "רַ֭גְלִי עָֽמְדָ֣ה בְמִישׁ֑וֹר בְּ֝מַקְהֵלִ֗ים אֲבָרֵ֥ךְ יְהוָֽה ׃",
      "paragraphStart": false
    }
  ]
}
