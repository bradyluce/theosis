{
  "chapter": {
    "id": "wlc:psalms.11",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 11,
    "referenceLabel": "Psalms 11",
    "summary": "Source text for Psalms 11 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.11.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "לַמְנַצֵּ֗חַ לְדָ֫וִ֥ד בַּֽיהוָ֨ה ׀ חָסִ֗יתִי אֵ֭יךְ תֹּאמְר֣וּ לְנַפְשִׁ֑י נודו הַרְכֶ֥ם צִפּֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.11.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "כִּ֤י הִנֵּ֪ה הָרְשָׁעִ֡ים יִדְרְכ֬וּן קֶ֗שֶׁת כּוֹנְנ֣וּ חִצָּ֣ם עַל ־ יֶ֑תֶר לִיר֥וֹת בְּמוֹ ־ אֹ֝֗פֶל לְיִשְׁרֵי ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.11.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "כִּ֣י הַ֭שָּׁתוֹת יֵֽהָרֵס֑וּן צַ֝דִּ֗יק מַה ־ פָּעָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.11.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "יְהוָ֤ה ׀ בְּֽהֵ֘יכַ֤ל קָדְשׁ֗וֹ יְהוָה֮ בַּשָּׁמַ֪יִם כִּ֫סְא֥וֹ עֵינָ֥יו יֶחֱז֑וּ עַפְעַפָּ֥יו יִ֝בְחֲנ֗וּ בְּנֵ֣י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.11.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "יְהוָה֮ צַדִּ֪יק יִ֫בְחָ֥ן וְ֭רָשָׁע וְאֹהֵ֣ב חָמָ֑ס שָֽׂנְאָ֥ה נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.11.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "יַמְטֵ֥ר עַל ־ רְשָׁעִ֗ים פַּ֫חִ֥ים אֵ֣שׁ וְ֭גָפְרִית וְר֥וּחַ זִלְעָפ֗וֹת מְנָ֣ת כּוֹסָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.11.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "כִּֽי ־ צַדִּ֣יק יְ֭הוָה צְדָק֣וֹת אָהֵ֑ב יָ֝שָׁ֗ר יֶחֱז֥וּ פָנֵֽימוֹ ׃",
      "paragraphStart": false
    }
  ]
}
