{
  "chapter": {
    "id": "wlc:psalms.144",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 144,
    "referenceLabel": "Psalms 144",
    "summary": "Source text for Psalms 144 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.144.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 1,
      "referenceLabel": "Psalms 144:1",
      "text": "לְדָוִ֨ד ׀ בָּ֘ר֤וּךְ יְהוָ֨ה ׀ צוּרִ֗י הַֽמְלַמֵּ֣ד יָדַ֣י לַקְרָ֑ב אֶ֝צְבְּעוֹתַ֗י לַמִּלְחָמָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.144.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 2,
      "referenceLabel": "Psalms 144:2",
      "text": "חַסְדִּ֥י וּמְצוּדָתִי֮ מִשְׂגַּבִּ֪י וּֽמְפַלְטִ֫י לִ֥י מָ֭גִנִּי וּב֣וֹ חָסִ֑יתִי הָרוֹדֵ֖ד עַמִּ֣י תַחְתָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 3,
      "referenceLabel": "Psalms 144:3",
      "text": "יְֽהוָ֗ה מָה ־ אָ֭דָם וַתֵּדָעֵ֑הוּ בֶּן ־ אֱ֝נ֗וֹשׁ וַֽתְּחַשְּׁבֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 4,
      "referenceLabel": "Psalms 144:4",
      "text": "אָ֭דָם לַהֶ֣בֶל דָּמָ֑ה יָ֝מָ֗יו כְּצֵ֣ל עוֹבֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 5,
      "referenceLabel": "Psalms 144:5",
      "text": "יְ֭הוָה הַט ־ שָׁמֶ֣יךָ וְתֵרֵ֑ד גַּ֖ע בֶּהָרִ֣ים וְֽיֶעֱשָֽׁנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 6,
      "referenceLabel": "Psalms 144:6",
      "text": "בְּר֣וֹק בָּ֭רָק וּתְפִיצֵ֑ם שְׁלַ֥ח חִ֝צֶּ֗יךָ וּתְהֻמֵּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 7,
      "referenceLabel": "Psalms 144:7",
      "text": "שְׁלַ֥ח יָדֶ֗יךָ מִמָּ֫ר֥וֹם פְּצֵ֣נִי וְ֭הַצִּילֵנִי מִמַּ֣יִם רַבִּ֑ים מִ֝יַּ֗ד בְּנֵ֣י נֵכָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 8,
      "referenceLabel": "Psalms 144:8",
      "text": "אֲשֶׁ֣ר פִּ֭יהֶם דִּבֶּר ־ שָׁ֑וְא וִֽ֝ימִינָ֗ם יְמִ֣ין שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 9,
      "referenceLabel": "Psalms 144:9",
      "text": "אֱֽלֹהִ֗ים שִׁ֣יר חָ֭דָשׁ אָשִׁ֣ירָה לָּ֑ךְ בְּנֵ֥בֶל עָ֝שׂ֗וֹר אֲזַמְּרָה ־ לָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 10,
      "referenceLabel": "Psalms 144:10",
      "text": "הַנּוֹתֵ֥ן תְּשׁוּעָ֗ה לַמְּלָ֫כִ֥ים הַ֭פּוֹצֶה אֶת ־ דָּוִ֥ד עַבְדּ֗וֹ מֵחֶ֥רֶב רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 11,
      "referenceLabel": "Psalms 144:11",
      "text": "פְּצֵ֥נִי וְהַצִּילֵנִי֮ מִיַּ֪ד בְּֽנֵי ־ נֵ֫כָ֥ר אֲשֶׁ֣ר פִּ֭יהֶם דִּבֶּר ־ שָׁ֑וְא וִֽ֝ימִינָ֗ם יְמִ֣ין שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 12,
      "referenceLabel": "Psalms 144:12",
      "text": "אֲשֶׁ֤ר בָּנֵ֨ינוּ ׀ כִּנְטִעִים֮ מְגֻדָּלִ֪ים בִּֽנְעוּרֵ֫יהֶ֥ם בְּנוֹתֵ֥ינוּ כְזָוִיֹּ֑ת מְ֝חֻטָּב֗וֹת תַּבְנִ֥ית הֵיכָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 13,
      "referenceLabel": "Psalms 144:13",
      "text": "מְזָוֵ֣ינוּ מְלֵאִים֮ מְפִיקִ֥ים מִזַּ֗ן אֶ֫ל ־ זַ֥ן צֹאונֵ֣נוּ מַ֭אֲלִיפוֹת מְרֻבָּב֗וֹת בְּחוּצוֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 14,
      "referenceLabel": "Psalms 144:14",
      "text": "אַלּוּפֵ֗ינוּ מְֽסֻבָּ֫לִ֥ים אֵֽין ־ פֶּ֭רֶץ וְאֵ֣ין יוֹצֵ֑את וְאֵ֥ין צְ֝וָחָ֗ה בִּרְחֹבֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.144.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 15,
      "referenceLabel": "Psalms 144:15",
      "text": "אַשְׁרֵ֣י הָ֭עָם שֶׁכָּ֣כָה לּ֑וֹ אַֽשְׁרֵ֥י הָ֝עָ֗ם שֶׁיֲהוָ֥ה אֱלֹהָֽיו ׃",
      "paragraphStart": false
    }
  ]
}
