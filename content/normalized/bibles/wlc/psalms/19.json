{
  "chapter": {
    "id": "wlc:psalms.19",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 19,
    "referenceLabel": "Psalms 19",
    "summary": "Source text for Psalms 19 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.19.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Psalms 19:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.19.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Psalms 19:2",
      "text": "הַשָּׁמַ֗יִם מְֽסַפְּרִ֥ים כְּבֽוֹד ־ אֵ֑ל וּֽמַעֲשֵׂ֥ה יָ֝דָ֗יו מַגִּ֥יד הָרָקִֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Psalms 19:3",
      "text": "י֣וֹם לְ֭יוֹם יַבִּ֣יעַֽ אֹ֑מֶר וְלַ֥יְלָה לְּ֝לַ֗יְלָה יְחַוֶּה ־ דָּֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Psalms 19:4",
      "text": "אֵֽין ־ אֹ֭מֶר וְאֵ֣ין דְּבָרִ֑ים בְּ֝לִ֗י נִשְׁמָ֥ע קוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Psalms 19:5",
      "text": "בְּכָל ־ הָאָ֨רֶץ ׀ יָ֘צָ֤א קַוָּ֗ם וּבִקְצֵ֣ה תֵ֭בֵל מִלֵּיהֶ֑ם לַ֝שֶּׁ֗מֶשׁ שָֽׂם ־ אֹ֥הֶל בָּהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Psalms 19:6",
      "text": "וְה֗וּא כְּ֭חָתָן יֹצֵ֣א מֵחֻפָּת֑וֹ יָשִׂ֥ישׂ כְּ֝גִבּ֗וֹר לָר֥וּץ אֹֽרַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Psalms 19:7",
      "text": "מִקְצֵ֤ה הַשָּׁמַ֨יִם ׀ מֽוֹצָא֗וֹ וּתְקוּפָת֥וֹ עַל ־ קְצוֹתָ֑ם וְאֵ֥ין נִ֝סְתָּ֗ר מֵֽחַמָּתוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Psalms 19:8",
      "text": "תּ֘וֹרַ֤ת יְהוָ֣ה תְּ֭מִימָה מְשִׁ֣יבַת נָ֑פֶשׁ עֵד֥וּת יְהוָ֥ה נֶ֝אֱמָנָ֗ה מַחְכִּ֥ימַת פֶּֽתִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Psalms 19:9",
      "text": "פִּקּ֘וּדֵ֤י יְהוָ֣ה יְ֭שָׁרִים מְשַׂמְּחֵי ־ לֵ֑ב מִצְוַ֥ת יְהוָ֥ה בָּ֝רָ֗ה מְאִירַ֥ת עֵינָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Psalms 19:10",
      "text": "יִרְאַ֤ת יְהוָ֨ה ׀ טְהוֹרָה֮ עוֹמֶ֪דֶת לָ֫עַ֥ד מִֽשְׁפְּטֵי ־ יְהוָ֥ה אֱמֶ֑ת צָֽדְק֥וּ יַחְדָּֽו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Psalms 19:11",
      "text": "הַֽנֶּחֱמָדִ֗ים מִ֭זָּהָב וּמִפַּ֣ז רָ֑ב וּמְתוּקִ֥ים מִ֝דְּבַ֗שׁ וְנֹ֣פֶת צוּפִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Psalms 19:12",
      "text": "גַּֽם ־ עַ֭בְדְּךָ נִזְהָ֣ר בָּהֶ֑ם בְּ֝שָׁמְרָ֗ם עֵ֣קֶב רָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Psalms 19:13",
      "text": "שְׁגִיא֥וֹת מִֽי ־ יָבִ֑ין מִֽנִּסְתָּר֥וֹת נַקֵּֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Psalms 19:14",
      "text": "גַּ֤ם מִזֵּדִ֨ים ׀ חֲשֹׂ֬ךְ עַבְדֶּ֗ךָ אַֽל ־ יִמְשְׁלוּ ־ בִ֣י אָ֣ז אֵיתָ֑ם וְ֝נִקֵּ֗יתִי מִפֶּ֥שַֽׁע רָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.19.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Psalms 19:15",
      "text": "יִֽהְי֥וּ לְרָצ֨וֹן ׀ אִמְרֵי ־ פִ֡י וְהֶגְי֣וֹן לִבִּ֣י לְפָנֶ֑יךָ יְ֝הוָ֗ה צוּרִ֥י וְגֹאֲלִֽי ׃",
      "paragraphStart": false
    }
  ]
}
