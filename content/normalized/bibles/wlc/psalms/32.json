{
  "chapter": {
    "id": "wlc:psalms.32",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 32,
    "referenceLabel": "Psalms 32",
    "summary": "Source text for Psalms 32 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.32.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Psalms 32:1",
      "text": "לְדָוִ֗ד מַ֫שְׂכִּ֥יל אַשְׁרֵ֥י נְֽשׂוּי ־ פֶּ֗שַׁע כְּס֣וּי חֲטָאָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.32.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Psalms 32:2",
      "text": "אַ֥שְֽׁרֵי אָדָ֗ם לֹ֤א יַחְשֹׁ֬ב יְהוָ֣ה ל֣וֹ עָוֺ֑ן וְאֵ֖ין בְּרוּח֣וֹ רְמִיָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Psalms 32:3",
      "text": "כִּֽי ־ הֶ֭חֱרַשְׁתִּי בָּל֣וּ עֲצָמָ֑י בְּ֝שַׁאֲגָתִ֗י כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Psalms 32:4",
      "text": "כִּ֤י ׀ יוֹמָ֣ם וָלַיְלָה֮ תִּכְבַּ֥ד עָלַ֗י יָ֫דֶ֥ךָ נֶהְפַּ֥ךְ לְשַׁדִּ֑י בְּחַרְבֹ֖נֵי קַ֣יִץ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Psalms 32:5",
      "text": "חַטָּאתִ֨י אוֹדִ֪יעֲךָ֡ וַעֲוֺ֘נִ֤י לֹֽא ־ כִסִּ֗יתִי אָמַ֗רְתִּי אוֹדֶ֤ה עֲלֵ֣י פְ֭שָׁעַי לַיהוָ֑ה וְאַתָּ֨ה נָ֘שָׂ֤אתָ עֲוֺ֖ן חַטָּאתִ֣י סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Psalms 32:6",
      "text": "עַל ־ זֹ֡את יִתְפַּלֵּ֬ל כָּל ־ חָסִ֨יד ׀ אֵלֶיךָ֮ לְעֵ֪ת מְ֫צֹ֥א רַ֗ק לְ֭שֵׁטֶף מַ֣יִם רַבִּ֑ים אֵ֝לָ֗יו לֹ֣א יַגִּֽיעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Psalms 32:7",
      "text": "אַתָּ֤ה ׀ סֵ֥תֶר לִי֮ מִצַּ֪ר תִּ֫צְּרֵ֥נִי רָנֵּ֥י פַלֵּ֑ט תְּס֖וֹבְבֵ֣נִי סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Psalms 32:8",
      "text": "אַשְׂכִּֽילְךָ֨ ׀ וְֽאוֹרְךָ֗ בְּדֶֽרֶךְ ־ ז֥וּ תֵלֵ֑ךְ אִֽיעֲצָ֖ה עָלֶ֣יךָ עֵינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Psalms 32:9",
      "text": "אַל ־ תִּֽהְי֤וּ ׀ כְּס֥וּס כְּפֶרֶד֮ אֵ֤ין הָ֫בִ֥ין בְּמֶֽתֶג ־ וָרֶ֣סֶן עֶדְי֣וֹ לִבְל֑וֹם בַּ֝֗ל קְרֹ֣ב אֵלֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Psalms 32:10",
      "text": "רַבִּ֥ים מַכְאוֹבִ֗ים לָרָ֫שָׁ֥ע וְהַבּוֹטֵ֥חַ בַּיהוָ֑ה חֶ֝֗סֶד יְסוֹבְבֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.32.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Psalms 32:11",
      "text": "שִׂמְח֬וּ בַֽיהוָ֣ה וְ֭גִילוּ צַדִּיקִ֑ים וְ֝הַרְנִ֗ינוּ כָּל ־ יִשְׁרֵי ־ לֵֽב ׃",
      "paragraphStart": false
    }
  ]
}
