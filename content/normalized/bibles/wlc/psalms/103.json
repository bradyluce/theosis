{
  "chapter": {
    "id": "wlc:psalms.103",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.103.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "לְדָוִ֨ד ׀ בָּרֲכִ֣י נַ֭פְשִׁי אֶת ־ יְהוָ֑ה וְכָל ־ קְ֝רָבַ֗י אֶת ־ שֵׁ֥ם קָדְשֽׁוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.103.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "בָּרֲכִ֣י נַ֭פְשִׁי אֶת ־ יְהוָ֑ה וְאַל ־ תִּ֝שְׁכְּחִ֗י כָּל ־ גְּמוּלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "הַסֹּלֵ֥חַ לְכָל ־ עֲוֺנֵ֑כִי הָ֝רֹפֵ֗א לְכָל ־ תַּחֲלֻאָֽיְכִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "הַגּוֹאֵ֣ל מִשַּׁ֣חַת חַיָּ֑יְכִי הַֽ֝מְעַטְּרֵ֗כִי חֶ֣סֶד וְרַחֲמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "הַמַּשְׂבִּ֣יַע בַּטּ֣וֹב עֶדְיֵ֑ךְ תִּתְחַדֵּ֖שׁ כַּנֶּ֣שֶׁר נְעוּרָֽיְכִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "עֹשֵׂ֣ה צְדָק֣וֹת יְהוָ֑ה וּ֝מִשְׁפָּטִ֗ים לְכָל ־ עֲשׁוּקִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "יוֹדִ֣יעַ דְּרָכָ֣יו לְמֹשֶׁ֑ה לִבְנֵ֥י יִ֝שְׂרָאֵ֗ל עֲלִילֽוֹתָיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "רַח֣וּם וְחַנּ֣וּן יְהוָ֑ה אֶ֖רֶךְ אַפַּ֣יִם וְרַב ־ חָֽסֶד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "לֹֽא ־ לָנֶ֥צַח יָרִ֑יב וְלֹ֖א לְעוֹלָ֣ם יִטּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "לֹ֣א כַ֭חֲטָאֵינוּ עָ֣שָׂה לָ֑נוּ וְלֹ֥א כַ֝עֲוֺנֹתֵ֗ינוּ גָּמַ֥ל עָלֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "כִּ֤י כִגְבֹ֣הַּ שָׁ֭מַיִם עַל ־ הָאָ֑רֶץ גָּבַ֥ר חַ֝סְדּ֗וֹ עַל ־ יְרֵאָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "כִּרְחֹ֣ק מִ֭זְרָח מִֽמַּֽעֲרָ֑ב הִֽרְחִ֥יק מִ֝מֶּ֗נּוּ אֶת ־ פְּשָׁעֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "כְּרַחֵ֣ם אָ֭ב עַל ־ בָּנִ֑ים רִחַ֥ם יְ֝הוָ֗ה עַל ־ יְרֵאָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "כִּי ־ ה֖וּא יָדַ֣ע יִצְרֵ֑נוּ זָ֝כ֗וּר כִּי ־ עָפָ֥ר אֲנָֽחְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "אֱ֭נוֹשׁ כֶּחָצִ֣יר יָמָ֑יו כְּצִ֥יץ הַ֝שָּׂדֶ֗ה כֵּ֣ן יָצִֽיץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "כִּ֤י ר֣וּחַ עָֽבְרָה ־ בּ֣וֹ וְאֵינֶ֑נּוּ וְלֹא ־ יַכִּירֶ֖נּוּ ע֣וֹד מְקוֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "וְחֶ֤סֶד יְהוָ֨ה ׀ מֵעוֹלָ֣ם וְעַד ־ ע֭וֹלָם עַל ־ יְרֵאָ֑יו וְ֝צִדְקָת֗וֹ לִבְנֵ֥י בָנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "לְשֹׁמְרֵ֥י בְרִית֑וֹ וּלְזֹכְרֵ֥י פִ֝קֻּדָ֗יו לַעֲשׂוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "יְֽהוָ֗ה בַּ֭שָּׁמַיִם הֵכִ֣ין כִּסְא֑וֹ וּ֝מַלְכוּת֗וֹ בַּכֹּ֥ל מָשָֽׁלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "בָּרֲכ֥וּ יְהוָ֗ה מַלְאָ֫כָ֥יו גִּבֹּ֣רֵי כֹ֭חַ עֹשֵׂ֣י דְבָר֑וֹ לִ֝שְׁמֹ֗עַ בְּק֣וֹל דְּבָרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "בָּרֲכ֣וּ יְ֭הוָה כָּל ־ צְבָאָ֑יו מְ֝שָׁרְתָ֗יו עֹשֵׂ֥י רְצוֹנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.103.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "בָּרֲכ֤וּ יְהוָ֨ה ׀ כָּֽל ־ מַעֲשָׂ֗יו בְּכָל ־ מְקֹמ֥וֹת מֶמְשַׁלְתּ֑וֹ בָּרֲכִ֥י נַ֝פְשִׁ֗י אֶת ־ יְהוָֽה ׃",
      "paragraphStart": false
    }
  ]
}
