{
  "chapter": {
    "id": "wlc:psalms.96",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.96.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "שִׁ֣ירוּ לַ֭יהוָה שִׁ֣יר חָדָ֑שׁ שִׁ֥ירוּ לַ֝יהוָ֗ה כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.96.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "שִׁ֣ירוּ לַ֭יהוָה בָּרֲכ֣וּ שְׁמ֑וֹ בַּשְּׂר֥וּ מִיּֽוֹם ־ לְ֝י֗וֹם יְשׁוּעָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "סַפְּר֣וּ בַגּוֹיִ֣ם כְּבוֹד֑וֹ בְּכָל ־ הָֽ֝עַמִּ֗ים נִפְלְאוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "כִּ֥י גָ֘ד֤וֹל יְהוָ֣ה וּמְהֻלָּ֣ל מְאֹ֑ד נוֹרָ֥א ה֝֗וּא עַל ־ כָּל ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "כִּ֤י ׀ כָּל ־ אֱלֹהֵ֣י הָעַמִּ֣ים אֱלִילִ֑ים וַֽ֝יהוָ֗ה שָׁמַ֥יִם עָשָֽׂה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "הוֹד ־ וְהָדָ֥ר לְפָנָ֑יו עֹ֥ז וְ֝תִפְאֶ֗רֶת בְּמִקְדָּשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "הָב֣וּ לַ֭יהוָה מִשְׁפְּח֣וֹת עַמִּ֑ים הָב֥וּ לַ֝יהוָ֗ה כָּב֥וֹד וָעֹֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "הָב֣וּ לַ֭יהוָה כְּב֣וֹד שְׁמ֑וֹ שְׂאֽוּ ־ מִ֝נְחָ֗ה וּבֹ֥אוּ לְחַצְרוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "הִשְׁתַּחֲו֣וּ לַ֭יהוָה בְּהַדְרַת ־ קֹ֑דֶשׁ חִ֥ילוּ מִ֝פָּנָ֗יו כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "אִמְר֤וּ בַגּוֹיִ֨ם ׀ יְה֘וָ֤ה מָלָ֗ךְ אַף ־ תִּכּ֣וֹן תֵּ֭בֵל בַּל ־ תִּמּ֑וֹט יָדִ֥ין עַ֝מִּ֗ים בְּמֵישָׁרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "יִשְׂמְח֣וּ הַ֭שָּׁמַיִם וְתָגֵ֣ל הָאָ֑רֶץ יִֽרְעַ֥ם הַ֝יָּ֗ם וּמְלֹאֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "יַעֲלֹ֣ז שָׂ֭דַי וְכָל ־ אֲשֶׁר ־ בּ֑וֹ אָ֥ז יְ֝רַנְּנ֗וּ כָּל ־ עֲצֵי ־ יָֽעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.96.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 13,
      "referenceLabel": "Psalms 96:13",
      "text": "לִפְנֵ֤י יְהוָ֨ה ׀ כִּ֬י בָ֗א כִּ֥י בָא֮ לִשְׁפֹּ֪ט הָ֫אָ֥רֶץ יִשְׁפֹּֽט ־ תֵּבֵ֥ל בְּצֶ֑דֶק וְ֝עַמִּ֗ים בֶּאֱמוּנָתֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
