{
  "chapter": {
    "id": "wlc:psalms.7",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 7,
    "referenceLabel": "Psalms 7",
    "summary": "Source text for Psalms 7 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.7.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Psalms 7:1",
      "text": "שִׁגָּי֗וֹן לְדָ֫וִ֥ד אֲשֶׁר ־ שָׁ֥ר לַיהוָ֑ה עַל ־ דִּבְרֵי ־ כ֝֗וּשׁ בֶּן ־ יְמִינִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.7.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Psalms 7:2",
      "text": "יְהוָ֣ה אֱ֭לֹהַי בְּךָ֣ חָסִ֑יתִי הוֹשִׁיעֵ֥נִי מִכָּל ־ רֹ֝דְפַ֗י וְהַצִּילֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Psalms 7:3",
      "text": "פֶּן ־ יִטְרֹ֣ף כְּאַרְיֵ֣ה נַפְשִׁ֑י פֹּ֝רֵ֗ק וְאֵ֣ין מַצִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Psalms 7:4",
      "text": "יְהוָ֣ה אֱ֭לֹהַי אִם ־ עָשִׂ֣יתִי זֹ֑את אִֽם ־ יֶשׁ ־ עָ֥וֶל בְּכַפָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Psalms 7:5",
      "text": "אִם ־ גָּ֭מַלְתִּי שֽׁוֹלְמִ֥י רָ֑ע וָאֲחַלְּצָ֖ה צוֹרְרִ֣י רֵיקָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Psalms 7:6",
      "text": "יִֽרַדֹּ֥ף אוֹיֵ֨ב ׀ נַפְשִׁ֡י וְיַשֵּׂ֗ג וְיִרְמֹ֣ס לָאָ֣רֶץ חַיָּ֑י וּכְבוֹדִ֓י ׀ לֶעָפָ֖ר יַשְׁכֵּ֣ן סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Psalms 7:7",
      "text": "ק֘וּמָ֤ה יְהוָ֨ה ׀ בְּאַפֶּ֗ךָ הִ֭נָּשֵׂא בְּעַבְר֣וֹת צוֹרְרָ֑י וְע֥וּרָה אֵ֝לַ֗י מִשְׁפָּ֥ט צִוִּֽיתָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Psalms 7:8",
      "text": "וַעֲדַ֣ת לְ֭אֻמִּים תְּסוֹבְבֶ֑ךָּ וְ֝עָלֶ֗יהָ לַמָּר֥וֹם שֽׁוּבָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Psalms 7:9",
      "text": "יְהוָה֮ יָדִ֪ין עַ֫מִּ֥ים שָׁפְטֵ֥נִי יְהוָ֑ה כְּצִדְקִ֖י וּכְתֻמִּ֣י עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Psalms 7:10",
      "text": "יִגְמָר ־ נָ֬א רַ֨ע ׀ רְשָׁעִים֮ וּתְכוֹנֵ֪ן צַ֫דִּ֥יק וּבֹחֵ֣ן לִ֭בּ֗וֹת וּכְלָי֗וֹת אֱלֹהִ֥ים צַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Psalms 7:11",
      "text": "מָֽגִנִּ֥י עַל ־ אֱלֹהִ֑ים מ֝וֹשִׁ֗יעַ יִשְׁרֵי ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Psalms 7:12",
      "text": "אֱ֭לֹהִים שׁוֹפֵ֣ט צַדִּ֑יק וְ֝אֵ֗ל זֹעֵ֥ם בְּכָל ־ יֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Psalms 7:13",
      "text": "אִם ־ לֹ֣א יָ֭שׁוּב חַרְבּ֣וֹ יִלְט֑וֹשׁ קַשְׁתּ֥וֹ דָ֝רַ֗ךְ וַֽיְכוֹנְנֶֽהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Psalms 7:14",
      "text": "וְ֭לוֹ הֵכִ֣ין כְּלֵי ־ מָ֑וֶת חִ֝צָּ֗יו לְֽדֹלְקִ֥ים יִפְעָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Psalms 7:15",
      "text": "הִנֵּ֥ה יְחַבֶּל ־ אָ֑וֶן וְהָרָ֥ה עָ֝מָ֗ל וְיָ֣לַד שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Psalms 7:16",
      "text": "בּ֣וֹר כָּ֭רָֽה וַֽיַּחְפְּרֵ֑הוּ וַ֝יִּפֹּ֗ל בְּשַׁ֣חַת יִפְעָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Psalms 7:17",
      "text": "יָשׁ֣וּב עֲמָל֣וֹ בְרֹאשׁ֑וֹ וְעַ֥ל קָ֝דְקֳד֗וֹ חֲמָס֥וֹ יֵרֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.7.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Psalms 7:18",
      "text": "אוֹדֶ֣ה יְהוָ֣ה כְּצִדְק֑וֹ וַ֝אֲזַמְּרָ֗ה שֵֽׁם ־ יְהוָ֥ה עֶלְיֽוֹן ׃",
      "paragraphStart": false
    }
  ]
}
