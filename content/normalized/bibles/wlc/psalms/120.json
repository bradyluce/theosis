{
  "chapter": {
    "id": "wlc:psalms.120",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.120.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת אֶל ־ יְ֭הוָה בַּצָּרָ֣תָה לִּ֑י קָ֝רָ֗אתִי וַֽיַּעֲנֵֽנִי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.120.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "יְֽהוָ֗ה הַצִּ֣ילָה נַ֭פְשִׁי מִשְּׂפַת ־ שֶׁ֑קֶר מִלָּשׁ֥וֹן רְמִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.120.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "מַה ־ יִּתֵּ֣ן לְ֭ךָ וּמַה ־ יֹּסִ֥יף לָ֗ךְ לָשׁ֥וֹן רְמִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.120.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "חִצֵּ֣י גִבּ֣וֹר שְׁנוּנִ֑ים עִ֝֗ם גַּחֲלֵ֥י רְתָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.120.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "אֽוֹיָה ־ לִ֭י כִּי ־ גַ֣רְתִּי מֶ֑שֶׁךְ שָׁ֝כַ֗נְתִּי עִֽם ־ אָהֳלֵ֥י קֵדָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.120.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "רַ֭בַּת שָֽׁכְנָה ־ לָּ֣הּ נַפְשִׁ֑י עִ֝֗ם שׂוֹנֵ֥א שָׁלֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.120.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "אֲֽנִי ־ שָׁ֭לוֹם וְכִ֣י אֲדַבֵּ֑ר הֵ֝֗מָּה לַמִּלְחָמָֽה ׃",
      "paragraphStart": false
    }
  ]
}
