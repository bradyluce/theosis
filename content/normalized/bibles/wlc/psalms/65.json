{
  "chapter": {
    "id": "wlc:psalms.65",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.65.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "לַמְנַצֵּ֥חַ מִזְמ֗וֹר לְדָוִ֥ד שִֽׁיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.65.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "לְךָ֤ דֻֽמִיָּ֬ה תְהִלָּ֓ה אֱלֹ֘הִ֥ים בְּצִיּ֑וֹן וּ֝לְךָ֗ יְשֻׁלַּם ־ נֶֽדֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "שֹׁמֵ֥עַ תְּפִלָּ֑ה עָ֝דֶ֗יךָ כָּל ־ בָּשָׂ֥ר יָבֹֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "דִּבְרֵ֣י עֲ֭וֺנֹת גָּ֣בְרוּ מֶ֑נִּי פְּ֝שָׁעֵ֗ינוּ אַתָּ֥ה תְכַפְּרֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "אַשְׁרֵ֤י ׀ תִּֽבְחַ֣ר וּתְקָרֵב֮ יִשְׁכֹּ֪ן חֲצֵ֫רֶ֥יךָ נִ֭שְׂבְּעָה בְּט֣וּב בֵּיתֶ֑ךָ קְ֝דֹ֗שׁ הֵיכָלֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "נ֤וֹרָא֨וֹת ׀ בְּצֶ֣דֶק תַּ֭עֲנֵנוּ אֱלֹהֵ֣י יִשְׁעֵ֑נוּ מִבְטָ֥ח כָּל ־ קַצְוֵי ־ אֶ֝֗רֶץ וְיָ֣ם רְחֹקִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "מֵכִ֣ין הָרִ֣ים בְּכֹח֑וֹ נֶ֝אְזָ֗ר בִּגְבוּרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "מַשְׁבִּ֤יחַ ׀ שְׁא֣וֹן יַ֭מִּים שְׁא֥וֹן גַּלֵּיהֶ֗ם וַהֲמ֥וֹן לְאֻמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "וַיִּ֤ירְא֨וּ ׀ יֹשְׁבֵ֣י קְ֭צָוֺת מֵאוֹתֹתֶ֑יךָ מ֤וֹצָֽאֵי ־ בֹ֖קֶר וָעֶ֣רֶב תַּרְנִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "פָּקַ֥דְתָּ הָאָ֨רֶץ ׀ וַתְּשֹׁ֪קְקֶ֡הָ רַבַּ֬ת תַּעְשְׁרֶ֗נָּה פֶּ֣לֶג אֱ֭לֹהִים מָ֣לֵא מָ֑יִם תָּכִ֥ין דְּ֝גָנָ֗ם כִּי ־ כֵ֥ן תְּכִינֶֽהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "תְּלָמֶ֣יהָ רַ֭וֵּה נַחֵ֣ת גְּדוּדֶ֑יהָ בִּרְבִיבִ֥ים תְּ֝מֹגְגֶ֗נָּה צִמְחָ֥הּ תְּבָרֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "עִ֭טַּרְתָּ שְׁנַ֣ת טוֹבָתֶ֑ךָ וּ֝מַעְגָּלֶ֗יךָ יִרְעֲפ֥וּן דָּֽשֶׁן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "יִ֭רְעֲפוּ נְא֣וֹת מִדְבָּ֑ר וְ֝גִ֗יל גְּבָע֥וֹת תַּחְגֹּֽרְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.65.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 14,
      "referenceLabel": "Psalms 65:14",
      "text": "לָבְשׁ֬וּ כָרִ֨ים ׀ הַצֹּ֗אן וַעֲמָקִ֥ים יַֽעַטְפוּ ־ בָ֑ר יִ֝תְרוֹעֲע֗וּ אַף ־ יָשִֽׁירוּ ׃",
      "paragraphStart": false
    }
  ]
}
