{
  "chapter": {
    "id": "wlc:psalms.22",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.22.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "לַ֭מְנַצֵּחַ עַל ־ אַיֶּ֥לֶת הַשַּׁ֗חַר מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.22.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "אֵלִ֣י אֵ֭לִי לָמָ֣ה עֲזַבְתָּ֑נִי רָח֥וֹק מִֽ֝ישׁוּעָתִ֗י דִּבְרֵ֥י שַׁאֲגָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "אֱֽלֹהַ֗י אֶקְרָ֣א י֭וֹמָם וְלֹ֣א תַעֲנֶ֑ה וְ֝לַ֗יְלָה וְֽלֹא ־ דֽוּמִיָּ֥ה לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "וְאַתָּ֥ה קָד֑וֹשׁ י֝וֹשֵׁ֗ב תְּהִלּ֥וֹת יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "בְּ֭ךָ בָּטְח֣וּ אֲבֹתֵ֑ינוּ בָּ֝טְח֗וּ וַֽתְּפַלְּטֵֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "אֵלֶ֣יךָ זָעֲק֣וּ וְנִמְלָ֑טוּ בְּךָ֖ בָטְח֣וּ וְלֹא ־ בֽוֹשׁוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Psalms 22:7",
      "text": "וְאָנֹכִ֣י תוֹלַ֣עַת וְלֹא ־ אִ֑ישׁ חֶרְפַּ֥ת אָ֝דָ֗ם וּבְז֥וּי עָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Psalms 22:8",
      "text": "כָּל ־ רֹ֭אַי יַלְעִ֣גוּ לִ֑י יַפְטִ֥ירוּ בְ֝שָׂפָ֗ה יָנִ֥יעוּ רֹֽאשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Psalms 22:9",
      "text": "גֹּ֣ל אֶל ־ יְהוָ֣ה יְפַלְּטֵ֑הוּ יַ֝צִּילֵ֗הוּ כִּ֘י חָ֥פֵֽץ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Psalms 22:10",
      "text": "כִּֽי ־ אַתָּ֣ה גֹחִ֣י מִבָּ֑טֶן מַ֝בְטִיחִ֗י עַל ־ שְׁדֵ֥י אִמִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Psalms 22:11",
      "text": "עָ֭לֶיךָ הָשְׁלַ֣כְתִּי מֵרָ֑חֶם מִבֶּ֥טֶן אִ֝מִּ֗י אֵ֣לִי אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Psalms 22:12",
      "text": "אַל ־ תִּרְחַ֣ק מִ֭מֶּנִּי כִּי ־ צָרָ֣ה קְרוֹבָ֑ה כִּי ־ אֵ֥ין עוֹזֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Psalms 22:13",
      "text": "סְ֭בָבוּנִי פָּרִ֣ים רַבִּ֑ים אַבִּירֵ֖י בָשָׁ֣ן כִּתְּרֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Psalms 22:14",
      "text": "פָּצ֣וּ עָלַ֣י פִּיהֶ֑ם אַ֝רְיֵ֗ה טֹרֵ֥ף וְשֹׁאֵֽג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Psalms 22:15",
      "text": "כַּמַּ֥יִם נִשְׁפַּכְתִּי֮ וְהִתְפָּֽרְד֗וּ כָּֽל ־ עַצְמ֫וֹתָ֥י הָיָ֣ה לִ֭בִּי כַּדּוֹנָ֑ג נָ֝מֵ֗ס בְּת֣וֹךְ מֵעָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Psalms 22:16",
      "text": "יָ֘בֵ֤שׁ כַּחֶ֨רֶשׂ ׀ כֹּחִ֗י וּ֭לְשׁוֹנִי מֻדְבָּ֣ק מַלְקוֹחָ֑י וְֽלַעֲפַר ־ מָ֥וֶת תִּשְׁפְּתֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Psalms 22:17",
      "text": "כִּ֥י סְבָב֗וּנִי כְּלָ֫בִ֥ים עֲדַ֣ת מְ֭רֵעִים הִקִּיפ֑וּנִי כָּ֝אֲרִ֗י יָדַ֥י וְרַגְלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Psalms 22:18",
      "text": "אֲסַפֵּ֥ר כָּל ־ עַצְמוֹתָ֑י הֵ֥מָּה יַ֝בִּ֗יטוּ יִרְאוּ ־ בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Psalms 22:19",
      "text": "יְחַלְּק֣וּ בְגָדַ֣י לָהֶ֑ם וְעַל ־ לְ֝בוּשִׁ֗י יַפִּ֥ילוּ גוֹרָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Psalms 22:20",
      "text": "וְאַתָּ֣ה יְ֭הוָה אַל ־ תִּרְחָ֑ק אֱ֝יָלוּתִ֗י לְעֶזְרָ֥תִי חֽוּשָׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Psalms 22:21",
      "text": "הַצִּ֣ילָה מֵחֶ֣רֶב נַפְשִׁ֑י מִיַּד ־ כֶּ֝֗לֶב יְחִידָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Psalms 22:22",
      "text": "ה֭וֹשִׁיעֵנִי מִפִּ֣י אַרְיֵ֑ה וּמִקַּרְנֵ֖י רֵמִ֣ים עֲנִיתָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Psalms 22:23",
      "text": "אֲסַפְּרָ֣ה שִׁמְךָ֣ לְאֶחָ֑י בְּת֖וֹךְ קָהָ֣ל אֲהַלְלֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Psalms 22:24",
      "text": "יִרְאֵ֤י יְהוָ֨ה ׀ הַֽלְל֗וּהוּ כָּל ־ זֶ֣רַע יַעֲקֹ֣ב כַּבְּד֑וּהוּ וְג֥וּרוּ מִ֝מֶּ֗נּוּ כָּל ־ זֶ֥רַע יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Psalms 22:25",
      "text": "כִּ֤י לֹֽא ־ בָזָ֨ה וְלֹ֪א שִׁקַּ֡ץ עֱנ֬וּת עָנִ֗י וְלֹא ־ הִסְתִּ֣יר פָּנָ֣יו מִמֶּ֑נּוּ וּֽבְשַׁוְּע֖וֹ אֵלָ֣יו שָׁמֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Psalms 22:26",
      "text": "מֵ֥אִתְּךָ֗ תְֽהִלָּ֫תִ֥י בְּקָהָ֥ל רָ֑ב נְדָרַ֥י אֲ֝שַׁלֵּ֗ם נֶ֣גֶד יְרֵאָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Psalms 22:27",
      "text": "יֹאכְל֬וּ עֲנָוִ֨ים ׀ וְיִשְׂבָּ֗עוּ יְהַֽלְל֣וּ יְ֭הוָה דֹּ֣רְשָׁ֑יו יְחִ֖י לְבַבְכֶ֣ם לָעַֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Psalms 22:28",
      "text": "יִזְכְּר֤וּ ׀ וְיָשֻׁ֣בוּ אֶל ־ יְ֭הוָה כָּל ־ אַפְסֵי ־ אָ֑רֶץ וְיִֽשְׁתַּחֲו֥וּ לְ֝פָנֶ֗יךָ כָּֽל ־ מִשְׁפְּח֥וֹת גּוֹיִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Psalms 22:29",
      "text": "כִּ֣י לַ֭יהוָה הַמְּלוּכָ֑ה וּ֝מֹשֵׁ֗ל בַּגּוֹיִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Psalms 22:30",
      "text": "אָכְל֬וּ וַיִּֽשְׁתַּחֲוּ֨וּ ׀ כָּֽל ־ דִּשְׁנֵי ־ אֶ֗רֶץ לְפָנָ֣יו יִ֭כְרְעוּ כָּל ־ יוֹרְדֵ֣י עָפָ֑ר וְ֝נַפְשׁ֗וֹ לֹ֣א חִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Psalms 22:31",
      "text": "זֶ֥רַע יַֽעַבְדֶ֑נּוּ יְסֻפַּ֖ר לַֽאדֹנָ֣י לַדּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.22.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Psalms 22:32",
      "text": "יָ֭בֹאוּ וְיַגִּ֣ידוּ צִדְקָת֑וֹ לְעַ֥ם נ֝וֹלָ֗ד כִּ֣י עָשָֽׂה ׃",
      "paragraphStart": false
    }
  ]
}
