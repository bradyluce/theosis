{
  "chapter": {
    "id": "wlc:psalms.38",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 38,
    "referenceLabel": "Psalms 38",
    "summary": "Source text for Psalms 38 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.38.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Psalms 38:1",
      "text": "מִזְמ֖וֹר לְדָוִ֣ד לְהַזְכִּֽיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.38.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Psalms 38:2",
      "text": "יְֽהוָ֗ה אַל ־ בְּקֶצְפְּךָ֥ תוֹכִיחֵ֑נִי וּֽבַחֲמָתְךָ֥ תְיַסְּרֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Psalms 38:3",
      "text": "כִּֽי ־ חִ֭צֶּיךָ נִ֣חֲתוּ בִ֑י וַתִּנְחַ֖ת עָלַ֣י יָדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Psalms 38:4",
      "text": "אֵין ־ מְתֹ֣ם בִּ֭בְשָׂרִי מִפְּנֵ֣י זַעְמֶ֑ךָ אֵין ־ שָׁל֥וֹם בַּ֝עֲצָמַ֗י מִפְּנֵ֥י חַטָּאתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Psalms 38:5",
      "text": "כִּ֣י עֲ֭וֺנֹתַי עָבְר֣וּ רֹאשִׁ֑י כְּמַשָּׂ֥א כָ֝בֵ֗ד יִכְבְּד֥וּ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Psalms 38:6",
      "text": "הִבְאִ֣ישׁוּ נָ֭מַקּוּ חַבּוּרֹתָ֑י מִ֝פְּנֵ֗י אִוַּלְתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Psalms 38:7",
      "text": "נַעֲוֵ֣יתִי שַׁחֹ֣תִי עַד ־ מְאֹ֑ד כָּל ־ הַ֝יּ֗וֹם קֹדֵ֥ר הִלָּֽכְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Psalms 38:8",
      "text": "כִּֽי ־ כְ֭סָלַי מָלְא֣וּ נִקְלֶ֑ה וְאֵ֥ין מְ֝תֹ֗ם בִּבְשָׂרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Psalms 38:9",
      "text": "נְפוּג֣וֹתִי וְנִדְכֵּ֣יתִי עַד ־ מְאֹ֑ד שָׁ֝אַ֗גְתִּי מִֽנַּהֲמַ֥ת לִבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Psalms 38:10",
      "text": "אֲֽדֹנָי נֶגְדְּךָ֥ כָל ־ תַּאֲוָתִ֑י וְ֝אַנְחָתִ֗י מִמְּךָ֥ לֹא ־ נִסְתָּֽרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Psalms 38:11",
      "text": "לִבִּ֣י סְ֭חַרְחַר עֲזָבַ֣נִי כֹחִ֑י וְֽאוֹר ־ עֵינַ֥י גַּם ־ הֵ֝֗ם אֵ֣ין אִתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Psalms 38:12",
      "text": "אֹֽהֲבַ֨י ׀ וְרֵעַ֗י מִנֶּ֣גֶד נִגְעִ֣י יַעֲמֹ֑דוּ וּ֝קְרוֹבַ֗י מֵרָחֹ֥ק עָמָֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Psalms 38:13",
      "text": "וַיְנַקְשׁ֤וּ ׀ מְבַקְשֵׁ֬י נַפְשִׁ֗י וְדֹרְשֵׁ֣י רָ֭עָתִי דִּבְּר֣וּ הַוּ֑וֹת וּ֝מִרְמ֗וֹת כָּל ־ הַיּ֥וֹם יֶהְגּֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Psalms 38:14",
      "text": "וַאֲנִ֣י כְ֭חֵרֵשׁ לֹ֣א אֶשְׁמָ֑ע וּ֝כְאִלֵּ֗ם לֹ֣א יִפְתַּח ־ פִּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Psalms 38:15",
      "text": "וָאֱהִ֗י כְּ֭אִישׁ אֲשֶׁ֣ר לֹא ־ שֹׁמֵ֑עַ וְאֵ֥ין בְּ֝פִ֗יו תּוֹכָחֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Psalms 38:16",
      "text": "כִּֽי ־ לְךָ֣ יְהוָ֣ה הוֹחָ֑לְתִּי אַתָּ֥ה תַ֝עֲנֶ֗ה אֲדֹנָ֥י אֱלֹהָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Psalms 38:17",
      "text": "כִּֽי ־ אָ֭מַרְתִּי פֶּן ־ יִשְׂמְחוּ ־ לִ֑י בְּמ֥וֹט רַ֝גְלִ֗י עָלַ֥י הִגְדִּֽילוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Psalms 38:18",
      "text": "כִּֽי ־ אֲ֭נִי לְצֶ֣לַע נָכ֑וֹן וּמַכְאוֹבִ֖י נֶגְדִּ֣י תָמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Psalms 38:19",
      "text": "כִּֽי ־ עֲוֺנִ֥י אַגִּ֑יד אֶ֝דְאַ֗ג מֵֽחַטָּאתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Psalms 38:20",
      "text": "וְֽ֭אֹיְבַי חַיִּ֣ים עָצֵ֑מוּ וְרַבּ֖וּ שֹׂנְאַ֣י שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Psalms 38:21",
      "text": "וּמְשַׁלְּמֵ֣י רָ֭עָה תַּ֣חַת טוֹבָ֑ה יִ֝שְׂטְנ֗וּנִי תַּ֣חַת רדופי ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Psalms 38:22",
      "text": "אַל ־ תַּֽעַזְבֵ֥נִי יְהוָ֑ה אֱ֝לֹהַ֗י אַל ־ תִּרְחַ֥ק מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.38.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 23,
      "referenceLabel": "Psalms 38:23",
      "text": "ח֥וּשָׁה לְעֶזְרָתִ֑י אֲ֝דֹנָ֗י תְּשׁוּעָתִֽי ׃",
      "paragraphStart": false
    }
  ]
}
