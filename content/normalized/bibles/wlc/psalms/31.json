{
  "chapter": {
    "id": "wlc:psalms.31",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 31,
    "referenceLabel": "Psalms 31",
    "summary": "Source text for Psalms 31 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.31.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Psalms 31:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.31.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Psalms 31:2",
      "text": "בְּךָ֖ יְהוָ֣ה חָ֭סִיתִי אַל ־ אֵב֣וֹשָׁה לְעוֹלָ֑ם בְּצִדְקָתְךָ֥ פַלְּטֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Psalms 31:3",
      "text": "הַטֵּ֤ה אֵלַ֨י ׀ אָזְנְךָ֮ מְהֵרָ֪ה הַצִּ֫ילֵ֥נִי הֱיֵ֤ה לִ֨י ׀ לְֽצוּר ־ מָ֭עוֹז לְבֵ֥ית מְצוּד֗וֹת לְהוֹשִׁיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Psalms 31:4",
      "text": "כִּֽי ־ סַלְעִ֣י וּמְצוּדָתִ֣י אָ֑תָּה וּלְמַ֥עַן שִׁ֝מְךָ֗ תַּֽנְחֵ֥נִי וּֽתְנַהֲלֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Psalms 31:5",
      "text": "תּוֹצִיאֵ֗נִי מֵרֶ֣שֶׁת ז֭וּ טָ֣מְנוּ לִ֑י כִּֽי ־ אַ֝תָּה מָֽעוּזִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Psalms 31:6",
      "text": "בְּיָדְךָ֮ אַפְקִ֪יד ר֫וּחִ֥י פָּדִ֖יתָה אוֹתִ֥י יְהוָ֗ה אֵ֣ל אֱמֶֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Psalms 31:7",
      "text": "שָׂנֵ֗אתִי הַשֹּׁמְרִ֥ים הַבְלֵי ־ שָׁ֑וְא וַ֝אֲנִ֗י אֶל ־ יְהוָ֥ה בָּטָֽחְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Psalms 31:8",
      "text": "אָגִ֥ילָה וְאֶשְׂמְחָ֗ה בְּחַ֫סְדֶּ֥ךָ אֲשֶׁ֣ר רָ֭אִיתָ אֶת ־ עָנְיִ֑י יָ֝דַ֗עְתָּ בְּצָר֥וֹת נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Psalms 31:9",
      "text": "וְלֹ֣א הִ֭סְגַּרְתַּנִי בְּיַד ־ אוֹיֵ֑ב הֶֽעֱמַ֖דְתָּ בַמֶּרְחָ֣ב רַגְלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Psalms 31:10",
      "text": "חָנֵּ֥נִי יְהוָה֮ כִּ֤י צַ֫ר ־ לִ֥י עָשְׁשָׁ֖ה בְכַ֥עַס עֵינִ֗י נַפְשִׁ֥י וּבִטְנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Psalms 31:11",
      "text": "כִּ֤י כָל֪וּ בְיָג֡וֹן חַיַּי֮ וּשְׁנוֹתַ֪י בַּאֲנָ֫חָ֥ה כָּשַׁ֣ל בַּעֲוֺנִ֣י כֹחִ֑י וַעֲצָמַ֥י עָשֵֽׁשׁוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Psalms 31:12",
      "text": "מִכָּל ־ צֹרְרַ֨י הָיִ֪יתִי חֶרְפָּ֡ה וְלִשֲׁכֵנַ֨י ׀ מְאֹד֮ וּפַ֪חַד לִֽמְיֻדָּ֫עָ֥י רֹאַ֥י בַּח֑וּץ נָדְד֥וּ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Psalms 31:13",
      "text": "נִ֭שְׁכַּחְתִּי כְּמֵ֣ת מִלֵּ֑ב הָ֝יִ֗יתִי כִּכְלִ֥י אֹבֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Psalms 31:14",
      "text": "כִּ֤י שָׁמַ֨עְתִּי ׀ דִּבַּ֥ת רַבִּים֮ מָג֪וֹר מִסָּ֫בִ֥יב בְּהִוָּסְדָ֣ם יַ֣חַד עָלַ֑י לָקַ֖חַת נַפְשִׁ֣י זָמָֽמוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Psalms 31:15",
      "text": "וַאֲנִ֤י ׀ עָלֶ֣יךָ בָטַ֣חְתִּי יְהוָ֑ה אָ֝מַ֗רְתִּי אֱלֹהַ֥י אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Psalms 31:16",
      "text": "בְּיָדְךָ֥ עִתֹּתָ֑י הַצִּ֘ילֵ֤נִי מִיַּד ־ א֝וֹיְבַ֗י וּמֵרֹדְפָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Psalms 31:17",
      "text": "הָאִ֣ירָה פָ֭נֶיךָ עַל ־ עַבְדֶּ֑ךָ ה֖וֹשִׁיעֵ֣נִי בְחַסְדֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Psalms 31:18",
      "text": "יְֽהוָ֗ה אַל ־ אֵ֭בוֹשָׁה כִּ֣י קְרָאתִ֑יךָ יֵבֹ֥שׁוּ רְ֝שָׁעִ֗ים יִדְּמ֥וּ לִשְׁאֽוֹל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Psalms 31:19",
      "text": "תֵּ֥אָלַ֗מְנָה שִׂפְתֵ֫י שָׁ֥קֶר הַדֹּבְר֖וֹת עַל ־ צַדִּ֥יק עָתָ֗ק בְּגַאֲוָ֥ה וָבֽוּז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Psalms 31:20",
      "text": "מָ֤ה רַֽב ־ טוּבְךָ֮ אֲשֶׁר ־ צָפַ֪נְתָּ לִּֽירֵ֫אֶ֥יךָ פָּ֭עַלְתָּ לַחֹסִ֣ים בָּ֑ךְ נֶ֝֗גֶד בְּנֵ֣י אָדָם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Psalms 31:21",
      "text": "תַּסְתִּירֵ֤ם ׀ בְּסֵ֥תֶר פָּנֶיךָ֮ מֵֽרֻכְסֵ֫י אִ֥ישׁ תִּצְפְּנֵ֥ם בְּסֻכָּ֗ה מֵרִ֥יב לְשֹׁנֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Psalms 31:22",
      "text": "בָּר֥וּךְ יְהוָ֑ה כִּ֥י הִפְלִ֘יא חַסְדּ֥וֹ לִ֝֗י בְּעִ֣יר מָצֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Psalms 31:23",
      "text": "וַאֲנִ֤י ׀ אָ֘מַ֤רְתִּי בְחָפְזִ֗י נִגְרַזְתִּי֮ מִנֶּ֪גֶד עֵ֫ינֶ֥יךָ אָכֵ֗ן שָׁ֭מַעְתָּ ק֥וֹל תַּחֲנוּנַ֗י בְּשַׁוְּעִ֥י אֵלֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Psalms 31:24",
      "text": "אֶֽהֱב֥וּ אֶת ־ יְהוָ֗ה כָּֽל ־ חֲסִ֫ידָ֥יו אֱ֭מוּנִים נֹצֵ֣ר יְהוָ֑ה וּמְשַׁלֵּ֥ם עַל ־ יֶ֝֗תֶר עֹשֵׂ֥ה גַאֲוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.31.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Psalms 31:25",
      "text": "חִ֭זְקוּ וְיַאֲמֵ֣ץ לְבַבְכֶ֑ם כָּל ־ הַ֝מְיַחֲלִ֗ים לַיהוָֽה ׃",
      "paragraphStart": false
    }
  ]
}
