{
  "chapter": {
    "id": "wlc:psalms.114",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.114.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "בְּצֵ֣את יִ֭שְׂרָאֵל מִמִּצְרָ֑יִם בֵּ֥ית יַ֝עֲקֹ֗ב מֵעַ֥ם לֹעֵֽז ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.114.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "הָיְתָ֣ה יְהוּדָ֣ה לְקָדְשׁ֑וֹ יִ֝שְׂרָאֵ֗ל מַמְשְׁלוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.114.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "הַיָּ֣ם רָ֭אָה וַיָּנֹ֑ס הַ֝יַּרְדֵּ֗ן יִסֹּ֥ב לְאָחֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.114.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "הֶֽ֭הָרִים רָקְד֣וּ כְאֵילִ֑ים גְּ֝בָע֗וֹת כִּבְנֵי ־ צֹֽאן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.114.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "מַה ־ לְּךָ֣ הַ֭יָּם כִּ֣י תָנ֑וּס הַ֝יַּרְדֵּ֗ן תִּסֹּ֥ב לְאָחֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.114.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "הֶֽ֭הָרִים תִּרְקְד֣וּ כְאֵילִ֑ים גְּ֝בָע֗וֹת כִּבְנֵי ־ צֹֽאן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.114.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "מִלִּפְנֵ֣י אָ֭דוֹן ח֣וּלִי אָ֑רֶץ מִ֝לִּפְנֵ֗י אֱל֣וֹהַּ יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.114.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "הַהֹפְכִ֣י הַצּ֣וּר אֲגַם ־ מָ֑יִם חַ֝לָּמִ֗ישׁ לְמַעְיְנוֹ ־ מָֽיִם ׃",
      "paragraphStart": false
    }
  ]
}
