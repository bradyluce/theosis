{
  "chapter": {
    "id": "wlc:psalms.143",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 143,
    "referenceLabel": "Psalms 143",
    "summary": "Source text for Psalms 143 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.143.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 1,
      "referenceLabel": "Psalms 143:1",
      "text": "מִזְמ֗וֹר לְדָ֫וִ֥ד יְהוָ֤ה ׀ שְׁמַ֬ע תְּפִלָּתִ֗י הַאֲזִ֥ינָה אֶל ־ תַּחֲנוּנַ֑י בֶּאֱמֻנָתְךָ֥ עֲ֝נֵ֗נִי בְּצִדְקָתֶֽךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.143.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 2,
      "referenceLabel": "Psalms 143:2",
      "text": "וְאַל ־ תָּב֣וֹא בְ֭מִשְׁפָּט אֶת ־ עַבְדֶּ֑ךָ כִּ֤י לֹֽא ־ יִצְדַּ֖ק לְפָנֶ֣יךָ כָל ־ חָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 3,
      "referenceLabel": "Psalms 143:3",
      "text": "כִּ֥י רָ֘דַ֤ף אוֹיֵ֨ב ׀ נַפְשִׁ֗י דִּכָּ֣א לָ֭אָרֶץ חַיָּתִ֑י הוֹשִׁיבַ֥נִי בְ֝מַחֲשַׁכִּ֗ים כְּמֵתֵ֥י עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 4,
      "referenceLabel": "Psalms 143:4",
      "text": "וַתִּתְעַטֵּ֣ף עָלַ֣י רוּחִ֑י בְּ֝תוֹכִ֗י יִשְׁתּוֹמֵ֥ם לִבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 5,
      "referenceLabel": "Psalms 143:5",
      "text": "זָ֘כַ֤רְתִּי יָמִ֨ים ׀ מִקֶּ֗דֶם הָגִ֥יתִי בְכָל ־ פָּעֳלֶ֑ךָ בְּֽמַעֲשֵׂ֖ה יָדֶ֣יךָ אֲשׂוֹחֵֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 6,
      "referenceLabel": "Psalms 143:6",
      "text": "פֵּרַ֣שְׂתִּי יָדַ֣י אֵלֶ֑יךָ נַפְשִׁ֓י ׀ כְּאֶֽרֶץ ־ עֲיֵפָ֖ה לְךָ֣ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 7,
      "referenceLabel": "Psalms 143:7",
      "text": "מַ֘הֵ֤ר עֲנֵ֨נִי ׀ יְהוָה֮ כָּלְתָ֪ה ר֫וּחִ֥י אַל ־ תַּסְתֵּ֣ר פָּנֶ֣יךָ מִמֶּ֑נִּי וְ֝נִמְשַׁ֗לְתִּי עִם ־ יֹ֥רְדֵי בֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 8,
      "referenceLabel": "Psalms 143:8",
      "text": "הַשְׁמִ֘יעֵ֤נִי בַבֹּ֨קֶר ׀ חַסְדֶּךָ֮ כִּֽי ־ בְךָ֪ בָ֫טָ֥חְתִּי הוֹדִיעֵ֗נִי דֶּֽרֶךְ ־ ז֥וּ אֵלֵ֑ךְ כִּֽי ־ אֵ֝לֶיךָ נָשָׂ֥אתִי נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 9,
      "referenceLabel": "Psalms 143:9",
      "text": "הַצִּילֵ֖נִי מֵאֹיְבַ֥י ׀ יְהוָ֗ה אֵלֶ֥יךָ כִסִּֽתִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 10,
      "referenceLabel": "Psalms 143:10",
      "text": "לַמְּדֵ֤נִי ׀ לַֽעֲשׂ֣וֹת רְצוֹנֶךָ֮ כִּֽי ־ אַתָּ֪ה אֱל֫וֹהָ֥י רוּחֲךָ֥ טוֹבָ֑ה תַּ֝נְחֵ֗נִי בְּאֶ֣רֶץ מִישֽׁוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 11,
      "referenceLabel": "Psalms 143:11",
      "text": "לְמַֽעַן ־ שִׁמְךָ֣ יְהוָ֣ה תְּחַיֵּ֑נִי בְּצִדְקָתְךָ֓ ׀ תוֹצִ֖יא מִצָּרָ֣ה נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.143.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 12,
      "referenceLabel": "Psalms 143:12",
      "text": "וּֽבְחַסְדְּךָ֮ תַּצְמִ֪ית אֹ֫יְבָ֥י וְֽ֭הַאֲבַדְתָּ כָּל ־ צֹרֲרֵ֣י נַפְשִׁ֑י כִּ֝֗י אֲנִ֣י עַבְדֶּֽךָ ׃",
      "paragraphStart": false
    }
  ]
}
