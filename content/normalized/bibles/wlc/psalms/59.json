{
  "chapter": {
    "id": "wlc:psalms.59",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 59,
    "referenceLabel": "Psalms 59",
    "summary": "Source text for Psalms 59 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.59.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 1,
      "referenceLabel": "Psalms 59:1",
      "text": "לַמְנַצֵּ֣חַ אַל ־ תַּשְׁחֵת֮ לְדָוִ֪ד מִ֫כְתָּ֥ם בִּשְׁלֹ֥חַ שָׁא֑וּל וַֽיִּשְׁמְר֥וּ אֶת ־ הַ֝בַּ֗יִת לַהֲמִיתֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.59.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 2,
      "referenceLabel": "Psalms 59:2",
      "text": "הַצִּילֵ֖נִי מֵאֹיְבַ֥י ׀ אֱלֹהָ֑י מִּמִתְקוֹמְמַ֥י תְּשַׂגְּבֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 3,
      "referenceLabel": "Psalms 59:3",
      "text": "הַ֭צִּילֵנִי מִפֹּ֣עֲלֵי אָ֑וֶן וּֽמֵאַנְשֵׁ֥י דָ֝מִ֗ים הוֹשִׁיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 4,
      "referenceLabel": "Psalms 59:4",
      "text": "כִּ֤י הִנֵּ֪ה אָֽרְב֡וּ לְנַפְשִׁ֗י יָג֣וּרוּ עָלַ֣י עַזִ֑ים לֹא ־ פִשְׁעִ֖י וְלֹא ־ חַטָּאתִ֣י יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 5,
      "referenceLabel": "Psalms 59:5",
      "text": "בְּֽלִי ־ עָ֭וֺן יְרוּצ֣וּן וְיִכּוֹנָ֑נוּ ע֖וּרָה לִקְרָאתִ֣י וּרְאֵה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 6,
      "referenceLabel": "Psalms 59:6",
      "text": "וְאַתָּ֤ה יְהוָֽה ־ אֱלֹהִ֥ים ׀ צְבָא֡וֹת אֱלֹ֘הֵ֤י יִשְׂרָאֵ֗ל הָקִ֗יצָה לִפְקֹ֥ד כָּֽל ־ הַגּוֹיִ֑ם אַל ־ תָּחֹ֨ן כָּל ־ בֹּ֖גְדֵי אָ֣וֶן סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 7,
      "referenceLabel": "Psalms 59:7",
      "text": "יָשׁ֣וּבוּ לָ֭עֶרֶב יֶהֱמ֥וּ כַכָּ֗לֶב וִיס֥וֹבְבוּ עִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 8,
      "referenceLabel": "Psalms 59:8",
      "text": "הִנֵּ֤ה ׀ יַבִּ֘יע֤וּן בְּפִיהֶ֗ם חֲ֭רָבוֹת בְּשִׂפְתוֹתֵיהֶ֑ם כִּי ־ מִ֥י שֹׁמֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 9,
      "referenceLabel": "Psalms 59:9",
      "text": "וְאַתָּ֣ה יְ֭הוָה תִּשְׂחַק ־ לָ֑מוֹ תִּ֝לְעַ֗ג לְכָל ־ גּוֹיִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 10,
      "referenceLabel": "Psalms 59:10",
      "text": "עֻ֭זּוֹ אֵלֶ֣יךָ אֶשְׁמֹ֑רָה כִּֽי ־ אֱ֝לֹהִ֗ים מִשְׂגַּבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 11,
      "referenceLabel": "Psalms 59:11",
      "text": "אֱלֹהֵ֣י חסדו יְקַדְּמֵ֑נִי אֱ֝לֹהִ֗ים יַרְאֵ֥נִי בְשֹׁרְרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 12,
      "referenceLabel": "Psalms 59:12",
      "text": "אַל ־ תַּהַרְגֵ֤ם ׀ פֶּֽן ־ יִשְׁכְּח֬וּ עַמִּ֗י הֲנִיעֵ֣מוֹ בְ֭חֵילְךָ וְהוֹרִידֵ֑מוֹ מָֽגִנֵּ֣נוּ אֲדֹנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 13,
      "referenceLabel": "Psalms 59:13",
      "text": "חַטַּאת ־ פִּ֗ימוֹ דְּֽבַר ־ שְׂפָ֫תֵ֥ימוֹ וְיִלָּכְד֥וּ בִגְאוֹנָ֑ם וּמֵאָלָ֖ה וּמִכַּ֣חַשׁ יְסַפֵּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 14,
      "referenceLabel": "Psalms 59:14",
      "text": "כַּלֵּ֥ה בְחֵמָה֮ כַּלֵּ֪ה וְֽאֵ֫ינֵ֥מוֹ וְֽיֵדְע֗וּ כִּֽי ־ אֱ֭לֹהִים מֹשֵׁ֣ל בְּיַעֲקֹ֑ב לְאַפְסֵ֖י הָאָ֣רֶץ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 15,
      "referenceLabel": "Psalms 59:15",
      "text": "וְיָשׁ֣וּבוּ לָ֭עֶרֶב יֶהֱמ֥וּ כַכָּ֗לֶב וִיס֥וֹבְבוּ עִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 16,
      "referenceLabel": "Psalms 59:16",
      "text": "הֵ֭מָּה ינועון לֶאֱכֹ֑ל אִם ־ לֹ֥א יִ֝שְׂבְּע֗וּ וַיָּלִֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 17,
      "referenceLabel": "Psalms 59:17",
      "text": "וַאֲנִ֤י ׀ אָשִׁ֣יר עֻזֶּךָ֮ וַאֲרַנֵּ֥ן לַבֹּ֗קֶר חַ֫סְדֶּ֥ךָ כִּֽי ־ הָיִ֣יתָ מִשְׂגָּ֣ב לִ֑י וּ֝מָנ֗וֹס בְּי֣וֹם צַר ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.59.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 18,
      "referenceLabel": "Psalms 59:18",
      "text": "עֻ֭זִּי אֵלֶ֣יךָ אֲזַמֵּ֑רָה כִּֽי ־ אֱלֹהִ֥ים מִ֝שְׂגַּבִּ֗י אֱלֹהֵ֥י חַסְדִּֽי ׃",
      "paragraphStart": false
    }
  ]
}
