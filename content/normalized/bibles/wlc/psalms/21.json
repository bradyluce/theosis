{
  "chapter": {
    "id": "wlc:psalms.21",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.21.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.21.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "יְֽהוָ֗ה בְּעָזְּךָ֥ יִשְׂמַח ־ מֶ֑לֶךְ וּ֝בִישׁ֥וּעָתְךָ֗ מַה ־ יגיל מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "תַּאֲוַ֣ת לִ֭בּוֹ נָתַ֣תָּה לּ֑וֹ וַאֲרֶ֥שֶׁת שְׂ֝פָתָ֗יו בַּל ־ מָנַ֥עְתָּ סֶּֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "כִּֽי ־ תְ֭קַדְּמֶנּוּ בִּרְכ֣וֹת ט֑וֹב תָּשִׁ֥ית לְ֝רֹאשׁ֗וֹ עֲטֶ֣רֶת פָּֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "חַיִּ֤ים ׀ שָׁאַ֣ל מִ֭מְּךָ נָתַ֣תָּה לּ֑וֹ אֹ֥רֶךְ יָ֝מִ֗ים עוֹלָ֥ם וָעֶֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "גָּד֣וֹל כְּ֭בוֹדוֹ בִּישׁוּעָתֶ֑ךָ ה֥וֹד וְ֝הָדָר תְּשַׁוֶּ֥ה עָלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "כִּֽי ־ תְשִׁיתֵ֣הוּ בְרָכ֣וֹת לָעַ֑ד תְּחַדֵּ֥הוּ בְ֝שִׂמְחָ֗ה אֶת ־ פָּנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "כִּֽי ־ הַ֭מֶּלֶךְ בֹּטֵ֣חַ בַּיהוָ֑ה וּבְחֶ֥סֶד עֶ֝לְי֗וֹן בַּל ־ יִמּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "תִּמְצָ֣א יָ֭דְךָ לְכָל ־ אֹיְבֶ֑יךָ יְ֝מִֽינְךָ תִּמְצָ֥א שֹׂנְאֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "תְּשִׁיתֵ֤מוֹ ׀ כְּתַנּ֥וּר אֵשׁ֮ לְעֵ֪ת פָּ֫נֶ֥יךָ יְ֭הוָה בְּאַפּ֣וֹ יְבַלְּעֵ֑ם וְֽתֹאכְלֵ֥ם אֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "פִּ֭רְיָמוֹ מֵאֶ֣רֶץ תְּאַבֵּ֑ד וְ֝זַרְעָ֗ם מִבְּנֵ֥י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "כִּי ־ נָט֣וּ עָלֶ֣יךָ רָעָ֑ה חָֽשְׁב֥וּ מְ֝זִמָּ֗ה בַּל ־ יוּכָֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "כִּ֭י תְּשִׁיתֵ֣מוֹ שֶׁ֑כֶם בְּ֝מֵֽיתָרֶ֗יךָ תְּכוֹנֵ֥ן עַל ־ פְּנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.21.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Psalms 21:14",
      "text": "ר֣וּמָה יְהוָ֣ה בְּעֻזֶּ֑ךָ נָשִׁ֥ירָה וּֽ֝נְזַמְּרָה גְּבוּרָתֶֽךָ ׃",
      "paragraphStart": false
    }
  ]
}
