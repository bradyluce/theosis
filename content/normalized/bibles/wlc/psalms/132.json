{
  "chapter": {
    "id": "wlc:psalms.132",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 132,
    "referenceLabel": "Psalms 132",
    "summary": "Source text for Psalms 132 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.132.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 1,
      "referenceLabel": "Psalms 132:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת זְכוֹר ־ יְהוָ֥ה לְדָוִ֑ד אֵ֝ת כָּל ־ עֻנּוֹתֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.132.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 2,
      "referenceLabel": "Psalms 132:2",
      "text": "אֲשֶׁ֣ר נִ֭שְׁבַּע לַיהוָ֑ה נָ֝דַ֗ר לַאֲבִ֥יר יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 3,
      "referenceLabel": "Psalms 132:3",
      "text": "אִם ־ אָ֭בֹא בְּאֹ֣הֶל בֵּיתִ֑י אִם ־ אֶ֝עֱלֶ֗ה עַל ־ עֶ֥רֶשׂ יְצוּעָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 4,
      "referenceLabel": "Psalms 132:4",
      "text": "אִם ־ אֶתֵּ֣ן שְׁנַ֣ת לְעֵינָ֑י לְֽעַפְעַפַּ֥י תְּנוּמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 5,
      "referenceLabel": "Psalms 132:5",
      "text": "עַד ־ אֶמְצָ֣א מָ֭קוֹם לַיהוָ֑ה מִ֝שְׁכָּנ֗וֹת לַאֲבִ֥יר יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 6,
      "referenceLabel": "Psalms 132:6",
      "text": "הִנֵּֽה ־ שְׁמַֽעֲנ֥וּהָ בְאֶפְרָ֑תָה מְ֝צָאנ֗וּהָ בִּשְׂדֵי ־ יָֽעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 7,
      "referenceLabel": "Psalms 132:7",
      "text": "נָב֥וֹאָה לְמִשְׁכְּנוֹתָ֑יו נִ֝שְׁתַּחֲוֶ֗ה לַהֲדֹ֥ם רַגְלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 8,
      "referenceLabel": "Psalms 132:8",
      "text": "קוּמָ֣ה יְ֭הוָה לִמְנוּחָתֶ֑ךָ אַ֝תָּ֗ה וַאֲר֥וֹן עֻזֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 9,
      "referenceLabel": "Psalms 132:9",
      "text": "כֹּהֲנֶ֥יךָ יִלְבְּשׁוּ ־ צֶ֑דֶק וַחֲסִידֶ֥יךָ יְרַנֵּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 10,
      "referenceLabel": "Psalms 132:10",
      "text": "בַּ֭עֲבוּר דָּוִ֣ד עַבְדֶּ֑ךָ אַל ־ תָּ֝שֵׁ֗ב פְּנֵ֣י מְשִׁיחֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 11,
      "referenceLabel": "Psalms 132:11",
      "text": "נִשְׁבַּֽע ־ יְהוָ֨ה ׀ לְדָוִ֡ד אֱמֶת֮ לֹֽא ־ יָשׁ֪וּב מִ֫מֶּ֥נָּה מִפְּרִ֥י בִטְנְךָ֑ אָ֝שִׁ֗ית לְכִסֵּא ־ לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 12,
      "referenceLabel": "Psalms 132:12",
      "text": "אִֽם ־ יִשְׁמְר֬וּ בָנֶ֨יךָ ׀ בְּרִיתִי֮ וְעֵדֹתִ֥י ז֗וֹ אֲלַ֫מְּדֵ֥ם גַּם ־ בְּנֵיהֶ֥ם עֲדֵי ־ עַ֑ד יֵ֝שְׁב֗וּ לְכִסֵּא ־ לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 13,
      "referenceLabel": "Psalms 132:13",
      "text": "כִּֽי ־ בָחַ֣ר יְהוָ֣ה בְּצִיּ֑וֹן אִ֝וָּ֗הּ לְמוֹשָׁ֥ב לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 14,
      "referenceLabel": "Psalms 132:14",
      "text": "זֹאת ־ מְנוּחָתִ֥י עֲדֵי ־ עַ֑ד פֹּֽה ־ אֵ֝שֵׁ֗ב כִּ֣י אִוִּתִֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 15,
      "referenceLabel": "Psalms 132:15",
      "text": "צֵ֭ידָהּ בָּרֵ֣ךְ אֲבָרֵ֑ךְ אֶ֝בְיוֹנֶ֗יהָ אַשְׂבִּ֥יעַֽ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 16,
      "referenceLabel": "Psalms 132:16",
      "text": "וְֽ֭כֹהֲנֶיהָ אַלְבִּ֣ישׁ יֶ֑שַׁע וַ֝חֲסִידֶ֗יהָ רַנֵּ֥ן יְרַנֵּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 17,
      "referenceLabel": "Psalms 132:17",
      "text": "שָׁ֤ם אַצְמִ֣יחַ קֶ֣רֶן לְדָוִ֑ד עָרַ֥כְתִּי נֵ֝֗ר לִמְשִׁיחִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.132.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 18,
      "referenceLabel": "Psalms 132:18",
      "text": "א֭וֹיְבָיו אַלְבִּ֣ישׁ בֹּ֑שֶׁת וְ֝עָלָ֗יו יָצִ֥יץ נִזְרֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
