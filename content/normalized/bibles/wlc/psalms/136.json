{
  "chapter": {
    "id": "wlc:psalms.136",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.136.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "הוֹד֣וּ לַיהוָ֣ה כִּי ־ ט֑וֹב כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.136.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "ה֭וֹדוּ לֵֽאלֹהֵ֣י הָאֱלֹהִ֑ים כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "ה֭וֹדוּ לַאֲדֹנֵ֣י הָאֲדֹנִ֑ים כִּ֖י לְעֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "לְעֹ֘שֵׂ֤ה נִפְלָא֣וֹת גְּדֹל֣וֹת לְבַדּ֑וֹ כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "לְעֹשֵׂ֣ה הַ֭שָּׁמַיִם בִּתְבוּנָ֑ה כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "לְרֹקַ֣ע הָ֭אָרֶץ עַל ־ הַמָּ֑יִם כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "לְ֭עֹשֵׂה אוֹרִ֣ים גְּדֹלִ֑ים כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "אֶת ־ הַ֭שֶּׁמֶשׁ לְמֶמְשֶׁ֣לֶת בַּיּ֑וֹם כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "אֶת ־ הַיָּרֵ֣חַ וְ֭כוֹכָבִים לְמֶמְשְׁל֣וֹת בַּלָּ֑יְלָה כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 10,
      "referenceLabel": "Psalms 136:10",
      "text": "לְמַכֵּ֣ה מִ֭צְרַיִם בִּבְכוֹרֵיהֶ֑ם כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 11,
      "referenceLabel": "Psalms 136:11",
      "text": "וַיּוֹצֵ֣א יִ֭שְׂרָאֵל מִתּוֹכָ֑ם כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 12,
      "referenceLabel": "Psalms 136:12",
      "text": "בְּיָ֣ד חֲ֭זָקָה וּבִזְר֣וֹעַ נְטוּיָ֑ה כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 13,
      "referenceLabel": "Psalms 136:13",
      "text": "לְגֹזֵ֣ר יַם ־ ס֭וּף לִגְזָרִ֑ים כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 14,
      "referenceLabel": "Psalms 136:14",
      "text": "וְהֶעֱבִ֣יר יִשְׂרָאֵ֣ל בְּתוֹכ֑וֹ כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 15,
      "referenceLabel": "Psalms 136:15",
      "text": "וְנִ֘עֵ֤ר פַּרְעֹ֣ה וְחֵיל֣וֹ בְיַם ־ ס֑וּף כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 16,
      "referenceLabel": "Psalms 136:16",
      "text": "לְמוֹלִ֣יךְ עַ֭מּוֹ בַּמִּדְבָּ֑ר כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 17,
      "referenceLabel": "Psalms 136:17",
      "text": "לְ֭מַכֵּה מְלָכִ֣ים גְּדֹלִ֑ים כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 18,
      "referenceLabel": "Psalms 136:18",
      "text": "וַֽ֭יַּהֲרֹג מְלָכִ֣ים אַדִּירִ֑ים כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 19,
      "referenceLabel": "Psalms 136:19",
      "text": "לְ֭סִיחוֹן מֶ֣לֶךְ הָאֱמֹרִ֑י כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 20,
      "referenceLabel": "Psalms 136:20",
      "text": "וּ֭לְעוֹג מֶ֣לֶךְ הַבָּשָׁ֑ן כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 21,
      "referenceLabel": "Psalms 136:21",
      "text": "וְנָתַ֣ן אַרְצָ֣ם לְנַחֲלָ֑ה כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 22,
      "referenceLabel": "Psalms 136:22",
      "text": "נַ֭חֲלָה לְיִשְׂרָאֵ֣ל עַבְדּ֑וֹ כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 23,
      "referenceLabel": "Psalms 136:23",
      "text": "שֶׁ֭בְּשִׁפְלֵנוּ זָ֣כַר לָ֑נוּ כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 24,
      "referenceLabel": "Psalms 136:24",
      "text": "וַיִּפְרְקֵ֥נוּ מִצָּרֵ֑ינוּ כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 25,
      "referenceLabel": "Psalms 136:25",
      "text": "נֹתֵ֣ן לֶ֭חֶם לְכָל ־ בָּשָׂ֑ר כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.136.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 26,
      "referenceLabel": "Psalms 136:26",
      "text": "ה֭וֹדוּ לְאֵ֣ל הַשָּׁמָ֑יִם כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
