{
  "chapter": {
    "id": "wlc:psalms.57",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 57,
    "referenceLabel": "Psalms 57",
    "summary": "Source text for Psalms 57 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.57.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 1,
      "referenceLabel": "Psalms 57:1",
      "text": "לַמְנַצֵּ֣חַ אַל ־ תַּ֭שְׁחֵת לְדָוִ֣ד מִכְתָּ֑ם בְּבָרְח֥וֹ מִפְּנֵי ־ שָׁ֝א֗וּל בַּמְּעָרָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.57.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 2,
      "referenceLabel": "Psalms 57:2",
      "text": "חָנֵּ֤נִי אֱלֹהִ֨ים ׀ חָנֵּ֗נִי כִּ֥י בְךָ֮ חָסָ֪יָה נַ֫פְשִׁ֥י וּבְצֵֽל ־ כְּנָפֶ֥יךָ אֶחְסֶ֑ה עַ֝֗ד יַעֲבֹ֥ר הַוּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 3,
      "referenceLabel": "Psalms 57:3",
      "text": "אֶ֭קְרָא לֵֽאלֹהִ֣ים עֶלְי֑וֹן לָ֝אֵ֗ל גֹּמֵ֥ר עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 4,
      "referenceLabel": "Psalms 57:4",
      "text": "יִשְׁלַ֤ח מִשָּׁמַ֨יִם ׀ וְֽיוֹשִׁיעֵ֗נִי חֵרֵ֣ף שֹׁאֲפִ֣י סֶ֑לָה יִשְׁלַ֥ח אֱ֝לֹהִ֗ים חַסְדּ֥וֹ וַאֲמִתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 5,
      "referenceLabel": "Psalms 57:5",
      "text": "נַפְשִׁ֤י ׀ בְּת֥וֹךְ לְבָאִם֮ אֶשְׁכְּבָ֪ה לֹ֫הֲטִ֥ים בְּֽנֵי ־ אָדָ֗ם שִׁ֭נֵּיהֶם חֲנִ֣ית וְחִצִּ֑ים וּ֝לְשׁוֹנָ֗ם חֶ֣רֶב חַדָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 6,
      "referenceLabel": "Psalms 57:6",
      "text": "ר֣וּמָה עַל ־ הַשָּׁמַ֣יִם אֱלֹהִ֑ים עַ֖ל כָּל ־ הָאָ֣רֶץ כְּבוֹדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 7,
      "referenceLabel": "Psalms 57:7",
      "text": "רֶ֤שֶׁת ׀ הֵכִ֣ינוּ לִפְעָמַי֮ כָּפַ֪ף נַ֫פְשִׁ֥י כָּר֣וּ לְפָנַ֣י שִׁיחָ֑ה נָפְל֖וּ בְתוֹכָ֣הּ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 8,
      "referenceLabel": "Psalms 57:8",
      "text": "נָ֘כ֤וֹן לִבִּ֣י אֱ֭לֹהִים נָכ֣וֹן לִבִּ֑י אָ֝שִׁ֗ירָה וַאֲזַמֵּֽרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 9,
      "referenceLabel": "Psalms 57:9",
      "text": "ע֤וּרָה כְבוֹדִ֗י ע֭וּרָֽה הַנֵּ֥בֶל וְכִנּ֗וֹר אָעִ֥ירָה שָּֽׁחַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 10,
      "referenceLabel": "Psalms 57:10",
      "text": "אוֹדְךָ֖ בָעַמִּ֥ים ׀ אֲדֹנָ֑י אֲ֝זַמֶּרְךָ֗ בַּל ־ אֻמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 11,
      "referenceLabel": "Psalms 57:11",
      "text": "כִּֽי ־ גָדֹ֣ל עַד ־ שָׁמַ֣יִם חַסְדֶּ֑ךָ וְֽעַד ־ שְׁחָקִ֥ים אֲמִתֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.57.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 12,
      "referenceLabel": "Psalms 57:12",
      "text": "ר֣וּמָה עַל ־ שָׁמַ֣יִם אֱלֹהִ֑ים עַ֖ל כָּל ־ הָאָ֣רֶץ כְּבוֹדֶֽךָ ׃",
      "paragraphStart": false
    }
  ]
}
