{
  "chapter": {
    "id": "wlc:psalms.99",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 99,
    "referenceLabel": "Psalms 99",
    "summary": "Source text for Psalms 99 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.99.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "יְהוָ֣ה מָ֭לָךְ יִרְגְּז֣וּ עַמִּ֑ים יֹשֵׁ֥ב כְּ֝רוּבִ֗ים תָּנ֥וּט הָאָֽרֶץ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.99.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "יְ֭הוָה בְּצִיּ֣וֹן גָּד֑וֹל וְרָ֥ם ה֝֗וּא עַל ־ כָּל ־ הָֽעַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "יוֹד֣וּ שִׁ֭מְךָ גָּד֥וֹל וְנוֹרָ֗א קָד֥וֹשׁ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "וְעֹ֥ז מֶלֶךְ֮ מִשְׁפָּ֪ט אָ֫הֵ֥ב אַ֭תָּה כּוֹנַ֣נְתָּ מֵישָׁרִ֑ים מִשְׁפָּ֥ט וּ֝צְדָקָ֗ה בְּיַעֲקֹ֤ב ׀ אַתָּ֬ה עָשִֽׂיתָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "רֽוֹמְמ֡וּ יְה֘וָ֤ה אֱלֹהֵ֗ינוּ וְֽ֭הִשְׁתַּחֲווּ לַהֲדֹ֥ם רַגְלָ֗יו קָד֥וֹשׁ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 6,
      "referenceLabel": "Psalms 99:6",
      "text": "מֹ֘שֶׁ֤ה וְאַהֲרֹ֨ן ׀ בְּֽכֹהֲנָ֗יו וּ֭שְׁמוּאֵל בְּקֹרְאֵ֣י שְׁמ֑וֹ קֹרִ֥אים אֶל ־ יְ֝הוָ֗ה וְה֣וּא יַעֲנֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 7,
      "referenceLabel": "Psalms 99:7",
      "text": "בְּעַמּ֣וּד עָ֭נָן יְדַבֵּ֣ר אֲלֵיהֶ֑ם שָׁמְר֥וּ עֵ֝דֹתָ֗יו וְחֹ֣ק נָֽתַן ־ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 8,
      "referenceLabel": "Psalms 99:8",
      "text": "יְהוָ֣ה אֱלֹהֵינוּ֮ אַתָּ֪ה עֲנִ֫יתָ֥ם אֵ֣ל נֹ֭שֵׂא הָיִ֣יתָ לָהֶ֑ם וְ֝נֹקֵ֗ם עַל ־ עֲלִילוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.99.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 9,
      "referenceLabel": "Psalms 99:9",
      "text": "רֽוֹמְמ֡וּ יְה֘וָ֤ה אֱלֹהֵ֗ינוּ וְ֭הִֽשְׁתַּחֲווּ לְהַ֣ר קָדְשׁ֑וֹ כִּֽי ־ קָ֝ד֗וֹשׁ יְהוָ֥ה אֱלֹהֵֽינוּ ׃",
      "paragraphStart": false
    }
  ]
}
