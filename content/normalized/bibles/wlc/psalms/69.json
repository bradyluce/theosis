{
  "chapter": {
    "id": "wlc:psalms.69",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.69.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "לַמְנַצֵּ֬חַ עַֽל ־ שׁוֹשַׁנִּ֬ים לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.69.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "הוֹשִׁיעֵ֥נִי אֱלֹהִ֑ים כִּ֤י בָ֖אוּ מַ֣יִם עַד ־ נָֽפֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "טָבַ֤עְתִּי ׀ בִּיוֵ֣ן מְ֭צוּלָה וְאֵ֣ין מָעֳמָ֑ד בָּ֥אתִי בְמַעֲמַקֵּי ־ מַ֝֗יִם וְשִׁבֹּ֥לֶת שְׁטָפָֽתְנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "יָגַ֣עְתִּי בְקָרְאִי֮ נִחַ֪ר גְּר֫וֹנִ֥י כָּל֥וּ עֵינַ֑י מְ֝יַחֵ֗ל לֵאלֹהָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "רַבּ֤וּ ׀ מִשַּׂעֲר֣וֹת רֹאשִׁי֮ שֹׂנְאַ֪י חִ֫נָּ֥ם עָצְמ֣וּ מַ֭צְמִיתַי אֹיְבַ֣י שֶׁ֑קֶר אֲשֶׁ֥ר לֹא ־ גָ֝זַ֗לְתִּי אָ֣ז אָשִֽׁיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "אֱֽלֹהִ֗ים אַתָּ֣ה יָ֭דַעְתָּ לְאִוַּלְתִּ֑י וְ֝אַשְׁמוֹתַ֗י מִמְּךָ֥ לֹא ־ נִכְחָֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 7,
      "referenceLabel": "Psalms 69:7",
      "text": "אַל ־ יֵ֘בֹ֤שׁוּ בִ֨י ׀ קֹוֶיךָ֮ אֲדֹנָ֥י יְהוִ֗ה צְבָ֫א֥וֹת אַל ־ יִכָּ֣לְמוּ בִ֣י מְבַקְשֶׁ֑יךָ אֱ֝לֹהֵ֗י יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 8,
      "referenceLabel": "Psalms 69:8",
      "text": "כִּֽי ־ עָ֭לֶיךָ נָשָׂ֣אתִי חֶרְפָּ֑ה כִּסְּתָ֖ה כְלִמָּ֣ה פָנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 9,
      "referenceLabel": "Psalms 69:9",
      "text": "מ֭וּזָר הָיִ֣יתִי לְאֶחָ֑י וְ֝נָכְרִ֗י לִבְנֵ֥י אִמִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 10,
      "referenceLabel": "Psalms 69:10",
      "text": "כִּֽי ־ קִנְאַ֣ת בֵּיתְךָ֣ אֲכָלָ֑תְנִי וְחֶרְפּ֥וֹת ח֝וֹרְפֶ֗יךָ נָפְל֥וּ עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 11,
      "referenceLabel": "Psalms 69:11",
      "text": "וָאֶבְכֶּ֣ה בַצּ֣וֹם נַפְשִׁ֑י וַתְּהִ֖י לַחֲרָפ֣וֹת לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 12,
      "referenceLabel": "Psalms 69:12",
      "text": "וָאֶתְּנָ֣ה לְבוּשִׁ֣י שָׂ֑ק וָאֱהִ֖י לָהֶ֣ם לְמָשָֽׁל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 13,
      "referenceLabel": "Psalms 69:13",
      "text": "יָשִׂ֣יחוּ בִ֭י יֹ֣שְׁבֵי שָׁ֑עַר וּ֝נְגִינ֗וֹת שׁוֹתֵ֥י שֵׁכָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 14,
      "referenceLabel": "Psalms 69:14",
      "text": "וַאֲנִ֤י תְפִלָּתִֽי ־ לְךָ֨ ׀ יְהוָ֡ה עֵ֤ת רָצ֗וֹן אֱלֹהִ֥ים בְּרָב ־ חַסְדֶּ֑ךָ עֲ֝נֵ֗נִי בֶּאֱמֶ֥ת יִשְׁעֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 15,
      "referenceLabel": "Psalms 69:15",
      "text": "הַצִּילֵ֣נִי מִ֭טִּיט וְאַל ־ אֶטְבָּ֑עָה אִנָּצְלָ֥ה מִ֝שֹּֽׂנְאַ֗י וּמִמַּֽעֲמַקֵּי ־ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 16,
      "referenceLabel": "Psalms 69:16",
      "text": "אַל ־ תִּשְׁטְפֵ֤נִי ׀ שִׁבֹּ֣לֶת מַ֭יִם וְאַל ־ תִּבְלָעֵ֣נִי מְצוּלָ֑ה וְאַל ־ תֶּאְטַר ־ עָלַ֖י בְּאֵ֣ר פִּֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 17,
      "referenceLabel": "Psalms 69:17",
      "text": "עֲנֵ֣נִי יְ֭הוָה כִּי ־ ט֣וֹב חַסְדֶּ֑ךָ כְּרֹ֥ב רַ֝חֲמֶ֗יךָ פְּנֵ֣ה אֵלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 18,
      "referenceLabel": "Psalms 69:18",
      "text": "וְאַל ־ תַּסְתֵּ֣ר פָּ֭נֶיךָ מֵֽעַבְדֶּ֑ךָ כִּֽי ־ צַר ־ לִ֝֗י מַהֵ֥ר עֲנֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 19,
      "referenceLabel": "Psalms 69:19",
      "text": "קָרְבָ֣ה אֶל ־ נַפְשִׁ֣י גְאָלָ֑הּ לְמַ֖עַן אֹיְבַ֣י פְּדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 20,
      "referenceLabel": "Psalms 69:20",
      "text": "אַתָּ֤ה יָדַ֗עְתָּ חֶרְפָּתִ֣י וּ֭בָשְׁתִּי וּכְלִמָּתִ֑י נֶ֝גְדְּךָ֗ כָּל ־ צוֹרְרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 21,
      "referenceLabel": "Psalms 69:21",
      "text": "חֶרְפָּ֤ה ׀ שָֽׁבְרָ֥ה לִבִּ֗י וָֽאָ֫נ֥וּשָׁה וָאֲקַוֶּ֣ה לָנ֣וּד וָאַ֑יִן וְ֝לַמְנַחֲמִ֗ים וְלֹ֣א מָצָֽאתִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 22,
      "referenceLabel": "Psalms 69:22",
      "text": "וַיִּתְּנ֣וּ בְּבָרוּתִ֣י רֹ֑אשׁ וְ֝לִצְמָאִ֗י יַשְׁק֥וּנִי חֹֽמֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 23,
      "referenceLabel": "Psalms 69:23",
      "text": "יְהִֽי ־ שֻׁלְחָנָ֣ם לִפְנֵיהֶ֣ם לְפָ֑ח וְלִשְׁלוֹמִ֥ים לְמוֹקֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 24,
      "referenceLabel": "Psalms 69:24",
      "text": "תֶּחְשַׁ֣כְנָה עֵ֭ינֵיהֶם מֵרְא֑וֹת וּ֝מָתְנֵ֗יהֶם תָּמִ֥יד הַמְעַֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 25,
      "referenceLabel": "Psalms 69:25",
      "text": "שְׁפָךְ ־ עֲלֵיהֶ֥ם זַעְמֶ֑ךָ וַחֲר֥וֹן אַ֝פְּךָ֗ יַשִּׂיגֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 26,
      "referenceLabel": "Psalms 69:26",
      "text": "תְּהִי ־ טִֽירָתָ֥ם נְשַׁמָּ֑ה בְּ֝אָהֳלֵיהֶ֗ם אַל ־ יְהִ֥י יֹשֵֽׁב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 27,
      "referenceLabel": "Psalms 69:27",
      "text": "כִּֽי ־ אַתָּ֣ה אֲשֶׁר ־ הִכִּ֣יתָ רָדָ֑פוּ וְאֶל ־ מַכְא֖וֹב חֲלָלֶ֣יךָ יְסַפֵּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 28,
      "referenceLabel": "Psalms 69:28",
      "text": "תְּֽנָה ־ עָ֭וֺן עַל ־ עֲוֺנָ֑ם וְאַל ־ יָ֝בֹ֗אוּ בְּצִדְקָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 29,
      "referenceLabel": "Psalms 69:29",
      "text": "יִ֭מָּחֽוּ מִסֵּ֣פֶר חַיִּ֑ים וְעִ֥ם צַ֝דִּיקִ֗ים אַל ־ יִכָּתֵֽבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 30,
      "referenceLabel": "Psalms 69:30",
      "text": "וַ֭אֲנִי עָנִ֣י וְכוֹאֵ֑ב יְשׁוּעָתְךָ֖ אֱלֹהִ֣ים תְּשַׂגְּבֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 31,
      "referenceLabel": "Psalms 69:31",
      "text": "אֲהַֽלְלָ֣ה שֵׁם ־ אֱלֹהִ֣ים בְּשִׁ֑יר וַאֲגַדְּלֶ֥נּוּ בְתוֹדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 32,
      "referenceLabel": "Psalms 69:32",
      "text": "וְתִיטַ֣ב לַֽ֭יהוָה מִשּׁ֥וֹר פָּ֗ר מַקְרִ֥ן מַפְרִֽיס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 33,
      "referenceLabel": "Psalms 69:33",
      "text": "רָא֣וּ עֲנָוִ֣ים יִשְׂמָ֑חוּ דֹּרְשֵׁ֥י אֱ֝לֹהִ֗ים וִיחִ֥י לְבַבְכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 34,
      "referenceLabel": "Psalms 69:34",
      "text": "כִּֽי ־ שֹׁמֵ֣עַ אֶל ־ אֶבְיוֹנִ֣ים יְהוָ֑ה וְאֶת ־ אֲ֝סִירָ֗יו לֹ֣א בָזָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 35,
      "referenceLabel": "Psalms 69:35",
      "text": "יְֽ֭הַלְלוּהוּ שָׁמַ֣יִם וָאָ֑רֶץ יַ֝מִּ֗ים וְֽכָל ־ רֹמֵ֥שׂ בָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 36,
      "referenceLabel": "Psalms 69:36",
      "text": "כִּ֤י אֱלֹהִ֨ים ׀ י֘וֹשִׁ֤יעַ צִיּ֗וֹן וְ֭יִבְנֶה עָרֵ֣י יְהוּדָ֑ה וְיָ֥שְׁבוּ שָׁ֝֗ם וִירֵשֽׁוּהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.69.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 37,
      "referenceLabel": "Psalms 69:37",
      "text": "וְזֶ֣רַע עֲ֭בָדָיו יִנְחָל֑וּהָ וְאֹהֲבֵ֥י שְׁ֝מ֗וֹ יִשְׁכְּנוּ ־ בָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
