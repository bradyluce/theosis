{
  "chapter": {
    "id": "wlc:psalms.115",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.115.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "לֹ֤א לָ֥נוּ יְהוָ֗ה לֹ֫א לָ֥נוּ כִּֽי ־ לְ֭שִׁמְךָ תֵּ֣ן כָּב֑וֹד עַל ־ חַ֝סְדְּךָ֗ עַל ־ אֲמִתֶּֽךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.115.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "לָ֭מָּה יֹאמְר֣וּ הַגּוֹיִ֑ם אַיֵּה ־ נָ֝֗א אֱלֹהֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "וֵֽאלֹהֵ֥ינוּ בַשָּׁמָ֑יִם כֹּ֭ל אֲשֶׁר ־ חָפֵ֣ץ עָשָֽׂה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "עֲֽ֭צַבֵּיהֶם כֶּ֣סֶף וְזָהָ֑ב מַ֝עֲשֵׂ֗ה יְדֵ֣י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "פֶּֽה ־ לָ֭הֶם וְלֹ֣א יְדַבֵּ֑רוּ עֵינַ֥יִם לָ֝הֶ֗ם וְלֹ֣א יִרְאֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "אָזְנַ֣יִם לָ֭הֶם וְלֹ֣א יִשְׁמָ֑עוּ אַ֥ף לָ֝הֶ֗ם וְלֹ֣א יְרִיחֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "יְדֵיהֶ֤ם ׀ וְלֹ֬א יְמִישׁ֗וּן רַ֭גְלֵיהֶם וְלֹ֣א יְהַלֵּ֑כוּ לֹֽא ־ יֶ֝הְגּ֗וּ בִּגְרוֹנָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "כְּ֭מוֹהֶם יִהְי֣וּ עֹשֵׂיהֶ֑ם כֹּ֭ל אֲשֶׁר ־ בֹּטֵ֣חַ בָּהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "יִ֭שְׂרָאֵל בְּטַ֣ח בַּיהוָ֑ה עֶזְרָ֖ם וּמָגִנָּ֣ם הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "בֵּ֣ית אַ֭הֲרֹן בִּטְח֣וּ בַיהוָ֑ה עֶזְרָ֖ם וּמָגִנָּ֣ם הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 11,
      "referenceLabel": "Psalms 115:11",
      "text": "יִרְאֵ֣י יְ֭הוָה בִּטְח֣וּ בַיהוָ֑ה עֶזְרָ֖ם וּמָגִנָּ֣ם הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 12,
      "referenceLabel": "Psalms 115:12",
      "text": "יְהוָה֮ זְכָרָ֪נוּ יְבָ֫רֵ֥ךְ יְ֭בָרֵךְ אֶת ־ בֵּ֣ית יִשְׂרָאֵ֑ל יְ֝בָרֵ֗ךְ אֶת ־ בֵּ֥ית אַהֲרֹֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 13,
      "referenceLabel": "Psalms 115:13",
      "text": "יְ֭בָרֵךְ יִרְאֵ֣י יְהוָ֑ה הַ֝קְּטַנִּ֗ים עִם ־ הַגְּדֹלִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 14,
      "referenceLabel": "Psalms 115:14",
      "text": "יֹסֵ֣ף יְהוָ֣ה עֲלֵיכֶ֑ם עֲ֝לֵיכֶ֗ם וְעַל ־ בְּנֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 15,
      "referenceLabel": "Psalms 115:15",
      "text": "בְּרוּכִ֣ים אַ֭תֶּם לַיהוָ֑ה עֹ֝שֵׂ֗ה שָׁמַ֥יִם וָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 16,
      "referenceLabel": "Psalms 115:16",
      "text": "הַשָּׁמַ֣יִם שָׁ֭מַיִם לַיהוָ֑ה וְ֝הָאָ֗רֶץ נָתַ֥ן לִבְנֵי ־ אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 17,
      "referenceLabel": "Psalms 115:17",
      "text": "לֹ֣א הַ֭מֵּתִים יְהַֽלְלוּ ־ יָ֑הּ וְ֝לֹ֗א כָּל ־ יֹרְדֵ֥י דוּמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.115.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 18,
      "referenceLabel": "Psalms 115:18",
      "text": "וַאֲנַ֤חְנוּ ׀ נְבָ֘רֵ֤ךְ יָ֗הּ מֵֽעַתָּ֥ה וְעַד ־ עוֹלָ֗ם הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
