{
  "chapter": {
    "id": "wlc:psalms.56",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 56,
    "referenceLabel": "Psalms 56",
    "summary": "Source text for Psalms 56 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.56.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 1,
      "referenceLabel": "Psalms 56:1",
      "text": "לַמְנַצֵּ֤חַ ׀ עַל ־ י֬וֹנַת אֵ֣לֶם רְ֭חֹקִים לְדָוִ֣ד מִכְתָּ֑ם בֶּֽאֱחֹ֨ז אֹת֖וֹ פְלִשְׁתִּ֣ים בְּגַֽת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.56.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 2,
      "referenceLabel": "Psalms 56:2",
      "text": "חָנֵּ֣נִי אֱ֭לֹהִים כִּֽי ־ שְׁאָפַ֣נִי אֱנ֑וֹשׁ כָּל ־ הַ֝יּ֗וֹם לֹחֵ֥ם יִלְחָצֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 3,
      "referenceLabel": "Psalms 56:3",
      "text": "שָׁאֲפ֣וּ שׁ֭וֹרְרַי כָּל ־ הַיּ֑וֹם כִּֽי ־ רַבִּ֨ים לֹחֲמִ֖ים לִ֣י מָרֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 4,
      "referenceLabel": "Psalms 56:4",
      "text": "י֥וֹם אִירָ֑א אֲ֝נִ֗י אֵלֶ֥יךָ אֶבְטָֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 5,
      "referenceLabel": "Psalms 56:5",
      "text": "בֵּאלֹהִים֮ אֲהַלֵּ֪ל דְּבָ֫ר֥וֹ בֵּאלֹהִ֣ים בָּ֭טַחְתִּי לֹ֣א אִירָ֑א מַה ־ יַּעֲשֶׂ֖ה בָשָׂ֣ר לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 6,
      "referenceLabel": "Psalms 56:6",
      "text": "כָּל ־ הַ֭יּוֹם דְּבָרַ֣י יְעַצֵּ֑בוּ עָלַ֖י כָּל ־ מַחְשְׁבֹתָ֣ם לָרָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 7,
      "referenceLabel": "Psalms 56:7",
      "text": "יָג֤וּרוּ ׀ יצפינו הֵ֭מָּה עֲקֵבַ֣י יִשְׁמֹ֑רוּ כַּ֝אֲשֶׁ֗ר קִוּ֥וּ נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 8,
      "referenceLabel": "Psalms 56:8",
      "text": "עַל ־ אָ֥וֶן פַּלֶּט ־ לָ֑מוֹ בְּ֝אַ֗ף עַמִּ֤ים ׀ הוֹרֵ֬ד אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 9,
      "referenceLabel": "Psalms 56:9",
      "text": "נֹדִי֮ סָפַ֪רְתָּ֫ה אָ֥תָּה שִׂ֣ימָה דִמְעָתִ֣י בְנֹאדֶ֑ךָ הֲ֝לֹ֗א בְּסִפְרָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 10,
      "referenceLabel": "Psalms 56:10",
      "text": "אָ֥֨ז יָ֘שׁ֤וּבוּ אוֹיְבַ֣י אָ֭חוֹר בְּי֣וֹם אֶקְרָ֑א זֶה ־ יָ֝דַ֗עְתִּי כִּֽי ־ אֱלֹהִ֥ים לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 11,
      "referenceLabel": "Psalms 56:11",
      "text": "בֵּֽ֭אלֹהִים אֲהַלֵּ֣ל דָּבָ֑ר בַּ֝יהוָ֗ה אֲהַלֵּ֥ל דָּבָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 12,
      "referenceLabel": "Psalms 56:12",
      "text": "בֵּֽאלֹהִ֣ים בָּ֭טַחְתִּי לֹ֣א אִירָ֑א מַה ־ יַּעֲשֶׂ֖ה אָדָ֣ם לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 13,
      "referenceLabel": "Psalms 56:13",
      "text": "עָלַ֣י אֱלֹהִ֣ים נְדָרֶ֑יךָ אֲשַׁלֵּ֖ם תּוֹדֹ֣ת לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.56.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 14,
      "referenceLabel": "Psalms 56:14",
      "text": "כִּ֤י הִצַּ֪לְתָּ נַפְשִׁ֡י מִמָּוֶת֮ הֲלֹ֥א רַגְלַ֗י מִ֫דֶּ֥חִי לְ֭הִֽתְהַלֵּךְ לִפְנֵ֣י אֱלֹהִ֑ים בְּ֝א֗וֹר הַֽחַיִּֽים ׃",
      "paragraphStart": false
    }
  ]
}
