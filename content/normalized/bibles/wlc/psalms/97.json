{
  "chapter": {
    "id": "wlc:psalms.97",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.97.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "יְהוָ֣ה מָ֭לָךְ תָּגֵ֣ל הָאָ֑רֶץ יִ֝שְׂמְח֗וּ אִיִּ֥ים רַבִּֽים ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.97.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "עָנָ֣ן וַעֲרָפֶ֣ל סְבִיבָ֑יו צֶ֥דֶק וּ֝מִשְׁפָּ֗ט מְכ֣וֹן כִּסְאֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "אֵ֭שׁ לְפָנָ֣יו תֵּלֵ֑ךְ וּתְלַהֵ֖ט סָבִ֣יב צָרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "הֵאִ֣ירוּ בְרָקָ֣יו תֵּבֵ֑ל רָאֲתָ֖ה וַתָּחֵ֣ל הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "הָרִ֗ים כַּדּוֹנַ֗ג נָ֭מַסּוּ מִלִּפְנֵ֣י יְהוָ֑ה מִ֝לִּפְנֵ֗י אֲד֣וֹן כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "הִגִּ֣ידוּ הַשָּׁמַ֣יִם צִדְק֑וֹ וְרָא֖וּ כָל ־ הָעַמִּ֣ים כְּבוֹדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "יֵבֹ֤שׁוּ ׀ כָּל ־ עֹ֬בְדֵי פֶ֗סֶל הַמִּֽתְהַלְלִ֥ים בָּאֱלִילִ֑ים הִשְׁתַּחֲווּ ־ ל֝וֹ כָּל ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "שָׁמְעָ֬ה וַתִּשְׂמַ֨ח ׀ צִיּ֗וֹן וַ֭תָּגֵלְנָה בְּנ֣וֹת יְהוּדָ֑ה לְמַ֖עַן מִשְׁפָּטֶ֣יךָ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "כִּֽי ־ אַתָּ֤ה יְהוָ֗ה עֶלְי֥וֹן עַל ־ כָּל ־ הָאָ֑רֶץ מְאֹ֥ד נַ֝עֲלֵ֗יתָ עַל ־ כָּל ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 10,
      "referenceLabel": "Psalms 97:10",
      "text": "אֹהֲבֵ֥י יְהוָ֗ה שִׂנְא֫וּ רָ֥ע שֹׁ֭מֵר נַפְשׁ֣וֹת חֲסִידָ֑יו מִיַּ֥ד רְ֝שָׁעִ֗ים יַצִּילֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 11,
      "referenceLabel": "Psalms 97:11",
      "text": "א֭וֹר זָרֻ֣עַ לַצַּדִּ֑יק וּֽלְיִשְׁרֵי ־ לֵ֥ב שִׂמְחָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.97.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 12,
      "referenceLabel": "Psalms 97:12",
      "text": "שִׂמְח֣וּ צַ֭דִּיקִים בַּֽיהוָ֑ה וְ֝הוֹד֗וּ לְזֵ֣כֶר קָדְשֽׁוֹ ׃",
      "paragraphStart": false
    }
  ]
}
