{
  "chapter": {
    "id": "wlc:psalms.25",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.25.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "לְדָוִ֡ד אֵלֶ֥יךָ יְ֝הוָ֗ה נַפְשִׁ֥י אֶשָּֽׂא ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.25.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "אֱֽלֹהַ֗י בְּךָ֣ בָ֭טַחְתִּי אַל ־ אֵב֑וֹשָׁה אַל ־ יַֽעַלְצ֖וּ אֹיְבַ֣י לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "גַּ֣ם כָּל ־ קֹ֭וֶיךָ לֹ֣א יֵבֹ֑שׁוּ יֵ֝בֹ֗שׁוּ הַבּוֹגְדִ֥ים רֵיקָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "דְּרָכֶ֣יךָ יְ֭הוָה הוֹדִיעֵ֑נִי אֹ֖רְחוֹתֶ֣יךָ לַמְּדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "הַדְרִ֘יכֵ֤נִי בַאֲמִתֶּ֨ךָ ׀ וְֽלַמְּדֵ֗נִי כִּֽי ־ אַ֭תָּה אֱלֹהֵ֣י יִשְׁעִ֑י אוֹתְךָ֥ קִ֝וִּ֗יתִי כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "זְכֹר ־ רַחֲמֶ֣יךָ יְ֭הוָה וַחֲסָדֶ֑יךָ כִּ֖י מֵעוֹלָ֣ם הֵֽמָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "חַטֹּ֤אות נְעוּרַ֨י ׀ וּפְשָׁעַ֗י אַל ־ תִּ֫זְכֹּ֥ר כְּחַסְדְּךָ֥ זְכָר ־ לִי ־ אַ֑תָּה לְמַ֖עַן טוּבְךָ֣ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "טוֹב ־ וְיָשָׁ֥ר יְהוָ֑ה עַל ־ כֵּ֤ן יוֹרֶ֖ה חַטָּאִ֣ים בַּדָּֽרֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "יַדְרֵ֣ךְ עֲ֭נָוִים בַּמִּשְׁפָּ֑ט וִֽילַמֵּ֖ד עֲנָוִ֣ים דַּרְכּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "כָּל ־ אָרְח֣וֹת יְ֭הוָה חֶ֣סֶד וֶאֱמֶ֑ת לְנֹצְרֵ֥י בְ֝רִית֗וֹ וְעֵדֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "לְמַֽעַן ־ שִׁמְךָ֥ יְהוָ֑ה וְֽסָלַחְתָּ֥ לַ֝עֲוֺנִ֗י כִּ֣י רַב ־ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "מִי ־ זֶ֣ה הָ֭אִישׁ יְרֵ֣א יְהוָ֑ה י֝וֹרֶ֗נּוּ בְּדֶ֣רֶךְ יִבְחָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Psalms 25:13",
      "text": "נַ֭פְשׁוֹ בְּט֣וֹב תָּלִ֑ין וְ֝זַרְע֗וֹ יִ֣ירַשׁ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Psalms 25:14",
      "text": "ס֣וֹד יְ֭הוָה לִירֵאָ֑יו וּ֝בְרִית֗וֹ לְהוֹדִיעָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Psalms 25:15",
      "text": "עֵינַ֣י תָּ֭מִיד אֶל ־ יְהוָ֑ה כִּ֤י הֽוּא ־ יוֹצִ֖יא מֵרֶ֣שֶׁת רַגְלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Psalms 25:16",
      "text": "פְּנֵה ־ אֵלַ֥י וְחָנֵּ֑נִי כִּֽי ־ יָחִ֖יד וְעָנִ֣י אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Psalms 25:17",
      "text": "צָר֣וֹת לְבָבִ֣י הִרְחִ֑יבוּ מִ֝מְּצֽוּקוֹתַ֗י הוֹצִיאֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Psalms 25:18",
      "text": "רְאֵ֣ה עָ֭נְיִי וַעֲמָלִ֑י וְ֝שָׂ֗א לְכָל ־ חַטֹּאותָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Psalms 25:19",
      "text": "רְאֵֽה ־ אוֹיְבַ֥י כִּי ־ רָ֑בּוּ וְשִׂנְאַ֖ת חָמָ֣ס שְׂנֵאֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Psalms 25:20",
      "text": "שָׁמְרָ֣ה נַ֭פְשִׁי וְהַצִּילֵ֑נִי אַל ־ אֵ֝ב֗וֹשׁ כִּֽי ־ חָסִ֥יתִי בָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Psalms 25:21",
      "text": "תֹּם ־ וָיֹ֥שֶׁר יִצְּר֑וּנִי כִּ֝֗י קִוִּיתִֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.25.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Psalms 25:22",
      "text": "פְּדֵ֣ה אֱ֭לֹהִים אֶת ־ יִשְׂרָאֵ֑ל מִ֝כֹּ֗ל צָֽרוֹתָיו ׃",
      "paragraphStart": false
    }
  ]
}
