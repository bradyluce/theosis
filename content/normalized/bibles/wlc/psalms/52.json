{
  "chapter": {
    "id": "wlc:psalms.52",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 52,
    "referenceLabel": "Psalms 52",
    "summary": "Source text for Psalms 52 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.52.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 1,
      "referenceLabel": "Psalms 52:1",
      "text": "לַמְנַצֵּ֗חַ מַשְׂכִּ֥יל לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.52.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 2,
      "referenceLabel": "Psalms 52:2",
      "text": "בְּב֤וֹא ׀ דּוֹאֵ֣ג הָאֲדֹמִי֮ וַיַּגֵּ֪ד לְשָׁ֫א֥וּל וַיֹּ֥אמֶר ל֑וֹ בָּ֥א דָ֝וִ֗ד אֶל ־ בֵּ֥ית אֲחִימֶֽלֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 3,
      "referenceLabel": "Psalms 52:3",
      "text": "מַה ־ תִּתְהַלֵּ֣ל בְּ֭רָעָה הַגִּבּ֑וֹר חֶ֥סֶד אֵ֝֗ל כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 4,
      "referenceLabel": "Psalms 52:4",
      "text": "הַ֭וּוֹת תַּחְשֹׁ֣ב לְשׁוֹנֶ֑ךָ כְּתַ֥עַר מְ֝לֻטָּ֗שׁ עֹשֵׂ֥ה רְמִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 5,
      "referenceLabel": "Psalms 52:5",
      "text": "אָהַ֣בְתָּ רָּ֣ע מִטּ֑וֹב שֶׁ֓קֶר ׀ מִדַּבֵּ֖ר צֶ֣דֶק סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 6,
      "referenceLabel": "Psalms 52:6",
      "text": "אָהַ֥בְתָּ כָֽל ־ דִּבְרֵי ־ בָ֗לַע לְשׁ֣וֹן מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 7,
      "referenceLabel": "Psalms 52:7",
      "text": "גַּם ־ אֵל֮ יִתָּצְךָ֪ לָ֫נֶ֥צַח יַחְתְּךָ֣ וְיִסָּחֲךָ֣ מֵאֹ֑הֶל וְשֵֽׁרֶשְׁךָ֨ מֵאֶ֖רֶץ חַיִּ֣ים סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 8,
      "referenceLabel": "Psalms 52:8",
      "text": "וְיִרְא֖וּ צַדִּיקִ֥ים וְיִירָ֗אוּ וְעָלָ֥יו יִשְׂחָֽקוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 9,
      "referenceLabel": "Psalms 52:9",
      "text": "הִנֵּ֤ה הַגֶּ֗בֶר לֹ֤א יָשִׂ֥ים אֱלֹהִ֗ים מָֽע֫וּזּ֥וֹ וַ֭יִּבְטַח בְּרֹ֣ב עָשְׁר֑וֹ יָ֝עֹ֗ז בְּהַוָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 10,
      "referenceLabel": "Psalms 52:10",
      "text": "וַאֲנִ֤י ׀ כְּזַ֣יִת רַ֭עֲנָן בְּבֵ֣ית אֱלֹהִ֑ים בָּטַ֥חְתִּי בְחֶֽסֶד ־ אֱ֝לֹהִ֗ים עוֹלָ֥ם וָעֶֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.52.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 11,
      "referenceLabel": "Psalms 52:11",
      "text": "אוֹדְךָ֣ לְ֭עוֹלָם כִּ֣י עָשִׂ֑יתָ וַאֲקַוֶּ֖ה שִׁמְךָ֥ כִֽי ־ ט֝֗וֹב נֶ֣גֶד חֲסִידֶֽיךָ ׃",
      "paragraphStart": false
    }
  ]
}
