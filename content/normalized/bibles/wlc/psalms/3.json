{
  "chapter": {
    "id": "wlc:psalms.3",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.3.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "מִזְמ֥וֹר לְדָוִ֑ד בְּ֝בָרְח֗וֹ מִפְּנֵ֤י ׀ אַבְשָׁל֬וֹם בְּנֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.3.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "יְ֭הוָה מָֽה ־ רַבּ֣וּ צָרָ֑י רַ֝בִּ֗ים קָמִ֥ים עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "רַבִּים֮ אֹמְרִ֪ים לְנַ֫פְשִׁ֥י אֵ֤ין יְֽשׁוּעָ֓תָה לּ֬וֹ בֵֽאלֹהִ֬ים סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "וְאַתָּ֣ה יְ֭הוָה מָגֵ֣ן בַּעֲדִ֑י כְּ֝בוֹדִ֗י וּמֵרִ֥ים רֹאשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "ק֭וֹלִי אֶל ־ יְהוָ֣ה אֶקְרָ֑א וַיַּֽעֲנֵ֨נִי מֵהַ֖ר קָדְשׁ֣וֹ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "אֲנִ֥י שָׁכַ֗בְתִּי וָֽאִ֫ישָׁ֥נָה הֱקִיצ֑וֹתִי כִּ֖י יְהוָ֣ה יִסְמְכֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "לֹֽא ־ אִ֭ירָא מֵרִבְב֥וֹת עָ֑ם אֲשֶׁ֥ר סָ֝בִ֗יב שָׁ֣תוּ עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "ק֘וּמָ֤ה יְהוָ֨ה ׀ הוֹשִׁ֘יעֵ֤נִי אֱלֹהַ֗י כִּֽי ־ הִכִּ֣יתָ אֶת ־ כָּל ־ אֹיְבַ֣י לֶ֑חִי שִׁנֵּ֖י רְשָׁעִ֣ים שִׁבַּֽרְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.3.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Psalms 3:9",
      "text": "לַיהוָ֥ה הַיְשׁוּעָ֑ה עַֽל ־ עַמְּךָ֖ בִרְכָתֶ֣ךָ סֶּֽלָה ׃",
      "paragraphStart": false
    }
  ]
}
