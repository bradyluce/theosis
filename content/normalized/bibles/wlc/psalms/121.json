{
  "chapter": {
    "id": "wlc:psalms.121",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.121.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "שִׁ֗יר לַֽמַּ֫עֲל֥וֹת אֶשָּׂ֣א עֵ֭ינַי אֶל ־ הֶהָרִ֑ים מֵ֝אַ֗יִן יָבֹ֥א עֶזְרִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.121.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "עֶ֭זְרִי מֵעִ֣ם יְהוָ֑ה עֹ֝שֵׂ֗ה שָׁמַ֥יִם וָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.121.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "אַל ־ יִתֵּ֣ן לַמּ֣וֹט רַגְלֶ֑ךָ אַל ־ יָ֝נ֗וּם שֹֽׁמְרֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.121.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "הִנֵּ֣ה לֹֽא ־ יָ֭נוּם וְלֹ֣א יִישָׁ֑ן שׁ֝וֹמֵ֗ר יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.121.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "יְהוָ֥ה שֹׁמְרֶ֑ךָ יְהוָ֥ה צִ֝לְּךָ֗ עַל ־ יַ֥ד יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.121.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "יוֹמָ֗ם הַשֶּׁ֥מֶשׁ לֹֽא ־ יַכֶּ֗כָּה וְיָרֵ֥חַ בַּלָּֽיְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.121.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "יְֽהוָ֗ה יִשְׁמָרְךָ֥ מִכָּל ־ רָ֑ע יִ֝שְׁמֹ֗ר אֶת ־ נַפְשֶֽׁךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.121.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "יְֽהוָ֗ה יִשְׁמָר ־ צֵאתְךָ֥ וּבוֹאֶ֑ךָ מֵֽ֝עַתָּ֗ה וְעַד ־ עוֹלָֽם ׃",
      "paragraphStart": false
    }
  ]
}
