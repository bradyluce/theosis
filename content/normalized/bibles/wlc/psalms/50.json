{
  "chapter": {
    "id": "wlc:psalms.50",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.50.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "מִזְמ֗וֹר לְאָ֫סָ֥ף אֵ֤ל ׀ אֱֽלֹהִ֡ים יְֽהוָ֗ה דִּבֶּ֥ר וַיִּקְרָא ־ אָ֑רֶץ מִמִּזְרַח ־ שֶׁ֝֗מֶשׁ עַד ־ מְבֹאֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.50.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "מִצִּיּ֥וֹן מִכְלַל ־ יֹ֗פִי אֱלֹהִ֥ים הוֹפִֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "יָ֤בֹ֥א אֱלֹהֵ֗ינוּ וְֽאַל ־ יֶ֫חֱרַ֥שׁ אֵשׁ ־ לְפָנָ֥יו תֹּאכֵ֑ל וּ֝סְבִיבָ֗יו נִשְׂעֲרָ֥ה מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "יִקְרָ֣א אֶל ־ הַשָּׁמַ֣יִם מֵעָ֑ל וְאֶל ־ הָ֝אָ֗רֶץ לָדִ֥ין עַמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "אִסְפוּ ־ לִ֥י חֲסִידָ֑י כֹּרְתֵ֖י בְרִיתִ֣י עֲלֵי ־ זָֽבַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "וַיַּגִּ֣ידוּ שָׁמַ֣יִם צִדְק֑וֹ כִּֽי ־ אֱלֹהִ֓ים ׀ שֹׁפֵ֖ט ה֣וּא סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "שִׁמְעָ֤ה עַמִּ֨י ׀ וַאֲדַבֵּ֗רָה יִ֭שְׂרָאֵל וְאָעִ֣ידָה בָּ֑ךְ אֱלֹהִ֖ים אֱלֹהֶ֣יךָ אָנֹֽכִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "לֹ֣א עַל ־ זְ֭בָחֶיךָ אוֹכִיחֶ֑ךָ וְעוֹלֹתֶ֖יךָ לְנֶגְדִּ֣י תָמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "לֹא ־ אֶקַּ֣ח מִבֵּיתְךָ֣ פָ֑ר מִ֝מִּכְלְאֹתֶ֗יךָ עַתּוּדִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "כִּי ־ לִ֥י כָל ־ חַיְתוֹ ־ יָ֑עַר בְּ֝הֵמ֗וֹת בְּהַרְרֵי ־ אָֽלֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "יָ֭דַעְתִּי כָּל ־ ע֣וֹף הָרִ֑ים וְזִ֥יז שָׂ֝דַ֗י עִמָּדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "אִם ־ אֶ֭רְעַב לֹא ־ אֹ֣מַר לָ֑ךְ כִּי ־ לִ֥י תֵ֝בֵ֗ל וּמְלֹאָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "הַֽ֭אוֹכַל בְּשַׂ֣ר אַבִּירִ֑ים וְדַ֖ם עַתּוּדִ֣ים אֶשְׁתֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "זְבַ֣ח לֵאלֹהִ֣ים תּוֹדָ֑ה וְשַׁלֵּ֖ם לְעֶלְי֣וֹן נְדָרֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "וּ֭קְרָאֵנִי בְּי֣וֹם צָרָ֑ה אֲ֝חַלֶּצְךָ֗ וּֽתְכַבְּדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "וְלָ֤רָשָׁ֨ע ׀ אָ֘מַ֤ר אֱלֹהִ֗ים מַה ־ לְּ֭ךָ לְסַפֵּ֣ר חֻקָּ֑י וַתִּשָּׂ֖א בְרִיתִ֣י עֲלֵי ־ פִֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "וְ֭אַתָּה שָׂנֵ֣אתָ מוּסָ֑ר וַתַּשְׁלֵ֖ךְ דְּבָרַ֣י אַחֲרֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "אִם ־ רָאִ֣יתָ גַ֭נָּב וַתִּ֣רֶץ עִמּ֑וֹ וְעִ֖ם מְנָאֲפִ֣ים חֶלְקֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "פִּ֭יךָ שָׁלַ֣חְתָּ בְרָעָ֑ה וּ֝לְשׁוֹנְךָ֗ תַּצְמִ֥יד מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "תֵּ֭שֵׁב בְּאָחִ֣יךָ תְדַבֵּ֑ר בְּבֶֽן ־ אִ֝מְּךָ֗ תִּתֶּן ־ דֹּֽפִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "אֵ֤לֶּה עָשִׂ֨יתָ ׀ וְֽהֶחֱרַ֗שְׁתִּי דִּמִּ֗יתָ הֱֽיוֹת ־ אֶֽהְיֶ֥ה כָמ֑וֹךָ אוֹכִיחֲךָ֖ וְאֶֽעֶרְכָ֣ה לְעֵינֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 22,
      "referenceLabel": "Psalms 50:22",
      "text": "בִּֽינוּ ־ נָ֣א זֹ֭את שֹׁכְחֵ֣י אֱל֑וֹהַּ פֶּן ־ אֶ֝טְרֹ֗ף וְאֵ֣ין מַצִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.50.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 23,
      "referenceLabel": "Psalms 50:23",
      "text": "זֹבֵ֥חַ תּוֹדָ֗ה יְֽכַ֫בְּדָ֥נְנִי וְשָׂ֥ם דֶּ֑רֶךְ אַ֝רְאֶ֗נּוּ בְּיֵ֣שַׁע אֱלֹהִֽים ׃",
      "paragraphStart": false
    }
  ]
}
