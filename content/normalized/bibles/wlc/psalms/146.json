{
  "chapter": {
    "id": "wlc:psalms.146",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.146.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "הַֽלְלוּ ־ יָ֡הּ הַלְלִ֥י נַ֝פְשִׁ֗י אֶת ־ יְהוָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.146.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "אֲהַלְלָ֣ה יְהוָ֣ה בְּחַיָּ֑י אֲזַמְּרָ֖ה לֵֽאלֹהַ֣י בְּעוֹדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "אַל ־ תִּבְטְח֥וּ בִנְדִיבִ֑ים בְּבֶן ־ אָדָ֓ם ׀ שֶׁ֤אֵֽין ל֥וֹ תְשׁוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "תֵּצֵ֣א ר֭וּחוֹ יָשֻׁ֣ב לְאַדְמָת֑וֹ בַּיּ֥וֹם הַ֝ה֗וּא אָבְד֥וּ עֶשְׁתֹּנֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "אַשְׁרֵ֗י שֶׁ֤אֵ֣ל יַעֲקֹ֣ב בְּעֶזְר֑וֹ שִׂ֝בְר֗וֹ עַל ־ יְהוָ֥ה אֱלֹהָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "עֹשֶׂ֤ה ׀ שָׁ֘מַ֤יִם וָאָ֗רֶץ אֶת ־ הַיָּ֥ם וְאֶת ־ כָּל ־ אֲשֶׁר ־ בָּ֑ם הַשֹּׁמֵ֖ר אֱמֶ֣ת לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "עֹשֶׂ֤ה מִשְׁפָּ֨ט ׀ לָעֲשׁוּקִ֗ים נֹתֵ֣ן לֶ֭חֶם לָרְעֵבִ֑ים יְ֝הוָ֗ה מַתִּ֥יר אֲסוּרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "יְהוָ֤ה ׀ פֹּ֘קֵ֤חַ עִוְרִ֗ים יְ֭הוָה זֹקֵ֣ף כְּפוּפִ֑ים יְ֝הוָ֗ה אֹהֵ֥ב צַדִּיקִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "יְהוָ֤ה ׀ שֹׁ֘מֵ֤ר אֶת ־ גֵּרִ֗ים יָת֣וֹם וְאַלְמָנָ֣ה יְעוֹדֵ֑ד וְדֶ֖רֶךְ רְשָׁעִ֣ים יְעַוֵּֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.146.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "יִמְלֹ֤ךְ יְהוָ֨ה ׀ לְעוֹלָ֗ם אֱלֹהַ֣יִךְ צִ֭יּוֹן לְדֹ֥ר וָדֹ֗ר הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
