{
  "chapter": {
    "id": "wlc:psalms.137",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.137.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "עַ֥ל נַהֲר֨וֹת ׀ בָּבֶ֗ל שָׁ֣ם יָ֭שַׁבְנוּ גַּם ־ בָּכִ֑ינוּ בְּ֝זָכְרֵ֗נוּ אֶת ־ צִיּֽוֹן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.137.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "עַֽל ־ עֲרָבִ֥ים בְּתוֹכָ֑הּ תָּ֝לִ֗ינוּ כִּנֹּרוֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "כִּ֤י שָׁ֨ם שְֽׁאֵל֪וּנוּ שׁוֹבֵ֡ינוּ דִּבְרֵי ־ שִׁ֭יר וְתוֹלָלֵ֣ינוּ שִׂמְחָ֑ה שִׁ֥ירוּ לָ֝֗נוּ מִשִּׁ֥יר צִיּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "אֵ֗יךְ נָשִׁ֥יר אֶת ־ שִׁיר ־ יְהוָ֑ה עַ֝֗ל אַדְמַ֥ת נֵכָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "אִֽם ־ אֶשְׁכָּחֵ֥ךְ יְֽרוּשָׁלִָ֗ם תִּשְׁכַּ֥ח יְמִינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "תִּדְבַּ֥ק ־ לְשׁוֹנִ֨י ׀ לְחִכִּי֮ אִם ־ לֹ֪א אֶ֫זְכְּרֵ֥כִי אִם ־ לֹ֣א אַ֭עֲלֶה אֶת ־ יְרוּשָׁלִַ֑ם עַ֝֗ל רֹ֣אשׁ שִׂמְחָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "זְכֹ֤ר יְהוָ֨ה ׀ לִבְנֵ֬י אֱד֗וֹם אֵת֮ י֤וֹם יְֽרוּשָׁ֫לִָ֥ם הָ֭אֹ֣מְרִים עָ֤רוּ ׀ עָ֑רוּ עַ֝֗ד הַיְס֥וֹד בָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "בַּת ־ בָּבֶ֗ל הַשְּׁד֫וּדָ֥ה אַשְׁרֵ֥י שֶׁיְשַׁלֶּם ־ לָ֑ךְ אֶת ־ גְּ֝מוּלֵ֗ךְ שֶׁגָּמַ֥לְתְּ לָֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.137.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 9,
      "referenceLabel": "Psalms 137:9",
      "text": "אַשְׁרֵ֤י ׀ שֶׁיֹּאחֵ֓ז וְנִפֵּ֬ץ אֶֽת ־ עֹ֝לָלַ֗יִךְ אֶל ־ הַסָּֽלַע ׃",
      "paragraphStart": false
    }
  ]
}
