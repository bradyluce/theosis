{
  "chapter": {
    "id": "wlc:psalms.71",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.71.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "בְּךָֽ ־ יְהוָ֥ה חָסִ֑יתִי אַל ־ אֵב֥וֹשָׁה לְעוֹלָֽם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.71.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "בְּצִדְקָתְךָ֗ תַּצִּילֵ֥נִי וּֽתְפַלְּטֵ֑נִי הַטֵּֽה ־ אֵלַ֥י אָ֝זְנְךָ֗ וְהוֹשִׁיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "הֱיֵ֤ה לִ֨י ׀ לְצ֥וּר מָע֡וֹן לָב֗וֹא תָּמִ֗יד צִוִּ֥יתָ לְהוֹשִׁיעֵ֑נִי כִּֽי ־ סַלְעִ֖י וּמְצוּדָתִ֣י אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "אֱֽלֹהַ֗י פַּ֭לְּטֵנִי מִיַּ֣ד רָשָׁ֑ע מִכַּ֖ף מְעַוֵּ֣ל וְחוֹמֵץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "כִּֽי ־ אַתָּ֥ה תִקְוָתִ֑י אֲדֹנָ֥י יְ֝הוִ֗ה מִבְטַחִ֥י מִנְּעוּרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "עָלֶ֤יךָ ׀ נִסְמַ֬כְתִּי מִבֶּ֗טֶן מִמְּעֵ֣י אִ֭מִּי אַתָּ֣ה גוֹזִ֑י בְּךָ֖ תְהִלָּתִ֣י תָמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "כְּ֭מוֹפֵת הָיִ֣יתִי לְרַבִּ֑ים וְ֝אַתָּ֗ה מַֽחֲסִי ־ עֹֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "יִמָּ֣לֵא פִ֭י תְּהִלָּתֶ֑ךָ כָּל ־ הַ֝יּ֗וֹם תִּפְאַרְתֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "אַֽל ־ תַּ֭שְׁלִיכֵנִי לְעֵ֣ת זִקְנָ֑ה כִּכְל֥וֹת כֹּ֝חִ֗י אַֽל ־ תַּעַזְבֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "כִּֽי ־ אָמְר֣וּ אוֹיְבַ֣י לִ֑י וְשֹׁמְרֵ֥י נַ֝פְשִׁ֗י נוֹעֲצ֥וּ יַחְדָּֽו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "לֵ֭אמֹר אֱלֹהִ֣ים עֲזָב֑וֹ רִֽדְפ֥וּ וְ֝תִפְשׂ֗וּהוּ כִּי ־ אֵ֥ין מַצִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "אֱ֭לֹהִים אַל ־ תִּרְחַ֣ק מִמֶּ֑נִּי אֱ֝לֹהַ֗י לְעֶזְרָ֥תִי חישה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "יֵבֹ֣שׁוּ יִכְלוּ֮ שֹׂטְנֵ֪י נַ֫פְשִׁ֥י יַֽעֲט֣וּ חֶ֭רְפָּה וּכְלִמָּ֑ה מְ֝בַקְשֵׁ֗י רָעָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "וַ֭אֲנִי תָּמִ֣יד אֲיַחֵ֑ל וְ֝הוֹסַפְתִּ֗י עַל ־ כָּל ־ תְּהִלָּתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "פִּ֤י ׀ יְסַפֵּ֬ר צִדְקָתֶ֗ךָ כָּל ־ הַיּ֥וֹם תְּשׁוּעָתֶ֑ךָ כִּ֤י לֹ֖א יָדַ֣עְתִּי סְפֹרֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "אָב֗וֹא בִּ֭גְבֻרוֹת אֲדֹנָ֣י יְהוִ֑ה אַזְכִּ֖יר צִדְקָתְךָ֣ לְבַדֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "אֱֽלֹהִ֗ים לִמַּדְתַּ֥נִי מִנְּעוּרָ֑י וְעַד ־ הֵ֝֗נָּה אַגִּ֥יד נִפְלְאוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "וְגַ֤ם עַד ־ זִקְנָ֨ה ׀ וְשֵׂיבָה֮ אֱלֹהִ֪ים אַֽל ־ תַּעַ֫זְבֵ֥נִי עַד ־ אַגִּ֣יד זְרוֹעֲךָ֣ לְד֑וֹר לְכָל ־ יָ֝ב֗וֹא גְּבוּרָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "וְצִדְקָתְךָ֥ אֱלֹהִ֗ים עַד ־ מָ֫ר֥וֹם אֲשֶׁר ־ עָשִׂ֥יתָ גְדֹל֑וֹת אֱ֝לֹהִ֗ים מִ֣י כָמֽוֹךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "אֲשֶׁ֤ר הראיתנו ׀ צָר֥וֹת רַבּ֗וֹת וְרָ֫ע֥וֹת תָּשׁ֥וּב תחיינו וּֽמִתְּהֹמ֥וֹת הָ֝אָ֗רֶץ תָּשׁ֥וּב תַּעֲלֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 21,
      "referenceLabel": "Psalms 71:21",
      "text": "תֶּ֤רֶב ׀ גְּֽדֻלָּתִ֗י וְתִסֹּ֥ב תְּֽנַחֲמֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 22,
      "referenceLabel": "Psalms 71:22",
      "text": "גַּם ־ אֲנִ֤י ׀ אוֹדְךָ֣ בִכְלִי ־ נֶבֶל֮ אֲמִתְּךָ֪ אֱלֹ֫הָ֥י אֲזַמְּרָ֣ה לְךָ֣ בְכִנּ֑וֹר קְ֝ד֗וֹשׁ יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 23,
      "referenceLabel": "Psalms 71:23",
      "text": "תְּרַנֵּ֣נָּ֣ה שְׂ֭פָתַי כִּ֣י אֲזַמְּרָה ־ לָּ֑ךְ וְ֝נַפְשִׁ֗י אֲשֶׁ֣ר פָּדִֽיתָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.71.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 24,
      "referenceLabel": "Psalms 71:24",
      "text": "גַּם ־ לְשׁוֹנִ֗י כָּל ־ הַ֭יּוֹם תֶּהְגֶּ֣ה צִדְקָתֶ֑ךָ כִּי ־ בֹ֥שׁוּ כִֽי ־ חָ֝פְר֗וּ מְבַקְשֵׁ֥י רָעָתִֽי ׃",
      "paragraphStart": false
    }
  ]
}
