{
  "chapter": {
    "id": "wlc:psalms.34",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.34.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "לְדָוִ֗ד בְּשַׁנּוֹת֣וֹ אֶת ־ טַ֭עְמוֹ לִפְנֵ֣י אֲבִימֶ֑לֶךְ וַֽ֝יְגָרֲשֵׁ֗הוּ וַיֵּלַֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.34.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "אֲבָרֲכָ֣ה אֶת ־ יְהוָ֣ה בְּכָל ־ עֵ֑ת תָּ֝מִ֗יד תְּֽהִלָּת֥וֹ בְּפִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "בַּ֭יהוָה תִּתְהַלֵּ֣ל נַפְשִׁ֑י יִשְׁמְע֖וּ עֲנָוִ֣ים וְיִשְׂמָֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "גַּדְּל֣וּ לַיהוָ֣ה אִתִּ֑י וּנְרוֹמְמָ֖ה שְׁמ֣וֹ יַחְדָּֽו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "דָּרַ֣שְׁתִּי אֶת ־ יְהוָ֣ה וְעָנָ֑נִי וּמִכָּל ־ מְ֝גוּרוֹתַ֗י הִצִּילָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "הִבִּ֣יטוּ אֵלָ֣יו וְנָהָ֑רוּ וּ֝פְנֵיהֶ֗ם אַל ־ יֶחְפָּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "זֶ֤ה עָנִ֣י קָ֭רָא וַיהוָ֣ה שָׁמֵ֑עַ וּמִכָּל ־ צָ֝רוֹתָ֗יו הוֹשִׁיעֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "חֹנֶ֤ה מַלְאַךְ ־ יְהוָ֓ה סָ֘בִ֤יב לִֽירֵאָ֗יו וַֽיְחַלְּצֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "טַעֲמ֣וּ וּ֭רְאוּ כִּי ־ ט֣וֹב יְהוָ֑ה אַֽשְׁרֵ֥י הַ֝גֶּ֗בֶר יֶחֱסֶה ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "יְר֣אוּ אֶת ־ יְהוָ֣ה קְדֹשָׁ֑יו כִּי ־ אֵ֥ין מַ֝חְס֗וֹר לִירֵאָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "כְּ֭פִירִים רָשׁ֣וּ וְרָעֵ֑בוּ וְדֹרְשֵׁ֥י יְ֝הוָ֗ה לֹא ־ יַחְסְר֥וּ כָל ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "לְֽכוּ ־ בָ֭נִים שִׁמְעוּ ־ לִ֑י יִֽרְאַ֥ת יְ֝הוָ֗ה אֲלַמֶּדְכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "מִֽי ־ הָ֭אִישׁ הֶחָפֵ֣ץ חַיִּ֑ים אֹהֵ֥ב יָ֝מִ֗ים לִרְא֥וֹת טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "נְצֹ֣ר לְשׁוֹנְךָ֣ מֵרָ֑ע וּ֝שְׂפָתֶ֗יךָ מִדַּבֵּ֥ר מִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "ס֣וּר מֵ֭רָע וַעֲשֵׂה ־ ט֑וֹב בַּקֵּ֖שׁ שָׁל֣וֹם וְרָדְפֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "עֵינֵ֣י יְ֭הוָה אֶל ־ צַדִּיקִ֑ים וְ֝אָזְנָ֗יו אֶל ־ שַׁוְעָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "פְּנֵ֣י יְ֭הוָה בְּעֹ֣שֵׂי רָ֑ע לְהַכְרִ֖ית מֵאֶ֣רֶץ זִכְרָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "צָעֲק֣וּ וַיהוָ֣ה שָׁמֵ֑עַ וּמִכָּל ־ צָ֝רוֹתָ֗ם הִצִּילָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "קָר֣וֹב יְ֭הוָה לְנִשְׁבְּרֵי ־ לֵ֑ב וְֽאֶת ־ דַּכְּאֵי ־ ר֥וּחַ יוֹשִֽׁיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "רַ֭בּוֹת רָע֣וֹת צַדִּ֑יק וּ֝מִכֻּלָּ֗ם יַצִּילֶ֥נּוּ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "שֹׁמֵ֥ר כָּל ־ עַצְמוֹתָ֑יו אַחַ֥ת מֵ֝הֵ֗נָּה לֹ֣א נִשְׁבָּֽרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "תְּמוֹתֵ֣ת רָשָׁ֣ע רָעָ֑ה וְשֹׂנְאֵ֖י צַדִּ֣יק יֶאְשָֽׁמוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.34.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Psalms 34:23",
      "text": "פּוֹדֶ֣ה יְ֭הוָה נֶ֣פֶשׁ עֲבָדָ֑יו וְלֹ֥א יֶ֝אְשְׁמ֗וּ כָּֽל ־ הַחֹסִ֥ים בּֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
