  },
  "verses": [
    {
      "id": "wlc:psalms.67.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 1,
      "referenceLabel": "Psalms 67:1",
      "text": "לַמְנַצֵּ֥ח בִּנְגִינֹ֗ת מִזְמ֥וֹר שִֽׁיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.67.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 2,
      "referenceLabel": "Psalms 67:2",
      "text": "אֱלֹהִ֗ים יְחָנֵּ֥נוּ וִֽיבָרְכֵ֑נוּ יָ֤אֵ֥ר פָּנָ֖יו אִתָּ֣נוּ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.67.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 3,
      "referenceLabel": "Psalms 67:3",
      "text": "לָדַ֣עַת בָּאָ֣רֶץ דַּרְכֶּ֑ךָ בְּכָל ־ גּ֝וֹיִ֗ם יְשׁוּעָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.67.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 4,
      "referenceLabel": "Psalms 67:4",
      "text": "יוֹד֖וּךָ עַמִּ֥ים ׀ אֱלֹהִ֑ים י֝וֹד֗וּךָ עַמִּ֥ים כֻּלָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.67.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 5,
      "referenceLabel": "Psalms 67:5",
      "text": "יִֽשְׂמְח֥וּ וִֽירַנְּנ֗וּ לְאֻ֫מִּ֥ים כִּֽי ־ תִשְׁפֹּ֣ט עַמִּ֣ים מִישׁ֑וֹר וּלְאֻמִּ֓ים ׀ בָּאָ֖רֶץ תַּנְחֵ֣ם סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.67.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 6,
      "referenceLabel": "Psalms 67:6",
      "text": "יוֹד֖וּךָ עַמִּ֥ים ׀ אֱלֹהִ֑ים י֝וֹד֗וּךָ עַמִּ֥ים כֻּלָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.67.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 7,
      "referenceLabel": "Psalms 67:7",
      "text": "אֶ֭רֶץ נָתְנָ֣ה יְבוּלָ֑הּ יְ֝בָרְכֵ֗נוּ אֱלֹהִ֥ים אֱלֹהֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.67.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 8,
      "referenceLabel": "Psalms 67:8",
      "text": "יְבָרְכֵ֥נוּ אֱלֹהִ֑ים וְיִֽירְא֥וּ אֹ֝ת֗וֹ כָּל ־ אַפְסֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
}
