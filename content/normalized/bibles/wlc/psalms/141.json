{
  "chapter": {
    "id": "wlc:psalms.141",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 141,
    "referenceLabel": "Psalms 141",
    "summary": "Source text for Psalms 141 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.141.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 1,
      "referenceLabel": "Psalms 141:1",
      "text": "מִזְמ֗וֹר לְדָ֫וִ֥ד יְהוָ֣ה קְ֭רָאתִיךָ ח֣וּשָׁה לִּ֑י הַאֲזִ֥ינָה ק֝וֹלִ֗י בְּקָרְאִי ־ לָֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.141.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 2,
      "referenceLabel": "Psalms 141:2",
      "text": "תִּכּ֤וֹן תְּפִלָּתִ֣י קְטֹ֣רֶת לְפָנֶ֑יךָ מַֽשְׂאַ֥ת כַּ֝פַּ֗י מִנְחַת ־ עָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 3,
      "referenceLabel": "Psalms 141:3",
      "text": "שִׁיתָ֣ה יְ֭הוָה שָׁמְרָ֣ה לְפִ֑י נִ֝צְּרָ֗ה עַל ־ דַּ֥ל שְׂפָתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 4,
      "referenceLabel": "Psalms 141:4",
      "text": "אַל ־ תַּט ־ לִבִּ֨י לְדָבָ֪ר ׀ רָ֡ע לְהִתְע֘וֹלֵ֤ל עֲלִל֨וֹת ׀ בְּרֶ֗שַׁע אֶת ־ אִישִׁ֥ים פֹּֽעֲלֵי ־ אָ֑וֶן וּבַל ־ אֶ֝לְחַ֗ם בְּמַנְעַמֵּיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 5,
      "referenceLabel": "Psalms 141:5",
      "text": "יֶֽהֶלְמֵֽנִי ־ צַדִּ֨יק ׀ חֶ֡סֶד וְֽיוֹכִיחֵ֗נִי שֶׁ֣מֶן רֹ֭אשׁ אַל ־ יָנִ֣י רֹאשִׁ֑י כִּי ־ ע֥וֹד וּ֝תְפִלָּתִ֗י בְּרָעוֹתֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 6,
      "referenceLabel": "Psalms 141:6",
      "text": "נִשְׁמְט֣וּ בִֽידֵי ־ סֶ֭לַע שֹׁפְטֵיהֶ֑ם וְשָׁמְע֥וּ אֲ֝מָרַ֗י כִּ֣י נָעֵֽמוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 7,
      "referenceLabel": "Psalms 141:7",
      "text": "כְּמ֤וֹ פֹלֵ֣חַ וּבֹקֵ֣עַ בָּאָ֑רֶץ נִפְזְר֥וּ עֲ֝צָמֵ֗ינוּ לְפִ֣י שְׁאֽוֹל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 8,
      "referenceLabel": "Psalms 141:8",
      "text": "כִּ֤י אֵלֶ֨יךָ ׀ יְהֹוִ֣ה אֲדֹנָ֣י עֵינָ֑י בְּכָ֥ה חָ֝סִ֗יתִי אַל ־ תְּעַ֥ר נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 9,
      "referenceLabel": "Psalms 141:9",
      "text": "שָׁמְרֵ֗נִי מִ֣ידֵי פַ֭ח יָ֣קְשׁוּ לִ֑י וּ֝מֹקְשׁ֗וֹת פֹּ֣עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.141.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 10,
      "referenceLabel": "Psalms 141:10",
      "text": "יִפְּל֣וּ בְמַכְמֹרָ֣יו רְשָׁעִ֑ים יַ֥חַד אָ֝נֹכִ֗י עַֽד ־ אֶעֱבֽוֹר ׃",
      "paragraphStart": false
    }
  ]
}
