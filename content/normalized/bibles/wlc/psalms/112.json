{
  "chapter": {
    "id": "wlc:psalms.112",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.112.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ אַשְׁרֵי ־ אִ֭ישׁ יָרֵ֣א אֶת ־ יְהוָ֑ה בְּ֝מִצְוֺתָ֗יו חָפֵ֥ץ מְאֹֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.112.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "גִּבּ֣וֹר בָּ֭אָרֶץ יִהְיֶ֣ה זַרְע֑וֹ דּ֭וֹר יְשָׁרִ֣ים יְבֹרָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "הוֹן ־ וָעֹ֥שֶׁר בְּבֵית֑וֹ וְ֝צִדְקָת֗וֹ עֹמֶ֥דֶת לָעַֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "זָ֘רַ֤ח בַּחֹ֣שֶׁךְ א֭וֹר לַיְשָׁרִ֑ים חַנּ֖וּן וְרַח֣וּם וְצַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "טֽוֹב ־ אִ֭ישׁ חוֹנֵ֣ן וּמַלְוֶ֑ה יְכַלְכֵּ֖ל דְּבָרָ֣יו בְּמִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "כִּֽי ־ לְעוֹלָ֥ם לֹא ־ יִמּ֑וֹט לְזֵ֥כֶר ע֝וֹלָ֗ם יִהְיֶ֥ה צַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "מִשְּׁמוּעָ֣ה רָ֭עָה לֹ֣א יִירָ֑א נָכ֥וֹן לִ֝בּ֗וֹ בָּטֻ֥חַ בַּיהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "סָמ֣וּךְ לִ֭בּוֹ לֹ֣א יִירָ֑א עַ֖ד אֲשֶׁר ־ יִרְאֶ֣ה בְצָרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "פִּזַּ֤ר ׀ נָ֘תַ֤ן לָאֶבְיוֹנִ֗ים צִ֭דְקָתוֹ עֹמֶ֣דֶת לָעַ֑ד קַ֝רְנ֗וֹ תָּר֥וּם בְּכָבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.112.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 10,
      "referenceLabel": "Psalms 112:10",
      "text": "רָ֘שָׁ֤ע יִרְאֶ֨ה ׀ וְכָעָ֗ס שִׁנָּ֣יו יַחֲרֹ֣ק וְנָמָ֑ס תַּאֲוַ֖ת רְשָׁעִ֣ים תֹּאבֵֽד ׃",
      "paragraphStart": false
    }
  ]
}
