{
  "chapter": {
    "id": "wlc:psalms.72",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.72.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "לִשְׁלֹמֹ֨ה ׀ אֱֽלֹהִ֗ים מִ֭שְׁפָּטֶיךָ לְמֶ֣לֶךְ תֵּ֑ן וְצִדְקָתְךָ֥ לְבֶן ־ מֶֽלֶךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.72.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "יָדִ֣ין עַמְּךָ֣ בְצֶ֑דֶק וַעֲנִיֶּ֥יךָ בְמִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "יִשְׂא֤וּ הָרִ֓ים שָׁ֘ל֥וֹם לָעָ֑ם וּ֝גְבָע֗וֹת בִּצְדָקָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "יִשְׁפֹּ֤ט ׀ עֲֽנִיֵּי ־ עָ֗ם י֭וֹשִׁיעַ לִבְנֵ֣י אֶבְי֑וֹן וִֽידַכֵּ֣א עוֹשֵֽׁק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "יִֽירָא֥וּךָ עִם ־ שָׁ֑מֶשׁ וְלִפְנֵ֥י יָ֝רֵ֗חַ דּ֣וֹר דּוֹרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "יֵ֭רֵד כְּמָטָ֣ר עַל ־ גֵּ֑ז כִּ֝רְבִיבִ֗ים זַרְזִ֥יף אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "יִֽפְרַח ־ בְּיָמָ֥יו צַדִּ֑יק וְרֹ֥ב שָׁ֝ל֗וֹם עַד ־ בְּלִ֥י יָרֵֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "וְ֭יֵרְדְּ מִיָּ֣ם עַד ־ יָ֑ם וּ֝מִנָּהָ֗ר עַד ־ אַפְסֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "לְ֭פָנָיו יִכְרְע֣וּ צִיִּ֑ים וְ֝אֹיְבָ֗יו עָפָ֥ר יְלַחֵֽכוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "מַלְכֵ֬י תַרְשִׁ֣ישׁ וְ֭אִיִּים מִנְחָ֣ה יָשִׁ֑יבוּ מַלְכֵ֥י שְׁבָ֥א וּ֝סְבָ֗א אֶשְׁכָּ֥ר יַקְרִֽיבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "וְיִשְׁתַּחֲווּ ־ ל֥וֹ כָל ־ מְלָכִ֑ים כָּל ־ גּוֹיִ֥ם יַֽעַבְדֽוּהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "כִּֽי ־ יַ֭צִּיל אֶבְי֣וֹן מְשַׁוֵּ֑עַ וְ֝עָנִ֗י וְֽאֵין ־ עֹזֵ֥ר לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "יָ֭חֹס עַל ־ דַּ֣ל וְאֶבְי֑וֹן וְנַפְשׁ֖וֹת אֶבְיוֹנִ֣ים יוֹשִֽׁיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "מִתּ֣וֹךְ וּ֭מֵחָמָס יִגְאַ֣ל נַפְשָׁ֑ם וְיֵיקַ֖ר דָּמָ֣ם בְּעֵינָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "וִיחִ֗י וְיִתֶּן ־ לוֹ֮ מִזְּהַ֪ב שְׁ֫בָ֥א וְיִתְפַּלֵּ֣ל בַּעֲד֣וֹ תָמִ֑יד כָּל ־ הַ֝יּ֗וֹם יְבָרֲכֶֽנְהֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "יְהִ֤י פִסַּת ־ בַּ֨ר ׀ בָּאָרֶץ֮ בְּרֹ֪אשׁ הָ֫רִ֥ים יִרְעַ֣שׁ כַּלְּבָנ֣וֹן פִּרְי֑וֹ וְיָצִ֥יצוּ מֵ֝עִ֗יר כְּעֵ֣שֶׂב הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "יְהִ֤י שְׁמ֨וֹ לְֽעוֹלָ֗ם לִפְנֵי ־ שֶׁמֶשׁ֮ ינין שְׁ֫מ֥וֹ וְיִתְבָּ֥רְכוּ ב֑וֹ כָּל ־ גּוֹיִ֥ם יְאַשְּׁרֽוּהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "בָּר֤וּךְ ׀ יְהוָ֣ה אֱ֭לֹהִים אֱלֹהֵ֣י יִשְׂרָאֵ֑ל עֹשֵׂ֖ה נִפְלָא֣וֹת לְבַדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "וּבָר֤וּךְ ׀ שֵׁ֥ם כְּבוֹד֗וֹ לְע֫וֹלָ֥ם וְיִמָּלֵ֣א כְ֭בוֹדוֹ אֶת ־ כֹּ֥ל הָאָ֗רֶץ אָ֘מֵ֥ן ׀ וְאָמֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.72.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "כָּלּ֥וּ תְפִלּ֑וֹת דָּ֝וִ֗ד בֶּן ־ יִשָֽׁי ׃",
      "paragraphStart": false
    }
  ]
}
