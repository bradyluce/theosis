{
  "chapter": {
    "id": "wlc:psalms.35",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.35.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "לְדָוִ֨ד ׀ רִיבָ֣ה יְ֭הוָה אֶת ־ יְרִיבַ֑י לְ֝חַ֗ם אֶת ־ לֹֽחֲמָֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.35.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "הַחֲזֵ֣ק מָגֵ֣ן וְצִנָּ֑ה וְ֝ק֗וּמָה בְּעֶזְרָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "וְהָ֘רֵ֤ק חֲנִ֣ית וּ֭סְגֹר לִקְרַ֣את רֹדְפָ֑י אֱמֹ֥ר לְ֝נַפְשִׁ֗י יְֽשֻׁעָתֵ֥ךְ אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "יֵבֹ֣שׁוּ וְיִכָּלְמוּ֮ מְבַקְשֵׁ֪י נַ֫פְשִׁ֥י יִסֹּ֣גוּ אָח֣וֹר וְיַחְפְּר֑וּ חֹ֝שְׁבֵ֗י רָעָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "יִֽהְי֗וּ כְּמֹ֥ץ לִפְנֵי ־ ר֑וּחַ וּמַלְאַ֖ךְ יְהוָ֣ה דּוֹחֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "יְֽהִי ־ דַרְכָּ֗ם חֹ֥שֶׁךְ וַחֲלַקְלַקּ֑וֹת וּמַלְאַ֥ךְ יְ֝הוָ֗ה רֹדְפָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "כִּֽי ־ חִנָּ֣ם טָֽמְנוּ ־ לִ֭י שַׁ֣חַת רִשְׁתָּ֑ם חִ֝נָּ֗ם חָפְר֥וּ לְנַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "תְּבוֹאֵ֣הוּ שׁוֹאָה֮ לֹֽא ־ יֵ֫דָ֥ע וְרִשְׁתּ֣וֹ אֲשֶׁר ־ טָמַ֣ן תִּלְכְּד֑וֹ בְּ֝שׁוֹאָ֗ה יִפָּל ־ בָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "וְ֭נַפְשִׁי תָּגִ֣יל בַּיהוָ֑ה תָּ֝שִׂישׂ בִּישׁוּעָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "כָּ֥ל עַצְמוֹתַ֨י ׀ תֹּאמַרְנָה֮ יְהוָ֗ה מִ֥י כָ֫מ֥וֹךָ מַצִּ֣יל עָ֭נִי מֵחָזָ֣ק מִמֶּ֑נּוּ וְעָנִ֥י וְ֝אֶבְי֗וֹן מִגֹּזְלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "יְ֭קוּמוּן עֵדֵ֣י חָמָ֑ס אֲשֶׁ֥ר לֹא ־ יָ֝דַ֗עְתִּי יִשְׁאָלֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "יְשַׁלְּמ֣וּנִי רָ֭עָה תַּ֥חַת טוֹבָ֗ה שְׁכ֣וֹל לְנַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Psalms 35:13",
      "text": "וַאֲנִ֤י ׀ בַּחֲלוֹתָ֡ם לְב֬וּשִׁי שָׂ֗ק עִנֵּ֣יתִי בַצּ֣וֹם נַפְשִׁ֑י וּ֝תְפִלָּתִ֗י עַל ־ חֵיקִ֥י תָשֽׁוּב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Psalms 35:14",
      "text": "כְּרֵֽעַ ־ כְּאָ֣ח לִ֭י הִתְהַלָּ֑כְתִּי כַּאֲבֶל ־ אֵ֝֗ם קֹדֵ֥ר שַׁחֽוֹתִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Psalms 35:15",
      "text": "וּבְצַלְעִי֮ שָׂמְח֪וּ וְֽנֶאֱ֫סָ֥פוּ נֶאֶסְפ֬וּ עָלַ֣י נֵ֭כִים וְלֹ֣א יָדַ֑עְתִּי קָֽרְע֥וּ וְלֹא ־ דָֽמּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Psalms 35:16",
      "text": "בְּ֭חַנְפֵי לַעֲגֵ֣י מָע֑וֹג חָרֹ֖ק עָלַ֣י שִׁנֵּֽימוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Psalms 35:17",
      "text": "אֲדֹנָי֮ כַּמָּ֪ה תִּ֫רְאֶ֥ה הָשִׁ֣יבָה נַ֭פְשִׁי מִשֹּׁאֵיהֶ֑ם מִ֝כְּפִירִ֗ים יְחִידָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Psalms 35:18",
      "text": "א֭וֹדְךָ בְּקָהָ֣ל רָ֑ב בְּעַ֖ם עָצ֣וּם אֲהַֽלְלֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Psalms 35:19",
      "text": "אַֽל ־ יִשְׂמְחוּ ־ לִ֣י אֹיְבַ֣י שֶׁ֑קֶר שֹׂנְאַ֥י חִ֝נָּ֗ם יִקְרְצוּ ־ עָֽיִן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Psalms 35:20",
      "text": "כִּ֤י לֹ֥א שָׁל֗וֹם יְדַ֫בֵּ֥רוּ וְעַ֥ל רִגְעֵי ־ אֶ֑רֶץ דִּבְרֵ֥י מִ֝רְמוֹת יַחֲשֹׁבֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Psalms 35:21",
      "text": "וַיַּרְחִ֥יבוּ עָלַ֗י פִּ֫יהֶ֥ם אָ֭מְרוּ הֶאָ֣ח ׀ הֶאָ֑ח רָאֲתָ֥ה עֵינֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Psalms 35:22",
      "text": "רָאִ֣יתָה יְ֭הוָה אַֽל ־ תֶּחֱרַ֑שׁ אֲ֝דֹנָ֗י אֲל ־ תִּרְחַ֥ק מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Psalms 35:23",
      "text": "הָעִ֣ירָה וְ֭הָקִיצָה לְמִשְׁפָּטִ֑י אֱלֹהַ֖י וַֽאדֹנָ֣י לְרִיבִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Psalms 35:24",
      "text": "שָׁפְטֵ֣נִי כְ֭צִדְקְךָ יְהוָ֥ה אֱלֹהָ֗י וְאַל ־ יִשְׂמְחוּ ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Psalms 35:25",
      "text": "אַל ־ יֹאמְר֣וּ בְ֭לִבָּם הֶאָ֣ח נַפְשֵׁ֑נוּ אַל ־ יֹ֝אמְר֗וּ בִּֽלַּעֲנֽוּהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Psalms 35:26",
      "text": "יֵ֘בֹ֤שׁוּ וְיַחְפְּר֨וּ ׀ יַחְדָּו֮ שְׂמֵחֵ֪י רָעָ֫תִ֥י יִֽלְבְּשׁוּ ־ בֹ֥שֶׁת וּכְלִמָּ֑ה הַֽמַּגְדִּילִ֥ים עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Psalms 35:27",
      "text": "יָרֹ֣נּוּ וְיִשְׂמְחוּ֮ חֲפֵצֵ֪י צִ֫דְקִ֥י וְיֹאמְר֣וּ תָ֭מִיד יִגְדַּ֣ל יְהוָ֑ה הֶ֝חָפֵ֗ץ שְׁל֣וֹם עַבְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.35.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Psalms 35:28",
      "text": "וּ֭לְשׁוֹנִי תֶּהְגֶּ֣ה צִדְקֶ֑ךָ כָּל ־ הַ֝יּוֹם תְּהִלָּתֶֽךָ ׃",
      "paragraphStart": false
    }
  ]
}
