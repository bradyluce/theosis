{
  "chapter": {
    "id": "wlc:psalms.29",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.29.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "מִזְמ֗וֹר לְדָ֫וִ֥ד הָב֣וּ לַֽ֭יהוָה בְּנֵ֣י אֵלִ֑ים הָב֥וּ לַ֝יהוָ֗ה כָּב֥וֹד וָעֹֽז ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.29.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "הָב֣וּ לַֽ֭יהוָה כְּב֣וֹד שְׁמ֑וֹ הִשְׁתַּחֲו֥וּ לַ֝יהוָ֗ה בְּהַדְרַת ־ קֹֽדֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "ק֥וֹל יְהוָ֗ה עַל ־ הַ֫מָּ֥יִם אֵֽל ־ הַכָּב֥וֹד הִרְעִ֑ים יְ֝הוָ֗ה עַל ־ מַ֥יִם רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "קוֹל ־ יְהוָ֥ה בַּכֹּ֑חַ ק֥וֹל יְ֝הוָ֗ה בֶּהָדָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "ק֣וֹל יְ֭הוָה שֹׁבֵ֣ר אֲרָזִ֑ים וַיְשַׁבֵּ֥ר יְ֝הוָ֗ה אֶת ־ אַרְזֵ֥י הַלְּבָנֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "וַיַּרְקִידֵ֥ם כְּמוֹ ־ עֵ֑גֶל לְבָנ֥וֹן וְ֝שִׂרְיֹ֗ן כְּמ֣וֹ בֶן ־ רְאֵמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "קוֹל ־ יְהוָ֥ה חֹצֵ֗ב לַהֲב֥וֹת אֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "ק֣וֹל יְ֭הוָה יָחִ֣יל מִדְבָּ֑ר יָחִ֥יל יְ֝הוָ֗ה מִדְבַּ֥ר קָדֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "ק֤וֹל יְהוָ֨ה ׀ יְחוֹלֵ֣ל אַיָּלוֹת֮ וַֽיֶּחֱשֹׂ֪ף יְעָ֫ר֥וֹת וּבְהֵיכָל֑וֹ כֻּ֝לּ֗וֹ אֹמֵ֥ר כָּבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "יְ֭הוָה לַמַּבּ֣וּל יָשָׁ֑ב וַיֵּ֥שֶׁב יְ֝הוָ֗ה מֶ֣לֶךְ לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.29.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "יְֽהוָ֗ה עֹ֭ז לְעַמּ֣וֹ יִתֵּ֑ן יְהוָ֓ה ׀ יְבָרֵ֖ךְ אֶת ־ עַמּ֣וֹ בַשָּׁלֽוֹם ׃",
      "paragraphStart": false
    }
  ]
}
