{
  "chapter": {
    "id": "wlc:psalms.9",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.9.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "לַ֭מְנַצֵּחַ עַלְמ֥וּת לַבֵּ֗ן מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.9.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "אוֹדֶ֣ה יְ֭הוָה בְּכָל ־ לִבִּ֑י אֲ֝סַפְּרָ֗ה כָּל ־ נִפְלְאוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "אֶשְׂמְחָ֣ה וְאֶעֶלְצָ֣ה בָ֑ךְ אֲזַמְּרָ֖ה שִׁמְךָ֣ עֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "בְּשׁוּב ־ אוֹיְבַ֥י אָח֑וֹר יִכָּשְׁל֥וּ וְ֝יֹאבְד֗וּ מִפָּנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "כִּֽי ־ עָ֭שִׂיתָ מִשְׁפָּטִ֣י וְדִינִ֑י יָשַׁ֥בְתָּ לְ֝כִסֵּ֗א שׁוֹפֵ֥ט צֶֽדֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "גָּעַ֣רְתָּ ג֭וֹיִם אִבַּ֣דְתָּ רָשָׁ֑ע שְׁמָ֥ם מָ֝חִ֗יתָ לְעוֹלָ֥ם וָעֶֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "הָֽאוֹיֵ֨ב ׀ תַּ֥מּוּ חֳרָב֗וֹת לָ֫נֶ֥צַח וְעָרִ֥ים נָתַ֑שְׁתָּ אָבַ֖ד זִכְרָ֣ם הֵֽמָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "וַֽ֭יהוָה לְעוֹלָ֣ם יֵשֵׁ֑ב כּוֹנֵ֖ן לַמִּשְׁפָּ֣ט כִּסְאֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "וְה֗וּא יִשְׁפֹּֽט ־ תֵּבֵ֥ל בְּצֶ֑דֶק יָדִ֥ין לְ֝אֻמִּ֗ים בְּמֵישָׁרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "וִ֘יהִ֤י יְהוָ֣ה מִשְׂגָּ֣ב לַדָּ֑ךְ מִ֝שְׂגָּ֗ב לְעִתּ֥וֹת בַּצָּרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "וְיִבְטְח֣וּ בְ֭ךָ יוֹדְעֵ֣י שְׁמֶ֑ךָ כִּ֤י לֹֽא ־ עָזַ֖בְתָּ דֹרְשֶׁ֣יךָ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "זַמְּר֗וּ לַ֭יהוָה יֹשֵׁ֣ב צִיּ֑וֹן הַגִּ֥ידוּ בָ֝עַמִּ֗ים עֲלִֽילוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "כִּֽי ־ דֹרֵ֣שׁ דָּ֭מִים אוֹתָ֣ם זָכָ֑ר לֹֽא ־ שָׁ֝כַ֗ח צַעֲקַ֥ת עניים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "חָֽנְנֵ֬נִי יְהוָ֗ה רְאֵ֣ה עָ֭נְיִי מִשֹּׂנְאָ֑י מְ֝רוֹמְמִ֗י מִשַּׁ֥עֲרֵי מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "לְמַ֥עַן אֲסַפְּרָ֗ה כָּֽל ־ תְּהִלָּ֫תֶ֥יךָ בְּשַֽׁעֲרֵ֥י בַת ־ צִיּ֑וֹן אָ֝גִ֗ילָה בִּישׁוּעָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "טָבְע֣וּ ג֭וֹיִם בְּשַׁ֣חַת עָשׂ֑וּ בְּרֶֽשֶׁת ־ ז֥וּ טָ֝מָ֗נוּ נִלְכְּדָ֥ה רַגְלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "נ֤וֹדַ֨ע ׀ יְהוָה֮ מִשְׁפָּ֪ט עָ֫שָׂ֥ה בְּפֹ֣עַל כַּ֭פָּיו נוֹקֵ֣שׁ רָשָׁ֑ע הִגָּי֥וֹן סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "יָשׁ֣וּבוּ רְשָׁעִ֣ים לִשְׁא֑וֹלָה כָּל ־ גּ֝וֹיִ֗ם שְׁכֵחֵ֥י אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "כִּ֤י לֹ֣א לָ֭נֶצַח יִשָּׁכַ֣ח אֶבְי֑וֹן תִּקְוַ֥ת ענוים תֹּאבַ֥ד לָעַֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "קוּמָ֣ה יְ֭הוָה אַל ־ יָעֹ֣ז אֱנ֑וֹשׁ יִשָּׁפְט֥וּ ג֝וֹיִ֗ם עַל ־ פָּנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.9.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Psalms 9:21",
      "text": "שִׁ֘יתָ֤ה יְהוָ֨ה ׀ מוֹרָ֗ה לָ֫הֶ֥ם יֵדְע֥וּ גוֹיִ֑ם אֱנ֖וֹשׁ הֵ֣מָּה סֶּֽלָה ׃",
      "paragraphStart": false
    }
  ]
}
