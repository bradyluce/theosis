{
  "chapter": {
    "id": "wlc:psalms.148",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.148.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ הַֽלְל֣וּ אֶת ־ יְ֭הוָה מִן ־ הַשָּׁמַ֑יִם הַֽ֝לְל֗וּהוּ בַּמְּרוֹמִֽים ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.148.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "הַֽלְל֥וּהוּ כָל ־ מַלְאָכָ֑יו הַֽ֝לְל֗וּהוּ כָּל ־ צבאו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "הַֽ֭לְלוּהוּ שֶׁ֣מֶשׁ וְיָרֵ֑חַ הַ֝לְל֗וּהוּ כָּל ־ כּ֥וֹכְבֵי אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "הַֽ֭לְלוּהוּ שְׁמֵ֣י הַשָּׁמָ֑יִם וְ֝הַמַּ֗יִם אֲשֶׁ֤ר ׀ מֵעַ֬ל הַשָּׁמָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "יְֽ֭הַֽלְלוּ אֶת ־ שֵׁ֣ם יְהוָ֑ה כִּ֤י ה֭וּא צִוָּ֣ה וְנִבְרָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "וַיַּעֲמִידֵ֣ם לָעַ֣ד לְעוֹלָ֑ם חָק ־ נָ֝תַ֗ן וְלֹ֣א יַעֲבֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "הַֽלְל֣וּ אֶת ־ יְ֭הוָה מִן ־ הָאָ֑רֶץ תַּ֝נִּינִ֗ים וְכָל ־ תְּהֹמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "אֵ֣שׁ וּ֭בָרָד שֶׁ֣לֶג וְקִיט֑וֹר ר֥וּחַ סְ֝עָרָ֗ה עֹשָׂ֥ה דְבָרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "הֶהָרִ֥ים וְכָל ־ גְּבָע֑וֹת עֵ֥ץ פְּ֝רִ֗י וְכָל ־ אֲרָזִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "הַֽחַיָּ֥ה וְכָל ־ בְּהֵמָ֑ה רֶ֝֗מֶשׂ וְצִפּ֥וֹר כָּנָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "מַלְכֵי ־ אֶ֭רֶץ וְכָל ־ לְאֻמִּ֑ים שָׂ֝רִ֗ים וְכָל ־ שֹׁ֥פְטֵי אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "בַּחוּרִ֥ים וְגַם ־ בְּתוּל֑וֹת זְ֝קֵנִ֗ים עִם ־ נְעָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "יְהַלְל֤וּ ׀ אֶת ־ שֵׁ֬ם יְהוָ֗ה כִּֽי ־ נִשְׂגָּ֣ב שְׁמ֣וֹ לְבַדּ֑וֹ ה֝וֹד֗וֹ עַל ־ אֶ֥רֶץ וְשָׁמָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.148.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "וַיָּ֤רֶם קֶ֨רֶן ׀ לְעַמּ֡וֹ תְּהִלָּ֤ה לְֽכָל ־ חֲסִידָ֗יו לִבְנֵ֣י יִ֭שְׂרָאֵל עַֽם ־ קְרֹב֗וֹ הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
