{
  "chapter": {
    "id": "wlc:psalms.66",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.66.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "לַ֭מְנַצֵּחַ שִׁ֣יר מִזְמ֑וֹר הָרִ֥יעוּ לֵ֝אלֹהִים כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.66.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "זַמְּר֥וּ כְבֽוֹד ־ שְׁמ֑וֹ שִׂ֥ימוּ כָ֝ב֗וֹד תְּהִלָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "אִמְר֣וּ לֵ֭אלֹהִים מַה ־ נּוֹרָ֣א מַעֲשֶׂ֑יךָ בְּרֹ֥ב עֻ֝זְּךָ֗ יְֽכַחֲשׁ֖וּ לְךָ֣ אֹיְבֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "כָּל ־ הָאָ֤רֶץ ׀ יִשְׁתַּחֲו֣וּ לְ֭ךָ וִֽיזַמְּרוּ ־ לָ֑ךְ יְזַמְּר֖וּ שִׁמְךָ֣ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "לְכ֣וּ וּ֭רְאוּ מִפְעֲל֣וֹת אֱלֹהִ֑ים נוֹרָ֥א עֲ֝לִילָ֗ה עַל ־ בְּנֵ֥י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "הָ֤פַךְ יָ֨ם ׀ לְֽיַבָּשָׁ֗ה בַּ֭נָּהָר יַֽעַבְר֣וּ בְרָ֑גֶל שָׁ֝֗ם נִשְׂמְחָה ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "מֹ֘שֵׁ֤ל בִּגְבוּרָת֨וֹ ׀ עוֹלָ֗ם עֵ֭ינָיו בַּגּוֹיִ֣ם תִּצְפֶּ֑ינָה הַסּוֹרְרִ֓ים ׀ אַל ־ ירימו לָ֣מוֹ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "בָּרְכ֖וּ עַמִּ֥ים ׀ אֱלֹהֵ֑ינוּ וְ֝הַשְׁמִ֗יעוּ ק֣וֹל תְּהִלָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 9,
      "referenceLabel": "Psalms 66:9",
      "text": "הַשָּׂ֣ם נַ֭פְשֵׁנוּ בַּֽחַיִּ֑ים וְלֹֽא ־ נָתַ֖ן לַמּ֣וֹט רַגְלֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 10,
      "referenceLabel": "Psalms 66:10",
      "text": "כִּֽי ־ בְחַנְתָּ֥נוּ אֱלֹהִ֑ים צְ֝רַפְתָּ֗נוּ כִּצְרָף ־ כָּֽסֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 11,
      "referenceLabel": "Psalms 66:11",
      "text": "הֲבֵאתָ֥נוּ בַמְּצוּדָ֑ה שַׂ֖מְתָּ מוּעָקָ֣ה בְמָתְנֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 12,
      "referenceLabel": "Psalms 66:12",
      "text": "הִרְכַּ֥בְתָּ אֱנ֗וֹשׁ לְרֹ֫אשֵׁ֥נוּ בָּֽאנוּ ־ בָאֵ֥שׁ וּבַמַּ֑יִם וַ֝תּוֹצִיאֵ֗נוּ לָֽרְוָיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 13,
      "referenceLabel": "Psalms 66:13",
      "text": "אָב֣וֹא בֵיתְךָ֣ בְעוֹל֑וֹת אֲשַׁלֵּ֖ם לְךָ֣ נְדָרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 14,
      "referenceLabel": "Psalms 66:14",
      "text": "אֲשֶׁר ־ פָּצ֥וּ שְׂפָתָ֑י וְדִבֶּר ־ פִּ֝֗י בַּצַּר ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 15,
      "referenceLabel": "Psalms 66:15",
      "text": "עֹ֘ל֤וֹת מֵחִ֣ים אַעֲלֶה ־ לָּ֭ךְ עִם ־ קְטֹ֣רֶת אֵילִ֑ים אֶ֥עֱשֶֽׂה בָקָ֖ר עִם ־ עַתּוּדִ֣ים סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 16,
      "referenceLabel": "Psalms 66:16",
      "text": "לְכֽוּ ־ שִׁמְע֣וּ וַ֭אֲסַפְּרָה כָּל ־ יִרְאֵ֣י אֱלֹהִ֑ים אֲשֶׁ֖ר עָשָׂ֣ה לְנַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 17,
      "referenceLabel": "Psalms 66:17",
      "text": "אֵלָ֥יו פִּֽי ־ קָרָ֑אתִי וְ֝רוֹמַ֗ם תַּ֣חַת לְשׁוֹנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 18,
      "referenceLabel": "Psalms 66:18",
      "text": "אָ֭וֶן אִם ־ רָאִ֣יתִי בְלִבִּ֑י לֹ֖א יִשְׁמַ֣ע ׀ אֲדֹנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 19,
      "referenceLabel": "Psalms 66:19",
      "text": "אָ֭כֵן שָׁמַ֣ע אֱלֹהִ֑ים הִ֝קְשִׁ֗יב בְּק֣וֹל תְּפִלָּתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.66.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 20,
      "referenceLabel": "Psalms 66:20",
      "text": "בָּר֥וּךְ אֱלֹהִ֑ים אֲשֶׁ֥ר לֹֽא ־ הֵסִ֘יר תְּפִלָּתִ֥י וְ֝חַסְדּ֗וֹ מֵאִתִּֽי ׃",
      "paragraphStart": false
    }
  ]
}
