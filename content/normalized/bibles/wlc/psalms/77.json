{
  "chapter": {
    "id": "wlc:psalms.77",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 77,
    "referenceLabel": "Psalms 77",
    "summary": "Source text for Psalms 77 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.77.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 1,
      "referenceLabel": "Psalms 77:1",
      "text": "לַמְנַצֵּ֥חַ עַֽל ־ ידיתון לְאָסָ֥ף מִזְמֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.77.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 2,
      "referenceLabel": "Psalms 77:2",
      "text": "קוֹלִ֣י אֶל ־ אֱלֹהִ֣ים וְאֶצְעָ֑קָה קוֹלִ֥י אֶל ־ אֱ֝לֹהִ֗ים וְהַאֲזִ֥ין אֵלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 3,
      "referenceLabel": "Psalms 77:3",
      "text": "בְּי֥וֹם צָרָתִי֮ אֲדֹנָ֪י דָּ֫רָ֥שְׁתִּי יָדִ֤י ׀ לַ֣יְלָה נִ֭גְּרָה וְלֹ֣א תָפ֑וּג מֵאֲנָ֖ה הִנָּחֵ֣ם נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 4,
      "referenceLabel": "Psalms 77:4",
      "text": "אֶזְכְּרָ֣ה אֱלֹהִ֣ים וְאֶֽהֱמָיָ֑ה אָשִׂ֓יחָה ׀ וְתִתְעַטֵּ֖ף רוּחִ֣י סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 5,
      "referenceLabel": "Psalms 77:5",
      "text": "אָ֭חַזְתָּ שְׁמֻר֣וֹת עֵינָ֑י נִ֝פְעַ֗מְתִּי וְלֹ֣א אֲדַבֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 6,
      "referenceLabel": "Psalms 77:6",
      "text": "חִשַּׁ֣בְתִּי יָמִ֣ים מִקֶּ֑דֶם שְׁ֝נ֗וֹת עוֹלָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 7,
      "referenceLabel": "Psalms 77:7",
      "text": "אֶֽזְכְּרָ֥ה נְגִינָתִ֗י בַּ֫לָּ֥יְלָה עִם ־ לְבָבִ֥י אָשִׂ֑יחָה וַיְחַפֵּ֥שׂ רוּחִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 8,
      "referenceLabel": "Psalms 77:8",
      "text": "הַֽ֭לְעוֹלָמִים יִזְנַ֥ח ׀ אֲדֹנָ֑י וְלֹֽא ־ יֹסִ֖יף לִרְצ֣וֹת עֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 9,
      "referenceLabel": "Psalms 77:9",
      "text": "הֶאָפֵ֣ס לָנֶ֣צַח חַסְדּ֑וֹ גָּ֥מַר אֹ֝֗מֶר לְדֹ֣ר וָדֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 10,
      "referenceLabel": "Psalms 77:10",
      "text": "הֲשָׁכַ֣ח חַנּ֣וֹת אֵ֑ל אִם ־ קָפַ֥ץ בְּ֝אַ֗ף רַחֲמָ֥יו סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 11,
      "referenceLabel": "Psalms 77:11",
      "text": "וָ֭אֹמַר חַלּ֣וֹתִי הִ֑יא שְׁ֝נ֗וֹת יְמִ֣ין עֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 12,
      "referenceLabel": "Psalms 77:12",
      "text": "אזכיר מַֽעַלְלֵי ־ יָ֑הּ כִּֽי ־ אֶזְכְּרָ֖ה מִקֶּ֣דֶם פִּלְאֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 13,
      "referenceLabel": "Psalms 77:13",
      "text": "וְהָגִ֥יתִי בְכָל ־ פָּעֳלֶ֑ךָ וּֽבַעֲלִ֖ילוֹתֶ֣יךָ אָשִֽׂיחָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 14,
      "referenceLabel": "Psalms 77:14",
      "text": "אֱ֭לֹהִים בַּקֹּ֣דֶשׁ דַּרְכֶּ֑ךָ מִי ־ אֵ֥ל גָּ֝ד֗וֹל כֵּֽאלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 15,
      "referenceLabel": "Psalms 77:15",
      "text": "אַתָּ֣ה הָ֭אֵל עֹ֣שֵׂה פֶ֑לֶא הוֹדַ֖עְתָּ בָעַמִּ֣ים עֻזֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 16,
      "referenceLabel": "Psalms 77:16",
      "text": "גָּאַ֣לְתָּ בִּזְר֣וֹעַ עַמֶּ֑ךָ בְּנֵי ־ יַעֲקֹ֖ב וְיוֹסֵ֣ף סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 17,
      "referenceLabel": "Psalms 77:17",
      "text": "רָ֘א֤וּךָ מַּ֨יִם ׀ אֱֽלֹהִ֗ים רָא֣וּךָ מַּ֣יִם יָחִ֑ילוּ אַ֝֗ף יִרְגְּז֥וּ תְהֹמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 18,
      "referenceLabel": "Psalms 77:18",
      "text": "זֹ֤רְמוּ מַ֨יִם ׀ עָב֗וֹת ק֭וֹל נָתְנ֣וּ שְׁחָקִ֑ים אַף ־ חֲ֝צָצֶ֗יךָ יִתְהַלָּֽכוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 19,
      "referenceLabel": "Psalms 77:19",
      "text": "ק֤וֹל רַעַמְךָ֨ ׀ בַּגַּלְגַּ֗ל הֵאִ֣ירוּ בְרָקִ֣ים תֵּבֵ֑ל רָגְזָ֖ה וַתִּרְעַ֣שׁ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 20,
      "referenceLabel": "Psalms 77:20",
      "text": "בַּיָּ֤ם דַּרְכֶּ֗ךָ ושביליך בְּמַ֣יִם רַבִּ֑ים וְ֝עִקְּבוֹתֶ֗יךָ לֹ֣א נֹדָֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.77.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 21,
      "referenceLabel": "Psalms 77:21",
      "text": "נָחִ֣יתָ כַצֹּ֣אן עַמֶּ֑ךָ בְּֽיַד ־ מֹשֶׁ֥ה וְאַהֲרֹֽן ׃",
      "paragraphStart": false
    }
  ]
}
