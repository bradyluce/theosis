{
  "chapter": {
    "id": "wlc:psalms.46",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.46.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "לַמְנַצֵּ֥חַ לִבְנֵי ־ קֹ֑רַח עַֽל ־ עֲלָמ֥וֹת שִֽׁיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.46.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "אֱלֹהִ֣ים לָ֭נוּ מַחֲסֶ֣ה וָעֹ֑ז עֶזְרָ֥ה בְ֝צָר֗וֹת נִמְצָ֥א מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "עַל ־ כֵּ֣ן לֹא ־ נִ֭ירָא בְּהָמִ֣יר אָ֑רֶץ וּבְמ֥וֹט הָ֝רִ֗ים בְּלֵ֣ב יַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "יֶהֱמ֣וּ יֶחְמְר֣וּ מֵימָ֑יו יִֽרְעֲשֽׁוּ ־ הָרִ֖ים בְּגַאֲוָת֣וֹ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "נָהָ֗ר פְּלָגָ֗יו יְשַׂמְּח֥וּ עִיר ־ אֱלֹהִ֑ים קְ֝דֹ֗שׁ מִשְׁכְּנֵ֥י עֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "אֱלֹהִ֣ים בְּ֭קִרְבָּהּ בַּל ־ תִּמּ֑וֹט יַעְזְרֶ֥הָ אֱ֝לֹהִ֗ים לִפְנ֥וֹת בֹּֽקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "הָמ֣וּ ג֭וֹיִם מָ֣טוּ מַמְלָכ֑וֹת נָתַ֥ן בְּ֝קוֹל֗וֹ תָּמ֥וּג אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "יְהוָ֣ה צְבָא֣וֹת עִמָּ֑נוּ מִשְׂגָּֽב ־ לָ֝נוּ אֱלֹהֵ֖י יַעֲקֹ֣ב סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "לְֽכוּ ־ חֲ֭זוּ מִפְעֲל֣וֹת יְהוָ֑ה אֲשֶׁר ־ שָׂ֖ם שַׁמּ֣וֹת בָּאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "מַשְׁבִּ֥ית מִלְחָמוֹת֮ עַד ־ קְצֵ֪ה הָ֫אָ֥רֶץ קֶ֣שֶׁת יְ֭שַׁבֵּר וְקִצֵּ֣ץ חֲנִ֑ית עֲ֝גָל֗וֹת יִשְׂרֹ֥ף בָּאֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Psalms 46:11",
      "text": "הַרְפּ֣וּ וּ֭דְעוּ כִּי ־ אָנֹכִ֣י אֱלֹהִ֑ים אָר֥וּם בַּ֝גּוֹיִ֗ם אָר֥וּם בָּאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.46.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 12,
      "referenceLabel": "Psalms 46:12",
      "text": "יְהוָ֣ה צְבָא֣וֹת עִמָּ֑נוּ מִשְׂגָּֽב ־ לָ֝נוּ אֱלֹהֵ֖י יַעֲקֹ֣ב סֶֽלָה ׃",
      "paragraphStart": false
    }
  ]
}
