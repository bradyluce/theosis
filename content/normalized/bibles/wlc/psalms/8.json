{
  "chapter": {
    "id": "wlc:psalms.8",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.8.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "לַמְנַצֵּ֥חַ עַֽל ־ הַגִּתִּ֗ית מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.8.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "יְהוָ֤ה אֲדֹנֵ֗ינוּ מָֽה ־ אַדִּ֣יר שִׁ֭מְךָ בְּכָל ־ הָאָ֑רֶץ אֲשֶׁ֥ר תְּנָ֥ה ה֝וֹדְךָ֗ עַל ־ הַשָּׁמָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "מִפִּ֤י עֽוֹלְלִ֨ים ׀ וְֽיֹנְקִים֮ יִסַּ֪דְתָּ֫ עֹ֥ז לְמַ֥עַן צוֹרְרֶ֑יךָ לְהַשְׁבִּ֥ית א֝וֹיֵ֗ב וּמִתְנַקֵּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "כִּֽי ־ אֶרְאֶ֣ה שָׁ֭מֶיךָ מַעֲשֵׂ֣י אֶצְבְּעֹתֶ֑יךָ יָרֵ֥חַ וְ֝כוֹכָבִ֗ים אֲשֶׁ֣ר כּוֹנָֽנְתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "מָֽה ־ אֱנ֥וֹשׁ כִּֽי ־ תִזְכְּרֶ֑נּוּ וּבֶן ־ אָ֝דָ֗ם כִּ֣י תִפְקְדֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "וַתְּחַסְּרֵ֣הוּ מְּ֭עַט מֵאֱלֹהִ֑ים וְכָב֖וֹד וְהָדָ֣ר תְּעַטְּרֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "תַּ֭מְשִׁילֵהוּ בְּמַעֲשֵׂ֣י יָדֶ֑יךָ כֹּ֝ל שַׁ֣תָּה תַֽחַת ־ רַגְלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "צֹנֶ֣ה וַאֲלָפִ֣ים כֻּלָּ֑ם וְ֝גַ֗ם בַּהֲמ֥וֹת שָׂדָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "צִפּ֣וֹר שָׁ֭מַיִם וּדְגֵ֣י הַיָּ֑ם עֹ֝בֵ֗ר אָרְח֥וֹת יַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.8.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Psalms 8:10",
      "text": "יְהוָ֥ה אֲדֹנֵ֑ינוּ מָֽה ־ אַדִּ֥יר שִׁ֝מְךָ֗ בְּכָל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
}
