{
  "chapter": {
    "id": "wlc:psalms.91",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.91.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 1,
      "referenceLabel": "Psalms 91:1",
      "text": "יֹ֭שֵׁב בְּסֵ֣תֶר עֶלְי֑וֹן בְּצֵ֥ל שַׁ֝דַּ֗י יִתְלוֹנָֽן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.91.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "אֹמַ֗ר לַֽ֭יהוָה מַחְסִ֣י וּמְצוּדָתִ֑י אֱ֝לֹהַ֗י אֶבְטַח ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "כִּ֤י ה֣וּא יַ֭צִּֽילְךָ מִפַּ֥ח יָק֗וּשׁ מִדֶּ֥בֶר הַוּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "בְּאֶבְרָת֨וֹ ׀ יָ֣סֶךְ לָ֭ךְ וְתַֽחַת ־ כְּנָפָ֣יו תֶּחְסֶ֑ה צִנָּ֖ה וְֽסֹחֵרָ֣ה אֲמִתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "לֹא ־ תִ֭ירָא מִפַּ֣חַד לָ֑יְלָה מֵ֝חֵ֗ץ יָע֥וּף יוֹמָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "מִ֭דֶּבֶר בָּאֹ֣פֶל יַהֲלֹ֑ךְ מִ֝קֶּ֗טֶב יָשׁ֥וּד צָהֳרָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "יִפֹּ֤ל מִצִּדְּךָ֨ ׀ אֶ֗לֶף וּרְבָבָ֥ה מִימִינֶ֑ךָ אֵ֝לֶ֗יךָ לֹ֣א יִגָּֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "רַ֭ק בְּעֵינֶ֣יךָ תַבִּ֑יט וְשִׁלֻּמַ֖ת רְשָׁעִ֣ים תִּרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "כִּֽי ־ אַתָּ֣ה יְהוָ֣ה מַחְסִ֑י עֶ֝לְי֗וֹן שַׂ֣מְתָּ מְעוֹנֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "לֹֽא ־ תְאֻנֶּ֣ה אֵלֶ֣יךָ רָעָ֑ה וְ֝נֶ֗גַע לֹא ־ יִקְרַ֥ב בְּאָהֳלֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "כִּ֣י מַ֭לְאָכָיו יְצַוֶּה ־ לָּ֑ךְ לִ֝שְׁמָרְךָ֗ בְּכָל ־ דְּרָכֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "עַל ־ כַּפַּ֥יִם יִשָּׂא֑וּנְךָ פֶּן ־ תִּגֹּ֖ף בָּאֶ֣בֶן רַגְלֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "עַל ־ שַׁ֣חַל וָפֶ֣תֶן תִּדְרֹ֑ךְ תִּרְמֹ֖ס כְּפִ֣יר וְתַנִּֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "כִּ֤י בִ֣י חָ֭שַׁק וַאֲפַלְּטֵ֑הוּ אֲ֝שַׂגְּבֵ֗הוּ כִּֽי ־ יָדַ֥ע שְׁמִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "יִקְרָאֵ֨נִי ׀ וְֽאֶעֱנֵ֗הוּ עִמּֽוֹ ־ אָנֹכִ֥י בְצָרָ֑ה אֲ֝חַלְּצֵ֗הוּ וַֽאֲכַבְּדֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.91.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "אֹ֣רֶךְ יָ֭מִים אַשְׂבִּיעֵ֑הוּ וְ֝אַרְאֵ֗הוּ בִּֽישׁוּעָתִֽי ׃",
      "paragraphStart": false
    }
  ]
}
