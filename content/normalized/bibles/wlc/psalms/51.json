{
  "chapter": {
    "id": "wlc:psalms.51",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.51.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.51.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "בְּֽבוֹא ־ אֵ֭לָיו נָתָ֣ן הַנָּבִ֑יא כַּֽאֲשֶׁר ־ בָּ֝֗א אֶל ־ בַּת ־ שָֽׁבַע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "חָנֵּ֣נִי אֱלֹהִ֣ים כְּחַסְדֶּ֑ךָ כְּרֹ֥ב רַ֝חֲמֶ֗יךָ מְחֵ֣ה פְשָׁעָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "הרבה כַּבְּסֵ֣נִי מֵעֲוֺנִ֑י וּֽמֵחַטָּאתִ֥י טַהֲרֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "כִּֽי ־ פְ֭שָׁעַי אֲנִ֣י אֵדָ֑ע וְחַטָּאתִ֖י נֶגְדִּ֣י תָמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "לְךָ֤ לְבַדְּךָ֨ ׀ חָטָאתִי֮ וְהָרַ֥ע בְּעֵינֶ֗יךָ עָ֫שִׂ֥יתִי לְ֭מַעַן תִּצְדַּ֥ק בְּדָבְרֶ֗ךָ תִּזְכֶּ֥ה בְשָׁפְטֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "הֵן ־ בְּעָו֥וֹן חוֹלָ֑לְתִּי וּ֝בְחֵ֗טְא יֶֽחֱמַ֥תְנִי אִמִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "הֵן ־ אֱ֭מֶת חָפַ֣צְתָּ בַטֻּח֑וֹת וּ֝בְסָתֻ֗ם חָכְמָ֥ה תוֹדִיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "תְּחַטְּאֵ֣נִי בְאֵז֣וֹב וְאֶטְהָ֑ר תְּ֝כַבְּסֵ֗נִי וּמִשֶּׁ֥לֶג אַלְבִּֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "תַּ֭שְׁמִיעֵנִי שָׂשׂ֣וֹן וְשִׂמְחָ֑ה תָּ֝גֵ֗לְנָה עֲצָמ֥וֹת דִּכִּֽיתָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "הַסְתֵּ֣ר פָּ֭נֶיךָ מֵחֲטָאָ֑י וְֽכָל ־ עֲוֺ֖נֹתַ֣י מְחֵֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 12,
      "referenceLabel": "Psalms 51:12",
      "text": "לֵ֣ב טָ֭הוֹר בְּרָא ־ לִ֣י אֱלֹהִ֑ים וְר֥וּחַ נָ֝כ֗וֹן חַדֵּ֥שׁ בְּקִרְבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 13,
      "referenceLabel": "Psalms 51:13",
      "text": "אַל ־ תַּשְׁלִיכֵ֥נִי מִלְּפָנֶ֑יךָ וְר֥וּחַ קָ֝דְשְׁךָ֗ אַל ־ תִּקַּ֥ח מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 14,
      "referenceLabel": "Psalms 51:14",
      "text": "הָשִׁ֣יבָה לִּ֭י שְׂשׂ֣וֹן יִשְׁעֶ֑ךָ וְר֖וּחַ נְדִיבָ֣ה תִסְמְכֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 15,
      "referenceLabel": "Psalms 51:15",
      "text": "אֲלַמְּדָ֣ה פֹשְׁעִ֣ים דְּרָכֶ֑יךָ וְ֝חַטָּאִ֗ים אֵלֶ֥יךָ יָשֽׁוּבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 16,
      "referenceLabel": "Psalms 51:16",
      "text": "הַצִּ֘ילֵ֤נִי מִדָּמִ֨ים ׀ אֱֽלֹהִ֗ים אֱלֹהֵ֥י תְּשׁוּעָתִ֑י תְּרַנֵּ֥ן לְ֝שׁוֹנִ֗י צִדְקָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 17,
      "referenceLabel": "Psalms 51:17",
      "text": "אֲ֭דֹנָי שְׂפָתַ֣י תִּפְתָּ֑ח וּ֝פִ֗י יַגִּ֥יד תְּהִלָּתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 18,
      "referenceLabel": "Psalms 51:18",
      "text": "כִּ֤י ׀ לֹא ־ תַחְפֹּ֣ץ זֶ֣בַח וְאֶתֵּ֑נָה ע֝וֹלָ֗ה לֹ֣א תִרְצֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 19,
      "referenceLabel": "Psalms 51:19",
      "text": "זִֽבְחֵ֣י אֱלֹהִים֮ ר֪וּחַ נִשְׁבָּ֫רָ֥ה לֵב ־ נִשְׁבָּ֥ר וְנִדְכֶּ֑ה אֱ֝לֹהִ֗ים לֹ֣א תִבְזֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 20,
      "referenceLabel": "Psalms 51:20",
      "text": "הֵיטִ֣יבָה בִ֭רְצוֹנְךָ אֶת ־ צִיּ֑וֹן תִּ֝בְנֶ֗ה חוֹמ֥וֹת יְרוּשָׁלִָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.51.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 21,
      "referenceLabel": "Psalms 51:21",
      "text": "אָ֤ז תַּחְפֹּ֣ץ זִבְחֵי ־ צֶ֭דֶק עוֹלָ֣ה וְכָלִ֑יל אָ֤ז יַעֲל֖וּ עַל ־ מִזְבַּחֲךָ֣ פָרִֽים ׃",
      "paragraphStart": false
    }
  ]
}
