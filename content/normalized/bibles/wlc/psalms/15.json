  },
  "verses": [
    {
      "id": "wlc:psalms.15.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Psalms 15:1",
      "text": "מִזְמ֗וֹר לְדָ֫וִ֥ד יְ֭הֹוָה מִי ־ יָג֣וּר בְּאָהֳלֶ֑ךָ מִֽי ־ יִ֝שְׁכֹּ֗ן בְּהַ֣ר קָדְשֶֽׁךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.15.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Psalms 15:2",
      "text": "הוֹלֵ֣ךְ תָּ֭מִים וּפֹעֵ֥ל צֶ֑דֶק וְדֹבֵ֥ר אֱ֝מֶ֗ת בִּלְבָבֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.15.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Psalms 15:3",
      "text": "לֹֽא ־ רָגַ֨ל ׀ עַל ־ לְשֹׁנ֗וֹ לֹא ־ עָשָׂ֣ה לְרֵעֵ֣הוּ רָעָ֑ה וְ֝חֶרְפָּ֗ה לֹא ־ נָשָׂ֥א עַל ־ קְרֹֽבוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.15.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Psalms 15:4",
      "text": "נִבְזֶ֤ה ׀ בְּֽעֵ֘ינָ֤יו נִמְאָ֗ס וְאֶת ־ יִרְאֵ֣י יְהוָ֣ה יְכַבֵּ֑ד נִשְׁבַּ֥ע לְ֝הָרַ֗ע וְלֹ֣א יָמִֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.15.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Psalms 15:5",
      "text": "כַּסְפּ֤וֹ ׀ לֹא ־ נָתַ֣ן בְּנֶשֶׁךְ֮ וְשֹׁ֥חַד עַל ־ נָקִ֗י לֹ֥א לָ֫קָ֥ח עֹֽשֵׂה ־ אֵ֑לֶּה לֹ֖א יִמּ֣וֹט לְעוֹלָֽם ׃",
      "paragraphStart": false
    }
  ]
}
