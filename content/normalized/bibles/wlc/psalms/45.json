{
  "chapter": {
    "id": "wlc:psalms.45",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 45,
    "referenceLabel": "Psalms 45",
    "summary": "Source text for Psalms 45 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.45.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 1,
      "referenceLabel": "Psalms 45:1",
      "text": "לַמְנַצֵּ֣חַ עַל ־ שֹׁ֭שַׁנִּים לִבְנֵי ־ קֹ֑רַח מַ֝שְׂכִּ֗יל שִׁ֣יר יְדִידֹֽת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.45.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 2,
      "referenceLabel": "Psalms 45:2",
      "text": "רָ֘חַ֤שׁ לִבִּ֨י ׀ דָּ֘בָ֤ר ט֗וֹב אֹמֵ֣ר אָ֭נִי מַעֲשַׂ֣י לְמֶ֑לֶךְ לְ֝שׁוֹנִ֗י עֵ֤ט ׀ סוֹפֵ֬ר מָהִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 3,
      "referenceLabel": "Psalms 45:3",
      "text": "יָפְיָפִ֡יתָ מִבְּנֵ֬י אָדָ֗ם ה֣וּצַק חֵ֭ן בְּשְׂפְתוֹתֶ֑יךָ עַל ־ כֵּ֤ן בֵּֽרַכְךָ֖ אֱלֹהִ֣ים לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 4,
      "referenceLabel": "Psalms 45:4",
      "text": "חֲגֽוֹר ־ חַרְבְּךָ֣ עַל ־ יָרֵ֣ךְ גִּבּ֑וֹר ה֝וֹדְךָ֗ וַהֲדָרֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 5,
      "referenceLabel": "Psalms 45:5",
      "text": "וַהֲדָ֬רְךָ֨ ׀ צְלַ֬ח רְכַ֗ב עַֽל ־ דְּבַר ־ אֱ֭מֶת וְעַנְוָה ־ צֶ֑דֶק וְתוֹרְךָ֖ נוֹרָא֣וֹת יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 6,
      "referenceLabel": "Psalms 45:6",
      "text": "חִצֶּ֗יךָ שְׁנ֫וּנִ֥ים עַ֭מִּים תַּחְתֶּ֣יךָ יִפְּל֑וּ בְּ֝לֵ֗ב אוֹיְבֵ֥י הַמֶּֽלֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 7,
      "referenceLabel": "Psalms 45:7",
      "text": "כִּסְאֲךָ֣ אֱ֭לֹהִים עוֹלָ֣ם וָעֶ֑ד שֵׁ֥בֶט מִ֝ישֹׁ֗ר שֵׁ֣בֶט מַלְכוּתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 8,
      "referenceLabel": "Psalms 45:8",
      "text": "אָהַ֣בְתָּ צֶּדֶק֮ וַתִּשְׂנָ֫א רֶ֥שַׁע עַל ־ כֵּ֤ן ׀ מְשָׁחֲךָ֡ אֱלֹהִ֣ים אֱ֭לֹהֶיךָ שֶׁ֥מֶן שָׂשׂ֗וֹן מֵֽחֲבֵרֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 9,
      "referenceLabel": "Psalms 45:9",
      "text": "מֹר ־ וַאֲהָל֣וֹת קְ֭צִיעוֹת כָּל ־ בִּגְדֹתֶ֑יךָ מִֽן ־ הֵ֥יכְלֵי שֵׁ֝֗ן מִנִּ֥י שִׂמְּחֽוּךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 10,
      "referenceLabel": "Psalms 45:10",
      "text": "בְּנ֣וֹת מְ֭לָכִים בְּיִקְּרוֹתֶ֑יךָ נִצְּבָ֥ה שֵׁגַ֥ל לִֽ֝ימִינְךָ֗ בְּכֶ֣תֶם אוֹפִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 11,
      "referenceLabel": "Psalms 45:11",
      "text": "שִׁמְעִי ־ בַ֣ת וּ֭רְאִי וְהַטִּ֣י אָזְנֵ֑ךְ וְשִׁכְחִ֥י עַ֝מֵּ֗ךְ וּבֵ֥ית אָבִֽיךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 12,
      "referenceLabel": "Psalms 45:12",
      "text": "וְיִתְאָ֣ו הַמֶּ֣לֶךְ יָפְיֵ֑ךְ כִּי ־ ה֥וּא אֲ֝דֹנַ֗יִךְ וְהִשְׁתַּֽחֲוִי ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 13,
      "referenceLabel": "Psalms 45:13",
      "text": "וּבַֽת ־ צֹ֨ר ׀ בְּ֭מִנְחָה פָּנַ֥יִךְ יְחַלּ֗וּ עֲשִׁ֣ירֵי עָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 14,
      "referenceLabel": "Psalms 45:14",
      "text": "כָּל ־ כְּבוּדָּ֣ה בַת ־ מֶ֣לֶךְ פְּנִ֑ימָה מִֽמִּשְׁבְּצ֖וֹת זָהָ֣ב לְבוּשָֽׁהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 15,
      "referenceLabel": "Psalms 45:15",
      "text": "לִרְקָמוֹת֮ תּוּבַ֪ל לַ֫מֶּ֥לֶךְ בְּתוּל֣וֹת אַ֭חֲרֶיהָ רֵעוֹתֶ֑יהָ מ֖וּבָא֣וֹת לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 16,
      "referenceLabel": "Psalms 45:16",
      "text": "תּ֭וּבַלְנָה בִּשְׂמָחֹ֣ת וָגִ֑יל תְּ֝בֹאֶ֗ינָה בְּהֵ֣יכַל מֶֽלֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 17,
      "referenceLabel": "Psalms 45:17",
      "text": "תַּ֣חַת אֲ֭בֹתֶיךָ יִהְי֣וּ בָנֶ֑יךָ תְּשִׁיתֵ֥מוֹ לְ֝שָׂרִ֗ים בְּכָל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.45.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 18,
      "referenceLabel": "Psalms 45:18",
      "text": "אַזְכִּ֣ירָה שִׁ֭מְךָ בְּכָל ־ דֹּ֣ר וָדֹ֑ר עַל ־ כֵּ֥ן עַמִּ֥ים יְ֝הוֹדֻ֗ךָ לְעֹלָ֥ם וָעֶֽד ׃",
      "paragraphStart": false
    }
  ]
}
