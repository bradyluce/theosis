  },
  "verses": [
    {
      "id": "wlc:psalms.126.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 1,
      "referenceLabel": "Psalms 126:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת בְּשׁ֣וּב יְ֭הוָה אֶת ־ שִׁיבַ֣ת צִיּ֑וֹן הָ֝יִ֗ינוּ כְּחֹלְמִֽים ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.126.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 2,
      "referenceLabel": "Psalms 126:2",
      "text": "אָ֤ז יִמָּלֵ֪א שְׂח֡וֹק פִּינוּ֮ וּלְשׁוֹנֵ֪נוּ רִ֫נָּ֥ה אָ֭ז יֹאמְר֣וּ בַגּוֹיִ֑ם הִגְדִּ֥יל יְ֝הוָ֗ה לַעֲשׂ֥וֹת עִם ־ אֵֽלֶּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.126.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 3,
      "referenceLabel": "Psalms 126:3",
      "text": "הִגְדִּ֣יל יְ֭הוָה לַעֲשׂ֥וֹת עִמָּ֗נוּ הָיִ֥ינוּ שְׂמֵחִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.126.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 4,
      "referenceLabel": "Psalms 126:4",
      "text": "שׁוּבָ֣ה יְ֭הוָה אֶת ־ שבותנו כַּאֲפִיקִ֥ים בַּנֶּֽגֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.126.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 5,
      "referenceLabel": "Psalms 126:5",
      "text": "הַזֹּרְעִ֥ים בְּדִמְעָ֗ה בְּרִנָּ֥ה יִקְצֹֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.126.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 6,
      "referenceLabel": "Psalms 126:6",
      "text": "הָ֘ל֤וֹךְ יֵלֵ֨ךְ ׀ וּבָכֹה֮ נֹשֵׂ֪א מֶֽשֶׁךְ ־ הַ֫זָּ֥רַע בֹּֽ֬א ־ יָב֥וֹא בְרִנָּ֑ה נֹ֝שֵׂ֗א אֲלֻמֹּתָֽיו ׃",
      "paragraphStart": false
    }
  ]
}
