  },
  "verses": [
    {
      "id": "wlc:psalms.125.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 1,
      "referenceLabel": "Psalms 125:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת הַבֹּטְחִ֥ים בַּיהוָ֑ה כְּֽהַר ־ צִיּ֥וֹן לֹא ־ יִ֝מּ֗וֹט לְעוֹלָ֥ם יֵשֵֽׁב ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.125.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 2,
      "referenceLabel": "Psalms 125:2",
      "text": "יְֽרוּשָׁלִַ֗ם הָרִים֮ סָבִ֪יב לָ֥הּ וַ֭יהוָה סָבִ֣יב לְעַמּ֑וֹ מֵ֝עַתָּ֗ה וְעַד ־ עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.125.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 3,
      "referenceLabel": "Psalms 125:3",
      "text": "כִּ֤י לֹ֪א יָנ֡וּחַ שֵׁ֤בֶט הָרֶ֗שַׁע עַל֮ גּוֹרַ֪ל הַֽצַּדִּ֫יקִ֥ים לְמַ֡עַן לֹא ־ יִשְׁלְח֖וּ הַצַּדִּיקִ֨ים בְּעַוְלָ֬תָה יְדֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.125.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 4,
      "referenceLabel": "Psalms 125:4",
      "text": "הֵיטִ֣יבָה יְ֭הוָה לַטּוֹבִ֑ים וְ֝לִֽישָׁרִ֗ים בְּלִבּוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.125.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 5,
      "referenceLabel": "Psalms 125:5",
      "text": "וְהַמַּטִּ֤ים עַֽקַלְקַלּוֹתָ֗ם יוֹלִיכֵ֣ם יְ֭הוָה אֶת ־ פֹּעֲלֵ֣י הָאָ֑וֶן שָׁ֝ל֗וֹם עַל ־ יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    }
  ]
}
