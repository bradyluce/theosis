{
  "chapter": {
    "id": "wlc:psalms.142",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 142,
    "referenceLabel": "Psalms 142",
    "summary": "Source text for Psalms 142 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.142.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 1,
      "referenceLabel": "Psalms 142:1",
      "text": "מַשְׂכִּ֥יל לְדָוִ֑ד בִּהְיוֹת֖וֹ בַמְּעָרָ֣ה תְפִלָּֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.142.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 2,
      "referenceLabel": "Psalms 142:2",
      "text": "ק֭וֹלִי אֶל ־ יְהוָ֣ה אֶזְעָ֑ק ק֝וֹלִ֗י אֶל ־ יְהוָ֥ה אֶתְחַנָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.142.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 3,
      "referenceLabel": "Psalms 142:3",
      "text": "אֶשְׁפֹּ֣ךְ לְפָנָ֣יו שִׂיחִ֑י צָ֝רָתִ֗י לְפָנָ֥יו אַגִּֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.142.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 4,
      "referenceLabel": "Psalms 142:4",
      "text": "בְּהִתְעַטֵּ֬ף עָלַ֨י ׀ רוּחִ֗י וְאַתָּה֮ יָדַ֪עְתָּ נְֽתִיבָ֫תִ֥י בְּאֹֽרַח ־ ז֥וּ אֲהַלֵּ֑ךְ טָמְנ֖וּ פַ֣ח לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.142.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 5,
      "referenceLabel": "Psalms 142:5",
      "text": "הַבֵּ֤יט יָמִ֨ין ׀ וּרְאֵה֮ וְאֵֽין ־ לִ֪י מַ֫כִּ֥יר אָבַ֣ד מָנ֣וֹס מִמֶּ֑נִּי אֵ֖ין דּוֹרֵ֣שׁ לְנַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.142.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 6,
      "referenceLabel": "Psalms 142:6",
      "text": "זָעַ֥קְתִּי אֵלֶ֗יךָ יְה֫וָ֥ה אָ֭מַרְתִּי אַתָּ֣ה מַחְסִ֑י חֶ֝לְקִ֗י בְּאֶ֣רֶץ הַֽחַיִּים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.142.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 7,
      "referenceLabel": "Psalms 142:7",
      "text": "הַקְשִׁ֤יבָה ׀ אֶֽל ־ רִנָּתִי֮ כִּֽי ־ דַלּ֪וֹתִ֫י מְאֹ֥ד הַצִּילֵ֥נִי מֵרֹדְפַ֑י כִּ֖י אָמְצ֣וּ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.142.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 8,
      "referenceLabel": "Psalms 142:8",
      "text": "ה֘וֹצִ֤יאָה מִמַּסְגֵּ֨ר ׀ נַפְשִׁי֮ לְהוֹד֪וֹת אֶת ־ שְׁ֫מֶ֥ךָ בִּ֭י יַכְתִּ֣רוּ צַדִּיקִ֑ים כִּ֖י תִגְמֹ֣ל עָלָֽי ׃",
      "paragraphStart": false
    }
  ]
}
