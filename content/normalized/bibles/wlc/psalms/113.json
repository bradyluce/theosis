{
  "chapter": {
    "id": "wlc:psalms.113",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.113.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ הַ֭לְלוּ עַבְדֵ֣י יְהוָ֑ה הַֽ֝לְלוּ אֶת ־ שֵׁ֥ם יְהוָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.113.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "יְהִ֤י שֵׁ֣ם יְהוָ֣ה מְבֹרָ֑ךְ מֵֽ֝עַתָּ֗ה וְעַד ־ עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "מִמִּזְרַח ־ שֶׁ֥מֶשׁ עַד ־ מְבוֹא֑וֹ מְ֝הֻלָּ֗ל שֵׁ֣ם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "רָ֖ם עַל ־ כָּל ־ גּוֹיִ֥ם ׀ יְהוָ֑ה עַ֖ל הַשָּׁמַ֣יִם כְּבוֹדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "מִ֭י כַּיהוָ֣ה אֱלֹהֵ֑ינוּ הַֽמַּגְבִּיהִ֥י לָשָֽׁבֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "הַֽמַּשְׁפִּילִ֥י לִרְא֑וֹת בַּשָּׁמַ֥יִם וּבָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "מְקִֽימִ֣י מֵעָפָ֣ר דָּ֑ל מֵֽ֝אַשְׁפֹּ֗ת יָרִ֥ים אֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "לְהוֹשִׁיבִ֥י עִם ־ נְדִיבִ֑ים עִ֝֗ם נְדִיבֵ֥י עַמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.113.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "מֽוֹשִׁיבִ֨י ׀ עֲקֶ֬רֶת הַבַּ֗יִת אֵֽם ־ הַבָּנִ֥ים שְׂמֵחָ֗ה הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
