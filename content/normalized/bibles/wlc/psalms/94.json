{
  "chapter": {
    "id": "wlc:psalms.94",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.94.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "אֵל ־ נְקָמ֥וֹת יְהוָ֑ה אֵ֖ל נְקָמ֣וֹת הוֹפִֽיַע ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.94.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "הִ֭נָּשֵׂא שֹׁפֵ֣ט הָאָ֑רֶץ הָשֵׁ֥ב גְּ֝מ֗וּל עַל ־ גֵּאִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "עַד ־ מָתַ֖י רְשָׁעִ֥ים ׀ יְהוָ֑ה עַד ־ מָ֝תַ֗י רְשָׁעִ֥ים יַעֲלֹֽזוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "יַבִּ֣יעוּ יְדַבְּר֣וּ עָתָ֑ק יִֽ֝תְאַמְּר֗וּ כָּל ־ פֹּ֥עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "עַמְּךָ֣ יְהוָ֣ה יְדַכְּא֑וּ וְֽנַחֲלָתְךָ֥ יְעַנּֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "אַ֭לְמָנָה וְגֵ֣ר יַהֲרֹ֑גוּ וִֽיתוֹמִ֣ים יְרַצֵּֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "וַ֭יֹּ֣אמְרוּ לֹ֣א יִרְאֶה ־ יָּ֑הּ וְלֹא ־ יָ֝בִ֗ין אֱלֹהֵ֥י יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "בִּ֭ינוּ בֹּעֲרִ֣ים בָּעָ֑ם וּ֝כְסִילִ֗ים מָתַ֥י תַּשְׂכִּֽילוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "הֲנֹ֣טַֽע אֹ֭זֶן הֲלֹ֣א יִשְׁמָ֑ע אִֽם ־ יֹ֥צֵֽר עַ֝֗יִן הֲלֹ֣א יַבִּֽיט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "הֲיֹסֵ֣ר גּ֭וֹיִם הֲלֹ֣א יוֹכִ֑יחַ הַֽמְלַמֵּ֖ד אָדָ֣ם דָּֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "יְֽהוָ֗ה יֹ֭דֵעַ מַחְשְׁב֣וֹת אָדָ֑ם כִּי ־ הֵ֥מָּה הָֽבֶל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 12,
      "referenceLabel": "Psalms 94:12",
      "text": "אַשְׁרֵ֤י ׀ הַגֶּ֣בֶר אֲשֶׁר ־ תְּיַסְּרֶ֣נּוּ יָּ֑הּ וּֽמִתּוֹרָתְךָ֥ תְלַמְּדֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 13,
      "referenceLabel": "Psalms 94:13",
      "text": "לְהַשְׁקִ֣יט ל֭וֹ מִ֣ימֵי רָ֑ע עַ֤ד יִכָּרֶ֖ה לָרָשָׁ֣ע שָֽׁחַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 14,
      "referenceLabel": "Psalms 94:14",
      "text": "כִּ֤י ׀ לֹא ־ יִטֹּ֣שׁ יְהוָ֣ה עַמּ֑וֹ וְ֝נַחֲלָת֗וֹ לֹ֣א יַעֲזֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 15,
      "referenceLabel": "Psalms 94:15",
      "text": "כִּֽי ־ עַד ־ צֶ֭דֶק יָשׁ֣וּב מִשְׁפָּ֑ט וְ֝אַחֲרָ֗יו כָּל ־ יִשְׁרֵי ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 16,
      "referenceLabel": "Psalms 94:16",
      "text": "מִֽי ־ יָק֣וּם לִ֭י עִם ־ מְרֵעִ֑ים מִֽי ־ יִתְיַצֵּ֥ב לִ֝י עִם ־ פֹּ֥עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 17,
      "referenceLabel": "Psalms 94:17",
      "text": "לוּלֵ֣י יְ֭הוָה עֶזְרָ֣תָה לִּ֑י כִּמְעַ֓ט ׀ שָֽׁכְנָ֖ה דוּמָ֣ה נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 18,
      "referenceLabel": "Psalms 94:18",
      "text": "אִם ־ אָ֭מַרְתִּי מָ֣טָה רַגְלִ֑י חַסְדְּךָ֥ יְ֝הוָ֗ה יִסְעָדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 19,
      "referenceLabel": "Psalms 94:19",
      "text": "בְּרֹ֣ב שַׂרְעַפַּ֣י בְּקִרְבִּ֑י תַּ֝נְחוּמֶ֗יךָ יְֽשַׁעַשְׁע֥וּ נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 20,
      "referenceLabel": "Psalms 94:20",
      "text": "הַֽ֭יְחָבְרְךָ כִּסֵּ֣א הַוּ֑וֹת יֹצֵ֖ר עָמָ֣ל עֲלֵי ־ חֹֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 21,
      "referenceLabel": "Psalms 94:21",
      "text": "יָ֭גוֹדּוּ עַל ־ נֶ֣פֶשׁ צַדִּ֑יק וְדָ֖ם נָקִ֣י יַרְשִֽׁיעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 22,
      "referenceLabel": "Psalms 94:22",
      "text": "וַיְהִ֬י יְהוָ֣ה לִ֣י לְמִשְׂגָּ֑ב וֵ֝אלֹהַ֗י לְצ֣וּר מַחְסִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.94.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 23,
      "referenceLabel": "Psalms 94:23",
      "text": "וַיָּ֤שֶׁב עֲלֵיהֶ֨ם ׀ אֶת ־ אוֹנָ֗ם וּבְרָעָתָ֥ם יַצְמִיתֵ֑ם יַ֝צְמִיתֵ֗ם יְהוָ֥ה אֱלֹהֵֽינוּ ׃",
      "paragraphStart": false
    }
  ]
}
