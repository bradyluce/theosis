{
  "chapter": {
    "id": "wlc:psalms.83",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 83,
    "referenceLabel": "Psalms 83",
    "summary": "Source text for Psalms 83 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.83.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 1,
      "referenceLabel": "Psalms 83:1",
      "text": "שִׁ֖יר מִזְמ֣וֹר לְאָסָֽף ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.83.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 2,
      "referenceLabel": "Psalms 83:2",
      "text": "אֱלֹהִ֥ים אַל ־ דֳּמִי ־ לָ֑ךְ אַל ־ תֶּחֱרַ֖שׁ וְאַל ־ תִּשְׁקֹ֣ט אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 3,
      "referenceLabel": "Psalms 83:3",
      "text": "כִּֽי ־ הִנֵּ֣ה א֭וֹיְבֶיךָ יֶהֱמָי֑וּן וּ֝מְשַׂנְאֶ֗יךָ נָ֣שְׂאוּ רֹֽאשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 4,
      "referenceLabel": "Psalms 83:4",
      "text": "עַֽל ־ עַ֭מְּךָ יַעֲרִ֣ימוּ ס֑וֹד וְ֝יִתְיָעֲצ֗וּ עַל ־ צְפוּנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 5,
      "referenceLabel": "Psalms 83:5",
      "text": "אָמְר֗וּ לְ֭כוּ וְנַכְחִידֵ֣ם מִגּ֑וֹי וְלֹֽא ־ יִזָּכֵ֖ר שֵֽׁם ־ יִשְׂרָאֵ֣ל עֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 6,
      "referenceLabel": "Psalms 83:6",
      "text": "כִּ֤י נוֹעֲצ֣וּ לֵ֣ב יַחְדָּ֑ו עָ֝לֶ֗יךָ בְּרִ֣ית יִכְרֹֽתוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 7,
      "referenceLabel": "Psalms 83:7",
      "text": "אָהֳלֵ֣י אֱ֭דוֹם וְיִשְׁמְעֵאלִ֗ים מוֹאָ֥ב וְהַגְרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 8,
      "referenceLabel": "Psalms 83:8",
      "text": "גְּבָ֣ל וְ֭עַמּוֹן וַעֲמָלֵ֑ק פְּ֝לֶ֗שֶׁת עִם ־ יֹ֥שְׁבֵי צֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 9,
      "referenceLabel": "Psalms 83:9",
      "text": "גַּם ־ אַ֭שּׁוּר נִלְוָ֣ה עִמָּ֑ם הָ֤י֥וּ זְר֖וֹעַ לִבְנֵי ־ ל֣וֹט סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 10,
      "referenceLabel": "Psalms 83:10",
      "text": "עֲשֵֽׂה ־ לָהֶ֥ם כְּמִדְיָ֑ן כְּֽסִֽיסְרָ֥א כְ֝יָבִ֗ין בְּנַ֣חַל קִישֽׁוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 11,
      "referenceLabel": "Psalms 83:11",
      "text": "נִשְׁמְד֥וּ בְֽעֵין ־ דֹּ֑אר הָ֥יוּ דֹּ֝֗מֶן לָאֲדָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 12,
      "referenceLabel": "Psalms 83:12",
      "text": "שִׁיתֵ֣מוֹ נְ֭דִיבֵמוֹ כְּעֹרֵ֣ב וְכִזְאֵ֑ב וּֽכְזֶ֥בַח וּ֝כְצַלְמֻנָּ֗ע כָּל ־ נְסִיכֵֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 13,
      "referenceLabel": "Psalms 83:13",
      "text": "אֲשֶׁ֣ר אָ֭מְרוּ נִ֣ירֲשָׁה לָּ֑נוּ אֵ֝֗ת נְא֣וֹת אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 14,
      "referenceLabel": "Psalms 83:14",
      "text": "אֱֽלֹהַ֗י שִׁיתֵ֥מוֹ כַגַּלְגַּ֑ל כְּ֝קַ֗שׁ לִפְנֵי ־ רֽוּחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 15,
      "referenceLabel": "Psalms 83:15",
      "text": "כְּאֵ֥שׁ תִּבְעַר ־ יָ֑עַר וּ֝כְלֶהָבָ֗ה תְּלַהֵ֥ט הָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 16,
      "referenceLabel": "Psalms 83:16",
      "text": "כֵּ֭ן תִּרְדְּפֵ֣ם בְּסַעֲרֶ֑ךָ וּבְסוּפָתְךָ֥ תְבַהֲלֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 17,
      "referenceLabel": "Psalms 83:17",
      "text": "מַלֵּ֣א פְנֵיהֶ֣ם קָל֑וֹן וִֽיבַקְשׁ֖וּ שִׁמְךָ֣ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 18,
      "referenceLabel": "Psalms 83:18",
      "text": "יֵבֹ֖שׁוּ וְיִבָּהֲל֥וּ עֲדֵי ־ עַ֗ד וְֽיַחְפְּר֥וּ וְיֹאבֵֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.83.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 19,
      "referenceLabel": "Psalms 83:19",
      "text": "וְֽיֵדְע֗וּ כִּֽי ־ אַתָּ֬ה שִׁמְךָ֣ יְהוָ֣ה לְבַדֶּ֑ךָ עֶ֝לְי֗וֹן עַל ־ כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
}
