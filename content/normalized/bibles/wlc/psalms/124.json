{
  "chapter": {
    "id": "wlc:psalms.124",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.124.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "שִׁ֥יר הַֽמַּעֲל֗וֹת לְדָ֫וִ֥ד לוּלֵ֣י יְ֭הוָה שֶׁהָ֣יָה לָ֑נוּ יֹֽאמַר ־ נָ֝א יִשְׂרָאֵֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.124.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "לוּלֵ֣י יְ֭הוָה שֶׁהָ֣יָה לָ֑נוּ בְּק֖וּם עָלֵ֣ינוּ אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.124.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "אֲ֭זַי חַיִּ֣ים בְּלָע֑וּנוּ בַּחֲר֖וֹת אַפָּ֣ם בָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.124.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "אֲ֭זַי הַמַּ֣יִם שְׁטָפ֑וּנוּ נַ֗֜חְלָה עָבַ֥ר עַל ־ נַפְשֵֽׁנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.124.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "אֲ֭זַי עָבַ֣ר עַל ־ נַפְשֵׁ֑נוּ הַ֝מַּ֗יִם הַזֵּֽידוֹנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.124.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 6,
      "referenceLabel": "Psalms 124:6",
      "text": "בָּר֥וּךְ יְהוָ֑ה שֶׁלֹּ֥א נְתָנָ֥נוּ טֶ֝֗רֶף לְשִׁנֵּיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.124.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 7,
      "referenceLabel": "Psalms 124:7",
      "text": "נַפְשֵׁ֗נוּ כְּצִפּ֥וֹר נִמְלְטָה֮ מִפַּ֪ח י֫וֹקְשִׁ֥ים הַפַּ֥ח נִשְׁבָּ֗ר וַאֲנַ֥חְנוּ נִמְלָֽטְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.124.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 8,
      "referenceLabel": "Psalms 124:8",
      "text": "עֶ֭זְרֵנוּ בְּשֵׁ֣ם יְהוָ֑ה עֹ֝שֵׂ֗ה שָׁמַ֥יִם וָאָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
}
