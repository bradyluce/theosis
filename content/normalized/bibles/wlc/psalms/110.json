    "bookSlug": "psalms",
    "chapterNumber": 110,
    "referenceLabel": "Psalms 110",
    "summary": "Source text for Psalms 110 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.110.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 1,
      "referenceLabel": "Psalms 110:1",
      "text": "לְדָוִ֗ד מִ֫זְמ֥וֹר נְאֻ֤ם יְהוָ֨ה ׀ לַֽאדֹנִ֗י שֵׁ֥ב לִֽימִינִ֑י עַד ־ אָשִׁ֥ית אֹ֝יְבֶ֗יךָ הֲדֹ֣ם לְרַגְלֶֽיךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.110.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 2,
      "referenceLabel": "Psalms 110:2",
      "text": "מַטֵּֽה ־ עֻזְּךָ֗ יִשְׁלַ֣ח יְ֭הוָה מִצִּיּ֑וֹן רְ֝דֵ֗ה בְּקֶ֣רֶב אֹיְבֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.110.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 3,
      "referenceLabel": "Psalms 110:3",
      "text": "עַמְּךָ֣ נְדָבֹת֮ בְּי֪וֹם חֵ֫ילֶ֥ךָ בְּֽהַדְרֵי ־ קֹ֭דֶשׁ מֵרֶ֣חֶם מִשְׁחָ֑ר לְ֝ךָ֗ טַ֣ל יַלְדֻתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.110.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 4,
      "referenceLabel": "Psalms 110:4",
      "text": "נִשְׁבַּ֤ע יְהוָ֨ה ׀ וְלֹ֥א יִנָּחֵ֗ם אַתָּֽה ־ כֹהֵ֥ן לְעוֹלָ֑ם עַל ־ דִּ֝בְרָתִ֗י מַלְכִּי ־ צֶֽדֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.110.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 5,
      "referenceLabel": "Psalms 110:5",
      "text": "אֲדֹנָ֥י עַל ־ יְמִֽינְךָ֑ מָחַ֖ץ בְּיוֹם ־ אַפּ֣וֹ מְלָכִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.110.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 6,
      "referenceLabel": "Psalms 110:6",
      "text": "יָדִ֣ין בַּ֭גּוֹיִם מָלֵ֣א גְוִיּ֑וֹת מָ֥חַץ רֹ֝֗אשׁ עַל ־ אֶ֥רֶץ רַבָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.110.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 7,
      "referenceLabel": "Psalms 110:7",
      "text": "מִ֭נַּחַל בַּדֶּ֣רֶךְ יִשְׁתֶּ֑ה עַל ־ כֵּ֝֗ן יָרִ֥ים רֹֽאשׁ ׃",
      "paragraphStart": false
    }
  ]
}
