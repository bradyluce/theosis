{
  "chapter": {
    "id": "wlc:psalms.111",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.111.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ אוֹדֶ֣ה יְ֭הוָה בְּכָל ־ לֵבָ֑ב בְּס֖וֹד יְשָׁרִ֣ים וְעֵדָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.111.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "גְּ֭דֹלִים מַעֲשֵׂ֣י יְהוָ֑ה דְּ֝רוּשִׁ֗ים לְכָל ־ חֶפְצֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "הוֹד ־ וְהָדָ֥ר פָּֽעֳל֑וֹ וְ֝צִדְקָת֗וֹ עֹמֶ֥דֶת לָעַֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "זֵ֣כֶר עָ֭שָׂה לְנִפְלְאֹתָ֑יו חַנּ֖וּן וְרַח֣וּם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "טֶ֭רֶף נָתַ֣ן לִֽירֵאָ֑יו יִזְכֹּ֖ר לְעוֹלָ֣ם בְּרִיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "כֹּ֣חַ מַ֭עֲשָׂיו הִגִּ֣יד לְעַמּ֑וֹ לָתֵ֥ת לָ֝הֶ֗ם נַחֲלַ֥ת גּוֹיִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "מַעֲשֵׂ֣י יָ֭דָיו אֱמֶ֣ת וּמִשְׁפָּ֑ט נֶ֝אֱמָנִ֗ים כָּל ־ פִּקּוּדָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "סְמוּכִ֣ים לָעַ֣ד לְעוֹלָ֑ם עֲ֝שׂוּיִ֗ם בֶּאֱמֶ֥ת וְיָשָֽׁר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "פְּד֤וּת ׀ שָׁ֘לַ֤ח לְעַמּ֗וֹ צִוָּֽה ־ לְעוֹלָ֥ם בְּרִית֑וֹ קָד֖וֹשׁ וְנוֹרָ֣א שְׁמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.111.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "רֵ֘אשִׁ֤ית חָכְמָ֨ה ׀ יִרְאַ֬ת יְהוָ֗ה שֵׂ֣כֶל ט֭וֹב לְכָל ־ עֹשֵׂיהֶ֑ם תְּ֝הִלָּת֗וֹ עֹמֶ֥דֶת לָעַֽד ׃",
      "paragraphStart": false
    }
  ]
}
