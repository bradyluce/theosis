{
  "chapter": {
    "id": "wlc:psalms.86",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.86.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "תְּפִלָּ֗ה לְדָ֫וִ֥ד הַטֵּֽה ־ יְהוָ֣ה אָזְנְךָ֣ עֲנֵ֑נִי כִּֽי ־ עָנִ֖י וְאֶבְי֣וֹן אָֽנִי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.86.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "שָֽׁמְרָ֣ה נַפְשִׁי֮ כִּֽי ־ חָסִ֪יד אָ֥נִי הוֹשַׁ֣ע עַ֭בְדְּךָ אַתָּ֣ה אֱלֹהַ֑י הַבּוֹטֵ֥חַ אֵלֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "חָנֵּ֥נִי אֲדֹנָ֑י כִּ֥י אֵלֶ֥יךָ אֶ֝קְרָ֗א כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "שַׂ֭מֵּחַ נֶ֣פֶשׁ עַבְדֶּ֑ךָ כִּ֥י אֵלֶ֥יךָ אֲ֝דֹנָ֗י נַפְשִׁ֥י אֶשָּֽׂא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "כִּֽי ־ אַתָּ֣ה אֲ֭דֹנָי ט֣וֹב וְסַלָּ֑ח וְרַב ־ חֶ֝֗סֶד לְכָל ־ קֹרְאֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "הַאֲזִ֣ינָה יְ֭הוָה תְּפִלָּתִ֑י וְ֝הַקְשִׁ֗יבָה בְּק֣וֹל תַּחֲנוּנוֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "בְּי֣וֹם צָ֭רָתִ֥י אֶקְרָאֶ֗ךָּ כִּ֣י תַעֲנֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 8,
      "referenceLabel": "Psalms 86:8",
      "text": "אֵין ־ כָּמ֖וֹךָ בָאֱלֹהִ֥ים ׀ אֲדֹנָ֗י וְאֵ֣ין כְּֽמַעֲשֶֽׂיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 9,
      "referenceLabel": "Psalms 86:9",
      "text": "כָּל ־ גּוֹיִ֤ם ׀ אֲשֶׁ֥ר עָשִׂ֗יתָ יָב֤וֹאוּ ׀ וְיִשְׁתַּחֲו֣וּ לְפָנֶ֣יךָ אֲדֹנָ֑י וִֽיכַבְּד֣וּ לִשְׁמֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 10,
      "referenceLabel": "Psalms 86:10",
      "text": "כִּֽי ־ גָד֣וֹל אַ֭תָּה וְעֹשֵׂ֣ה נִפְלָא֑וֹת אַתָּ֖ה אֱלֹהִ֣ים לְבַדֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 11,
      "referenceLabel": "Psalms 86:11",
      "text": "ה֘וֹרֵ֤נִי יְהוָ֨ה ׀ דַּרְכֶּ֗ךָ אֲהַלֵּ֥ךְ בַּאֲמִתֶּ֑ךָ יַחֵ֥ד לְ֝בָבִ֗י לְיִרְאָ֥ה שְׁמֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 12,
      "referenceLabel": "Psalms 86:12",
      "text": "אוֹדְךָ֤ ׀ אֲדֹנָ֣י אֱ֭לֹהַי בְּכָל ־ לְבָבִ֑י וַאֲכַבְּדָ֖ה שִׁמְךָ֣ לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 13,
      "referenceLabel": "Psalms 86:13",
      "text": "כִּֽי ־ חַ֭סְדְּךָ גָּד֣וֹל עָלָ֑י וְהִצַּ֥לְתָּ נַ֝פְשִׁ֗י מִשְּׁא֥וֹל תַּחְתִּיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 14,
      "referenceLabel": "Psalms 86:14",
      "text": "אֱלֹהִ֤ים ׀ זֵ֘דִ֤ים קָֽמוּ ־ עָלַ֗י וַעֲדַ֣ת עָ֭רִיצִים בִּקְשׁ֣וּ נַפְשִׁ֑י וְלֹ֖א שָׂמ֣וּךָ לְנֶגְדָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 15,
      "referenceLabel": "Psalms 86:15",
      "text": "וְאַתָּ֣ה אֲ֭דֹנָי אֵל ־ רַח֣וּם וְחַנּ֑וּן אֶ֥רֶךְ אַ֝פַּ֗יִם וְרַב ־ חֶ֥סֶד וֶאֱמֶֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 16,
      "referenceLabel": "Psalms 86:16",
      "text": "פְּנֵ֥ה אֵלַ֗י וְחָ֫נֵּ֥נִי תְּנָֽה ־ עֻזְּךָ֥ לְעַבְדֶּ֑ךָ וְ֝הוֹשִׁ֗יעָה לְבֶן ־ אֲמָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.86.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 17,
      "referenceLabel": "Psalms 86:17",
      "text": "עֲשֵֽׂה ־ עִמִּ֥י א֗וֹת לְט֫וֹבָ֥ה וְיִרְא֣וּ שֹׂנְאַ֣י וְיֵבֹ֑שׁוּ כִּֽי ־ אַתָּ֥ה יְ֝הוָ֗ה עֲזַרְתַּ֥נִי וְנִחַמְתָּֽנִי ׃",
      "paragraphStart": false
    }
  ]
}
