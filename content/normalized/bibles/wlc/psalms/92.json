{
  "chapter": {
    "id": "wlc:psalms.92",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 92,
    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.92.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "מִזְמ֥וֹר שִׁ֗יר לְי֣וֹם הַשַּׁבָּֽת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.92.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "ט֗וֹב לְהֹד֥וֹת לַיהוָ֑ה וּלְזַמֵּ֖ר לְשִׁמְךָ֣ עֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "לְהַגִּ֣יד בַּבֹּ֣קֶר חַסְֽדֶּ֑ךָ וֶ֝אֱמֽוּנָתְךָ֗ בַּלֵּילֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "עֲֽלֵי ־ עָ֭שׂוֹר וַעֲלֵי ־ נָ֑בֶל עֲלֵ֖י הִגָּי֣וֹן בְּכִנּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "כִּ֤י שִׂמַּחְתַּ֣נִי יְהוָ֣ה בְּפָעֳלֶ֑ךָ בְּֽמַעֲשֵׂ֖י יָדֶ֣יךָ אֲרַנֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 6,
      "referenceLabel": "Psalms 92:6",
      "text": "מַה ־ גָּדְל֣וּ מַעֲשֶׂ֣יךָ יְהוָ֑ה מְ֝אֹ֗ד עָמְק֥וּ מַחְשְׁבֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 7,
      "referenceLabel": "Psalms 92:7",
      "text": "אִֽישׁ ־ בַּ֭עַר לֹ֣א יֵדָ֑ע וּ֝כְסִ֗יל לֹא ־ יָבִ֥ין אֶת ־ זֹֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 8,
      "referenceLabel": "Psalms 92:8",
      "text": "בִּפְרֹ֤חַ רְשָׁעִ֨ים ׀ כְּמ֥וֹ עֵ֗שֶׂב וַ֭יָּצִיצוּ כָּל ־ פֹּ֣עֲלֵי אָ֑וֶן לְהִשָּֽׁמְדָ֥ם עֲדֵי ־ עַֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 9,
      "referenceLabel": "Psalms 92:9",
      "text": "וְאַתָּ֥ה מָר֗וֹם לְעֹלָ֥ם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 10,
      "referenceLabel": "Psalms 92:10",
      "text": "כִּ֤י הִנֵּ֪ה אֹיְבֶ֡יךָ ׀ יְֽהוָ֗ה כִּֽי ־ הִנֵּ֣ה אֹיְבֶ֣יךָ יֹאבֵ֑דוּ יִ֝תְפָּרְד֗וּ כָּל ־ פֹּ֥עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 11,
      "referenceLabel": "Psalms 92:11",
      "text": "וַתָּ֣רֶם כִּרְאֵ֣ים קַרְנִ֑י בַּ֝לֹּתִ֗י בְּשֶׁ֣מֶן רַעֲנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 12,
      "referenceLabel": "Psalms 92:12",
      "text": "וַתַּבֵּ֥ט עֵינִ֗י בְּשׁ֫וּרָ֥י בַּקָּמִ֖ים עָלַ֥י מְרֵעִ֗ים תִּשְׁמַ֥עְנָה אָזְנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 13,
      "referenceLabel": "Psalms 92:13",
      "text": "צַ֭דִּיק כַּתָּמָ֣ר יִפְרָ֑ח כְּאֶ֖רֶז בַּלְּבָנ֣וֹן יִשְׂגֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 14,
      "referenceLabel": "Psalms 92:14",
      "text": "שְׁ֭תוּלִים בְּבֵ֣ית יְהוָ֑ה בְּחַצְר֖וֹת אֱלֹהֵ֣ינוּ יַפְרִֽיחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 15,
      "referenceLabel": "Psalms 92:15",
      "text": "ע֭וֹד יְנוּב֣וּן בְּשֵׂיבָ֑ה דְּשֵׁנִ֖ים וְרַֽעֲנַנִּ֣ים יִהְיֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.92.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 16,
      "referenceLabel": "Psalms 92:16",
      "text": "לְ֭הַגִּיד כִּֽי ־ יָשָׁ֣ר יְהוָ֑ה צ֝וּרִ֗י וְֽלֹא ־ עלתה בּֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
