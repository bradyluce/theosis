{
  "chapter": {
    "id": "wlc:psalms.139",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.139.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "לַ֭מְנַצֵּחַ לְדָוִ֣ד מִזְמ֑וֹר יְהוָ֥ה חֲ֝קַרְתַּ֗נִי וַתֵּדָֽע ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.139.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "אַתָּ֣ה יָ֭דַעְתָּ שִׁבְתִּ֣י וְקוּמִ֑י בַּ֥נְתָּה לְ֝רֵעִ֗י מֵרָחֽוֹק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "אָרְחִ֣י וְרִבְעִ֣י זֵרִ֑יתָ וְֽכָל ־ דְּרָכַ֥י הִסְכַּֽנְתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "כִּ֤י אֵ֣ין מִ֭לָּה בִּלְשׁוֹנִ֑י הֵ֥ן יְ֝הוָ֗ה יָדַ֥עְתָּ כֻלָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "אָח֣וֹר וָקֶ֣דֶם צַרְתָּ֑נִי וַתָּ֖שֶׁת עָלַ֣י כַּפֶּֽכָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "פלאיה דַ֣עַת מִמֶּ֑נִּי נִ֝שְׂגְּבָ֗ה לֹא ־ א֥וּכַֽל לָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "אָ֭נָ֥ה אֵלֵ֣ךְ מֵרוּחֶ֑ךָ וְ֝אָ֗נָה מִפָּנֶ֥יךָ אֶבְרָֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "אִם ־ אֶסַּ֣ק שָׁ֭מַיִם שָׁ֣ם אָ֑תָּה וְאַצִּ֖יעָה שְּׁא֣וֹל הִנֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "אֶשָּׂ֥א כַנְפֵי ־ שָׁ֑חַר אֶ֝שְׁכְּנָ֗ה בְּאַחֲרִ֥ית יָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "גַּם ־ שָׁ֭ם יָדְךָ֣ תַנְחֵ֑נִי וְֽתֹאחֲזֵ֥נִי יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "וָ֭אֹמַר אַךְ ־ חֹ֣שֶׁךְ יְשׁוּפֵ֑נִי וְ֝לַ֗יְלָה א֣וֹר בַּעֲדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "גַּם ־ חֹשֶׁךְ֮ לֹֽא ־ יַחְשִׁ֪יךְ מִ֫מֶּ֥ךָ וְ֭לַיְלָה כַּיּ֣וֹם יָאִ֑יר כַּ֝חֲשֵׁיכָ֗ה כָּאוֹרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "כִּֽי ־ אַ֭תָּה קָנִ֣יתָ כִלְיֹתָ֑י תְּ֝סֻכֵּ֗נִי בְּבֶ֣טֶן אִמִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "אֽוֹדְךָ֗ עַ֤ל כִּ֥י נוֹרָא֗וֹת נִ֫פְלֵ֥יתִי נִפְלָאִ֥ים מַעֲשֶׂ֑יךָ וְ֝נַפְשִׁ֗י יֹדַ֥עַת מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 15,
      "referenceLabel": "Psalms 139:15",
      "text": "לֹא ־ נִכְחַ֥ד עָצְמִ֗י מִ֫מֶּ֥ךָּ אֲשֶׁר ־ עֻשֵּׂ֥יתִי בַסֵּ֑תֶר רֻ֝קַּ֗מְתִּי בְּֽתַחְתִּיּ֥וֹת אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 16,
      "referenceLabel": "Psalms 139:16",
      "text": "גָּלְמִ֤י ׀ רָ֘א֤וּ עֵינֶ֗יךָ וְעַֽל ־ סִפְרְךָ֮ כֻּלָּ֪ם יִכָּ֫תֵ֥בוּ יָמִ֥ים יֻצָּ֑רוּ ולא אֶחָ֣ד בָּהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 17,
      "referenceLabel": "Psalms 139:17",
      "text": "וְלִ֗י מַה ־ יָּקְר֣וּ רֵעֶ֣יךָ אֵ֑ל מֶ֥ה עָ֝צְמוּ רָאשֵׁיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 18,
      "referenceLabel": "Psalms 139:18",
      "text": "אֶ֭סְפְּרֵם מֵח֣וֹל יִרְבּ֑וּן הֱ֝קִיצֹ֗תִי וְעוֹדִ֥י עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 19,
      "referenceLabel": "Psalms 139:19",
      "text": "אִם ־ תִּקְטֹ֖ל אֱל֥וֹהַּ ׀ רָשָׁ֑ע וְאַנְשֵׁ֥י דָ֝מִ֗ים ס֣וּרוּ מֶֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 20,
      "referenceLabel": "Psalms 139:20",
      "text": "אֲשֶׁ֣ר יֹ֭אמְרֻךָ לִמְזִמָּ֑ה נָשֻׂ֖א לַשָּׁ֣וְא עָרֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 21,
      "referenceLabel": "Psalms 139:21",
      "text": "הֲלֽוֹא ־ מְשַׂנְאֶ֖יךָ יְהוָ֥ה ׀ אֶשְׂנָ֑א וּ֝בִתְקוֹמְמֶ֗יךָ אֶתְקוֹטָֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 22,
      "referenceLabel": "Psalms 139:22",
      "text": "תַּכְלִ֣ית שִׂנְאָ֣ה שְׂנֵאתִ֑ים לְ֝אוֹיְבִ֗ים הָ֣יוּ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 23,
      "referenceLabel": "Psalms 139:23",
      "text": "חָקְרֵ֣נִי אֵ֭ל וְדַ֣ע לְבָבִ֑י בְּ֝חָנֵ֗נִי וְדַ֣ע שַׂרְעַפָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.139.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 24,
      "referenceLabel": "Psalms 139:24",
      "text": "וּרְאֵ֗ה אִם ־ דֶּֽרֶךְ ־ עֹ֥צֶב בִּ֑י וּ֝נְחֵ֗נִי בְּדֶ֣רֶךְ עוֹלָֽם ׃",
      "paragraphStart": false
    }
  ]
}
