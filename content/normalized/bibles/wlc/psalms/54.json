{
  "chapter": {
    "id": "wlc:psalms.54",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.54.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "לַמְנַצֵּ֥חַ בִּנְגִינֹ֗ת מַשְׂכִּ֥יל לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.54.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "בְּב֣וֹא הַ֭זִּיפִים וַיֹּאמְר֣וּ לְשָׁא֑וּל הֲלֹ֥א דָ֝וִ֗ד מִסְתַּתֵּ֥ר עִמָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "אֱ֭לֹהִים בְּשִׁמְךָ֣ הוֹשִׁיעֵ֑נִי וּבִגְבוּרָתְךָ֥ תְדִינֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "אֱ֭לֹהִים שְׁמַ֣ע תְּפִלָּתִ֑י הַ֝אֲזִ֗ינָה לְאִמְרֵי ־ פִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "כִּ֤י זָרִ֨ים ׀ קָ֤מוּ עָלַ֗י וְֽ֭עָרִיצִים בִּקְשׁ֣וּ נַפְשִׁ֑י לֹ֤א שָׂ֨מוּ אֱלֹהִ֖ים לְנֶגְדָּ֣ם סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "הִנֵּ֣ה אֱ֭לֹהִים עֹזֵ֣ר לִ֑י אֲ֝דֹנָ֗י בְּֽסֹמְכֵ֥י נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "ישוב הָ֭רַע לְשֹׁרְרָ֑י בַּ֝אֲמִתְּךָ֗ הַצְמִיתֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 8,
      "referenceLabel": "Psalms 54:8",
      "text": "בִּנְדָבָ֥ה אֶזְבְּחָה ־ לָּ֑ךְ א֤וֹדֶה שִּׁמְךָ֖ יְהוָ֣ה כִּי ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.54.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 9,
      "referenceLabel": "Psalms 54:9",
      "text": "כִּ֣י מִכָּל ־ צָ֭רָה הִצִּילָ֑נִי וּ֝בְאֹיְבַ֗י רָאֲתָ֥ה עֵינִֽי ׃",
      "paragraphStart": false
    }
  ]
}
