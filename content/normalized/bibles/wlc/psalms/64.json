{
  "chapter": {
    "id": "wlc:psalms.64",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 64,
    "referenceLabel": "Psalms 64",
    "summary": "Source text for Psalms 64 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.64.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 1,
      "referenceLabel": "Psalms 64:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.64.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 2,
      "referenceLabel": "Psalms 64:2",
      "text": "שְׁמַע ־ אֱלֹהִ֣ים קוֹלִ֣י בְשִׂיחִ֑י מִפַּ֥חַד א֝וֹיֵ֗ב תִּצֹּ֥ר חַיָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 3,
      "referenceLabel": "Psalms 64:3",
      "text": "תַּ֭סְתִּירֵנִי מִסּ֣וֹד מְרֵעִ֑ים מֵ֝רִגְשַׁ֗ת פֹּ֣עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 4,
      "referenceLabel": "Psalms 64:4",
      "text": "אֲשֶׁ֤ר שָׁנְנ֣וּ כַחֶ֣רֶב לְשׁוֹנָ֑ם דָּרְכ֥וּ חִ֝צָּ֗ם דָּבָ֥ר מָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 5,
      "referenceLabel": "Psalms 64:5",
      "text": "לִיר֣וֹת בַּמִּסְתָּרִ֣ים תָּ֑ם פִּתְאֹ֥ם יֹ֝רֻ֗הוּ וְלֹ֣א יִירָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 6,
      "referenceLabel": "Psalms 64:6",
      "text": "יְחַזְּקוּ ־ לָ֨מוֹ ׀ דָּ֘בָ֤ר רָ֗ע יְֽ֭סַפְּרוּ לִטְמ֣וֹן מוֹקְשִׁ֑ים אָ֝מְר֗וּ מִ֣י יִרְאֶה ־ לָּֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 7,
      "referenceLabel": "Psalms 64:7",
      "text": "יַֽחְפְּֽשׂוּ ־ עוֹלֹ֗ת תַּ֭מְנוּ חֵ֣פֶשׂ מְחֻפָּ֑שׂ וְקֶ֥רֶב אִ֝֗ישׁ וְלֵ֣ב עָמֹֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 8,
      "referenceLabel": "Psalms 64:8",
      "text": "וַיֹּרֵ֗ם אֱלֹ֫הִ֥ים חֵ֥ץ פִּתְא֑וֹם הָ֝י֗וּ מַכּוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 9,
      "referenceLabel": "Psalms 64:9",
      "text": "וַיַּכְשִׁיל֣וּהוּ עָלֵ֣ימוֹ לְשׁוֹנָ֑ם יִ֝תְנֹדֲד֗וּ כָּל ־ רֹ֥אֵה בָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 10,
      "referenceLabel": "Psalms 64:10",
      "text": "וַיִּֽירְא֗וּ כָּל ־ אָ֫דָ֥ם וַ֭יַּגִּידוּ פֹּ֥עַל אֱלֹהִ֗ים וּֽמַעֲשֵׂ֥הוּ הִשְׂכִּֽילוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.64.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 11,
      "referenceLabel": "Psalms 64:11",
      "text": "יִשְׂמַ֬ח צַדִּ֣יק בַּ֭יהוָה וְחָ֣סָה ב֑וֹ וְ֝יִתְהַֽלְל֗וּ כָּל ־ יִשְׁרֵי ־ לֵֽב ׃",
      "paragraphStart": false
    }
  ]
}
