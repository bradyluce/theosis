      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 1,
      "referenceLabel": "Psalms 134:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת הִנֵּ֤ה ׀ בָּרֲכ֣וּ אֶת ־ יְ֭הוָה כָּל ־ עַבְדֵ֣י יְהוָ֑ה הָעֹמְדִ֥ים בְּבֵית ־ יְ֝הוָ֗ה בַּלֵּילֽוֹת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.134.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 2,
      "referenceLabel": "Psalms 134:2",
      "text": "שְׂאֽוּ ־ יְדֵכֶ֥ם קֹ֑דֶשׁ וּ֝בָרֲכוּ אֶת ־ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.134.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 3,
      "referenceLabel": "Psalms 134:3",
      "text": "יְבָרֶכְךָ֣ יְ֭הוָה מִצִּיּ֑וֹן עֹ֝שֵׂ֗ה שָׁמַ֥יִם וָאָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
