  },
  "verses": [
    {
      "id": "wlc:psalms.70.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 1,
      "referenceLabel": "Psalms 70:1",
      "text": "לַ֝מְנַצֵּ֗חַ לְדָוִ֥ד לְהַזְכִּֽיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.70.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 2,
      "referenceLabel": "Psalms 70:2",
      "text": "אֱלֹהִ֥ים לְהַצִּילֵ֑נִי יְ֝הוָ֗ה לְעֶזְרָ֥תִי חֽוּשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.70.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 3,
      "referenceLabel": "Psalms 70:3",
      "text": "יֵבֹ֣שׁוּ וְיַחְפְּרוּ֮ מְבַקְשֵׁ֪י נַ֫פְשִׁ֥י יִסֹּ֣גוּ אָ֭חוֹר וְיִכָּלְמ֑וּ חֲ֝פֵצֵ֗י רָעָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.70.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 4,
      "referenceLabel": "Psalms 70:4",
      "text": "יָ֭שׁוּבוּ עַל ־ עֵ֣קֶב בָּשְׁתָּ֑ם הָ֝אֹמְרִ֗ים הֶ֘אָ֥ח ׀ הֶאָֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.70.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 5,
      "referenceLabel": "Psalms 70:5",
      "text": "יָ֘שִׂ֤ישׂוּ וְיִשְׂמְח֨וּ ׀ בְּךָ֗ כָּֽל ־ מְבַ֫קְשֶׁ֥יךָ וְיֹאמְר֣וּ תָ֭מִיד יִגְדַּ֣ל אֱלֹהִ֑ים אֹ֝הֲבֵ֗י יְשׁוּעָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.70.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 6,
      "referenceLabel": "Psalms 70:6",
      "text": "וַאֲנִ֤י ׀ עָנִ֣י וְאֶבְיוֹן֮ אֱלֹהִ֪ים חֽוּשָׁ֫ה ־ לִּ֥י עֶזְרִ֣י וּמְפַלְטִ֣י אַ֑תָּה יְ֝הוָ֗ה אַל ־ תְּאַחַֽר ׃",
      "paragraphStart": false
    }
  ]
}
