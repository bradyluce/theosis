{
  "chapter": {
    "id": "wlc:psalms.129",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.129.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת רַ֭בַּת צְרָר֣וּנִי מִנְּעוּרַ֑י יֹֽאמַר ־ נָ֝א יִשְׂרָאֵֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.129.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "רַ֭בַּת צְרָר֣וּנִי מִנְּעוּרָ֑י גַּ֝ם לֹא ־ יָ֥כְלוּ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.129.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "עַל ־ גַּ֭בִּי חָרְשׁ֣וּ חֹרְשִׁ֑ים הֶ֝אֱרִ֗יכוּ למענותם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.129.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "יְהוָ֥ה צַדִּ֑יק קִ֝צֵּ֗ץ עֲב֣וֹת רְשָׁעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.129.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "יֵ֭בֹשׁוּ וְיִסֹּ֣גוּ אָח֑וֹר כֹּ֝֗ל שֹׂנְאֵ֥י צִיּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.129.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "יִ֭הְיוּ כַּחֲצִ֣יר גַּגּ֑וֹת שֶׁקַּדְמַ֖ת שָׁלַ֣ף יָבֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.129.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "שֶׁלֹּ֤א מִלֵּ֖א כַפּ֥וֹ קוֹצֵ֗ר וְחִצְנ֥וֹ מְעַמֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.129.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "וְלֹ֤א אָֽמְר֨וּ ׀ הָעֹבְרִ֗ים בִּרְכַּֽת ־ יְהוָ֥ה אֲלֵיכֶ֑ם בֵּרַ֥כְנוּ אֶ֝תְכֶ֗ם בְּשֵׁ֣ם יְהוָֽה ׃",
      "paragraphStart": false
    }
  ]
}
