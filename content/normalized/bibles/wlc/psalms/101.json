{
  "chapter": {
    "id": "wlc:psalms.101",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 101,
    "referenceLabel": "Psalms 101",
    "summary": "Source text for Psalms 101 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.101.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 1,
      "referenceLabel": "Psalms 101:1",
      "text": "לְדָוִ֗ד מִ֫זְמ֥וֹר חֶֽסֶד ־ וּמִשְׁפָּ֥ט אָשִׁ֑ירָה לְךָ֖ יְהוָ֣ה אֲזַמֵּֽרָה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.101.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 2,
      "referenceLabel": "Psalms 101:2",
      "text": "אַשְׂכִּ֤ילָה ׀ בְּדֶ֬רֶךְ תָּמִ֗ים מָ֭תַי תָּב֣וֹא אֵלָ֑י אֶתְהַלֵּ֥ךְ בְּתָם ־ לְ֝בָבִ֗י בְּקֶ֣רֶב בֵּיתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.101.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 3,
      "referenceLabel": "Psalms 101:3",
      "text": "לֹֽא ־ אָשִׁ֨ית ׀ לְנֶ֥גֶד עֵינַ֗י דְּֽבַר ־ בְּלִ֫יָּ֥עַל עֲשֹֽׂה ־ סֵטִ֥ים שָׂנֵ֑אתִי לֹ֖א יִדְבַּ֣ק בִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.101.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 4,
      "referenceLabel": "Psalms 101:4",
      "text": "לֵבָ֣ב עִ֭קֵּשׁ יָס֣וּר מִמֶּ֑נִּי רָ֝֗ע לֹ֣א אֵדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.101.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 5,
      "referenceLabel": "Psalms 101:5",
      "text": "מלושני בַסֵּ֨תֶר ׀ רֵעֵהוּ֮ אוֹת֪וֹ אַ֫צְמִ֥ית גְּֽבַהּ ־ עֵ֭ינַיִם וּרְחַ֣ב לֵבָ֑ב אֹ֝ת֗וֹ לֹ֣א אוּכָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.101.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 6,
      "referenceLabel": "Psalms 101:6",
      "text": "עֵינַ֤י ׀ בְּנֶֽאֶמְנֵי ־ אֶרֶץ֮ לָשֶׁ֪בֶת עִמָּ֫דִ֥י הֹ֭לֵךְ בְּדֶ֣רֶךְ תָּמִ֑ים ה֝֗וּא יְשָׁרְתֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.101.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 7,
      "referenceLabel": "Psalms 101:7",
      "text": "לֹֽא ־ יֵשֵׁ֨ב ׀ בְּקֶ֥רֶב בֵּיתִי֮ עֹשֵׂ֪ה רְמִ֫יָּ֥ה דֹּבֵ֥ר שְׁקָרִ֑ים לֹֽא ־ יִ֝כּ֗וֹן לְנֶ֣גֶד עֵינָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.101.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 8,
      "referenceLabel": "Psalms 101:8",
      "text": "לַבְּקָרִ֗ים אַצְמִ֥ית כָּל ־ רִשְׁעֵי ־ אָ֑רֶץ לְהַכְרִ֥ית מֵֽעִיר ־ יְ֝הוָ֗ה כָּל ־ פֹּ֥עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    }
  ]
}
