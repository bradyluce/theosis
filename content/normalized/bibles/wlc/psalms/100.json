  },
  "verses": [
    {
      "id": "wlc:psalms.100.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 1,
      "referenceLabel": "Psalms 100:1",
      "text": "מִזְמ֥וֹר לְתוֹדָ֑ה הָרִ֥יעוּ לַ֝יהוָ֗ה כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.100.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 2,
      "referenceLabel": "Psalms 100:2",
      "text": "עִבְד֣וּ אֶת ־ יְהוָ֣ה בְּשִׂמְחָ֑ה בֹּ֥אוּ לְ֝פָנָ֗יו בִּרְנָנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.100.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 3,
      "referenceLabel": "Psalms 100:3",
      "text": "דְּע֗וּ כִּֽי ־ יְהוָה֮ ה֤וּא אֱלֹ֫הִ֥ים הֽוּא ־ עָ֭שָׂנוּ ולא אֲנַ֑חְנוּ עַ֝מּ֗וֹ וְצֹ֣אן מַרְעִיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.100.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 4,
      "referenceLabel": "Psalms 100:4",
      "text": "בֹּ֤אוּ שְׁעָרָ֨יו ׀ בְּתוֹדָ֗ה חֲצֵרֹתָ֥יו בִּתְהִלָּ֑ה הֽוֹדוּ ־ ל֝֗וֹ בָּרֲכ֥וּ שְׁמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.100.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 5,
      "referenceLabel": "Psalms 100:5",
      "text": "כִּי ־ ט֣וֹב יְ֭הֹוָה לְעוֹלָ֣ם חַסְדּ֑וֹ וְעַד ־ דֹּ֥ר וָ֝דֹ֗ר אֱמוּנָתֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
