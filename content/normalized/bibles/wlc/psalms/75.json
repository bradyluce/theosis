{
  "chapter": {
    "id": "wlc:psalms.75",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.75.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "לַמְנַצֵּ֥חַ אַל ־ תַּשְׁחֵ֑ת מִזְמ֖וֹר לְאָסָ֣ף שִֽׁיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.75.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "ה֘וֹדִ֤ינוּ לְּךָ֨ ׀ אֱֽלֹהִ֗ים ה֭וֹדִינוּ וְקָר֣וֹב שְׁמֶ֑ךָ סִ֝פְּר֗וּ נִפְלְאוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "כִּ֭י אֶקַּ֣ח מוֹעֵ֑ד אֲ֝נִ֗י מֵישָׁרִ֥ים אֶשְׁפֹּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "נְֽמֹגִ֗ים אֶ֥רֶץ וְכָל ־ יֹשְׁבֶ֑יהָ אָנֹכִ֨י תִכַּ֖נְתִּי עַמּוּדֶ֣יהָ סֶּֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "אָמַ֣רְתִּי לַֽ֭הוֹלְלִים אַל ־ תָּהֹ֑לּוּ וְ֝לָרְשָׁעִ֗ים אַל ־ תָּרִ֥ימוּ קָֽרֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "אַל ־ תָּרִ֣ימוּ לַמָּר֣וֹם קַרְנְכֶ֑ם תְּדַבְּר֖וּ בְצַוָּ֣אר עָתָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "כִּ֤י לֹ֣א מִ֭מּוֹצָא וּמִֽמַּעֲרָ֑ב וְ֝לֹ֗א מִמִּדְבַּ֥ר הָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "כִּֽי ־ אֱלֹהִ֥ים שֹׁפֵ֑ט זֶ֥ה יַ֝שְׁפִּ֗יל וְזֶ֣ה יָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "כִּ֤י כ֪וֹס בְּֽיַד ־ יְהוָ֡ה וְיַ֤יִן חָמַ֨ר ׀ מָ֥לֵא מֶסֶךְ֮ וַיַּגֵּ֪ר מִ֫זֶּ֥ה אַךְ ־ שְׁ֭מָרֶיהָ יִמְצ֣וּ יִשְׁתּ֑וּ כֹּ֝֗ל רִשְׁעֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "וַ֭אֲנִי אַגִּ֣יד לְעֹלָ֑ם אֲ֝זַמְּרָ֗ה לֵאלֹהֵ֥י יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.75.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 11,
      "referenceLabel": "Psalms 75:11",
      "text": "וְכָל ־ קַרְנֵ֣י רְשָׁעִ֣ים אֲגַדֵּ֑עַ תְּ֝רוֹמַ֗מְנָה קַֽרְנ֥וֹת צַדִּֽיק ׃",
      "paragraphStart": false
    }
  ]
}
