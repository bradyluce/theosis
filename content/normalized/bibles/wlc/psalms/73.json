{
  "chapter": {
    "id": "wlc:psalms.73",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 73,
    "referenceLabel": "Psalms 73",
    "summary": "Source text for Psalms 73 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.73.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 1,
      "referenceLabel": "Psalms 73:1",
      "text": "מִזְמ֗וֹר לְאָ֫סָ֥ף אַ֤ךְ ט֭וֹב לְיִשְׂרָאֵ֥ל אֱלֹהִ֗ים לְבָרֵ֥י לֵבָֽב ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.73.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 2,
      "referenceLabel": "Psalms 73:2",
      "text": "וַאֲנִ֗י כִּ֭מְעַט נטוי רַגְלָ֑י כְּ֝אַ֗יִן שפכה אֲשֻׁרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 3,
      "referenceLabel": "Psalms 73:3",
      "text": "כִּֽי ־ קִ֭נֵּאתִי בַּֽהוֹלְלִ֑ים שְׁל֖וֹם רְשָׁעִ֣ים אֶרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 4,
      "referenceLabel": "Psalms 73:4",
      "text": "כִּ֤י אֵ֖ין חַרְצֻבּ֥וֹת לְמוֹתָ֗ם וּבָרִ֥יא אוּלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 5,
      "referenceLabel": "Psalms 73:5",
      "text": "בַּעֲמַ֣ל אֱנ֣וֹשׁ אֵינֵ֑מוֹ וְעִם ־ אָ֝דָ֗ם לֹ֣א יְנֻגָּֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 6,
      "referenceLabel": "Psalms 73:6",
      "text": "לָ֭כֵן עֲנָקַ֣תְמוֹ גַאֲוָ֑ה יַעֲטָף ־ שִׁ֝֗ית חָמָ֥ס לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 7,
      "referenceLabel": "Psalms 73:7",
      "text": "יָ֭צָא מֵחֵ֣לֶב עֵינֵ֑מוֹ עָ֝בְר֗וּ מַשְׂכִּיּ֥וֹת לֵבָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 8,
      "referenceLabel": "Psalms 73:8",
      "text": "יָמִ֤יקוּ ׀ וִידַבְּר֣וּ בְרָ֣ע עֹ֑שֶׁק מִמָּר֥וֹם יְדַבֵּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 9,
      "referenceLabel": "Psalms 73:9",
      "text": "שַׁתּ֣וּ בַשָּׁמַ֣יִם פִּיהֶ֑ם וּ֝לְשׁוֹנָ֗ם תִּֽהֲלַ֥ךְ בָּאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 10,
      "referenceLabel": "Psalms 73:10",
      "text": "לָכֵ֤ן ׀ ישיב עַמּ֣וֹ הֲלֹ֑ם וּמֵ֥י מָ֝לֵ֗א יִמָּ֥צוּ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 11,
      "referenceLabel": "Psalms 73:11",
      "text": "וְֽאָמְר֗וּ אֵיכָ֥ה יָדַֽע ־ אֵ֑ל וְיֵ֖שׁ דֵּעָ֣ה בְעֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 12,
      "referenceLabel": "Psalms 73:12",
      "text": "הִנֵּה ־ אֵ֥לֶּה רְשָׁעִ֑ים וְשַׁלְוֵ֥י ע֝וֹלָ֗ם הִשְׂגּוּ ־ חָֽיִל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 13,
      "referenceLabel": "Psalms 73:13",
      "text": "אַךְ ־ רִ֭יק זִכִּ֣יתִי לְבָבִ֑י וָאֶרְחַ֖ץ בְּנִקָּי֣וֹן כַּפָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 14,
      "referenceLabel": "Psalms 73:14",
      "text": "וָאֱהִ֣י נָ֭גוּעַ כָּל ־ הַיּ֑וֹם וְ֝תוֹכַחְתִּ֗י לַבְּקָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 15,
      "referenceLabel": "Psalms 73:15",
      "text": "אִם ־ אָ֭מַרְתִּי אֲסַפְּרָ֥ה כְמ֑וֹ הִנֵּ֤ה ד֭וֹר בָּנֶ֣יךָ בָגָֽדְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 16,
      "referenceLabel": "Psalms 73:16",
      "text": "וָֽ֭אֲחַשְּׁבָה לָדַ֣עַת זֹ֑את עָמָ֖ל היא בְעֵינָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 17,
      "referenceLabel": "Psalms 73:17",
      "text": "עַד ־ אָ֭בוֹא אֶל ־ מִקְדְּשֵׁי ־ אֵ֑ל אָ֝בִ֗ינָה לְאַחֲרִיתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 18,
      "referenceLabel": "Psalms 73:18",
      "text": "אַ֣ךְ בַּ֭חֲלָקוֹת תָּשִׁ֣ית לָ֑מוֹ הִ֝פַּלְתָּ֗ם לְמַשּׁוּאֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 19,
      "referenceLabel": "Psalms 73:19",
      "text": "אֵ֤יךְ הָי֣וּ לְשַׁמָּ֣ה כְרָ֑גַע סָ֥פוּ תַ֝֗מּוּ מִן ־ בַּלָּהֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 20,
      "referenceLabel": "Psalms 73:20",
      "text": "כַּחֲל֥וֹם מֵהָקִ֑יץ אֲ֝דֹנָי בָּעִ֤יר ׀ צַלְמָ֬ם תִּבְזֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 21,
      "referenceLabel": "Psalms 73:21",
      "text": "כִּ֭י יִתְחַמֵּ֣ץ לְבָבִ֑י וְ֝כִלְיוֹתַ֗י אֶשְׁתּוֹנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 22,
      "referenceLabel": "Psalms 73:22",
      "text": "וַאֲנִי ־ בַ֭עַר וְלֹ֣א אֵדָ֑ע בְּ֝הֵמ֗וֹת הָיִ֥יתִי עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 23,
      "referenceLabel": "Psalms 73:23",
      "text": "וַאֲנִ֣י תָמִ֣יד עִמָּ֑ךְ אָ֝חַ֗זְתָּ בְּיַד ־ יְמִינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 24,
      "referenceLabel": "Psalms 73:24",
      "text": "בַּעֲצָתְךָ֥ תַנְחֵ֑נִי וְ֝אַחַ֗ר כָּב֥וֹד תִּקָּחֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 25,
      "referenceLabel": "Psalms 73:25",
      "text": "מִי ־ לִ֥י בַשָּׁמָ֑יִם וְ֝עִמְּךָ֗ לֹא ־ חָפַ֥צְתִּי בָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 26,
      "referenceLabel": "Psalms 73:26",
      "text": "כָּלָ֥ה שְׁאֵרִ֗י וּלְבָ֫בִ֥י צוּר ־ לְבָבִ֥י וְחֶלְקִ֗י אֱלֹהִ֥ים לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 27,
      "referenceLabel": "Psalms 73:27",
      "text": "כִּֽי ־ הִנֵּ֣ה רְחֵקֶ֣יךָ יֹאבֵ֑דוּ הִ֝צְמַ֗תָּה כָּל ־ זוֹנֶ֥ה מִמֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.73.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 28,
      "referenceLabel": "Psalms 73:28",
      "text": "וַאֲנִ֤י ׀ קִֽרֲבַ֥ת אֱלֹהִ֗ים לִ֫י ־ ט֥וֹב שַׁתִּ֤י ׀ בַּאדֹנָ֣י יְהֹוִ֣ה מַחְסִ֑י לְ֝סַפֵּ֗ר כָּל ־ מַלְאֲכוֹתֶֽיךָ ׃",
      "paragraphStart": false
    }
  ]
}
