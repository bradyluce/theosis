{
  "chapter": {
    "id": "wlc:psalms.88",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.88.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "שִׁ֥יר מִזְמ֗וֹר לִבְנֵ֫י קֹ֥רַח לַמְנַצֵּ֣חַ עַל ־ מָחֲלַ֣ת לְעַנּ֑וֹת מַ֝שְׂכִּ֗יל לְהֵימָ֥ן הָאֶזְרָחִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.88.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "יְ֭הוָה אֱלֹהֵ֣י יְשׁוּעָתִ֑י יוֹם ־ צָעַ֖קְתִּי בַלַּ֣יְלָה נֶגְדֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "תָּב֣וֹא לְ֭פָנֶיךָ תְּפִלָּתִ֑י הַטֵּֽה ־ אָ֝זְנְךָ֗ לְרִנָּתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "כִּֽי ־ שָֽׂבְעָ֣ה בְרָע֣וֹת נַפְשִׁ֑י וְחַיַּ֗י לִשְׁא֥וֹל הִגִּֽיעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "נֶ֭חְשַׁבְתִּי עִם ־ י֣וֹרְדֵי ב֑וֹר הָ֝יִ֗יתִי כְּגֶ֣בֶר אֵֽין ־ אֱיָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "בַּמֵּתִ֗ים חָ֫פְשִׁ֥י כְּמ֤וֹ חֲלָלִ֨ים ׀ שֹׁ֥כְבֵי קֶ֗בֶר אֲשֶׁ֤ר לֹ֣א זְכַרְתָּ֣ם ע֑וֹד וְ֝הֵ֗מָּה מִיָּדְךָ֥ נִגְזָֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "שַׁ֭תַּנִי בְּב֣וֹר תַּחְתִּיּ֑וֹת בְּ֝מַחֲשַׁכִּ֗ים בִּמְצֹלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "עָ֭לַי סָמְכָ֣ה חֲמָתֶ֑ךָ וְכָל ־ מִ֝שְׁבָּרֶ֗יךָ עִנִּ֥יתָ סֶּֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "הִרְחַ֥קְתָּ מְיֻדָּעַ֗י מִ֫מֶּ֥נִּי שַׁתַּ֣נִי תוֹעֵב֣וֹת לָ֑מוֹ כָּ֝לֻ֗א וְלֹ֣א אֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "עֵינִ֥י דָאֲבָ֗ה מִנִּ֫י עֹ֥נִי קְרָאתִ֣יךָ יְהוָ֣ה בְּכָל ־ י֑וֹם שִׁטַּ֖חְתִּי אֵלֶ֣יךָ כַפָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "הֲלַמֵּתִ֥ים תַּעֲשֶׂה ־ פֶּ֑לֶא אִם ־ רְ֝פָאִ֗ים יָק֤וּמוּ ׀ יוֹד֬וּךָ סֶּֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "הַיְסֻפַּ֣ר בַּקֶּ֣בֶר חַסְדֶּ֑ךָ אֱ֝מֽוּנָתְךָ֗ בָּאֲבַדּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "הֲיִוָּדַ֣ע בַּחֹ֣שֶׁךְ פִּלְאֶ֑ךָ וְ֝צִדְקָתְךָ֗ בְּאֶ֣רֶץ נְשִׁיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "וַאֲנִ֤י ׀ אֵלֶ֣יךָ יְהוָ֣ה שִׁוַּ֑עְתִּי וּ֝בַבֹּ֗קֶר תְּֽפִלָּתִ֥י תְקַדְּמֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "לָמָ֣ה יְ֭הוָה תִּזְנַ֣ח נַפְשִׁ֑י תַּסְתִּ֖יר פָּנֶ֣יךָ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "עָ֘נִ֤י אֲנִ֣י וְגֹוֵ֣עַ מִנֹּ֑עַר נָשָׂ֖אתִי אֵמֶ֣יךָ אָפֽוּנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "עָ֭לַי עָבְר֣וּ חֲרוֹנֶ֑יךָ בִּ֝עוּתֶ֗יךָ צִמְּתוּתֻֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "סַבּ֣וּנִי כַ֭מַּיִם כָּל ־ הַיּ֑וֹם הִקִּ֖יפוּ עָלַ֣י יָֽחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.88.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 19,
      "referenceLabel": "Psalms 88:19",
      "text": "הִרְחַ֣קְתָּ מִ֭מֶּנִּי אֹהֵ֣ב וָרֵ֑עַ מְֽיֻדָּעַ֥י מַחְשָֽׁךְ ׃",
      "paragraphStart": false
    }
  ]
}
