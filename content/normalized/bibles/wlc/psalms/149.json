{
  "chapter": {
    "id": "wlc:psalms.149",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.149.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ שִׁ֣ירוּ לַֽ֭יהוָה שִׁ֣יר חָדָ֑שׁ תְּ֝הִלָּת֗וֹ בִּקְהַ֥ל חֲסִידִֽים ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.149.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "יִשְׂמַ֣ח יִשְׂרָאֵ֣ל בְּעֹשָׂ֑יו בְּנֵֽי ־ צִ֝יּ֗וֹן יָגִ֥ילוּ בְמַלְכָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "יְהַֽלְל֣וּ שְׁמ֣וֹ בְמָח֑וֹל בְּתֹ֥ף וְ֝כִנּ֗וֹר יְזַמְּרוּ ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "כִּֽי ־ רוֹצֶ֣ה יְהוָ֣ה בְּעַמּ֑וֹ יְפָאֵ֥ר עֲ֝נָוִ֗ים בִּישׁוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "יַעְלְז֣וּ חֲסִידִ֣ים בְּכָב֑וֹד יְ֝רַנְּנ֗וּ עַל ־ מִשְׁכְּבוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "רוֹמְמ֣וֹת אֵ֭ל בִּגְרוֹנָ֑ם וְחֶ֖רֶב פִּֽיפִיּ֣וֹת בְּיָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "לַעֲשׂ֣וֹת נְ֭קָמָה בַּגּוֹיִ֑ם תּֽ֝וֹכֵחֹ֗ת בַּל ־ אֻמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "לֶאְסֹ֣ר מַלְכֵיהֶ֣ם בְּזִקִּ֑ים וְ֝נִכְבְּדֵיהֶ֗ם בְּכַבְלֵ֥י בַרְזֶֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.149.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "לַעֲשׂ֤וֹת בָּהֶ֨ם ׀ מִשְׁפָּ֬ט כָּת֗וּב הָדָ֣ר ה֭וּא לְכָל ־ חֲסִידָ֗יו הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
