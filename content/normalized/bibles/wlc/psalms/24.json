{
  "chapter": {
    "id": "wlc:psalms.24",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.24.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "לְדָוִ֗ד מִ֫זְמ֥וֹר לַֽ֭יהוָה הָאָ֣רֶץ וּמְלוֹאָ֑הּ תֵּ֝בֵ֗ל וְיֹ֣שְׁבֵי בָֽהּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.24.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "כִּי ־ ה֭וּא עַל ־ יַמִּ֣ים יְסָדָ֑הּ וְעַל ־ נְ֝הָר֗וֹת יְכוֹנְנֶֽהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "מִֽי ־ יַעֲלֶ֥ה בְהַר ־ יְהוָ֑ה וּמִי ־ יָ֝קוּם בִּמְק֥וֹם קָדְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "נְקִ֥י כַפַּ֗יִם וּֽבַר ־ לֵ֫בָ֥ב אֲשֶׁ֤ר ׀ לֹא ־ נָשָׂ֣א לַשָּׁ֣וְא נַפְשִׁ֑י וְלֹ֖א נִשְׁבַּ֣ע לְמִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "יִשָּׂ֣א בְ֭רָכָה מֵאֵ֣ת יְהוָ֑ה וּ֝צְדָקָ֗ה מֵאֱלֹהֵ֥י יִשְׁעֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "זֶ֭ה דּ֣וֹר דרשו מְבַקְשֵׁ֨י פָנֶ֖יךָ יַעֲקֹ֣ב סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "שְׂא֤וּ שְׁעָרִ֨ים ׀ רָֽאשֵׁיכֶ֗ם וְֽ֭הִנָּשְׂאוּ פִּתְחֵ֣י עוֹלָ֑ם וְ֝יָב֗וֹא מֶ֣לֶךְ הַכָּבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "מִ֥י זֶה֮ מֶ֤לֶךְ הַכָּ֫ב֥וֹד יְ֭הוָה עִזּ֣וּז וְגִבּ֑וֹר יְ֝הוָ֗ה גִּבּ֥וֹר מִלְחָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "שְׂא֤וּ שְׁעָרִ֨ים ׀ רָֽאשֵׁיכֶ֗ם וּ֭שְׂאוּ פִּתְחֵ֣י עוֹלָ֑ם וְ֝יָבֹא מֶ֣לֶךְ הַכָּבֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.24.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "מִ֤י ה֣וּא זֶה֮ מֶ֤לֶךְ הַכָּ֫ב֥וֹד יְהוָ֥ה צְבָא֑וֹת ה֤וּא מֶ֖לֶךְ הַכָּב֣וֹד סֶֽלָה ׃",
      "paragraphStart": false
    }
  ]
}
