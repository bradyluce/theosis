{
  "chapter": {
    "id": "wlc:psalms.16",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 16,
    "referenceLabel": "Psalms 16",
    "summary": "Source text for Psalms 16 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.16.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Psalms 16:1",
      "text": "מִכְתָּ֥ם לְדָוִ֑ד שָֽׁמְרֵ֥נִי אֵ֝֗ל כִּֽי ־ חָסִ֥יתִי בָֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.16.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Psalms 16:2",
      "text": "אָמַ֣רְתְּ לַֽ֭יהוָה אֲדֹנָ֣י אָ֑תָּה ט֝וֹבָתִ֗י בַּל ־ עָלֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Psalms 16:3",
      "text": "לִ֭קְדוֹשִׁים אֲשֶׁר ־ בָּאָ֣רֶץ הֵ֑מָּה וְ֝אַדִּירֵ֗י כָּל ־ חֶפְצִי ־ בָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Psalms 16:4",
      "text": "יִרְבּ֥וּ עַצְּבוֹתָם֮ אַחֵ֪ר מָ֫הָ֥רוּ בַּל ־ אַסִּ֣יךְ נִסְכֵּיהֶ֣ם מִדָּ֑ם וּֽבַל ־ אֶשָּׂ֥א אֶת ־ שְׁ֝מוֹתָ֗ם עַל ־ שְׂפָתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Psalms 16:5",
      "text": "יְֽהוָ֗ה מְנָת ־ חֶלְקִ֥י וְכוֹסִ֑י אַ֝תָּ֗ה תּוֹמִ֥יךְ גּוֹרָלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Psalms 16:6",
      "text": "חֲבָלִ֣ים נָֽפְלוּ ־ לִ֭י בַּנְּעִמִ֑ים אַף ־ נַ֝חֲלָ֗ת שָֽׁפְרָ֥ה עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Psalms 16:7",
      "text": "אֲבָרֵ֗ךְ אֶת ־ יְ֭הוָה אֲשֶׁ֣ר יְעָצָ֑נִי אַף ־ לֵ֝יל֗וֹת יִסְּר֥וּנִי כִלְיוֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Psalms 16:8",
      "text": "שִׁוִּ֬יתִי יְהוָ֣ה לְנֶגְדִּ֣י תָמִ֑יד כִּ֥י מִֽ֝ימִינִ֗י בַּל ־ אֶמּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Psalms 16:9",
      "text": "לָכֵ֤ן ׀ שָׂמַ֣ח לִ֭בִּי וַיָּ֣גֶל כְּבוֹדִ֑י אַף ־ בְּ֝שָׂרִ֗י יִשְׁכֹּ֥ן לָבֶֽטַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Psalms 16:10",
      "text": "כִּ֤י ׀ לֹא ־ תַעֲזֹ֣ב נַפְשִׁ֣י לִשְׁא֑וֹל לֹֽא ־ תִתֵּ֥ן חֲ֝סִידְךָ֗ לִרְא֥וֹת שָֽׁחַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.16.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Psalms 16:11",
      "text": "תּֽוֹדִיעֵנִי֮ אֹ֤רַח חַ֫יִּ֥ים שֹׂ֣בַע שְׂ֭מָחוֹת אֶת ־ פָּנֶ֑יךָ נְעִמ֖וֹת בִּימִינְךָ֣ נֶֽצַח ׃",
      "paragraphStart": false
    }
  ]
}
