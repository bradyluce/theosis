{
  "chapter": {
    "id": "wlc:psalms.47",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.47.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "לַמְנַצֵּ֬חַ ׀ לִבְנֵי ־ קֹ֬רַח מִזְמֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.47.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "כָּֽל ־ הָ֭עַמִּים תִּקְעוּ ־ כָ֑ף הָרִ֥יעוּ לֵ֝אלֹהִ֗ים בְּק֣וֹל רִנָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "כִּֽי ־ יְהוָ֣ה עֶלְי֣וֹן נוֹרָ֑א מֶ֥לֶךְ גָּ֝דוֹל עַל ־ כָּל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "יַדְבֵּ֣ר עַמִּ֣ים תַּחְתֵּ֑ינוּ וּ֝לְאֻמִּ֗ים תַּ֣חַת רַגְלֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "יִבְחַר ־ לָ֥נוּ אֶת ־ נַחֲלָתֵ֑נוּ אֶ֥ת גְּא֨וֹן יַעֲקֹ֖ב אֲשֶׁר ־ אָהֵ֣ב סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "עָלָ֣ה אֱ֭לֹהִים בִּתְרוּעָ֑ה יְ֝הֹוָ֗ה בְּק֣וֹל שׁוֹפָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "זַמְּר֣וּ אֱלֹהִ֣ים זַמֵּ֑רוּ זַמְּר֖וּ לְמַלְכֵּ֣נוּ זַמֵּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "כִּ֤י מֶ֖לֶךְ כָּל ־ הָאָ֥רֶץ אֱלֹהִ֗ים זַמְּר֥וּ מַשְׂכִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "מָלַ֣ךְ אֱ֭לֹהִים עַל ־ גּוֹיִ֑ם אֱ֝לֹהִ֗ים יָשַׁ֤ב ׀ עַל ־ כִּסֵּ֬א קָדְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.47.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 10,
      "referenceLabel": "Psalms 47:10",
      "text": "נְדִ֘יבֵ֤י עַמִּ֨ים ׀ נֶאֱסָ֗פוּ עַם֮ אֱלֹהֵ֪י אַבְרָ֫הָ֥ם כִּ֣י לֵֽ֭אלֹהִים מָֽגִנֵּי ־ אֶ֗רֶץ מְאֹ֣ד נַעֲלָֽה ׃",
      "paragraphStart": false
    }
  ]
}
