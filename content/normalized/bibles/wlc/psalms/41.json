{
  "chapter": {
    "id": "wlc:psalms.41",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 41,
    "referenceLabel": "Psalms 41",
    "summary": "Source text for Psalms 41 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.41.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Psalms 41:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.41.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Psalms 41:2",
      "text": "אַ֭שְׁרֵי מַשְׂכִּ֣יל אֶל ־ דָּ֑ל בְּי֥וֹם רָ֝עָ֗ה יְֽמַלְּטֵ֥הוּ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Psalms 41:3",
      "text": "יְהוָ֤ה ׀ יִשְׁמְרֵ֣הוּ וִֽ֭יחַיֵּהוּ יאשר בָּאָ֑רֶץ וְאַֽל ־ תִּ֝תְּנֵ֗הוּ בְּנֶ֣פֶשׁ אֹיְבָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Psalms 41:4",
      "text": "יְֽהוָ֗ה יִ֭סְעָדֶנּוּ עַל ־ עֶ֣רֶשׂ דְּוָ֑י כָּל ־ מִ֝שְׁכָּב֗וֹ הָפַ֥כְתָּ בְחָלְיֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Psalms 41:5",
      "text": "אֲֽנִי ־ אָ֭מַרְתִּי יְהוָ֣ה חָנֵּ֑נִי רְפָאָ֥ה נַ֝פְשִׁ֗י כִּי ־ חָטָ֥אתִי לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Psalms 41:6",
      "text": "אוֹיְבַ֗י יֹאמְר֣וּ רַ֣ע לִ֑י מָתַ֥י יָ֝מ֗וּת וְאָבַ֥ד שְׁמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Psalms 41:7",
      "text": "וְאִם ־ בָּ֤א לִרְא֨וֹת ׀ שָׁ֤וְא יְדַבֵּ֗ר לִבּ֗וֹ יִקְבָּץ ־ אָ֥וֶן ל֑וֹ יֵצֵ֖א לַח֣וּץ יְדַבֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Psalms 41:8",
      "text": "יַ֗חַד עָלַ֣י יִ֭תְלַחֲשׁוּ כָּל ־ שֹׂנְאָ֑י עָלַ֓י ׀ יַחְשְׁב֖וּ רָעָ֣ה לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Psalms 41:9",
      "text": "דְּֽבַר ־ בְּ֭לִיַּעַל יָצ֣וּק בּ֑וֹ וַאֲשֶׁ֥ר שָׁ֝כַ֗ב לֹא ־ יוֹסִ֥יף לָקֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Psalms 41:10",
      "text": "גַּם ־ אִ֤ישׁ שְׁלוֹמִ֨י ׀ אֲשֶׁר ־ בָּטַ֣חְתִּי ב֭וֹ אוֹכֵ֣ל לַחְמִ֑י הִגְדִּ֖יל עָלַ֣י עָקֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Psalms 41:11",
      "text": "וְאַתָּ֤ה יְהוָ֗ה חָנֵּ֥נִי וַהֲקִימֵ֑נִי וַֽאֲשַׁלְּמָ֥ה לָהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Psalms 41:12",
      "text": "בְּזֹ֣את יָ֭דַעְתִּי כִּֽי ־ חָפַ֣צְתָּ בִּ֑י כִּ֤י לֹֽא ־ יָרִ֖יעַ אֹיְבִ֣י עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Psalms 41:13",
      "text": "וַאֲנִ֗י בְּ֭תֻמִּי תָּמַ֣כְתָּ בִּ֑י וַתַּצִּיבֵ֖נִי לְפָנֶ֣יךָ לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.41.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 14,
      "referenceLabel": "Psalms 41:14",
      "text": "בָּ֘ר֤וּךְ יְהוָ֨ה ׀ אֱלֹ֘הֵ֤י יִשְׂרָאֵ֗ל מֵֽ֭הָעוֹלָם וְעַ֥ד הָעוֹלָ֗ם אָ֘מֵ֥ן ׀ וְאָמֵֽן ׃",
      "paragraphStart": false
    }
  ]
}
