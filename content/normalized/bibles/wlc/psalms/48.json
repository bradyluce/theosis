{
  "chapter": {
    "id": "wlc:psalms.48",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 48,
    "referenceLabel": "Psalms 48",
    "summary": "Source text for Psalms 48 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.48.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Psalms 48:1",
      "text": "שִׁ֥יר מִ֝זְמוֹר לִבְנֵי ־ קֹֽרַח ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.48.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Psalms 48:2",
      "text": "גָּ֘ד֤וֹל יְהוָ֣ה וּמְהֻלָּ֣ל מְאֹ֑ד בְּעִ֥יר אֱ֝לֹהֵ֗ינוּ הַר ־ קָדְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Psalms 48:3",
      "text": "יְפֵ֥ה נוֹף֮ מְשׂ֪וֹשׂ כָּל ־ הָ֫אָ֥רֶץ הַר ־ צִ֭יּוֹן יַרְכְּתֵ֣י צָפ֑וֹן קִ֝רְיַ֗ת מֶ֣לֶךְ רָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Psalms 48:4",
      "text": "אֱלֹהִ֥ים בְּאַרְמְנוֹתֶ֗יהָ נוֹדַ֥ע לְמִשְׂגָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Psalms 48:5",
      "text": "כִּֽי ־ הִנֵּ֣ה הַ֭מְּלָכִים נֽוֹעֲד֑וּ עָבְר֥וּ יַחְדָּֽו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Psalms 48:6",
      "text": "הֵ֣מָּה רָ֭אוּ כֵּ֣ן תָּמָ֑הוּ נִבְהֲל֥וּ נֶחְפָּֽזוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Psalms 48:7",
      "text": "רְ֭עָדָה אֲחָזָ֣תַם שָׁ֑ם חִ֝֗יל כַּיּוֹלֵֽדָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Psalms 48:8",
      "text": "בְּר֥וּחַ קָדִ֑ים תְּ֝שַׁבֵּ֗ר אֳנִיּ֥וֹת תַּרְשִֽׁישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Psalms 48:9",
      "text": "כַּאֲשֶׁ֤ר שָׁמַ֨עְנוּ ׀ כֵּ֤ן רָאִ֗ינוּ בְּעִיר ־ יְהוָ֣ה צְ֭בָאוֹת בְּעִ֣יר אֱלֹהֵ֑ינוּ אֱלֹ֘הִ֤ים יְכוֹנְנֶ֖הָ עַד ־ עוֹלָ֣ם סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Psalms 48:10",
      "text": "דִּמִּ֣ינוּ אֱלֹהִ֣ים חַסְדֶּ֑ךָ בְּ֝קֶ֗רֶב הֵיכָלֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Psalms 48:11",
      "text": "כְּשִׁמְךָ֤ אֱלֹהִ֗ים כֵּ֣ן תְּ֭הִלָּתְךָ עַל ־ קַצְוֵי ־ אֶ֑רֶץ צֶ֝֗דֶק מָלְאָ֥ה יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Psalms 48:12",
      "text": "יִשְׂמַ֤ח ׀ הַר ־ צִיּ֗וֹן תָּ֭גֵלְנָה בְּנ֣וֹת יְהוּדָ֑ה לְ֝מַ֗עַן מִשְׁפָּטֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Psalms 48:13",
      "text": "סֹ֣בּוּ צִ֭יּוֹן וְהַקִּיפ֑וּהָ סִ֝פְר֗וּ מִגְדָּלֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Psalms 48:14",
      "text": "שִׁ֤יתוּ לִבְּכֶ֨ם ׀ לְֽחֵילָ֗ה פַּסְּג֥וּ אַרְמְנוֹתֶ֑יהָ לְמַ֥עַן תְּ֝סַפְּר֗וּ לְד֣וֹר אַחֲרֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.48.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 15,
      "referenceLabel": "Psalms 48:15",
      "text": "כִּ֤י זֶ֨ה ׀ אֱלֹהִ֣ים אֱ֭לֹהֵינוּ עוֹלָ֣ם וָעֶ֑ד ה֖וּא יְנַהֲגֵ֣נוּ עַל ־ מֽוּת ׃",
      "paragraphStart": false
    }
  ]
}
