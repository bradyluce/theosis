{
  "chapter": {
    "id": "wlc:psalms.36",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.36.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "לַמְנַצֵּ֬חַ ׀ לְעֶֽבֶד ־ יְהוָ֬ה לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.36.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "נְאֻֽם ־ פֶּ֣שַׁע לָ֭רָשָׁע בְּקֶ֣רֶב לִבִּ֑י אֵֽין ־ פַּ֥חַד אֱ֝לֹהִ֗ים לְנֶ֣גֶד עֵינָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "כִּֽי ־ הֶחֱלִ֣יק אֵלָ֣יו בְּעֵינָ֑יו לִמְצֹ֖א עֲוֺנ֣וֹ לִשְׂנֹֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "דִּבְרֵי ־ פִ֭יו אָ֣וֶן וּמִרְמָ֑ה חָדַ֖ל לְהַשְׂכִּ֣יל לְהֵיטִֽיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "אָ֤וֶן ׀ יַחְשֹׁ֗ב עַֽל ־ מִשְׁכָּ֫ב֥וֹ יִ֭תְיַצֵּב עַל ־ דֶּ֣רֶךְ לֹא ־ ט֑וֹב רָ֝֗ע לֹ֣א יִמְאָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "יְ֭הוָה בְּהַשָּׁמַ֣יִם חַסְדֶּ֑ךָ אֱ֝מֽוּנָתְךָ֗ עַד ־ שְׁחָקִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "צִדְקָֽתְךָ֨ ׀ כְּֽהַרְרֵי ־ אֵ֗ל מִ֭שְׁפָּטֶךָ תְּה֣וֹם רַבָּ֑ה אָ֤דָֽם ־ וּבְהֵמָ֖ה תוֹשִׁ֣יעַ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "מַה ־ יָּקָ֥ר חַסְדְּךָ֗ אֱלֹ֫הִ֥ים וּבְנֵ֥י אָדָ֑ם בְּצֵ֥ל כְּ֝נָפֶ֗יךָ יֶחֱסָיֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "יִ֭רְוְיֻן מִדֶּ֣שֶׁן בֵּיתֶ֑ךָ וְנַ֖חַל עֲדָנֶ֣יךָ תַשְׁקֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "כִּֽי ־ עִ֭מְּךָ מְק֣וֹר חַיִּ֑ים בְּ֝אוֹרְךָ֗ נִרְאֶה ־ אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "מְשֹׁ֣ךְ חַ֭סְדְּךָ לְיֹדְעֶ֑יךָ וְ֝צִדְקָֽתְךָ֗ לְיִשְׁרֵי ־ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "אַל ־ תְּ֭בוֹאֵנִי רֶ֣גֶל גַּאֲוָ֑ה וְיַד ־ רְ֝שָׁעִ֗ים אַל ־ תְּנִדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.36.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Psalms 36:13",
      "text": "שָׁ֣ם נָ֭פְלוּ פֹּ֣עֲלֵי אָ֑וֶן דֹּ֝ח֗וּ וְלֹא ־ יָ֥כְלוּ קֽוּם ׃",
      "paragraphStart": false
    }
  ]
}
