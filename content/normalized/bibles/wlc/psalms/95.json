{
  "chapter": {
    "id": "wlc:psalms.95",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.95.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "לְ֭כוּ נְרַנְּנָ֣ה לַיהוָ֑ה נָ֝רִ֗יעָה לְצ֣וּר יִשְׁעֵֽנוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.95.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "נְקַדְּמָ֣ה פָנָ֣יו בְּתוֹדָ֑ה בִּ֝זְמִר֗וֹת נָרִ֥יעַֽ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "כִּ֤י אֵ֣ל גָּד֣וֹל יְהוָ֑ה וּמֶ֥לֶךְ גָּ֝ד֗וֹל עַל ־ כָּל ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "אֲשֶׁ֣ר בְּ֭יָדוֹ מֶחְקְרֵי ־ אָ֑רֶץ וְתוֹעֲפ֖וֹת הָרִ֣ים לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "אֲשֶׁר ־ ל֣וֹ הַ֭יָּם וְה֣וּא עָשָׂ֑הוּ וְ֝יַבֶּ֗שֶׁת יָדָ֥יו יָצָֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "בֹּ֭אוּ נִשְׁתַּחֲוֶ֣ה וְנִכְרָ֑עָה נִ֝בְרְכָ֗ה לִֽפְנֵי ־ יְהוָ֥ה עֹשֵֽׂנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "כִּ֘י ה֤וּא אֱלֹהֵ֗ינוּ וַאֲנַ֤חְנוּ עַ֣ם מַ֭רְעִיתוֹ וְצֹ֣אן יָד֑וֹ הַ֝יּ֗וֹם אִֽם ־ בְּקֹל֥וֹ תִשְׁמָֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "אַל ־ תַּקְשׁ֣וּ לְ֭בַבְכֶם כִּמְרִיבָ֑ה כְּי֥וֹם מַ֝סָּ֗ה בַּמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "אֲשֶׁ֣ר נִ֭סּוּנִי אֲבוֹתֵיכֶ֑ם בְּ֝חָנ֗וּנִי גַּם ־ רָא֥וּ פָעֳלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "אַרְבָּ֘עִ֤ים שָׁנָ֨ה ׀ אָ֘ק֤וּט בְּד֗וֹר וָאֹמַ֗ר עַ֤ם תֹּעֵ֣י לֵבָ֣ב הֵ֑ם וְ֝הֵ֗ם לֹא ־ יָדְע֥וּ דְרָכָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.95.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "אֲשֶׁר ־ נִשְׁבַּ֥עְתִּי בְאַפִּ֑י אִם ־ יְ֝בֹא֗וּן אֶל ־ מְנוּחָתִֽי ׃",
      "paragraphStart": false
    }
  ]
}
