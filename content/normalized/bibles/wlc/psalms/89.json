{
  "chapter": {
    "id": "wlc:psalms.89",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.89.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "מַ֝שְׂכִּ֗יל לְאֵיתָ֥ן הָֽאֶזְרָחִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.89.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "חַֽסְדֵ֣י יְ֭הוָה עוֹלָ֣ם אָשִׁ֑ירָה לְדֹ֥ר וָדֹ֓ר ׀ אוֹדִ֖יעַ אֱמוּנָתְךָ֣ בְּפִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "כִּֽי ־ אָמַ֗רְתִּי ע֭וֹלָם חֶ֣סֶד יִבָּנֶ֑ה שָׁמַ֓יִם ׀ תָּכִ֖ן אֱמוּנָתְךָ֣ בָהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "כָּרַ֣תִּֽי בְ֭רִית לִבְחִירִ֑י נִ֝שְׁבַּ֗עְתִּי לְדָוִ֥ד עַבְדִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "עַד ־ ע֭וֹלָם אָכִ֣ין זַרְעֶ֑ךָ וּבָנִ֨יתִי לְדֹר ־ וָד֖וֹר כִּסְאֲךָ֣ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "וְי֘וֹד֤וּ שָׁמַ֣יִם פִּלְאֲךָ֣ יְהוָ֑ה אַף ־ אֱ֝מֽוּנָתְךָ֗ בִּקְהַ֥ל קְדֹשִֽׁים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "כִּ֤י מִ֣י בַ֭שַּׁחַק יַעֲרֹ֣ךְ לַיהוָ֑ה יִדְמֶ֥ה לַ֝יהוָ֗ה בִּבְנֵ֥י אֵלִים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "אֵ֣ל נַ֭עֲרָץ בְּסוֹד ־ קְדֹשִׁ֣ים רַבָּ֑ה וְ֝נוֹרָ֗א עַל ־ כָּל ־ סְבִיבָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "יְהוָ֤ה ׀ אֱלֹ֘הֵ֤י צְבָא֗וֹת מִֽי ־ כָֽמ֖וֹךָ חֲסִ֥ין ׀ יָ֑הּ וֶ֝אֱמֽוּנָתְךָ֗ סְבִיבוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "אַתָּ֣ה מ֭וֹשֵׁל בְּגֵא֣וּת הַיָּ֑ם בְּשׂ֥וֹא גַ֝לָּ֗יו אַתָּ֥ה תְשַׁבְּחֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "אַתָּ֤ה דִכִּ֣אתָ כֶחָלָ֣ל רָ֑הַב בִּזְר֥וֹעַ עֻ֝זְּךָ֗ פִּזַּ֥רְתָּ אוֹיְבֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "לְךָ֣ שָׁ֭מַיִם אַף ־ לְךָ֥ אָ֑רֶץ תֵּבֵ֥ל וּ֝מְלֹאָ֗הּ אַתָּ֥ה יְסַדְתָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "צָפ֣וֹן וְ֭יָמִין אַתָּ֣ה בְרָאתָ֑ם תָּב֥וֹר וְ֝חֶרְמ֗וֹן בְּשִׁמְךָ֥ יְרַנֵּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "לְךָ֣ זְ֭רוֹעַ עִם ־ גְּבוּרָ֑ה תָּעֹ֥ז יָ֝דְךָ֗ תָּר֥וּם יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "צֶ֣דֶק וּ֭מִשְׁפָּט מְכ֣וֹן כִּסְאֶ֑ךָ חֶ֥סֶד וֶ֝אֱמֶ֗ת יְֽקַדְּמ֥וּ פָנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "אַשְׁרֵ֣י הָ֭עָם יוֹדְעֵ֣י תְרוּעָ֑ה יְ֝הוָ֗ה בְּֽאוֹר ־ פָּנֶ֥יךָ יְהַלֵּכֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "בְּ֭שִׁמְךָ יְגִיל֣וּן כָּל ־ הַיּ֑וֹם וּבְצִדְקָתְךָ֥ יָרֽוּמוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 18,
      "referenceLabel": "Psalms 89:18",
      "text": "כִּֽי ־ תִפְאֶ֣רֶת עֻזָּ֣מוֹ אָ֑תָּה וּ֝בִרְצֹנְךָ֗ תרים קַרְנֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 19,
      "referenceLabel": "Psalms 89:19",
      "text": "כִּ֣י לַֽ֭יהוָה מָֽגִנֵּ֑נוּ וְלִקְד֖וֹשׁ יִשְׂרָאֵ֣ל מַלְכֵּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 20,
      "referenceLabel": "Psalms 89:20",
      "text": "אָ֤ז דִּבַּ֥רְתָּֽ ־ בְחָ֡זוֹן לַֽחֲסִידֶ֗יךָ וַתֹּ֗אמֶר שִׁוִּ֣יתִי עֵ֭זֶר עַל ־ גִּבּ֑וֹר הֲרִימ֖וֹתִי בָח֣וּר מֵעָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 21,
      "referenceLabel": "Psalms 89:21",
      "text": "מָ֭צָאתִי דָּוִ֣ד עַבְדִּ֑י בְּשֶׁ֖מֶן קָדְשִׁ֣י מְשַׁחְתִּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 22,
      "referenceLabel": "Psalms 89:22",
      "text": "אֲשֶׁ֣ר יָ֭דִי תִּכּ֣וֹן עִמּ֑וֹ אַף ־ זְרוֹעִ֥י תְאַמְּצֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 23,
      "referenceLabel": "Psalms 89:23",
      "text": "לֹֽא ־ יַשִּׁ֣א אוֹיֵ֣ב בּ֑וֹ וּבֶן ־ עַ֝וְלָ֗ה לֹ֣א יְעַנֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 24,
      "referenceLabel": "Psalms 89:24",
      "text": "וְכַתּוֹתִ֣י מִפָּנָ֣יו צָרָ֑יו וּמְשַׂנְאָ֥יו אֶגּֽוֹף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 25,
      "referenceLabel": "Psalms 89:25",
      "text": "וֶֽאֶֽמוּנָתִ֣י וְחַסְדִּ֣י עִמּ֑וֹ וּ֝בִשְׁמִ֗י תָּר֥וּם קַרְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 26,
      "referenceLabel": "Psalms 89:26",
      "text": "וְשַׂמְתִּ֣י בַיָּ֣ם יָד֑וֹ וּֽבַנְּהָר֥וֹת יְמִינֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 27,
      "referenceLabel": "Psalms 89:27",
      "text": "ה֣וּא יִ֭קְרָאֵנִי אָ֣בִי אָ֑תָּה אֵ֝לִ֗י וְצ֣וּר יְשׁוּעָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 28,
      "referenceLabel": "Psalms 89:28",
      "text": "אַף ־ אָ֭נִי בְּכ֣וֹר אֶתְּנֵ֑הוּ עֶ֝לְי֗וֹן לְמַלְכֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 29,
      "referenceLabel": "Psalms 89:29",
      "text": "לְ֭עוֹלָ֗ם אשמור ־ ל֣וֹ חַסְדִּ֑י וּ֝בְרִיתִ֗י נֶאֱמֶ֥נֶת לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 30,
      "referenceLabel": "Psalms 89:30",
      "text": "וְשַׂמְתִּ֣י לָעַ֣ד זַרְע֑וֹ וְ֝כִסְא֗וֹ כִּימֵ֥י שָׁמָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 31,
      "referenceLabel": "Psalms 89:31",
      "text": "אִם ־ יַֽעַזְב֣וּ בָ֭נָיו תּוֹרָתִ֑י וּ֝בְמִשְׁפָּטַ֗י לֹ֣א יֵלֵכֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 32,
      "referenceLabel": "Psalms 89:32",
      "text": "אִם ־ חֻקֹּתַ֥י יְחַלֵּ֑לוּ וּ֝מִצְוֺתַ֗י לֹ֣א יִשְׁמֹֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 33,
      "referenceLabel": "Psalms 89:33",
      "text": "וּפָקַדְתִּ֣י בְשֵׁ֣בֶט פִּשְׁעָ֑ם וּבִנְגָעִ֥ים עֲוֺנָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 34,
      "referenceLabel": "Psalms 89:34",
      "text": "וְ֭חַסְדִּי לֹֽא ־ אָפִ֣יר מֵֽעִמּ֑וֹ וְלֹֽא ־ אֲ֝שַׁקֵּ֗ר בֶּאֱמוּנָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 35,
      "referenceLabel": "Psalms 89:35",
      "text": "לֹא ־ אֲחַלֵּ֥ל בְּרִיתִ֑י וּמוֹצָ֥א שְׂ֝פָתַ֗י לֹ֣א אֲשַׁנֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 36,
      "referenceLabel": "Psalms 89:36",
      "text": "אַ֭חַת נִשְׁבַּ֣עְתִּי בְקָדְשִׁ֑י אִֽם ־ לְדָוִ֥ד אֲכַזֵּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 37,
      "referenceLabel": "Psalms 89:37",
      "text": "זַ֭רְעוֹ לְעוֹלָ֣ם יִהְיֶ֑ה וְכִסְא֖וֹ כַשֶּׁ֣מֶשׁ נֶגְדִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.38",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 38,
      "referenceLabel": "Psalms 89:38",
      "text": "כְּ֭יָרֵחַ יִכּ֣וֹן עוֹלָ֑ם וְעֵ֥ד בַּ֝שַּׁ֗חַק נֶאֱמָ֥ן סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.39",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 39,
      "referenceLabel": "Psalms 89:39",
      "text": "וְאַתָּ֣ה זָ֭נַחְתָּ וַתִּמְאָ֑ס הִ֝תְעַבַּ֗רְתָּ עִם ־ מְשִׁיחֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.40",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 40,
      "referenceLabel": "Psalms 89:40",
      "text": "נֵ֭אַרְתָּה בְּרִ֣ית עַבְדֶּ֑ךָ חִלַּ֖לְתָּ לָאָ֣רֶץ נִזְרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.41",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 41,
      "referenceLabel": "Psalms 89:41",
      "text": "פָּרַ֥צְתָּ כָל ־ גְּדֵרֹתָ֑יו שַׂ֖מְתָּ מִבְצָרָ֣יו מְחִתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.42",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 42,
      "referenceLabel": "Psalms 89:42",
      "text": "שַׁ֭סֻּהוּ כָּל ־ עֹ֣בְרֵי דָ֑רֶךְ הָיָ֥ה חֶ֝רְפָּ֗ה לִשְׁכֵנָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.43",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 43,
      "referenceLabel": "Psalms 89:43",
      "text": "הֲ֭רִימוֹתָ יְמִ֣ין צָרָ֑יו הִ֝שְׂמַ֗חְתָּ כָּל ־ אוֹיְבָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.44",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 44,
      "referenceLabel": "Psalms 89:44",
      "text": "אַף ־ תָּ֭שִׁיב צ֣וּר חַרְבּ֑וֹ וְלֹ֥א הֲ֝קֵימֹת֗וֹ בַּמִּלְחָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.45",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 45,
      "referenceLabel": "Psalms 89:45",
      "text": "הִשְׁבַּ֥תָּ מִטְּהָר֑וֹ וְ֝כִסְא֗וֹ לָאָ֥רֶץ מִגַּֽרְתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.46",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 46,
      "referenceLabel": "Psalms 89:46",
      "text": "הִ֭קְצַרְתָּ יְמֵ֣י עֲלוּמָ֑יו הֶֽעֱטִ֨יתָ עָלָ֖יו בּוּשָׁ֣ה סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.47",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 47,
      "referenceLabel": "Psalms 89:47",
      "text": "עַד ־ מָ֣ה יְ֭הוָה תִּסָּתֵ֣ר לָנֶ֑צַח תִּבְעַ֖ר כְּמוֹ ־ אֵ֣שׁ חֲמָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.48",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 48,
      "referenceLabel": "Psalms 89:48",
      "text": "זְכָר ־ אֲנִ֥י מֶה ־ חָ֑לֶד עַל ־ מַה ־ שָּׁ֝֗וְא בָּרָ֥אתָ כָל ־ בְּנֵי ־ אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.49",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 49,
      "referenceLabel": "Psalms 89:49",
      "text": "מִ֤י גֶ֣בֶר יִֽ֭חְיֶה וְלֹ֣א יִרְאֶה ־ מָּ֑וֶת יְמַלֵּ֨ט נַפְשׁ֖וֹ מִיַּד ־ שְׁא֣וֹל סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.50",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 50,
      "referenceLabel": "Psalms 89:50",
      "text": "אַיֵּ֤ה ׀ חֲסָדֶ֖יךָ הָרִאשֹׁנִ֥ים ׀ אֲדֹנָ֑י נִשְׁבַּ֥עְתָּ לְ֝דָוִ֗ד בֶּאֱמוּנָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.51",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 51,
      "referenceLabel": "Psalms 89:51",
      "text": "זְכֹ֣ר אֲ֭דֹנָי חֶרְפַּ֣ת עֲבָדֶ֑יךָ שְׂאֵתִ֥י בְ֝חֵיקִ֗י כָּל ־ רַבִּ֥ים עַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.52",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 52,
      "referenceLabel": "Psalms 89:52",
      "text": "אֲשֶׁ֤ר חֵרְפ֖וּ אוֹיְבֶ֥יךָ ׀ יְהוָ֑ה אֲשֶׁ֥ר חֵ֝רְפ֗וּ עִקְּב֥וֹת מְשִׁיחֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.89.53",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 53,
      "referenceLabel": "Psalms 89:53",
      "text": "בָּר֖וּךְ יְהוָ֥ה לְ֝עוֹלָ֗ם אָ֘מֵ֥ן ׀ וְאָמֵֽן ׃",
      "paragraphStart": false
    }
  ]
}
