  },
  "verses": [
    {
      "id": "wlc:psalms.23.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "מִזְמ֥וֹר לְדָוִ֑ד יְהוָ֥ה רֹ֝עִ֗י לֹ֣א אֶחְסָֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.23.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "בִּנְא֣וֹת דֶּ֭שֶׁא יַרְבִּיצֵ֑נִי עַל ־ מֵ֖י מְנֻח֣וֹת יְנַהֲלֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.23.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "נַפְשִׁ֥י יְשׁוֹבֵ֑ב יַֽנְחֵ֥נִי בְמַעְגְּלֵי ־ צֶ֝֗דֶק לְמַ֣עַן שְׁמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.23.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "גַּ֤ם כִּֽי ־ אֵלֵ֨ךְ בְּגֵ֪יא צַלְמָ֡וֶת לֹא ־ אִ֘ירָ֤א רָ֗ע כִּי ־ אַתָּ֥ה עִמָּדִ֑י שִׁבְטְךָ֥ וּ֝מִשְׁעַנְתֶּ֗ךָ הֵ֣מָּה יְנַֽחֲמֻֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.23.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "תַּעֲרֹ֬ךְ לְפָנַ֨י ׀ שֻׁלְחָ֗ן נֶ֥גֶד צֹרְרָ֑י דִּשַּׁ֖נְתָּ בַשֶּׁ֥מֶן רֹ֝אשִׁ֗י כּוֹסִ֥י רְוָיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.23.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "אַ֤ךְ ׀ ט֤וֹב וָחֶ֣סֶד יִ֭רְדְּפוּנִי כָּל ־ יְמֵ֣י חַיָּ֑י וְשַׁבְתִּ֥י בְּבֵית ־ יְ֝הוָ֗ה לְאֹ֣רֶךְ יָמִֽים ׃",
      "paragraphStart": false
    }
  ]
}
