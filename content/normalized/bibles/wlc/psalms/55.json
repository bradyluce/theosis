{
  "chapter": {
    "id": "wlc:psalms.55",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 55,
    "referenceLabel": "Psalms 55",
    "summary": "Source text for Psalms 55 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.55.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 1,
      "referenceLabel": "Psalms 55:1",
      "text": "לַמְנַצֵּ֥חַ בִּנְגִינֹ֗ת מַשְׂכִּ֥יל לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.55.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 2,
      "referenceLabel": "Psalms 55:2",
      "text": "הַאֲזִ֣ינָה אֱ֭לֹהִים תְּפִלָּתִ֑י וְאַל ־ תִּ֝תְעַלַּ֗ם מִתְּחִנָּתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 3,
      "referenceLabel": "Psalms 55:3",
      "text": "הַקְשִׁ֣יבָה לִּ֣י וַעֲנֵ֑נִי אָרִ֖יד בְּשִׂיחִ֣י וְאָהִֽימָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 4,
      "referenceLabel": "Psalms 55:4",
      "text": "מִקּ֤וֹל אוֹיֵ֗ב מִפְּנֵ֣י עָקַ֣ת רָשָׁ֑ע כִּי ־ יָמִ֥יטוּ עָלַ֥י אָ֝֗וֶן וּבְאַ֥ף יִשְׂטְמֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 5,
      "referenceLabel": "Psalms 55:5",
      "text": "לִ֭בִּי יָחִ֣יל בְּקִרְבִּ֑י וְאֵימ֥וֹת מָ֝֗וֶת נָפְל֥וּ עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 6,
      "referenceLabel": "Psalms 55:6",
      "text": "יִרְאָ֣ה וָ֭רַעַד יָ֣בֹא בִ֑י וַ֝תְּכַסֵּ֗נִי פַּלָּצֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 7,
      "referenceLabel": "Psalms 55:7",
      "text": "וָאֹמַ֗ר מִֽי ־ יִתֶּן ־ לִּ֣י אֵ֭בֶר כַּיּוֹנָ֗ה אָע֥וּפָה וְאֶשְׁכֹּֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 8,
      "referenceLabel": "Psalms 55:8",
      "text": "הִ֭נֵּה אַרְחִ֣יק נְדֹ֑ד אָלִ֖ין בַּמִּדְבָּ֣ר סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 9,
      "referenceLabel": "Psalms 55:9",
      "text": "אָחִ֣ישָׁה מִפְלָ֣ט לִ֑י מֵר֖וּחַ סֹעָ֣ה מִסָּֽעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 10,
      "referenceLabel": "Psalms 55:10",
      "text": "בַּלַּ֣ע אֲ֭דֹנָי פַּלַּ֣ג לְשׁוֹנָ֑ם כִּֽי ־ רָאִ֨יתִי חָמָ֖ס וְרִ֣יב בָּעִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 11,
      "referenceLabel": "Psalms 55:11",
      "text": "יוֹמָ֤ם וָלַ֗יְלָה יְסוֹבְבֻ֥הָ עַל ־ חוֹמֹתֶ֑יהָ וְאָ֖וֶן וְעָמָ֣ל בְּקִרְבָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 12,
      "referenceLabel": "Psalms 55:12",
      "text": "הַוּ֥וֹת בְּקִרְבָּ֑הּ וְֽלֹא ־ יָמִ֥ישׁ מֵ֝רְחֹבָ֗הּ תֹּ֣ךְ וּמִרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 13,
      "referenceLabel": "Psalms 55:13",
      "text": "כִּ֤י לֹֽא ־ אוֹיֵ֥ב יְחָֽרְפֵ֗נִי וְאֶ֫שָּׂ֥א לֹֽא ־ מְ֭שַׂנְאִי עָלַ֣י הִגְדִּ֑יל וְאֶסָּתֵ֥ר מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 14,
      "referenceLabel": "Psalms 55:14",
      "text": "וְאַתָּ֣ה אֱנ֣וֹשׁ כְּעֶרְכִּ֑י אַ֝לּוּפִ֗י וּמְיֻדָּֽעִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 15,
      "referenceLabel": "Psalms 55:15",
      "text": "אֲשֶׁ֣ר יַ֭חְדָּו נַמְתִּ֣יק ס֑וֹד בְּבֵ֥ית אֱ֝לֹהִ֗ים נְהַלֵּ֥ךְ בְּרָֽגֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 16,
      "referenceLabel": "Psalms 55:16",
      "text": "ישימות עָלֵ֗ימוֹ יֵרְד֣וּ שְׁא֣וֹל חַיִּ֑ים כִּֽי ־ רָע֖וֹת בִּמְגוּרָ֣ם בְּקִרְבָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 17,
      "referenceLabel": "Psalms 55:17",
      "text": "אֲ֭נִי אֶל ־ אֱלֹהִ֣ים אֶקְרָ֑א וַ֝יהוָ֗ה יוֹשִׁיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 18,
      "referenceLabel": "Psalms 55:18",
      "text": "עֶ֤רֶב וָבֹ֣קֶר וְ֭צָהֳרַיִם אָשִׂ֣יחָה וְאֶהֱמֶ֑ה וַיִּשְׁמַ֥ע קוֹלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 19,
      "referenceLabel": "Psalms 55:19",
      "text": "פָּ֘דָ֤ה בְשָׁל֣וֹם נַ֭פְשִׁי מִקֲּרָב ־ לִ֑י כִּֽי ־ בְ֝רַבִּ֗ים הָי֥וּ עִמָּדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 20,
      "referenceLabel": "Psalms 55:20",
      "text": "יִשְׁמַ֤ע ׀ אֵ֨ל ׀ וְֽיַעֲנֵם֮ וְיֹ֤שֵׁ֥ב קֶ֗דֶם סֶ֥לָה אֲשֶׁ֤ר אֵ֣ין חֲלִיפ֣וֹת לָ֑מוֹ וְלֹ֖א יָרְא֣וּ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 21,
      "referenceLabel": "Psalms 55:21",
      "text": "שָׁלַ֣ח יָ֭דָיו בִּשְׁלֹמָ֗יו חִלֵּ֥ל בְּרִיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 22,
      "referenceLabel": "Psalms 55:22",
      "text": "חָלְק֤וּ ׀ מַחְמָאֹ֣ת פִּיו֮ וּֽקֲרָב ־ לִ֫בּ֥וֹ רַכּ֖וּ דְבָרָ֥יו מִשֶּׁ֗מֶן וְהֵ֣מָּה פְתִחֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 23,
      "referenceLabel": "Psalms 55:23",
      "text": "הַשְׁלֵ֤ךְ עַל ־ יְהוָ֨ה ׀ יְהָבְךָ֮ וְה֪וּא יְכַ֫לְכְּלֶ֥ךָ לֹא ־ יִתֵּ֖ן לְעוֹלָ֥ם מ֗וֹט לַצַּדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.55.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 24,
      "referenceLabel": "Psalms 55:24",
      "text": "וְאַתָּ֤ה אֱלֹהִ֨ים ׀ תּוֹרִדֵ֬ם ׀ לִבְאֵ֬ר שַׁ֗חַת אַנְשֵׁ֤י דָמִ֣ים וּ֭מִרְמָה לֹא ־ יֶחֱצ֣וּ יְמֵיהֶ֑ם וַ֝אֲנִ֗י אֶבְטַח ־ בָּֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
