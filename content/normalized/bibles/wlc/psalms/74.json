{
  "chapter": {
    "id": "wlc:psalms.74",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.74.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "מַשְׂכִּ֗יל לְאָ֫סָ֥ף לָמָ֣ה אֱ֭לֹהִים זָנַ֣חְתָּ לָנֶ֑צַח יֶעְשַׁ֥ן אַ֝פְּךָ֗ בְּצֹ֣אן מַרְעִיתֶֽךָ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.74.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "זְכֹ֤ר עֲדָתְךָ֨ ׀ קָ֘נִ֤יתָ קֶּ֗דֶם גָּ֭אַלְתָּ שֵׁ֣בֶט נַחֲלָתֶ֑ךָ הַר ־ צִ֝יּ֗וֹן זֶ֤ה ׀ שָׁכַ֬נְתָּ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "הָרִ֣ימָה פְ֭עָמֶיךָ לְמַשֻּׁא֣וֹת נֶ֑צַח כָּל ־ הֵרַ֖ע אוֹיֵ֣ב בַּקֹּֽדֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "שָׁאֲג֣וּ צֹ֭רְרֶיךָ בְּקֶ֣רֶב מוֹעֲדֶ֑ךָ שָׂ֖מוּ אוֹתֹתָ֣ם אֹתֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "יִ֭וָּדַע כְּמֵבִ֣יא לְמָ֑עְלָה בִּֽסֲבָךְ ־ עֵ֝֗ץ קַרְדֻּמּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "ועת פִּתּוּחֶ֣יהָ יָּ֑חַד בְּכַשִּׁ֥יל וְ֝כֵֽילַפֹּ֗ת יַהֲלֹמֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "שִׁלְח֣וּ בָ֭אֵשׁ מִקְדָּשֶׁ֑ךָ לָ֝אָ֗רֶץ חִלְּל֥וּ מִֽשְׁכַּן ־ שְׁמֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "אָמְר֣וּ בְ֭לִבָּם נִינָ֣ם יָ֑חַד שָׂרְפ֖וּ כָל ־ מוֹעֲדֵי ־ אֵ֣ל בָּאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "אֽוֹתֹתֵ֗ינוּ לֹ֥א רָ֫אִ֥ינוּ אֵֽין ־ ע֥וֹד נָבִ֑יא וְלֹֽא ־ אִ֝תָּ֗נוּ יֹדֵ֥עַ עַד ־ מָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "עַד ־ מָתַ֣י אֱ֭לֹהִים יְחָ֣רֶף צָ֑ר יְנָ֘אֵ֤ץ אוֹיֵ֖ב שִׁמְךָ֣ לָנֶֽצַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 11,
      "referenceLabel": "Psalms 74:11",
      "text": "לָ֤מָּה תָשִׁ֣יב יָ֭דְךָ וִֽימִינֶ֑ךָ מִקֶּ֖רֶב חוקך כַלֵּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 12,
      "referenceLabel": "Psalms 74:12",
      "text": "וֵ֭אלֹהִים מַלְכִּ֣י מִקֶּ֑דֶם פֹּעֵ֥ל יְ֝שׁוּע֗וֹת בְּקֶ֣רֶב הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 13,
      "referenceLabel": "Psalms 74:13",
      "text": "אַתָּ֤ה פוֹרַ֣רְתָּ בְעָזְּךָ֣ יָ֑ם שִׁבַּ֖רְתָּ רָאשֵׁ֥י תַ֝נִּינִ֗ים עַל ־ הַמָּֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 14,
      "referenceLabel": "Psalms 74:14",
      "text": "אַתָּ֣ה רִ֭צַּצְתָּ רָאשֵׁ֣י לִוְיָתָ֑ן תִּתְּנֶ֥נּוּ מַ֝אֲכָ֗ל לְעָ֣ם לְצִיִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 15,
      "referenceLabel": "Psalms 74:15",
      "text": "אַתָּ֣ה בָ֭קַעְתָּ מַעְיָ֣ן וָנָ֑חַל אַתָּ֥ה ה֝וֹבַ֗שְׁתָּ נַהֲר֥וֹת אֵיתָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 16,
      "referenceLabel": "Psalms 74:16",
      "text": "לְךָ֣ י֭וֹם אַף ־ לְךָ֥ לָ֑יְלָה אַתָּ֥ה הֲ֝כִינ֗וֹתָ מָא֥וֹר וָשָֽׁמֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 17,
      "referenceLabel": "Psalms 74:17",
      "text": "אַתָּ֣ה הִ֭צַּבְתָּ כָּל ־ גְּבוּל֣וֹת אָ֑רֶץ קַ֥יִץ וָ֝חֹ֗רֶף אַתָּ֥ה יְצַרְתָּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 18,
      "referenceLabel": "Psalms 74:18",
      "text": "זְכָר ־ זֹ֗את א֭וֹיֵב חֵרֵ֣ף ׀ יְהוָ֑ה וְעַ֥ם נָ֝בָ֗ל נִֽאֲצ֥וּ שְׁמֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 19,
      "referenceLabel": "Psalms 74:19",
      "text": "אַל ־ תִּתֵּ֣ן לְ֭חַיַּת נֶ֣פֶשׁ תּוֹרֶ֑ךָ חַיַּ֥ת עֲ֝נִיֶּ֗יךָ אַל ־ תִּשְׁכַּ֥ח לָנֶֽצַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 20,
      "referenceLabel": "Psalms 74:20",
      "text": "הַבֵּ֥ט לַבְּרִ֑ית כִּ֥י מָלְא֥וּ מַחֲשַׁכֵּי ־ אֶ֝֗רֶץ נְא֣וֹת חָמָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 21,
      "referenceLabel": "Psalms 74:21",
      "text": "אַל ־ יָשֹׁ֣ב דַּ֣ךְ נִכְלָ֑ם עָנִ֥י וְ֝אֶבְי֗וֹן יְֽהַלְל֥וּ שְׁמֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 22,
      "referenceLabel": "Psalms 74:22",
      "text": "קוּמָ֣ה אֱ֭לֹהִים רִיבָ֣ה רִיבֶ֑ךָ זְכֹ֥ר חֶרְפָּתְךָ֥ מִנִּי ־ נָ֝בָ֗ל כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.74.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 23,
      "referenceLabel": "Psalms 74:23",
      "text": "אַל ־ תִּ֭שְׁכַּח ק֣וֹל צֹרְרֶ֑יךָ שְׁא֥וֹן קָ֝מֶ֗יךָ עֹלֶ֥ה תָמִֽיד ׃",
      "paragraphStart": false
    }
  ]
}
