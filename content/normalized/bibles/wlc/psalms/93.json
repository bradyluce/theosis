  },
  "verses": [
    {
      "id": "wlc:psalms.93.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 1,
      "referenceLabel": "Psalms 93:1",
      "text": "יְהוָ֣ה מָלָךְ֮ גֵּא֪וּת לָ֫בֵ֥שׁ לָבֵ֣שׁ יְ֭הוָה עֹ֣ז הִתְאַזָּ֑ר אַף ־ תִּכּ֥וֹן תֵּ֝בֵ֗ל בַּל ־ תִּמּֽוֹט ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.93.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 2,
      "referenceLabel": "Psalms 93:2",
      "text": "נָכ֣וֹן כִּסְאֲךָ֣ מֵאָ֑ז מֵֽעוֹלָ֣ם אָֽתָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.93.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 3,
      "referenceLabel": "Psalms 93:3",
      "text": "נָשְׂא֤וּ נְהָר֨וֹת ׀ יְֽהוָ֗ה נָשְׂא֣וּ נְהָר֣וֹת קוֹלָ֑ם יִשְׂא֖וּ נְהָר֣וֹת דָּכְיָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.93.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 4,
      "referenceLabel": "Psalms 93:4",
      "text": "מִקֹּל֨וֹת ׀ מַ֤יִם רַבִּ֗ים אַדִּירִ֣ים מִשְׁבְּרֵי ־ יָ֑ם אַדִּ֖יר בַּמָּר֣וֹם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.93.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 5,
      "referenceLabel": "Psalms 93:5",
      "text": "עֵֽדֹתֶ֨יךָ ׀ נֶאֶמְנ֬וּ מְאֹ֗ד לְבֵיתְךָ֥ נַאֲוָה ־ קֹ֑דֶשׁ יְ֝הוָ֗ה לְאֹ֣רֶךְ יָמִֽים ׃",
      "paragraphStart": false
    }
  ]
}
