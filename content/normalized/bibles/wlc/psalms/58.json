{
  "chapter": {
    "id": "wlc:psalms.58",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 58,
    "referenceLabel": "Psalms 58",
    "summary": "Source text for Psalms 58 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.58.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 1,
      "referenceLabel": "Psalms 58:1",
      "text": "לַמְנַצֵּ֥חַ אַל ־ תַּשְׁחֵ֗ת לְדָוִ֥ד מִכְתָּֽם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.58.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 2,
      "referenceLabel": "Psalms 58:2",
      "text": "הַֽאֻמְנָ֗ם אֵ֣לֶם צֶ֭דֶק תְּדַבֵּר֑וּן מֵישָׁרִ֥ים תִּ֝שְׁפְּט֗וּ בְּנֵ֣י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 3,
      "referenceLabel": "Psalms 58:3",
      "text": "אַף ־ בְּלֵב֮ עוֹלֹ֪ת תִּפְעָ֫ל֥וּן בָּאָ֡רֶץ חֲמַ֥ס יְ֝דֵיכֶ֗ם תְּפַלֵּֽסֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 4,
      "referenceLabel": "Psalms 58:4",
      "text": "זֹ֣רוּ רְשָׁעִ֣ים מֵרָ֑חֶם תָּע֥וּ מִ֝בֶּ֗טֶן דֹּבְרֵ֥י כָזָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 5,
      "referenceLabel": "Psalms 58:5",
      "text": "חֲמַת ־ לָ֗מוֹ כִּדְמ֥וּת חֲמַת ־ נָחָ֑שׁ כְּמוֹ ־ פֶ֥תֶן חֵ֝רֵ֗שׁ יַאְטֵ֥ם אָזְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 6,
      "referenceLabel": "Psalms 58:6",
      "text": "אֲשֶׁ֣ר לֹא ־ יִ֭שְׁמַע לְק֣וֹל מְלַחֲשִׁ֑ים חוֹבֵ֖ר חֲבָרִ֣ים מְחֻכָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 7,
      "referenceLabel": "Psalms 58:7",
      "text": "אֱֽלֹהִ֗ים הֲרָס ־ שִׁנֵּ֥ימוֹ בְּפִ֑ימוֹ מַלְתְּע֥וֹת כְּ֝פִירִ֗ים נְתֹ֣ץ ׀ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 8,
      "referenceLabel": "Psalms 58:8",
      "text": "יִמָּאֲס֣וּ כְמוֹ ־ מַ֭יִם יִתְהַלְּכוּ ־ לָ֑מוֹ יִדְרֹ֥ךְ חצו כְּמ֣וֹ יִתְמֹלָֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 9,
      "referenceLabel": "Psalms 58:9",
      "text": "כְּמ֣וֹ שַׁ֭בְּלוּל תֶּ֣מֶס יַהֲלֹ֑ךְ נֵ֥פֶל אֵ֝֗שֶׁת בַּל ־ חָ֥זוּ שָֽׁמֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 10,
      "referenceLabel": "Psalms 58:10",
      "text": "בְּטֶ֤רֶם יָבִ֣ינוּ סִּֽירֹתֵיכֶ֣ם אָטָ֑ד כְּמוֹ ־ חַ֥י כְּמוֹ ־ חָ֝ר֗וֹן יִשְׂעָרֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 11,
      "referenceLabel": "Psalms 58:11",
      "text": "יִשְׂמַ֣ח צַ֭דִּיק כִּי ־ חָזָ֣ה נָקָ֑ם פְּעָמָ֥יו יִ֝רְחַ֗ץ בְּדַ֣ם הָרָשָֽׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.58.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 12,
      "referenceLabel": "Psalms 58:12",
      "text": "וְיֹאמַ֣ר אָ֭דָם אַךְ ־ פְּרִ֣י לַצַּדִּ֑יק אַ֥ךְ יֵשׁ ־ אֱ֝לֹהִ֗ים שֹׁפְטִ֥ים בָּאָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
}
