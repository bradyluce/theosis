{
  "chapter": {
    "id": "wlc:psalms.78",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 78,
    "referenceLabel": "Psalms 78",
    "summary": "Source text for Psalms 78 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.78.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 1,
      "referenceLabel": "Psalms 78:1",
      "text": "מַשְׂכִּ֗יל לְאָ֫סָ֥ף הַאֲזִ֣ינָה עַ֭מִּי תּוֹרָתִ֑י הַטּ֥וּ אָ֝זְנְכֶ֗ם לְאִמְרֵי ־ פִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.78.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 2,
      "referenceLabel": "Psalms 78:2",
      "text": "אֶפְתְּחָ֣ה בְמָשָׁ֣ל פִּ֑י אַבִּ֥יעָה חִ֝יד֗וֹת מִנִּי ־ קֶֽדֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 3,
      "referenceLabel": "Psalms 78:3",
      "text": "אֲשֶׁ֣ר שָׁ֭מַעְנוּ וַנֵּדָעֵ֑ם וַ֝אֲבוֹתֵ֗ינוּ סִפְּרוּ ־ לָֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 4,
      "referenceLabel": "Psalms 78:4",
      "text": "לֹ֤א נְכַחֵ֨ד ׀ מִבְּנֵיהֶ֗ם לְד֥וֹר אַחֲר֗וֹן מְֽ֭סַפְּרִים תְּהִלּ֣וֹת יְהוָ֑ה וֶעֱזוּז֥וֹ וְ֝נִפְלְאוֹתָ֗יו אֲשֶׁ֣ר עָשָֽׂה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 5,
      "referenceLabel": "Psalms 78:5",
      "text": "וַיָּ֤קֶם עֵד֨וּת ׀ בְּֽיַעֲקֹ֗ב וְתוֹרָה֮ שָׂ֤ם בְּיִשְׂרָ֫אֵ֥ל אֲשֶׁ֣ר צִ֭וָּה אֶת ־ אֲבוֹתֵ֑ינוּ לְ֝הוֹדִיעָ֗ם לִבְנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 6,
      "referenceLabel": "Psalms 78:6",
      "text": "לְמַ֤עַן יֵדְע֨וּ ׀ דּ֣וֹר אַ֭חֲרוֹן בָּנִ֣ים יִוָּלֵ֑דוּ יָ֝קֻ֗מוּ וִֽיסַפְּר֥וּ לִבְנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 7,
      "referenceLabel": "Psalms 78:7",
      "text": "וְיָשִׂ֥ימוּ בֵֽאלֹהִ֗ים כִּ֫סְלָ֥ם וְלֹ֣א יִ֭שְׁכְּחוּ מַֽעַלְלֵי ־ אֵ֑ל וּמִצְוֺתָ֥יו יִנְצֹֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 8,
      "referenceLabel": "Psalms 78:8",
      "text": "וְלֹ֤א יִהְי֨וּ ׀ כַּאֲבוֹתָ֗ם דּוֹר֮ סוֹרֵ֪ר וּמֹ֫רֶ֥ה דּ֭וֹר לֹא ־ הֵכִ֣ין לִבּ֑וֹ וְלֹא ־ נֶאֶמְנָ֖ה אֶת ־ אֵ֣ל רוּחֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 9,
      "referenceLabel": "Psalms 78:9",
      "text": "בְּֽנֵי ־ אֶפְרַ֗יִם נוֹשְׁקֵ֥י רוֹמֵי ־ קָ֑שֶׁת הָ֝פְכ֗וּ בְּי֣וֹם קְרָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 10,
      "referenceLabel": "Psalms 78:10",
      "text": "לֹ֣א שָׁ֭מְרוּ בְּרִ֣ית אֱלֹהִ֑ים וּ֝בְתוֹרָת֗וֹ מֵאֲנ֥וּ לָלֶֽכֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 11,
      "referenceLabel": "Psalms 78:11",
      "text": "וַיִּשְׁכְּח֥וּ עֲלִילוֹתָ֑יו וְ֝נִפְלְאוֹתָ֗יו אֲשֶׁ֣ר הֶרְאָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 12,
      "referenceLabel": "Psalms 78:12",
      "text": "נֶ֣גֶד אֲ֭בוֹתָם עָ֣שָׂה פֶ֑לֶא בְּאֶ֖רֶץ מִצְרַ֣יִם שְׂדֵה ־ צֹֽעַן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 13,
      "referenceLabel": "Psalms 78:13",
      "text": "בָּ֣קַע יָ֭ם וַיַּֽעֲבִירֵ֑ם וַֽיַּצֶּב ־ מַ֥יִם כְּמוֹ ־ נֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 14,
      "referenceLabel": "Psalms 78:14",
      "text": "וַיַּנְחֵ֣ם בֶּעָנָ֣ן יוֹמָ֑ם וְכָל ־ הַ֝לַּ֗יְלָה בְּא֣וֹר אֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 15,
      "referenceLabel": "Psalms 78:15",
      "text": "יְבַקַּ֣ע צֻ֭רִים בַּמִּדְבָּ֑ר וַ֝יַּ֗שְׁקְ כִּתְהֹמ֥וֹת רַבָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 16,
      "referenceLabel": "Psalms 78:16",
      "text": "וַיּוֹצִ֣א נוֹזְלִ֣ים מִסָּ֑לַע וַיּ֖וֹרֶד כַּנְּהָר֣וֹת מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 17,
      "referenceLabel": "Psalms 78:17",
      "text": "וַיּוֹסִ֣יפוּ ע֭וֹד לַחֲטֹא ־ ל֑וֹ לַֽמְר֥וֹת עֶ֝לְי֗וֹן בַּצִּיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 18,
      "referenceLabel": "Psalms 78:18",
      "text": "וַיְנַסּוּ ־ אֵ֥ל בִּלְבָבָ֑ם לִֽשְׁאָל ־ אֹ֥כֶל לְנַפְשָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 19,
      "referenceLabel": "Psalms 78:19",
      "text": "וַֽיְדַבְּר֗וּ בֵּֽאלֹ֫הִ֥ים אָ֭מְרוּ הֲי֣וּכַל אֵ֑ל לַעֲרֹ֥ךְ שֻׁ֝לְחָ֗ן בַּמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 20,
      "referenceLabel": "Psalms 78:20",
      "text": "הֵ֤ן הִכָּה ־ צ֨וּר ׀ וַיָּז֣וּבוּ מַיִם֮ וּנְחָלִ֪ים יִ֫שְׁטֹ֥פוּ הֲגַם ־ לֶ֭חֶם י֣וּכַל תֵּ֑ת אִם ־ יָכִ֖ין שְׁאֵ֣ר לְעַמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 21,
      "referenceLabel": "Psalms 78:21",
      "text": "לָכֵ֤ן ׀ שָׁמַ֥ע יְהוָ֗ה וַֽיִּתְעַבָּ֥ר וְ֭אֵשׁ נִשְּׂקָ֣ה בְיַעֲקֹ֑ב וְגַם ־ אַ֝֗ף עָלָ֥ה בְיִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 22,
      "referenceLabel": "Psalms 78:22",
      "text": "כִּ֤י לֹ֣א הֶ֭אֱמִינוּ בֵּאלֹהִ֑ים וְלֹ֥א בָ֝טְח֗וּ בִּֽישׁוּעָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 23,
      "referenceLabel": "Psalms 78:23",
      "text": "וַיְצַ֣ו שְׁחָקִ֣ים מִמָּ֑עַל וְדַלְתֵ֖י שָׁמַ֣יִם פָּתָֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 24,
      "referenceLabel": "Psalms 78:24",
      "text": "וַיַּמְטֵ֬ר עֲלֵיהֶ֣ם מָ֣ן לֶאֱכֹ֑ל וּדְגַן ־ שָׁ֝מַ֗יִם נָ֣תַן לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 25,
      "referenceLabel": "Psalms 78:25",
      "text": "לֶ֣חֶם אַ֭בִּירִים אָ֣כַל אִ֑ישׁ צֵידָ֬ה שָׁלַ֖ח לָהֶ֣ם לָשֹֽׂבַע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 26,
      "referenceLabel": "Psalms 78:26",
      "text": "יַסַּ֣ע קָ֭דִים בַּשָּׁמָ֑יִם וַיְנַהֵ֖ג בְּעֻזּ֣וֹ תֵימָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 27,
      "referenceLabel": "Psalms 78:27",
      "text": "וַיַּמְטֵ֬ר עֲלֵיהֶ֣ם כֶּעָפָ֣ר שְׁאֵ֑ר וּֽכְח֥וֹל יַ֝מִּ֗ים ע֣וֹף כָּנָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 28,
      "referenceLabel": "Psalms 78:28",
      "text": "וַ֭יַּפֵּל בְּקֶ֣רֶב מַחֲנֵ֑הוּ סָ֝בִ֗יב לְמִשְׁכְּנֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 29,
      "referenceLabel": "Psalms 78:29",
      "text": "וַיֹּאכְל֣וּ וַיִּשְׂבְּע֣וּ מְאֹ֑ד וְ֝תַֽאֲוָתָ֗ם יָבִ֥א לָהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 30,
      "referenceLabel": "Psalms 78:30",
      "text": "לֹא ־ זָר֥וּ מִתַּאֲוָתָ֑ם ע֝֗וֹד אָכְלָ֥ם בְּפִיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 31,
      "referenceLabel": "Psalms 78:31",
      "text": "וְאַ֤ף אֱלֹהִ֨ים ׀ עָ֘לָ֤ה בָהֶ֗ם וַֽ֭יַּהֲרֹג בְּמִשְׁמַנֵּיהֶ֑ם וּבַחוּרֵ֖י יִשְׂרָאֵ֣ל הִכְרִֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 32,
      "referenceLabel": "Psalms 78:32",
      "text": "בְּכָל ־ זֹ֭את חָֽטְאוּ ־ ע֑וֹד וְלֹֽא ־ הֶ֝אֱמִ֗ינוּ בְּנִפְלְאוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 33,
      "referenceLabel": "Psalms 78:33",
      "text": "וַיְכַל ־ בַּהֶ֥בֶל יְמֵיהֶ֑ם וּ֝שְׁנוֹתָ֗ם בַּבֶּהָלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 34,
      "referenceLabel": "Psalms 78:34",
      "text": "אִם ־ הֲרָגָ֥ם וּדְרָשׁ֑וּהוּ וְ֝שָׁ֗בוּ וְשִֽׁחֲרוּ ־ אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 35,
      "referenceLabel": "Psalms 78:35",
      "text": "וַֽ֭יִּזְכְּרוּ כִּֽי ־ אֱלֹהִ֣ים צוּרָ֑ם וְאֵ֥ל עֶ֝לְיוֹן גֹּאֲלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 36,
      "referenceLabel": "Psalms 78:36",
      "text": "וַיְפַתּ֥וּהוּ בְּפִיהֶ֑ם וּ֝בִלְשׁוֹנָ֗ם יְכַזְּבוּ ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 37,
      "referenceLabel": "Psalms 78:37",
      "text": "וְ֭לִבָּם לֹא ־ נָכ֣וֹן עִמּ֑וֹ וְלֹ֥א נֶ֝אֶמְנ֗וּ בִּבְרִיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.38",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 38,
      "referenceLabel": "Psalms 78:38",
      "text": "וְה֤וּא רַח֨וּם ׀ יְכַפֵּ֥ר עָוֺן֮ וְֽלֹא ־ יַ֫שְׁחִ֥ית וְ֭הִרְבָּה לְהָשִׁ֣יב אַפּ֑וֹ וְלֹֽא ־ יָ֝עִיר כָּל ־ חֲמָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.39",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 39,
      "referenceLabel": "Psalms 78:39",
      "text": "וַ֭יִּזְכֹּר כִּי ־ בָשָׂ֣ר הֵ֑מָּה ר֥וּחַ ה֝וֹלֵ֗ךְ וְלֹ֣א יָשֽׁוּב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.40",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 40,
      "referenceLabel": "Psalms 78:40",
      "text": "כַּ֭מָּה יַמְר֣וּהוּ בַמִּדְבָּ֑ר יַ֝עֲצִיב֗וּהוּ בִּֽישִׁימֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.41",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 41,
      "referenceLabel": "Psalms 78:41",
      "text": "וַיָּשׁ֣וּבוּ וַיְנַסּ֣וּ אֵ֑ל וּקְד֖וֹשׁ יִשְׂרָאֵ֣ל הִתְווּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.42",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 42,
      "referenceLabel": "Psalms 78:42",
      "text": "לֹא ־ זָכְר֥וּ אֶת ־ יָד֑וֹ י֝֗וֹם אֲֽשֶׁר ־ פָּדָ֥ם מִנִּי ־ צָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.43",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 43,
      "referenceLabel": "Psalms 78:43",
      "text": "אֲשֶׁר ־ שָׂ֣ם בְּ֭מִצְרַיִם אֹֽתוֹתָ֑יו וּ֝מוֹפְתָ֗יו בִּשְׂדֵה ־ צֹֽעַן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.44",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 44,
      "referenceLabel": "Psalms 78:44",
      "text": "וַיַּהֲפֹ֣ךְ לְ֭דָם יְאֹרֵיהֶ֑ם וְ֝נֹזְלֵיהֶ֗ם בַּל ־ יִשְׁתָּיֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.45",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 45,
      "referenceLabel": "Psalms 78:45",
      "text": "יְשַׁלַּ֬ח בָּהֶ֣ם עָ֭רֹב וַיֹּאכְלֵ֑ם וּ֝צְפַרְדֵּ֗עַ וַתַּשְׁחִיתֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.46",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 46,
      "referenceLabel": "Psalms 78:46",
      "text": "וַיִּתֵּ֣ן לֶחָסִ֣יל יְבוּלָ֑ם וִֽ֝יגִיעָ֗ם לָאַרְבֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.47",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 47,
      "referenceLabel": "Psalms 78:47",
      "text": "יַהֲרֹ֣ג בַּבָּרָ֣ד גַּפְנָ֑ם וְ֝שִׁקְמוֹתָ֗ם בַּֽחֲנָמַֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.48",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 48,
      "referenceLabel": "Psalms 78:48",
      "text": "וַיַּסְגֵּ֣ר לַבָּרָ֣ד בְּעִירָ֑ם וּ֝מִקְנֵיהֶ֗ם לָרְשָׁפִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.49",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 49,
      "referenceLabel": "Psalms 78:49",
      "text": "יְשַׁלַּח ־ בָּ֨ם ׀ חֲר֬וֹן אַפּ֗וֹ עֶבְרָ֣ה וָזַ֣עַם וְצָרָ֑ה מִ֝שְׁלַ֗חַת מַלְאֲכֵ֥י רָעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.50",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 50,
      "referenceLabel": "Psalms 78:50",
      "text": "יְפַלֵּ֥ס נָתִ֗יב לְאַ֫פּ֥וֹ לֹא ־ חָשַׂ֣ךְ מִמָּ֣וֶת נַפְשָׁ֑ם וְ֝חַיָּתָ֗ם לַדֶּ֥בֶר הִסְגִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.51",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 51,
      "referenceLabel": "Psalms 78:51",
      "text": "וַיַּ֣ךְ כָּל ־ בְּכ֣וֹר בְּמִצְרָ֑יִם רֵאשִׁ֥ית א֝וֹנִ֗ים בְּאָהֳלֵי ־ חָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.52",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 52,
      "referenceLabel": "Psalms 78:52",
      "text": "וַיַּסַּ֣ע כַּצֹּ֣אן עַמּ֑וֹ וַֽיְנַהֲגֵ֥ם כַּ֝עֵ֗דֶר בַּמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.53",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 53,
      "referenceLabel": "Psalms 78:53",
      "text": "וַיַּנְחֵ֣ם לָ֭בֶטַח וְלֹ֣א פָחָ֑דוּ וְאֶת ־ א֝וֹיְבֵיהֶ֗ם כִּסָּ֥ה הַיָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.54",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 54,
      "referenceLabel": "Psalms 78:54",
      "text": "וַ֭יְבִיאֵם אֶל ־ גְּב֣וּל קָדְשׁ֑וֹ הַר ־ זֶ֝֗ה קָנְתָ֥ה יְמִינֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.55",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 55,
      "referenceLabel": "Psalms 78:55",
      "text": "וַיְגָ֤רֶשׁ מִפְּנֵיהֶ֨ם ׀ גּוֹיִ֗ם וַֽ֭יַּפִּילֵם בְּחֶ֣בֶל נַחֲלָ֑ה וַיַּשְׁכֵּ֥ן בְּ֝אָהֳלֵיהֶ֗ם שִׁבְטֵ֥י יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.56",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 56,
      "referenceLabel": "Psalms 78:56",
      "text": "וַיְנַסּ֣וּ וַ֭יַּמְרוּ אֶת ־ אֱלֹהִ֣ים עֶלְי֑וֹן וְ֝עֵדוֹתָ֗יו לֹ֣א שָׁמָֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.57",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 57,
      "referenceLabel": "Psalms 78:57",
      "text": "וַיִּסֹּ֣גוּ וַֽ֭יִּבְגְּדוּ כַּאֲבוֹתָ֑ם נֶ֝הְפְּכ֗וּ כְּקֶ֣שֶׁת רְמִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.58",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 58,
      "referenceLabel": "Psalms 78:58",
      "text": "וַיַּכְעִיס֥וּהוּ בְּבָמוֹתָ֑ם וּ֝בִפְסִילֵיהֶ֗ם יַקְנִיאֽוּהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.59",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 59,
      "referenceLabel": "Psalms 78:59",
      "text": "שָׁמַ֣ע אֱ֭לֹהִים וַֽיִּתְעַבָּ֑ר וַיִּמְאַ֥ס מְ֝אֹ֗ד בְּיִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.60",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 60,
      "referenceLabel": "Psalms 78:60",
      "text": "וַ֭יִּטֹּשׁ מִשְׁכַּ֣ן שִׁל֑וֹ אֹ֝֗הֶל שִׁכֵּ֥ן בָּאָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.61",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 61,
      "referenceLabel": "Psalms 78:61",
      "text": "וַיִּתֵּ֣ן לַשְּׁבִ֣י עֻזּ֑וֹ וְֽתִפְאַרְתּ֥וֹ בְיַד ־ צָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.62",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 62,
      "referenceLabel": "Psalms 78:62",
      "text": "וַיַּסְגֵּ֣ר לַחֶ֣רֶב עַמּ֑וֹ וּ֝בְנַחֲלָת֗וֹ הִתְעַבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.63",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 63,
      "referenceLabel": "Psalms 78:63",
      "text": "בַּחוּרָ֥יו אָֽכְלָה ־ אֵ֑שׁ וּ֝בְתוּלֹתָ֗יו לֹ֣א הוּלָּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.64",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 64,
      "referenceLabel": "Psalms 78:64",
      "text": "כֹּ֭הֲנָיו בַּחֶ֣רֶב נָפָ֑לוּ וְ֝אַלְמְנֹתָ֗יו לֹ֣א תִבְכֶּֽינָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.65",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 65,
      "referenceLabel": "Psalms 78:65",
      "text": "וַיִּקַ֖ץ כְּיָשֵׁ֥ן ׀ אֲדֹנָ֑י כְּ֝גִבּ֗וֹר מִתְרוֹנֵ֥ן מִיָּֽיִן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.66",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 66,
      "referenceLabel": "Psalms 78:66",
      "text": "וַיַּךְ ־ צָרָ֥יו אָח֑וֹר חֶרְפַּ֥ת ע֝וֹלָ֗ם נָ֣תַן לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.67",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 67,
      "referenceLabel": "Psalms 78:67",
      "text": "וַ֭יִּמְאַס בְּאֹ֣הֶל יוֹסֵ֑ף וּֽבְשֵׁ֥בֶט אֶ֝פְרַ֗יִם לֹ֣א בָחָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.68",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 68,
      "referenceLabel": "Psalms 78:68",
      "text": "וַ֭יִּבְחַר אֶת ־ שֵׁ֣בֶט יְהוּדָ֑ה אֶֽת ־ הַ֥ר צִ֝יּ֗וֹן אֲשֶׁ֣ר אָהֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.69",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 69,
      "referenceLabel": "Psalms 78:69",
      "text": "וַיִּ֣בֶן כְּמוֹ ־ רָ֭מִים מִקְדָּשׁ֑וֹ כְּ֝אֶ֗רֶץ יְסָדָ֥הּ לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.70",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 70,
      "referenceLabel": "Psalms 78:70",
      "text": "וַ֭יִּבְחַר בְּדָוִ֣ד עַבְדּ֑וֹ וַ֝יִּקָּחֵ֗הוּ מִֽמִּכְלְאֹ֥ת צֹֽאן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.71",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 71,
      "referenceLabel": "Psalms 78:71",
      "text": "מֵאַחַ֥ר עָל֗וֹת הֱ֫בִיא֥וֹ לִ֭רְעוֹת בְּיַעֲקֹ֣ב עַמּ֑וֹ וּ֝בְיִשְׂרָאֵ֗ל נַחֲלָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.78.72",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 78,
      "verseNumber": 72,
      "referenceLabel": "Psalms 78:72",
      "text": "וַ֭יִּרְעֵם כְּתֹ֣ם לְבָב֑וֹ וּבִתְבוּנ֖וֹת כַּפָּ֣יו יַנְחֵֽם ׃",
      "paragraphStart": false
    }
  ]
}
