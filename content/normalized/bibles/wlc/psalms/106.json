      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 44,
      "referenceLabel": "Psalms 106:44",
      "text": "וַ֭יַּרְא בַּצַּ֣ר לָהֶ֑ם בְּ֝שָׁמְע֗וֹ אֶת ־ רִנָּתָֽם ׃",
      "paragraphStart": false
