{
  "chapter": {
    "id": "wlc:psalms.106",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 106,
    "referenceLabel": "Psalms 106",
    "summary": "Source text for Psalms 106 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.106.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 1,
      "referenceLabel": "Psalms 106:1",
      "text": "הַֽלְלוּ יָ֨הּ ׀ הוֹד֣וּ לַיהוָ֣ה כִּי ־ ט֑וֹב כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.106.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 2,
      "referenceLabel": "Psalms 106:2",
      "text": "מִ֗י יְ֭מַלֵּל גְּבוּר֣וֹת יְהוָ֑ה יַ֝שְׁמִ֗יעַ כָּל ־ תְּהִלָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 3,
      "referenceLabel": "Psalms 106:3",
      "text": "אַ֭שְׁרֵי שֹׁמְרֵ֣י מִשְׁפָּ֑ט עֹשֵׂ֖ה צְדָקָ֣ה בְכָל ־ עֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 4,
      "referenceLabel": "Psalms 106:4",
      "text": "זָכְרֵ֣נִי יְ֭הוָה בִּרְצ֣וֹן עַמֶּ֑ךָ פָּ֝קְדֵ֗נִי בִּישׁוּעָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 5,
      "referenceLabel": "Psalms 106:5",
      "text": "לִרְא֤וֹת ׀ בְּט֘וֹבַ֤ת בְּחִירֶ֗יךָ לִ֭שְׂמֹחַ בְּשִׂמְחַ֣ת גּוֹיֶ֑ךָ לְ֝הִתְהַלֵּ֗ל עִם ־ נַחֲלָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 6,
      "referenceLabel": "Psalms 106:6",
      "text": "חָטָ֥אנוּ עִם ־ אֲבוֹתֵ֗ינוּ הֶעֱוִ֥ינוּ הִרְשָֽׁעְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 7,
      "referenceLabel": "Psalms 106:7",
      "text": "אֲב֘וֹתֵ֤ינוּ בְמִצְרַ֨יִם ׀ לֹא ־ הִשְׂכִּ֬ילוּ נִפְלְאוֹתֶ֗יךָ לֹ֣א זָ֭כְרוּ אֶת ־ רֹ֣ב חֲסָדֶ֑יךָ וַיַּמְר֖וּ עַל ־ יָ֣ם בְּיַם ־ סֽוּף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 8,
      "referenceLabel": "Psalms 106:8",
      "text": "וַֽ֭יּוֹשִׁיעֵם לְמַ֣עַן שְׁמ֑וֹ לְ֝הוֹדִ֗יעַ אֶת ־ גְּבוּרָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 9,
      "referenceLabel": "Psalms 106:9",
      "text": "וַיִּגְעַ֣ר בְּיַם ־ ס֭וּף וַֽיֶּחֱרָ֑ב וַיּוֹלִיכֵ֥ם בַּ֝תְּהֹמ֗וֹת כַּמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 10,
      "referenceLabel": "Psalms 106:10",
      "text": "וַֽ֭יּוֹשִׁיעֵם מִיַּ֣ד שׂוֹנֵ֑א וַ֝יִּגְאָלֵ֗ם מִיַּ֥ד אוֹיֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 11,
      "referenceLabel": "Psalms 106:11",
      "text": "וַיְכַסּוּ ־ מַ֥יִם צָרֵיהֶ֑ם אֶחָ֥ד מֵ֝הֶ֗ם לֹ֣א נוֹתָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 12,
      "referenceLabel": "Psalms 106:12",
      "text": "וַיַּאֲמִ֥ינוּ בִדְבָרָ֑יו יָ֝שִׁ֗ירוּ תְּהִלָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 13,
      "referenceLabel": "Psalms 106:13",
      "text": "מִֽ֭הֲרוּ שָׁכְח֣וּ מַעֲשָׂ֑יו לֹֽא ־ חִ֝כּ֗וּ לַעֲצָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 14,
      "referenceLabel": "Psalms 106:14",
      "text": "וַיִּתְאַוּ֣וּ תַ֭אֲוָה בַּמִּדְבָּ֑ר וַיְנַסּוּ ־ אֵ֝֗ל בִּֽישִׁימֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 15,
      "referenceLabel": "Psalms 106:15",
      "text": "וַיִּתֵּ֣ן לָ֭הֶם שֶׁאֱלָתָ֑ם וַיְשַׁלַּ֖ח רָז֣וֹן בְּנַפְשָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 16,
      "referenceLabel": "Psalms 106:16",
      "text": "וַיְקַנְא֣וּ לְ֭מֹשֶׁה בַּֽמַּחֲנֶ֑ה לְ֝אַהֲרֹ֗ן קְד֣וֹשׁ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 17,
      "referenceLabel": "Psalms 106:17",
      "text": "תִּפְתַּח ־ אֶ֭רֶץ וַתִּבְלַ֣ע דָּתָ֑ן וַ֝תְּכַ֗ס עַל ־ עֲדַ֥ת אֲבִירָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 18,
      "referenceLabel": "Psalms 106:18",
      "text": "וַתִּבְעַר ־ אֵ֥שׁ בַּעֲדָתָ֑ם לֶ֝הָבָ֗ה תְּלַהֵ֥ט רְשָׁעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 19,
      "referenceLabel": "Psalms 106:19",
      "text": "יַעֲשׂוּ ־ עֵ֥גֶל בְּחֹרֵ֑ב וַ֝יִּשְׁתַּחֲו֗וּ לְמַסֵּכָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 20,
      "referenceLabel": "Psalms 106:20",
      "text": "וַיָּמִ֥ירוּ אֶת ־ כְּבוֹדָ֑ם בְּתַבְנִ֥ית שׁ֝֗וֹר אֹכֵ֥ל עֵֽשֶׂב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 21,
      "referenceLabel": "Psalms 106:21",
      "text": "שָׁ֭כְחוּ אֵ֣ל מוֹשִׁיעָ֑ם עֹשֶׂ֖ה גְדֹל֣וֹת בְּמִצְרָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 22,
      "referenceLabel": "Psalms 106:22",
      "text": "נִ֭פְלָאוֹת בְּאֶ֣רֶץ חָ֑ם נ֝וֹרָא֗וֹת עַל ־ יַם ־ סֽוּף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 23,
      "referenceLabel": "Psalms 106:23",
      "text": "וַיֹּ֗אמֶר לְֽהַשְׁמִ֫ידָ֥ם לוּלֵ֡י מֹ֘שֶׁ֤ה בְחִיר֗וֹ עָמַ֣ד בַּפֶּ֣רֶץ לְפָנָ֑יו לְהָשִׁ֥יב חֲ֝מָת֗וֹ מֵֽהַשְׁחִֽית ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 24,
      "referenceLabel": "Psalms 106:24",
      "text": "וַֽ֭יִּמְאֲסוּ בְּאֶ֣רֶץ חֶמְדָּ֑ה לֹֽא ־ הֶ֝אֱמִ֗ינוּ לִדְבָרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 25,
      "referenceLabel": "Psalms 106:25",
      "text": "וַיֵּרָגְנ֥וּ בְאָהֳלֵיהֶ֑ם לֹ֥א שָׁ֝מְע֗וּ בְּק֣וֹל יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 26,
      "referenceLabel": "Psalms 106:26",
      "text": "וַיִּשָּׂ֣א יָד֣וֹ לָהֶ֑ם לְהַפִּ֥יל א֝וֹתָ֗ם בַּמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 27,
      "referenceLabel": "Psalms 106:27",
      "text": "וּלְהַפִּ֣יל זַ֭רְעָם בַּגּוֹיִ֑ם וּ֝לְזָרוֹתָ֗ם בָּאֲרָצֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 28,
      "referenceLabel": "Psalms 106:28",
      "text": "וַ֭יִּצָּ֣מְדוּ לְבַ֣עַל פְּע֑וֹר וַ֝יֹּאכְל֗וּ זִבְחֵ֥י מֵתִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 29,
      "referenceLabel": "Psalms 106:29",
      "text": "וַ֭יַּכְעִיסוּ בְּמַֽעַלְלֵיהֶ֑ם וַתִּפְרָץ ־ בָּ֝֗ם מַגֵּפָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 30,
      "referenceLabel": "Psalms 106:30",
      "text": "וַיַּעֲמֹ֣ד פִּֽ֭ינְחָס וַיְפַלֵּ֑ל וַ֝תֵּעָצַ֗ר הַמַּגֵּפָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 31,
      "referenceLabel": "Psalms 106:31",
      "text": "וַתֵּחָ֣שֶׁב ל֭וֹ לִצְדָקָ֑ה לְדֹ֥ר וָ֝דֹ֗ר עַד ־ עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 32,
      "referenceLabel": "Psalms 106:32",
      "text": "וַ֭יַּקְצִיפוּ עַל ־ מֵ֥י מְרִיבָ֑ה וַיֵּ֥רַע לְ֝מֹשֶׁ֗ה בַּעֲבוּרָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 33,
      "referenceLabel": "Psalms 106:33",
      "text": "כִּֽי ־ הִמְר֥וּ אֶת ־ רוּח֑וֹ וַ֝יְבַטֵּ֗א בִּשְׂפָתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 34,
      "referenceLabel": "Psalms 106:34",
      "text": "לֹֽא ־ הִ֭שְׁמִידוּ אֶת ־ הָֽעַמִּ֑ים אֲשֶׁ֤ר אָמַ֖ר יְהוָ֣ה לָהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 35,
      "referenceLabel": "Psalms 106:35",
      "text": "וַיִּתְעָרְב֥וּ בַגּוֹיִ֑ם וַֽ֝יִּלְמְד֗וּ מַֽעֲשֵׂיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 36,
      "referenceLabel": "Psalms 106:36",
      "text": "וַיַּעַבְד֥וּ אֶת ־ עֲצַבֵּיהֶ֑ם וַיִּהְי֖וּ לָהֶ֣ם לְמוֹקֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 37,
      "referenceLabel": "Psalms 106:37",
      "text": "וַיִּזְבְּח֣וּ אֶת ־ בְּ֭נֵיהֶם וְאֶת ־ בְּנֽוֹתֵיהֶ֗ם לַשֵּֽׁדִים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.38",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 38,
      "referenceLabel": "Psalms 106:38",
      "text": "וַיִּֽשְׁפְּכ֨וּ דָ֪ם נָקִ֡י דַּם ־ בְּנֵ֘יהֶ֤ם וּֽבְנוֹתֵיהֶ֗ם אֲשֶׁ֣ר זִ֭בְּחוּ לַעֲצַבֵּ֣י כְנָ֑עַן וַתֶּחֱנַ֥ף הָ֝אָ֗רֶץ בַּדָּמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.39",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 39,
      "referenceLabel": "Psalms 106:39",
      "text": "וַיִּטְמְא֥וּ בְמַעֲשֵׂיהֶ֑ם וַ֝יִּזְנוּ֗ בְּמַֽעַלְלֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.40",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 40,
      "referenceLabel": "Psalms 106:40",
      "text": "וַיִּֽחַר ־ אַ֣ף יְהוָ֣ה בְּעַמּ֑וֹ וַ֝יְתָעֵ֗ב אֶת ־ נַחֲלָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.106.41",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 41,
      "referenceLabel": "Psalms 106:41",
      "text": "וַיִּתְּנֵ֥ם בְּיַד ־ גּוֹיִ֑ם וַֽיִּמְשְׁל֥וּ בָ֝הֶ֗ם שֹׂנְאֵיהֶֽם ׃",
