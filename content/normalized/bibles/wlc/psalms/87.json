{
  "chapter": {
    "id": "wlc:psalms.87",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.87.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "לִבְנֵי ־ קֹ֭רַח מִזְמ֣וֹר שִׁ֑יר יְ֝סוּדָת֗וֹ בְּהַרְרֵי ־ קֹֽדֶשׁ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.87.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "אֹהֵ֣ב יְ֭הוָה שַׁעֲרֵ֣י צִיּ֑וֹן מִ֝כֹּ֗ל מִשְׁכְּנ֥וֹת יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.87.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "נִ֭כְבָּדוֹת מְדֻבָּ֣ר בָּ֑ךְ עִ֖יר הָאֱלֹהִ֣ים סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.87.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "אַזְכִּ֤יר ׀ רַ֥הַב וּבָבֶ֗ל לְֽיֹ֫דְעָ֥י הִנֵּ֤ה פְלֶ֣שֶׁת וְצ֣וֹר עִם ־ כּ֑וּשׁ זֶ֝֗ה יֻלַּד ־ שָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.87.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "וּֽלֲצִיּ֨וֹן ׀ יֵאָמַ֗ר אִ֣ישׁ וְ֭אִישׁ יֻלַּד ־ בָּ֑הּ וְה֖וּא יְכוֹנְנֶ֣הָ עֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.87.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "יְֽהוָ֗ה יִ֭סְפֹּר בִּכְת֣וֹב עַמִּ֑ים זֶ֖ה יֻלַּד ־ שָׁ֣ם סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.87.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "וְשָׁרִ֥ים כְּחֹלְלִ֑ים כָּֽל ־ מַעְיָנַ֥י בָּֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
