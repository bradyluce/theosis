{
  "chapter": {
    "id": "wlc:psalms.14",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 14,
    "referenceLabel": "Psalms 14",
    "summary": "Source text for Psalms 14 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.14.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Psalms 14:1",
      "text": "לַמְנַצֵּ֗חַ לְדָ֫וִ֥ד אָ֘מַ֤ר נָבָ֣ל בְּ֭לִבּוֹ אֵ֣ין אֱלֹהִ֑ים הִֽשְׁחִ֗יתוּ הִֽתְעִ֥יבוּ עֲלִילָ֗ה אֵ֣ין עֹֽשֵׂה ־ טֽוֹב ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.14.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Psalms 14:2",
      "text": "יְֽהוָ֗ה מִשָּׁמַיִם֮ הִשְׁקִ֪יף עַֽל ־ בְּנֵי ־ אָ֫דָ֥ם לִ֭רְאוֹת הֲיֵ֣שׁ מַשְׂכִּ֑יל דֹּ֝רֵשׁ אֶת ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.14.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Psalms 14:3",
      "text": "הַכֹּ֥ל סָר֮ יַחְדָּ֪ו נֶ֫אֱלָ֥חוּ אֵ֤ין עֹֽשֵׂה ־ ט֑וֹב אֵ֝֗ין גַּם ־ אֶחָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.14.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Psalms 14:4",
      "text": "הֲלֹ֥א יָדְעוּ֮ כָּל ־ פֹּ֪עֲלֵ֫י אָ֥וֶן אֹכְלֵ֣י עַ֭מִּי אָ֣כְלוּ לֶ֑חֶם יְ֝הוָ֗ה לֹ֣א קָרָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.14.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Psalms 14:5",
      "text": "שָׁ֤ם ׀ פָּ֣חֲדוּ פָ֑חַד כִּֽי ־ אֱ֝לֹהִ֗ים בְּד֣וֹר צַדִּֽיק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.14.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Psalms 14:6",
      "text": "עֲצַת ־ עָנִ֥י תָבִ֑ישׁוּ כִּ֖י יְהוָ֣ה מַחְסֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.14.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Psalms 14:7",
      "text": "מִ֥י יִתֵּ֣ן מִצִּיּוֹן֮ יְשׁוּעַ֪ת יִשְׂרָ֫אֵ֥ל בְּשׁ֣וּב יְ֭הוָה שְׁב֣וּת עַמּ֑וֹ יָגֵ֥ל יַ֝עֲקֹ֗ב יִשְׂמַ֥ח יִשְׂרָֽאֵל ׃",
      "paragraphStart": false
    }
  ]
}
