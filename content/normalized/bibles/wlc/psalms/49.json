{
  "chapter": {
    "id": "wlc:psalms.49",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 49,
    "referenceLabel": "Psalms 49",
    "summary": "Source text for Psalms 49 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.49.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 1,
      "referenceLabel": "Psalms 49:1",
      "text": "לַמְנַצֵּ֬חַ ׀ לִבְנֵי ־ קֹ֬רַח מִזְמֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.49.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 2,
      "referenceLabel": "Psalms 49:2",
      "text": "שִׁמְעוּ ־ זֹ֭את כָּל ־ הָֽעַמִּ֑ים הַ֝אֲזִ֗ינוּ כָּל ־ יֹ֥שְׁבֵי חָֽלֶד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 3,
      "referenceLabel": "Psalms 49:3",
      "text": "גַּם ־ בְּנֵ֣י אָ֭דָם גַּם ־ בְּנֵי ־ אִ֑ישׁ יַ֝֗חַד עָשִׁ֥יר וְאֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 4,
      "referenceLabel": "Psalms 49:4",
      "text": "פִּ֭י יְדַבֵּ֣ר חָכְמ֑וֹת וְהָג֖וּת לִבִּ֣י תְבוּנֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 5,
      "referenceLabel": "Psalms 49:5",
      "text": "אַטֶּ֣ה לְמָשָׁ֣ל אָזְנִ֑י אֶפְתַּ֥ח בְּ֝כִנּ֗וֹר חִידָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 6,
      "referenceLabel": "Psalms 49:6",
      "text": "לָ֣מָּה אִ֭ירָא בִּ֣ימֵי רָ֑ע עֲוֺ֖ן עֲקֵבַ֣י יְסוּבֵּֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 7,
      "referenceLabel": "Psalms 49:7",
      "text": "הַבֹּטְחִ֥ים עַל ־ חֵילָ֑ם וּבְרֹ֥ב עָ֝שְׁרָ֗ם יִתְהַלָּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 8,
      "referenceLabel": "Psalms 49:8",
      "text": "אָ֗ח לֹא ־ פָדֹ֣ה יִפְדֶּ֣ה אִ֑ישׁ לֹא ־ יִתֵּ֖ן לֵאלֹהִ֣ים כָּפְרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 9,
      "referenceLabel": "Psalms 49:9",
      "text": "וְ֭יֵקַר פִּדְי֥וֹן נַפְשָׁ֗ם וְחָדַ֥ל לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 10,
      "referenceLabel": "Psalms 49:10",
      "text": "וִֽיחִי ־ ע֥וֹד לָנֶ֑צַח לֹ֖א יִרְאֶ֣ה הַשָּֽׁחַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 11,
      "referenceLabel": "Psalms 49:11",
      "text": "כִּ֤י יִרְאֶ֨ה ׀ חֲכָ֘מִ֤ים יָמ֗וּתוּ יַ֤חַד כְּסִ֣יל וָבַ֣עַר יֹאבֵ֑דוּ וְעָזְב֖וּ לַאֲחֵרִ֣ים חֵילָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 12,
      "referenceLabel": "Psalms 49:12",
      "text": "קִרְבָּ֤ם בָּתֵּ֨ימוֹ ׀ לְֽעוֹלָ֗ם מִ֭שְׁכְּנֹתָם לְדֹ֣ר וָדֹ֑ר קָֽרְא֥וּ בִ֝שְׁמוֹתָ֗ם עֲלֵ֣י אֲדָמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 13,
      "referenceLabel": "Psalms 49:13",
      "text": "וְאָדָ֣ם בִּ֭יקָר בַּל ־ יָלִ֑ין נִמְשַׁ֖ל כַּבְּהֵמ֣וֹת נִדְמֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 14,
      "referenceLabel": "Psalms 49:14",
      "text": "זֶ֣ה דַ֭רְכָּם כֵּ֣סֶל לָ֑מוֹ וְאַחֲרֵיהֶ֓ם ׀ בְּפִיהֶ֖ם יִרְצ֣וּ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 15,
      "referenceLabel": "Psalms 49:15",
      "text": "כַּצֹּ֤אן ׀ לִֽשְׁא֣וֹל שַׁתּוּ֮ מָ֤וֶת יִ֫רְעֵ֥ם וַיִּרְדּ֘וּ בָ֤ם יְשָׁרִ֨ים ׀ לַבֹּ֗קֶר וצירם לְבַלּ֥וֹת שְׁא֗וֹל מִזְּבֻ֥ל לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 16,
      "referenceLabel": "Psalms 49:16",
      "text": "אַךְ ־ אֱלֹהִ֗ים יִפְדֶּ֣ה נַ֭פְשִׁי מִֽיַּד ־ שְׁא֑וֹל כִּ֖י יִקָּחֵ֣נִי סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 17,
      "referenceLabel": "Psalms 49:17",
      "text": "אַל ־ תִּ֭ירָא כִּֽי ־ יַעֲשִׁ֣ר אִ֑ישׁ כִּֽי ־ יִ֝רְבֶּה כְּב֣וֹד בֵּיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 18,
      "referenceLabel": "Psalms 49:18",
      "text": "כִּ֤י לֹ֣א בְ֭מוֹתוֹ יִקַּ֣ח הַכֹּ֑ל לֹא ־ יֵרֵ֖ד אַחֲרָ֣יו כְּבוֹדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 19,
      "referenceLabel": "Psalms 49:19",
      "text": "כִּֽי ־ נַ֭פְשׁוֹ בְּחַיָּ֣יו יְבָרֵ֑ךְ וְ֝יוֹדֻ֗ךָ כִּי ־ תֵיטִ֥יב לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 20,
      "referenceLabel": "Psalms 49:20",
      "text": "תָּ֭בוֹא עַד ־ דּ֣וֹר אֲבוֹתָ֑יו עַד ־ נֵ֝֗צַח לֹ֣א יִרְאוּ ־ אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.49.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 21,
      "referenceLabel": "Psalms 49:21",
      "text": "אָדָ֣ם בִּ֭יקָר וְלֹ֣א יָבִ֑ין נִמְשַׁ֖ל כַּבְּהֵמ֣וֹת נִדְמֽוּ ׃",
      "paragraphStart": false
    }
  ]
}
