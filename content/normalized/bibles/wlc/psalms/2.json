{
  "chapter": {
    "id": "wlc:psalms.2",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.2.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "לָ֭מָּה רָגְשׁ֣וּ גוֹיִ֑ם וּ֝לְאֻמִּ֗ים יֶהְגּוּ ־ רִֽיק ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.2.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "יִ֥תְיַצְּב֨וּ ׀ מַלְכֵי ־ אֶ֗רֶץ וְרוֹזְנִ֥ים נֽוֹסְדוּ ־ יָ֑חַד עַל ־ יְ֝הוָה וְעַל ־ מְשִׁיחֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "נְֽ֭נַתְּקָה אֶת ־ מֽוֹסְרוֹתֵ֑ימוֹ וְנַשְׁלִ֖יכָה מִמֶּ֣נּוּ עֲבֹתֵֽימוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "יוֹשֵׁ֣ב בַּשָּׁמַ֣יִם יִשְׂחָ֑ק אֲ֝דֹנָ֗י יִלְעַג ־ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "אָ֤ז יְדַבֵּ֣ר אֵלֵ֣ימוֹ בְאַפּ֑וֹ וּֽבַחֲרוֹנ֥וֹ יְבַהֲלֵֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "וַ֭אֲנִי נָסַ֣כְתִּי מַלְכִּ֑י עַל ־ צִ֝יּ֗וֹן הַר ־ קָדְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "אֲסַפְּרָ֗ה אֶֽ֫ל חֹ֥ק יְֽהוָ֗ה אָמַ֘ר אֵלַ֥י בְּנִ֥י אַ֑תָּה אֲ֝נִ֗י הַיּ֥וֹם יְלִדְתִּֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "שְׁאַ֤ל מִמֶּ֗נִּי וְאֶתְּנָ֣ה ג֭וֹיִם נַחֲלָתֶ֑ךָ וַ֝אֲחֻזָּתְךָ֗ אַפְסֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "תְּ֭רֹעֵם בְּשֵׁ֣בֶט בַּרְזֶ֑ל כִּכְלִ֖י יוֹצֵ֣ר תְּנַפְּצֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "וְ֭עַתָּה מְלָכִ֣ים הַשְׂכִּ֑ילוּ הִ֝וָּסְר֗וּ שֹׁ֣פְטֵי אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "עִבְד֣וּ אֶת ־ יְהוָ֣ה בְּיִרְאָ֑ה וְ֝גִ֗ילוּ בִּרְעָדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.2.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "נַשְּׁקוּ ־ בַ֡ר פֶּן ־ יֶאֱנַ֤ף ׀ וְתֹ֬אבְדוּ דֶ֗רֶךְ כִּֽי ־ יִבְעַ֣ר כִּמְעַ֣ט אַפּ֑וֹ אַ֝שְׁרֵ֗י כָּל ־ ח֥וֹסֵי בֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
