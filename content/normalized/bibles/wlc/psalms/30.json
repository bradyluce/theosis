{
  "chapter": {
    "id": "wlc:psalms.30",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 30,
    "referenceLabel": "Psalms 30",
    "summary": "Source text for Psalms 30 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.30.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Psalms 30:1",
      "text": "מִזְמ֡וֹר שִׁיר ־ חֲנֻכַּ֖ת הַבַּ֣יִת לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.30.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Psalms 30:2",
      "text": "אֲרוֹמִמְךָ֣ יְ֭הוָה כִּ֣י דִלִּיתָ֑נִי וְלֹא ־ שִׂמַּ֖חְתָּ אֹיְבַ֣י לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Psalms 30:3",
      "text": "יְהוָ֥ה אֱלֹהָ֑י שִׁוַּ֥עְתִּי אֵ֝לֶ֗יךָ וַתִּרְפָּאֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Psalms 30:4",
      "text": "יְֽהוָ֗ה הֶֽעֱלִ֣יתָ מִן ־ שְׁא֣וֹל נַפְשִׁ֑י חִ֝יִּיתַ֗נִי מיורדי ־ בֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Psalms 30:5",
      "text": "זַמְּר֣וּ לַיהוָ֣ה חֲסִידָ֑יו וְ֝הוֹד֗וּ לְזֵ֣כֶר קָדְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Psalms 30:6",
      "text": "כִּ֤י רֶ֨גַע ׀ בְּאַפּוֹ֮ חַיִּ֪ים בִּרְצ֫וֹנ֥וֹ בָּ֭עֶרֶב יָלִ֥ין בֶּ֗כִי וְלַבֹּ֥קֶר רִנָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Psalms 30:7",
      "text": "וַ֭אֲנִי אָמַ֣רְתִּי בְשַׁלְוִ֑י בַּל ־ אֶמּ֥וֹט לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Psalms 30:8",
      "text": "יְֽהוָ֗ה בִּרְצוֹנְךָ֮ הֶעֱמַ֪דְתָּה לְֽהַרְרִ֫י עֹ֥ז הִסְתַּ֥רְתָּ פָנֶ֗יךָ הָיִ֥יתִי נִבְהָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Psalms 30:9",
      "text": "אֵלֶ֣יךָ יְהוָ֣ה אֶקְרָ֑א וְאֶל ־ אֲ֝דֹנָ֗י אֶתְחַנָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Psalms 30:10",
      "text": "מַה ־ בֶּ֥צַע בְּדָמִי֮ בְּרִדְתִּ֪י אֶ֫ל ־ שָׁ֥חַת הֲיוֹדְךָ֥ עָפָ֑ר הֲיַגִּ֥יד אֲמִתֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Psalms 30:11",
      "text": "שְׁמַע ־ יְהוָ֥ה וְחָנֵּ֑נִי יְ֝הוָה הֱֽיֵה ־ עֹזֵ֥ר לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Psalms 30:12",
      "text": "הָפַ֣כְתָּ מִסְפְּדִי֮ לְמָח֪וֹל לִ֥י פִּתַּ֥חְתָּ שַׂקִּ֑י וַֽתְּאַזְּרֵ֥נִי שִׂמְחָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.30.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Psalms 30:13",
      "text": "לְמַ֤עַן ׀ יְזַמֶּרְךָ֣ כָ֭בוֹד וְלֹ֣א יִדֹּ֑ם יְהוָ֥ה אֱ֝לֹהַ֗י לְעוֹלָ֥ם אוֹדֶֽךָּ ׃",
      "paragraphStart": false
    }
  ]
}
