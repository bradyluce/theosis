{
  "chapter": {
    "id": "wlc:psalms.53",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 53,
    "referenceLabel": "Psalms 53",
    "summary": "Source text for Psalms 53 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.53.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 1,
      "referenceLabel": "Psalms 53:1",
      "text": "לַמְנַצֵּ֥חַ עַֽל ־ מָחֲלַ֗ת מַשְׂכִּ֥יל לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.53.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 2,
      "referenceLabel": "Psalms 53:2",
      "text": "אָ֘מַ֤ר נָבָ֣ל בְּ֭לִבּוֹ אֵ֣ין אֱלֹהִ֑ים הִֽ֝שְׁחִ֗יתוּ וְהִֽתְעִ֥יבוּ עָ֝֗וֶל אֵ֣ין עֹֽשֵׂה ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.53.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 3,
      "referenceLabel": "Psalms 53:3",
      "text": "אֱֽלֹהִ֗ים מִשָּׁמַיִם֮ הִשְׁקִ֪יף עַֽל ־ בְּנֵ֫י אָדָ֥ם לִ֭רְאוֹת הֲיֵ֣שׁ מַשְׂכִּ֑יל דֹּ֝רֵ֗שׁ אֶת ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.53.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 4,
      "referenceLabel": "Psalms 53:4",
      "text": "כֻּלּ֥וֹ סָג֮ יַחְדָּ֪ו נֶ֫אֱלָ֥חוּ אֵ֤ין עֹֽשֵׂה ־ ט֑וֹב אֵ֝֗ין גַּם ־ אֶחָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.53.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 5,
      "referenceLabel": "Psalms 53:5",
      "text": "הֲלֹ֥א יָדְעוּ֮ פֹּ֤עֲלֵ֫י אָ֥וֶן אֹכְלֵ֣י עַ֭מִּי אָ֣כְלוּ לֶ֑חֶם אֱ֝לֹהִ֗ים לֹ֣א קָרָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.53.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 6,
      "referenceLabel": "Psalms 53:6",
      "text": "שָׁ֤ם ׀ פָּֽחֲדוּ ־ פַחַד֮ לֹא ־ הָ֪יָה֫ פָ֥חַד כִּֽי ־ אֱלֹהִ֗ים פִּ֭זַּר עַצְמ֣וֹת חֹנָ֑ךְ הֱ֝בִשֹׁ֗תָה כִּֽי ־ אֱלֹהִ֥ים מְאָסָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.53.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 7,
      "referenceLabel": "Psalms 53:7",
      "text": "מִ֥י יִתֵּ֣ן מִצִּיּוֹן֮ יְשֻׁע֪וֹת יִשְׂרָ֫אֵ֥ל בְּשׁ֣וּב אֱ֭לֹהִים שְׁב֣וּת עַמּ֑וֹ יָגֵ֥ל יַ֝עֲקֹ֗ב יִשְׂמַ֥ח יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    }
  ]
}
