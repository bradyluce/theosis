{
  "chapter": {
    "id": "wlc:psalms.20",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.20.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.20.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "יַֽעַנְךָ֣ יְ֭הוָה בְּי֣וֹם צָרָ֑ה יְ֝שַׂגֶּבְךָ֗ שֵׁ֤ם ׀ אֱלֹהֵ֬י יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "יִשְׁלַֽח ־ עֶזְרְךָ֥ מִקֹּ֑דֶשׁ וּ֝מִצִּיּ֗וֹן יִסְעָדֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "יִזְכֹּ֥ר כָּל ־ מִנְחֹתֶ֑ךָ וְעוֹלָתְךָ֖ יְדַשְּׁנֶ֣ה סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "יִֽתֶּן ־ לְךָ֥ כִלְבָבֶ֑ךָ וְֽכָל ־ עֲצָתְךָ֥ יְמַלֵּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "נְרַנְּנָ֤ה ׀ בִּ֘ישׁ֤וּעָתֶ֗ךָ וּבְשֵֽׁם ־ אֱלֹהֵ֥ינוּ נִדְגֹּ֑ל יְמַלֵּ֥א יְ֝הוָ֗ה כָּל ־ מִשְׁאֲלוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "עַתָּ֤ה יָדַ֗עְתִּי כִּ֤י הוֹשִׁ֥יעַ ׀ יְהוָ֗ה מְשִׁ֫יח֥וֹ יַ֭עֲנֵהוּ מִשְּׁמֵ֣י קָדְשׁ֑וֹ בִּ֝גְבֻר֗וֹת יֵ֣שַׁע יְמִינֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "אֵ֣לֶּה בָ֭רֶכֶב וְאֵ֣לֶּה בַסּוּסִ֑ים וַאֲנַ֓חְנוּ ׀ בְּשֵׁם ־ יְהוָ֖ה אֱלֹהֵ֣ינוּ נַזְכִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "הֵ֭מָּה כָּרְע֣וּ וְנָפָ֑לוּ וַאֲנַ֥חְנוּ קַּ֝֗מְנוּ וַנִּתְעוֹדָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.20.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Psalms 20:10",
      "text": "יְהוָ֥ה הוֹשִׁ֑יעָה הַ֝מֶּ֗לֶךְ יַעֲנֵ֥נוּ בְיוֹם ־ קָרְאֵֽנוּ ׃",
      "paragraphStart": false
    }
  ]
}
