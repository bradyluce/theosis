{
  "chapter": {
    "id": "wlc:psalms.33",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.33.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "רַנְּנ֣וּ צַ֭דִּיקִים בַּֽיהוָ֑ה לַ֝יְשָׁרִ֗ים נָאוָ֥ה תְהִלָּֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.33.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "הוֹד֣וּ לַיהוָ֣ה בְּכִנּ֑וֹר בְּנֵ֥בֶל עָ֝שׂ֗וֹר זַמְּרוּ ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "שִֽׁירוּ ־ ל֭וֹ שִׁ֣יר חָדָ֑שׁ הֵיטִ֥יבוּ נַ֝גֵּ֗ן בִּתְרוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "כִּֽי ־ יָשָׁ֥ר דְּבַר ־ יְהוָ֑ה וְכָל ־ מַ֝עֲשֵׂ֗הוּ בֶּאֱמוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "אֹ֭הֵב צְדָקָ֣ה וּמִשְׁפָּ֑ט חֶ֥סֶד יְ֝הוָ֗ה מָלְאָ֥ה הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "בִּדְבַ֣ר יְ֭הוָה שָׁמַ֣יִם נַעֲשׂ֑וּ וּבְר֥וּחַ פִּ֝֗יו כָּל ־ צְבָאָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "כֹּנֵ֣ס כַּ֭נֵּד מֵ֣י הַיָּ֑ם נֹתֵ֖ן בְּאֹצָר֣וֹת תְּהוֹמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "יִֽירְא֣וּ מֵ֭יְהוָה כָּל ־ הָאָ֑רֶץ מִמֶּ֥נּוּ יָ֝ג֗וּרוּ כָּל ־ יֹשְׁבֵ֥י תֵבֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "כִּ֤י ה֣וּא אָמַ֣ר וַיֶּ֑הִי הֽוּא ־ צִ֝וָּ֗ה וַֽיַּעֲמֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "יְֽהוָ֗ה הֵפִ֥יר עֲצַת ־ גּוֹיִ֑ם הֵ֝נִ֗יא מַחְשְׁב֥וֹת עַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "עֲצַ֣ת יְ֭הוָה לְעוֹלָ֣ם תַּעֲמֹ֑ד מַחְשְׁב֥וֹת לִ֝בּ֗וֹ לְדֹ֣ר וָדֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "אַשְׁרֵ֣י הַ֭גּוֹי אֲשֶׁר ־ יְהוָ֣ה אֱלֹהָ֑יו הָעָ֓ם ׀ בָּחַ֖ר לְנַחֲלָ֣ה לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "מִ֭שָּׁמַיִם הִבִּ֣יט יְהוָ֑ה רָ֝אָ֗ה אֶֽת ־ כָּל ־ בְּנֵ֥י הָאָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "מִֽמְּכוֹן ־ שִׁבְתּ֥וֹ הִשְׁגִּ֑יחַ אֶ֖ל כָּל ־ יֹשְׁבֵ֣י הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "הַיֹּצֵ֣ר יַ֣חַד לִבָּ֑ם הַ֝מֵּבִ֗ין אֶל ־ כָּל ־ מַעֲשֵׂיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "אֵֽין ־ הַ֭מֶּלֶךְ נוֹשָׁ֣ע בְּרָב ־ חָ֑יִל גִּ֝בּ֗וֹר לֹֽא ־ יִנָּצֵ֥ל בְּרָב ־ כֹּֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "שֶׁ֣קֶר הַ֭סּוּס לִתְשׁוּעָ֑ה וּבְרֹ֥ב חֵ֝יל֗וֹ לֹ֣א יְמַלֵּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "הִנֵּ֤ה עֵ֣ין יְ֭הוָה אֶל ־ יְרֵאָ֑יו לַֽמְיַחֲלִ֥ים לְחַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "לְהַצִּ֣יל מִמָּ֣וֶת נַפְשָׁ֑ם וּ֝לְחַיּוֹתָ֗ם בָּרָעָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "נַ֭פְשֵׁנוּ חִכְּתָ֣ה לַֽיהוָ֑ה עֶזְרֵ֖נוּ וּמָגִנֵּ֣נוּ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "כִּי ־ ב֭וֹ יִשְׂמַ֣ח לִבֵּ֑נוּ כִּ֤י בְשֵׁ֖ם קָדְשׁ֣וֹ בָטָֽחְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.33.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "יְהִֽי ־ חַסְדְּךָ֣ יְהוָ֣ה עָלֵ֑ינוּ כַּ֝אֲשֶׁ֗ר יִחַ֥לְנוּ לָֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
