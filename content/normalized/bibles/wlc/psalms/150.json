  },
  "verses": [
    {
      "id": "wlc:psalms.150.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ הַֽלְלוּ ־ אֵ֥ל בְּקָדְשׁ֑וֹ הַֽ֝לְל֗וּהוּ בִּרְקִ֥יעַ עֻזּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.150.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "הַֽלְל֥וּהוּ בִגְבוּרֹתָ֑יו הַֽ֝לְל֗וּהוּ כְּרֹ֣ב גֻּדְלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.150.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "הַֽ֭לְלוּהוּ בְּתֵ֣קַע שׁוֹפָ֑ר הַֽ֝לְל֗וּהוּ בְּנֵ֣בֶל וְכִנּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.150.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "הַֽ֭לְלוּהוּ בְתֹ֣ף וּמָח֑וֹל הַֽ֝לְל֗וּהוּ בְּמִנִּ֥ים וְעוּגָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.150.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "הַֽלְל֥וּהוּ בְצִלְצְלֵי ־ שָׁ֑מַע הַֽ֝לְל֗וּהוּ בְּֽצִלְצְלֵ֥י תְרוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.150.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "כֹּ֣ל הַ֭נְּשָׁמָה תְּהַלֵּ֥ל יָ֗הּ הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
