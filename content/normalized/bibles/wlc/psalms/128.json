  },
  "verses": [
    {
      "id": "wlc:psalms.128.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "שִׁ֗יר הַֽמַּ֫עֲל֥וֹת אַ֭שְׁרֵי כָּל ־ יְרֵ֣א יְהוָ֑ה הַ֝הֹלֵ֗ךְ בִּדְרָכָֽיו ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.128.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "יְגִ֣יעַ כַּ֭פֶּיךָ כִּ֣י תֹאכֵ֑ל אַ֝שְׁרֶ֗יךָ וְט֣וֹב לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.128.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "אֶשְׁתְּךָ֤ ׀ כְּגֶ֥פֶן פֹּרִיָּה֮ בְּיַרְכְּתֵ֪י בֵ֫יתֶ֥ךָ בָּ֭נֶיךָ כִּשְׁתִלֵ֣י זֵיתִ֑ים סָ֝בִ֗יב לְשֻׁלְחָנֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.128.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "הִנֵּ֣ה כִי ־ כֵ֭ן יְבֹ֥רַךְ גָּ֗בֶר יְרֵ֣א יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.128.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "יְבָרֶכְךָ֥ יְהוָ֗ה מִצִּ֫יּ֥וֹן וּ֭רְאֵה בְּט֣וּב יְרוּשָׁלִָ֑ם כֹּ֝֗ל יְמֵ֣י חַיֶּֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.128.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "וּרְאֵֽה ־ בָנִ֥ים לְבָנֶ֑יךָ שָׁ֝ל֗וֹם עַל ־ יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    }
  ]
}
