{
  "chapter": {
    "id": "wlc:psalms.118",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 118,
    "referenceLabel": "Psalms 118",
    "summary": "Source text for Psalms 118 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.118.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 1,
      "referenceLabel": "Psalms 118:1",
      "text": "הוֹד֣וּ לַיהוָ֣ה כִּי ־ ט֑וֹב כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.118.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 2,
      "referenceLabel": "Psalms 118:2",
      "text": "יֹֽאמַר ־ נָ֥א יִשְׂרָאֵ֑ל כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 3,
      "referenceLabel": "Psalms 118:3",
      "text": "יֹֽאמְרוּ ־ נָ֥א בֵֽית ־ אַהֲרֹ֑ן כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 4,
      "referenceLabel": "Psalms 118:4",
      "text": "יֹֽאמְרוּ ־ נָ֭א יִרְאֵ֣י יְהוָ֑ה כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 5,
      "referenceLabel": "Psalms 118:5",
      "text": "מִֽן ־ הַ֭מֵּצַ֥ר קָרָ֣אתִי יָּ֑הּ עָנָ֖נִי בַמֶּרְחָ֣ב יָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 6,
      "referenceLabel": "Psalms 118:6",
      "text": "יְהוָ֣ה לִ֭י לֹ֣א אִירָ֑א מַה ־ יַּעֲשֶׂ֖ה לִ֣י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 7,
      "referenceLabel": "Psalms 118:7",
      "text": "יְהוָ֣ה לִ֭י בְּעֹזְרָ֑י וַ֝אֲנִ֗י אֶרְאֶ֥ה בְשֹׂנְאָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 8,
      "referenceLabel": "Psalms 118:8",
      "text": "ט֗וֹב לַחֲס֥וֹת בַּיהוָ֑ה מִ֝בְּטֹ֗חַ בָּאָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 9,
      "referenceLabel": "Psalms 118:9",
      "text": "ט֗וֹב לַחֲס֥וֹת בַּיהוָ֑ה מִ֝בְּטֹ֗חַ בִּנְדִיבִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 10,
      "referenceLabel": "Psalms 118:10",
      "text": "כָּל ־ גּוֹיִ֥ם סְבָב֑וּנִי בְּשֵׁ֥ם יְ֝הוָ֗ה כִּ֣י אֲמִילַֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 11,
      "referenceLabel": "Psalms 118:11",
      "text": "סַבּ֥וּנִי גַם ־ סְבָב֑וּנִי בְּשֵׁ֥ם יְ֝הוָ֗ה כִּ֣י אֲמִילַֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 12,
      "referenceLabel": "Psalms 118:12",
      "text": "סַבּ֤וּנִי כִדְבוֹרִ֗ים דֹּ֭עֲכוּ כְּאֵ֣שׁ קוֹצִ֑ים בְּשֵׁ֥ם יְ֝הוָ֗ה כִּ֣י אֲמִילַֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 13,
      "referenceLabel": "Psalms 118:13",
      "text": "דַּחֹ֣ה דְחִיתַ֣נִי לִנְפֹּ֑ל וַ֖יהוָ֣ה עֲזָרָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 14,
      "referenceLabel": "Psalms 118:14",
      "text": "עָזִּ֣י וְזִמְרָ֣ת יָ֑הּ וַֽיְהִי ־ לִ֝֗י לִֽישׁוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 15,
      "referenceLabel": "Psalms 118:15",
      "text": "ק֤וֹל ׀ רִנָּ֬ה וִֽישׁוּעָ֗ה בְּאָהֳלֵ֥י צַדִּיקִ֑ים יְמִ֥ין יְ֝הוָה עֹ֣שָׂה חָֽיִל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 16,
      "referenceLabel": "Psalms 118:16",
      "text": "יְמִ֣ין יְ֭הוָה רוֹמֵמָ֑ה יְמִ֥ין יְ֝הוָה עֹ֣שָׂה חָֽיִל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 17,
      "referenceLabel": "Psalms 118:17",
      "text": "לֹֽא אָמ֥וּת כִּי ־ אֶֽחְיֶ֑ה וַ֝אֲסַפֵּ֗ר מַֽעֲשֵׂ֥י יָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 18,
      "referenceLabel": "Psalms 118:18",
      "text": "יַסֹּ֣ר יִסְּרַ֣נִּי יָּ֑הּ וְ֝לַמָּ֗וֶת לֹ֣א נְתָנָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 19,
      "referenceLabel": "Psalms 118:19",
      "text": "פִּתְחוּ ־ לִ֥י שַׁעֲרֵי ־ צֶ֑דֶק אָֽבֹא ־ בָ֝ם אוֹדֶ֥ה יָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 20,
      "referenceLabel": "Psalms 118:20",
      "text": "זֶֽה ־ הַשַּׁ֥עַר לַיהוָ֑ה צַ֝דִּיקִ֗ים יָבֹ֥אוּ בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 21,
      "referenceLabel": "Psalms 118:21",
      "text": "א֭וֹדְךָ כִּ֣י עֲנִיתָ֑נִי וַתְּהִי ־ לִ֝֗י לִֽישׁוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 22,
      "referenceLabel": "Psalms 118:22",
      "text": "אֶ֭בֶן מָאֲס֣וּ הַבּוֹנִ֑ים הָ֝יְתָ֗ה לְרֹ֣אשׁ פִּנָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 23,
      "referenceLabel": "Psalms 118:23",
      "text": "מֵאֵ֣ת יְ֭הוָה הָ֣יְתָה זֹּ֑את הִ֖יא נִפְלָ֣את בְּעֵינֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 24,
      "referenceLabel": "Psalms 118:24",
      "text": "זֶה ־ הַ֭יּוֹם עָשָׂ֣ה יְהוָ֑ה נָגִ֖ילָה וְנִשְׂמְחָ֣ה בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 25,
      "referenceLabel": "Psalms 118:25",
      "text": "אָנָּ֣א יְ֭הוָה הוֹשִׁ֘יעָ֥ה נָּ֑א אָֽנָּ֥א יְ֝הוָ֗ה הַצְלִ֘יחָ֥ה נָּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 26,
      "referenceLabel": "Psalms 118:26",
      "text": "בָּר֣וּךְ הַ֭בָּא בְּשֵׁ֣ם יְהוָ֑ה בֵּ֝רַֽכְנוּכֶ֗ם מִבֵּ֥ית יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 27,
      "referenceLabel": "Psalms 118:27",
      "text": "אֵ֤ל ׀ יְהוָה֮ וַיָּ֪אֶר לָ֥נוּ אִסְרוּ ־ חַ֥ג בַּעֲבֹתִ֑ים עַד ־ קַ֝רְנ֗וֹת הַמִּזְבֵּֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 28,
      "referenceLabel": "Psalms 118:28",
      "text": "אֵלִ֣י אַתָּ֣ה וְאוֹדֶ֑ךָּ אֱ֝לֹהַ֗י אֲרוֹמְמֶֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.118.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 29,
      "referenceLabel": "Psalms 118:29",
      "text": "הוֹד֣וּ לַיהוָ֣ה כִּי ־ ט֑וֹב כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
