{
  "chapter": {
    "id": "wlc:psalms.90",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.90.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "תְּפִלָּה֮ לְמֹשֶׁ֪ה אִֽישׁ ־ הָאֱלֹ֫הִ֥ים אֲֽדֹנָ֗י מָע֣וֹן אַ֭תָּה הָיִ֥יתָ לָּ֗נוּ בְּדֹ֣ר וָדֹֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.90.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "בְּטֶ֤רֶם ׀ הָ֘רִ֤ים יֻלָּ֗דוּ וַתְּח֣וֹלֵֽל אֶ֣רֶץ וְתֵבֵ֑ל וּֽמֵעוֹלָ֥ם עַד ־ ע֝וֹלָ֗ם אַתָּ֥ה אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "תָּשֵׁ֣ב אֱ֭נוֹשׁ עַד ־ דַּכָּ֑א וַ֝תֹּ֗אמֶר שׁ֣וּבוּ בְנֵי ־ אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "כִּ֤י אֶ֪לֶף שָׁנִ֡ים בְּֽעֵינֶ֗יךָ כְּי֣וֹם אֶ֭תְמוֹל כִּ֣י יַעֲבֹ֑ר וְאַשְׁמוּרָ֥ה בַלָּֽיְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "זְ֭רַמְתָּם שֵׁנָ֣ה יִהְי֑וּ בַּ֝בֹּ֗קֶר כֶּחָצִ֥יר יַחֲלֹֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "בַּ֭בֹּקֶר יָצִ֣יץ וְחָלָ֑ף לָ֝עֶ֗רֶב יְמוֹלֵ֥ל וְיָבֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "כִּֽי ־ כָלִ֥ינוּ בְאַפֶּ֑ךָ וּֽבַחֲמָתְךָ֥ נִבְהָֽלְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "שת עֲוֺנֹתֵ֣ינוּ לְנֶגְדֶּ֑ךָ עֲ֝לֻמֵ֗נוּ לִמְא֥וֹר פָּנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "כִּ֣י כָל ־ יָ֭מֵינוּ פָּנ֣וּ בְעֶבְרָתֶ֑ךָ כִּלִּ֖ינוּ שָׁנֵ֣ינוּ כְמוֹ ־ הֶֽגֶה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "יְמֵֽי ־ שְׁנוֹתֵ֨ינוּ בָהֶ֥ם שִׁבְעִ֪ים שָׁנָ֡ה וְאִ֤ם בִּגְבוּרֹ֨ת ׀ שְׁמ֘וֹנִ֤ים שָׁנָ֗ה וְ֭רָהְבָּם עָמָ֣ל וָאָ֑וֶן כִּי ־ גָ֥ז חִ֝֗ישׁ וַנָּעֻֽפָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "מִֽי ־ י֭וֹדֵעַ עֹ֣ז אַפֶּ֑ךָ וּ֝כְיִרְאָתְךָ֗ עֶבְרָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "לִמְנ֣וֹת יָ֭מֵינוּ כֵּ֣ן הוֹדַ֑ע וְ֝נָבִ֗א לְבַ֣ב חָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "שׁוּבָ֣ה יְ֭הוָה עַד ־ מָתָ֑י וְ֝הִנָּחֵ֗ם עַל ־ עֲבָדֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "שַׂבְּעֵ֣נוּ בַבֹּ֣קֶר חַסְדֶּ֑ךָ וּֽנְרַנְּנָ֥ה וְ֝נִשְׂמְחָ֗ה בְּכָל ־ יָמֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "שַׂ֭מְּחֵנוּ כִּימ֣וֹת עִנִּיתָ֑נוּ שְׁ֝נ֗וֹת רָאִ֥ינוּ רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "יֵרָאֶ֣ה אֶל ־ עֲבָדֶ֣יךָ פָעֳלֶ֑ךָ וַ֝הֲדָרְךָ֗ עַל ־ בְּנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.90.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 17,
      "referenceLabel": "Psalms 90:17",
      "text": "וִיהִ֤י ׀ נֹ֤עַם אֲדֹנָ֥י אֱלֹהֵ֗ינוּ עָ֫לֵ֥ינוּ וּמַעֲשֵׂ֣ה יָ֭דֵינוּ כּוֹנְנָ֥ה עָלֵ֑ינוּ וּֽמַעֲשֵׂ֥ה יָ֝דֵ֗ינוּ כּוֹנְנֵֽהוּ ׃",
      "paragraphStart": false
    }
  ]
}
