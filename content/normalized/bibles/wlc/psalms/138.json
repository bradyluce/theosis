    "bookSlug": "psalms",
    "chapterNumber": 138,
    "referenceLabel": "Psalms 138",
    "summary": "Source text for Psalms 138 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.138.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 1,
      "referenceLabel": "Psalms 138:1",
      "text": "לְדָוִ֨ד ׀ אוֹדְךָ֥ בְכָל ־ לִבִּ֑י נֶ֖גֶד אֱלֹהִ֣ים אֲזַמְּרֶֽךָּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.138.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 2,
      "referenceLabel": "Psalms 138:2",
      "text": "אֶשְׁתַּחֲוֶ֨ה אֶל ־ הֵיכַ֪ל קָדְשְׁךָ֡ וְא֘וֹדֶ֤ה אֶת ־ שְׁמֶ֗ךָ עַל ־ חַסְדְּךָ֥ וְעַל ־ אֲמִתֶּ֑ךָ כִּֽי ־ הִגְדַּ֥לְתָּ עַל ־ כָּל ־ שִׁ֝מְךָ֗ אִמְרָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.138.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 3,
      "referenceLabel": "Psalms 138:3",
      "text": "בְּי֣וֹם קָ֭רָֽאתִי וַֽתַּעֲנֵ֑נִי תַּרְהִבֵ֖נִי בְנַפְשִׁ֣י עֹֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.138.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 4,
      "referenceLabel": "Psalms 138:4",
      "text": "יוֹד֣וּךָ יְ֭הוָה כָּל ־ מַלְכֵי ־ אָ֑רֶץ כִּ֥י שָׁ֝מְע֗וּ אִמְרֵי ־ פִֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.138.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 5,
      "referenceLabel": "Psalms 138:5",
      "text": "וְ֭יָשִׁירוּ בְּדַרְכֵ֣י יְהוָ֑ה כִּ֥י גָ֝ד֗וֹל כְּב֣וֹד יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.138.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 6,
      "referenceLabel": "Psalms 138:6",
      "text": "כִּי ־ רָ֣ם יְ֭הוָה וְשָׁפָ֣ל יִרְאֶ֑ה וְ֝גָבֹ֗הַּ מִמֶּרְחָ֥ק יְיֵדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.138.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 7,
      "referenceLabel": "Psalms 138:7",
      "text": "אִם ־ אֵלֵ֤ךְ ׀ בְּקֶ֥רֶב צָרָ֗ה תְּחַ֫יֵּ֥נִי עַ֤ל אַ֣ף אֹ֭יְבַי תִּשְׁלַ֣ח יָדֶ֑ךָ וְת֖וֹשִׁיעֵ֣נִי יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.138.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 8,
      "referenceLabel": "Psalms 138:8",
      "text": "יְהוָה֮ יִגְמֹ֪ר בַּ֫עֲדִ֥י יְ֭הוָה חַסְדְּךָ֣ לְעוֹלָ֑ם מַעֲשֵׂ֖י יָדֶ֣יךָ אַל ־ תֶּֽרֶף ׃",
      "paragraphStart": false
    }
  ]
}
