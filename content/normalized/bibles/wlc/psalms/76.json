{
  "chapter": {
    "id": "wlc:psalms.76",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.76.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "לַמְנַצֵּ֥חַ בִּנְגִינֹ֑ת מִזְמ֖וֹר לְאָסָ֣ף שִֽׁיר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.76.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "נוֹדָ֣ע בִּֽיהוּדָ֣ה אֱלֹהִ֑ים בְּ֝יִשְׂרָאֵ֗ל גָּד֥וֹל שְׁמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "וַיְהִ֣י בְשָׁלֵ֣ם סֻכּ֑וֹ וּמְע֖וֹנָת֣וֹ בְצִיּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "שָׁ֭מָּה שִׁבַּ֣ר רִשְׁפֵי ־ קָ֑שֶׁת מָגֵ֬ן וְחֶ֖רֶב וּמִלְחָמָ֣ה סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "נָ֭אוֹר אַתָּ֥ה אַדִּ֗יר מֵֽהַרְרֵי ־ טָֽרֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "אֶשְׁתּוֹלְל֨וּ ׀ אַבִּ֣ירֵי לֵ֭ב נָמ֣וּ שְׁנָתָ֑ם וְלֹא ־ מָצְא֖וּ כָל ־ אַנְשֵׁי ־ חַ֣יִל יְדֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "מִ֭גַּעֲרָ֣תְךָ אֱלֹהֵ֣י יַעֲקֹ֑ב נִ֝רְדָּ֗ם וְרֶ֣כֶב וָסֽוּס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "אַתָּ֤ה ׀ נ֥וֹרָא אַ֗תָּה וּמִֽי ־ יַעֲמֹ֥ד לְפָנֶ֗יךָ מֵאָ֥ז אַפֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "מִ֭שָּׁמַיִם הִשְׁמַ֣עְתָּ דִּ֑ין אֶ֖רֶץ יָֽרְאָ֣ה וְשָׁקָֽטָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "בְּקוּם ־ לַמִּשְׁפָּ֥ט אֱלֹהִ֑ים לְהוֹשִׁ֖יעַ כָּל ־ עַנְוֵי ־ אֶ֣רֶץ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "כִּֽי ־ חֲמַ֣ת אָדָ֣ם תּוֹדֶ֑ךָּ שְׁאֵרִ֖ית חֵמֹ֣ת תַּחְגֹּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "נִֽדֲר֣וּ וְשַׁלְּמוּ֮ לַיהוָ֪ה אֱֽלֹהֵ֫יכֶ֥ם כָּל ־ סְבִיבָ֑יו יוֹבִ֥ילוּ שַׁ֝֗י לַמּוֹרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.76.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 13,
      "referenceLabel": "Psalms 76:13",
      "text": "יִ֭בְצֹר ר֣וּחַ נְגִידִ֑ים נ֝וֹרָ֗א לְמַלְכֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    }
  ]
}
