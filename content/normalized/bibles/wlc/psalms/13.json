  },
  "verses": [
    {
      "id": "wlc:psalms.13.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Psalms 13:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.13.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Psalms 13:2",
      "text": "עַד ־ אָ֣נָה יְ֭הוָה תִּשְׁכָּחֵ֣נִי נֶ֑צַח עַד ־ אָ֓נָה ׀ תַּסְתִּ֖יר אֶת ־ פָּנֶ֣יךָ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.13.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Psalms 13:3",
      "text": "עַד ־ אָ֨נָה אָשִׁ֪ית עֵצ֡וֹת בְּנַפְשִׁ֗י יָג֣וֹן בִּלְבָבִ֣י יוֹמָ֑ם עַד ־ אָ֓נָה ׀ יָר֖וּם אֹיְבִ֣י עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.13.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Psalms 13:4",
      "text": "הַבִּ֣יטָֽה עֲ֭נֵנִי יְהוָ֣ה אֱלֹהָ֑י הָאִ֥ירָה עֵ֝ינַ֗י פֶּן ־ אִישַׁ֥ן הַמָּֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.13.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Psalms 13:5",
      "text": "פֶּן ־ יֹאמַ֣ר אֹיְבִ֣י יְכָלְתִּ֑יו צָרַ֥י יָ֝גִ֗ילוּ כִּ֣י אֶמּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.13.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Psalms 13:6",
      "text": "וַאֲנִ֤י ׀ בְּחַסְדְּךָ֣ בָטַחְתִּי֮ יָ֤גֵ֥ל לִבִּ֗י בִּֽישׁוּעָ֫תֶ֥ךָ אָשִׁ֥ירָה לַיהוָ֑ה כִּ֖י גָמַ֣ל עָלָֽי ׃",
      "paragraphStart": false
    }
  ]
}
