{
  "chapter": {
    "id": "wlc:psalms.140",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 140,
    "referenceLabel": "Psalms 140",
    "summary": "Source text for Psalms 140 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.140.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 1,
      "referenceLabel": "Psalms 140:1",
      "text": "לַמְנַצֵּ֗חַ מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.140.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 2,
      "referenceLabel": "Psalms 140:2",
      "text": "חַלְּצֵ֣נִי יְ֭הוָה מֵאָדָ֣ם רָ֑ע מֵאִ֖ישׁ חֲמָסִ֣ים תִּנְצְרֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 3,
      "referenceLabel": "Psalms 140:3",
      "text": "אֲשֶׁ֤ר חָשְׁב֣וּ רָע֣וֹת בְּלֵ֑ב כָּל ־ י֝֗וֹם יָג֥וּרוּ מִלְחָמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 4,
      "referenceLabel": "Psalms 140:4",
      "text": "שָֽׁנֲנ֣וּ לְשׁוֹנָם֮ כְּֽמוֹ ־ נָ֫חָ֥שׁ חֲמַ֥ת עַכְשׁ֑וּב תַּ֖חַת שְׂפָתֵ֣ימוֹ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 5,
      "referenceLabel": "Psalms 140:5",
      "text": "שָׁמְרֵ֤נִי יְהוָ֨ה ׀ מִ֘ידֵ֤י רָשָׁ֗ע מֵאִ֣ישׁ חֲמָסִ֣ים תִּנְצְרֵ֑נִי אֲשֶׁ֥ר חָ֝שְׁב֗וּ לִדְח֥וֹת פְּעָמָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 6,
      "referenceLabel": "Psalms 140:6",
      "text": "טָֽמְנֽוּ ־ גֵאִ֨ים ׀ פַּ֡ח לִ֗י וַחֲבָלִ֗ים פָּ֣רְשׂוּ רֶ֭שֶׁת לְיַד ־ מַעְגָּ֑ל מֹקְשִׁ֖ים שָֽׁתוּ ־ לִ֣י סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 7,
      "referenceLabel": "Psalms 140:7",
      "text": "אָמַ֣רְתִּי לַ֭יהוָה אֵ֣לִי אָ֑תָּה הַאֲזִ֥ינָה יְ֝הוָ֗ה ק֣וֹל תַּחֲנוּנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 8,
      "referenceLabel": "Psalms 140:8",
      "text": "יְהֹוִ֣ה אֲ֭דֹנָי עֹ֣ז יְשׁוּעָתִ֑י סַכֹּ֥תָה לְ֝רֹאשִׁ֗י בְּי֣וֹם נָֽשֶׁק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 9,
      "referenceLabel": "Psalms 140:9",
      "text": "אַל ־ תִּתֵּ֣ן יְ֭הוָה מַאֲוַיֵּ֣י רָשָׁ֑ע זְמָמ֥וֹ אַל ־ תָּ֝פֵ֗ק יָר֥וּמוּ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 10,
      "referenceLabel": "Psalms 140:10",
      "text": "רֹ֥אשׁ מְסִבָּ֑י עֲמַ֖ל שְׂפָתֵ֣ימוֹ יכסומו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 11,
      "referenceLabel": "Psalms 140:11",
      "text": "ימיטו עֲלֵיהֶ֗ם גֶּֽחָ֫לִ֥ים בָּאֵ֥שׁ יַפִּלֵ֑ם בְּ֝מַהֲמֹר֗וֹת בַּֽל ־ יָקֽוּמוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 12,
      "referenceLabel": "Psalms 140:12",
      "text": "אִ֥ישׁ לָשׁוֹן֮ בַּל ־ יִכּ֪וֹן בָּ֫אָ֥רֶץ אִישׁ ־ חָמָ֥ס רָ֑ע יְ֝צוּדֶ֗נּוּ לְמַדְחֵפֹֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 13,
      "referenceLabel": "Psalms 140:13",
      "text": "ידעת כִּֽי ־ יַעֲשֶׂ֣ה יְ֭הוָה דִּ֣ין עָנִ֑י מִ֝שְׁפַּ֗ט אֶבְיֹנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.140.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 14,
      "referenceLabel": "Psalms 140:14",
      "text": "אַ֣ךְ צַ֭דִּיקִים יוֹד֣וּ לִשְׁמֶ֑ךָ יֵשְׁב֥וּ יְ֝שָׁרִ֗ים אֶת ־ פָּנֶֽיךָ ׃",
      "paragraphStart": false
    }
  ]
}
