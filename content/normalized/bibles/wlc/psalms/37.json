{
  "chapter": {
    "id": "wlc:psalms.37",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.37.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "לְדָוִ֨ד ׀ אַל ־ תִּתְחַ֥ר בַּמְּרֵעִ֑ים אַל ־ תְּ֝קַנֵּ֗א בְּעֹשֵׂ֥י עַוְלָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.37.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "כִּ֣י כֶ֭חָצִיר מְהֵרָ֣ה יִמָּ֑לוּ וּכְיֶ֥רֶק דֶּ֝֗שֶׁא יִבּוֹלֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "בְּטַ֣ח בַּֽ֭יהוָה וַעֲשֵׂה ־ ט֑וֹב שְׁכָן ־ אֶ֝֗רֶץ וּרְעֵ֥ה אֱמוּנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "וְהִתְעַנַּ֥ג עַל ־ יְהוָ֑ה וְיִֽתֶּן ־ לְ֝ךָ֗ מִשְׁאֲלֹ֥ת לִבֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "גּ֣וֹל עַל ־ יְהוָ֣ה דַּרְכֶּ֑ךָ וּבְטַ֥ח עָ֝לָ֗יו וְה֣וּא יַעֲשֶֽׂה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "וְהוֹצִ֣יא כָא֣וֹר צִדְקֶ֑ךָ וּ֝מִשְׁפָּטֶ֗ךָ כַּֽצָּהֳרָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "דּ֤וֹם ׀ לַיהוָה֮ וְהִתְח֪וֹלֵ֫ל ל֥וֹ אַל ־ תִּ֭תְחַר בְּמַצְלִ֣יחַ דַּרְכּ֑וֹ בְּ֝אִ֗ישׁ עֹשֶׂ֥ה מְזִמּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "הֶ֣רֶף מֵ֭אַף וַעֲזֹ֣ב חֵמָ֑ה אַל ־ תִּ֝תְחַ֗ר אַךְ ־ לְהָרֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "כִּֽי ־ מְ֭רֵעִים יִכָּרֵת֑וּן וְקֹוֵ֥י יְ֝הוָ֗ה הֵ֣מָּה יִֽירְשׁוּ ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "וְע֣וֹד מְ֭עַט וְאֵ֣ין רָשָׁ֑ע וְהִתְבּוֹנַ֖נְתָּ עַל ־ מְקוֹמ֣וֹ וְאֵינֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "וַעֲנָוִ֥ים יִֽירְשׁוּ ־ אָ֑רֶץ וְ֝הִתְעַנְּג֗וּ עַל ־ רֹ֥ב שָׁלֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "זֹמֵ֣ם רָ֭שָׁע לַצַּדִּ֑יק וְחֹרֵ֖ק עָלָ֣יו שִׁנָּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "אֲדֹנָ֥י יִשְׂחַק ־ ל֑וֹ כִּֽי ־ רָ֝אָ֗ה כִּֽי ־ יָבֹ֥א יוֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "חֶ֤רֶב ׀ פָּֽתְח֣וּ רְשָׁעִים֮ וְדָרְכ֪וּ קַ֫שְׁתָּ֥ם לְ֭הַפִּיל עָנִ֣י וְאֶבְי֑וֹן לִ֝טְב֗וֹחַ יִשְׁרֵי ־ דָֽרֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "חַ֭רְבָּם תָּב֣וֹא בְלִבָּ֑ם וְ֝קַשְּׁתוֹתָ֗ם תִּשָּׁבַֽרְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "טוֹב ־ מְ֭עַט לַצַּדִּ֑יק מֵ֝הֲמ֗וֹן רְשָׁעִ֥ים רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "כִּ֤י זְרוֹע֣וֹת רְ֭שָׁעִים תִּשָּׁבַ֑רְנָה וְסוֹמֵ֖ךְ צַדִּיקִ֣ים יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "יוֹדֵ֣עַ יְ֭הוָה יְמֵ֣י תְמִימִ֑ם וְ֝נַחֲלָתָ֗ם לְעוֹלָ֥ם תִּהְיֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "לֹֽא ־ יֵ֭בֹשׁוּ בְּעֵ֣ת רָעָ֑ה וּבִימֵ֖י רְעָב֣וֹן יִשְׂבָּֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "כִּ֤י רְשָׁעִ֨ים ׀ יֹאבֵ֗דוּ וְאֹיְבֵ֣י יְ֭הוָה כִּיקַ֣ר כָּרִ֑ים כָּל֖וּ בֶעָשָׁ֣ן כָּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "לֹוֶ֣ה רָ֭שָׁע וְלֹ֣א יְשַׁלֵּ֑ם וְ֝צַדִּ֗יק חוֹנֵ֥ן וְנוֹתֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "כִּ֣י מְ֭בֹרָכָיו יִ֣ירְשׁוּ אָ֑רֶץ וּ֝מְקֻלָּלָ֗יו יִכָּרֵֽתוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Psalms 37:23",
      "text": "מֵ֭יְהוָה מִֽצְעֲדֵי ־ גֶ֥בֶר כּוֹנָ֗נוּ וְדַרְכּ֥וֹ יֶחְפָּֽץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Psalms 37:24",
      "text": "כִּֽי ־ יִפֹּ֥ל לֹֽא ־ יוּטָ֑ל כִּֽי ־ יְ֝הוָ֗ה סוֹמֵ֥ךְ יָדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 25,
      "referenceLabel": "Psalms 37:25",
      "text": "נַ֤עַר ׀ הָיִ֗יתִי גַּם ־ זָ֫קַ֥נְתִּי וְֽלֹא ־ רָ֭אִיתִי צַדִּ֣יק נֶעֱזָ֑ב וְ֝זַרְע֗וֹ מְבַקֶּשׁ ־ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 26,
      "referenceLabel": "Psalms 37:26",
      "text": "כָּל ־ הַ֭יּוֹם חוֹנֵ֣ן וּמַלְוֶ֑ה וְ֝זַרְע֗וֹ לִבְרָכָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 27,
      "referenceLabel": "Psalms 37:27",
      "text": "ס֣וּר מֵ֭רָע וַעֲשֵׂה ־ ט֗וֹב וּשְׁכֹ֥ן לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 28,
      "referenceLabel": "Psalms 37:28",
      "text": "כִּ֤י יְהוָ֨ה ׀ אֹ֘הֵ֤ב מִשְׁפָּ֗ט וְלֹא ־ יַעֲזֹ֣ב אֶת ־ חֲ֭סִידָיו לְעוֹלָ֣ם נִשְׁמָ֑רוּ וְזֶ֖רַע רְשָׁעִ֣ים נִכְרָֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 29,
      "referenceLabel": "Psalms 37:29",
      "text": "צַדִּיקִ֥ים יִֽירְשׁוּ ־ אָ֑רֶץ וְיִשְׁכְּנ֖וּ לָעַ֣ד עָלֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 30,
      "referenceLabel": "Psalms 37:30",
      "text": "פִּֽי ־ צַ֭דִּיק יֶהְגֶּ֣ה חָכְמָ֑ה וּ֝לְשׁוֹנ֗וֹ תְּדַבֵּ֥ר מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 31,
      "referenceLabel": "Psalms 37:31",
      "text": "תּוֹרַ֣ת אֱלֹהָ֣יו בְּלִבּ֑וֹ לֹ֖א תִמְעַ֣ד אֲשֻׁרָיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 32,
      "referenceLabel": "Psalms 37:32",
      "text": "צוֹפֶ֣ה רָ֭שָׁע לַצַּדִּ֑יק וּ֝מְבַקֵּ֗שׁ לַהֲמִיתוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 33,
      "referenceLabel": "Psalms 37:33",
      "text": "יְ֭הוָה לֹא ־ יַעַזְבֶ֣נּוּ בְיָד֑וֹ וְלֹ֥א יַ֝רְשִׁיעֶ֗נּוּ בְּהִשָּׁפְטֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 34,
      "referenceLabel": "Psalms 37:34",
      "text": "קַוֵּ֤ה אֶל ־ יְהוָ֨ה ׀ וּשְׁמֹ֬ר דַּרְכּ֗וֹ וִֽ֭ירוֹמִמְךָ לָרֶ֣שֶׁת אָ֑רֶץ בְּהִכָּרֵ֖ת רְשָׁעִ֣ים תִּרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 35,
      "referenceLabel": "Psalms 37:35",
      "text": "רָ֭אִיתִי רָשָׁ֣ע עָרִ֑יץ וּ֝מִתְעָרֶ֗ה כְּאֶזְרָ֥ח רַעֲנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 36,
      "referenceLabel": "Psalms 37:36",
      "text": "וַ֭יַּֽעֲבֹר וְהִנֵּ֣ה אֵינֶ֑נּוּ וָֽ֝אֲבַקְשֵׁ֗הוּ וְלֹ֣א נִמְצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 37,
      "referenceLabel": "Psalms 37:37",
      "text": "שְׁמָר ־ תָּ֭ם וּרְאֵ֣ה יָשָׁ֑ר כִּֽי ־ אַחֲרִ֖ית לְאִ֣ישׁ שָׁלֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.38",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 38,
      "referenceLabel": "Psalms 37:38",
      "text": "וּֽ֭פֹשְׁעִים נִשְׁמְד֣וּ יַחְדָּ֑ו אַחֲרִ֖ית רְשָׁעִ֣ים נִכְרָֽתָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.39",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 39,
      "referenceLabel": "Psalms 37:39",
      "text": "וּתְשׁוּעַ֣ת צַ֭דִּיקִים מֵיְהוָ֑ה מָֽ֝עוּזָּ֗ם בְּעֵ֣ת צָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.37.40",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 40,
      "referenceLabel": "Psalms 37:40",
