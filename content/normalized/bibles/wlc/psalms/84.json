{
  "chapter": {
    "id": "wlc:psalms.84",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.84.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "לַמְנַצֵּ֥חַ עַֽל ־ הַגִּתִּ֑ית לִבְנֵי ־ קֹ֥רַח מִזְמֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.84.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "מַה ־ יְּדִיד֥וֹת מִשְׁכְּנוֹתֶ֗יךָ יְהוָ֥ה צְבָאֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "נִכְסְפָ֬ה וְגַם ־ כָּלְתָ֨ה ׀ נַפְשִׁי֮ לְחַצְר֪וֹת יְה֫וָ֥ה לִבִּ֥י וּבְשָׂרִ֑י יְ֝רַנְּנ֗וּ אֶ֣ל אֵֽל ־ חָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "גַּם ־ צִפּ֨וֹר ׀ מָ֪צְאָה בַ֡יִת וּדְר֤וֹר ׀ קֵ֥ן לָהּ֮ אֲשֶׁר ־ שָׁ֪תָה אֶפְרֹ֫חֶ֥יהָ אֶֽת ־ מִ֭זְבְּחוֹתֶיךָ יְהוָ֣ה צְבָא֑וֹת מַ֝לְכִּ֗י וֵאלֹהָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "אַ֭שְׁרֵי יוֹשְׁבֵ֣י בֵיתֶ֑ךָ ע֝֗וֹד יְֽהַלְל֥וּךָ סֶּֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "אַשְׁרֵ֣י אָ֭דָם עֽוֹז ־ ל֥וֹ בָ֑ךְ מְ֝סִלּ֗וֹת בִּלְבָבָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "עֹבְרֵ֤י ׀ בְּעֵ֣מֶק הַ֭בָּכָא מַעְיָ֣ן יְשִׁית֑וּהוּ גַּם ־ בְּ֝רָכ֗וֹת יַעְטֶ֥ה מוֹרֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "יֵ֭לְכוּ מֵחַ֣יִל אֶל ־ חָ֑יִל יֵרָאֶ֖ה אֶל ־ אֱלֹהִ֣ים בְּצִיּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "יְה֘וָ֤ה אֱלֹהִ֣ים צְ֭בָאוֹת שִׁמְעָ֣ה תְפִלָּתִ֑י הַאֲזִ֨ינָה אֱלֹהֵ֖י יַעֲקֹ֣ב סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "מָ֭גִנֵּנוּ רְאֵ֣ה אֱלֹהִ֑ים וְ֝הַבֵּ֗ט פְּנֵ֣י מְשִׁיחֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "כִּ֤י טֽוֹב ־ י֥וֹם בַּחֲצֵרֶ֗יךָ מֵ֫אָ֥לֶף בָּחַ֗רְתִּי הִ֭סְתּוֹפֵף בְּבֵ֣ית אֱלֹהַ֑י מִ֝דּ֗וּר בְּאָהֳלֵי ־ רֶֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "כִּ֤י שֶׁ֨מֶשׁ ׀ וּמָגֵן֮ יְהוָ֪ה אֱלֹ֫הִ֥ים חֵ֣ן וְ֭כָבוֹד יִתֵּ֣ן יְהוָ֑ה לֹ֥א יִמְנַע ־ ט֝֗וֹב לַֽהֹלְכִ֥ים בְּתָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.84.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "יְהוָ֥ה צְבָא֑וֹת אַֽשְׁרֵ֥י אָ֝דָ֗ם בֹּטֵ֥חַ בָּֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
