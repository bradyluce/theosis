{
  "chapter": {
    "id": "wlc:psalms.147",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.147.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "הַ֥לְלוּ יָ֨הּ ׀ כִּי ־ ט֭וֹב זַמְּרָ֣ה אֱלֹהֵ֑ינוּ כִּֽי ־ נָ֝עִים נָאוָ֥ה תְהִלָּֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.147.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "בּוֹנֵ֣ה יְרוּשָׁלִַ֣ם יְהוָ֑ה נִדְחֵ֖י יִשְׂרָאֵ֣ל יְכַנֵּֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "הָ֭רֹפֵא לִשְׁב֣וּרֵי לֵ֑ב וּ֝מְחַבֵּ֗שׁ לְעַצְּבוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "מוֹנֶ֣ה מִ֭סְפָּר לַכּוֹכָבִ֑ים לְ֝כֻלָּ֗ם שֵׁמ֥וֹת יִקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "גָּד֣וֹל אֲדוֹנֵ֣ינוּ וְרַב ־ כֹּ֑חַ לִ֝תְבוּנָת֗וֹ אֵ֣ין מִסְפָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "מְעוֹדֵ֣ד עֲנָוִ֣ים יְהוָ֑ה מַשְׁפִּ֖יל רְשָׁעִ֣ים עֲדֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "עֱנ֣וּ לַיהוָ֣ה בְּתוֹדָ֑ה זַמְּר֖וּ לֵאלֹהֵ֣ינוּ בְכִנּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "הַֽמְכַסֶּ֬ה שָׁמַ֨יִם ׀ בְּעָבִ֗ים הַמֵּכִ֣ין לָאָ֣רֶץ מָטָ֑ר הַמַּצְמִ֖יחַ הָרִ֣ים חָצִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "נוֹתֵ֣ן לִבְהֵמָ֣ה לַחְמָ֑הּ לִבְנֵ֥י עֹ֝רֵ֗ב אֲשֶׁ֣ר יִקְרָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 10,
      "referenceLabel": "Psalms 147:10",
      "text": "לֹ֤א בִגְבוּרַ֣ת הַסּ֣וּס יֶחְפָּ֑ץ לֹֽא ־ בְשׁוֹקֵ֖י הָאִ֣ישׁ יִרְצֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 11,
      "referenceLabel": "Psalms 147:11",
      "text": "רוֹצֶ֣ה יְ֭הוָה אֶת ־ יְרֵאָ֑יו אֶת ־ הַֽמְיַחֲלִ֥ים לְחַסְדּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 12,
      "referenceLabel": "Psalms 147:12",
      "text": "שַׁבְּחִ֣י יְ֭רוּשָׁלִַם אֶת ־ יְהוָ֑ה הַֽלְלִ֖י אֱלֹהַ֣יִךְ צִיּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 13,
      "referenceLabel": "Psalms 147:13",
      "text": "כִּֽי ־ חִ֭זַּק בְּרִיחֵ֣י שְׁעָרָ֑יִךְ בֵּרַ֖ךְ בָּנַ֣יִךְ בְּקִרְבֵּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 14,
      "referenceLabel": "Psalms 147:14",
      "text": "הַשָּׂם ־ גְּבוּלֵ֥ךְ שָׁל֑וֹם חֵ֥לֶב חִ֝טִּ֗ים יַשְׂבִּיעֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 15,
      "referenceLabel": "Psalms 147:15",
      "text": "הַשֹּׁלֵ֣חַ אִמְרָת֣וֹ אָ֑רֶץ עַד ־ מְ֝הֵרָ֗ה יָר֥וּץ דְּבָרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 16,
      "referenceLabel": "Psalms 147:16",
      "text": "הַנֹּתֵ֣ן שֶׁ֣לֶג כַּצָּ֑מֶר כְּ֝פ֗וֹר כָּאֵ֥פֶר יְפַזֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 17,
      "referenceLabel": "Psalms 147:17",
      "text": "מַשְׁלִ֣יךְ קַֽרְח֣וֹ כְפִתִּ֑ים לִפְנֵ֥י קָ֝רָת֗וֹ מִ֣י יַעֲמֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 18,
      "referenceLabel": "Psalms 147:18",
      "text": "יִשְׁלַ֣ח דְּבָר֣וֹ וְיַמְסֵ֑ם יַשֵּׁ֥ב ר֝וּח֗וֹ יִזְּלוּ ־ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 19,
      "referenceLabel": "Psalms 147:19",
      "text": "מַגִּ֣יד דברו לְיַעֲקֹ֑ב חֻקָּ֥יו וּ֝מִשְׁפָּטָ֗יו לְיִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.147.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 20,
      "referenceLabel": "Psalms 147:20",
      "text": "לֹ֘א עָ֤שָׂה כֵ֨ן ׀ לְכָל ־ גּ֗וֹי וּמִשְׁפָּטִ֥ים בַּל ־ יְדָע֗וּם הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
