{
  "chapter": {
    "id": "wlc:psalms.107",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 107,
    "referenceLabel": "Psalms 107",
    "summary": "Source text for Psalms 107 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.107.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 1,
      "referenceLabel": "Psalms 107:1",
      "text": "הֹד֣וּ לַיהוָ֣ה כִּי ־ ט֑וֹב כִּ֖י לְעוֹלָ֣ם חַסְדּֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.107.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 2,
      "referenceLabel": "Psalms 107:2",
      "text": "יֹ֭אמְרוּ גְּאוּלֵ֣י יְהוָ֑ה אֲשֶׁ֥ר גְּ֝אָלָ֗ם מִיַּד ־ צָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 3,
      "referenceLabel": "Psalms 107:3",
      "text": "וּֽמֵאֲרָצ֗וֹת קִ֫בְּצָ֥ם מִמִּזְרָ֥ח וּמִֽמַּעֲרָ֑ב מִצָּפ֥וֹן וּמִיָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 4,
      "referenceLabel": "Psalms 107:4",
      "text": "תָּע֣וּ בַ֭מִּדְבָּר בִּישִׁימ֣וֹן דָּ֑רֶךְ עִ֥יר מ֝וֹשָׁ֗ב לֹ֣א מָצָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 5,
      "referenceLabel": "Psalms 107:5",
      "text": "רְעֵבִ֥ים גַּם ־ צְמֵאִ֑ים נַ֝פְשָׁ֗ם בָּהֶ֥ם תִּתְעַטָּֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 6,
      "referenceLabel": "Psalms 107:6",
      "text": "וַיִּצְעֲק֣וּ אֶל ־ יְ֭הוָה בַּצַּ֣ר לָהֶ֑ם מִ֝מְּצֽוּקוֹתֵיהֶ֗ם יַצִּילֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 7,
      "referenceLabel": "Psalms 107:7",
      "text": "וַ֭יַּֽדְרִיכֵם בְּדֶ֣רֶךְ יְשָׁרָ֑ה לָ֝לֶ֗כֶת אֶל ־ עִ֥יר מוֹשָֽׁב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 8,
      "referenceLabel": "Psalms 107:8",
      "text": "יוֹד֣וּ לַיהוָ֣ה חַסְדּ֑וֹ וְ֝נִפְלְאוֹתָ֗יו לִבְנֵ֥י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 9,
      "referenceLabel": "Psalms 107:9",
      "text": "כִּי ־ הִ֭שְׂבִּיעַ נֶ֣פֶשׁ שֹׁקֵקָ֑ה וְנֶ֥פֶשׁ רְ֝עֵבָה מִלֵּא ־ טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 10,
      "referenceLabel": "Psalms 107:10",
      "text": "יֹ֭שְׁבֵי חֹ֣שֶׁךְ וְצַלְמָ֑וֶת אֲסִירֵ֖י עֳנִ֣י וּבַרְזֶֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 11,
      "referenceLabel": "Psalms 107:11",
      "text": "כִּֽי ־ הִמְר֥וּ אִמְרֵי ־ אֵ֑ל וַעֲצַ֖ת עֶלְי֣וֹן נָאָֽצוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 12,
      "referenceLabel": "Psalms 107:12",
      "text": "וַיַּכְנַ֣ע בֶּעָמָ֣ל לִבָּ֑ם כָּ֝שְׁל֗וּ וְאֵ֣ין עֹזֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 13,
      "referenceLabel": "Psalms 107:13",
      "text": "וַיִּזְעֲק֣וּ אֶל ־ יְ֭הוָה בַּצַּ֣ר לָהֶ֑ם מִ֝מְּצֻֽקוֹתֵיהֶ֗ם יוֹשִׁיעֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 14,
      "referenceLabel": "Psalms 107:14",
      "text": "יֽ֭וֹצִיאֵם מֵחֹ֣שֶׁךְ וְצַלְמָ֑וֶת וּמוֹסְר֖וֹתֵיהֶ֣ם יְנַתֵּֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 15,
      "referenceLabel": "Psalms 107:15",
      "text": "יוֹד֣וּ לַיהוָ֣ה חַסְדּ֑וֹ וְ֝נִפְלְאוֹתָ֗יו לִבְנֵ֥י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 16,
      "referenceLabel": "Psalms 107:16",
      "text": "כִּֽי ־ שִׁ֭בַּר דַּלְת֣וֹת נְחֹ֑שֶׁת וּבְרִיחֵ֖י בַרְזֶ֣ל גִּדֵּֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 17,
      "referenceLabel": "Psalms 107:17",
      "text": "אֱ֭וִלִים מִדֶּ֣רֶךְ פִּשְׁעָ֑ם וּֽ֝מֵעֲוֺֽנֹתֵיהֶ֗ם יִתְעַנּֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 18,
      "referenceLabel": "Psalms 107:18",
      "text": "כָּל ־ אֹ֭כֶל תְּתַעֵ֣ב נַפְשָׁ֑ם וַ֝יַּגִּ֗יעוּ עַד ־ שַׁ֥עֲרֵי מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 19,
      "referenceLabel": "Psalms 107:19",
      "text": "וַיִּזְעֲק֣וּ אֶל ־ יְ֭הוָה בַּצַּ֣ר לָהֶ֑ם מִ֝מְּצֻֽקוֹתֵיהֶ֗ם יוֹשִׁיעֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 20,
      "referenceLabel": "Psalms 107:20",
      "text": "יִשְׁלַ֣ח דְּ֭בָרוֹ וְיִרְפָּאֵ֑ם וִֽ֝ימַלֵּ֗ט מִשְּׁחִיתוֹתָֽם ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 21,
      "referenceLabel": "Psalms 107:21",
      "text": "יוֹד֣וּ לַיהוָ֣ה חַסְדּ֑וֹ וְ֝נִפְלְאוֹתָ֗יו לִבְנֵ֥י אָדָֽם ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 22,
      "referenceLabel": "Psalms 107:22",
      "text": "וְ֭יִזְבְּחוּ זִבְחֵ֣י תוֹדָ֑ה וִֽיסַפְּר֖וּ מַעֲשָׂ֣יו בְּרִנָּֽה ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 23,
      "referenceLabel": "Psalms 107:23",
      "text": "יוֹרְדֵ֣י הַ֭יָּם בָּאֳנִיּ֑וֹת עֹשֵׂ֥י מְ֝לָאכָ֗ה בְּמַ֣יִם רַבִּֽים ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 24,
      "referenceLabel": "Psalms 107:24",
      "text": "הֵ֣מָּה רָ֭אוּ מַעֲשֵׂ֣י יְהוָ֑ה וְ֝נִפְלְאוֹתָ֗יו בִּמְצוּלָֽה ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 25,
      "referenceLabel": "Psalms 107:25",
      "text": "וַיֹּ֗אמֶר וַֽ֭יַּעֲמֵד ר֣וּחַ סְעָרָ֑ה וַתְּרוֹמֵ֥ם גַּלָּֽיו ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 26,
      "referenceLabel": "Psalms 107:26",
      "text": "יַעֲל֣וּ שָׁ֭מַיִם יֵרְד֣וּ תְהוֹמ֑וֹת נַ֝פְשָׁ֗ם בְּרָעָ֥ה תִתְמוֹגָֽג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 27,
      "referenceLabel": "Psalms 107:27",
      "text": "יָח֣וֹגּוּ וְ֭יָנוּעוּ כַּשִּׁכּ֑וֹר וְכָל ־ חָ֝כְמָתָ֗ם תִּתְבַּלָּֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 28,
      "referenceLabel": "Psalms 107:28",
      "text": "וַיִּצְעֲק֣וּ אֶל ־ יְ֭הוָה בַּצַּ֣ר לָהֶ֑ם וּֽ֝מִמְּצֽוּקֹתֵיהֶ֗ם יוֹצִיאֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 29,
      "referenceLabel": "Psalms 107:29",
      "text": "יָקֵ֣ם סְ֭עָרָה לִדְמָמָ֑ה וַ֝יֶּחֱשׁ֗וּ גַּלֵּיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 30,
      "referenceLabel": "Psalms 107:30",
      "text": "וַיִּשְׂמְח֥וּ כִֽי ־ יִשְׁתֹּ֑קוּ וַ֝יַּנְחֵ֗ם אֶל ־ מְח֥וֹז חֶפְצָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 31,
      "referenceLabel": "Psalms 107:31",
      "text": "יוֹד֣וּ לַיהוָ֣ה חַסְדּ֑וֹ וְ֝נִפְלְאוֹתָ֗יו לִבְנֵ֥י אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 32,
      "referenceLabel": "Psalms 107:32",
      "text": "וִֽ֭ירֹמְמוּהוּ בִּקְהַל ־ עָ֑ם וּבְמוֹשַׁ֖ב זְקֵנִ֣ים יְהַלְלֽוּהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 33,
      "referenceLabel": "Psalms 107:33",
      "text": "יָשֵׂ֣ם נְהָר֣וֹת לְמִדְבָּ֑ר וּמֹצָ֥אֵי מַ֝֗יִם לְצִמָּאֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 34,
      "referenceLabel": "Psalms 107:34",
      "text": "אֶ֣רֶץ פְּ֭רִי לִמְלֵחָ֑ה מֵ֝רָעַ֗ת יֹ֣שְׁבֵי בָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 35,
      "referenceLabel": "Psalms 107:35",
      "text": "יָשֵׂ֣ם מִ֭דְבָּר לַֽאֲגַם ־ מַ֑יִם וְאֶ֥רֶץ צִ֝יָּ֗ה לְמֹצָ֥אֵי מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.36",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 36,
      "referenceLabel": "Psalms 107:36",
      "text": "וַיּ֣וֹשֶׁב שָׁ֣ם רְעֵבִ֑ים וַ֝יְכוֹנְנ֗וּ עִ֣יר מוֹשָֽׁב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.37",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 37,
      "referenceLabel": "Psalms 107:37",
      "text": "וַיִּזְרְע֣וּ שָׂ֭דוֹת וַיִּטְּע֣וּ כְרָמִ֑ים וַ֝יַּעֲשׂ֗וּ פְּרִ֣י תְבֽוּאָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.38",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 38,
      "referenceLabel": "Psalms 107:38",
      "text": "וַיְבָרֲכֵ֣ם וַיִּרְבּ֣וּ מְאֹ֑ד וּ֝בְהֶמְתָּ֗ם לֹ֣א יַמְעִֽיט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.39",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 39,
      "referenceLabel": "Psalms 107:39",
      "text": "וַיִּמְעֲט֥וּ וַיָּשֹׁ֑חוּ מֵעֹ֖צֶר רָעָ֣ה וְיָגֽוֹן ׃ ׆",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.40",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 40,
      "referenceLabel": "Psalms 107:40",
      "text": "שֹׁפֵ֣ךְ בּ֭וּז עַל ־ נְדִיבִ֑ים וַ֝יַּתְעֵ֗ם בְּתֹ֣הוּ לֹא ־ דָֽרֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.41",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 41,
      "referenceLabel": "Psalms 107:41",
      "text": "וַיְשַׂגֵּ֣ב אֶבְי֣וֹן מֵע֑וֹנִי וַיָּ֥שֶׂם כַּ֝צֹּ֗אן מִשְׁפָּחֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.107.42",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 107,
