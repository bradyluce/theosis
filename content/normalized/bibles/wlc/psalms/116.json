{
  "chapter": {
    "id": "wlc:psalms.116",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 116,
    "referenceLabel": "Psalms 116",
    "summary": "Source text for Psalms 116 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.116.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 1,
      "referenceLabel": "Psalms 116:1",
      "text": "אָ֭הַבְתִּי כִּֽי ־ יִשְׁמַ֥ע ׀ יְהוָ֑ה אֶת ־ ק֝וֹלִ֗י תַּחֲנוּנָֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.116.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 2,
      "referenceLabel": "Psalms 116:2",
      "text": "כִּֽי ־ הִטָּ֣ה אָזְנ֣וֹ לִ֑י וּבְיָמַ֥י אֶקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 3,
      "referenceLabel": "Psalms 116:3",
      "text": "אֲפָפ֤וּנִי ׀ חֶבְלֵי ־ מָ֗וֶת וּמְצָרֵ֣י שְׁא֣וֹל מְצָא֑וּנִי צָרָ֖ה וְיָג֣וֹן אֶמְצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 4,
      "referenceLabel": "Psalms 116:4",
      "text": "וּבְשֵֽׁם ־ יְהוָ֥ה אֶקְרָ֑א אָנָּ֥ה יְ֝הוָ֗ה מַלְּטָ֥ה נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 5,
      "referenceLabel": "Psalms 116:5",
      "text": "חַנּ֣וּן יְהֹוָ֣ה וְצַדִּ֑יק וֵ֖אלֹהֵ֣ינוּ מְרַחֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 6,
      "referenceLabel": "Psalms 116:6",
      "text": "שֹׁמֵ֣ר פְּתָאיִ֣ם יְהֹוָ֑ה דַּ֝לּוֹתִ֗י וְלִ֣י יְהוֹשִֽׁיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 7,
      "referenceLabel": "Psalms 116:7",
      "text": "שׁוּבִ֣י נַ֭פְשִׁי לִמְנוּחָ֑יְכִי כִּֽי ־ יְ֝הוָ֗ה גָּמַ֥ל עָלָֽיְכִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 8,
      "referenceLabel": "Psalms 116:8",
      "text": "כִּ֤י חִלַּ֥צְתָּ נַפְשִׁ֗י מִ֫מָּ֥וֶת אֶת ־ עֵינִ֥י מִן ־ דִּמְעָ֑ה אֶת ־ רַגְלִ֥י מִדֶּֽחִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 9,
      "referenceLabel": "Psalms 116:9",
      "text": "אֶ֭תְהַלֵּךְ לִפְנֵ֣י יְהוָ֑ה בְּ֝אַרְצ֗וֹת הַֽחַיִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 10,
      "referenceLabel": "Psalms 116:10",
      "text": "הֶ֭אֱמַנְתִּי כִּ֣י אֲדַבֵּ֑ר אֲ֝נִ֗י עָנִ֥יתִי מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 11,
      "referenceLabel": "Psalms 116:11",
      "text": "אֲ֭נִי אָמַ֣רְתִּי בְחָפְזִ֑י כָּֽל ־ הָאָדָ֥ם כֹּזֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 12,
      "referenceLabel": "Psalms 116:12",
      "text": "מָֽה ־ אָשִׁ֥יב לַיהוָ֑ה כָּֽל ־ תַּגְמוּל֥וֹהִי עָלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 13,
      "referenceLabel": "Psalms 116:13",
      "text": "כּוֹס ־ יְשׁוּע֥וֹת אֶשָּׂ֑א וּבְשֵׁ֖ם יְהוָ֣ה אֶקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 14,
      "referenceLabel": "Psalms 116:14",
      "text": "נְ֭דָרַי לַיהוָ֣ה אֲשַׁלֵּ֑ם נֶגְדָה ־ נָּ֝֗א לְכָל ־ עַמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 15,
      "referenceLabel": "Psalms 116:15",
      "text": "יָ֭קָר בְּעֵינֵ֣י יְהוָ֑ה הַ֝מָּ֗וְתָה לַחֲסִידָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 16,
      "referenceLabel": "Psalms 116:16",
      "text": "אָֽנָּ֣ה יְהוָה֮ כִּֽי ־ אֲנִ֪י עַ֫בְדֶּ֥ךָ אֲֽנִי ־ עַ֭בְדְּךָ בֶּן ־ אֲמָתֶ֑ךָ פִּ֝תַּ֗חְתָּ לְמוֹסֵרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 17,
      "referenceLabel": "Psalms 116:17",
      "text": "לְֽךָ ־ אֶ֭זְבַּח זֶ֣בַח תּוֹדָ֑ה וּבְשֵׁ֖ם יְהוָ֣ה אֶקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 18,
      "referenceLabel": "Psalms 116:18",
      "text": "נְ֭דָרַי לַיהוָ֣ה אֲשַׁלֵּ֑ם נֶגְדָה ־ נָּ֝֗א לְכָל ־ עַמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.116.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 19,
      "referenceLabel": "Psalms 116:19",
      "text": "בְּחַצְר֤וֹת ׀ בֵּ֤ית יְהוָ֗ה בְּֽת֘וֹכֵ֤כִי יְֽרוּשָׁלִָ֗ם הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
