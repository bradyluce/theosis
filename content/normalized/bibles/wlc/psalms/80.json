{
  "chapter": {
    "id": "wlc:psalms.80",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 80,
    "referenceLabel": "Psalms 80",
    "summary": "Source text for Psalms 80 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.80.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 1,
      "referenceLabel": "Psalms 80:1",
      "text": "לַמְנַצֵּ֥חַ אֶל ־ שֹׁשַׁנִּ֑ים עֵד֖וּת לְאָסָ֣ף מִזְמֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.80.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 2,
      "referenceLabel": "Psalms 80:2",
      "text": "רֹ֘עֵ֤ה יִשְׂרָאֵ֨ל ׀ הַאֲזִ֗ינָה נֹהֵ֣ג כַּצֹּ֣אן יוֹסֵ֑ף יֹשֵׁ֖ב הַכְּרוּבִ֣ים הוֹפִֽיעָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 3,
      "referenceLabel": "Psalms 80:3",
      "text": "לִפְנֵ֤י אֶפְרַ֨יִם ׀ וּבִנְיָ֘מִ֤ן וּמְנַשֶּׁ֗ה עוֹרְרָ֥ה אֶת ־ גְּבֽוּרָתֶ֑ךָ וּלְכָ֖ה לִישֻׁעָ֣תָה לָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 4,
      "referenceLabel": "Psalms 80:4",
      "text": "אֱלֹהִ֥ים הֲשִׁיבֵ֑נוּ וְהָאֵ֥ר פָּ֝נֶ֗יךָ וְנִוָּשֵֽׁעָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 5,
      "referenceLabel": "Psalms 80:5",
      "text": "יְהוָ֣ה אֱלֹהִ֣ים צְבָא֑וֹת עַד ־ מָתַ֥י עָ֝שַׁ֗נְתָּ בִּתְפִלַּ֥ת עַמֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 6,
      "referenceLabel": "Psalms 80:6",
      "text": "הֶ֭אֱכַלְתָּם לֶ֣חֶם דִּמְעָ֑ה וַ֝תַּשְׁקֵ֗מוֹ בִּדְמָע֥וֹת שָׁלִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 7,
      "referenceLabel": "Psalms 80:7",
      "text": "תְּשִׂימֵ֣נוּ מָ֭דוֹן לִשְׁכֵנֵ֑ינוּ וְ֝אֹיְבֵ֗ינוּ יִלְעֲגוּ ־ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 8,
      "referenceLabel": "Psalms 80:8",
      "text": "אֱלֹהִ֣ים צְבָא֣וֹת הֲשִׁיבֵ֑נוּ וְהָאֵ֥ר פָּ֝נֶ֗יךָ וְנִוָּשֵֽׁעָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 9,
      "referenceLabel": "Psalms 80:9",
      "text": "גֶּ֭פֶן מִמִּצְרַ֣יִם תַּסִּ֑יעַ תְּגָרֵ֥שׁ גּ֝וֹיִ֗ם וַתִּטָּעֶֽהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 10,
      "referenceLabel": "Psalms 80:10",
      "text": "פִּנִּ֥יתָ לְפָנֶ֑יהָ וַתַּשְׁרֵ֥שׁ שָׁ֝רָשֶׁ֗יהָ וַתְּמַלֵּא ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 11,
      "referenceLabel": "Psalms 80:11",
      "text": "כָּסּ֣וּ הָרִ֣ים צִלָּ֑הּ וַ֝עֲנָפֶ֗יהָ אַֽרְזֵי ־ אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 12,
      "referenceLabel": "Psalms 80:12",
      "text": "תְּשַׁלַּ֣ח קְצִירֶ֣הָ עַד ־ יָ֑ם וְאֶל ־ נָ֝הָ֗ר יֽוֹנְקוֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 13,
      "referenceLabel": "Psalms 80:13",
      "text": "לָ֭מָּה פָּרַ֣צְתָּ גְדֵרֶ֑יהָ וְ֝אָר֗וּהָ כָּל ־ עֹ֥בְרֵי דָֽרֶךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 14,
      "referenceLabel": "Psalms 80:14",
      "text": "יְכַרְסְמֶ֣נָּֽה חֲזִ֣יר מִיָּ֑ עַ ר וְזִ֖יז שָׂדַ֣י יִרְעֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 15,
      "referenceLabel": "Psalms 80:15",
      "text": "אֱלֹהִ֣ים צְבָאוֹת֮ שֽׁ֫וּב ־ נָ֥א הַבֵּ֣ט מִשָּׁמַ֣יִם וּרְאֵ֑ה וּ֝פְקֹ֗ד גֶּ֣פֶן זֹֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 16,
      "referenceLabel": "Psalms 80:16",
      "text": "וְ֭כַנָּה אֲשֶׁר ־ נָטְעָ֣ה יְמִינֶ֑ךָ וְעַל ־ בֵּ֝֗ן אִמַּ֥צְתָּה לָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 17,
      "referenceLabel": "Psalms 80:17",
      "text": "שְׂרֻפָ֣ה בָאֵ֣שׁ כְּסוּחָ֑ה מִגַּעֲרַ֖ת פָּנֶ֣יךָ יֹאבֵֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 18,
      "referenceLabel": "Psalms 80:18",
      "text": "תְּֽהִי ־ יָ֭דְךָ עַל ־ אִ֣ישׁ יְמִינֶ֑ךָ עַל ־ בֶּן ־ אָ֝דָ֗ם אִמַּ֥צְתָּ לָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 19,
      "referenceLabel": "Psalms 80:19",
      "text": "וְלֹא ־ נָס֥וֹג מִמֶּ֑ךָּ תְּ֝חַיֵּ֗נוּ וּבְשִׁמְךָ֥ נִקְרָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.80.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 20,
      "referenceLabel": "Psalms 80:20",
      "text": "יְה֘וָ֤ה אֱלֹהִ֣ים צְבָא֣וֹת הֲשִׁיבֵ֑נוּ הָאֵ֥ר פָּ֝נֶ֗יךָ וְנִוָּשֵֽׁעָה ׃",
      "paragraphStart": false
    }
  ]
}
