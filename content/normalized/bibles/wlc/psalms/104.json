{
  "chapter": {
    "id": "wlc:psalms.104",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 104,
    "referenceLabel": "Psalms 104",
    "summary": "Source text for Psalms 104 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.104.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 1,
      "referenceLabel": "Psalms 104:1",
      "text": "בָּרֲכִ֥י נַפְשִׁ֗י אֶת ־ יְה֫וָ֥ה יְהוָ֣ה אֱ֭לֹהַי גָּדַ֣לְתָּ מְּאֹ֑ד ה֭וֹד וְהָדָ֣ר לָבָֽשְׁתָּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.104.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 2,
      "referenceLabel": "Psalms 104:2",
      "text": "עֹֽטֶה ־ א֭וֹר כַּשַּׂלְמָ֑ה נוֹטֶ֥ה שָׁ֝מַ֗יִם כַּיְרִיעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 3,
      "referenceLabel": "Psalms 104:3",
      "text": "הַ֥מְקָרֶֽה בַמַּ֗יִם עֲֽלִיּ֫וֹתָ֥יו הַשָּׂם ־ עָבִ֥ים רְכוּב֑וֹ הַֽ֝מְהַלֵּ֗ךְ עַל ־ כַּנְפֵי ־ רֽוּחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 4,
      "referenceLabel": "Psalms 104:4",
      "text": "עֹשֶׂ֣ה מַלְאָכָ֣יו רוּח֑וֹת מְ֝שָׁרְתָ֗יו אֵ֣שׁ לֹהֵֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 5,
      "referenceLabel": "Psalms 104:5",
      "text": "יָֽסַד ־ אֶ֭רֶץ עַל ־ מְכוֹנֶ֑יהָ בַּל ־ תִּ֝מּ֗וֹט עוֹלָ֥ם וָעֶֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 6,
      "referenceLabel": "Psalms 104:6",
      "text": "תְּ֭הוֹם כַּלְּב֣וּשׁ כִּסִּית֑וֹ עַל ־ הָ֝רִ֗ים יַֽעַמְדוּ ־ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 7,
      "referenceLabel": "Psalms 104:7",
      "text": "מִן ־ גַּעֲרָ֣תְךָ֣ יְנוּס֑וּן מִן ־ ק֥וֹל רַֽ֝עַמְךָ֗ יֵחָפֵזֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 8,
      "referenceLabel": "Psalms 104:8",
      "text": "יַעֲל֣וּ הָ֭רִים יֵרְד֣וּ בְקָע֑וֹת אֶל ־ מְ֝ק֗וֹם זֶ֤ה ׀ יָסַ֬דְתָּ לָהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 9,
      "referenceLabel": "Psalms 104:9",
      "text": "גְּֽבוּל ־ שַׂ֭מְתָּ בַּל ־ יַֽעֲבֹר֑וּן בַּל ־ יְ֝שׁוּב֗וּן לְכַסּ֥וֹת הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 10,
      "referenceLabel": "Psalms 104:10",
      "text": "הַֽמְשַׁלֵּ֣חַ מַ֭עְיָנִים בַּנְּחָלִ֑ים בֵּ֥ין הָ֝רִ֗ים יְהַלֵּכֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 11,
      "referenceLabel": "Psalms 104:11",
      "text": "יַ֭שְׁקוּ כָּל ־ חַיְת֣וֹ שָׂדָ֑י יִשְׁבְּר֖וּ פְרָאִ֣ים צְמָאָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 12,
      "referenceLabel": "Psalms 104:12",
      "text": "עֲ֭לֵיהֶם עוֹף ־ הַשָּׁמַ֣יִם יִשְׁכּ֑וֹן מִבֵּ֥ין עֳ֝פָאיִ֗ם יִתְּנוּ ־ קֽוֹל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 13,
      "referenceLabel": "Psalms 104:13",
      "text": "מַשְׁקֶ֣ה הָ֭רִים מֵעֲלִיּוֹתָ֑יו מִפְּרִ֥י מַ֝עֲשֶׂ֗יךָ תִּשְׂבַּ֥ע הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 14,
      "referenceLabel": "Psalms 104:14",
      "text": "מַצְמִ֤יחַ חָצִ֨יר ׀ לַבְּהֵמָ֗ה וְ֭עֵשֶׂב לַעֲבֹדַ֣ת הָאָדָ֑ם לְה֥וֹצִיא לֶ֝֗חֶם מִן ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 15,
      "referenceLabel": "Psalms 104:15",
      "text": "וְיַ֤יִן ׀ יְשַׂמַּ֬ח לְֽבַב ־ אֱנ֗וֹשׁ לְהַצְהִ֣יל פָּנִ֣ים מִשָּׁ֑מֶן וְ֝לֶ֗חֶם לְֽבַב ־ אֱנ֥וֹשׁ יִסְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 16,
      "referenceLabel": "Psalms 104:16",
      "text": "יִ֭שְׂבְּעוּ עֲצֵ֣י יְהוָ֑ה אַֽרְזֵ֥י לְ֝בָנ֗וֹן אֲשֶׁ֣ר נָטָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 17,
      "referenceLabel": "Psalms 104:17",
      "text": "אֲשֶׁר ־ שָׁ֭ם צִפֳּרִ֣ים יְקַנֵּ֑נוּ חֲ֝סִידָ֗ה בְּרוֹשִׁ֥ים בֵּיתָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 18,
      "referenceLabel": "Psalms 104:18",
      "text": "הָרִ֣ים הַ֭גְּבֹהִים לַיְּעֵלִ֑ים סְ֝לָעִ֗ים מַחְסֶ֥ה לַֽשְׁפַנִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 19,
      "referenceLabel": "Psalms 104:19",
      "text": "עָשָׂ֣ה יָ֭רֵחַ לְמוֹעֲדִ֑ים שֶׁ֝֗מֶשׁ יָדַ֥ע מְבוֹאֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 20,
      "referenceLabel": "Psalms 104:20",
      "text": "תָּֽשֶׁת ־ חֹ֭שֶׁךְ וִ֣יהִי לָ֑יְלָה בּֽוֹ ־ תִ֝רְמֹ֗שׂ כָּל ־ חַיְתוֹ ־ יָֽעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 21,
      "referenceLabel": "Psalms 104:21",
      "text": "הַ֭כְּפִירִים שֹׁאֲגִ֣ים לַטָּ֑רֶף וּלְבַקֵּ֖שׁ מֵאֵ֣ל אָכְלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 22,
      "referenceLabel": "Psalms 104:22",
      "text": "תִּזְרַ֣ח הַ֭שֶּׁמֶשׁ יֵאָסֵפ֑וּן וְאֶל ־ מְ֝עוֹנֹתָ֗ם יִרְבָּצֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 23,
      "referenceLabel": "Psalms 104:23",
      "text": "יֵצֵ֣א אָדָ֣ם לְפָעֳל֑וֹ וְֽלַעֲבֹ֖דָת֣וֹ עֲדֵי ־ עָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 24,
      "referenceLabel": "Psalms 104:24",
      "text": "מָֽה ־ רַבּ֬וּ מַעֲשֶׂ֨יךָ ׀ יְֽהוָ֗ה כֻּ֭לָּם בְּחָכְמָ֣ה עָשִׂ֑יתָ מָלְאָ֥ה הָ֝אָ֗רֶץ קִנְיָנֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 25,
      "referenceLabel": "Psalms 104:25",
      "text": "זֶ֤ה ׀ הַיָּ֥ם גָּדוֹל֮ וּרְחַ֪ב יָ֫דָ֥יִם שָֽׁם ־ רֶ֭מֶשׂ וְאֵ֣ין מִסְפָּ֑ר חַיּ֥וֹת קְ֝טַנּ֗וֹת עִם ־ גְּדֹלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 26,
      "referenceLabel": "Psalms 104:26",
      "text": "שָׁ֭ם אֳנִיּ֣וֹת יְהַלֵּכ֑וּן לִ֝וְיָתָ֗ן זֶֽה ־ יָצַ֥רְתָּ לְשַֽׂחֶק ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 27,
      "referenceLabel": "Psalms 104:27",
      "text": "כֻּ֭לָּם אֵלֶ֣יךָ יְשַׂבֵּר֑וּן לָתֵ֖ת אָכְלָ֣ם בְּעִתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 28,
      "referenceLabel": "Psalms 104:28",
      "text": "תִּתֵּ֣ן לָ֭הֶם יִלְקֹט֑וּן תִּפְתַּ֥ח יָֽ֝דְךָ֗ יִשְׂבְּע֥וּן טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 29,
      "referenceLabel": "Psalms 104:29",
      "text": "תַּסְתִּ֥יר פָּנֶיךָ֮ יִֽבָּהֵ֫ל֥וּן תֹּסֵ֣ף ר֭וּחָם יִגְוָע֑וּן וְֽאֶל ־ עֲפָרָ֥ם יְשׁוּבֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 30,
      "referenceLabel": "Psalms 104:30",
      "text": "תְּשַׁלַּ֣ח ר֭וּחֲךָ יִבָּרֵא֑וּן וּ֝תְחַדֵּ֗שׁ פְּנֵ֣י אֲדָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 31,
      "referenceLabel": "Psalms 104:31",
      "text": "יְהִ֤י כְב֣וֹד יְהוָ֣ה לְעוֹלָ֑ם יִשְׂמַ֖ח יְהוָ֣ה בְּמַעֲשָֽׂיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.32",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 32,
      "referenceLabel": "Psalms 104:32",
      "text": "הַמַּבִּ֣יט לָ֭אָרֶץ וַתִּרְעָ֑ד יִגַּ֖ע בֶּהָרִ֣ים וְֽיֶעֱשָֽׁנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.33",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 33,
      "referenceLabel": "Psalms 104:33",
      "text": "אָשִׁ֣ירָה לַיהוָ֣ה בְּחַיָּ֑י אֲזַמְּרָ֖ה לֵאלֹהַ֣י בְּעוֹדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.34",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 34,
      "referenceLabel": "Psalms 104:34",
      "text": "יֶעֱרַ֣ב עָלָ֣יו שִׂיחִ֑י אָ֝נֹכִ֗י אֶשְׂמַ֥ח בַּיהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.104.35",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 35,
      "referenceLabel": "Psalms 104:35",
      "text": "יִתַּ֤מּוּ חַטָּאִ֨ים ׀ מִן ־ הָאָ֡רֶץ וּרְשָׁעִ֤ים ׀ ע֤וֹד אֵינָ֗ם בָּרֲכִ֣י נַ֭פְשִׁי אֶת ־ יְהוָ֗ה הַֽלְלוּ ־ יָֽהּ ׃",
      "paragraphStart": false
    }
  ]
}
