{
  "chapter": {
    "id": "wlc:psalms.109",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.109.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "לַ֭מְנַצֵּחַ לְדָוִ֣ד מִזְמ֑וֹר אֱלֹהֵ֥י תְ֝הִלָּתִ֗י אַֽל ־ תֶּחֱרַֽשׁ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.109.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "כִּ֤י פִ֪י רָשָׁ֡ע וּֽפִי ־ מִ֭רְמָה עָלַ֣י פָּתָ֑חוּ דִּבְּר֥וּ אִ֝תִּ֗י לְשׁ֣וֹן שָֽׁקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "וְדִבְרֵ֣י שִׂנְאָ֣ה סְבָב֑וּנִי וַיִּֽלָּחֲמ֥וּנִי חִנָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "תַּֽחַת ־ אַהֲבָתִ֥י יִשְׂטְנ֗וּנִי וַאֲנִ֥י תְפִלָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "וַיָּ֘שִׂ֤ימוּ עָלַ֣י רָ֭עָה תַּ֣חַת טוֹבָ֑ה וְ֝שִׂנְאָ֗ה תַּ֣חַת אַהֲבָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "הַפְקֵ֣ד עָלָ֣יו רָשָׁ֑ע וְ֝שָׂטָ֗ן יַעֲמֹ֥ד עַל ־ יְמִינֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "בְּ֭הִשָּׁ֣פְטוֹ יֵצֵ֣א רָשָׁ֑ע וּ֝תְפִלָּת֗וֹ תִּהְיֶ֥ה לַֽחֲטָאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 8,
      "referenceLabel": "Psalms 109:8",
      "text": "יִֽהְיֽוּ ־ יָמָ֥יו מְעַטִּ֑ים פְּ֝קֻדָּת֗וֹ יִקַּ֥ח אַחֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 9,
      "referenceLabel": "Psalms 109:9",
      "text": "יִֽהְיוּ ־ בָנָ֥יו יְתוֹמִ֑ים וְ֝אִשְׁתּוֹ אַלְמָנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 10,
      "referenceLabel": "Psalms 109:10",
      "text": "וְנ֤וֹעַ יָנ֣וּעוּ בָנָ֣יו וְשִׁאֵ֑לוּ וְ֝דָרְשׁ֗וּ מֵחָרְבוֹתֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 11,
      "referenceLabel": "Psalms 109:11",
      "text": "יְנַקֵּ֣שׁ נ֭וֹשֶׁה לְכָל ־ אֲשֶׁר ־ ל֑וֹ וְיָבֹ֖זּוּ זָרִ֣ים יְגִיעֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 12,
      "referenceLabel": "Psalms 109:12",
      "text": "אַל ־ יְהִי ־ ל֭וֹ מֹשֵׁ֣ךְ חָ֑סֶד וְֽאַל ־ יְהִ֥י ח֝וֹנֵ֗ן לִיתוֹמָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 13,
      "referenceLabel": "Psalms 109:13",
      "text": "יְהִֽי ־ אַחֲרִית֥וֹ לְהַכְרִ֑ית בְּד֥וֹר אַ֝חֵ֗ר יִמַּ֥ח שְׁמָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 14,
      "referenceLabel": "Psalms 109:14",
      "text": "יִזָּכֵ֤ר ׀ עֲוֺ֣ן אֲ֭בֹתָיו אֶל ־ יְהוָ֑ה וְחַטַּ֥את אִ֝מּ֗וֹ אַל ־ תִּמָּֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 15,
      "referenceLabel": "Psalms 109:15",
      "text": "יִהְי֣וּ נֶֽגֶד ־ יְהוָ֣ה תָּמִ֑יד וְיַכְרֵ֖ת מֵאֶ֣רֶץ זִכְרָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 16,
      "referenceLabel": "Psalms 109:16",
      "text": "יַ֗עַן אֲשֶׁ֤ר ׀ לֹ֥א זָכַר֮ עֲשׂ֪וֹת חָ֥סֶד וַיִּרְדֹּ֡ף אִישׁ ־ עָנִ֣י וְ֭אֶבְיוֹן וְנִכְאֵ֨ה לֵבָ֬ב לְמוֹתֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 17,
      "referenceLabel": "Psalms 109:17",
      "text": "וַיֶּאֱהַ֣ב קְ֭לָלָה וַתְּבוֹאֵ֑הוּ וְֽלֹא ־ חָפֵ֥ץ בִּ֝בְרָכָ֗ה וַתִּרְחַ֥ק מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 18,
      "referenceLabel": "Psalms 109:18",
      "text": "וַיִּלְבַּ֥שׁ קְלָלָ֗ה כְּמַ֫דּ֥וֹ וַתָּבֹ֣א כַמַּ֣יִם בְּקִרְבּ֑וֹ וְ֝כַשֶּׁ֗מֶן בְּעַצְמוֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 19,
      "referenceLabel": "Psalms 109:19",
      "text": "תְּהִי ־ ל֭וֹ כְּבֶ֣גֶד יַעְטֶ֑ה וּ֝לְמֵ֗זַח תָּמִ֥יד יַחְגְּרֶֽהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 20,
      "referenceLabel": "Psalms 109:20",
      "text": "זֹ֤את פְּעֻלַּ֣ת שֹׂ֭טְנַי מֵאֵ֣ת יְהוָ֑ה וְהַדֹּבְרִ֥ים רָ֝֗ע עַל ־ נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 21,
      "referenceLabel": "Psalms 109:21",
      "text": "וְאַתָּ֤ה ׀ יְה֘וִ֤ה אֲדֹנָ֗י עֲֽשֵׂה ־ אִ֭תִּי לְמַ֣עַן שְׁמֶ֑ךָ כִּי ־ ט֥וֹב חַ֝סְדְּךָ֗ הַצִּילֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 22,
      "referenceLabel": "Psalms 109:22",
      "text": "כִּֽי ־ עָנִ֣י וְאֶבְי֣וֹן אָנֹ֑כִי וְ֝לִבִּ֗י חָלַ֥ל בְּקִרְבִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 23,
      "referenceLabel": "Psalms 109:23",
      "text": "כְּצֵל ־ כִּנְטוֹת֥וֹ נֶהֱלָ֑כְתִּי נִ֝נְעַ֗רְתִּי כָּֽאַרְבֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 24,
      "referenceLabel": "Psalms 109:24",
      "text": "בִּ֭רְכַּי כָּשְׁל֣וּ מִצּ֑וֹם וּ֝בְשָׂרִ֗י כָּחַ֥שׁ מִשָּֽׁמֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 25,
      "referenceLabel": "Psalms 109:25",
      "text": "וַאֲנִ֤י ׀ הָיִ֣יתִי חֶרְפָּ֣ה לָהֶ֑ם יִ֝רְא֗וּנִי יְנִיע֥וּן רֹאשָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 26,
      "referenceLabel": "Psalms 109:26",
      "text": "עָ֭זְרֵנִי יְהוָ֣ה אֱלֹהָ֑י ה֭וֹשִׁיעֵ֣נִי כְחַסְדֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 27,
      "referenceLabel": "Psalms 109:27",
      "text": "וְֽ֭יֵדְעוּ כִּי ־ יָ֣דְךָ זֹּ֑את אַתָּ֖ה יְהוָ֣ה עֲשִׂיתָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 28,
      "referenceLabel": "Psalms 109:28",
      "text": "יְקַֽלְלוּ ־ הֵמָּה֮ וְאַתָּ֪ה תְבָ֫רֵ֥ךְ קָ֤מוּ ׀ וַיֵּבֹ֗שׁוּ וְֽעַבְדְּךָ֥ יִשְׂמָֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 29,
      "referenceLabel": "Psalms 109:29",
      "text": "יִלְבְּשׁ֣וּ שׂוֹטְנַ֣י כְּלִמָּ֑ה וְיַעֲט֖וּ כַמְעִ֣יל בָּשְׁתָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.30",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 30,
      "referenceLabel": "Psalms 109:30",
      "text": "א֘וֹדֶ֤ה יְהוָ֣ה מְאֹ֣ד בְּפִ֑י וּבְת֖וֹךְ רַבִּ֣ים אֲהַֽלְלֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.109.31",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 31,
      "referenceLabel": "Psalms 109:31",
      "text": "כִּֽי ־ יַ֭עֲמֹד לִימִ֣ין אֶבְי֑וֹן לְ֝הוֹשִׁ֗יעַ מִשֹּׁפְטֵ֥י נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    }
  ]
}
