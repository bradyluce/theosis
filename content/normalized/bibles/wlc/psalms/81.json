{
  "chapter": {
    "id": "wlc:psalms.81",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.81.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "לַמְנַצֵּ֬חַ ׀ עַֽל ־ הַגִּתִּ֬ית לְאָסָֽף ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.81.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "הַ֭רְנִינוּ לֵאלֹהִ֣ים עוּזֵּ֑נוּ הָ֝רִ֗יעוּ לֵאלֹהֵ֥י יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "שְֽׂאוּ ־ זִ֭מְרָה וּתְנוּ ־ תֹ֑ף כִּנּ֖וֹר נָעִ֣ים עִם ־ נָֽבֶל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "תִּקְע֣וּ בַחֹ֣דֶשׁ שׁוֹפָ֑ר בַּ֝כֵּ֗סֶה לְי֣וֹם חַגֵּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "כִּ֤י חֹ֣ק לְיִשְׂרָאֵ֣ל ה֑וּא מִ֝שְׁפָּ֗ט לֵאלֹהֵ֥י יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "עֵ֤דוּת ׀ בִּֽיה֘וֹסֵ֤ף שָׂמ֗וֹ בְּ֭צֵאתוֹ עַל ־ אֶ֣רֶץ מִצְרָ֑יִם שְׂפַ֖ת לֹא ־ יָדַ֣עְתִּי אֶשְׁמָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "הֲסִיר֣וֹתִי מִסֵּ֣בֶל שִׁכְמ֑וֹ כַּ֝פָּ֗יו מִדּ֥וּד תַּעֲבֹֽרְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "בַּצָּרָ֥ה קָרָ֗אתָ וָאֲחַ֫לְּצֶ֥ךָּ אֶ֭עֶנְךָ בְּסֵ֣תֶר רַ֑עַם אֶבְחָֽנְךָ֨ עַל ־ מֵ֖י מְרִיבָ֣ה סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 9,
      "referenceLabel": "Psalms 81:9",
      "text": "שְׁמַ֣ע עַ֭מִּי וְאָעִ֣ידָה בָּ֑ךְ יִ֝שְׂרָאֵ֗ל אִם ־ תִּֽשְׁמַֽע ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 10,
      "referenceLabel": "Psalms 81:10",
      "text": "לֹֽא ־ יִהְיֶ֣ה בְ֭ךָ אֵ֣ל זָ֑ר וְלֹ֥א תִ֝שְׁתַּחֲוֶ֗ה לְאֵ֣ל נֵכָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 11,
      "referenceLabel": "Psalms 81:11",
      "text": "אָנֹכִ֨י ׀ יְה֘וָ֤ה אֱלֹהֶ֗יךָ הַֽ֭מַּעַלְךָ מֵאֶ֣רֶץ מִצְרָ֑יִם הַרְחֶב ־ פִּ֝֗יךָ וַאֲמַלְאֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 12,
      "referenceLabel": "Psalms 81:12",
      "text": "וְלֹא ־ שָׁמַ֣ע עַמִּ֣י לְקוֹלִ֑י וְ֝יִשְׂרָאֵ֗ל לֹא ־ אָ֥בָה לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 13,
      "referenceLabel": "Psalms 81:13",
      "text": "וָֽ֭אֲשַׁלְּחֵהוּ בִּשְׁרִיר֣וּת לִבָּ֑ם יֵ֝לְכ֗וּ בְּֽמוֹעֲצוֹתֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 14,
      "referenceLabel": "Psalms 81:14",
      "text": "ל֗וּ עַ֭מִּי שֹׁמֵ֣עַֽ לִ֑י יִ֝שְׂרָאֵ֗ל בִּדְרָכַ֥י יְהַלֵּֽכוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 15,
      "referenceLabel": "Psalms 81:15",
      "text": "כִּ֭מְעַט אוֹיְבֵיהֶ֣ם אַכְנִ֑יעַ וְעַ֥ל צָ֝רֵיהֶ֗ם אָשִׁ֥יב יָדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 16,
      "referenceLabel": "Psalms 81:16",
      "text": "מְשַׂנְאֵ֣י יְ֭הוָה יְכַֽחֲשׁוּ ־ ל֑וֹ וִיהִ֖י עִתָּ֣ם לְעוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.81.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 17,
      "referenceLabel": "Psalms 81:17",
      "text": "וַֽ֭יַּאֲכִילֵהוּ מֵחֵ֣לֶב חִטָּ֑ה וּ֝מִצּ֗וּר דְּבַ֣שׁ אַשְׂבִּיעֶֽךָ ׃",
      "paragraphStart": false
    }
  ]
}
