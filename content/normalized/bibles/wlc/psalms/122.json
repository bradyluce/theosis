{
  "chapter": {
    "id": "wlc:psalms.122",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 122,
    "referenceLabel": "Psalms 122",
    "summary": "Source text for Psalms 122 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.122.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "שִׁ֥יר הַֽמַּעֲל֗וֹת לְדָ֫וִ֥ד שָׂ֭מַחְתִּי בְּאֹמְרִ֣ים לִ֑י בֵּ֖ית יְהוָ֣ה נֵלֵֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.122.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "עֹ֭מְדוֹת הָי֣וּ רַגְלֵ֑ינוּ בִּ֝שְׁעָרַ֗יִךְ יְרוּשָׁלִָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "יְרוּשָׁלִַ֥ם הַבְּנוּיָ֑ה כְּ֝עִ֗יר שֶׁחֻבְּרָה ־ לָּ֥הּ יַחְדָּֽו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "שֶׁשָּׁ֨ם עָל֪וּ שְׁבָטִ֡ים שִׁבְטֵי ־ יָ֭הּ עֵד֣וּת לְיִשְׂרָאֵ֑ל לְ֝הֹד֗וֹת לְשֵׁ֣ם יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 5,
      "referenceLabel": "Psalms 122:5",
      "text": "כִּ֤י שָׁ֨מָּה ׀ יָשְׁב֣וּ כִסְא֣וֹת לְמִשְׁפָּ֑ט כִּ֝סְא֗וֹת לְבֵ֣ית דָּוִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 6,
      "referenceLabel": "Psalms 122:6",
      "text": "שַׁ֭אֲלוּ שְׁל֣וֹם יְרוּשָׁלִָ֑ם יִ֝שְׁלָ֗יוּ אֹהֲבָֽיִךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 7,
      "referenceLabel": "Psalms 122:7",
      "text": "יְהִֽי ־ שָׁל֥וֹם בְּחֵילֵ֑ךְ שַׁ֝לְוָ֗ה בְּאַרְמְנוֹתָֽיִךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 8,
      "referenceLabel": "Psalms 122:8",
      "text": "לְ֭מַעַן אַחַ֣י וְרֵעָ֑י אֲדַבְּרָה ־ נָּ֖א שָׁל֣וֹם בָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.122.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 9,
      "referenceLabel": "Psalms 122:9",
      "text": "לְ֭מַעַן בֵּית ־ יְהוָ֣ה אֱלֹהֵ֑ינוּ אֲבַקְשָׁ֖ה ט֣וֹב לָֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
