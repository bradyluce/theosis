{
  "chapter": {
    "id": "wlc:psalms.85",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.85.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "לַמְנַצֵּ֬חַ ׀ לִבְנֵי ־ קֹ֬רַח מִזְמֽוֹר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.85.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "רָצִ֣יתָ יְהוָ֣ה אַרְצֶ֑ךָ שַׁ֝֗בְתָּ שבות יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "נָ֭שָׂאתָ עֲוֺ֣ן עַמֶּ֑ךָ כִּסִּ֖יתָ כָל ־ חַטָּאתָ֣ם סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "אָסַ֥פְתָּ כָל ־ עֶבְרָתֶ֑ךָ הֱ֝שִׁיב֗וֹתָ מֵחֲר֥וֹן אַפֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "שׁ֭וּבֵנוּ אֱלֹהֵ֣י יִשְׁעֵ֑נוּ וְהָפֵ֖ר כַּֽעַסְךָ֣ עִמָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "הַלְעוֹלָ֥ם תֶּֽאֱנַף ־ בָּ֑נוּ תִּמְשֹׁ֥ךְ אַ֝פְּךָ֗ לְדֹ֣ר וָדֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "הֲֽלֹא ־ אַ֭תָּה תָּשׁ֣וּב תְּחַיֵּ֑נוּ וְ֝עַמְּךָ֗ יִשְׂמְחוּ ־ בָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "הַרְאֵ֣נוּ יְהוָ֣ה חַסְדֶּ֑ךָ וְ֝יֶשְׁעֲךָ֗ תִּתֶּן ־ לָֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "אֶשְׁמְעָ֗ה מַה ־ יְדַבֵּר֮ הָאֵ֪ל ׀ יְה֫וָ֥ה כִּ֤י ׀ יְדַבֵּ֬ר שָׁל֗וֹם אֶל ־ עַמּ֥וֹ וְאֶל ־ חֲסִידָ֑יו וְֽאַל ־ יָשׁ֥וּבוּ לְכִסְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "אַ֤ךְ ׀ קָר֣וֹב לִירֵאָ֣יו יִשְׁע֑וֹ לִשְׁכֹּ֖ן כָּב֣וֹד בְּאַרְצֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "חֶֽסֶד ־ וֶאֱמֶ֥ת נִפְגָּ֑שׁוּ צֶ֖דֶק וְשָׁל֣וֹם נָשָֽׁקוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "אֱ֭מֶת מֵאֶ֣רֶץ תִּצְמָ֑ח וְ֝צֶ֗דֶק מִשָּׁמַ֥יִם נִשְׁקָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "גַּם ־ יְ֭הוָה יִתֵּ֣ן הַטּ֑וֹב וְ֝אַרְצֵ֗נוּ תִּתֵּ֥ן יְבוּלָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.85.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 14,
      "referenceLabel": "Psalms 85:14",
      "text": "צֶ֭דֶק לְפָנָ֣יו יְהַלֵּ֑ךְ וְיָשֵׂ֖ם לְדֶ֣רֶךְ פְּעָמָֽיו ׃",
      "paragraphStart": false
    }
  ]
}
