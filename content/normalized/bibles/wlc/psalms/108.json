{
  "chapter": {
    "id": "wlc:psalms.108",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.108.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "שִׁ֖יר מִזְמ֣וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.108.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "נָכ֣וֹן לִבִּ֣י אֱלֹהִ֑ים אָשִׁ֥ירָה וַ֝אֲזַמְּרָ֗ה אַף ־ כְּבוֹדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "ע֭וּרָֽה הַנֵּ֥בֶל וְכִנּ֗וֹר אָעִ֥ירָה שָּֽׁחַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "אוֹדְךָ֖ בָעַמִּ֥ים ׀ יְהוָ֑ה וַ֝אֲזַמֶּרְךָ֗ בַּל ־ אֻמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "כִּֽי ־ גָד֣וֹל מֵֽעַל ־ שָׁמַ֣יִם חַסְדֶּ֑ךָ וְֽעַד ־ שְׁחָקִ֥ים אֲמִתֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "ר֣וּמָה עַל ־ שָׁמַ֣יִם אֱלֹהִ֑ים וְעַ֖ל כָּל ־ הָאָ֣רֶץ כְּבוֹדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "לְ֭מַעַן יֵחָלְצ֣וּן יְדִידֶ֑יךָ הוֹשִׁ֖יעָה יְמִֽינְךָ֣ וַעֲנֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "אֱלֹהִ֤ים ׀ דִּבֶּ֥ר בְּקָדְשׁ֗וֹ אֶעְלֹ֥זָה אֲחַלְּקָ֥ה שְׁכֶ֑ם וְעֵ֖מֶק סֻכּ֣וֹת אֲמַדֵּֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "לִ֤י גִלְעָ֨ד ׀ לִ֤י מְנַשֶּׁ֗ה וְ֭אֶפְרַיִם מָע֣וֹז רֹאשִׁ֑י יְ֝הוּדָ֗ה מְחֹקְקִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "מוֹאָ֤ב ׀ סִ֬יר רַחְצִ֗י עַל ־ אֱ֭דוֹם אַשְׁלִ֣יךְ נַעֲלִ֑י עֲלֵֽי ־ פְ֝לֶ֗שֶׁת אֶתְרוֹעָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "מִ֣י יֹ֭בִלֵנִי עִ֣יר מִבְצָ֑ר מִ֖י נָחַ֣נִי עַד ־ אֱדֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "הֲלֹֽא ־ אֱלֹהִ֥ים זְנַחְתָּ֑נוּ וְֽלֹא ־ תֵצֵ֥א אֱ֝לֹהִ֗ים בְּצִבְאֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "הָֽבָה ־ לָּ֣נוּ עֶזְרָ֣ת מִצָּ֑ר וְ֝שָׁ֗וְא תְּשׁוּעַ֥ת אָדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.108.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 14,
      "referenceLabel": "Psalms 108:14",
      "text": "בֵּֽאלֹהִ֥ים נַעֲשֶׂה ־ חָ֑יִל וְ֝ה֗וּא יָב֥וּס צָרֵֽינוּ ׃",
      "paragraphStart": false
    }
  ]
}
