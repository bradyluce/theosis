{
  "chapter": {
    "id": "wlc:psalms.82",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.82.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "מִזְמ֗וֹר לְאָ֫סָ֥ף אֱֽלֹהִ֗ים נִצָּ֥ב בַּעֲדַת ־ אֵ֑ל בְּקֶ֖רֶב אֱלֹהִ֣ים יִשְׁפֹּֽט ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.82.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "עַד ־ מָתַ֥י תִּשְׁפְּטוּ ־ עָ֑וֶל וּפְנֵ֥י רְ֝שָׁעִ֗ים תִּשְׂאוּ ־ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.82.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "שִׁפְטוּ ־ דַ֥ל וְיָת֑וֹם עָנִ֖י וָרָ֣שׁ הַצְדִּֽיקוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.82.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "פַּלְּטוּ ־ דַ֥ל וְאֶבְי֑וֹן מִיַּ֖ד רְשָׁעִ֣ים הַצִּֽילוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.82.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "לֹ֤א יָֽדְע֨וּ ׀ וְלֹ֥א יָבִ֗ינוּ בַּחֲשֵׁכָ֥ה יִתְהַלָּ֑כוּ יִ֝מּ֗וֹטוּ כָּל ־ מ֥וֹסְדֵי אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.82.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "אֲֽנִי ־ אָ֭מַרְתִּי אֱלֹהִ֣ים אַתֶּ֑ם וּבְנֵ֖י עֶלְי֣וֹן כֻּלְּכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.82.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "אָ֭כֵן כְּאָדָ֣ם תְּמוּת֑וּן וּכְאַחַ֖ד הַשָּׂרִ֣ים תִּפֹּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.82.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "קוּמָ֣ה אֱ֭לֹהִים שָׁפְטָ֣ה הָאָ֑רֶץ כִּֽי ־ אַתָּ֥ה תִ֝נְחַ֗ל בְּכָל ־ הַגּוֹיִֽם ׃",
      "paragraphStart": false
    }
  ]
}
