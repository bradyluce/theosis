{
  "chapter": {
    "id": "wlc:psalms.130",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 130,
    "referenceLabel": "Psalms 130",
    "summary": "Source text for Psalms 130 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.130.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 1,
      "referenceLabel": "Psalms 130:1",
      "text": "שִׁ֥יר הַֽמַּעֲל֑וֹת מִמַּעֲמַקִּ֖ים קְרָאתִ֣יךָ יְהוָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.130.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 2,
      "referenceLabel": "Psalms 130:2",
      "text": "אֲדֹנָי֮ שִׁמְעָ֪ה בְק֫וֹלִ֥י תִּהְיֶ֣ינָה אָ֭זְנֶיךָ קַשֻּׁב֑וֹת לְ֝ק֗וֹל תַּחֲנוּנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.130.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 3,
      "referenceLabel": "Psalms 130:3",
      "text": "אִם ־ עֲוֺנ֥וֹת תִּשְׁמָר ־ יָ֑הּ אֲ֝דֹנָ֗י מִ֣י יַעֲמֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.130.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 4,
      "referenceLabel": "Psalms 130:4",
      "text": "כִּֽי ־ עִמְּךָ֥ הַסְּלִיחָ֑ה לְ֝מַ֗עַן תִּוָּרֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.130.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 5,
      "referenceLabel": "Psalms 130:5",
      "text": "קִוִּ֣יתִי יְ֭הוָה קִוְּתָ֣ה נַפְשִׁ֑י וְֽלִדְבָר֥וֹ הוֹחָֽלְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.130.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 6,
      "referenceLabel": "Psalms 130:6",
      "text": "נַפְשִׁ֥י לַֽאדֹנָ֑י מִשֹּׁמְרִ֥ים לַ֝בֹּ֗קֶר שֹׁמְרִ֥ים לַבֹּֽקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.130.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 7,
      "referenceLabel": "Psalms 130:7",
      "text": "יַחֵ֥ל יִשְׂרָאֵ֗ל אֶל ־ יְה֫וָה כִּֽי ־ עִם ־ יְהוָ֥ה הַחֶ֑סֶד וְהַרְבֵּ֖ה עִמּ֣וֹ פְדֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.130.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 8,
      "referenceLabel": "Psalms 130:8",
      "text": "וְ֭הוּא יִפְדֶּ֣ה אֶת ־ יִשְׂרָאֵ֑ל מִ֝כֹּ֗ל עֲוֺנֹתָֽיו ׃",
      "paragraphStart": false
    }
  ]
}
