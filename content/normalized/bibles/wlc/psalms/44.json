{
  "chapter": {
    "id": "wlc:psalms.44",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 44,
    "referenceLabel": "Psalms 44",
    "summary": "Source text for Psalms 44 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.44.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 1,
      "referenceLabel": "Psalms 44:1",
      "text": "לַמְנַצֵּ֬חַ לִבְנֵי ־ קֹ֬רַח מַשְׂכִּֽיל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.44.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 2,
      "referenceLabel": "Psalms 44:2",
      "text": "אֱלֹהִ֤ים ׀ בְּאָזְנֵ֬ינוּ שָׁמַ֗עְנוּ אֲבוֹתֵ֥ינוּ סִפְּרוּ ־ לָ֑נוּ פֹּ֥עַל פָּעַ֥לְתָּ בִֽ֝ימֵיהֶ֗ם בִּ֣ימֵי קֶֽדֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 3,
      "referenceLabel": "Psalms 44:3",
      "text": "אַתָּ֤ה ׀ יָדְךָ֡ גּוֹיִ֣ם ה֭וֹרַשְׁתָּ וַתִּטָּעֵ֑ם תָּרַ֥ע לְ֝אֻמִּ֗ים וַֽתְּשַׁלְּחֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 4,
      "referenceLabel": "Psalms 44:4",
      "text": "כִּ֤י לֹ֪א בְחַרְבָּ֡ם יָ֥רְשׁוּ אָ֗רֶץ וּזְרוֹעָם֮ לֹא ־ הוֹשִׁ֪יעָ֫ה לָּ֥מוֹ כִּֽי ־ יְמִֽינְךָ֣ וּ֭זְרוֹעֲךָ וְא֥וֹר פָּנֶ֗יךָ כִּ֣י רְצִיתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 5,
      "referenceLabel": "Psalms 44:5",
      "text": "אַתָּה ־ ה֣וּא מַלְכִּ֣י אֱלֹהִ֑ים צַ֝וֵּ֗ה יְשׁוּע֥וֹת יַעֲקֹֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 6,
      "referenceLabel": "Psalms 44:6",
      "text": "בְּ֭ךָ צָרֵ֣ינוּ נְנַגֵּ֑חַ בְּ֝שִׁמְךָ֗ נָב֥וּס קָמֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 7,
      "referenceLabel": "Psalms 44:7",
      "text": "כִּ֤י לֹ֣א בְקַשְׁתִּ֣י אֶבְטָ֑ח וְ֝חַרְבִּ֗י לֹ֣א תוֹשִׁיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 8,
      "referenceLabel": "Psalms 44:8",
      "text": "כִּ֣י ה֭וֹשַׁעְתָּנוּ מִצָּרֵ֑ינוּ וּמְשַׂנְאֵ֥ינוּ הֱבִישֽׁוֹתָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 9,
      "referenceLabel": "Psalms 44:9",
      "text": "בֵּֽ֭אלֹהִים הִלַּלְ֣נוּ כָל ־ הַיּ֑וֹם וְשִׁמְךָ֓ ׀ לְעוֹלָ֖ם נוֹדֶ֣ה סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 10,
      "referenceLabel": "Psalms 44:10",
      "text": "אַף ־ זָ֭נַחְתָּ וַתַּכְלִימֵ֑נוּ וְלֹא ־ תֵ֝צֵ֗א בְּצִבְאוֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 11,
      "referenceLabel": "Psalms 44:11",
      "text": "תְּשִׁיבֵ֣נוּ אָ֭חוֹר מִנִּי ־ צָ֑ר וּ֝מְשַׂנְאֵ֗ינוּ שָׁ֣סוּ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 12,
      "referenceLabel": "Psalms 44:12",
      "text": "תִּ֭תְּנֵנוּ כְּצֹ֣אן מַאֲכָ֑ל וּ֝בַגּוֹיִ֗ם זֵרִיתָֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 13,
      "referenceLabel": "Psalms 44:13",
      "text": "תִּמְכֹּֽר ־ עַמְּךָ֥ בְלֹא ־ ה֑וֹן וְלֹ֥א ־ רִ֝בִּ֗יתָ בִּמְחִירֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 14,
      "referenceLabel": "Psalms 44:14",
      "text": "תְּשִׂימֵ֣נוּ חֶ֭רְפָּה לִשְׁכֵנֵ֑ינוּ לַ֥עַג וָ֝קֶ֗לֶס לִסְבִיבוֹתֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 15,
      "referenceLabel": "Psalms 44:15",
      "text": "תְּשִׂימֵ֣נוּ מָ֭שָׁל בַּגּוֹיִ֑ם מְנֽוֹד ־ רֹ֝֗אשׁ בַּל ־ אֻמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 16,
      "referenceLabel": "Psalms 44:16",
      "text": "כָּל ־ הַ֭יּוֹם כְּלִמָּתִ֣י נֶגְדִּ֑י וּבֹ֖שֶׁת פָּנַ֣י כִּסָּֽתְנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 17,
      "referenceLabel": "Psalms 44:17",
      "text": "מִ֭קּוֹל מְחָרֵ֣ף וּמְגַדֵּ֑ף מִפְּנֵ֥י א֝וֹיֵ֗ב וּמִתְנַקֵּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 18,
      "referenceLabel": "Psalms 44:18",
      "text": "כָּל ־ זֹ֣את בָּ֭אַתְנוּ וְלֹ֣א שְׁכַחֲנ֑וּךָ וְלֹֽא ־ שִׁ֝קַּ֗רְנוּ בִּבְרִיתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 19,
      "referenceLabel": "Psalms 44:19",
      "text": "לֹא ־ נָס֣וֹג אָח֣וֹר לִבֵּ֑נוּ וַתֵּ֥ט אֲשֻׁרֵ֗ינוּ מִנִּ֥י אָרְחֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 20,
      "referenceLabel": "Psalms 44:20",
      "text": "כִּ֣י דִ֭כִּיתָנוּ בִּמְק֣וֹם תַּנִּ֑ים וַתְּכַ֖ס עָלֵ֣ינוּ בְצַלְמָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 21,
      "referenceLabel": "Psalms 44:21",
      "text": "אִם ־ שָׁ֭כַחְנוּ שֵׁ֣ם אֱלֹהֵ֑ינוּ וַנִּפְרֹ֥שׂ כַּ֝פֵּ֗ינוּ לְאֵ֣ל זָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 22,
      "referenceLabel": "Psalms 44:22",
      "text": "הֲלֹ֣א אֱ֭לֹהִים יַֽחֲקָר ־ זֹ֑את כִּֽי ־ ה֥וּא יֹ֝דֵ֗עַ תַּעֲלֻמ֥וֹת לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 23,
      "referenceLabel": "Psalms 44:23",
      "text": "כִּֽי ־ עָ֭לֶיךָ הֹרַ֣גְנוּ כָל ־ הַיּ֑וֹם נֶ֝חְשַׁ֗בְנוּ כְּצֹ֣אן טִבְחָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 24,
      "referenceLabel": "Psalms 44:24",
      "text": "ע֤וּרָה ׀ לָ֖מָּה תִישַׁ֥ן ׀ אֲדֹנָ֑י הָ֝קִ֗יצָה אַל ־ תִּזְנַ֥ח לָנֶֽצַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 25,
      "referenceLabel": "Psalms 44:25",
      "text": "לָֽמָּה ־ פָנֶ֥יךָ תַסְתִּ֑יר תִּשְׁכַּ֖ח עָנְיֵ֣נוּ וְֽלַחֲצֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 26,
      "referenceLabel": "Psalms 44:26",
      "text": "כִּ֤י שָׁ֣חָה לֶעָפָ֣ר נַפְשֵׁ֑נוּ דָּבְקָ֖ה לָאָ֣רֶץ בִּטְנֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.44.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 27,
      "referenceLabel": "Psalms 44:27",
      "text": "ק֭וּמָֽה עֶזְרָ֣תָה לָּ֑נוּ וּ֝פְדֵ֗נוּ לְמַ֣עַן חַסְדֶּֽךָ ׃",
      "paragraphStart": false
    }
  ]
}
