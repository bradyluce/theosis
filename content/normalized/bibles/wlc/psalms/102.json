{
  "chapter": {
    "id": "wlc:psalms.102",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.102.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "תְּ֭פִלָּה לְעָנִ֣י כִֽי ־ יַעֲטֹ֑ף וְלִפְנֵ֥י יְ֝הוָ֗ה יִשְׁפֹּ֥ךְ שִׂיחֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.102.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "יְ֭הוָה שִׁמְעָ֣ה תְפִלָּתִ֑י וְ֝שַׁוְעָתִ֗י אֵלֶ֥יךָ תָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "אַל ־ תַּסְתֵּ֬ר פָּנֶ֨יךָ ׀ מִמֶּנִּי֮ בְּי֪וֹם צַ֫ר לִ֥י הַטֵּֽה ־ אֵלַ֥י אָזְנֶ֑ךָ בְּי֥וֹם אֶ֝קְרָ֗א מַהֵ֥ר עֲנֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "כִּֽי ־ כָל֣וּ בְעָשָׁ֣ן יָמָ֑י וְ֝עַצְמוֹתַ֗י כְּמוֹ ־ קֵ֥ד נִחָֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "הוּכָּֽה ־ כָ֭עֵשֶׂב וַיִּבַ֣שׁ לִבִּ֑י כִּֽי ־ שָׁ֝כַ֗חְתִּי מֵאֲכֹ֥ל לַחְמִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "מִקּ֥וֹל אַנְחָתִ֑י דָּבְקָ֥ה עַ֝צְמִ֗י לִבְשָׂרִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "דָּ֭מִיתִי לִקְאַ֣ת מִדְבָּ֑ר הָ֝יִ֗יתִי כְּכ֣וֹס חֳרָבֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "שָׁקַ֥דְתִּי וָאֶֽהְיֶ֑ה כְּ֝צִפּ֗וֹר בּוֹדֵ֥ד עַל ־ גָּֽג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "כָּל ־ הַ֭יּוֹם חֵרְפ֣וּנִי אוֹיְבָ֑י מְ֝הוֹלָלַ֗י בִּ֣י נִשְׁבָּֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "כִּי ־ אֵ֭פֶר כַּלֶּ֣חֶם אָכָ֑לְתִּי וְ֝שִׁקֻּוַ֗י בִּבְכִ֥י מָסָֽכְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "מִפְּנֵֽי ־ זַֽעַמְךָ֥ וְקִצְפֶּ֑ךָ כִּ֥י נְ֝שָׂאתַ֗נִי וַתַּשְׁלִיכֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "יָ֭מַי כְּצֵ֣ל נָט֑וּי וַ֝אֲנִ֗י כָּעֵ֥שֶׂב אִיבָֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "וְאַתָּ֣ה יְ֭הוָה לְעוֹלָ֣ם תֵּשֵׁ֑ב וְ֝זִכְרְךָ֗ לְדֹ֣ר וָדֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.14",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "אַתָּ֣ה תָ֭קוּם תְּרַחֵ֣ם צִיּ֑וֹן כִּי ־ עֵ֥ת לְ֝חֶֽנְנָ֗הּ כִּי ־ בָ֥א מוֹעֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.15",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "כִּֽי ־ רָצ֣וּ עֲ֭בָדֶיךָ אֶת ־ אֲבָנֶ֑יהָ וְֽאֶת ־ עֲפָרָ֥הּ יְחֹנֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.16",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "וְיִֽירְא֣וּ ג֭וֹיִם אֶת ־ שֵׁ֣ם יְהוָ֑ה וְֽכָל ־ מַלְכֵ֥י הָ֝אָ֗רֶץ אֶת ־ כְּבוֹדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.17",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "כִּֽי ־ בָנָ֣ה יְהוָ֣ה צִיּ֑וֹן נִ֝רְאָ֗ה בִּכְבוֹדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.18",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "פָּ֭נָה אֶל ־ תְּפִלַּ֣ת הָעַרְעָ֑ר וְלֹֽא ־ בָ֝זָ֗ה אֶת ־ תְּפִלָּתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.19",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "תִּכָּ֣תֶב זֹ֭את לְד֣וֹר אַחֲר֑וֹן וְעַ֥ם נִ֝בְרָ֗א יְהַלֶּל ־ יָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.20",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "כִּֽי ־ הִ֭שְׁקִיף מִמְּר֣וֹם קָדְשׁ֑וֹ יְ֝הוָ֗ה מִשָּׁמַ֤יִם ׀ אֶל ־ אֶ֬רֶץ הִבִּֽיט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.21",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "לִ֭שְׁמֹעַ אֶנְקַ֣ת אָסִ֑יר לְ֝פַתֵּ֗חַ בְּנֵ֣י תְמוּתָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.22",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "לְסַפֵּ֣ר בְּ֭צִיּוֹן שֵׁ֣ם יְהוָ֑ה וּ֝תְהִלָּת֗וֹ בִּירוּשָׁלִָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.23",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 23,
      "referenceLabel": "Psalms 102:23",
      "text": "בְּהִקָּבֵ֣ץ עַמִּ֣ים יַחְדָּ֑ו וּ֝מַמְלָכ֗וֹת לַעֲבֹ֥ד אֶת ־ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.24",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 24,
      "referenceLabel": "Psalms 102:24",
      "text": "עִנָּ֖ה בַדֶּ֥רֶךְ כחו קִצַּ֥ר יָמָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.25",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 25,
      "referenceLabel": "Psalms 102:25",
      "text": "אֹמַ֗ר אֵלִ֗י אַֽל ־ תַּ֭עֲלֵנִי בַּחֲצִ֣י יָמָ֑י בְּד֖וֹר דּוֹרִ֣ים שְׁנוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.26",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 26,
      "referenceLabel": "Psalms 102:26",
      "text": "לְ֭פָנִים הָאָ֣רֶץ יָסַ֑דְתָּ וּֽמַעֲשֵׂ֖ה יָדֶ֣יךָ שָׁמָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.27",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 27,
      "referenceLabel": "Psalms 102:27",
      "text": "הֵ֤מָּה ׀ יֹאבֵדוּ֮ וְאַתָּ֪ה תַ֫עֲמֹ֥ד וְ֭כֻלָּם כַּבֶּ֣גֶד יִבְל֑וּ כַּלְּב֖וּשׁ תַּחֲלִיפֵ֣ם וְֽיַחֲלֹֽפוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.28",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 28,
      "referenceLabel": "Psalms 102:28",
      "text": "וְאַתָּה ־ ה֑וּא וּ֝שְׁנוֹתֶ֗יךָ לֹ֣א יִתָּֽמּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.102.29",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 29,
      "referenceLabel": "Psalms 102:29",
      "text": "בְּנֵֽי ־ עֲבָדֶ֥יךָ יִשְׁכּ֑וֹנוּ וְ֝זַרְעָ֗ם לְפָנֶ֥יךָ יִכּֽוֹן ׃",
      "paragraphStart": false
    }
  ]
}
