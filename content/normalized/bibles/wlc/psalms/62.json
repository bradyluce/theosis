{
  "chapter": {
    "id": "wlc:psalms.62",
    "translationId": "wlc",
    "bookSlug": "psalms",
    "chapterNumber": 62,
    "referenceLabel": "Psalms 62",
    "summary": "Source text for Psalms 62 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:psalms.62.1",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 1,
      "referenceLabel": "Psalms 62:1",
      "text": "לַמְנַצֵּ֥חַ עַֽל ־ יְדוּת֗וּן מִזְמ֥וֹר לְדָוִֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:psalms.62.2",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 2,
      "referenceLabel": "Psalms 62:2",
      "text": "אַ֣ךְ אֶל ־ אֱ֭לֹהִים דּֽוּמִיָּ֣ה נַפְשִׁ֑י מִ֝מֶּ֗נּוּ יְשׁוּעָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.3",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 3,
      "referenceLabel": "Psalms 62:3",
      "text": "אַךְ ־ ה֣וּא צ֭וּרִי וִֽישׁוּעָתִ֑י מִ֝שְׂגַּבִּ֗י לֹא ־ אֶמּ֥וֹט רַבָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.4",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 4,
      "referenceLabel": "Psalms 62:4",
      "text": "עַד ־ אָ֤נָה ׀ תְּהֽוֹתְת֣וּ עַל אִישׁ֮ תְּרָצְּח֪וּ כֻ֫לְּכֶ֥ם כְּקִ֥יר נָט֑וּי גָּ֝דֵ֗ר הַדְּחוּיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.5",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 5,
      "referenceLabel": "Psalms 62:5",
      "text": "אַ֤ךְ מִשְּׂאֵת֨וֹ ׀ יָעֲצ֣וּ לְהַדִּיחַ֮ יִרְצ֪וּ כָ֫זָ֥ב בְּפִ֥יו יְבָרֵ֑כוּ וּ֝בְקִרְבָּ֗ם יְקַלְלוּ ־ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.6",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 6,
      "referenceLabel": "Psalms 62:6",
      "text": "אַ֣ךְ לֵ֭אלֹהִים דּ֣וֹמִּי נַפְשִׁ֑י כִּי ־ מִ֝מֶּ֗נּוּ תִּקְוָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.7",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 7,
      "referenceLabel": "Psalms 62:7",
      "text": "אַךְ ־ ה֣וּא צ֭וּרִי וִֽישׁוּעָתִ֑י מִ֝שְׂגַּבִּ֗י לֹ֣א אֶמּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.8",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 8,
      "referenceLabel": "Psalms 62:8",
      "text": "עַל ־ אֱ֭לֹהִים יִשְׁעִ֣י וּכְבוֹדִ֑י צוּר ־ עֻזִּ֥י מַ֝חְסִ֗י בֵּֽאלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.9",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 9,
      "referenceLabel": "Psalms 62:9",
      "text": "בִּטְח֘וּ ב֤וֹ בְכָל ־ עֵ֨ת ׀ עָ֗ם שִׁפְכֽוּ ־ לְפָנָ֥יו לְבַבְכֶ֑ם אֱלֹהִ֖ים מַחֲסֶה ־ לָּ֣נוּ סֶֽלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.10",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 10,
      "referenceLabel": "Psalms 62:10",
      "text": "אַ֤ךְ ׀ הֶ֥בֶל בְּנֵֽי ־ אָדָם֮ כָּזָ֪ב בְּנֵ֫י אִ֥ישׁ בְּמֹאזְנַ֥יִם לַעֲל֑וֹת הֵ֝֗מָּה מֵהֶ֥בֶל יָֽחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.11",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 11,
      "referenceLabel": "Psalms 62:11",
      "text": "אַל ־ תִּבְטְח֣וּ בְעֹשֶׁק֮ וּבְגָזֵ֪ל אַל ־ תֶּ֫הְבָּ֥לוּ חַ֤יִל ׀ כִּֽי ־ יָנ֑וּב אַל ־ תָּשִׁ֥יתוּ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.12",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 12,
      "referenceLabel": "Psalms 62:12",
      "text": "אַחַ֤ת ׀ דִּבֶּ֬ר אֱלֹהִ֗ים שְׁתַּֽיִם ־ ז֥וּ שָׁמָ֑עְתִּי כִּ֥י עֹ֝֗ז לֵאלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:psalms.62.13",
      "translationId": "wlc",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 13,
      "referenceLabel": "Psalms 62:13",
      "text": "וּלְךָֽ ־ אֲדֹנָ֥י חָ֑סֶד כִּֽי ־ אַתָּ֨ה תְשַׁלֵּ֖ם לְאִ֣ישׁ כְּֽמַעֲשֵֽׂהוּ ׃",
      "paragraphStart": false
    }
  ]
}
