      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Joshua 15:26",
      "text": "אֲמָ֥ם וּשְׁמַ֖ע וּמוֹלָדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.27",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Joshua 15:27",
      "text": "וַחֲצַ֥ר גַּדָּ֛ה וְחֶשְׁמ֖וֹן וּבֵ֥ית פָּֽלֶט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.28",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Joshua 15:28",
      "text": "וַחֲצַ֥ר שׁוּעָ֛ל וּבְאֵ֥ר שֶׁ֖בַע וּבִזְיוֹתְיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.29",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Joshua 15:29",
      "text": "בַּעֲלָ֥ה וְעִיִּ֖ים וָעָֽצֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.30",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Joshua 15:30",
      "text": "וְאֶלְתּוֹלַ֥ד וּכְסִ֖יל וְחָרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.31",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Joshua 15:31",
      "text": "וְצִֽקְלַ֥ג וּמַדְמַנָּ֖ה וְסַנְסַנָּֽה ׃",
      "paragraphStart": false
