    "bookSlug": "joshua",
    "chapterNumber": 15,
    "referenceLabel": "Joshua 15",
    "summary": "Source text for Joshua 15 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:joshua.15.1",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Joshua 15:1",
      "text": "וַיְהִ֣י הַגּוֹרָ֗ל לְמַטֵּ֛ה בְּנֵ֥י יְהוּדָ֖ה לְמִשְׁפְּחֹתָ֑ם אֶל ־ גְּב֨וּל אֱד֧וֹם מִדְבַּר ־ צִ֛ן נֶ֖גְבָּה מִקְצֵ֥ה תֵימָֽן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:joshua.15.2",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Joshua 15:2",
      "text": "וַיְהִ֤י לָהֶם֙ גְּב֣וּל נֶ֔גֶב מִקְצֵ֖ה יָ֣ם הַמֶּ֑לַח מִן ־ הַלָּשֹׁ֖ן הַפֹּנֶ֥ה נֶֽגְבָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.3",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Joshua 15:3",
      "text": "וְ֠יָצָא אֶל ־ מִנֶּ֜גֶב לְמַעֲלֵ֤ה עַקְרַבִּים֙ וְעָ֣בַר צִ֔נָה וְעָלָ֥ה מִנֶּ֖גֶב לְקָדֵ֣שׁ בַּרְנֵ֑עַ וְעָבַ֤ר חֶצְרוֹן֙ וְעָלָ֣ה אַדָּ֔רָה וְנָסַ֖ב הַקַּרְקָֽעָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.4",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Joshua 15:4",
      "text": "וְעָבַ֣ר עַצְמ֗וֹנָה וְיָצָא֙ נַ֣חַל מִצְרַ֔יִם והיה תֹּצְא֥וֹת הַגְּב֖וּל יָ֑מָּה זֶה ־ יִהְיֶ֥ה לָכֶ֖ם גְּב֥וּל נֶֽגֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.5",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Joshua 15:5",
      "text": "וּגְב֥וּל קֵ֨דְמָה֙ יָ֣ם הַמֶּ֔לַח עַד ־ קְצֵ֖ה הַיַּרְדֵּ֑ן וּגְב֞וּל לִפְאַ֤ת צָפ֨וֹנָה֙ מִלְּשׁ֣וֹן הַיָּ֔ם מִקְצֵ֖ה הַיַּרְדֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.6",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Joshua 15:6",
      "text": "וְעָלָ֤ה הַגְּבוּל֙ בֵּ֣ית חָגְלָ֔ה וְעָבַ֕ר מִצְּפ֖וֹן לְבֵ֣ית הָעֲרָבָ֑ה וְעָלָ֣ה הַגְּב֔וּל אֶ֥בֶן בֹּ֖הַן בֶּן ־ רְאוּבֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.7",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Joshua 15:7",
      "text": "וְעָלָ֨ה הַגְּב֥וּל ׀ דְּבִרָה֮ מֵעֵ֣מֶק עָכוֹר֒ וְצָפ֜וֹנָה פֹּנֶ֣ה אֶל ־ הַגִּלְגָּ֗ל אֲשֶׁר ־ נֹ֨כַח֙ לְמַעֲלֵ֣ה אֲדֻמִּ֔ים אֲשֶׁ֥ר מִנֶּ֖גֶב לַנָּ֑חַל וְעָבַ֤ר הַגְּבוּל֙ אֶל ־ מֵי ־ עֵ֣ין שֶׁ֔מֶשׁ וְהָי֥וּ תֹצְאֹתָ֖יו אֶל ־ עֵ֥ין רֹגֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.8",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Joshua 15:8",
      "text": "וְעָלָ֨ה הַגְּב֜וּל גֵּ֣י בֶן ־ הִנֹּ֗ם אֶל ־ כֶּ֤תֶף הַיְבוּסִי֙ מִנֶּ֔גֶב הִ֖יא יְרֽוּשָׁלִָ֑ם וְעָלָ֨ה הַגְּב֜וּל אֶל ־ רֹ֣אשׁ הָהָ֗ר אֲ֠שֶׁר עַל ־ פְּנֵ֤י גֵֽי ־ הִנֹּם֙ יָ֔מָּה אֲשֶׁ֛ר בִּקְצֵ֥ה עֵֽמֶק ־ רְפָאִ֖ים צָפֹֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.9",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Joshua 15:9",
      "text": "וְתָאַ֨ר הַגְּב֜וּל מֵרֹ֣אשׁ הָהָ֗ר אֶל ־ מַעְיַן֙ מֵ֣י נֶפְתּ֔וֹחַ וְיָצָ֖א אֶל ־ עָרֵ֣י הַר ־ עֶפְר֑וֹן וְתָאַ֤ר הַגְּבוּל֙ בַּעֲלָ֔ה הִ֖יא קִרְיַ֥ת יְעָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.10",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Joshua 15:10",
      "text": "וְנָסַב֩ הַגְּב֨וּל מִבַּעֲלָ֥ה יָ֨מָּה֙ אֶל ־ הַ֣ר שֵׂעִ֔יר וְעָבַ֕ר אֶל ־ כֶּ֧תֶף הַר ־ יְעָרִ֛ים מִצָּפ֖וֹנָה הִ֣יא כְסָל֑וֹן וְיָרַ֥ד בֵּֽית ־ שֶׁ֖מֶשׁ וְעָבַ֥ר תִּמְנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.11",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Joshua 15:11",
      "text": "וְיָצָ֨א הַגְּב֜וּל אֶל ־ כֶּ֣תֶף עֶקְרוֹן֮ צָפוֹנָה֒ וְתָאַ֤ר הַגְּבוּל֙ שִׁכְּר֔וֹנָה וְעָבַ֥ר הַר ־ הַֽבַּעֲלָ֖ה וְיָצָ֣א יַבְנְאֵ֑ל וְהָי֛וּ תֹּצְא֥וֹת הַגְּב֖וּל יָֽמָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.12",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Joshua 15:12",
      "text": "וּגְב֣וּל יָ֔ם הַיָּ֥מָּה הַגָּד֖וֹל וּגְב֑וּל זֶ֠ה גְּב֧וּל בְּנֵֽי ־ יְהוּדָ֛ה סָבִ֖יב לְמִשְׁפְּחֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.13",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Joshua 15:13",
      "text": "וּלְכָלֵ֣ב בֶּן ־ יְפֻנֶּ֗ה נָ֤תַן חֵ֨לֶק֙ בְּת֣וֹךְ בְּנֵֽי ־ יְהוּדָ֔ה אֶל ־ פִּ֥י יְהוָ֖ה לִֽיהוֹשֻׁ֑עַ אֶת ־ קִרְיַ֥ת אַרְבַּ֛ע אֲבִ֥י הָעֲנָ֖ק הִ֥יא חֶבְרֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.14",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Joshua 15:14",
      "text": "וַיֹּ֤רֶשׁ מִשָּׁם֙ כָּלֵ֔ב אֶת ־ שְׁלוֹשָׁ֖ה בְּנֵ֣י הָעֲנָ֑ק אֶת ־ שֵׁשַׁ֤י וְאֶת ־ אֲחִימַן֙ וְאֶת ־ תַּלְמַ֔י יְלִידֵ֖י הָעֲנָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.15",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Joshua 15:15",
      "text": "וַיַּ֣עַל מִשָּׁ֔ם אֶל ־ יֹשְׁבֵ֖י דְּבִ֑ר וְשֵׁם ־ דְּבִ֥ר לְפָנִ֖ים קִרְיַת ־ סֵֽפֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.16",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Joshua 15:16",
      "text": "וַיֹּ֣אמֶר כָּלֵ֔ב אֲשֶׁר ־ יַכֶּ֥ה אֶת ־ קִרְיַת ־ סֵ֖פֶר וּלְכָדָ֑הּ וְנָתַ֥תִּי ל֛וֹ אֶת ־ עַכְסָ֥ה בִתִּ֖י לְאִשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.17",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Joshua 15:17",
      "text": "וַֽיִּלְכְּדָ֛הּ עָתְנִיאֵ֥ל בֶּן ־ קְנַ֖ז אֲחִ֣י כָלֵ֑ב וַיִּתֶּן ־ ל֛וֹ אֶת ־ עַכְסָ֥ה בִתּ֖וֹ לְאִשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.18",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Joshua 15:18",
      "text": "וַיְהִ֣י בְּבוֹאָ֗הּ וַתְּסִיתֵ֨הוּ֙ לִשְׁא֤וֹל מֵֽאֵת ־ אָבִ֨יהָ֙ שָׂדֶ֔ה וַתִּצְנַ֖ח מֵעַ֣ל הַחֲמ֑וֹר וַיֹּֽאמֶר ־ לָ֥הּ כָּלֵ֖ב מַה ־ לָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.19",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Joshua 15:19",
      "text": "וַתֹּ֜אמֶר תְּנָה ־ לִּ֣י בְרָכָ֗ה כִּ֣י אֶ֤רֶץ הַנֶּ֨גֶב֙ נְתַתָּ֔נִי וְנָתַתָּ֥ה לִ֖י גֻּלֹּ֣ת מָ֑יִם וַיִּתֶּן ־ לָ֗הּ אֵ֚ת גֻּלֹּ֣ת עִלִּיּ֔וֹת וְאֵ֖ת גֻּלֹּ֥ת תַּחְתִּיּֽוֹת ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.20",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Joshua 15:20",
      "text": "זֹ֗את נַחֲלַ֛ת מַטֵּ֥ה בְנֵי ־ יְהוּדָ֖ה לְמִשְׁפְּחֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.21",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Joshua 15:21",
      "text": "וַיִּֽהְי֣וּ הֶעָרִ֗ים מִקְצֵה֙ לְמַטֵּ֣ה בְנֵֽי ־ יְהוּדָ֔ה אֶל ־ גְּב֥וּל אֱד֖וֹם בַּנֶּ֑גְבָּה קַבְצְאֵ֥ל וְעֵ֖דֶר וְיָגֽוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.22",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Joshua 15:22",
      "text": "וְקִינָ֥ה וְדִֽימוֹנָ֖ה וְעַדְעָדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.23",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Joshua 15:23",
      "text": "וְקֶ֥דֶשׁ וְחָצ֖וֹר וְיִתְנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.24",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Joshua 15:24",
      "text": "זִ֥יף וָטֶ֖לֶם וּבְעָלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.15.25",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Joshua 15:25",
      "text": "וְחָצ֤וֹר ׀ חֲדַתָּה֙ וּקְרִיּ֔וֹת חֶצְר֖וֹן הִ֥יא חָצֽוֹר ׃",
      "paragraphStart": false
    },
    {
