{
  "chapter": {
    "id": "wlc:joshua.19",
    "translationId": "wlc",
    "bookSlug": "joshua",
    "chapterNumber": 19,
    "referenceLabel": "Joshua 19",
    "summary": "Source text for Joshua 19 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:joshua.19.1",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Joshua 19:1",
      "text": "וַיֵּצֵ֞א הַגּוֹרָ֤ל הַשֵּׁנִי֙ לְשִׁמְע֔וֹן לְמַטֵּ֥ה בְנֵֽי ־ שִׁמְע֖וֹן לְמִשְׁפְּחוֹתָ֑ם וַֽיְהִי֙ נַֽחֲלָתָ֔ם בְּת֖וֹךְ נַחֲלַ֥ת בְּנֵֽי ־ יְהוּדָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:joshua.19.2",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Joshua 19:2",
      "text": "וַיְהִ֥י לָהֶ֖ם בְּנַֽחֲלָתָ֑ם בְּאֵֽר ־ שֶׁ֥בַע וְשֶׁ֖בַע וּמוֹלָדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.3",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Joshua 19:3",
      "text": "וַחֲצַ֥ר שׁוּעָ֛ל וּבָלָ֖ה וָעָֽצֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.4",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Joshua 19:4",
      "text": "וְאֶלְתּוֹלַ֥ד וּבְת֖וּל וְחָרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.5",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Joshua 19:5",
      "text": "וְצִֽקְלַ֥ג וּבֵית ־ הַמַּרְכָּב֖וֹת וַחֲצַ֥ר סוּסָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.6",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Joshua 19:6",
      "text": "וּבֵ֥ית לְבָא֖וֹת וְשָֽׁרוּחֶ֑ן עָרִ֥ים שְׁלֹשׁ ־ עֶשְׂרֵ֖ה וְחַצְרֵיהֶֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.7",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Joshua 19:7",
      "text": "עַ֥יִן ׀ רִמּ֖וֹן וָעֶ֣תֶר וְעָשָׁ֑ן עָרִ֥ים אַרְבַּ֖ע וְחַצְרֵיהֶֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.8",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Joshua 19:8",
      "text": "וְכָל ־ הַֽחֲצֵרִ֗ים אֲשֶׁ֤ר סְבִיבוֹת֙ הֶֽעָרִ֣ים הָאֵ֔לֶּה עַד ־ בַּֽעֲלַ֥ת בְּאֵ֖ר רָ֣אמַת נֶ֑גֶב זֹ֗את נַחֲלַ֛ת מַטֵּ֥ה בְנֵֽי ־ שִׁמְע֖וֹן לְמִשְׁפְּחֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.9",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Joshua 19:9",
      "text": "מֵחֶ֨בֶל֙ בְּנֵ֣י יְהוּדָ֔ה נַחֲלַ֖ת בְּנֵ֣י שִׁמְע֑וֹן כִּֽי ־ הָיָ֞ה חֵ֤לֶק בְּנֵֽי ־ יְהוּדָה֙ רַ֣ב מֵהֶ֔ם וַיִּנְחֲל֥וּ בְנֵֽי ־ שִׁמְע֖וֹן בְּת֥וֹךְ נַחֲלָתָֽם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.10",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Joshua 19:10",
      "text": "וַיַּ֨עַל֙ הַגּוֹרָ֣ל הַשְּׁלִישִׁ֔י לִבְנֵ֥י זְבוּלֻ֖ן לְמִשְׁפְּחֹתָ֑ם וַיְהִ֛י גְּב֥וּל נַחֲלָתָ֖ם עַד ־ שָׂרִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.11",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Joshua 19:11",
      "text": "וְעָלָ֨ה גְבוּלָ֧ם ׀ לַיָּ֛מָּה וּמַרְעֲלָ֖ה וּפָגַ֣ע בְּדַבָּ֑שֶׁת וּפָגַע֙ אֶל ־ הַנַּ֔חַל אֲשֶׁ֖ר עַל ־ פְּנֵ֥י יָקְנְעָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.12",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Joshua 19:12",
      "text": "וְשָׁ֣ב מִשָּׂרִ֗יד קֵ֚דְמָה מִזְרַ֣ח הַשֶּׁ֔מֶשׁ עַל ־ גְּב֥וּל כִּסְלֹ֖ת תָּבֹ֑ר וְיָצָ֥א אֶל ־ הַדָּֽבְרַ֖ת וְעָלָ֥ה יָפִֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.13",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Joshua 19:13",
      "text": "וּמִשָּׁ֤ם עָבַר֙ קֵ֣דְמָה מִזְרָ֔חָה גִּתָּ֥ה חֵ֖פֶר עִתָּ֣ה קָצִ֑ין וְיָצָ֛א רִמּ֥וֹן הַמְּתֹאָ֖ר הַנֵּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.14",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Joshua 19:14",
      "text": "וְנָסַ֤ב אֹתוֹ֙ הַגְּב֔וּל מִצְּפ֖וֹן חַנָּתֹ֑ן וְהָיוּ֙ תֹּֽצְאֹתָ֔יו גֵּ֖י יִפְתַּח ־ אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.15",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Joshua 19:15",
      "text": "וְקַטָּ֤ת וְנַֽהֲלָל֙ וְשִׁמְר֔וֹן וְיִדְאֲלָ֖ה וּבֵ֣ית לָ֑חֶם עָרִ֥ים שְׁתֵּים ־ עֶשְׂרֵ֖ה וְחַצְרֵיהֶֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.16",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Joshua 19:16",
      "text": "זֹ֛את נַחֲלַ֥ת בְּנֵֽי ־ זְבוּלֻ֖ן לְמִשְׁפְּחוֹתָ֑ם הֶֽעָרִ֥ים הָאֵ֖לֶּה וְחַצְרֵיהֶֽן ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.17",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Joshua 19:17",
      "text": "לְיִ֨שָּׂשכָ֔ר יָצָ֖א הַגּוֹרָ֣ל הָֽרְבִיעִ֑י לִבְנֵ֥י יִשָּׂשכָ֖ר לְמִשְׁפְּחוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.18",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Joshua 19:18",
      "text": "וַיְהִ֖י גְּבוּלָ֑ם יִזְרְעֶ֥אלָה וְהַכְּסוּלֹ֖ת וְשׁוּנֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.19",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Joshua 19:19",
      "text": "וַחֲפָרַ֥יִם וְשִׁיאֹ֖ן וַאֲנָחֲרַֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.20",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Joshua 19:20",
      "text": "וְהָֽרַבִּ֥ית וְקִשְׁי֖וֹן וָאָֽבֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.21",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Joshua 19:21",
      "text": "וְרֶ֧מֶת וְעֵין ־ גַּנִּ֛ים וְעֵ֥ין חַדָּ֖ה וּבֵ֥ית פַּצֵּֽץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.22",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Joshua 19:22",
      "text": "וּפָגַע֩ הַגְּב֨וּל בְּתָב֤וֹר ושחצומה וּבֵ֣ית שֶׁ֔מֶשׁ וְהָי֛וּ תֹּצְא֥וֹת גְּבוּלָ֖ם הַיַּרְדֵּ֑ן עָרִ֥ים שֵׁשׁ ־ עֶשְׂרֵ֖ה וְחַצְרֵיהֶֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.23",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Joshua 19:23",
      "text": "זֹ֗את נַחֲלַ֛ת מַטֵּ֥ה בְנֵֽי ־ יִשָּׂשכָ֖ר לְמִשְׁפְּחֹתָ֑ם הֶעָרִ֖ים וְחַצְרֵיהֶֽן ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.24",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Joshua 19:24",
      "text": "וַיֵּצֵא֙ הַגּוֹרָ֣ל הַֽחֲמִישִׁ֔י לְמַטֵּ֥ה בְנֵֽי ־ אָשֵׁ֖ר לְמִשְׁפְּחוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.25",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Joshua 19:25",
      "text": "וַיְהִ֖י גְּבוּלָ֑ם חֶלְקַ֥ת וַחֲלִ֖י וָבֶ֥טֶן וְאַכְשָֽׁף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.26",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Joshua 19:26",
      "text": "וְאַֽלַמֶּ֥לֶךְ וְעַמְעָ֖ד וּמִשְׁאָ֑ל וּפָגַ֤ע בְּכַרְמֶל֙ הַיָּ֔מָּה וּבְשִׁיח֖וֹר לִבְנָֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.27",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Joshua 19:27",
      "text": "וְשָׁ֨ב מִזְרַ֣ח הַשֶּׁמֶשׁ֮ בֵּ֣ית דָּגֹן֒ וּפָגַ֣ע בִּ֠זְבֻלוּן וּבְגֵ֨י יִפְתַּח ־ אֵ֥ל צָפ֛וֹנָה בֵּ֥ית הָעֵ֖מֶק וּנְעִיאֵ֑ל וְיָצָ֥א אֶל ־ כָּב֖וּל מִשְּׂמֹֽאל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.28",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Joshua 19:28",
      "text": "וְעֶבְרֹ֥ן וּרְחֹ֖ב וְחַמּ֣וֹן וְקָנָ֑ה עַ֖ד צִיד֥וֹן רַבָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.29",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Joshua 19:29",
      "text": "וְשָׁ֤ב הַגְּבוּל֙ הָֽרָמָ֔ה וְעַד ־ עִ֖יר מִבְצַר ־ צֹ֑ר וְשָׁ֤ב הַגְּבוּל֙ חֹסָ֔ה ויהיו תֹצְאֹתָ֛יו הַיָּ֖מָּה מֵחֶ֥בֶל אַכְזִֽיבָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.30",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Joshua 19:30",
      "text": "וְעֻמָ֥ה וַאֲפֵ֖ק וּרְחֹ֑ב עָרִ֛ים עֶשְׂרִ֥ים וּשְׁתַּ֖יִם וְחַצְרֵיהֶֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.31",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Joshua 19:31",
      "text": "זֹ֗את נַחֲלַ֛ת מַטֵּ֥ה בְנֵֽי ־ אָשֵׁ֖ר לְמִשְׁפְּחֹתָ֑ם הֶעָרִ֥ים הָאֵ֖לֶּה וְחַצְרֵיהֶֽן ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.32",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Joshua 19:32",
      "text": "לִבְנֵ֣י נַפְתָּלִ֔י יָצָ֖א הַגּוֹרָ֣ל הַשִּׁשִּׁ֑י לִבְנֵ֥י נַפְתָּלִ֖י לְמִשְׁפְּחֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.33",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Joshua 19:33",
      "text": "וַיְהִ֣י גְבוּלָ֗ם מֵחֵ֨לֶף מֵֽאֵל֜וֹן בְּצַעֲנַנִּ֗ים וַאֲדָמִ֥י הַנֶּ֛קֶב וְיַבְנְאֵ֖ל עַד ־ לַקּ֑וּם וַיְהִ֥י תֹצְאֹתָ֖יו הַיַּרְדֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.34",
      "translationId": "wlc",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Joshua 19:34",
      "text": "וְשָׁ֨ב הַגְּב֥וּל יָ֨מָּה֙ אַזְנ֣וֹת תָּב֔וֹר וְיָצָ֥א מִשָּׁ֖ם חוּקֹ֑קָה וּפָגַ֨ע בִּזְבֻל֜וּן מִנֶּ֗גֶב וּבְאָשֵׁר֙ פָּגַ֣ע מִיָּ֔ם וּבִ֣יהוּדָ֔ה הַיַּרְדֵּ֖ן מִזְרַ֥ח הַשָּֽׁמֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:joshua.19.35",
