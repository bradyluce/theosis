{
  "chapter": {
    "id": "wlc:ecclesiastes.10",
    "translationId": "wlc",
    "bookSlug": "ecclesiastes",
    "chapterNumber": 10,
    "referenceLabel": "Ecclesiastes 10",
    "summary": "Source text for Ecclesiastes 10 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:ecclesiastes.10.1",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Ecclesiastes 10:1",
      "text": "זְב֣וּבֵי מָ֔וֶת יַבְאִ֥ישׁ יַבִּ֖יעַ שֶׁ֣מֶן רוֹקֵ֑חַ יָקָ֛ר מֵחָכְמָ֥ה מִכָּב֖וֹד סִכְל֥וּת מְעָֽט ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:ecclesiastes.10.2",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Ecclesiastes 10:2",
      "text": "לֵ֤ב חָכָם֙ לִֽימִינ֔וֹ וְלֵ֥ב כְּסִ֖יל לִשְׂמֹאלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.3",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Ecclesiastes 10:3",
      "text": "וְגַם ־ בַּדֶּ֛רֶךְ כשהסכל הֹלֵ֖ךְ לִבּ֣וֹ חָסֵ֑ר וְאָמַ֥ר לַכֹּ֖ל סָכָ֥ל הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.4",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Ecclesiastes 10:4",
      "text": "אִם ־ ר֤וּחַ הַמּוֹשֵׁל֙ תַּעֲלֶ֣ה עָלֶ֔יךָ מְקוֹמְךָ֖ אַל ־ תַּנַּ֑ח כִּ֣י מַרְפֵּ֔א יַנִּ֖יחַ חֲטָאִ֥ים גְּדוֹלִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.5",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Ecclesiastes 10:5",
      "text": "יֵ֣שׁ רָעָ֔ה רָאִ֖יתִי תַּ֣חַת הַשָּׁ֑מֶשׁ כִּשְׁגָגָ֕ה שֶׁיֹּצָ֖א מִלִּפְנֵ֥י הַשַּׁלִּֽיט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.6",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Ecclesiastes 10:6",
      "text": "נִתַּ֣ן הַסֶּ֔כֶל בַּמְּרוֹמִ֖ים רַבִּ֑ים וַעֲשִׁירִ֖ים בַּשֵּׁ֥פֶל יֵשֵֽׁבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.7",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Ecclesiastes 10:7",
      "text": "רָאִ֥יתִי עֲבָדִ֖ים עַל ־ סוּסִ֑ים וְשָׂרִ֛ים הֹלְכִ֥ים כַּעֲבָדִ֖ים עַל ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.8",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Ecclesiastes 10:8",
      "text": "חֹפֵ֥ר גּוּמָּ֖ץ בּ֣וֹ יִפּ֑וֹל וּפֹרֵ֥ץ גָּדֵ֖ר יִשְּׁכֶ֥נּוּ נָחָֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.9",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Ecclesiastes 10:9",
      "text": "מַסִּ֣יעַ אֲבָנִ֔ים יֵעָצֵ֖ב בָּהֶ֑ם בּוֹקֵ֥עַ עֵצִ֖ים יִסָּ֥כֶן בָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.10",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Ecclesiastes 10:10",
      "text": "אִם ־ קֵהָ֣ה הַבַּרְזֶ֗ל וְהוּא֙ לֹא ־ פָנִ֣ים קִלְקַ֔ל וַחֲיָלִ֖ים יְגַבֵּ֑ר וְיִתְר֥וֹן הכשיר חָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.11",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Ecclesiastes 10:11",
      "text": "אִם ־ יִשֹּׁ֥ךְ הַנָּחָ֖שׁ בְּלוֹא ־ לָ֑חַשׁ וְאֵ֣ין יִתְר֔וֹן לְבַ֖עַל הַלָּשֽׁוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.12",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Ecclesiastes 10:12",
      "text": "דִּבְרֵ֥י פִי ־ חָכָ֖ם חֵ֑ן וְשִׂפְת֥וֹת כְּסִ֖יל תְּבַלְּעֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.13",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Ecclesiastes 10:13",
      "text": "תְּחִלַּ֥ת דִּבְרֵי ־ פִ֖יהוּ סִכְל֑וּת וְאַחֲרִ֣ית פִּ֔יהוּ הוֹלֵל֖וּת רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.14",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Ecclesiastes 10:14",
      "text": "וְהַסָּכָ֖ל יַרְבֶּ֣ה דְבָרִ֑ים לֹא ־ יֵדַ֤ע הָאָדָם֙ מַה ־ שֶׁיִּֽהְיֶ֔ה וַאֲשֶׁ֤ר יִֽהְיֶה֙ מֵֽאַחֲרָ֔יו מִ֖י יַגִּ֥יד לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.15",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Ecclesiastes 10:15",
      "text": "עֲמַ֥ל הַכְּסִילִ֖ים תְּיַגְּעֶ֑נּוּ אֲשֶׁ֥ר לֹֽא ־ יָדַ֖ע לָלֶ֥כֶת אֶל ־ עִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.16",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Ecclesiastes 10:16",
      "text": "אִֽי ־ לָ֣ךְ אֶ֔רֶץ שֶׁמַּלְכֵּ֖ךְ נָ֑עַר וְשָׂרַ֖יִךְ בַּבֹּ֥קֶר יֹאכֵֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.17",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Ecclesiastes 10:17",
      "text": "אַשְׁרֵ֣יךְ אֶ֔רֶץ שֶׁמַּלְכֵּ֖ךְ בֶּן ־ חוֹרִ֑ים וְשָׂרַ֨יִךְ֙ בָּעֵ֣ת יֹאכֵ֔לוּ בִּגְבוּרָ֖ה וְלֹ֥א בַשְּׁתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.18",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Ecclesiastes 10:18",
      "text": "בַּעֲצַלְתַּ֖יִם יִמַּ֣ךְ הַמְּקָרֶ֑ה וּבְשִׁפְל֥וּת יָדַ֖יִם יִדְלֹ֥ף הַבָּֽיִת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.19",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Ecclesiastes 10:19",
      "text": "לִשְׂחוֹק֙ עֹשִׂ֣ים לֶ֔חֶם וְיַ֖יִן יְשַׂמַּ֣ח חַיִּ֑ים וְהַכֶּ֖סֶף יַעֲנֶ֥ה אֶת ־ הַכֹּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:ecclesiastes.10.20",
      "translationId": "wlc",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Ecclesiastes 10:20",
      "text": "גַּ֣ם בְּמַדָּֽעֲךָ֗ מֶ֚לֶךְ אַל ־ תְּקַלֵּ֔ל וּבְחַדְרֵי֙ מִשְׁכָּ֣בְךָ֔ אַל ־ תְּקַלֵּ֖ל עָשִׁ֑יר כִּ֣י ע֤וֹף הַשָּׁמַ֨יִם֙ יוֹלִ֣יךְ אֶת ־ הַקּ֔וֹל וּבַ֥עַל הכנפים יַגֵּ֥יד דָּבָֽר ׃",
      "paragraphStart": false
    }
  ]
}
