{
  "chapter": {
    "id": "wlc:numbers.25",
    "translationId": "wlc",
    "bookSlug": "numbers",
    "chapterNumber": 25,
    "referenceLabel": "Numbers 25",
    "summary": "Source text for Numbers 25 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:numbers.25.1",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Numbers 25:1",
      "text": "וַיֵּ֥שֶׁב יִשְׂרָאֵ֖ל בַּשִּׁטִּ֑ים וַיָּ֣חֶל הָעָ֔ם לִזְנ֖וֹת אֶל ־ בְּנ֥וֹת מוֹאָֽב ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:numbers.25.2",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Numbers 25:2",
      "text": "וַתִּקְרֶ֣אןָ לָעָ֔ם לְזִבְחֵ֖י אֱלֹהֵיהֶ֑ן וַיֹּ֣אכַל הָעָ֔ם וַיִּֽשְׁתַּחֲוּ֖וּ לֵֽאלֹהֵיהֶֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.3",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Numbers 25:3",
      "text": "וַיִּצָּ֥מֶד יִשְׂרָאֵ֖ל לְבַ֣עַל פְּע֑וֹר וַיִּֽחַר ־ אַ֥ף יְהוָ֖ה בְּיִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.4",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Numbers 25:4",
      "text": "וַיֹּ֨אמֶר יְהוָ֜ה אֶל ־ מֹשֶׁ֗ה קַ֚ח אֶת ־ כָּל ־ רָאשֵׁ֣י הָעָ֔ם וְהוֹקַ֥ע אוֹתָ֛ם לַיהוָ֖ה נֶ֣גֶד הַשָּׁ֑מֶשׁ וְיָשֹׁ֛ב חֲר֥וֹן אַף ־ יְהוָ֖ה מִיִּשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.5",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Numbers 25:5",
      "text": "וַיֹּ֣אמֶר מֹשֶׁ֔ה אֶל ־ שֹׁפְטֵ֖י יִשְׂרָאֵ֑ל הִרְגוּ֙ אִ֣ישׁ אֲנָשָׁ֔יו הַנִּצְמָדִ֖ים לְבַ֥עַל פְּעֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.6",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Numbers 25:6",
      "text": "וְהִנֵּ֡ה אִישׁ֩ מִבְּנֵ֨י יִשְׂרָאֵ֜ל בָּ֗א וַיַּקְרֵ֤ב אֶל ־ אֶחָיו֙ אֶת ־ הַמִּדְיָנִ֔ית לְעֵינֵ֣י מֹשֶׁ֔ה וּלְעֵינֵ֖י כָּל ־ עֲדַ֣ת בְּנֵי ־ יִשְׂרָאֵ֑ל וְהֵ֣מָּה בֹכִ֔ים פֶּ֖תַח אֹ֥הֶל מוֹעֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.7",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Numbers 25:7",
      "text": "וַיַּ֗רְא פִּֽינְחָס֙ בֶּן ־ אֶלְעָזָ֔ר בֶּֽן ־ אַהֲרֹ֖ן הַכֹּהֵ֑ן וַיָּ֨קָם֙ מִתּ֣וֹךְ הָֽעֵדָ֔ה וַיִּקַּ֥ח רֹ֖מַח בְּיָדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.8",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Numbers 25:8",
      "text": "וַ֠יָּבֹא אַחַ֨ר אִֽישׁ ־ יִשְׂרָאֵ֜ל אֶל ־ הַקֻּבָּ֗ה וַיִּדְקֹר֙ אֶת ־ שְׁנֵיהֶ֔ם אֵ֚ת אִ֣ישׁ יִשְׂרָאֵ֔ל וְאֶת ־ הָאִשָּׁ֖ה אֶל ־ קֳבָתָ֑הּ וַתֵּֽעָצַר֙ הַמַּגֵּפָ֔ה מֵעַ֖ל בְּנֵ֥י יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.9",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Numbers 25:9",
      "text": "וַיִּהְי֕וּ הַמֵּתִ֖ים בַּמַּגֵּפָ֑ה אַרְבָּעָ֥ה וְעֶשְׂרִ֖ים אָֽלֶף ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.10",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Numbers 25:10",
      "text": "וַיְדַבֵּ֥ר יְהוָ֖ה אֶל ־ מֹשֶׁ֥ה לֵּאמֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.11",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Numbers 25:11",
      "text": "פִּֽינְחָ֨ס בֶּן ־ אֶלְעָזָ֜ר בֶּן ־ אַהֲרֹ֣ן הַכֹּהֵ֗ן הֵשִׁ֤יב אֶת ־ חֲמָתִי֙ מֵעַ֣ל בְּנֵֽי ־ יִשְׂרָאֵ֔ל בְּקַנְא֥וֹ אֶת ־ קִנְאָתִ֖י בְּתוֹכָ֑ם וְלֹא ־ כִלִּ֥יתִי אֶת ־ בְּנֵֽי ־ יִשְׂרָאֵ֖ל בְּקִנְאָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.12",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Numbers 25:12",
      "text": "לָכֵ֖ן אֱמֹ֑ר הִנְנִ֨י נֹתֵ֥ן ל֛וֹ אֶת ־ בְּרִיתִ֖י שָׁלֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.13",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Numbers 25:13",
      "text": "וְהָ֤יְתָה לּוֹ֙ וּלְזַרְע֣וֹ אַחֲרָ֔יו בְּרִ֖ית כְּהֻנַּ֣ת עוֹלָ֑ם תַּ֗חַת אֲשֶׁ֤ר קִנֵּא֙ לֵֽאלֹהָ֔יו וַיְכַפֵּ֖ר עַל ־ בְּנֵ֥י יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.14",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Numbers 25:14",
      "text": "וְשֵׁם֩ אִ֨ישׁ יִשְׂרָאֵ֜ל הַמֻּכֶּ֗ה אֲשֶׁ֤ר הֻכָּה֙ אֶת ־ הַמִּדְיָנִ֔ית זִמְרִ֖י בֶּן ־ סָל֑וּא נְשִׂ֥יא בֵֽית ־ אָ֖ב לַשִּׁמְעֹנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.15",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Numbers 25:15",
      "text": "וְשֵׁ֨ם הָֽאִשָּׁ֧ה הַמֻּכָּ֛ה הַמִּדְיָנִ֖ית כָּזְבִּ֣י בַת ־ צ֑וּר רֹ֣אשׁ אֻמּ֥וֹת בֵּֽית ־ אָ֛ב בְּמִדְיָ֖ן הֽוּא ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.16",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Numbers 25:16",
      "text": "וַיְדַבֵּ֥ר יְהוָ֖ה אֶל ־ מֹשֶׁ֥ה לֵּאמֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.17",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Numbers 25:17",
      "text": "צָר֖וֹר אֶת ־ הַמִּדְיָנִ֑ים וְהִכִּיתֶ֖ם אוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.18",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Numbers 25:18",
      "text": "כִּ֣י צֹרְרִ֥ים הֵם֙ לָכֶ֔ם בְּנִכְלֵיהֶ֛ם אֲשֶׁר ־ נִכְּל֥וּ לָכֶ֖ם עַל ־ דְּבַר ־ פְּע֑וֹר וְעַל ־ דְּבַ֞ר כָּזְבִּ֨י בַת ־ נְשִׂ֤יא מִדְיָן֙ אֲחֹתָ֔ם הַמֻּכָּ֥ה בְיוֹם ־ הַמַּגֵּפָ֖ה עַל ־ דְּבַר ־ פְּעֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.25.19",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Numbers 25:19",
      "text": "וַיְהִ֖י אַחֲרֵ֣י הַמַּגֵּפָ֑ה פ",
      "paragraphStart": false
    }
  ]
}
