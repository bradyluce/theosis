  },
  "verses": [
    {
      "id": "wlc:numbers.33.1",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Numbers 33:1",
      "text": "אֵ֜לֶּה מַסְעֵ֣י בְנֵֽי ־ יִשְׂרָאֵ֗ל אֲשֶׁ֥ר יָצְא֛וּ מֵאֶ֥רֶץ מִצְרַ֖יִם לְצִבְאֹתָ֑ם בְּיַד ־ מֹשֶׁ֖ה וְאַהֲרֹֽן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:numbers.33.2",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Numbers 33:2",
      "text": "וַיִּכְתֹּ֨ב מֹשֶׁ֜ה אֶת ־ מוֹצָאֵיהֶ֛ם לְמַסְעֵיהֶ֖ם עַל ־ פִּ֣י יְהוָ֑ה וְאֵ֥לֶּה מַסְעֵיהֶ֖ם לְמוֹצָאֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.3",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Numbers 33:3",
      "text": "וַיִּסְע֤וּ מֵֽרַעְמְסֵס֙ בַּחֹ֣דֶשׁ הָֽרִאשׁ֔וֹן בַּחֲמִשָּׁ֥ה עָשָׂ֛ר י֖וֹם לַחֹ֣דֶשׁ הָרִאשׁ֑וֹן מִֽמָּחֳרַ֣ת הַפֶּ֗סַח יָצְא֤וּ בְנֵֽי ־ יִשְׂרָאֵל֙ בְּיָ֣ד רָמָ֔ה לְעֵינֵ֖י כָּל ־ מִצְרָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.4",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Numbers 33:4",
      "text": "וּמִצְרַ֣יִם מְקַבְּרִ֗ים אֵת֩ אֲשֶׁ֨ר הִכָּ֧ה יְהוָ֛ה בָּהֶ֖ם כָּל ־ בְּכ֑וֹר וּבֵאלֹ֣הֵיהֶ֔ם עָשָׂ֥ה יְהוָ֖ה שְׁפָטִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.5",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Numbers 33:5",
      "text": "וַיִּסְע֥וּ בְנֵֽי ־ יִשְׂרָאֵ֖ל מֵרַעְמְסֵ֑ס וַֽיַּחֲנ֖וּ בְּסֻכֹּֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.6",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Numbers 33:6",
      "text": "וַיִּסְע֖וּ מִסֻּכֹּ֑ת וַיַּחֲנ֣וּ בְאֵתָ֔ם אֲשֶׁ֖ר בִּקְצֵ֥ה הַמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.7",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Numbers 33:7",
      "text": "וַיִּסְעוּ֙ מֵֽאֵתָ֔ם וַיָּ֨שָׁב֙ עַל ־ פִּ֣י הַחִירֹ֔ת אֲשֶׁ֥ר עַל ־ פְּנֵ֖י בַּ֣עַל צְפ֑וֹן וַֽיַּחֲנ֖וּ לִפְנֵ֥י מִגְדֹּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.8",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Numbers 33:8",
      "text": "וַיִּסְעוּ֙ מִפְּנֵ֣י הַֽחִירֹ֔ת וַיַּֽעַבְר֥וּ בְתוֹךְ ־ הַיָּ֖ם הַמִּדְבָּ֑רָה וַיֵּ֨לְכ֜וּ דֶּ֣רֶךְ שְׁלֹ֤שֶׁת יָמִים֙ בְּמִדְבַּ֣ר אֵתָ֔ם וַֽיַּחֲנ֖וּ בְּמָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.9",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Numbers 33:9",
      "text": "וַיִּסְעוּ֙ מִמָּרָ֔ה וַיָּבֹ֖אוּ אֵילִ֑מָה וּ֠בְאֵילִם שְׁתֵּ֣ים עֶשְׂרֵ֞ה עֵינֹ֥ת מַ֛יִם וְשִׁבְעִ֥ים תְּמָרִ֖ים וַיַּחֲנוּ ־ שָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.10",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Numbers 33:10",
      "text": "וַיִּסְע֖וּ מֵאֵילִ֑ם וַֽיַּחֲנ֖וּ עַל ־ יַם ־ סֽוּף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.11",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Numbers 33:11",
      "text": "וַיִּסְע֖וּ מִיַּם ־ ס֑וּף וַֽיַּחֲנ֖וּ בְּמִדְבַּר ־ סִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.12",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Numbers 33:12",
      "text": "וַיִּסְע֖וּ מִמִּדְבַּר ־ סִ֑ין וַֽיַּחֲנ֖וּ בְּדָפְקָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.13",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Numbers 33:13",
      "text": "וַיִּסְע֖וּ מִדָּפְקָ֑ה וַֽיַּחֲנ֖וּ בְּאָלֽוּשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.14",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Numbers 33:14",
      "text": "וַיִּסְע֖וּ מֵאָל֑וּשׁ וַֽיַּחֲנוּ֙ בִּרְפִידִ֔ם וְלֹא ־ הָ֨יָה שָׁ֥ם מַ֛יִם לָעָ֖ם לִשְׁתּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.33.15",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Numbers 33:15",
      "text": "וַיִּסְע֖וּ מֵרְפִידִ֑ם וַֽיַּחֲנ֖וּ בְּמִדְבַּ֥ר סִינָֽי ׃",
