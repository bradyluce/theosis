      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 39,
      "referenceLabel": "Numbers 33:39",
      "text": "וְאַהֲרֹ֔ן בֶּן ־ שָׁלֹ֧שׁ וְעֶשְׂרִ֛ים וּמְאַ֖ת שָׁנָ֑ה בְּמֹת֖וֹ בְּהֹ֥ר הָהָֽר ׃ ס",
      "paragraphStart": false
    },
    {
