{
  "chapter": {
    "id": "wlc:numbers.34",
    "translationId": "wlc",
    "bookSlug": "numbers",
    "chapterNumber": 34,
    "referenceLabel": "Numbers 34",
    "summary": "Source text for Numbers 34 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:numbers.34.1",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Numbers 34:1",
      "text": "וַיְדַבֵּ֥ר יְהוָ֖ה אֶל ־ מֹשֶׁ֥ה לֵּאמֹֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:numbers.34.2",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Numbers 34:2",
      "text": "צַ֞ו אֶת ־ בְּנֵ֤י יִשְׂרָאֵל֙ וְאָמַרְתָּ֣ אֲלֵהֶ֔ם כִּֽי ־ אַתֶּ֥ם בָּאִ֖ים אֶל ־ הָאָ֣רֶץ כְּנָ֑עַן זֹ֣את הָאָ֗רֶץ אֲשֶׁ֨ר תִּפֹּ֤ל לָכֶם֙ בְּֽנַחֲלָ֔ה אֶ֥רֶץ כְּנַ֖עַן לִגְבֻלֹתֶֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.3",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Numbers 34:3",
      "text": "וְהָיָ֨ה לָכֶ֧ם פְּאַת ־ נֶ֛גֶב מִמִּדְבַּר ־ צִ֖ן עַל ־ יְדֵ֣י אֱד֑וֹם וְהָיָ֤ה לָכֶם֙ גְּב֣וּל נֶ֔גֶב מִקְצֵ֥ה יָם ־ הַמֶּ֖לַח קֵֽדְמָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.4",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Numbers 34:4",
      "text": "וְנָסַ֣ב לָכֶם֩ הַגְּב֨וּל מִנֶּ֜גֶב לְמַעֲלֵ֤ה עַקְרַבִּים֙ וְעָ֣בַר צִ֔נָה והיה תּֽוֹצְאֹתָ֔יו מִנֶּ֖גֶב לְקָדֵ֣שׁ בַּרְנֵ֑עַ וְיָצָ֥א חֲצַר ־ אַדָּ֖ר וְעָבַ֥ר עַצְמֹֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.5",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Numbers 34:5",
      "text": "וְנָסַ֧ב הַגְּב֛וּל מֵעַצְמ֖וֹן נַ֣חְלָה מִצְרָ֑יִם וְהָי֥וּ תוֹצְאֹתָ֖יו הַיָּֽמָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.6",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Numbers 34:6",
      "text": "וּגְב֣וּל יָ֔ם וְהָיָ֥ה לָכֶ֛ם הַיָּ֥ם הַגָּד֖וֹל וּגְב֑וּל זֶֽה ־ יִהְיֶ֥ה לָכֶ֖ם גְּב֥וּל יָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.7",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Numbers 34:7",
      "text": "וְזֶֽה ־ יִהְיֶ֥ה לָכֶ֖ם גְּב֣וּל צָפ֑וֹן מִן ־ הַיָּם֙ הַגָּדֹ֔ל תְּתָא֥וּ לָכֶ֖ם הֹ֥ר הָהָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.8",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Numbers 34:8",
      "text": "מֵהֹ֣ר הָהָ֔ר תְּתָא֖וּ לְבֹ֣א חֲמָ֑ת וְהָי֛וּ תּוֹצְאֹ֥ת הַגְּבֻ֖ל צְדָֽדָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.9",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Numbers 34:9",
      "text": "וְיָצָ֤א הַגְּבֻל֙ זִפְרֹ֔נָה וְהָי֥וּ תוֹצְאֹתָ֖יו חֲצַ֣ר עֵינָ֑ן זֶֽה ־ יִהְיֶ֥ה לָכֶ֖ם גְּב֥וּל צָפֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.10",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Numbers 34:10",
      "text": "וְהִתְאַוִּיתֶ֥ם לָכֶ֖ם לִגְב֣וּל קֵ֑דְמָה מֵחֲצַ֥ר עֵינָ֖ן שְׁפָֽמָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.11",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Numbers 34:11",
      "text": "וְיָרַ֨ד הַגְּבֻ֧ל מִשְּׁפָ֛ם הָרִבְלָ֖ה מִקֶּ֣דֶם לָעָ֑יִן וְיָרַ֣ד הַגְּב֔וּל וּמָחָ֛ה עַל ־ כֶּ֥תֶף יָם ־ כִּנֶּ֖רֶת קֵֽדְמָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.12",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Numbers 34:12",
      "text": "וְיָרַ֤ד הַגְּבוּל֙ הַיַּרְדֵּ֔נָה וְהָי֥וּ תוֹצְאֹתָ֖יו יָ֣ם הַמֶּ֑לַח זֹאת֩ תִּהְיֶ֨ה לָכֶ֥ם הָאָ֛רֶץ לִגְבֻלֹתֶ֖יהָ סָבִֽיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.13",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Numbers 34:13",
      "text": "וַיְצַ֣ו מֹשֶׁ֔ה אֶת ־ בְּנֵ֥י יִשְׂרָאֵ֖ל לֵאמֹ֑ר זֹ֣את הָאָ֗רֶץ אֲשֶׁ֨ר תִּתְנַחֲל֤וּ אֹתָהּ֙ בְּגוֹרָ֔ל אֲשֶׁר֙ צִוָּ֣ה יְהוָ֔ה לָתֵ֛ת לְתִשְׁעַ֥ת הַמַּטּ֖וֹת וַחֲצִ֥י הַמַּטֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.14",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Numbers 34:14",
      "text": "כִּ֣י לָקְח֞וּ מַטֵּ֨ה בְנֵ֤י הָראוּבֵנִי֙ לְבֵ֣ית אֲבֹתָ֔ם וּמַטֵּ֥ה בְנֵֽי ־ הַגָּדִ֖י לְבֵ֣ית אֲבֹתָ֑ם וַחֲצִי֙ מַטֵּ֣ה מְנַשֶּׁ֔ה לָקְח֖וּ נַחֲלָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.15",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Numbers 34:15",
      "text": "שְׁנֵ֥י הַמַּטּ֖וֹת וַחֲצִ֣י הַמַּטֶּ֑ה לָקְח֣וּ נַחֲלָתָ֗ם מֵעֵ֛בֶר לְיַרְדֵּ֥ן יְרֵח֖וֹ קֵ֥דְמָה מִזְרָֽחָה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.16",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Numbers 34:16",
      "text": "וַיְדַבֵּ֥ר יְהוָ֖ה אֶל ־ מֹשֶׁ֥ה לֵּאמֹֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.17",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Numbers 34:17",
      "text": "אֵ֚לֶּה שְׁמ֣וֹת הָֽאֲנָשִׁ֔ים אֲשֶׁר ־ יִנְחֲל֥וּ לָכֶ֖ם אֶת ־ הָאָ֑רֶץ אֶלְעָזָר֙ הַכֹּהֵ֔ן וִיהוֹשֻׁ֖עַ בִּן ־ נֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.18",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Numbers 34:18",
      "text": "וְנָשִׂ֥יא אֶחָ֛ד נָשִׂ֥יא אֶחָ֖ד מִמַּטֶּ֑ה תִּקְח֖וּ לִנְחֹ֥ל אֶת ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.19",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Numbers 34:19",
      "text": "וְאֵ֖לֶּה שְׁמ֣וֹת הָאֲנָשִׁ֑ים לְמַטֵּ֣ה יְהוּדָ֔ה כָּלֵ֖ב בֶּן ־ יְפֻנֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.20",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Numbers 34:20",
      "text": "וּלְמַטֵּה֙ בְּנֵ֣י שִׁמְע֔וֹן שְׁמוּאֵ֖ל בֶּן ־ עַמִּיהֽוּד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.21",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Numbers 34:21",
      "text": "לְמַטֵּ֣ה בִנְיָמִ֔ן אֱלִידָ֖ד בֶּן ־ כִּסְלֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.22",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Numbers 34:22",
      "text": "וּלְמַטֵּ֥ה בְנֵי ־ דָ֖ן נָשִׂ֑יא בֻּקִּ֖י בֶּן ־ יָגְלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.23",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Numbers 34:23",
      "text": "לִבְנֵ֣י יוֹסֵ֔ף לְמַטֵּ֥ה בְנֵֽי ־ מְנַשֶּׁ֖ה נָשִׂ֑יא חַנִּיאֵ֖ל בֶּן ־ אֵפֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.24",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Numbers 34:24",
      "text": "וּלְמַטֵּ֥ה בְנֵֽי ־ אֶפְרַ֖יִם נָשִׂ֑יא קְמוּאֵ֖ל בֶּן ־ שִׁפְטָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.25",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Numbers 34:25",
      "text": "וּלְמַטֵּ֥ה בְנֵֽי ־ זְבוּלֻ֖ן נָשִׂ֑יא אֱלִיצָפָ֖ן בֶּן ־ פַּרְנָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.26",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Numbers 34:26",
      "text": "וּלְמַטֵּ֥ה בְנֵֽי ־ יִשָׂשכָ֖ר נָשִׂ֑יא פַּלְטִיאֵ֖ל בֶּן ־ עַזָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.27",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Numbers 34:27",
      "text": "וּלְמַטֵּ֥ה בְנֵי ־ אָשֵׁ֖ר נָשִׂ֑יא אֲחִיה֖וּד בֶּן ־ שְׁלֹמִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.28",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Numbers 34:28",
      "text": "וּלְמַטֵּ֥ה בְנֵֽי ־ נַפְתָּלִ֖י נָשִׂ֑יא פְּדַהְאֵ֖ל בֶּן ־ עַמִּיהֽוּד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.34.29",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Numbers 34:29",
      "text": "אֵ֕לֶּה אֲשֶׁ֖ר צִוָּ֣ה יְהוָ֑ה לְנַחֵ֥ל אֶת ־ בְּנֵֽי ־ יִשְׂרָאֵ֖ל בְּאֶ֥רֶץ כְּנָֽעַן ׃ פ",
      "paragraphStart": false
    }
  ]
}
