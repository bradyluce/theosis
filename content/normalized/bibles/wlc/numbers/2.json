  },
  "verses": [
    {
      "id": "wlc:numbers.2.1",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Numbers 2:1",
      "text": "וַיְדַבֵּ֣ר יְהוָ֔ה אֶל ־ מֹשֶׁ֥ה וְאֶֽל ־ אַהֲרֹ֖ן לֵאמֹֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:numbers.2.2",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Numbers 2:2",
      "text": "אִ֣ישׁ עַל ־ דִּגְל֤וֹ בְאֹתֹת֙ לְבֵ֣ית אֲבֹתָ֔ם יַחֲנ֖וּ בְּנֵ֣י יִשְׂרָאֵ֑ל מִנֶּ֕גֶד סָבִ֥יב לְאֹֽהֶל ־ מוֹעֵ֖ד יַחֲנֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.3",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Numbers 2:3",
      "text": "וְהַחֹנִים֙ קֵ֣דְמָה מִזְרָ֔חָה דֶּ֛גֶל מַחֲנֵ֥ה יְהוּדָ֖ה לְצִבְאֹתָ֑ם וְנָשִׂיא֙ לִבְנֵ֣י יְהוּדָ֔ה נַחְשׁ֖וֹן בֶּן ־ עַמִּינָדָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.4",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Numbers 2:4",
      "text": "וּצְבָא֖וֹ וּפְקֻדֵיהֶ֑ם אַרְבָּעָ֧ה וְשִׁבְעִ֛ים אֶ֖לֶף וְשֵׁ֥שׁ מֵאֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.5",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Numbers 2:5",
      "text": "וְהַחֹנִ֥ים עָלָ֖יו מַטֵּ֣ה יִשָּׂשכָ֑ר וְנָשִׂיא֙ לִבְנֵ֣י יִשָּׂשכָ֔ר נְתַנְאֵ֖ל בֶּן ־ צוּעָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.6",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Numbers 2:6",
      "text": "וּצְבָא֖וֹ וּפְקֻדָ֑יו אַרְבָּעָ֧ה וַחֲמִשִּׁ֛ים אֶ֖לֶף וְאַרְבַּ֥ע מֵאֽוֹת ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.7",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Numbers 2:7",
      "text": "מַטֵּ֖ה זְבוּלֻ֑ן וְנָשִׂיא֙ לִבְנֵ֣י זְבוּלֻ֔ן אֱלִיאָ֖ב בֶּן ־ חֵלֹֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.8",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Numbers 2:8",
      "text": "וּצְבָא֖וֹ וּפְקֻדָ֑יו שִׁבְעָ֧ה וַחֲמִשִּׁ֛ים אֶ֖לֶף וְאַרְבַּ֥ע מֵאֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.9",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Numbers 2:9",
      "text": "כָּֽל ־ הַפְּקֻדִ֞ים לְמַחֲנֵ֣ה יְהוּדָ֗ה מְאַ֨ת אֶ֜לֶף וּשְׁמֹנִ֥ים אֶ֛לֶף וְשֵֽׁשֶׁת ־ אֲלָפִ֥ים וְאַרְבַּע ־ מֵא֖וֹת לְצִבְאֹתָ֑ם רִאשֹׁנָ֖ה יִסָּֽעוּ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.10",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Numbers 2:10",
      "text": "דֶּ֣גֶל מַחֲנֵ֧ה רְאוּבֵ֛ן תֵּימָ֖נָה לְצִבְאֹתָ֑ם וְנָשִׂיא֙ לִבְנֵ֣י רְאוּבֵ֔ן אֱלִיצ֖וּר בֶּן ־ שְׁדֵיאֽוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:numbers.2.11",
      "translationId": "wlc",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Numbers 2:11",
      "text": "וּצְבָא֖וֹ וּפְקֻדָ֑יו שִׁשָּׁ֧ה וְאַרְבָּעִ֛ים אֶ֖לֶף וַחֲמֵ֥שׁ מֵאֽוֹת ׃",
      "paragraphStart": false
