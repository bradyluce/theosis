{
  "chapter": {
    "id": "wlc:job.5",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 5,
    "referenceLabel": "Job 5",
    "summary": "Source text for Job 5 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.5.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Job 5:1",
      "text": "קְֽרָא ־ נָ֭א הֲיֵ֣שׁ עוֹנֶ֑ךָּ וְאֶל ־ מִ֖י מִקְּדֹשִׁ֣ים תִּפְנֶֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.5.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Job 5:2",
      "text": "כִּֽי ־ לֶֽ֭אֱוִיל יַהֲרָג ־ כָּ֑עַשׂ וּ֝פֹתֶ֗ה תָּמִ֥ית קִנְאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Job 5:3",
      "text": "אֲֽנִי ־ רָ֭אִיתִי אֱוִ֣יל מַשְׁרִ֑ישׁ וָאֶקּ֖וֹב נָוֵ֣הוּ פִתְאֹֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Job 5:4",
      "text": "יִרְחֲק֣וּ בָנָ֣יו מִיֶּ֑שַׁע וְיִֽדַּכְּא֥וּ בַ֝שַּׁ֗עַר וְאֵ֣ין מַצִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Job 5:5",
      "text": "אֲשֶׁ֤ר קְצִיר֨וֹ ׀ רָ֘עֵ֤ב יֹאכֵ֗ל וְאֶֽל ־ מִצִּנִּ֥ים יִקָּחֵ֑הוּ וְשָׁאַ֖ף צַמִּ֣ים חֵילָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Job 5:6",
      "text": "כִּ֤י ׀ לֹא ־ יֵצֵ֣א מֵעָפָ֣ר אָ֑וֶן וּ֝מֵאֲדָמָ֗ה לֹא ־ יִצְמַ֥ח עָמָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Job 5:7",
      "text": "כִּֽי ־ אָ֭דָם לְעָמָ֣ל יוּלָּ֑ד וּבְנֵי ־ רֶ֝֗שֶׁף יַגְבִּ֥יהוּ עֽוּף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Job 5:8",
      "text": "אוּלָ֗ם אֲ֭נִי אֶדְרֹ֣שׁ אֶל ־ אֵ֑ל וְאֶל ־ אֱ֝לֹהִ֗ים אָשִׂ֥ים דִּבְרָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Job 5:9",
      "text": "עֹשֶׂ֣ה גְ֭דֹלוֹת וְאֵ֣ין חֵ֑קֶר נִ֝פְלָא֗וֹת עַד ־ אֵ֥ין מִסְפָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Job 5:10",
      "text": "הַנֹּתֵ֣ן מָ֭טָר עַל ־ פְּנֵי ־ אָ֑רֶץ וְשֹׁ֥לֵֽחַ מַ֝יִם עַל ־ פְּנֵ֥י חוּצֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Job 5:11",
      "text": "לָשׂ֣וּם שְׁפָלִ֣ים לְמָר֑וֹם וְ֝קֹדְרִ֗ים שָׂ֣גְבוּ יֶֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Job 5:12",
      "text": "מֵ֭פֵר מַחְשְׁב֣וֹת עֲרוּמִ֑ים וְֽלֹא ־ תַעֲשֶׂ֥ינָה יְ֝דֵיהֶ֗ם תּוּשִׁיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Job 5:13",
      "text": "לֹכֵ֣ד חֲכָמִ֣ים בְּעָרְמָ֑ם וַעֲצַ֖ת נִפְתָּלִ֣ים נִמְהָֽרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Job 5:14",
      "text": "יוֹמָ֥ם יְפַגְּשׁוּ ־ חֹ֑שֶׁךְ וְ֝כַלַּ֗יְלָה יְֽמַשְׁשׁ֥וּ בַֽצָּהֳרָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Job 5:15",
      "text": "וַיֹּ֣שַׁע מֵ֭חֶרֶב מִפִּיהֶ֑ם וּמִיַּ֖ד חָזָ֣ק אֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Job 5:16",
      "text": "וַתְּהִ֣י לַדַּ֣ל תִּקְוָ֑ה וְ֝עֹלָ֗תָה קָ֣פְצָה פִּֽיהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Job 5:17",
      "text": "הִנֵּ֤ה אַשְׁרֵ֣י אֱ֭נוֹשׁ יוֹכִחֶ֣נּֽוּ אֱל֑וֹהַּ וּמוּסַ֥ר שַׁ֝דַּ֗י אַל ־ תִּמְאָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Job 5:18",
      "text": "כִּ֤י ה֣וּא יַכְאִ֣יב וְיֶחְבָּ֑שׁ יִ֝מְחַ֗ץ וידו תִּרְפֶּֽינָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Job 5:19",
      "text": "בְּשֵׁ֣שׁ צָ֭רוֹת יַצִּילֶ֑ךָּ וּבְשֶׁ֓בַע ׀ לֹא ־ יִגַּ֖ע בְּךָ֣ רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Job 5:20",
      "text": "בְּ֭רָעָב פָּֽדְךָ֣ מִמָּ֑וֶת וּ֝בְמִלְחָמָ֗ה מִ֣ידֵי חָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Job 5:21",
      "text": "בְּשׁ֣וֹט לָ֭שׁוֹן תֵּחָבֵ֑א וְֽלֹא ־ תִירָ֥א מִ֝שֹּׁ֗ד כִּ֣י יָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Job 5:22",
      "text": "לְשֹׁ֣ד וּלְכָפָ֣ן תִּשְׂחָ֑ק וּֽמֵחַיַּ֥ת הָ֝אָ֗רֶץ אַל ־ תִּירָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Job 5:23",
      "text": "כִּ֤י עִם ־ אַבְנֵ֣י הַשָּׂדֶ֣ה בְרִיתֶ֑ךָ וְחַיַּ֥ת הַ֝שָּׂדֶ֗ה הָשְׁלְמָה ־ לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Job 5:24",
      "text": "וְֽ֭יָדַעְתָּ כִּי ־ שָׁל֣וֹם אָהֳלֶ֑ךָ וּֽפָקַדְתָּ֥ נָ֝וְךָ וְלֹ֣א תֶחֱטָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Job 5:25",
      "text": "וְֽ֭יָדַעְתָּ כִּי ־ רַ֣ב זַרְעֶ֑ךָ וְ֝צֶאֱצָאֶ֗יךָ כְּעֵ֣שֶׂב הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Job 5:26",
      "text": "תָּב֣וֹא בְכֶ֣לַח אֱלֵי ־ קָ֑בֶר כַּעֲל֖וֹת גָּדִ֣ישׁ בְּעִתּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.5.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Job 5:27",
      "text": "הִנֵּה ־ זֹ֭את חֲקַרְנ֥וּהָ כֶּֽן ־ הִ֑יא שְׁ֝מָעֶ֗נָּה וְאַתָּ֥ה דַֽע ־ לָֽךְ ׃ פ",
      "paragraphStart": false
    }
  ]
}
