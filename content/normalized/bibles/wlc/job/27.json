{
  "chapter": {
    "id": "wlc:job.27",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 27,
    "referenceLabel": "Job 27",
    "summary": "Source text for Job 27 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.27.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Job 27:1",
      "text": "וַיֹּ֣סֶף אִ֭יּוֹב שְׂאֵ֥ת מְשָׁל֗וֹ וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.27.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Job 27:2",
      "text": "חַי ־ אֵ֭ל הֵסִ֣יר מִשְׁפָּטִ֑י וְ֝שַׁדַּ֗י הֵמַ֥ר נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Job 27:3",
      "text": "כִּֽי ־ כָל ־ ע֣וֹד נִשְׁמָתִ֣י בִ֑י וְר֖וּחַ אֱל֣וֹהַּ בְּאַפִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Job 27:4",
      "text": "אִם ־ תְּדַבֵּ֣רְנָה שְׂפָתַ֣י עַוְלָ֑ה וּ֝לְשׁוֹנִ֗י אִם ־ יֶהְגֶּ֥ה רְמִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Job 27:5",
      "text": "חָלִ֣ילָה לִּי֮ אִם ־ אַצְדִּ֪יק אֶ֫תְכֶ֥ם עַד ־ אֶגְוָ֑ע לֹא ־ אָסִ֖יר תֻּמָּתִ֣י מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Job 27:6",
      "text": "בְּצִדְקָתִ֣י הֶ֭חֱזַקְתִּי וְלֹ֣א אַרְפֶּ֑הָ לֹֽא ־ יֶחֱרַ֥ף לְ֝בָבִ֗י מִיָּמָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Job 27:7",
      "text": "יְהִ֣י כְ֭רָשָׁע אֹ֣יְבִ֑י וּמִתְקוֹמְמִ֥י כְעַוָּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Job 27:8",
      "text": "כִּ֤י מַה ־ תִּקְוַ֣ת חָ֭נֵף כִּ֣י יִבְצָ֑ע כִּ֤י יֵ֖שֶׁל אֱל֣וֹהַּ נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Job 27:9",
      "text": "הַֽ֭צַעֲקָתוֹ יִשְׁמַ֥ע ׀ אֵ֑ל כִּֽי ־ תָב֖וֹא עָלָ֣יו צָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Job 27:10",
      "text": "אִם ־ עַל ־ שַׁדַּ֥י יִתְעַנָּ֑ג יִקְרָ֖א אֱל֣וֹהַּ בְּכָל ־ עֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Job 27:11",
      "text": "אוֹרֶ֣ה אֶתְכֶ֣ם בְּיַד ־ אֵ֑ל אֲשֶׁ֥ר עִם ־ שַׁ֝דַּ֗י לֹ֣א אֲכַחֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Job 27:12",
      "text": "הֵן ־ אַתֶּ֣ם כֻּלְּכֶ֣ם חֲזִיתֶ֑ם וְלָמָּה ־ זֶּ֝֗ה הֶ֣בֶל תֶּהְבָּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Job 27:13",
      "text": "זֶ֤ה ׀ חֵֽלֶק ־ אָדָ֖ם רָשָׁ֥ע ׀ עִם ־ אֵ֑ל וְֽנַחֲלַ֥ת עָ֝רִיצִ֗ים מִשַּׁדַּ֥י יִקָּֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Job 27:14",
      "text": "אִם ־ יִרְבּ֣וּ בָנָ֣יו לְמוֹ ־ חָ֑רֶב וְ֝צֶאֱצָאָ֗יו לֹ֣א יִשְׂבְּעוּ ־ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Job 27:15",
      "text": "שרידו בַּמָּ֣וֶת יִקָּבֵ֑רוּ וְ֝אַלְמְנֹתָ֗יו לֹ֣א תִבְכֶּֽינָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Job 27:16",
      "text": "אִם ־ יִצְבֹּ֣ר כֶּעָפָ֣ר כָּ֑סֶף וְ֝כַחֹ֗מֶר יָכִ֥ין מַלְבּֽוּשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Job 27:17",
      "text": "יָ֭כִין וְצַדִּ֣יק יִלְבָּ֑שׁ וְ֝כֶ֗סֶף נָקִ֥י יַחֲלֹֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Job 27:18",
      "text": "בָּנָ֣ה כָעָ֣שׁ בֵּית֑וֹ וּ֝כְסֻכָּ֗ה עָשָׂ֥ה נֹצֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Job 27:19",
      "text": "עָשִׁ֣יר יִ֭שְׁכַּב וְלֹ֣א יֵאָסֵ֑ף עֵינָ֖יו פָּקַ֣ח וְאֵינֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Job 27:20",
      "text": "תַּשִּׂיגֵ֣הוּ כַ֭מַּיִם בַּלָּה֑וֹת לַ֝֗יְלָה גְּנָבַ֥תּוּ סוּפָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Job 27:21",
      "text": "יִשָּׂאֵ֣הוּ קָדִ֣ים וְיֵלַ֑ךְ וִֽ֝ישָׂעֲרֵ֗הוּ מִמְּקֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Job 27:22",
      "text": "וְיַשְׁלֵ֣ךְ עָ֭לָיו וְלֹ֣א יַחְמֹ֑ל מִ֝יָּד֗וֹ בָּר֥וֹחַ יִבְרָֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.27.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Job 27:23",
      "text": "יִשְׂפֹּ֣ק עָלֵ֣ימוֹ כַפֵּ֑ימוֹ וְיִשְׁרֹ֥ק עָ֝לָ֗יו מִמְּקֹמֽוֹ ׃",
      "paragraphStart": false
    }
  ]
}
