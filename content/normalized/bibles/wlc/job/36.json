{
  "chapter": {
    "id": "wlc:job.36",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 36,
    "referenceLabel": "Job 36",
    "summary": "Source text for Job 36 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.36.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Job 36:1",
      "text": "וַיֹּ֥סֶף אֱלִיה֗וּא וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.36.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Job 36:2",
      "text": "כַּתַּר ־ לִ֣י זְ֭עֵיר וַאֲחַוֶּ֑ךָּ כִּ֤י ע֖וֹד לֶאֱל֣וֹהַּ מִלִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Job 36:3",
      "text": "אֶשָּׂ֣א דֵ֭עִי לְמֵרָח֑וֹק וּ֝לְפֹעֲלִ֗י אֶֽתֵּֽן ־ צֶֽדֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Job 36:4",
      "text": "כִּֽי ־ אָ֭מְנָם לֹא ־ שֶׁ֣קֶר מִלָּ֑י תְּמִ֖ים דֵּע֣וֹת עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Job 36:5",
      "text": "הֶן ־ אֵ֣ל כַּ֭בִּיר וְלֹ֣א יִמְאָ֑ס כַּ֝בִּ֗יר כֹּ֣חַֽ לֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Job 36:6",
      "text": "לֹא ־ יְחַיֶּ֥ה רָשָׁ֑ע וּמִשְׁפַּ֖ט עֲנִיִּ֣ים יִתֵּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Job 36:7",
      "text": "לֹֽא ־ יִגְרַ֥ע מִצַּדִּ֗יק עֵ֫ינָ֥יו וְאֶת ־ מְלָכִ֥ים לַכִּסֵּ֑א וַיֹּשִׁיבֵ֥ם לָ֝נֶ֗צַח וַיִּגְבָּֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Job 36:8",
      "text": "וְאִם ־ אֲסוּרִ֥ים בַּזִּקִּ֑ים יִ֝לָּכְד֗וּן בְּחַבְלֵי ־ עֹֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Job 36:9",
      "text": "וַיַּגֵּ֣ד לָהֶ֣ם פָּעֳלָ֑ם וּ֝פִשְׁעֵיהֶ֗ם כִּ֣י יִתְגַּבָּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Job 36:10",
      "text": "וַיִּ֣גֶל אָ֭זְנָם לַמּוּסָ֑ר וַ֝יֹּ֗אמֶר כִּֽי ־ יְשֻׁב֥וּן מֵאָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Job 36:11",
      "text": "אִֽם ־ יִשְׁמְע֗וּ וְֽיַ֫עֲבֹ֥דוּ יְכַלּ֣וּ יְמֵיהֶ֣ם בַּטּ֑וֹב וּ֝שְׁנֵיהֶ֗ם בַּנְּעִימִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Job 36:12",
      "text": "וְאִם ־ לֹ֣א יִ֭שְׁמְעוּ בְּשֶׁ֣לַח יַעֲבֹ֑רוּ וְ֝יִגְוְע֗וּ כִּבְלִי ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Job 36:13",
      "text": "וְֽחַנְפֵי ־ לֵ֭ב יָשִׂ֣ימוּ אָ֑ף לֹ֥א יְ֝שַׁוְּע֗וּ כִּ֣י אֲסָרָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Job 36:14",
      "text": "תָּמֹ֣ת בַּנֹּ֣עַר נַפְשָׁ֑ם וְ֝חַיָּתָ֗ם בַּקְּדֵשִֽׁים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Job 36:15",
      "text": "יְחַלֵּ֣ץ עָנִ֣י בְעָנְי֑וֹ וְיִ֖גֶל בַּלַּ֣חַץ אָזְנָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Job 36:16",
      "text": "וְאַ֤ף הֲסִיתְךָ֨ ׀ מִפִּי ־ צָ֗ר רַ֭חַב לֹא ־ מוּצָ֣ק תַּחְתֶּ֑יהָ וְנַ֥חַת שֻׁ֝לְחָנְךָ֗ מָ֣לֵא דָֽשֶׁן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Job 36:17",
      "text": "וְדִין ־ רָשָׁ֥ע מָלֵ֑אתָ דִּ֖ין וּמִשְׁפָּ֣ט יִתְמֹֽכוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Job 36:18",
      "text": "כִּֽי ־ חֵ֭מָה פֶּן ־ יְסִֽיתְךָ֣ בְסָ֑פֶק וְרָב ־ כֹּ֝֗פֶר אַל ־ יַטֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Job 36:19",
      "text": "הֲיַעֲרֹ֣ךְ שׁ֭וּעֲךָ לֹ֣א בְצָ֑ר וְ֝כֹ֗ל מַאֲמַצֵּי ־ כֹֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Job 36:20",
      "text": "אַל ־ תִּשְׁאַ֥ף הַלָּ֑יְלָה לַעֲל֖וֹת עַמִּ֣ים תַּחְתָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Job 36:21",
      "text": "הִ֭שָּׁמֶר אַל ־ תֵּ֣פֶן אֶל ־ אָ֑וֶן כִּֽי ־ עַל ־ זֶ֝֗ה בָּחַ֥רְתָּ מֵעֹֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Job 36:22",
      "text": "הֶן ־ אֵ֭ל יַשְׂגִּ֣יב בְּכֹח֑וֹ מִ֖י כָמֹ֣הוּ מוֹרֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Job 36:23",
      "text": "מִֽי ־ פָקַ֣ד עָלָ֣יו דַּרְכּ֑וֹ וּמִֽי ־ אָ֝מַ֗ר פָּעַ֥לְתָּ עַוְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Job 36:24",
      "text": "זְ֭כֹר כִּֽי ־ תַשְׂגִּ֣יא פָעֳל֑וֹ אֲשֶׁ֖ר שֹׁרְר֣וּ אֲנָשִֽׁים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Job 36:25",
      "text": "כָּל ־ אָדָ֥ם חָֽזוּ ־ ב֑וֹ אֱ֝נ֗וֹשׁ יַבִּ֥יט מֵרָחֽוֹק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Job 36:26",
      "text": "הֶן ־ אֵ֣ל שַׂ֭גִּיא וְלֹ֣א נֵדָ֑ע מִסְפַּ֖ר שָׁנָ֣יו וְלֹא ־ חֵֽקֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Job 36:27",
      "text": "כִּ֭י יְגָרַ֣ע נִטְפֵי ־ מָ֑יִם יָזֹ֖קּוּ מָטָ֣ר לְאֵדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Job 36:28",
      "text": "אֲשֶֽׁר ־ יִזְּל֥וּ שְׁחָקִ֑ים יִ֝רְעֲפ֗וּ עֲלֵ֤י ׀ אָדָ֬ם רָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Job 36:29",
      "text": "אַ֣ף אִם ־ יָ֭בִין מִפְרְשֵׂי ־ עָ֑ב תְּ֝שֻׁא֗וֹת סֻכָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Job 36:30",
      "text": "הֵן ־ פָּרַ֣שׂ עָלָ֣יו אוֹר֑וֹ וְשָׁרְשֵׁ֖י הַיָּ֣ם כִּסָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Job 36:31",
      "text": "כִּי ־ בָ֭ם יָדִ֣ין עַמִּ֑ים יִֽתֶּן ־ אֹ֥כֶל לְמַכְבִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Job 36:32",
      "text": "עַל ־ כַּפַּ֥יִם כִּסָּה ־ א֑וֹר וַיְצַ֖ו עָלֶ֣יהָ בְמַפְגִּֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.36.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Job 36:33",
      "text": "יַגִּ֣יד עָלָ֣יו רֵע֑וֹ מִ֝קְנֶ֗ה אַ֣ף עַל ־ עוֹלֶֽה ׃",
      "paragraphStart": false
    }
  ]
}
