{
  "chapter": {
    "id": "wlc:job.13",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 13,
    "referenceLabel": "Job 13",
    "summary": "Source text for Job 13 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.13.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Job 13:1",
      "text": "הֶן ־ כֹּ֭ל רָאֲתָ֣ה עֵינִ֑י שָֽׁמְעָ֥ה אָ֝זְנִ֗י וַתָּ֥בֶן לָֽהּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.13.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Job 13:2",
      "text": "כְּֽ֭דַעְתְּכֶם יָדַ֣עְתִּי גַם ־ אָ֑נִי לֹא ־ נֹפֵ֖ל אָנֹכִ֣י מִכֶּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Job 13:3",
      "text": "אוּלָ֗ם אֲ֭נִי אֶל ־ שַׁדַּ֣י אֲדַבֵּ֑ר וְהוֹכֵ֖חַ אֶל ־ אֵ֣ל אֶחְפָּֽץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Job 13:4",
      "text": "וְֽאוּלָ֗ם אַתֶּ֥ם טֹֽפְלֵי ־ שָׁ֑קֶר רֹפְאֵ֖י אֱלִ֣ל כֻּלְּכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Job 13:5",
      "text": "מִֽי ־ יִ֭תֵּן הַחֲרֵ֣שׁ תַּחֲרִישׁ֑וּן וּתְהִ֖י לָכֶ֣ם לְחָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Job 13:6",
      "text": "שִׁמְעוּ ־ נָ֥א תוֹכַחְתִּ֑י וְרִב֖וֹת שְׂפָתַ֣י הַקְשִֽׁיבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Job 13:7",
      "text": "הַ֭לְאֵל תְּדַבְּר֣וּ עַוְלָ֑ה וְ֝ל֗וֹ תְּֽדַבְּר֥וּ רְמִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Job 13:8",
      "text": "הֲפָנָ֥יו תִּשָּׂא֑וּן אִם ־ לָאֵ֥ל תְּרִיבֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Job 13:9",
      "text": "הֲ֭טוֹב כִּֽי ־ יַחְקֹ֣ר אֶתְכֶ֑ם אִם ־ כְּהָתֵ֥ל בֶּ֝אֱנ֗וֹשׁ תְּהָתֵ֥לּוּ בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Job 13:10",
      "text": "הוֹכֵ֣חַ יוֹכִ֣יחַ אֶתְכֶ֑ם אִם ־ בַּ֝סֵּ֗תֶר פָּנִ֥ים תִּשָּׂאֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Job 13:11",
      "text": "הֲלֹ֣א שְׂ֭אֵתוֹ תְּבַעֵ֣ת אֶתְכֶ֑ם וּ֝פַחְדּ֗וֹ יִפֹּ֥ל עֲלֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Job 13:12",
      "text": "זִֽ֭כְרֹנֵיכֶם מִשְׁלֵי ־ אֵ֑פֶר לְגַבֵּי ־ חֹ֝֗מֶר גַּבֵּיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Job 13:13",
      "text": "הַחֲרִ֣ישׁוּ מִ֭מֶּנִּי וַאֲדַבְּרָה ־ אָ֑נִי וְיַעֲבֹ֖ר עָלַ֣י מָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Job 13:14",
      "text": "עַל ־ מָ֤ה ׀ אֶשָּׂ֣א בְשָׂרִ֣י בְשִׁנָּ֑י וְ֝נַפְשִׁ֗י אָשִׂ֥ים בְּכַפִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Job 13:15",
      "text": "הֵ֣ן יִ֭קְטְלֵנִי לא אֲיַחֵ֑ל אַךְ ־ דְּ֝רָכַ֗י אֶל ־ פָּנָ֥יו אוֹכִֽיחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Job 13:16",
      "text": "גַּם ־ הוּא ־ לִ֥י לִֽישׁוּעָ֑ה כִּי ־ לֹ֥א לְ֝פָנָ֗יו חָנֵ֥ף יָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Job 13:17",
      "text": "שִׁמְע֣וּ שָׁ֭מוֹעַ מִלָּתִ֑י וְ֝אַֽחֲוָתִ֗י בְּאָזְנֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Job 13:18",
      "text": "הִנֵּה ־ נָ֭א עָרַ֣כְתִּי מִשְׁפָּ֑ט יָ֝דַ֗עְתִּי כִּֽי ־ אֲנִ֥י אֶצְדָּֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Job 13:19",
      "text": "מִי ־ ה֭וּא יָרִ֣יב עִמָּדִ֑י כִּֽי ־ עַתָּ֖ה אַחֲרִ֣ישׁ וְאֶגְוָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Job 13:20",
      "text": "אַךְ ־ שְׁ֭תַּיִם אַל ־ תַּ֣עַשׂ עִמָּדִ֑י אָ֥ז מִ֝פָּנֶ֗יךָ לֹ֣א אֶסָּתֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Job 13:21",
      "text": "כַּ֭פְּךָ מֵעָלַ֣י הַרְחַ֑ק וְ֝אֵ֥מָתְךָ֗ אַֽל ־ תְּבַעֲתַֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Job 13:22",
      "text": "וּ֭קְרָא וְאָנֹכִ֣י אֶֽעֱנֶ֑ה אֽוֹ ־ אֲ֝דַבֵּ֗ר וַהֲשִׁיבֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Job 13:23",
      "text": "כַּמָּ֣ה לִ֭י עֲוֺנ֣וֹת וְחַטָּא֑וֹת פִּֽשְׁעִ֥י וְ֝חַטָּאתִ֗י הֹדִיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Job 13:24",
      "text": "לָֽמָּה ־ פָנֶ֥יךָ תַסְתִּ֑יר וְתַחְשְׁבֵ֖נִי לְאוֹיֵ֣ב לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Job 13:25",
      "text": "הֶעָלֶ֣ה נִדָּ֣ף תַּעֲר֑וֹץ וְאֶת ־ קַ֖שׁ יָבֵ֣שׁ תִּרְדֹּֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Job 13:26",
      "text": "כִּֽי ־ תִכְתֹּ֣ב עָלַ֣י מְרֹר֑וֹת וְ֝תוֹרִישֵׁ֗נִי עֲוֺנ֥וֹת נְעוּרָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Job 13:27",
      "text": "וְתָ֘שֵׂ֤ם בַּסַּ֨ד ׀ רַגְלַ֗י וְתִשְׁמ֥וֹר כָּל ־ אָרְחוֹתָ֑י עַל ־ שָׁרְשֵׁ֥י רַ֝גְלַ֗י תִּתְחַקֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.13.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Job 13:28",
      "text": "וְ֭הוּא כְּרָקָ֣ב יִבְלֶ֑ה כְּ֝בֶ֗גֶד אֲכָ֣לוֹ עָֽשׁ ׃",
      "paragraphStart": false
    }
  ]
}
