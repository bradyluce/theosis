{
  "chapter": {
    "id": "wlc:job.38",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 38,
    "referenceLabel": "Job 38",
    "summary": "Source text for Job 38 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.38.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Job 38:1",
      "text": "וַיַּֽעַן ־ יְהוָ֣ה אֶת ־ אִ֭יּוֹב מנ הסערה וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.38.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Job 38:2",
      "text": "מִ֤י זֶ֨ה ׀ מַחְשִׁ֖יךְ עֵצָ֥ה בְמִלִּ֗ין בְּֽלִי ־ דָֽעַת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Job 38:3",
      "text": "אֱזָר ־ נָ֣א כְגֶ֣בֶר חֲלָצֶ֑יךָ וְ֝אֶשְׁאָלְךָ֗ וְהוֹדִיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Job 38:4",
      "text": "אֵיפֹ֣ה הָ֭יִיתָ בְּיָסְדִי ־ אָ֑רֶץ הַ֝גֵּ֗ד אִם ־ יָדַ֥עְתָּ בִינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Job 38:5",
      "text": "מִי ־ שָׂ֣ם מְ֭מַדֶּיהָ כִּ֣י תֵדָ֑ע א֤וֹ מִֽי ־ נָטָ֖ה עָלֶ֣יהָ קָּֽו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Job 38:6",
      "text": "עַל ־ מָ֭ה אֲדָנֶ֣יהָ הָטְבָּ֑עוּ א֥וֹ מִֽי ־ יָ֝רָ֗ה אֶ֣בֶן פִּנָּתָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Job 38:7",
      "text": "בְּרָן ־ יַ֭חַד כּ֣וֹכְבֵי בֹ֑קֶר וַ֝יָּרִ֗יעוּ כָּל ־ בְּנֵ֥י אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Job 38:8",
      "text": "וַיָּ֣סֶךְ בִּדְלָתַ֣יִם יָ֑ם בְּ֝גִיח֗וֹ מֵרֶ֥חֶם יֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Job 38:9",
      "text": "בְּשׂוּמִ֣י עָנָ֣ן לְבֻשׁ֑וֹ וַ֝עֲרָפֶ֗ל חֲתֻלָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Job 38:10",
      "text": "וָאֶשְׁבֹּ֣ר עָלָ֣יו חֻקִּ֑י וָֽ֝אָשִׂ֗ים בְּרִ֣יחַ וּדְלָתָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Job 38:11",
      "text": "וָאֹמַ֗ר עַד ־ פֹּ֣ה תָ֭בוֹא וְלֹ֣א תֹסִ֑יף וּפֹ֥א ־ יָ֝שִׁ֗ית בִּגְא֥וֹן גַּלֶּֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Job 38:12",
      "text": "הְֽ֭מִיָּמֶיךָ צִוִּ֣יתָ בֹּ֑קֶר ידעתה שחר מְקֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Job 38:13",
      "text": "לֶ֭אֱחֹז בְּכַנְפ֣וֹת הָאָ֑רֶץ וְיִנָּעֲר֖וּ רְשָׁ עִ֣ ים מִמֶּֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Job 38:14",
      "text": "תִּ֭תְהַפֵּךְ כְּחֹ֣מֶר חוֹתָ֑ם וְ֝יִֽתְיַצְּב֗וּ כְּמ֣וֹ לְבֽוּשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Job 38:15",
      "text": "וְיִמָּנַ֣ע מֵרְשָׁ עִ֣ ים אוֹרָ֑ם וּזְר֥וֹעַ רָ֝מָ֗ה תִּשָּׁבֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Job 38:16",
      "text": "הֲ֭בָאתָ עַד ־ נִבְכֵי ־ יָ֑ם וּבְחֵ֥קֶר תְּ֝ה֗וֹם הִתְהַלָּֽכְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Job 38:17",
      "text": "הֲנִגְל֣וּ לְ֭ךָ שַׁעֲרֵי ־ מָ֑וֶת וְשַׁעֲרֵ֖י צַלְמָ֣וֶת תִּרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Job 38:18",
      "text": "הִ֭תְבֹּנַנְתָּ עַד ־ רַחֲבֵי ־ אָ֑רֶץ הַ֝גֵּ֗ד אִם ־ יָדַ֥עְתָּ כֻלָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Job 38:19",
      "text": "אֵי ־ זֶ֣ה הַ֭דֶּרֶךְ יִשְׁכָּן ־ א֑וֹר וְ֝חֹ֗שֶׁךְ אֵי ־ זֶ֥ה מְקֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Job 38:20",
      "text": "כִּ֣י תִ֭קָּחֶנּוּ אֶל ־ גְּבוּל֑וֹ וְכִֽי ־ תָ֝בִ֗ין נְתִיב֥וֹת בֵּיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Job 38:21",
      "text": "יָ֭דַעְתָּ כִּי ־ אָ֣ז תִּוָּלֵ֑ד וּמִסְפַּ֖ר יָמֶ֣יךָ רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Job 38:22",
      "text": "הֲ֭בָאתָ אֶל ־ אֹצְר֣וֹת שָׁ֑לֶג וְאֹצְר֖וֹת בָּרָ֣ד תִּרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 23,
      "referenceLabel": "Job 38:23",
      "text": "אֲשֶׁר ־ חָשַׂ֥כְתִּי לְעֶת ־ צָ֑ר לְי֥וֹם קְ֝רָ֗ב וּמִלְחָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 24,
      "referenceLabel": "Job 38:24",
      "text": "אֵי ־ זֶ֣ה הַ֭דֶּרֶךְ יֵחָ֣לֶק א֑וֹר יָפֵ֖ץ קָדִ֣ים עֲלֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 25,
      "referenceLabel": "Job 38:25",
      "text": "מִֽי ־ פִלַּ֣ג לַשֶּׁ֣טֶף תְּעָלָ֑ה וְ֝דֶ֗רֶךְ לַחֲזִ֥יז קֹלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 26,
      "referenceLabel": "Job 38:26",
      "text": "לְ֭הַמְטִיר עַל ־ אֶ֣רֶץ לֹא ־ אִ֑ישׁ מִ֝דְבָּ֗ר לֹא ־ אָדָ֥ם בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 27,
      "referenceLabel": "Job 38:27",
      "text": "לְהַשְׂבִּ֣יעַ שֹׁ֭אָה וּמְשֹׁאָ֑ה וּ֝לְהַצְמִ֗יחַ מֹ֣צָא דֶֽשֶׁא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 28,
      "referenceLabel": "Job 38:28",
      "text": "הֲיֵשׁ ־ לַמָּטָ֥ר אָ֑ב א֥וֹ מִי ־ ה֝וֹלִ֗יד אֶגְלֵי ־ טָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 29,
      "referenceLabel": "Job 38:29",
      "text": "מִבֶּ֣טֶן מִ֭י יָצָ֣א הַקָּ֑רַח וּכְפֹ֥ר שָׁ֝מַיִם מִ֣י יְלָדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 30,
      "referenceLabel": "Job 38:30",
      "text": "כָּ֭אֶבֶן מַ֣יִם יִתְחַבָּ֑אוּ וּפְנֵ֥י תְ֝ה֗וֹם יִתְלַכָּֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 31,
      "referenceLabel": "Job 38:31",
      "text": "הַֽ֭תְקַשֵּׁר מַעֲדַנּ֣וֹת כִּימָ֑ה אֽוֹ ־ מֹשְׁכ֖וֹת כְּסִ֣יל תְּפַתֵּֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 32,
      "referenceLabel": "Job 38:32",
      "text": "הֲתֹצִ֣יא מַזָּר֣וֹת בְּעִתּ֑וֹ וְ֝עַ֗יִשׁ עַל ־ בָּנֶ֥יהָ תַנְחֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 33,
      "referenceLabel": "Job 38:33",
      "text": "הֲ֭יָדַעְתָּ חֻקּ֣וֹת שָׁמָ֑יִם אִם ־ תָּשִׂ֖ים מִשְׁטָר֣וֹ בָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.34",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 34,
      "referenceLabel": "Job 38:34",
      "text": "הֲתָרִ֣ים לָעָ֣ב קוֹלֶ֑ךָ וְֽשִׁפְעַת ־ מַ֥יִם תְּכַסֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.35",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 35,
      "referenceLabel": "Job 38:35",
      "text": "הַֽתְשַׁלַּ֣ח בְּרָקִ֣ים וְיֵלֵ֑כוּ וְיֹאמְר֖וּ לְךָ֣ הִנֵּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.36",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 36,
      "referenceLabel": "Job 38:36",
      "text": "מִי ־ שָׁ֭ת בַּטֻּח֣וֹת חָכְמָ֑ה א֤וֹ מִֽי ־ נָתַ֖ן לַשֶּׂ֣כְוִי בִינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.37",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 37,
      "referenceLabel": "Job 38:37",
      "text": "מִֽי ־ יְסַפֵּ֣ר שְׁחָקִ֣ים בְּחָכְמָ֑ה וְנִבְלֵ֥י שָׁ֝מַ֗יִם מִ֣י יַשְׁכִּֽיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.38",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 38,
      "referenceLabel": "Job 38:38",
      "text": "בְּצֶ֣קֶת עָ֭פָר לַמּוּצָ֑ק וּרְגָבִ֥ים יְדֻבָּֽקוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.39",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 39,
      "referenceLabel": "Job 38:39",
      "text": "הֲתָצ֣וּד לְלָבִ֣יא טָ֑רֶף וְחַיַּ֖ת כְּפִירִ֣ים תְּמַלֵּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.40",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 40,
      "referenceLabel": "Job 38:40",
      "text": "כִּי ־ יָשֹׁ֥חוּ בַמְּעוֹנ֑וֹת יֵשְׁב֖וּ בַסֻּכָּ֣ה לְמוֹ ־ אָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.38.41",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 41,
      "referenceLabel": "Job 38:41",
      "text": "מִ֤י יָכִ֥ין לָעֹרֵ֗ב צֵ֫יד֥וֹ כִּֽי ־ ילדו אֶל ־ אֵ֣ל יְשַׁוֵּ֑עוּ יִ֝תְע֗וּ לִבְלִי ־ אֹֽכֶל ׃",
      "paragraphStart": false
    }
  ]
}
