{
  "chapter": {
    "id": "wlc:job.19",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 19,
    "referenceLabel": "Job 19",
    "summary": "Source text for Job 19 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.19.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Job 19:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.19.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Job 19:2",
      "text": "עַד ־ אָ֭נָה תּוֹגְי֣וּן נַפְשִׁ֑י וּֽתְדַכְּאוּנַ֥נִי בְמִלִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Job 19:3",
      "text": "זֶ֤ה עֶ֣שֶׂר פְּ֭עָמִים תַּכְלִימ֑וּנִי לֹֽא ־ תֵ֝בֹ֗שׁוּ תַּהְכְּרוּ ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Job 19:4",
      "text": "וְאַף ־ אָמְנָ֥ם שָׁגִ֑יתִי אִ֝תִּ֗י תָּלִ֥ין מְשׁוּגָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Job 19:5",
      "text": "אִם ־ אָ֭מְנָם עָלַ֣י תַּגְדִּ֑ילוּ וְתוֹכִ֥יחוּ עָ֝לַ֗י חֶרְפָּתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Job 19:6",
      "text": "דְּֽעוּ ־ אֵ֭פוֹ כִּי ־ אֱל֣וֹהַּ עִוְּתָ֑נִי וּ֝מְצוּד֗וֹ עָלַ֥י הִקִּֽיף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Job 19:7",
      "text": "הֵ֤ן אֶצְעַ֣ק חָ֭מָס וְלֹ֣א אֵעָנֶ֑ה אֲ֝שַׁוַּ֗ע וְאֵ֣ין מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Job 19:8",
      "text": "אָרְחִ֣י גָ֭דַר וְלֹ֣א אֶעֱב֑וֹר וְעַ֥ל נְ֝תִיבוֹתַ֗י חֹ֣שֶׁךְ יָשִֽׂים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Job 19:9",
      "text": "כְּ֭בוֹדִי מֵעָלַ֣י הִפְשִׁ֑יט וַ֝יָּ֗סַר עֲטֶ֣רֶת רֹאשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Job 19:10",
      "text": "יִתְּצֵ֣נִי סָ֭בִיב וָאֵלַ֑ךְ וַיַּסַּ֥ע כָּ֝עֵ֗ץ תִּקְוָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Job 19:11",
      "text": "וַיַּ֣חַר עָלַ֣י אַפּ֑וֹ וַיַּחְשְׁבֵ֖נִי ל֣וֹ כְצָרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Job 19:12",
      "text": "יַ֤חַד ׀ יָ֘בֹ֤אוּ גְדוּדָ֗יו וַיָּסֹ֣לּוּ עָלַ֣י דַּרְכָּ֑ם וַיַּחֲנ֖וּ סָבִ֣יב לְאָהֳלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Job 19:13",
      "text": "אַ֭חַי מֵעָלַ֣י הִרְחִ֑יק וְ֝יֹדְעַ֗י אַךְ ־ זָ֥רוּ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Job 19:14",
      "text": "חָדְל֥וּ קְרוֹבָ֑י וּֽמְיֻדָּעַ֥י שְׁכֵחֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Job 19:15",
      "text": "גָּ֘רֵ֤י בֵיתִ֣י וְ֭אַמְהֹתַי לְזָ֣ר תַּחְשְׁבֻ֑נִי נָ֝כְרִ֗י הָיִ֥יתִי בְעֵינֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Job 19:16",
      "text": "לְעַבְדִּ֣י קָ֭רָאתִי וְלֹ֣א יַעֲנֶ֑ה בְּמוֹ ־ פִ֝֗י אֶתְחַנֶּן ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Job 19:17",
      "text": "ר֭וּחִֽי זָ֣רָה לְאִשְׁתִּ֑י וְ֝חַנֹּתִ֗י לִבְנֵ֥י בִטְנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Job 19:18",
      "text": "גַּם ־ עֲ֭וִילִים מָ֣אֲסוּ בִ֑י אָ֝ק֗וּמָה וַיְדַבְּרוּ ־ בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Job 19:19",
      "text": "תִּֽ֭עֲבוּנִי כָּל ־ מְתֵ֣י סוֹדִ֑י וְזֶֽה ־ אָ֝הַ֗בְתִּי נֶהְפְּכוּ ־ בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Job 19:20",
      "text": "בְּעוֹרִ֣י וּ֭בִבְשָׂרִי דָּבְקָ֣ה עַצְמִ֑י וָ֝אֶתְמַלְּטָ֗ה בְּע֣וֹר שִׁנָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Job 19:21",
      "text": "חָנֻּ֬נִי חָנֻּ֣נִי אַתֶּ֣ם רֵעָ֑י כִּ֥י יַד ־ אֱ֝ל֗וֹהַּ נָ֣גְעָה בִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Job 19:22",
      "text": "לָ֭מָּה תִּרְדְּפֻ֣נִי כְמוֹ ־ אֵ֑ל וּ֝מִבְּשָׂרִ֗י לֹ֣א תִשְׂבָּֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Job 19:23",
      "text": "מִֽי ־ יִתֵּ֣ן אֵ֭פוֹ וְיִכָּתְב֣וּן מִלָּ֑י מִֽי ־ יִתֵּ֖ן בַּסֵּ֣פֶר וְיֻחָֽקוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Job 19:24",
      "text": "בְּעֵט ־ בַּרְזֶ֥ל וְעֹפָ֑רֶת לָ֝עַ֗ד בַּצּ֥וּר יֵחָצְבֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Job 19:25",
      "text": "וַאֲנִ֣י יָ֭דַעְתִּי גֹּ֣אֲלִי חָ֑י וְ֝אַחֲר֗וֹן עַל ־ עָפָ֥ר יָקֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Job 19:26",
      "text": "וְאַחַ֣ר ע֭וֹרִֽי נִקְּפוּ ־ זֹ֑את וּ֝מִבְּשָׂרִ֗י אֶֽחֱזֶ֥ה אֱלֽוֹהַּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Job 19:27",
      "text": "אֲשֶׁ֤ר אֲנִ֨י ׀ אֶֽחֱזֶה ־ לִּ֗י וְעֵינַ֣י רָא֣וּ וְלֹא ־ זָ֑ר כָּל֖וּ כִלְיֹתַ֣י בְּחֵקִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Job 19:28",
      "text": "כִּ֣י תֹ֭אמְרוּ מַה ־ נִּרְדָּף ־ ל֑וֹ וְשֹׁ֥רֶשׁ דָּ֝בָ֗ר נִמְצָא ־ בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.19.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Job 19:29",
      "text": "גּ֤וּרוּ לָכֶ֨ם ׀ מִפְּנֵי ־ חֶ֗רֶב כִּֽי ־ חֵ֭מָה עֲוֺנ֣וֹת חָ֑רֶב לְמַ֖עַן תֵּדְע֣וּן שדין ׃ ס",
      "paragraphStart": false
    }
  ]
}
