{
  "chapter": {
    "id": "wlc:job.31",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 31,
    "referenceLabel": "Job 31",
    "summary": "Source text for Job 31 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.31.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Job 31:1",
      "text": "בְּ֭רִית כָּרַ֣תִּי לְעֵינָ֑י וּמָ֥ה אֶ֝תְבּוֹנֵ֗ן עַל ־ בְּתוּלָֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.31.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Job 31:2",
      "text": "וּמֶ֤ה ׀ חֵ֣לֶק אֱל֣וֹהַּ מִמָּ֑עַל וְֽנַחֲלַ֥ת שַׁ֝דַּ֗י מִמְּרֹמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Job 31:3",
      "text": "הֲלֹא ־ אֵ֥יד לְעַוָּ֑ל וְ֝נֵ֗כֶר לְפֹ֣עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Job 31:4",
      "text": "הֲלֹא ־ ה֭וּא יִרְאֶ֣ה דְרָכָ֑י וְֽכָל ־ צְעָדַ֥י יִסְפּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Job 31:5",
      "text": "אִם ־ הָלַ֥כְתִּי עִם ־ שָׁ֑וְא וַתַּ֖חַשׁ עַל ־ מִרְמָ֣ה רַגְלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Job 31:6",
      "text": "יִשְׁקְלֵ֥נִי בְמֹאזְנֵי ־ צֶ֑דֶק וְיֵדַ֥ע אֱ֝ל֗וֹהַּ תֻּמָּתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Job 31:7",
      "text": "אִ֥ם תִּטֶּ֣ה אַשֻּׁרִי֮ מִנִּ֪י הַ֫דָּ֥רֶךְ וְאַחַ֣ר עֵ֭ינַי הָלַ֣ךְ לִבִּ֑י וּ֝בְכַפַּ֗י דָּ֣בַק מֻאֽוּם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Job 31:8",
      "text": "אֶ֭זְרְעָה וְאַחֵ֣ר יֹאכֵ֑ל וְֽצֶאֱצָאַ֥י יְשֹׁרָֽשׁוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Job 31:9",
      "text": "אִם ־ נִפְתָּ֣ה לִ֭בִּי עַל ־ אִשָּׁ֑ה וְעַל ־ פֶּ֖תַח רֵעִ֣י אָרָֽבְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Job 31:10",
      "text": "תִּטְחַ֣ן לְאַחֵ֣ר אִשְׁתִּ֑י וְ֝עָלֶ֗יהָ יִכְרְע֥וּן אֲחֵרִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Job 31:11",
      "text": "כִּי ־ הוא זִמָּ֑ה והיא עָוֺ֥ן פְּלִילִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Job 31:12",
      "text": "כִּ֤י אֵ֣שׁ הִ֭יא עַד ־ אֲבַדּ֣וֹן תֹּאכֵ֑ל וּֽבְכָל ־ תְּב֖וּאָתִ֣י תְשָׁרֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Job 31:13",
      "text": "אִם ־ אֶמְאַ֗ס מִשְׁפַּ֣ט עַ֭בְדִּי וַאֲמָתִ֑י בְּ֝רִבָ֗ם עִמָּדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Job 31:14",
      "text": "וּמָ֣ה אֶֽ֭עֱשֶׂה כִּֽי ־ יָק֣וּם אֵ֑ל וְכִֽי ־ יִ֝פְקֹ֗ד מָ֣ה אֲשִׁיבֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Job 31:15",
      "text": "הֲֽ֝לֹא ־ בַ֭בֶּטֶן עֹשֵׂ֣נִי עָשָׂ֑הוּ וַ֝יְכֻנֶ֗נּוּ בָּרֶ֥חֶם אֶחָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Job 31:16",
      "text": "אִם ־ אֶ֭מְנַע מֵחֵ֣פֶץ דַּלִּ֑ים וְעֵינֵ֖י אַלְמָנָ֣ה אֲכַלֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Job 31:17",
      "text": "וְאֹכַ֣ל פִּתִּ֣י לְבַדִּ֑י וְלֹא ־ אָכַ֖ל יָת֣וֹם מִמֶּֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Job 31:18",
      "text": "כִּ֣י מִ֭נְּעוּרַי גְּדֵלַ֣נִי כְאָ֑ב וּמִבֶּ֖טֶן אִמִּ֣י אַנְחֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Job 31:19",
      "text": "אִם ־ אֶרְאֶ֣ה א֭וֹבֵד מִבְּלִ֣י לְב֑וּשׁ וְאֵ֥ין כְּ֝ס֗וּת לָאֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Job 31:20",
      "text": "אִם ־ לֹ֣א בֵרֲכ֣וּנִי חלצו וּמִגֵּ֥ז כְּ֝בָשַׂי יִתְחַמָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Job 31:21",
      "text": "אִם ־ הֲנִיפ֣וֹתִי עַל ־ יָת֣וֹם יָדִ֑י כִּֽי ־ אֶרְאֶ֥ה בַ֝שַּׁ֗עַר עֶזְרָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Job 31:22",
      "text": "כְּ֭תֵפִי מִשִּׁכְמָ֣ה תִפּ֑וֹל וְ֝אֶזְרֹעִ֗י מִקָּנָ֥ה תִשָּׁבֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Job 31:23",
      "text": "כִּ֤י פַ֣חַד אֵ֭לַי אֵ֣יד אֵ֑ל וּ֝מִשְּׂאֵת֗וֹ לֹ֣א אוּכָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Job 31:24",
      "text": "אִם ־ שַׂ֣מְתִּי זָהָ֣ב כִּסְלִ֑י וְ֝לַכֶּ֗תֶם אָמַ֥רְתִּי מִבְטַחִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Job 31:25",
      "text": "אִם ־ אֶ֭שְׂמַח כִּי ־ רַ֣ב חֵילִ֑י וְכִֽי ־ כַ֝בִּ֗יר מָצְאָ֥ה יָדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Job 31:26",
      "text": "אִם ־ אֶרְאֶ֣ה א֖וֹר כִּ֣י יָהֵ֑ל וְ֝יָרֵ֗חַ יָקָ֥ר הֹלֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Job 31:27",
      "text": "וַיִּ֣פְתְּ בַּסֵּ֣תֶר לִבִּ֑י וַתִּשַּׁ֖ק יָדִ֣י לְפִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Job 31:28",
      "text": "גַּם ־ ה֭וּא עָוֺ֣ן פְּלִילִ֑י כִּֽי ־ כִחַ֖שְׁתִּי לָאֵ֣ל מִמָּֽעַל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Job 31:29",
      "text": "אִם ־ אֶ֭שְׂמַח בְּפִ֣יד מְשַׂנְאִ֑י וְ֝הִתְעֹרַ֗רְתִּי כִּֽי ־ מְצָ֥אוֹ רָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Job 31:30",
      "text": "וְלֹא ־ נָתַ֣תִּי לַחֲטֹ֣א חִכִּ֑י לִשְׁאֹ֖ל בְּאָלָ֣ה נַפְשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Job 31:31",
      "text": "אִם ־ לֹ֣א אָ֭מְרוּ מְתֵ֣י אָהֳלִ֑י מִֽי ־ יִתֵּ֥ן מִ֝בְּשָׂר֗וֹ לֹ֣א נִשְׂבָּֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 32,
      "referenceLabel": "Job 31:32",
      "text": "בַּ֭חוּץ לֹא ־ יָלִ֣ין גֵּ֑ר דְּ֝לָתַ֗י לָאֹ֥רַח אֶפְתָּֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 33,
      "referenceLabel": "Job 31:33",
      "text": "אִם ־ כִּסִּ֣יתִי כְאָדָ֣ם פְּשָׁעָ֑י לִטְמ֖וֹן בְּחֻבִּ֣י עֲוֺֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.34",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 34,
      "referenceLabel": "Job 31:34",
      "text": "כִּ֤י אֶֽעֱר֨וֹץ ׀ הָ֘מ֤וֹן רַבָּ֗ה וּבוּז ־ מִשְׁפָּח֥וֹת יְחִתֵּ֑נִי וָ֝אֶדֹּ֗ם לֹא ־ אֵ֥צֵא פָֽתַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.35",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 35,
      "referenceLabel": "Job 31:35",
      "text": "מִ֤י יִתֶּן ־ לִ֨י ׀ שֹׁ֘מֵ֤עַֽ לִ֗י הֶן ־ תָּ֭וִי שַׁדַּ֣י יַעֲנֵ֑נִי וְסֵ֥פֶר כָּ֝תַ֗ב אִ֣ישׁ רִיבִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.36",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 36,
      "referenceLabel": "Job 31:36",
      "text": "אִם ־ לֹ֣א עַל ־ שִׁ֭כְמִי אֶשָּׂאֶ֑נּוּ אֶֽעֶנְדֶ֖נּוּ עֲטָר֣וֹת לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.37",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 37,
      "referenceLabel": "Job 31:37",
      "text": "מִסְפַּ֣ר צְ֭עָדַי אַגִּידֶ֑נּוּ כְּמוֹ ־ נָ֝גִ֗יד אֲקָרֲבֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.38",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 38,
      "referenceLabel": "Job 31:38",
      "text": "אִם ־ עָ֭לַי אַדְמָתִ֣י תִזְעָ֑ק וְ֝יַ֗חַד תְּלָמֶ֥יהָ יִבְכָּיֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.39",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 39,
      "referenceLabel": "Job 31:39",
      "text": "אִם ־ כֹּ֭חָהּ אָכַ֣לְתִּי בְלִי ־ כָ֑סֶף וְנֶ֖פֶשׁ בְּעָלֶ֣יהָ הִפָּֽחְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.31.40",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 40,
      "referenceLabel": "Job 31:40",
      "text": "תַּ֤חַת חִטָּ֨ה ׀ יֵ֥צֵא ח֗וֹחַ וְתַֽחַת ־ שְׂעֹרָ֥ה בָאְשָׁ֑ה תַּ֝֗מּוּ דִּבְרֵ֥י אִיּֽוֹב ׃ פ",
      "paragraphStart": false
    }
  ]
}
