{
  "chapter": {
    "id": "wlc:job.24",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 24,
    "referenceLabel": "Job 24",
    "summary": "Source text for Job 24 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.24.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Job 24:1",
      "text": "מַדּ֗וּעַ מִ֭שַּׁדַּי לֹא ־ נִצְפְּנ֣וּ עִתִּ֑ים וידעו לֹא ־ חָ֥זוּ יָמָֽיו ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.24.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Job 24:2",
      "text": "גְּבֻל֥וֹת יַשִּׂ֑יגוּ עֵ֥דֶר גָּ֝זְל֗וּ וַיִּרְעֽוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Job 24:3",
      "text": "חֲמ֣וֹר יְתוֹמִ֣ים יִנְהָ֑גוּ יַ֝חְבְּל֗וּ שׁ֣וֹר אַלְמָנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Job 24:4",
      "text": "יַטּ֣וּ אֶבְיוֹנִ֣ים מִדָּ֑רֶךְ יַ֥חַד חֻ֝בְּא֗וּ עֲנִיֵּי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Job 24:5",
      "text": "הֵ֤ן פְּרָאִ֨ים ׀ בַּֽמִּדְבָּ֗ר יָצְא֣וּ בְּ֭פָעֳלָם מְשַׁחֲרֵ֣י לַטָּ֑רֶף עֲרָבָ֥ה ל֥וֹ לֶ֝֗חֶם לַנְּעָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Job 24:6",
      "text": "בַּ֭שָּׂדֶה בְּלִיל֣וֹ יקצירו וְכֶ֖רֶם רָשָׁ֣ע יְלַקֵּֽשׁוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Job 24:7",
      "text": "עָר֣וֹם יָ֭לִינוּ מִבְּלִ֣י לְב֑וּשׁ וְאֵ֥ין כְּ֝ס֗וּת בַּקָּרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Job 24:8",
      "text": "מִזֶּ֣רֶם הָרִ֣ים יִרְטָ֑בוּ וּֽמִבְּלִ֥י מַ֝חְסֶ֗ה חִבְּקוּ ־ צֽוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Job 24:9",
      "text": "יִ֭גְזְלוּ מִשֹּׁ֣ד יָת֑וֹם וְֽעַל ־ עָנִ֥י יַחְבֹּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Job 24:10",
      "text": "עָר֣וֹם הִ֭לְּכוּ בְּלִ֣י לְב֑וּשׁ וּ֝רְעֵבִ֗ים נָ֣שְׂאוּ עֹֽמֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Job 24:11",
      "text": "בֵּין ־ שׁוּרֹתָ֥ם יַצְהִ֑ירוּ יְקָבִ֥ים דָּ֝רְכ֗וּ וַיִּצְמָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Job 24:12",
      "text": "מֵ֘עִ֤יר מְתִ֨ים ׀ יִנְאָ֗קוּ וְנֶֽפֶשׁ ־ חֲלָלִ֥ים תְּשַׁוֵּ֑עַ וֶ֝אֱל֗וֹהַּ לֹא ־ יָשִׂ֥ים תִּפְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Job 24:13",
      "text": "הֵ֤מָּה ׀ הָיוּ֮ בְּֽמֹרְדֵ֫י ־ א֥וֹר לֹֽא ־ הִכִּ֥ירוּ דְרָכָ֑יו וְלֹ֥א יָ֝שְׁב֗וּ בִּנְתִיבֹתָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Job 24:14",
      "text": "לָא֡וֹר יָ֘ק֤וּם רוֹצֵ֗חַ יִֽקְטָל ־ עָנִ֥י וְאֶבְי֑וֹן וּ֝בַלַּ֗יְלָה יְהִ֣י כַגַּנָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Job 24:15",
      "text": "וְעֵ֤ין נֹאֵ֨ף ׀ שָׁ֤מְרָֽה נֶ֣שֶׁף לֵ֭אמֹר לֹא ־ תְשׁוּרֵ֣נִי עָ֑יִן וְסֵ֖תֶר פָּנִ֣ים יָשִֽׂים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Job 24:16",
      "text": "חָתַ֥ר בַּחֹ֗שֶׁךְ בָּ֫תִּ֥ים יוֹמָ֥ם חִתְּמוּ ־ לָ֗מוֹ לֹא ־ יָ֥דְעוּ אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Job 24:17",
      "text": "כִּ֤י יַחְדָּ֨ו ׀ בֹּ֣קֶר לָ֣מוֹ צַלְמָ֑וֶת כִּֽי ־ יַ֝כִּ֗יר בַּלְה֥וֹת צַלְמָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Job 24:18",
      "text": "קַֽל ־ ה֤וּא ׀ עַל ־ פְּנֵי ־ מַ֗יִם תְּקֻלַּ֣ל חֶלְקָתָ֣ם בָּאָ֑רֶץ לֹֽא ־ יִ֝פְנֶה דֶּ֣רֶךְ כְּרָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Job 24:19",
      "text": "צִיָּ֤ה גַם ־ חֹ֗ם יִגְזְל֥וּ מֵֽימֵי ־ שֶׁ֗לֶג שְׁא֣וֹל חָטָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Job 24:20",
      "text": "יִשְׁכָּ֘חֵ֤הוּ רֶ֨חֶם ׀ מְתָ֘ק֤וֹ רִמָּ֗ה ע֥וֹד לֹֽא ־ יִזָּכֵ֑ר וַתִּשָּׁבֵ֖ר כָּעֵ֣ץ עַוְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Job 24:21",
      "text": "רֹעֶ֣ה עֲ֭קָרָה לֹ֣א תֵלֵ֑ד וְ֝אַלְמָנָ֗ה לֹ֣א יְיֵטִֽיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Job 24:22",
      "text": "וּמָשַׁ֣ךְ אַבִּירִ֣ים בְּכֹח֑וֹ יָ֝ק֗וּם וְֽלֹא ־ יַאֲמִ֥ין בַּֽחַיִּֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Job 24:23",
      "text": "יִתֶּן ־ ל֣וֹ לָ֭בֶטַח וְיִשָּׁעֵ֑ן וְ֝עֵינֵ֗יהוּ עַל ־ דַּרְכֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Job 24:24",
      "text": "ר֤וֹמּוּ מְּעַ֨ט ׀ וְֽאֵינֶ֗נּוּ וְֽהֻמְּכ֗וּ כַּכֹּ֥ל יִקָּפְצ֑וּן וּכְרֹ֖אשׁ שִׁבֹּ֣לֶת יִמָּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.24.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Job 24:25",
      "text": "וְאִם ־ לֹ֣א אֵ֭פוֹ מִ֣י יַכְזִיבֵ֑נִי וְיָשֵׂ֥ם לְ֝אַ֗ל מִלָּתִֽי ׃ ס",
      "paragraphStart": false
    }
  ]
}
