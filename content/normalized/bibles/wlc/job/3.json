{
  "chapter": {
    "id": "wlc:job.3",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 3,
    "referenceLabel": "Job 3",
    "summary": "Source text for Job 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.3.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Job 3:1",
      "text": "אַחֲרֵי ־ כֵ֗ן פָּתַ֤ח אִיּוֹב֙ אֶת ־ פִּ֔יהוּ וַיְקַלֵּ֖ל אֶת ־ יוֹמֽוֹ ׃ פ",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.3.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Job 3:2",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Job 3:3",
      "text": "יֹ֣אבַד י֭וֹם אִוָּ֣לֶד בּ֑וֹ וְהַלַּ֥יְלָה אָ֝מַ֗ר הֹ֣רָה גָֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Job 3:4",
      "text": "הַיּ֥וֹם הַה֗וּא יְֽהִ֫י חֹ֥שֶׁךְ אַֽל ־ יִדְרְשֵׁ֣הוּ אֱל֣וֹהַּ מִמָּ֑עַל וְאַל ־ תּוֹפַ֖ע עָלָ֣יו נְהָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Job 3:5",
      "text": "יִגְאָלֻ֡הוּ חֹ֣שֶׁךְ וְ֭צַלְמָוֶת תִּשְׁכָּן ־ עָלָ֣יו עֲנָנָ֑ה יְ֝בַעֲתֻ֗הוּ כִּֽמְרִ֥ירֵי יֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Job 3:6",
      "text": "הַלַּ֥יְלָה הַהוּא֮ יִקָּחֵ֪ה֫וּ אֹ֥פֶל אַל ־ יִ֭חַדְּ בִּימֵ֣י שָׁנָ֑ה בְּמִסְפַּ֥ר יְ֝רָחִ֗ים אַל ־ יָבֹֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Job 3:7",
      "text": "הִנֵּ֤ה הַלַּ֣יְלָה הַ֭הוּא יְהִ֣י גַלְמ֑וּד אַל ־ תָּבֹ֖א רְנָנָ֣ה בֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Job 3:8",
      "text": "יִקְּבֻ֥הוּ אֹרְרֵי ־ י֑וֹם הָ֝עֲתִידִ֗ים עֹרֵ֥ר לִוְיָתָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Job 3:9",
      "text": "יֶחְשְׁכוּ֮ כּוֹכְבֵ֪י נִ֫שְׁפּ֥וֹ יְקַו ־ לְא֥וֹר וָאַ֑יִן וְאַל ־ יִ֝רְאֶ֗ה בְּעַפְעַפֵּי ־ שָֽׁחַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Job 3:10",
      "text": "כִּ֤י לֹ֣א סָ֭גַר דַּלְתֵ֣י בִטְנִ֑י וַיַּסְתֵּ֥ר עָ֝מָ֗ל מֵעֵינָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Job 3:11",
      "text": "לָ֤מָּה לֹּ֣א מֵרֶ֣חֶם אָמ֑וּת מִבֶּ֖טֶן יָצָ֣אתִי וְאֶגְוָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Job 3:12",
      "text": "מַ֭דּוּעַ קִדְּמ֣וּנִי בִרְכָּ֑יִם וּמַה ־ שָּׁ֝דַ֗יִם כִּ֣י אִינָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Job 3:13",
      "text": "כִּֽי ־ עַ֭תָּה שָׁכַ֣בְתִּי וְאֶשְׁק֑וֹט יָ֝שַׁ֗נְתִּי אָ֤ז ׀ יָנ֬וּחַֽ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Job 3:14",
      "text": "עִם ־ מְ֭לָכִים וְיֹ֣עֲצֵי אָ֑רֶץ הַבֹּנִ֖ים חֳרָב֣וֹת לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Job 3:15",
      "text": "א֣וֹ עִם ־ שָׂ֭רִים זָהָ֣ב לָהֶ֑ם הַֽמְמַלְאִ֖ים בָּתֵּיהֶ֣ם כָּֽסֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Job 3:16",
      "text": "א֤וֹ כְנֵ֣פֶל טָ֭מוּן לֹ֣א אֶהְיֶ֑ה כְּ֝עֹלְלִ֗ים לֹא ־ רָ֥אוּ אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Job 3:17",
      "text": "שָׁ֣ם רְ֭שָׁעִים חָ֣דְלוּ רֹ֑גֶז וְשָׁ֥ם יָ֝נ֗וּחוּ יְגִ֣יעֵי כֹֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Job 3:18",
      "text": "יַ֭חַד אֲסִירִ֣ים שַׁאֲנָ֑נוּ לֹ֥א שָׁ֝מְע֗וּ ק֣וֹל נֹגֵֽשׂ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Job 3:19",
      "text": "קָטֹ֣ן וְ֭גָדוֹל שָׁ֣ם ה֑וּא וְ֝עֶ֗בֶד חָפְשִׁ֥י מֵאֲדֹנָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Job 3:20",
      "text": "לָ֤מָּה יִתֵּ֣ן לְעָמֵ֣ל א֑וֹר וְ֝חַיִּ֗ים לְמָ֣רֵי נָֽפֶשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Job 3:21",
      "text": "הַֽמְחַכִּ֣ים לַמָּ֣וֶת וְאֵינֶ֑נּוּ וַֽ֝יַּחְפְּרֻ֗הוּ מִמַּטְמוֹנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Job 3:22",
      "text": "הַשְּׂמֵחִ֥ים אֱלֵי ־ גִ֑יל יָ֝שִׂ֗ישׂוּ כִּ֣י יִמְצְאוּ ־ קָֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Job 3:23",
      "text": "לְ֭גֶבֶר אֲשֶׁר ־ דַּרְכּ֣וֹ נִסְתָּ֑רָה וַיָּ֖סֶךְ אֱל֣וֹהַּ בַּעֲדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Job 3:24",
      "text": "כִּֽי ־ לִפְנֵ֣י לַ֭חְמִי אַנְחָתִ֣י תָבֹ֑א וַֽיִּתְּכ֥וּ כַ֝מַּ֗יִם שַׁאֲגֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Job 3:25",
      "text": "כִּ֤י פַ֣חַד פָּ֭חַדְתִּי וַיֶּאֱתָיֵ֑נִי וַאֲשֶׁ֥ר יָ֝גֹ֗רְתִּי יָ֣בֹא לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.3.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Job 3:26",
      "text": "לֹ֤א שָׁלַ֨וְתִּי ׀ וְלֹ֖א שָׁקַ֥טְתִּי וְֽלֹא ־ נָ֗חְתִּי וַיָּ֥בֹא רֹֽגֶז ׃ פ",
      "paragraphStart": false
    }
  ]
}
