{
  "chapter": {
    "id": "wlc:job.26",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 26,
    "referenceLabel": "Job 26",
    "summary": "Source text for Job 26 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.26.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Job 26:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.26.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Job 26:2",
      "text": "מֶה ־ עָזַ֥רְתָּ לְלֹא ־ כֹ֑חַ ה֝וֹשַׁ֗עְתָּ זְר֣וֹעַ לֹא ־ עֹֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Job 26:3",
      "text": "מַה ־ יָּ֭עַצְתָּ לְלֹ֣א חָכְמָ֑ה וְ֝תוּשִׁיָּ֗ה לָרֹ֥ב הוֹדָֽעְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Job 26:4",
      "text": "אֶת ־ מִ֭י הִגַּ֣דְתָּ מִלִּ֑ין וְנִשְׁמַת ־ מִ֝י יָצְאָ֥ה מִמֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Job 26:5",
      "text": "הָרְפָאִ֥ים יְחוֹלָ֑לוּ מִתַּ֥חַת מַ֝֗יִם וְשֹׁכְנֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Job 26:6",
      "text": "עָר֣וֹם שְׁא֣וֹל נֶגְדּ֑וֹ וְאֵ֥ין כְּ֝ס֗וּת לָֽאֲבַדּֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Job 26:7",
      "text": "נֹטֶ֣ה צָפ֣וֹן עַל ־ תֹּ֑הוּ תֹּ֥לֶה אֶ֝֗רֶץ עַל ־ בְּלִי ־ מָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Job 26:8",
      "text": "צֹרֵֽר ־ מַ֥יִם בְּעָבָ֑יו וְלֹא ־ נִבְקַ֖ע עָנָ֣ן תַּחְתָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Job 26:9",
      "text": "מְאַחֵ֥ז פְּנֵי ־ כִסֵּ֑ה פַּרְשֵׁ֖ז עָלָ֣יו עֲנָנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Job 26:10",
      "text": "חֹֽק ־ חָ֭ג עַל ־ פְּנֵי ־ מָ֑יִם עַד ־ תַּכְלִ֖ית א֣וֹר עִם ־ חֹֽשֶׁךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Job 26:11",
      "text": "עַמּוּדֵ֣י שָׁמַ֣יִם יְרוֹפָ֑פוּ וְ֝יִתְמְה֗וּ מִגַּעֲרָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Job 26:12",
      "text": "בְּ֭כֹחוֹ רָגַ֣ע הַיָּ֑ם ובתובנתו מָ֣חַץ רָֽהַב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Job 26:13",
      "text": "בְּ֭רוּחוֹ שָׁמַ֣יִם שִׁפְרָ֑ה חֹֽלֲלָ֥ה יָ֝ד֗וֹ נָחָ֥שׁ בָּרִֽיחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.26.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Job 26:14",
      "text": "הֶן ־ אֵ֤לֶּה ׀ קְצ֬וֹת דרכו וּמַה ־ שֵּׁ֣מֶץ דָּ֭בָר נִשְׁמַע ־ בּ֑וֹ וְרַ֥עַם גבורתו מִ֣י יִתְבּוֹנָֽן ׃ ס",
      "paragraphStart": false
    }
  ]
}
