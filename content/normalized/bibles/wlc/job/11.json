{
  "chapter": {
    "id": "wlc:job.11",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 11,
    "referenceLabel": "Job 11",
    "summary": "Source text for Job 11 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.11.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Job 11:1",
      "text": "וַ֭יַּעַן צֹפַ֥ר הַֽנַּעֲמָתִ֗י וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.11.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Job 11:2",
      "text": "הֲרֹ֣ב דְּ֭בָרִים לֹ֣א יֵעָנֶ֑ה וְאִם ־ אִ֖ישׁ שְׂפָתַ֣יִם יִצְדָּֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Job 11:3",
      "text": "בַּ֭דֶּיךָ מְתִ֣ים יַחֲרִ֑ישׁו וַ֝תִּלְעַ֗ג וְאֵ֣ין מַכְלִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Job 11:4",
      "text": "וַ֭תֹּאמֶר זַ֣ךְ לִקְחִ֑י וּ֝בַ֗ר הָיִ֥יתִי בְעֵינֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Job 11:5",
      "text": "וְֽאוּלָ֗ם מִֽי ־ יִתֵּ֣ן אֱל֣וֹהַּ דַּבֵּ֑ר וְיִפְתַּ֖ח שְׂפָתָ֣יו עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Job 11:6",
      "text": "וְיַגֶּד ־ לְךָ֨ ׀ תַּֽעֲלֻמ֣וֹת חָכְמָה֮ כִּֽי ־ כִפְלַ֪יִם לְֽת֫וּשִׁיָּ֥ה וְדַ֡ע כִּֽי ־ יַשֶּׁ֥ה לְךָ֥ אֱ֝ל֗וֹהַ מֵעֲוֺנֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Job 11:7",
      "text": "הַחֵ֣קֶר אֱל֣וֹהַ תִּמְצָ֑א אִ֤ם עַד ־ תַּכְלִ֖ית שַׁדַּ֣י תִּמְצָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Job 11:8",
      "text": "גָּבְהֵ֣י שָׁ֭מַיִם מַה ־ תִּפְעָ֑ל עֲמֻקָּ֥ה מִ֝שְּׁא֗וֹל מַה ־ תֵּדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Job 11:9",
      "text": "אֲרֻכָּ֣ה מֵאֶ֣רֶץ מִדָּ֑הּ וּ֝רְחָבָ֗ה מִנִּי ־ יָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Job 11:10",
      "text": "אִם ־ יַחֲלֹ֥ף וְיַסְגִּ֑יר וְ֝יַקְהִ֗יל וּמִ֣י יְשִׁיבֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Job 11:11",
      "text": "כִּי ־ ה֭וּא יָדַ֣ע מְתֵי ־ שָׁ֑וְא וַיַּרְא ־ אָ֝֗וֶן וְלֹ֣א יִתְבּוֹנָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Job 11:12",
      "text": "וְאִ֣ישׁ נָ֭בוּב יִלָּבֵ֑ב וְעַ֥יִר פֶּ֝֗רֶא אָדָ֥ם יִוָּלֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Job 11:13",
      "text": "אִם ־ אַ֭תָּ֗ה הֲכִינ֣וֹתָ לִבֶּ֑ךָ וּפָרַשְׂתָּ֖ אֵלָ֣יו כַּפֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Job 11:14",
      "text": "אִם ־ אָ֣וֶן בְּ֭יָדְךָ הַרְחִיקֵ֑הוּ וְאַל ־ תַּשְׁכֵּ֖ן בְּאֹהָלֶ֣יךָ עַוְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Job 11:15",
      "text": "כִּי ־ אָ֤ז ׀ תִּשָּׂ֣א פָנֶ֣יךָ מִמּ֑וּם וְהָיִ֥יתָ מֻ֝צָ֗ק וְלֹ֣א תִירָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Job 11:16",
      "text": "כִּי ־ אַ֭תָּה עָמָ֣ל תִּשְׁכָּ֑ח כְּמַ֖יִם עָבְר֣וּ תִזְכֹּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Job 11:17",
      "text": "וּֽ֭מִצָּהֳרַיִם יָק֣וּם חָ֑לֶד תָּ֝עֻ֗פָה כַּבֹּ֥קֶר תִּהְיֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Job 11:18",
      "text": "וּֽ֭בָטַחְתָּ כִּי ־ יֵ֣שׁ תִּקְוָ֑ה וְ֝חָפַרְתָּ֗ לָבֶ֥טַח תִּשְׁכָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Job 11:19",
      "text": "וְֽ֭רָבַצְתָּ וְאֵ֣ין מַחֲרִ֑יד וְחִלּ֖וּ פָנֶ֣יךָ רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.11.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Job 11:20",
      "text": "וְעֵינֵ֥י רְשָׁעִ֗ים תִּ֫כְלֶ֥ינָה וּ֭מָנוֹס אָבַ֣ד מִנְהֶ֑ם וְ֝תִקְוָתָ֗ם מַֽפַּח ־ נָֽפֶשׁ ׃ פ",
      "paragraphStart": false
    }
  ]
}
