{
  "chapter": {
    "id": "wlc:job.32",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 32,
    "referenceLabel": "Job 32",
    "summary": "Source text for Job 32 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.32.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Job 32:1",
      "text": "וַֽיִּשְׁבְּת֡וּ שְׁלֹ֤שֶׁת הָאֲנָשִׁ֣ים הָ֭אֵלֶּה מֵעֲנ֣וֹת אֶת ־ אִיּ֑וֹב כִּ֤י ה֖וּא צַדִּ֣יק בְּעֵינָֽיו ׃ פ",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.32.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Job 32:2",
      "text": "וַיִּ֤חַר אַ֨ף ׀ אֱלִיה֣וּא בֶן ־ בַּרַכְאֵ֣ל הַבּוּזִי֮ מִמִּשְׁפַּ֪חַ֫ת רָ֥ם בְּ֭אִיּוֹב חָרָ֣ה אַפּ֑וֹ עַֽל ־ צַדְּק֥וֹ נַ֝פְשׁ֗וֹ מֵאֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Job 32:3",
      "text": "וּבִשְׁלֹ֣שֶׁת רֵעָיו֮ חָרָ֪ה אַ֫פּ֥וֹ עַ֤ל אֲשֶׁ֣ר לֹא ־ מָצְא֣וּ מַעֲנֶ֑ה וַ֝יַּרְשִׁ֗יעוּ אֶת ־ אִיּֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Job 32:4",
      "text": "וֶֽאֱלִיה֗וּ חִכָּ֣ה אֶת ־ אִ֭יּוֹב בִּדְבָרִ֑ים כִּ֤י זְֽקֵנִים ־ הֵ֖מָּה מִמֶּ֣נּוּ לְיָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Job 32:5",
      "text": "וַיַּ֤רְא אֱלִיה֗וּא כִּ֘י אֵ֤ין מַעֲנֶ֗ה בְּ֭פִי שְׁלֹ֥שֶׁת הָאֲנָשִׁ֗ים וַיִּ֥חַר אַפּֽוֹ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Job 32:6",
      "text": "וַיַּ֤עַן ׀ אֱלִיה֖וּא בֶן ־ בַּֽרַכְאֵ֥ל הַבּוּזִ֗י וַיֹּ֫אמַ֥ר צָ֘עִ֤יר אֲנִ֣י לְ֭יָמִים וְאַתֶּ֣ם יְשִׁישִׁ֑ים עַל ־ כֵּ֖ן זָחַ֥לְתִּי וָֽאִירָ֓א ׀ מֵחַוֺּ֖ת דֵּעִ֣י אֶתְכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Job 32:7",
      "text": "אָ֭מַרְתִּי יָמִ֣ים יְדַבֵּ֑רוּ וְרֹ֥ב שָׁ֝נִ֗ים יֹדִ֥יעוּ חָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Job 32:8",
      "text": "אָ֭כֵן רֽוּחַ ־ הִ֣יא בֶאֱנ֑וֹשׁ וְנִשְׁמַ֖ת שַׁדַּ֣י תְּבִינֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Job 32:9",
      "text": "לֹֽא ־ רַבִּ֥ים יֶחְכָּ֑מוּ וּ֝זְקֵנִ֗ים יָבִ֥ינוּ מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Job 32:10",
      "text": "לָכֵ֣ן אָ֭מַרְתִּי שִׁמְעָה ־ לִּ֑י אֲחַוֶּ֖ה דֵּעִ֣י אַף ־ אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Job 32:11",
      "text": "הֵ֤ן הוֹחַ֨לְתִּי לְֽדִבְרֵיכֶ֗ם אָ֭זִין עַד ־ תְּב֥וּנֹֽתֵיכֶ֑ם עַֽד ־ תַּחְקְר֥וּן מִלִּֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Job 32:12",
      "text": "וְעָֽדֵיכֶ֗ם אֶתְבּ֫וֹנָ֥ן וְהִנֵּ֤ה אֵ֣ין לְאִיּ֣וֹב מוֹכִ֑יחַ עוֹנֶ֖ה אֲמָרָ֣יו מִכֶּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Job 32:13",
      "text": "פֶּן ־ תֹּ֣֭אמְרוּ מָצָ֣אנוּ חָכְמָ֑ה אֵ֖ל יִדְּפֶ֣נּוּ לֹא ־ אִֽישׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Job 32:14",
      "text": "וְלֹא ־ עָרַ֣ךְ אֵלַ֣י מִלִּ֑ין וּ֝בְאִמְרֵיכֶ֗ם לֹ֣א אֲשִׁיבֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Job 32:15",
      "text": "חַ֭תּוּ לֹא ־ עָ֣נוּ ע֑וֹד הֶעְתִּ֖יקוּ מֵהֶ֣ם מִלִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Job 32:16",
      "text": "וְ֭הוֹחַלְתִּי כִּי ־ לֹ֣א יְדַבֵּ֑רוּ כִּ֥י עָ֝מְד֗וּ לֹא ־ עָ֥נוּ עֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Job 32:17",
      "text": "אַעֲנֶ֣ה אַף ־ אֲנִ֣י חֶלְקִ֑י אֲחַוֶּ֖ה דֵעִ֣י אַף ־ אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Job 32:18",
      "text": "כִּ֭י מָלֵ֣תִי מִלִּ֑ים הֱ֝צִיקַ֗תְנִי ר֣וּחַ בִּטְנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Job 32:19",
      "text": "הִנֵּֽה ־ בִטְנִ֗י כְּיַ֥יִן לֹא ־ יִפָּתֵ֑חַ כְּאֹב֥וֹת חֲ֝דָשִׁ֗ים יִבָּקֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Job 32:20",
      "text": "אֲדַבְּרָ֥ה וְיִֽרְוַֽח ־ לִ֑י אֶפְתַּ֖ח שְׂפָתַ֣י וְאֶֽעֱנֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Job 32:21",
      "text": "אַל ־ נָ֭א אֶשָּׂ֣א פְנֵי ־ אִ֑ישׁ וְאֶל ־ אָ֝דָ֗ם לֹ֣א אֲכַנֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.32.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Job 32:22",
      "text": "כִּ֤י לֹ֣א יָדַ֣עְתִּי אֲכַנֶּ֑ה כִּ֝מְעַ֗ט יִשָּׂאֵ֥נִי עֹשֵֽׂנִי ׃",
      "paragraphStart": false
    }
  ]
}
