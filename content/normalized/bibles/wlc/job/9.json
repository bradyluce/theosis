{
  "chapter": {
    "id": "wlc:job.9",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 9,
    "referenceLabel": "Job 9",
    "summary": "Source text for Job 9 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.9.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Job 9:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.9.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Job 9:2",
      "text": "אָ֭מְנָם יָדַ֣עְתִּי כִי ־ כֵ֑ן וּמַה ־ יִּצְדַּ֖ק אֱנ֣וֹשׁ עִם ־ אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Job 9:3",
      "text": "אִם ־ יַ֭חְפֹּץ לָרִ֣יב עִמּ֑וֹ לֹֽא ־ יַ֝עֲנֶ֗נּוּ אַחַ֥ת מִנִּי ־ אָֽלֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Job 9:4",
      "text": "חֲכַ֣ם לֵ֭בָב וְאַמִּ֣יץ כֹּ֑חַ מִֽי ־ הִקְשָׁ֥ה אֵ֝לָ֗יו וַיִּשְׁלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Job 9:5",
      "text": "הַמַּעְתִּ֣יק הָ֭רִים וְלֹ֣א יָדָ֑עוּ אֲשֶׁ֖ר הֲפָכָ֣ם בְּאַפּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Job 9:6",
      "text": "הַמַּרְגִּ֣יז אֶ֭רֶץ מִמְּקוֹמָ֑הּ וְ֝עַמּוּדֶ֗יהָ יִתְפַלָּצֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Job 9:7",
      "text": "הָאֹמֵ֣ר לַ֭חֶרֶס וְלֹ֣א יִזְרָ֑ח וּבְעַ֖ד כּוֹכָבִ֣ים יַחְתֹּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Job 9:8",
      "text": "נֹטֶ֣ה שָׁמַ֣יִם לְבַדּ֑וֹ וְ֝דוֹרֵ֗ךְ עַל ־ בָּ֥מֳתֵי יָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Job 9:9",
      "text": "עֹֽשֶׂה ־ עָ֭שׁ כְּסִ֥יל וְכִימָ֗ה וְחַדְרֵ֥י תֵמָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Job 9:10",
      "text": "עֹשֶׂ֣ה גְ֭דֹלוֹת עַד ־ אֵ֣ין חֵ֑קֶר וְנִפְלָא֗וֹת עַד ־ אֵ֥ין מִסְפָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Job 9:11",
      "text": "הֵ֤ן יַעֲבֹ֣ר עָ֭לַי וְלֹ֣א אֶרְאֶ֑ה וְ֝יַחֲלֹ֗ף וְֽלֹא ־ אָבִ֥ין לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Job 9:12",
      "text": "הֵ֣ן יַ֭חְתֹּף מִ֣י יְשִׁיבֶ֑נּוּ מִֽי ־ יֹאמַ֥ר אֵ֝לָ֗יו מַֽה ־ תַּעֲשֶֽׂה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Job 9:13",
      "text": "אֱ֭לוֹהַּ לֹא ־ יָשִׁ֣יב אַפּ֑וֹ תחתו שָׁ֝חֲח֗וּ עֹ֣זְרֵי רָֽהַב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Job 9:14",
      "text": "אַ֭ף כִּֽי ־ אָנֹכִ֣י אֶֽעֱנֶ֑נּוּ אֶבְחֲרָ֖ה דְבָרַ֣י עִמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Job 9:15",
      "text": "אֲשֶׁ֣ר אִם ־ צָ֭דַקְתִּי לֹ֣א אֶעֱנֶ֑ה לִ֝מְשֹׁפְטִ֗י אֶתְחַנָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Job 9:16",
      "text": "אִם ־ קָרָ֥אתִי וַֽיַּעֲנֵ֑נִי לֹֽא ־ אַ֝אֲמִ֗ין כִּֽי ־ יַאֲזִ֥ין קוֹלִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Job 9:17",
      "text": "אֲשֶׁר ־ בִּשְׂעָרָ֥ה יְשׁוּפֵ֑נִי וְהִרְבָּ֖ה פְצָעַ֣י חִנָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Job 9:18",
      "text": "לֹֽא ־ יִ֭תְּנֵנִי הָשֵׁ֣ב רוּחִ֑י כִּ֥י יַ֝שְׂבִּעַ֗נִי מַמְּרֹרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Job 9:19",
      "text": "אִם ־ לְכֹ֣חַ אַמִּ֣יץ הִנֵּ֑ה וְאִם ־ לְ֝מִשְׁפָּ֗ט מִ֣י יוֹעִידֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Job 9:20",
      "text": "אִם ־ אֶ֭צְדָּק פִּ֣י יַרְשִׁיעֵ֑נִי תָּֽם ־ אָ֝֗נִי וַֽיַּעְקְשֵֽׁנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Job 9:21",
      "text": "תָּֽם ־ אָ֭נִי לֹֽא ־ אֵדַ֥ע נַפְשִׁ֗י אֶמְאַ֥ס חַיָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Job 9:22",
      "text": "אַחַ֗ת הִ֥יא עַל ־ כֵּ֥ן אָמַ֑רְתִּי תָּ֥ם וְ֝רָשָׁ֗ע ה֣וּא מְכַלֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Job 9:23",
      "text": "אִם ־ שׁ֭וֹט יָמִ֣ית פִּתְאֹ֑ם לְמַסַּ֖ת נְקִיִּ֣ם יִלְעָֽג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Job 9:24",
      "text": "אֶ֤רֶץ ׀ נִתְּנָ֬ה בְֽיַד ־ רָשָׁ֗ע פְּנֵֽי ־ שֹׁפְטֶ֥יהָ יְכַסֶּ֑ה אִם ־ לֹ֖א אֵפ֣וֹא מִי ־ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Job 9:25",
      "text": "וְיָמַ֣י קַ֭לּוּ מִנִּי ־ רָ֑ץ בָּֽ֝רְח֗וּ לֹא ־ רָא֥וּ טוֹבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Job 9:26",
      "text": "חָ֭לְפוּ עִם ־ אֳנִיּ֣וֹת אֵבֶ֑ה כְּ֝נֶ֗שֶׁר יָט֥וּשׂ עֲלֵי ־ אֹֽכֶל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Job 9:27",
      "text": "אִם ־ אָ֭מְרִי אֶשְׁכְּחָ֣ה שִׂיחִ֑י אֶעֶזְבָ֖ה פָנַ֣י וְאַבְלִֽיגָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Job 9:28",
      "text": "יָגֹ֥רְתִּי כָל ־ עַצְּבֹתָ֑י יָ֝דַ֗עְתִּי כִּי ־ לֹ֥א תְנַקֵּֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Job 9:29",
      "text": "אָנֹכִ֥י אֶרְשָׁ֑ע לָמָּה ־ זֶּ֝֗ה הֶ֣בֶל אִיגָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Job 9:30",
      "text": "אִם ־ הִתְרָחַ֥צְתִּי במו ־ שָׁ֑לֶג וַ֝הֲזִכּ֗וֹתִי בְּבֹ֣ר כַּפָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Job 9:31",
      "text": "אָ֭ז בַּשַּׁ֣חַת תִּטְבְּלֵ֑נִי וְ֝תִֽעֲב֗וּנִי שַׂלְמוֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Job 9:32",
      "text": "כִּי ־ לֹא ־ אִ֣ישׁ כָּמֹ֣נִי אֶֽעֱנֶ֑נּוּ נָב֥וֹא יַ֝חְדָּ֗ו בַּמִּשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Job 9:33",
      "text": "לֹ֣א יֵשׁ ־ בֵּינֵ֣ינוּ מוֹכִ֑יחַ יָשֵׁ֖ת יָד֣וֹ עַל ־ שְׁנֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.34",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Job 9:34",
      "text": "יָסֵ֣ר מֵעָלַ֣י שִׁבְט֑וֹ וְ֝אֵמָת֗וֹ אַֽל ־ תְּבַעֲתַֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.9.35",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Job 9:35",
      "text": "אַֽ֭דַבְּרָה וְלֹ֣א אִירָאֶ֑נּוּ כִּ֥י לֹא ־ כֵ֥ן אָ֝נֹכִ֗י עִמָּדִֽי ׃",
      "paragraphStart": false
    }
  ]
}
