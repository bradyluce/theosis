{
  "chapter": {
    "id": "wlc:job.34",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 34,
    "referenceLabel": "Job 34",
    "summary": "Source text for Job 34 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.34.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Job 34:1",
      "text": "וַיַּ֥עַן אֱלִיה֗וּא וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.34.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Job 34:2",
      "text": "שִׁמְע֣וּ חֲכָמִ֣ים מִלָּ֑י וְ֝יֹדְעִ֗ים הַאֲזִ֥ינוּ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Job 34:3",
      "text": "כִּי ־ אֹ֭זֶן מִלִּ֣ין תִּבְחָ֑ן וְ֝חֵ֗ךְ יִטְעַ֥ם לֶאֱכֹֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Job 34:4",
      "text": "מִשְׁפָּ֥ט נִבְחֲרָה ־ לָּ֑נוּ נֵדְעָ֖ה בֵינֵ֣ינוּ מַה ־ טּֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Job 34:5",
      "text": "כִּֽי ־ אָ֭מַר אִיּ֣וֹב צָדַ֑קְתִּי וְ֝אֵ֗ל הֵסִ֥יר מִשְׁפָּטִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Job 34:6",
      "text": "עַל ־ מִשְׁפָּטִ֥י אֲכַזֵּ֑ב אָנ֖וּשׁ חִצִּ֣י בְלִי ־ פָֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Job 34:7",
      "text": "מִי ־ גֶ֥בֶר כְּאִיּ֑וֹב יִֽשְׁתֶּה ־ לַּ֥עַג כַּמָּֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Job 34:8",
      "text": "וְאָרַ֣ח לְ֭חֶבְרָה עִם ־ פֹּ֣עֲלֵי אָ֑וֶן וְ֝לָלֶ֗כֶת עִם ־ אַנְשֵׁי ־ רֶֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Job 34:9",
      "text": "כִּֽי ־ אָ֭מַר לֹ֣א יִסְכָּן ־ גָּ֑בֶר בִּ֝רְצֹת֗וֹ עִם ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Job 34:10",
      "text": "לָכֵ֤ן ׀ אַ֥נֲשֵׁ֥י לֵבָ֗ב שִׁמְע֫וּ לִ֥י חָלִ֖לָה לָאֵ֥ל מֵרֶ֗שַׁע וְשַׁדַּ֥י מֵעָֽוֶל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Job 34:11",
      "text": "כִּ֤י פֹ֣עַל אָ֭דָם יְשַׁלֶּם ־ ל֑וֹ וּֽכְאֹ֥רַח אִ֝֗ישׁ יַמְצִאֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Job 34:12",
      "text": "אַף ־ אָמְנָ֗ם אֵ֥ל לֹֽא ־ יַרְשִׁ֑יעַ וְ֝שַׁדַּ֗י לֹֽא ־ יְעַוֵּ֥ת מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Job 34:13",
      "text": "מִֽי ־ פָקַ֣ד עָלָ֣יו אָ֑רְצָה וּמִ֥י שָׂ֝֗ם תֵּבֵ֥ל כֻּלָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Job 34:14",
      "text": "אִם ־ יָשִׂ֣ים אֵלָ֣יו לִבּ֑וֹ רוּח֥וֹ וְ֝נִשְׁמָת֗וֹ אֵלָ֥יו יֶאֱסֹֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Job 34:15",
      "text": "יִגְוַ֣ע כָּל ־ בָּשָׂ֣ר יָ֑חַד וְ֝אָדָ֗ם עַל ־ עָפָ֥ר יָשֽׁוּב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Job 34:16",
      "text": "וְאִם ־ בִּ֥ינָה שִׁמְעָה ־ זֹּ֑את הַ֝אֲזִ֗ינָה לְק֣וֹל מִלָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Job 34:17",
      "text": "הַאַ֬ף שׂוֹנֵ֣א מִשְׁפָּ֣ט יַחֲב֑וֹשׁ וְאִם ־ צַדִּ֖יק כַּבִּ֣יר תַּרְשִֽׁיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Job 34:18",
      "text": "הַאֲמֹ֣ר לְמֶ֣לֶךְ בְּלִיָּ֑עַל רָ֝שָׁ֗ע אֶל ־ נְדִיבִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Job 34:19",
      "text": "אֲשֶׁ֤ר לֹֽא ־ נָשָׂ֨א ׀ פְּנֵ֥י שָׂרִ֗ים וְלֹ֣א נִכַּר ־ שׁ֭וֹעַ לִפְנֵי ־ דָ֑ל כִּֽי ־ מַעֲשֵׂ֖ה יָדָ֣יו כֻּלָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Job 34:20",
      "text": "רֶ֤גַע ׀ יָמֻתוּ֮ וַחֲצ֪וֹת לָ֥יְלָה יְגֹעֲשׁ֣וּ עָ֣ם וְיַעֲבֹ֑רוּ וְיָסִ֥ירוּ אַ֝בִּ֗יר לֹ֣א בְיָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Job 34:21",
      "text": "כִּי ־ עֵ֭ינָיו עַל ־ דַּרְכֵי ־ אִ֑ישׁ וְֽכָל ־ צְעָדָ֥יו יִרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Job 34:22",
      "text": "אֵֽין ־ חֹ֭שֶׁךְ וְאֵ֣ין צַלְמָ֑וֶת לְהִסָּ֥תֶר שָׁ֝֗ם פֹּ֣עֲלֵי אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Job 34:23",
      "text": "כִּ֤י לֹ֣א עַל ־ אִ֭ישׁ יָשִׂ֣ים ע֑וֹד לַהֲלֹ֥ךְ אֶל ־ אֵ֝֗ל בַּמִּשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Job 34:24",
      "text": "יָרֹ֣עַ כַּבִּירִ֣ים לֹא ־ חֵ֑קֶר וַיַּעֲמֵ֖ד אֲחֵרִ֣ים תַּחְתָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Job 34:25",
      "text": "לָכֵ֗ן יַ֭כִּיר מַעְבָּֽדֵיהֶ֑ם וְהָ֥פַךְ לַ֝֗יְלָה וְיִדַּכָּֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Job 34:26",
      "text": "תַּֽחַת ־ רְשָׁעִ֥ים סְפָקָ֗ם בִּמְק֥וֹם רֹאִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Job 34:27",
      "text": "אֲשֶׁ֣ר עַל ־ כֵּ֭ן סָ֣רוּ מֵֽאַחֲרָ֑יו וְכָל ־ דְּ֝רָכָ֗יו לֹ֣א הִשְׂכִּֽילוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Job 34:28",
      "text": "לְהָבִ֣יא עָ֭לָיו צַֽעֲקַת ־ דָּ֑ל וְצַעֲקַ֖ת עֲנִיִּ֣ים יִשְׁמָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Job 34:29",
      "text": "וְה֤וּא יַשְׁקִ֨ט ׀ וּמִ֥י יַרְשִׁ֗עַ וְיַסְתֵּ֣ר פָּ֭נִים וּמִ֣י יְשׁוּרֶ֑נּוּ וְעַל ־ גּ֖וֹי וְעַל ־ אָדָ֣ם יָֽחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 30,
      "referenceLabel": "Job 34:30",
      "text": "מִ֭מְּלֹךְ אָדָ֥ם חָנֵ֗ף מִמֹּ֥קְשֵׁי עָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 31,
      "referenceLabel": "Job 34:31",
      "text": "כִּֽי ־ אֶל ־ אֵ֭ל הֶאָמַ֥ר נָשָׂ֗אתִי לֹ֣א אֶחְבֹּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 32,
      "referenceLabel": "Job 34:32",
      "text": "בִּלְעֲדֵ֣י אֶ֭חֱזֶה אַתָּ֣ה הֹרֵ֑נִי אִֽם ־ עָ֥וֶל פָּ֝עַ֗לְתִּי לֹ֣א אֹסִֽיף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 33,
      "referenceLabel": "Job 34:33",
      "text": "הַֽמֵעִמְּךָ֬ יְשַׁלְמֶ֨נָּה כִּֽי ־ מָאַ֗סְתָּ כִּי ־ אַתָּ֣ה תִבְחַ֣ר וְלֹא ־ אָ֑נִי וּֽמַה ־ יָדַ֥עְתָּ דַבֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.34",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 34,
      "referenceLabel": "Job 34:34",
      "text": "אַנְשֵׁ֣י לֵ֭בָב יֹ֣אמְרוּ לִ֑י וְגֶ֥בֶר חָ֝כָ֗ם שֹׁמֵ֥עַֽ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.35",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 35,
      "referenceLabel": "Job 34:35",
      "text": "אִ֭יּוֹב לֹא ־ בְדַ֣עַת יְדַבֵּ֑ר וּ֝דְבָרָ֗יו לֹ֣א בְהַשְׂכֵּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.36",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 36,
      "referenceLabel": "Job 34:36",
      "text": "אָבִ֗י יִבָּחֵ֣ן אִיּ֣וֹב עַד ־ נֶ֑צַח עַל ־ תְּ֝שֻׁבֹ֗ת בְּאַנְשֵׁי ־ אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.34.37",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 37,
      "referenceLabel": "Job 34:37",
      "text": "כִּ֥י יֹ֘סִ֤יף עַֽל ־ חַטָּאת֣וֹ פֶ֭שַׁע בֵּינֵ֣ינוּ יִסְפּ֑וֹק וְיֶ֖רֶב אֲמָרָ֣יו לָאֵֽל ׃ ס",
      "paragraphStart": false
    }
  ]
}
