{
  "chapter": {
    "id": "wlc:job.21",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 21,
    "referenceLabel": "Job 21",
    "summary": "Source text for Job 21 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.21.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Job 21:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.21.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Job 21:2",
      "text": "שִׁמְע֣וּ שָׁ֭מוֹעַ מִלָּתִ֑י וּתְהִי ־ זֹ֝֗את תַּנְח֥וּמֹֽתֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Job 21:3",
      "text": "שָׂ֭אוּנִי וְאָנֹכִ֣י אֲדַבֵּ֑ר וְאַחַ֖ר דַּבְּרִ֣י תַלְעִֽיג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Job 21:4",
      "text": "הֶ֭אָנֹכִי לְאָדָ֣ם שִׂיחִ֑י וְאִם ־ מַ֝דּ֗וּעַ לֹא ־ תִקְצַ֥ר רוּחִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Job 21:5",
      "text": "פְּנוּ ־ אֵלַ֥י וְהָשַׁ֑מּוּ וְשִׂ֖ימוּ יָ֣ד עַל ־ פֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Job 21:6",
      "text": "וְאִם ־ זָכַ֥רְתִּי וְנִבְהָ֑לְתִּי וְאָחַ֥ז בְּ֝שָׂרִ֗י פַּלָּצֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Job 21:7",
      "text": "מַדּ֣וּעַ רְשָׁעִ֣ים יִחְי֑וּ עָ֝תְק֗וּ גַּם ־ גָּ֥בְרוּ חָֽיִל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Job 21:8",
      "text": "זַרְעָ֤ם נָכ֣וֹן לִפְנֵיהֶ֣ם עִמָּ֑ם וְ֝צֶאֱצָאֵיהֶ֗ם לְעֵינֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Job 21:9",
      "text": "בָּתֵּיהֶ֣ם שָׁל֣וֹם מִפָּ֑חַד וְלֹ֤א שֵׁ֖בֶט אֱל֣וֹהַּ עֲלֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Job 21:10",
      "text": "שׁוֹר֣וֹ עִ֭בַּר וְלֹ֣א יַגְעִ֑ל תְּפַלֵּ֥ט פָּ֝רָת֗וֹ וְלֹ֣א תְשַׁכֵּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Job 21:11",
      "text": "יְשַׁלְּח֣וּ כַ֭צֹּאן עֲוִילֵיהֶ֑ם וְ֝יַלְדֵיהֶ֗ם יְרַקֵּדֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Job 21:12",
      "text": "יִ֭שְׂאוּ כְּתֹ֣ף וְכִנּ֑וֹר וְ֝יִשְׂמְח֗וּ לְק֣וֹל עוּגָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Job 21:13",
      "text": "יבלו בַטּ֣וֹב יְמֵיהֶ֑ם וּ֝בְרֶ֗גַע שְׁא֣וֹל יֵחָֽתּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Job 21:14",
      "text": "וַיֹּאמְר֣וּ לָ֭אֵל ס֣וּר מִמֶּ֑נּוּ וְדַ֥עַת דְּ֝רָכֶ֗יךָ לֹ֣א חָפָֽצְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Job 21:15",
      "text": "מַה ־ שַׁדַּ֥י כִּֽי ־ נַֽעַבְדֶ֑נּוּ וּמַה ־ נּ֝וֹעִ֗יל כִּ֣י נִפְגַּע ־ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Job 21:16",
      "text": "הֵ֤ן לֹ֣א בְיָדָ֣ם טוּבָ֑ם עֲצַ֥ת רְ֝שָׁעִ֗ים רָ֣חֲקָה מֶֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Job 21:17",
      "text": "כַּמָּ֤ה ׀ נֵר ־ רְשָׁ֘עִ֤ים יִדְעָ֗ךְ וְיָבֹ֣א עָלֵ֣ימוֹ אֵידָ֑ם חֲ֝בָלִ֗ים יְחַלֵּ֥ק בְּאַפּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Job 21:18",
      "text": "יִהְי֗וּ כְּתֶ֥בֶן לִפְנֵי ־ ר֑וּחַ וּ֝כְמֹ֗ץ גְּנָבַ֥תּוּ סוּפָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Job 21:19",
      "text": "אֱל֗וֹהַּ יִצְפֹּן ־ לְבָנָ֥יו אוֹנ֑וֹ יְשַׁלֵּ֖ם אֵלָ֣יו וְיֵדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Job 21:20",
      "text": "יִרְא֣וּ עינו כִּיד֑וֹ וּמֵחֲמַ֖ת שַׁדַּ֣י יִשְׁתֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Job 21:21",
      "text": "כִּ֤י מַה ־ חֶפְצ֣וֹ בְּבֵית֣וֹ אַחֲרָ֑יו וּמִסְפַּ֖ר חֳדָשָׁ֣יו חֻצָּֽצוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Job 21:22",
      "text": "הַלְאֵ֥ל יְלַמֶּד ־ דָּ֑עַת וְ֝ה֗וּא רָמִ֥ים יִשְׁפּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Job 21:23",
      "text": "זֶ֗ה יָ֭מוּת בְּעֶ֣צֶם תֻּמּ֑וֹ כֻּ֝לּ֗וֹ שַׁלְאֲנַ֥ן וְשָׁלֵֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Job 21:24",
      "text": "עֲ֭טִינָיו מָלְא֣וּ חָלָ֑ב וּמֹ֖חַ עַצְמוֹתָ֣יו יְשֻׁקֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Job 21:25",
      "text": "וְזֶ֗ה יָ֭מוּת בְּנֶ֣פֶשׁ מָרָ֑ה וְלֹֽא ־ אָ֝כַ֗ל בַּטּוֹבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Job 21:26",
      "text": "יַ֭חַד עַל ־ עָפָ֣ר יִשְׁכָּ֑בוּ וְ֝רִמָּ֗ה תְּכַסֶּ֥ה עֲלֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Job 21:27",
      "text": "הֵ֣ן יָ֭דַעְתִּי מַחְשְׁבֽוֹתֵיכֶ֑ם וּ֝מְזִמּ֗וֹת עָלַ֥י תַּחְמֹֽסוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Job 21:28",
      "text": "כִּ֤י תֹֽאמְר֗וּ אַיֵּ֥ה בֵית ־ נָדִ֑יב וְ֝אַיֵּ֗ה אֹ֤הֶל ׀ מִשְׁכְּנ֬וֹת רְשָׁעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Job 21:29",
      "text": "הֲלֹ֣א שְׁ֭אֶלְתֶּם ע֣וֹבְרֵי דָ֑רֶךְ וְ֝אֹתֹתָ֗ם לֹ֣א תְנַכֵּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Job 21:30",
      "text": "כִּ֤י לְי֣וֹם אֵ֭יד יֵחָ֣שֶׂךְ רָ֑ע לְי֖וֹם עֲבָר֣וֹת יוּבָֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Job 21:31",
      "text": "מִֽי ־ יַגִּ֣יד עַל ־ פָּנָ֣יו דַּרְכּ֑וֹ וְהֽוּא ־ עָ֝שָׂ֗ה מִ֣י יְשַׁלֶּם ־ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Job 21:32",
      "text": "וְ֭הוּא לִקְבָר֣וֹת יוּבָ֑ל וְֽעַל ־ גָּדִ֥ישׁ יִשְׁקֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Job 21:33",
      "text": "מָֽתְקוּ ־ ל֗וֹ רִגְבֵ֫י נָ֥חַל וְ֭אַחֲרָיו כָּל ־ אָדָ֣ם יִמְשׁ֑וֹךְ וּ֝לְפָנָ֗יו אֵ֣ין מִסְפָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.21.34",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Job 21:34",
      "text": "וְ֭אֵיךְ תְּנַחֲמ֣וּנִי הָ֑בֶל וּ֝תְשֽׁוּבֹתֵיכֶ֗ם נִשְׁאַר ־ מָֽעַל ׃ ס",
      "paragraphStart": false
    }
  ]
}
