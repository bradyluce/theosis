{
  "chapter": {
    "id": "wlc:job.41",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 41,
    "referenceLabel": "Job 41",
    "summary": "Source text for Job 41 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.41.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Job 41:1",
      "text": "הֵן ־ תֹּחַלְתּ֥וֹ נִכְזָ֑בָה הֲגַ֖ם אֶל ־ מַרְאָ֣יו יֻטָֽל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.41.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Job 41:2",
      "text": "לֹֽא ־ אַ֭כְזָר כִּ֣י יְעוּרֶ֑נּוּ וּמִ֥י ה֝֗וּא לְפָנַ֥י יִתְיַצָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Job 41:3",
      "text": "מִ֣י הִ֭קְדִּימַנִי וַאֲשַׁלֵּ֑ם תַּ֖חַת כָּל ־ הַשָּׁמַ֣יִם לִי ־ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Job 41:4",
      "text": "לא ־ אַחֲרִ֥ישׁ בַּדָּ֑יו וּדְבַר ־ גְּ֝בוּר֗וֹת וְחִ֣ין עֶרְכּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Job 41:5",
      "text": "מִֽי ־ גִ֭לָּה פְּנֵ֣י לְבוּשׁ֑וֹ בְּכֶ֥פֶל רִ֝סְנ֗וֹ מִ֣י יָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Job 41:6",
      "text": "דַּלְתֵ֣י פָ֭נָיו מִ֣י פִתֵּ֑חַ סְבִיב֖וֹת שִׁנָּ֣יו אֵימָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Job 41:7",
      "text": "גַּ֭אֲוָה אֲפִיקֵ֣י מָֽגִנִּ֑ים סָ֝ג֗וּר חוֹתָ֥ם צָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Job 41:8",
      "text": "אֶחָ֣ד בְּאֶחָ֣ד יִגַּ֑שׁוּ וְ֝ר֗וּחַ לֹא ־ יָב֥וֹא בֵֽינֵיהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Job 41:9",
      "text": "אִישׁ ־ בְּאָחִ֥יהוּ יְדֻבָּ֑קוּ יִ֝תְלַכְּד֗וּ וְלֹ֣א יִתְפָּרָֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Job 41:10",
      "text": "עֲֽ֭טִישֹׁתָיו תָּ֣הֶל א֑וֹר וְ֝עֵינָ֗יו כְּעַפְעַפֵּי ־ שָֽׁחַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Job 41:11",
      "text": "מִ֭פִּיו לַפִּידִ֣ים יַהֲלֹ֑כוּ כִּיד֥וֹדֵי אֵ֝֗שׁ יִתְמַלָּֽטוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Job 41:12",
      "text": "מִ֭נְּחִירָיו יֵצֵ֣א עָשָׁ֑ן כְּד֖וּד נָפ֣וּחַ וְאַגְמֹֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Job 41:13",
      "text": "נַ֭פְשׁוֹ גֶּחָלִ֣ים תְּלַהֵ֑ט וְ֝לַ֗הַב מִפִּ֥יו יֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 14,
      "referenceLabel": "Job 41:14",
      "text": "בְּֽ֭צַוָּארוֹ יָלִ֣ין עֹ֑ז וּ֝לְפָנָ֗יו תָּד֥וּץ דְּאָבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 15,
      "referenceLabel": "Job 41:15",
      "text": "מַפְּלֵ֣י בְשָׂר֣וֹ דָבֵ֑קוּ יָצ֥וּק עָ֝לָ֗יו בַּל ־ יִמּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 16,
      "referenceLabel": "Job 41:16",
      "text": "לִ֭בּוֹ יָצ֣וּק כְּמוֹ ־ אָ֑בֶן וְ֝יָצ֗וּק כְּפֶ֣לַח תַּחְתִּֽית ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 17,
      "referenceLabel": "Job 41:17",
      "text": "מִ֭שֵּׂתוֹ יָג֣וּרוּ אֵלִ֑ים מִ֝שְּׁבָרִ֗ים יִתְחַטָּֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 18,
      "referenceLabel": "Job 41:18",
      "text": "מַשִּׂיגֵ֣הוּ חֶ֭רֶב בְּלִ֣י תָק֑וּם חֲנִ֖ית מַסָּ֣ע וְשִׁרְיָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 19,
      "referenceLabel": "Job 41:19",
      "text": "יַחְשֹׁ֣ב לְתֶ֣בֶן בַּרְזֶ֑ל לְעֵ֖ץ רִקָּב֣וֹן נְחוּשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 20,
      "referenceLabel": "Job 41:20",
      "text": "לֹֽא ־ יַבְרִיחֶ֥נּוּ בֶן ־ קָ֑שֶׁת לְ֝קַ֗שׁ נֶהְפְּכוּ ־ ל֥וֹ אַבְנֵי ־ קָֽלַע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 21,
      "referenceLabel": "Job 41:21",
      "text": "כְּ֭קַשׁ נֶחְשְׁב֣וּ תוֹתָ֑ח וְ֝יִשְׂחַ֗ק לְרַ֣עַשׁ כִּידֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 22,
      "referenceLabel": "Job 41:22",
      "text": "תַּ֭חְתָּיו חַדּ֣וּדֵי חָ֑רֶשׂ יִרְפַּ֖ד חָר֣וּץ עֲלֵי ־ טִֽיט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 23,
      "referenceLabel": "Job 41:23",
      "text": "יַרְתִּ֣יחַ כַּסִּ֣יר מְצוּלָ֑ה יָ֝֗ם יָשִׂ֥ים כַּמֶּרְקָחָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 24,
      "referenceLabel": "Job 41:24",
      "text": "אַ֭חֲרָיו יָאִ֣יר נָתִ֑יב יַחְשֹׁ֖ב תְּה֣וֹם לְשֵׂיבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 25,
      "referenceLabel": "Job 41:25",
      "text": "אֵֽין ־ עַל ־ עָפָ֥ר מָשְׁל֑וֹ הֶ֝עָשׂ֗וּ לִבְלִי ־ חָֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.41.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 26,
      "referenceLabel": "Job 41:26",
      "text": "אֵֽת ־ כָּל ־ גָּבֹ֥הַּ יִרְאֶ֑ה ה֝֗וּא מֶ֣לֶךְ עַל ־ כָּל ־ בְּנֵי ־ שָֽׁחַץ ׃ ס",
      "paragraphStart": false
    }
  ]
}
