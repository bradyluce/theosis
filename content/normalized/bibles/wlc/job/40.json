{
  "chapter": {
    "id": "wlc:job.40",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 40,
    "referenceLabel": "Job 40",
    "summary": "Source text for Job 40 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.40.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Job 40:1",
      "text": "וַיַּ֖עַן יְהוָ֥ה אֶת ־ אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.40.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Job 40:2",
      "text": "הֲ֭רֹב עִם ־ שַׁדַּ֣י יִסּ֑וֹר מוֹכִ֖יחַ אֱל֣וֹהַּ יַעֲנֶֽנָּה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Job 40:3",
      "text": "וַיַּ֖עַן אִיּ֥וֹב אֶת ־ יְהוָ֗ה וַיֹּאמַֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Job 40:4",
      "text": "הֵ֣ן קַ֭לֹּתִי מָ֣ה אֲשִׁיבֶ֑ךָּ יָ֝דִ֗י שַׂ֣מְתִּי לְמוֹ ־ פִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Job 40:5",
      "text": "אַחַ֣ת דִּ֭בַּרְתִּי וְלֹ֣א אֶֽעֱנֶ֑ה וּ֝שְׁתַּ֗יִם וְלֹ֣א אוֹסִֽיף ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Job 40:6",
      "text": "וַיַּֽעַן ־ יְהוָ֣ה אֶת ־ אִ֭יּוֹב מנ סערה וַיֹּאמַֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Job 40:7",
      "text": "אֱזָר ־ נָ֣א כְגֶ֣בֶר חֲלָצֶ֑יךָ אֶ֝שְׁאָלְךָ֗ וְהוֹדִיעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Job 40:8",
      "text": "הַ֭אַף תָּפֵ֣ר מִשְׁפָּטִ֑י תַּ֝רְשִׁיעֵ֗נִי לְמַ֣עַן תִּצְדָּֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Job 40:9",
      "text": "וְאִם ־ זְר֖וֹעַ כָּאֵ֥ל ׀ לָ֑ךְ וּ֝בְק֗וֹל כָּמֹ֥הוּ תַרְעֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Job 40:10",
      "text": "עֲדֵ֥ה נָ֣א גָֽא֣וֹן וָגֹ֑בַהּ וְה֖וֹד וְהָדָ֣ר תִּלְבָּֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Job 40:11",
      "text": "הָ֭פֵץ עֶבְר֣וֹת אַפֶּ֑ךָ וּרְאֵ֥ה כָל ־ גֵּ֝אֶ֗ה וְהַשְׁפִּילֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Job 40:12",
      "text": "רְאֵ֣ה כָל ־ גֵּ֭אֶה הַכְנִיעֵ֑הוּ וַהֲדֹ֖ךְ רְשָׁעִ֣ים תַּחְתָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Job 40:13",
      "text": "טָמְנֵ֣ם בֶּעָפָ֣ר יָ֑חַד פְּ֝נֵיהֶ֗ם חֲבֹ֣שׁ בַּטָּמֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Job 40:14",
      "text": "וְגַם ־ אֲנִ֥י אוֹדֶ֑ךָּ כִּֽי ־ תוֹשִׁ֖עַ לְךָ֣ יְמִינֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 15,
      "referenceLabel": "Job 40:15",
      "text": "הִנֵּה ־ נָ֣א בְ֭הֵמוֹת אֲשֶׁר ־ עָשִׂ֣יתִי עִמָּ֑ךְ חָ֝צִ֗יר כַּבָּקָ֥ר יֹאכֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 16,
      "referenceLabel": "Job 40:16",
      "text": "הִנֵּה ־ נָ֣א כֹח֣וֹ בְמָתְנָ֑יו וְ֝אֹנ֗וֹ בִּשְׁרִירֵ֥י בִטְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 17,
      "referenceLabel": "Job 40:17",
      "text": "יַחְפֹּ֣ץ זְנָב֣וֹ כְמוֹ ־ אָ֑רֶז גִּידֵ֖י פחדו יְשֹׂרָֽגוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 18,
      "referenceLabel": "Job 40:18",
      "text": "עֲ֭צָמָיו אֲפִיקֵ֣י נְחוּשָׁ֑ה גְּ֝רָמָ֗יו כִּמְטִ֥יל בַּרְזֶֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 19,
      "referenceLabel": "Job 40:19",
      "text": "ה֭וּא רֵאשִׁ֣ית דַּרְכֵי ־ אֵ֑ל הָ֝עֹשׂוֹ יַגֵּ֥שׁ חַרְבּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 20,
      "referenceLabel": "Job 40:20",
      "text": "כִּֽי ־ ב֭וּל הָרִ֣ים יִשְׂאוּ ־ ל֑וֹ וְֽכָל ־ חַיַּ֥ת הַ֝שָּׂדֶ֗ה יְשַֽׂחֲקוּ ־ שָֽׁם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 21,
      "referenceLabel": "Job 40:21",
      "text": "תַּֽחַת ־ צֶאֱלִ֥ים יִשְׁכָּ֑ב בְּסֵ֖תֶר קָנֶ֣ה וּבִצָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 22,
      "referenceLabel": "Job 40:22",
      "text": "יְסֻכֻּ֣הוּ צֶאֱלִ֣ים צִֽלֲל֑וֹ יְ֝סֻבּ֗וּהוּ עַרְבֵי ־ נָֽחַל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 23,
      "referenceLabel": "Job 40:23",
      "text": "הֵ֤ן יַעֲשֹׁ֣ק נָ֭הָר לֹ֣א יַחְפּ֑וֹז יִבְטַ֓ח ׀ כִּֽי ־ יָגִ֖יחַ יַרְדֵּ֣ן אֶל ־ פִּֽיהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 24,
      "referenceLabel": "Job 40:24",
      "text": "בְּעֵינָ֥יו יִקָּחֶ֑נּוּ בְּ֝מֽוֹקְשִׁ֗ים יִנְקָב ־ אָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 25,
      "referenceLabel": "Job 40:25",
      "text": "תִּמְשֹׁ֣ךְ לִוְיָתָ֣ן בְּחַכָּ֑ה וּ֝בְחֶ֗בֶל תַּשְׁקִ֥יעַ לְשֹׁנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 26,
      "referenceLabel": "Job 40:26",
      "text": "הֲתָשִׂ֣ים אַגְמ֣וֹן בְּאַפּ֑וֹ וּ֝בְח֗וֹחַ תִּקּ֥וֹב לֶֽחֱיוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 27,
      "referenceLabel": "Job 40:27",
      "text": "הֲיַרְבֶּ֣ה אֵ֭לֶיךָ תַּחֲנוּנִ֑ים אִם ־ יְדַבֵּ֖ר אֵלֶ֣יךָ רַכּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 28,
      "referenceLabel": "Job 40:28",
      "text": "הֲיִכְרֹ֣ת בְּרִ֣ית עִמָּ֑ךְ תִּ֝קָּחֶ֗נּוּ לְעֶ֣בֶד עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 29,
      "referenceLabel": "Job 40:29",
      "text": "הַֽתְשַׂחֶק ־ בּ֭וֹ כַּצִּפּ֑וֹר וְ֝תִקְשְׁרֶ֗נּוּ לְנַעֲרוֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 30,
      "referenceLabel": "Job 40:30",
      "text": "יִכְר֣וּ עָ֭לָיו חַבָּרִ֑ים יֶ֝חֱצ֗וּהוּ בֵּ֣ין כְּֽנַעֲנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 31,
      "referenceLabel": "Job 40:31",
      "text": "הַֽתְמַלֵּ֣א בְשֻׂכּ֣וֹת עוֹר֑וֹ וּבְצִלְצַ֖ל דָּגִ֣ים רֹאשֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.40.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 32,
      "referenceLabel": "Job 40:32",
      "text": "שִׂים ־ עָלָ֥יו כַּפֶּ֑ךָ זְכֹ֥ר מִ֝לְחָמָ֗ה אַל ־ תּוֹסַֽף ׃",
      "paragraphStart": false
    }
  ]
}
