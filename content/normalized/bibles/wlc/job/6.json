{
  "chapter": {
    "id": "wlc:job.6",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 6,
    "referenceLabel": "Job 6",
    "summary": "Source text for Job 6 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.6.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Job 6:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.6.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Job 6:2",
      "text": "ל֗וּ שָׁק֣וֹל יִשָּׁקֵ֣ל כַּעְשִׂ֑י והיתי בְּֽמֹאזְנַ֥יִם יִשְׂאוּ ־ יָֽחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Job 6:3",
      "text": "כִּֽי ־ עַתָּ֗ה מֵח֣וֹל יַמִּ֣ים יִכְבָּ֑ד עַל ־ כֵּ֝֗ן דְּבָרַ֥י לָֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Job 6:4",
      "text": "כִּ֤י חִצֵּ֪י שַׁדַּ֡י עִמָּדִ֗י אֲשֶׁ֣ר חֲ֭מָתָם שֹׁתָ֣ה רוּחִ֑י בִּעוּתֵ֖י אֱל֣וֹהַּ יַֽעַרְכֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Job 6:5",
      "text": "הֲיִֽנְהַק ־ פֶּ֥רֶא עֲלֵי ־ דֶ֑שֶׁא אִ֥ם יִגְעֶה ־ שּׁ֝֗וֹר עַל ־ בְּלִילֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Job 6:6",
      "text": "הֲיֵאָכֵ֣ל תָּ֭פֵל מִבְּלִי ־ מֶ֑לַח אִם ־ יֶשׁ ־ טַ֝֗עַם בְּרִ֣יר חַלָּמֽוּת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Job 6:7",
      "text": "מֵאֲנָ֣ה לִנְגּ֣וֹעַ נַפְשִׁ֑י הֵ֝֗מָּה כִּדְוֵ֥י לַחְמִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Job 6:8",
      "text": "מִֽי ־ יִ֭תֵּן תָּב֣וֹא שֶֽׁאֱלָתִ֑י וְ֝תִקְוָתִ֗י יִתֵּ֥ן אֱלֽוֹהַּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Job 6:9",
      "text": "וְיֹאֵ֣ל אֱ֭לוֹהַּ וִֽידַכְּאֵ֑נִי יַתֵּ֥ר יָ֝ד֗וֹ וִֽיבַצְּעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Job 6:10",
      "text": "וּ֥תְהִי ע֨וֹד ׀ נֶ֘חָ֤מָתִ֗י וַאֲסַלְּדָ֣ה בְ֭חִילָה לֹ֣א יַחְמ֑וֹל כִּי ־ לֹ֥א כִ֝חַ֗דְתִּי אִמְרֵ֥י קָדֽוֹשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Job 6:11",
      "text": "מַה ־ כֹּחִ֥י כִֽי ־ אֲיַחֵ֑ל וּמַה ־ קִּ֝צִּ֗י כִּֽי ־ אַאֲרִ֥יךְ נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Job 6:12",
      "text": "אִם ־ כֹּ֣חַ אֲבָנִ֣ים כֹּחִ֑י אִֽם ־ בְּשָׂרִ֥י נָחֽוּשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Job 6:13",
      "text": "הַאִ֬ם אֵ֣ין עֶזְרָתִ֣י בִ֑י וְ֝תֻשִׁיָּ֗ה נִדְּחָ֥ה מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Job 6:14",
      "text": "לַמָּ֣ס מֵרֵעֵ֣הוּ חָ֑סֶד וְיִרְאַ֖ת שַׁדַּ֣י יַעֲזֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Job 6:15",
      "text": "אַ֭חַי בָּגְד֣וּ כְמוֹ ־ נָ֑חַל כַּאֲפִ֖יק נְחָלִ֣ים יַעֲבֹֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Job 6:16",
      "text": "הַקֹּדְרִ֥ים מִנִּי ־ קָ֑רַח עָ֝לֵ֗ימוֹ יִתְעַלֶּם ־ שָֽׁלֶג ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Job 6:17",
      "text": "בְּ֭עֵת יְזֹרְב֣וּ נִצְמָ֑תוּ בְּ֝חֻמּ֗וֹ נִדְעֲכ֥וּ מִמְּקוֹמָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Job 6:18",
      "text": "יִ֭לָּ֣פְתוּ אָרְח֣וֹת דַּרְכָּ֑ם יַעֲל֖וּ בַתֹּ֣הוּ וְיֹאבֵֽדוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Job 6:19",
      "text": "הִ֭בִּיטוּ אָרְח֣וֹת תֵּמָ֑א הֲלִיכֹ֥ת שְׁ֝בָ֗א קִוּוּ ־ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Job 6:20",
      "text": "בֹּ֥שׁוּ כִּֽי ־ בָטָ֑ח בָּ֥אוּ עָ֝דֶ֗יהָ וַיֶּחְפָּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Job 6:21",
      "text": "כִּֽי ־ עַ֭תָּה הֱיִ֣יתֶם לא תִּֽרְא֥וּ חֲ֝תַ֗ת וַתִּירָֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Job 6:22",
      "text": "הֲֽכִי ־ אָ֭מַרְתִּי הָ֣בוּ לִ֑י וּ֝מִכֹּחֲכֶ֗ם שִׁחֲד֥וּ בַעֲדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Job 6:23",
      "text": "וּמַלְּט֥וּנִי מִיַּד ־ צָ֑ר וּמִיַּ֖ד עָרִיצִ֣ים תִּפְדּֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Job 6:24",
      "text": "ה֭וֹרוּנִי וַאֲנִ֣י אַחֲרִ֑ישׁ וּמַה ־ שָּׁ֝גִ֗יתִי הָבִ֥ינוּ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Job 6:25",
      "text": "מַה ־ נִּמְרְצ֥וּ אִמְרֵי ־ יֹ֑שֶׁר וּמַה ־ יּוֹכִ֖יחַ הוֹכֵ֣חַ מִכֶּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Job 6:26",
      "text": "הַלְהוֹכַ֣ח מִלִּ֣ים תַּחְשֹׁ֑בוּ וּ֝לְר֗וּחַ אִמְרֵ֥י נֹאָֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Job 6:27",
      "text": "אַף ־ עַל ־ יָת֥וֹם תַּפִּ֑ילוּ וְ֝תִכְר֗וּ עַל ־ רֵֽיעֲכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Job 6:28",
      "text": "וְ֭עַתָּה הוֹאִ֣ילוּ פְנוּ ־ בִ֑י וְעַל ־ פְּ֝נֵיכֶ֗ם אִם ־ אֲכַזֵּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Job 6:29",
      "text": "שֻֽׁבוּ ־ נָ֭א אַל ־ תְּהִ֣י עַוְלָ֑ה ושבי ע֝וֹד צִדְקִי ־ בָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.6.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Job 6:30",
      "text": "הֲיֵשׁ ־ בִּלְשׁוֹנִ֥י עַוְלָ֑ה אִם ־ חִ֝כִּ֗י לֹא ־ יָבִ֥ין הַוּֽוֹת ׃",
      "paragraphStart": false
    }
  ]
}
