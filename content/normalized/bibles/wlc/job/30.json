{
  "chapter": {
    "id": "wlc:job.30",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 30,
    "referenceLabel": "Job 30",
    "summary": "Source text for Job 30 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.30.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Job 30:1",
      "text": "וְעַתָּ֤ה ׀ שָֽׂחֲק֣וּ עָלַי֮ צְעִירִ֥ים מִמֶּ֗נִּי לְיָ֫מִ֥ים אֲשֶׁר ־ מָאַ֥סְתִּי אֲבוֹתָ֑ם לָ֝שִׁ֗ית עִם ־ כַּלְבֵ֥י צֹאנִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.30.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Job 30:2",
      "text": "גַּם ־ כֹּ֣חַ יְ֭דֵיהֶם לָ֣מָּה לִּ֑י עָ֝לֵ֗ימוֹ אָ֣בַד כָּֽלַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Job 30:3",
      "text": "בְּחֶ֥סֶר וּבְכָפָ֗ן גַּ֫לְמ֥וּד הַֽעֹרְקִ֥ים צִיָּ֑ה אֶ֝֗מֶשׁ שׁוֹאָ֥ה וּמְשֹׁאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Job 30:4",
      "text": "הַקֹּטְפִ֣ים מַלּ֣וּחַ עֲלֵי ־ שִׂ֑יחַ וְשֹׁ֖רֶשׁ רְתָמִ֣ים לַחְמָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Job 30:5",
      "text": "מִן ־ גֵּ֥ו יְגֹרָ֑שׁוּ יָרִ֥יעוּ עָ֝לֵ֗ימוֹ כַּגַּנָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Job 30:6",
      "text": "בַּעֲר֣וּץ נְחָלִ֣ים לִשְׁכֹּ֑ן חֹרֵ֖י עָפָ֣ר וְכֵפִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Job 30:7",
      "text": "בֵּין ־ שִׂיחִ֥ים יִנְהָ֑קוּ תַּ֖חַת חָר֣וּל יְסֻפָּֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Job 30:8",
      "text": "בְּֽנֵי ־ נָ֭בָל גַּם ־ בְּנֵ֣י בְלִי ־ שֵׁ֑ם נִ֝כְּא֗וּ מִן ־ הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Job 30:9",
      "text": "וְ֭עַתָּה נְגִינָתָ֣ם הָיִ֑יתִי וָאֱהִ֖י לָהֶ֣ם לְמִלָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Job 30:10",
      "text": "תִּֽ֭עֲבוּנִי רָ֣חֲקוּ מֶ֑נִּי וּ֝מִפָּנַ֗י לֹא ־ חָ֥שְׂכוּ רֹֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Job 30:11",
      "text": "כִּֽי ־ יתרו פִ֭תַּח וַיְעַנֵּ֑נִי וְ֝רֶ֗סֶן מִפָּנַ֥י שִׁלֵּֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Job 30:12",
      "text": "עַל ־ יָמִין֮ פִּרְחַ֪ח יָ֫ק֥וּמוּ רַגְלַ֥י שִׁלֵּ֑חוּ וַיָּסֹ֥לּוּ עָ֝לַ֗י אָרְח֥וֹת אֵידָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Job 30:13",
      "text": "נָתְס֗וּ נְֽתִיבָ֫תִ֥י לְהַוָּתִ֥י יֹעִ֑ילוּ לֹ֖א עֹזֵ֣ר לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Job 30:14",
      "text": "כְּפֶ֣רֶץ רָחָ֣ב יֶאֱתָ֑יוּ תַּ֥חַת שֹׁ֝אָ֗ה הִתְגַּלְגָּֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Job 30:15",
      "text": "הָהְפַּ֥ךְ עָלַ֗י בַּלָּ֫ה֥וֹת תִּרְדֹּ֣ף כָּ֭רוּחַ נְדִבָתִ֑י וּ֝כְעָ֗ב עָבְרָ֥ה יְשֻׁעָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Job 30:16",
      "text": "וְעַתָּ֗ה עָ֭לַי תִּשְׁתַּפֵּ֣ךְ נַפְשִׁ֑י יֹ֭אחֲז֣וּנִי יְמֵי ־ עֹֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Job 30:17",
      "text": "לַ֗יְלָה עֲ֭צָמַי נִקַּ֣ר מֵעָלָ֑י וְ֝עֹרְקַ֗י לֹ֣א יִשְׁכָּבֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Job 30:18",
      "text": "בְּרָב ־ כֹּ֭חַ יִתְחַפֵּ֣שׂ לְבוּשִׁ֑י כְּפִ֖י כֻתָּנְתִּ֣י יַֽאַזְרֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Job 30:19",
      "text": "הֹרָ֥נִי לַחֹ֑מֶר וָ֝אֶתְמַשֵּׁ֗ל כֶּעָפָ֥ר וָאֵֽפֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Job 30:20",
      "text": "אֲשַׁוַּ֣ע אֵ֭לֶיךָ וְלֹ֣א תַעֲנֵ֑נִי עָ֝מַ֗דְתִּי וַתִּתְבֹּ֥נֶן בִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Job 30:21",
      "text": "תֵּהָפֵ֣ךְ לְאַכְזָ֣ר לִ֑י בְּעֹ֖צֶם יָדְךָ֣ תִשְׂטְמֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Job 30:22",
      "text": "תִּשָּׂאֵ֣נִי אֶל ־ ר֭וּחַ תַּרְכִּיבֵ֑נִי וּ֝תְמֹגְגֵ֗נִי תשוה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Job 30:23",
      "text": "כִּֽי ־ יָ֭דַעְתִּי מָ֣וֶת תְּשִׁיבֵ֑נִי וּבֵ֖ית מוֹעֵ֣ד לְכָל ־ חָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Job 30:24",
      "text": "אַ֣ךְ לֹא ־ בְ֭עִי יִשְׁלַח ־ יָ֑ד אִם ־ בְּ֝פִיד֗וֹ לָהֶ֥ן שֽׁוּעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Job 30:25",
      "text": "אִם ־ לֹ֣א בָ֭כִיתִי לִקְשֵׁה ־ י֑וֹם עָֽגְמָ֥ה נַ֝פְשִׁ֗י לָאֶבְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Job 30:26",
      "text": "כִּ֤י ט֣וֹב קִ֭וִּיתִי וַיָּ֣בֹא רָ֑ע וַֽאֲיַחֲלָ֥ה לְ֝א֗וֹר וַיָּ֥בֹא אֹֽפֶל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Job 30:27",
      "text": "מֵעַ֖י רֻתְּח֥וּ וְלֹא ־ דָ֗מּוּ קִדְּמֻ֥נִי יְמֵי ־ עֹֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Job 30:28",
      "text": "קֹדֵ֣ר הִ֭לַּכְתִּי בְּלֹ֣א חַמָּ֑ה קַ֖מְתִּי בַקָּהָ֣ל אֲשַׁוֵּֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Job 30:29",
      "text": "אָ֭ח הָיִ֣יתִי לְתַנִּ֑ים וְ֝רֵ֗עַ לִבְנ֥וֹת יַעֲנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Job 30:30",
      "text": "ע֭וֹרִי שָׁחַ֣ר מֵעָלָ֑י וְעַצְמִי ־ חָ֝֗רָה מִנִּי ־ חֹֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.30.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Job 30:31",
      "text": "וַיְהִ֣י לְ֭אֵבֶל כִּנֹּרִ֑י וְ֝עֻגָבִ֗י לְק֣וֹל בֹּכִֽים ׃",
      "paragraphStart": false
    }
  ]
}
