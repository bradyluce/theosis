{
  "chapter": {
    "id": "wlc:job.10",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 10,
    "referenceLabel": "Job 10",
    "summary": "Source text for Job 10 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.10.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Job 10:1",
      "text": "נָֽקְטָ֥ה נַפְשִׁ֗י בְּחַ֫יָּ֥י אֶֽעֶזְבָ֣ה עָלַ֣י שִׂיחִ֑י אֲ֝דַבְּרָה֗ בְּמַ֣ר נַפְשִֽׁי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.10.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Job 10:2",
      "text": "אֹמַ֣ר אֶל ־ אֱ֭לוֹהַּ אַל ־ תַּרְשִׁיעֵ֑נִי הֽ֝וֹדִיעֵ֗נִי עַ֣ל מַה ־ תְּרִיבֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Job 10:3",
      "text": "הֲט֤וֹב לְךָ֨ ׀ כִּֽי ־ תַעֲשֹׁ֗ק כִּֽי ־ תִ֭מְאַס יְגִ֣יעַ כַּפֶּ֑יךָ וְעַל ־ עֲצַ֖ת רְשָׁעִ֣ים הוֹפָֽעְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Job 10:4",
      "text": "הַעֵינֵ֣י בָשָׂ֣ר לָ֑ךְ אִם ־ כִּרְא֖וֹת אֱנ֣וֹשׁ תִּרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Job 10:5",
      "text": "הֲכִימֵ֣י אֱנ֣וֹשׁ יָמֶ֑יךָ אִם ־ שְׁ֝נוֹתֶ֗יךָ כִּ֣ימֵי גָֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Job 10:6",
      "text": "כִּֽי ־ תְבַקֵּ֥שׁ לַעֲוֺנִ֑י וּ֭לְחַטָּאתִ֥י תִדְרֽוֹשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Job 10:7",
      "text": "עַֽל ־ דַּ֭עְתְּךָ כִּי ־ לֹ֣א אֶרְשָׁ֑ע וְאֵ֖ין מִיָּדְךָ֣ מַצִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Job 10:8",
      "text": "יָדֶ֣יךָ עִ֭צְּבוּנִי וַֽיַּעֲשׂ֑וּנִי יַ֥חַד סָ֝בִ֗יב וַֽתְּבַלְּעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Job 10:9",
      "text": "זְכָר ־ נָ֭א כִּי ־ כַחֹ֣מֶר עֲשִׂיתָ֑נִי וְֽאֶל ־ עָפָ֥ר תְּשִׁיבֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Job 10:10",
      "text": "הֲלֹ֣א כֶ֭חָלָב תַּתִּיכֵ֑נִי וְ֝כַגְּבִנָּ֗ה תַּקְפִּיאֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Job 10:11",
      "text": "ע֣וֹר וּ֭בָשָׂר תַּלְבִּישֵׁ֑נִי וּֽבַעֲצָמ֥וֹת וְ֝גִידִ֗ים תְּסֹכְכֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Job 10:12",
      "text": "חַיִּ֣ים וָ֭חֶסֶד עָשִׂ֣יתָ עִמָּדִ֑י וּ֝פְקֻדָּתְךָ֗ שָֽׁמְרָ֥ה רוּחִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Job 10:13",
      "text": "וְ֭אֵלֶּה צָפַ֣נְתָּ בִלְבָבֶ֑ךָ יָ֝דַ֗עְתִּי כִּי ־ זֹ֥את עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Job 10:14",
      "text": "אִם ־ חָטָ֥אתִי וּשְׁמַרְתָּ֑נִי וּ֝מֵעֲוֺנִ֗י לֹ֣א תְנַקֵּֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Job 10:15",
      "text": "אִם ־ רָשַׁ֡עְתִּי אַלְלַ֬י לִ֗י וְ֭צָדַקְתִּי לֹא ־ אֶשָּׂ֣א רֹאשִׁ֑י שְׂבַ֥ע קָ֝ל֗וֹן וּרְאֵ֥ה עָנְיִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Job 10:16",
      "text": "וְ֭יִגְאֶה כַּשַּׁ֣חַל תְּצוּדֵ֑נִי וְ֝תָשֹׁ֗ב תִּתְפַּלָּא ־ בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Job 10:17",
      "text": "תְּחַדֵּ֬שׁ עֵדֶ֨יךָ ׀ נֶגְדִּ֗י וְתֶ֣רֶב כַּֽ֭עַשְׂךָ עִמָּדִ֑י חֲלִיפ֖וֹת וְצָבָ֣א עִמִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Job 10:18",
      "text": "וְלָ֣מָּה מֵ֭רֶחֶם הֹצֵאתָ֑נִי אֶ֝גְוַ֗ע וְעַ֣יִן לֹא ־ תִרְאֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Job 10:19",
      "text": "כַּאֲשֶׁ֣ר לֹא ־ הָיִ֣יתִי אֶהְיֶ֑ה מִ֝בֶּ֗טֶן לַקֶּ֥בֶר אוּבָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Job 10:20",
      "text": "הֲלֹא ־ מְעַ֣ט יָמַ֣י יחדל ישית מִ֝מֶּ֗נִּי וְאַבְלִ֥יגָה מְּעָֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Job 10:21",
      "text": "בְּטֶ֣רֶם אֵ֭לֵךְ וְלֹ֣א אָשׁ֑וּב אֶל ־ אֶ֖רֶץ חֹ֣שֶׁךְ וְצַלְמָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.10.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Job 10:22",
      "text": "אֶ֤רֶץ עֵיפָ֨תָה ׀ כְּמ֥וֹ אֹ֗פֶל צַ֭לְמָוֶת וְלֹ֥א סְדָרִ֗ים וַתֹּ֥פַע כְּמוֹ ־ אֹֽפֶל ׃ פ",
      "paragraphStart": false
    }
  ]
}
