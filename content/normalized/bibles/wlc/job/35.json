{
  "chapter": {
    "id": "wlc:job.35",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 35,
    "referenceLabel": "Job 35",
    "summary": "Source text for Job 35 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.35.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Job 35:1",
      "text": "וַיַּ֥עַן אֱלִיה֗וּ וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.35.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Job 35:2",
      "text": "הֲ֭זֹאת חָשַׁ֣בְתָּ לְמִשְׁפָּ֑ט אָ֝מַ֗רְתָּ צִדְקִ֥י מֵאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Job 35:3",
      "text": "כִּֽי ־ תֹ֭אמַר מַה ־ יִּסְכָּן ־ לָ֑ךְ מָֽה ־ אֹ֝עִ֗יל מֵֽחַטָּאתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Job 35:4",
      "text": "אֲ֭נִי אֲשִֽׁיבְךָ֣ מִלִּ֑ין וְֽאֶת ־ רֵעֶ֥יךָ עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Job 35:5",
      "text": "הַבֵּ֣ט שָׁמַ֣יִם וּרְאֵ֑ה וְשׁ֥וּר שְׁ֝חָקִ֗ים גָּבְה֥וּ מִמֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Job 35:6",
      "text": "אִם ־ חָ֭טָאתָ מַה ־ תִּפְעָל ־ בּ֑וֹ וְרַבּ֥וּ פְ֝שָׁעֶ֗יךָ מַה ־ תַּעֲשֶׂה ־ לּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Job 35:7",
      "text": "אִם ־ צָ֭דַקְתָּ מַה ־ תִּתֶּן ־ ל֑וֹ א֥וֹ מַה ־ מִיָּדְךָ֥ יִקָּֽח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Job 35:8",
      "text": "לְאִישׁ ־ כָּמ֥וֹךָ רִשְׁעֶ֑ךָ וּלְבֶן ־ אָ֝דָ֗ם צִדְקָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Job 35:9",
      "text": "מֵ֭רֹב עֲשׁוּקִ֣ים יַזְעִ֑יקוּ יְשַׁוְּע֖וּ מִזְּר֣וֹעַ רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Job 35:10",
      "text": "וְֽלֹא ־ אָמַ֗ר אַ֭יֵּה אֱל֣וֹהַּ עֹשָׂ֑י נֹתֵ֖ן זְמִר֣וֹת בַּלָּֽיְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Job 35:11",
      "text": "מַ֭לְּפֵנוּ מִבַּהֲמ֣וֹת אָ֑רֶץ וּמֵע֖וֹף הַשָּׁמַ֣יִם יְחַכְּמֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Job 35:12",
      "text": "שָׁ֣ם יִ֭צְעֲקוּ וְלֹ֣א יַעֲנֶ֑ה מִ֝פְּנֵ֗י גְּא֣וֹן רָעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Job 35:13",
      "text": "אַךְ ־ שָׁ֭וְא לֹא ־ יִשְׁמַ֥ע ׀ אֵ֑ל וְ֝שַׁדַּ֗י לֹ֣א יְשׁוּרֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Job 35:14",
      "text": "אַ֣ף כִּֽי ־ תֹ֭אמַר לֹ֣א תְשׁוּרֶ֑נּוּ דִּ֥ין לְ֝פָנָ֗יו וּתְח֥וֹלֵֽל לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Job 35:15",
      "text": "וְעַתָּ֗ה כִּי ־ אַ֭יִן פָּקַ֣ד אַפּ֑וֹ וְלֹֽא ־ יָדַ֖ע בַּפַּ֣שׁ מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.35.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Job 35:16",
      "text": "וְ֭אִיּוֹב הֶ֣בֶל יִפְצֶה ־ פִּ֑יהוּ בִּבְלִי ־ דַ֝֗עַת מִלִּ֥ין יַכְבִּֽר ׃ פ",
      "paragraphStart": false
    }
  ]
}
