      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "וַ֭יַּעַן בִּלְדַּ֥ד הַשֻּׁחִ֗י וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.25.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "הַמְשֵׁ֣ל וָפַ֣חַד עִמּ֑וֹ עֹשֶׂ֥ה שָׁ֝ל֗וֹם בִּמְרוֹמָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.25.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "הֲיֵ֣שׁ מִ֭סְפָּר לִגְדוּדָ֑יו וְעַל ־ מִ֝֗י לֹא ־ יָק֥וּם אוֹרֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.25.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "וּמַה ־ יִּצְדַּ֣ק אֱנ֣וֹשׁ עִם ־ אֵ֑ל וּמַה ־ יִּ֝זְכֶּ֗ה יְל֣וּד אִשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.25.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "הֵ֣ן עַד ־ יָ֭רֵחַ וְלֹ֣א יַאֲהִ֑יל וְ֝כוֹכָבִ֗ים לֹא ־ זַכּ֥וּ בְעֵינָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.25.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "אַ֭ף כִּֽי ־ אֱנ֣וֹשׁ רִמָּ֑ה וּבֶן ־ אָ֝דָ֗ם תּוֹלֵעָֽה ׃ פ",
      "paragraphStart": false
    }
  ]
}
