{
  "chapter": {
    "id": "wlc:job.37",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 37,
    "referenceLabel": "Job 37",
    "summary": "Source text for Job 37 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.37.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Job 37:1",
      "text": "אַף ־ לְ֭זֹאת יֶחֱרַ֣ד לִבִּ֑י וְ֝יִתַּ֗ר מִמְּקוֹמֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.37.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Job 37:2",
      "text": "שִׁמְע֤וּ שָׁמ֣וֹעַ בְּרֹ֣גֶז קֹל֑וֹ וְ֝הֶ֗גֶה מִפִּ֥יו יֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Job 37:3",
      "text": "תַּֽחַת ־ כָּל ־ הַשָּׁמַ֥יִם יִשְׁרֵ֑הוּ וְ֝אוֹר֗וֹ עַל ־ כַּנְפ֥וֹת הָאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Job 37:4",
      "text": "אַחֲרָ֤יו ׀ יִשְׁאַג ־ ק֗וֹל יַ֭רְעֵם בְּק֣וֹל גְּאוֹנ֑וֹ וְלֹ֥א יְ֝עַקְּבֵ֗ם כִּֽי ־ יִשָּׁמַ֥ע קוֹלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Job 37:5",
      "text": "יַרְעֵ֤ם אֵ֣ל בְּ֭קוֹלוֹ נִפְלָא֑וֹת עֹשֶׂ֥ה גְ֝דֹל֗וֹת וְלֹ֣א נֵדָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Job 37:6",
      "text": "כִּ֤י לַשֶּׁ֨לַג ׀ יֹאמַ֗ר הֱוֵ֫א אָ֥רֶץ וְגֶ֥שֶׁם מָטָ֑ר וְ֝גֶ֗שֶׁם מִטְר֥וֹת עֻזּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Job 37:7",
      "text": "בְּיַד ־ כָּל ־ אָדָ֥ם יַחְתּ֑וֹם לָ֝דַ֗עַת כָּל ־ אַנְשֵׁ֥י מַעֲשֵֽׂהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Job 37:8",
      "text": "וַתָּבֹ֣א חַיָּ֣ה בְמוֹ ־ אָ֑רֶב וּבִמְע֖וֹנֹתֶ֣יהָ תִשְׁכֹּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Job 37:9",
      "text": "מִן ־ הַ֭חֶדֶר תָּב֣וֹא סוּפָ֑ה וּֽמִמְּזָרִ֥ים קָרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Job 37:10",
      "text": "מִנִּשְׁמַת ־ אֵ֥ל יִתֶּן ־ קָ֑רַח וְרֹ֖חַב מַ֣יִם בְּמוּצָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Job 37:11",
      "text": "אַף ־ בְּ֭רִי יַטְרִ֣יחַ עָ֑ב יָ֝פִ֗יץ עֲנַ֣ן אוֹרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Job 37:12",
      "text": "וְה֤וּא מְסִבּ֨וֹת ׀ מִתְהַפֵּ֣ךְ בתחבולתו לְפָעֳלָ֑ם כֹּ֖ל אֲשֶׁ֥ר יְצַוֵּ֓ם ׀ עַל ־ פְּנֵ֖י תֵבֵ֣ל אָֽרְצָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Job 37:13",
      "text": "אִם ־ לְשֵׁ֥בֶט אִם ־ לְאַרְצ֑וֹ אִם ־ לְ֝חֶ֗סֶד יַמְצִאֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Job 37:14",
      "text": "הַאֲזִ֣ינָה זֹּ֣את אִיּ֑וֹב עֲ֝מֹ֗ד וְהִתְבּוֹנֵ֤ן ׀ נִפְלְא֬וֹת אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Job 37:15",
      "text": "הֲ֭תֵדַע בְּשׂוּם ־ אֱל֣וֹהַּ עֲלֵיהֶ֑ם וְ֝הוֹפִ֗יעַ א֣וֹר עֲנָנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Job 37:16",
      "text": "הֲ֭תֵדַע עַל ־ מִפְלְשֵׂי ־ עָ֑ב מִ֝פְלְא֗וֹת תְּמִ֣ים דֵּעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Job 37:17",
      "text": "אֲשֶׁר ־ בְּגָדֶ֥יךָ חַמִּ֑ים בְּהַשְׁקִ֥ט אֶ֝֗רֶץ מִדָּרֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Job 37:18",
      "text": "תַּרְקִ֣יעַ עִ֭מּוֹ לִשְׁחָקִ֑ים חֲ֝זָקִ֗ים כִּרְאִ֥י מוּצָֽק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Job 37:19",
      "text": "ה֭וֹדִיעֵנוּ מַה ־ נֹּ֣אמַר ל֑וֹ לֹ֥א ־ נַ֝עֲרֹ֗ךְ מִפְּנֵי ־ חֹֽשֶׁךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Job 37:20",
      "text": "הַֽיְסֻפַּר ־ ל֭וֹ כִּ֣י אֲדַבֵּ֑ר אִֽם ־ אָ֥מַר אִ֝֗ישׁ כִּ֣י יְבֻלָּֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Job 37:21",
      "text": "וְעַתָּ֤ה ׀ לֹ֘א רָ֤אוּ א֗וֹר בָּהִ֣יר ה֭וּא בַּשְּׁחָקִ֑ים וְר֥וּחַ עָ֝בְרָ֗ה וַֽתְּטַהֲרֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Job 37:22",
      "text": "מִ֭צָּפוֹן זָהָ֣ב יֶֽאֱתֶ֑ה עַל ־ אֱ֝ל֗וֹהַּ נ֣וֹרָא הֽוֹד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Job 37:23",
      "text": "שַׁדַּ֣י לֹֽא ־ מְ֭צָאנֻהוּ שַׂגִּיא ־ כֹ֑חַ וּמִשְׁפָּ֥ט וְרֹב ־ צְ֝דָקָ֗ה לֹ֣א יְעַנֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.37.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Job 37:24",
      "text": "לָ֭כֵן יְרֵא֣וּהוּ אֲנָשִׁ֑ים לֹֽא ־ יִ֝רְאֶ֗ה כָּל ־ חַכְמֵי ־ לֵֽב ׃ פ",
      "paragraphStart": false
    }
  ]
}
