{
  "chapter": {
    "id": "wlc:job.7",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 7,
    "referenceLabel": "Job 7",
    "summary": "Source text for Job 7 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.7.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Job 7:1",
      "text": "הֲלֹא ־ צָבָ֣א לֶאֱנ֣וֹשׁ על ־ אָ֑רֶץ וְכִימֵ֖י שָׂכִ֣יר יָמָֽיו ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.7.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Job 7:2",
      "text": "כְּעֶ֥בֶד יִשְׁאַף ־ צֵ֑ל וּ֝כְשָׂכִ֗יר יְקַוֶּ֥ה פָעֳלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Job 7:3",
      "text": "כֵּ֤ן הָנְחַ֣לְתִּי לִ֭י יַרְחֵי ־ שָׁ֑וְא וְלֵיל֥וֹת עָ֝מָ֗ל מִנּוּ ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Job 7:4",
      "text": "אִם ־ שָׁכַ֗בְתִּי וְאָמַ֗רְתִּי מָתַ֣י אָ֭קוּם וּמִדַּד ־ עָ֑רֶב וְשָׂבַ֖עְתִּי נְדֻדִ֣ים עֲדֵי ־ נָֽשֶׁף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Job 7:5",
      "text": "לָ֘בַ֤שׁ בְּשָׂרִ֣י רִ֭מָּה וגיש עָפָ֑ר עוֹרִ֥י רָ֝גַ֗ע וַיִּמָּאֵֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Job 7:6",
      "text": "יָמַ֣י קַ֭לּוּ מִנִּי ־ אָ֑רֶג וַ֝יִּכְל֗וּ בְּאֶ֣פֶס תִּקְוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Job 7:7",
      "text": "זְ֭כֹר כִּי ־ ר֣וּחַ חַיָּ֑י לֹא ־ תָשׁ֥וּב עֵ֝ינִ֗י לִרְא֥וֹת טֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Job 7:8",
      "text": "לֹֽא ־ תְ֭שׁוּרֵנִי עֵ֣ין רֹ֑אִי עֵינֶ֖יךָ בִּ֣י וְאֵינֶֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Job 7:9",
      "text": "כָּלָ֣ה עָ֭נָן וַיֵּלַ֑ךְ כֵּ֥ן יוֹרֵ֥ד שְׁ֝א֗וֹל לֹ֣א יַעֲלֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Job 7:10",
      "text": "לֹא ־ יָשׁ֣וּב ע֣וֹד לְבֵית֑וֹ וְלֹא ־ יַכִּירֶ֖נּוּ ע֣וֹד מְקֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Job 7:11",
      "text": "גַּם ־ אֲנִי֮ לֹ֤א אֶחֱשָׂ֫ךְ פִּ֥י אֲֽ֭דַבְּרָה בְּצַ֣ר רוּחִ֑י אָ֝שִׂ֗יחָה בְּמַ֣ר נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Job 7:12",
      "text": "הֲֽיָם ־ אָ֭נִי אִם ־ תַּנִּ֑ין כִּֽי ־ תָשִׂ֖ים עָלַ֣י מִשְׁמָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Job 7:13",
      "text": "כִּֽי ־ אָ֭מַרְתִּי תְּנַחֲמֵ֣נִי עַרְשִׂ֑י יִשָּׂ֥א בְ֝שִׂיחִ֗י מִשְׁכָּבִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Job 7:14",
      "text": "וְחִתַּתַּ֥נִי בַחֲלֹמ֑וֹת וּֽמֵחֶזְיֹנ֥וֹת תְּבַעֲתַֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Job 7:15",
      "text": "וַתִּבְחַ֣ר מַחֲנָ֣ק נַפְשִׁ֑י מָ֝֗וֶת מֵֽעַצְמוֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Job 7:16",
      "text": "מָ֭אַסְתִּי לֹא ־ לְעֹלָ֣ם אֶֽחְיֶ֑ה חֲדַ֥ל מִ֝מֶּ֗נִּי כִּי ־ הֶ֥בֶל יָמָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Job 7:17",
      "text": "מָֽה ־ אֱ֭נוֹשׁ כִּ֣י תְגַדְּלֶ֑נּוּ וְכִי ־ תָשִׁ֖ית אֵלָ֣יו לִבֶּֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Job 7:18",
      "text": "וַתִּפְקְדֶ֥נּוּ לִבְקָרִ֑ים לִ֝רְגָעִ֗ים תִּבְחָנֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Job 7:19",
      "text": "כַּ֭מָּה לֹא ־ תִשְׁעֶ֣ה מִמֶּ֑נִּי לֹֽא ־ תַ֝רְפֵּ֗נִי עַד ־ בִּלְעִ֥י רֻקִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Job 7:20",
      "text": "חָטָ֡אתִי מָ֤ה אֶפְעַ֨ל ׀ לָךְ֮ נֹצֵ֪ר הָאָ֫דָ֥ם לָ֤מָה שַׂמְתַּ֣נִי לְמִפְגָּ֣ע לָ֑ךְ וָאֶהְיֶ֖ה עָלַ֣י לְמַשָּֽׂא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.7.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Job 7:21",
      "text": "וּמֶ֤ה ׀ לֹא ־ תִשָּׂ֣א פִשְׁעִי֮ וְתַעֲבִ֪יר אֶת ־ עֲוֺ֫נִ֥י כִּֽי ־ עַ֭תָּה לֶעָפָ֣ר אֶשְׁכָּ֑ב וְשִׁ֖חֲרְתַּ֣נִי וְאֵינֶֽנִּי ׃ פ",
      "paragraphStart": false
    }
  ]
}
