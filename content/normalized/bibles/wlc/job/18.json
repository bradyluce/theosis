{
  "chapter": {
    "id": "wlc:job.18",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 18,
    "referenceLabel": "Job 18",
    "summary": "Source text for Job 18 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.18.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Job 18:1",
      "text": "וַ֭יַּעַן בִּלְדַּ֥ד הַשֻּׁחִ֗י וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.18.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Job 18:2",
      "text": "עַד ־ אָ֤נָה ׀ תְּשִׂימ֣וּן קִנְצֵ֣י לְמִלִּ֑ין תָּ֝בִ֗ינוּ וְאַחַ֥ר נְדַבֵּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Job 18:3",
      "text": "מַ֭דּוּעַ נֶחְשַׁ֣בְנוּ כַבְּהֵמָ֑ה נִ֝טְמִ֗ינוּ בְּעֵינֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Job 18:4",
      "text": "טֹֽרֵ֥ף נַפְשׁ֗וֹ בְּאַ֫פּ֥וֹ הַ֭לְמַעַנְךָ תֵּעָ֣זַב אָ֑רֶץ וְיֶעְתַּק ־ צ֝֗וּר מִמְּקֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Job 18:5",
      "text": "גַּ֤ם א֣וֹר רְשָׁעִ֣ים יִדְעָ֑ךְ וְלֹֽא ־ יִ֝גַּ֗הּ שְׁבִ֣יב אִשּֽׁוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Job 18:6",
      "text": "א֭וֹר חָשַׁ֣ךְ בְּאָהֳל֑וֹ וְ֝נֵר֗וֹ עָלָ֥יו יִדְעָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Job 18:7",
      "text": "יֵֽ֭צְרוּ צַעֲדֵ֣י אוֹנ֑וֹ וְֽתַשְׁלִיכֵ֥הוּ עֲצָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Job 18:8",
      "text": "כִּֽי ־ שֻׁלַּ֣ח בְּרֶ֣שֶׁת בְּרַגְלָ֑יו וְעַל ־ שְׂ֝בָכָ֗ה יִתְהַלָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Job 18:9",
      "text": "יֹאחֵ֣ז בְּעָקֵ֣ב פָּ֑ח יַחֲזֵ֖ק עָלָ֣יו צַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Job 18:10",
      "text": "טָמ֣וּן בָּאָ֣רֶץ חַבְל֑וֹ וּ֝מַלְכֻּדְתּ֗וֹ עֲלֵ֣י נָתִֽיב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Job 18:11",
      "text": "סָ֭בִיב בִּֽעֲתֻ֣הוּ בַלָּה֑וֹת וֶהֱפִיצֻ֥הוּ לְרַגְלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Job 18:12",
      "text": "יְהִי ־ רָעֵ֥ב אֹנ֑וֹ וְ֝אֵ֗יד נָכ֥וֹן לְצַלְעֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Job 18:13",
      "text": "יֹ֭אכַל בַּדֵּ֣י עוֹר֑וֹ יֹאכַ֥ל בַּ֝דָּ֗יו בְּכ֣וֹר מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Job 18:14",
      "text": "יִנָּתֵ֣ק מֵ֭אָהֳלוֹ מִבְטַח֑וֹ וְ֝תַצְעִדֵ֗הוּ לְמֶ֣לֶךְ בַּלָּהֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Job 18:15",
      "text": "תִּשְׁכּ֣וֹן בְּ֭אָהֳלוֹ מִבְּלִי ־ ל֑וֹ יְזֹרֶ֖ה עַל ־ נָוֵ֣הוּ גָפְרִֽית ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Job 18:16",
      "text": "מִ֭תַּחַת שָֽׁרָשָׁ֣יו יִבָ֑שׁוּ וּ֝מִמַּ֗עַל יִמַּ֥ל קְצִירֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Job 18:17",
      "text": "זִֽכְרוֹ ־ אָ֭בַד מִנִּי ־ אָ֑רֶץ וְלֹא ־ שֵׁ֥ם ל֝֗וֹ עַל ־ פְּנֵי ־ חֽוּץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Job 18:18",
      "text": "יֶ֭הְדְּפֻהוּ מֵא֣וֹר אֶל ־ חֹ֑שֶׁךְ וּֽמִתֵּבֵ֥ל יְנִדֻּֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Job 18:19",
      "text": "לֹ֘א נִ֤ין ל֣וֹ וְלֹא ־ נֶ֣כֶד בְּעַמּ֑וֹ וְאֵ֥ין שָׂ֝רִ֗יד בִּמְגוּרָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Job 18:20",
      "text": "עַל ־ י֭וֹמוֹ נָשַׁ֣מּוּ אַחֲרֹנִ֑ים וְ֝קַדְמֹנִ֗ים אָ֣חֲזוּ שָֽׂעַר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.18.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Job 18:21",
      "text": "אַךְ ־ אֵ֭לֶּה מִשְׁכְּנ֣וֹת עַוָּ֑ל וְ֝זֶ֗ה מְק֣וֹם לֹא ־ יָדַֽע ־ אֵֽל ׃ ס",
      "paragraphStart": false
    }
  ]
}
