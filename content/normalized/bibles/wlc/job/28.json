{
  "chapter": {
    "id": "wlc:job.28",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 28,
    "referenceLabel": "Job 28",
    "summary": "Source text for Job 28 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.28.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Job 28:1",
      "text": "כִּ֤י יֵ֣שׁ לַכֶּ֣סֶף מוֹצָ֑א וּ֝מָק֗וֹם לַזָּהָ֥ב יָזֹֽקּוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.28.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Job 28:2",
      "text": "בַּ֭רְזֶל מֵעָפָ֣ר יֻקָּ֑ח וְ֝אֶ֗בֶן יָצ֥וּק נְחוּשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Job 28:3",
      "text": "קֵ֤ץ ׀ שָׂ֤ם לַחֹ֗שֶׁךְ וּֽלְכָל ־ תַּ֭כְלִית ה֣וּא חוֹקֵ֑ר אֶ֖בֶן אֹ֣פֶל וְצַלְמָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Job 28:4",
      "text": "פָּ֤רַץ נַ֨חַל ׀ מֵֽעִם ־ גָּ֗ר הַֽנִּשְׁכָּחִ֥ים מִנִּי ־ רָ֑גֶל דַּ֖לּוּ מֵאֱנ֣וֹשׁ נָֽעוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Job 28:5",
      "text": "אֶ֗רֶץ מִמֶּ֥נָּה יֵֽצֵא ־ לָ֑חֶם וְ֝תַחְתֶּ֗יהָ נֶהְפַּ֥ךְ כְּמוֹ ־ אֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Job 28:6",
      "text": "מְקוֹם ־ סַפִּ֥יר אֲבָנֶ֑יהָ וְעַפְרֹ֖ת זָהָ֣ב לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Job 28:7",
      "text": "נָ֭תִיב לֹֽא ־ יְדָ֣עוֹ עָ֑יִט וְלֹ֥א שְׁ֝זָפַ֗תּוּ עֵ֣ין אַיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Job 28:8",
      "text": "לֹֽא ־ הִדְרִיכֻ֥הוּ בְנֵי ־ שָׁ֑חַץ לֹֽא ־ עָדָ֖ה עָלָ֣יו שָֽׁחַל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Job 28:9",
      "text": "בַּֽ֭חַלָּמִישׁ שָׁלַ֣ח יָד֑וֹ הָפַ֖ךְ מִשֹּׁ֣רֶשׁ הָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Job 28:10",
      "text": "בַּ֭צּוּרוֹת יְאֹרִ֣ים בִּקֵּ֑עַ וְכָל ־ יְ֝קָ֗ר רָאֲתָ֥ה עֵינֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Job 28:11",
      "text": "מִ֭בְּכִי נְהָר֣וֹת חִבֵּ֑שׁ וְ֝תַעֲלֻמָ֗הּ יֹ֣צִא אֽוֹר ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Job 28:12",
      "text": "וְֽ֭הַחָכְמָה מֵאַ֣יִן תִּמָּצֵ֑א וְאֵ֥י זֶ֝ה מְק֣וֹם בִּינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Job 28:13",
      "text": "לֹא ־ יָדַ֣ע אֱנ֣וֹשׁ עֶרְכָּ֑הּ וְלֹ֥א תִ֝מָּצֵ֗א בְּאֶ֣רֶץ הַֽחַיִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Job 28:14",
      "text": "תְּה֣וֹם אָ֭מַר לֹ֣א בִי ־ הִ֑יא וְיָ֥ם אָ֝מַ֗ר אֵ֣ין עִמָּדִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Job 28:15",
      "text": "לֹא ־ יֻתַּ֣ן סְג֣וֹר תַּחְתֶּ֑יהָ וְלֹ֥א יִ֝שָּׁקֵ֗ל כֶּ֣סֶף מְחִירָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Job 28:16",
      "text": "לֹֽא ־ תְ֭סֻלֶּה בְּכֶ֣תֶם אוֹפִ֑יר בְּשֹׁ֖הַם יָקָ֣ר וְסַפִּֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Job 28:17",
      "text": "לֹא ־ יַעַרְכֶ֣נָּה זָ֭הָב וּזְכוֹכִ֑ית וּתְמ֖וּרָתָ֣הּ כְּלִי ־ פָֽז ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Job 28:18",
      "text": "רָאמ֣וֹת וְ֭גָבִישׁ לֹ֣א יִזָּכֵ֑ר וּמֶ֥שֶׁךְ חָ֝כְמָ֗ה מִפְּנִינִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Job 28:19",
      "text": "לֹֽא ־ יַ֭עַרְכֶנָּה פִּטְדַת ־ כּ֑וּשׁ בְּכֶ֥תֶם טָ֝ה֗וֹר לֹ֣א תְסֻלֶּֽה ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Job 28:20",
      "text": "וְֽ֭הַחָכְמָה מֵאַ֣יִן תָּב֑וֹא וְאֵ֥י זֶ֝֗ה מְק֣וֹם בִּינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Job 28:21",
      "text": "וְֽ֭נֶעֶלְמָה מֵעֵינֵ֣י כָל ־ חָ֑י וּמֵע֖וֹף הַשָּׁמַ֣יִם נִסְתָּֽרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Job 28:22",
      "text": "אֲבַדּ֣וֹן וָ֭מָוֶת אָ֣מְר֑וּ בְּ֝אָזְנֵ֗ינוּ שָׁמַ֥עְנוּ שִׁמְעָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Job 28:23",
      "text": "אֱ֭לֹהִים הֵבִ֣ין דַּרְכָּ֑הּ וְ֝ה֗וּא יָדַ֥ע אֶת ־ מְקוֹמָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Job 28:24",
      "text": "כִּי ־ ה֭וּא לִקְצוֹת ־ הָאָ֣רֶץ יַבִּ֑יט תַּ֖חַת כָּל ־ הַשָּׁמַ֣יִם יִרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Job 28:25",
      "text": "לַעֲשׂ֣וֹת לָר֣וּחַ מִשְׁקָ֑ל וּ֝מַ֗יִם תִּכֵּ֥ן בְּמִדָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Job 28:26",
      "text": "בַּעֲשֹׂת֣וֹ לַמָּטָ֣ר חֹ֑ק וְ֝דֶ֗רֶךְ לַחֲזִ֥יז קֹלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Job 28:27",
      "text": "אָ֣ז רָ֭אָהּ וַֽיְסַפְּרָ֑הּ הֱ֝כִינָ֗הּ וְגַם ־ חֲקָרָֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.28.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Job 28:28",
      "text": "וַיֹּ֤אמֶר ׀ לָֽאָדָ֗ם הֵ֤ן יִרְאַ֣ת אֲ֭דֹנָי הִ֣יא חָכְמָ֑ה וְס֖וּר מֵרָ֣ע בִּינָֽה ׃ ס",
      "paragraphStart": false
    }
  ]
}
