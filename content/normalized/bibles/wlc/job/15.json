{
  "chapter": {
    "id": "wlc:job.15",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 15,
    "referenceLabel": "Job 15",
    "summary": "Source text for Job 15 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.15.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Job 15:1",
      "text": "וַ֭יַּעַן אֱלִיפַ֥ז הַֽתֵּימָנִ֗י וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.15.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Job 15:2",
      "text": "הֶֽחָכָ֗ם יַעֲנֶ֥ה דַֽעַת ־ ר֑וּחַ וִֽימַלֵּ֖א קָדִ֣ים בִּטְנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Job 15:3",
      "text": "הוֹכֵ֣חַ בְּ֭דָבָר לֹ֣א יִסְכּ֑וֹן וּ֝מִלִּ֗ים לֹא ־ יוֹעִ֥יל בָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Job 15:4",
      "text": "אַף ־ אַ֭תָּה תָּפֵ֣ר יִרְאָ֑ה וְתִגְרַ֥ע שִׂ֝יחָ֗ה לִפְנֵי ־ אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Job 15:5",
      "text": "כִּ֤י יְאַלֵּ֣ף עֲוֺנְךָ֣ פִ֑יךָ וְ֝תִבְחַ֗ר לְשׁ֣וֹן עֲרוּמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Job 15:6",
      "text": "יַרְשִֽׁיעֲךָ֣ פִ֣יךָ וְלֹא ־ אָ֑נִי וּ֝שְׂפָתֶ֗יךָ יַעֲנוּ ־ בָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Job 15:7",
      "text": "הֲרִאישׁ֣וֹן אָ֭דָם תִּוָּלֵ֑ד וְלִפְנֵ֖י גְבָע֣וֹת חוֹלָֽלְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Job 15:8",
      "text": "הַבְס֣וֹד אֱל֣וֹהַ תִּשְׁמָ֑ע וְתִגְרַ֖ע אֵלֶ֣יךָ חָכְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Job 15:9",
      "text": "מַה ־ יָּ֭דַעְתָּ וְלֹ֣א נֵדָ֑ע תָּ֝בִ֗ין וְֽלֹא ־ עִמָּ֥נוּ הֽוּא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Job 15:10",
      "text": "גַּם ־ שָׂ֣ב גַּם ־ יָשִׁ֣ישׁ בָּ֑נוּ כַּבִּ֖יר מֵאָבִ֣יךָ יָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Job 15:11",
      "text": "הַמְעַ֣ט מִ֭מְּךָ תַּנְחֻמ֣וֹת אֵ֑ל וְ֝דָבָ֗ר לָאַ֥ט עִמָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Job 15:12",
      "text": "מַה ־ יִּקָּחֲךָ֥ לִבֶּ֑ךָ וּֽמַה ־ יִּרְזְמ֥וּן עֵינֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Job 15:13",
      "text": "כִּֽי ־ תָשִׁ֣יב אֶל ־ אֵ֣ל רוּחֶ֑ךָ וְהֹצֵ֖אתָ מִפִּ֣יךָ מִלִּֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Job 15:14",
      "text": "מָֽה ־ אֱנ֥וֹשׁ כִּֽי ־ יִזְכֶּ֑ה וְכִֽי ־ יִ֝צְדַּ֗ק יְל֣וּד אִשָּֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Job 15:15",
      "text": "הֵ֣ן בקדשו לֹ֣א יַאֲמִ֑ין וְ֝שָׁמַ֗יִם לֹא ־ זַכּ֥וּ בְעֵינָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Job 15:16",
      "text": "אַ֭ף כִּֽי ־ נִתְעָ֥ב וְֽנֶאֱלָ֑ח אִישׁ ־ שֹׁתֶ֖ה כַמַּ֣יִם עַוְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Job 15:17",
      "text": "אֲחַוְךָ֥ שְֽׁמַֽע ־ לִ֑י וְזֶֽה ־ חָ֝זִ֗יתִי וַאֲסַפֵּֽרָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Job 15:18",
      "text": "אֲשֶׁר ־ חֲכָמִ֥ים יַגִּ֑ידוּ וְלֹ֥א כִֽ֝חֲד֗וּ מֵאֲבוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Job 15:19",
      "text": "לָהֶ֣ם לְ֭בַדָּם נִתְּנָ֣ה הָאָ֑רֶץ וְלֹא ־ עָ֖בַר זָ֣ר בְּתוֹכָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Job 15:20",
      "text": "כָּל ־ יְמֵ֣י רָ֭שָׁע ה֣וּא מִתְחוֹלֵ֑ל וּמִסְפַּ֥ר שָׁ֝נִ֗ים נִצְפְּנ֥וּ לֶעָרִֽיץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Job 15:21",
      "text": "קוֹל ־ פְּחָדִ֥ים בְּאָזְנָ֑יו בַּ֝שָּׁל֗וֹם שׁוֹדֵ֥ד יְבוֹאֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Job 15:22",
      "text": "לֹא ־ יַאֲמִ֣ין שׁ֭וּב מִנִּי ־ חֹ֑שֶׁךְ וצפו ה֣וּא אֱלֵי ־ חָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Job 15:23",
      "text": "נֹ֘דֵ֤ד ה֣וּא לַלֶּ֣חֶם אַיֵּ֑ה יָדַ֓ע ׀ כִּֽי ־ נָכ֖וֹן בְּיָד֣וֹ יֽוֹם ־ חֹֽשֶׁךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Job 15:24",
      "text": "יְֽ֭בַעֲתֻהוּ צַ֣ר וּמְצוּקָ֑ה תִּ֝תְקְפֵ֗הוּ כְּמֶ֤לֶךְ ׀ עָתִ֬יד לַכִּידֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Job 15:25",
      "text": "כִּֽי ־ נָטָ֣ה אֶל ־ אֵ֣ל יָד֑וֹ וְאֶל ־ שַׁ֝דַּ֗י יִתְגַּבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Job 15:26",
      "text": "יָר֣וּץ אֵלָ֣יו בְּצַוָּ֑אר בַּ֝עֲבִ֗י גַּבֵּ֥י מָֽגִנָּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Job 15:27",
      "text": "כִּֽי ־ כִסָּ֣ה פָנָ֣יו בְּחֶלְבּ֑וֹ וַיַּ֖עַשׂ פִּימָ֣ה עֲלֵי ־ כָֽסֶל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Job 15:28",
      "text": "וַיִּשְׁכּ֤וֹן ׀ עָ֘רִ֤ים נִכְחָד֗וֹת בָּ֭תִּים לֹא ־ יֵ֣שְׁבוּ לָ֑מוֹ אֲשֶׁ֖ר הִתְעַתְּד֣וּ לְגַלִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Job 15:29",
      "text": "לֹֽא ־ יֶ֭עְשַׁר וְלֹא ־ יָק֣וּם חֵיל֑וֹ וְלֹֽא ־ יִטֶּ֖ה לָאָ֣רֶץ מִנְלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Job 15:30",
      "text": "לֹֽא ־ יָס֨וּר ׀ מִנִּי ־ חֹ֗שֶׁךְ יֹֽ֭נַקְתּוֹ תְּיַבֵּ֣שׁ שַׁלְהָ֑בֶת וְ֝יָס֗וּר בְּר֣וּחַ פִּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.31",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Job 15:31",
      "text": "אַל ־ יַאֲמֵ֣ן בשו נִתְעָ֑ה כִּי ־ שָׁ֝֗וְא תִּהְיֶ֥ה תְמוּרָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.32",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Job 15:32",
      "text": "בְּֽלֹא ־ י֭וֹמוֹ תִּמָּלֵ֑א וְ֝כִפָּת֗וֹ לֹ֣א רַעֲנָֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.33",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Job 15:33",
      "text": "יַחְמֹ֣ס כַּגֶּ֣פֶן בִּסְר֑וֹ וְיַשְׁלֵ֥ךְ כַּ֝זַּ֗יִת נִצָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.34",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Job 15:34",
      "text": "כִּֽי ־ עֲדַ֣ת חָנֵ֣ף גַּלְמ֑וּד וְ֝אֵ֗שׁ אָכְלָ֥ה אָֽהֳלֵי ־ שֹֽׁחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.15.35",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Job 15:35",
      "text": "הָרֹ֣ה עָ֭מָל וְיָ֣לֹד אָ֑וֶן וּ֝בִטְנָ֗ם תָּכִ֥ין מִרְמָֽה ׃ ס",
      "paragraphStart": false
    }
  ]
}
