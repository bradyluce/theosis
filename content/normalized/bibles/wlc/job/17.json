{
  "chapter": {
    "id": "wlc:job.17",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 17,
    "referenceLabel": "Job 17",
    "summary": "Source text for Job 17 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.17.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Job 17:1",
      "text": "רוּחִ֣י חֻ֭בָּלָה יָמַ֥י נִזְעָ֗כוּ קְבָרִ֥ים לִֽי ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.17.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Job 17:2",
      "text": "אִם ־ לֹ֣א הֲ֭תֻלִים עִמָּדִ֑י וּ֝בְהַמְּרוֹתָ֗ם תָּלַ֥ן עֵינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Job 17:3",
      "text": "שִֽׂימָה ־ נָּ֭א עָרְבֵ֣נִי עִמָּ֑ךְ מִֽי ה֝֗וּא לְיָדִ֥י יִתָּקֵֽעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Job 17:4",
      "text": "כִּֽי ־ לִ֭בָּם צָפַ֣נְתָּ מִּשָּׂ֑כֶל עַל ־ כֵּ֝֗ן לֹ֣א תְרֹמֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Job 17:5",
      "text": "לְ֭חֵלֶק יַגִּ֣יד רֵעִ֑ים וְעֵינֵ֖י בָנָ֣יו תִּכְלֶֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Job 17:6",
      "text": "וְֽ֭הִצִּגַנִי לִמְשֹׁ֣ל עַמִּ֑ים וְתֹ֖פֶת לְפָנִ֣ים אֶֽהְיֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Job 17:7",
      "text": "וַתֵּ֣כַהּ מִכַּ֣עַשׂ עֵינִ֑י וִֽיצֻרַ֖י כַּצֵּ֣ל כֻּלָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Job 17:8",
      "text": "יָשֹׁ֣מּוּ יְשָׁרִ֣ים עַל ־ זֹ֑את וְ֝נָקִ֗י עַל ־ חָנֵ֥ף יִתְעֹרָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Job 17:9",
      "text": "וְיֹאחֵ֣ז צַדִּ֣יק דַּרְכּ֑וֹ וּֽטֳהָר ־ יָ֝דַ֗יִם יֹסִ֥יף אֹֽמֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Job 17:10",
      "text": "וְֽאוּלָ֗ם כֻּלָּ֣ם תָּ֭שֻׁבוּ וּבֹ֣אוּ נָ֑א וְלֹֽא ־ אֶמְצָ֖א בָכֶ֣ם חָכָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Job 17:11",
      "text": "יָמַ֣י עָ֭בְרוּ זִמֹּתַ֣י נִתְּק֑וּ מ֖וֹרָשֵׁ֣י לְבָבִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Job 17:12",
      "text": "לַ֭יְלָה לְי֣וֹם יָשִׂ֑ימוּ א֝֗וֹר קָר֥וֹב מִפְּנֵי ־ חֹֽשֶׁךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Job 17:13",
      "text": "אִם ־ אֲ֭קַוֶּה שְׁא֣וֹל בֵּיתִ֑י בַּ֝חֹ֗שֶׁךְ רִפַּ֥דְתִּי יְצוּעָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Job 17:14",
      "text": "לַשַּׁ֣חַת קָ֭רָאתִי אָ֣בִי אָ֑תָּה אִמִּ֥י וַ֝אֲחֹתִ֗י לָֽרִמָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Job 17:15",
      "text": "וְ֭אַיֵּה אֵפ֣וֹ תִקְוָתִ֑י וְ֝תִקְוָתִ֗י מִ֣י יְשׁוּרֶֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.17.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Job 17:16",
      "text": "בַּדֵּ֣י שְׁאֹ֣ל תֵּרַ֑דְנָה אִם ־ יַ֖חַד עַל ־ עָפָ֣ר נָֽחַת ׃ ס",
      "paragraphStart": false
    }
  ]
}
