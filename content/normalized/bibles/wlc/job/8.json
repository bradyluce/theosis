{
  "chapter": {
    "id": "wlc:job.8",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 8,
    "referenceLabel": "Job 8",
    "summary": "Source text for Job 8 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.8.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Job 8:1",
      "text": "וַ֭יַּעַן בִּלְדַּ֥ד הַשּׁוּחִ֗י וַיֹאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.8.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Job 8:2",
      "text": "עַד ־ אָ֥ן תְּמַלֶּל ־ אֵ֑לֶּה וְר֥וּחַ כַּ֝בִּיר אִמְרֵי ־ פִֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Job 8:3",
      "text": "הַ֭אֵל יְעַוֵּ֣ת מִשְׁפָּ֑ט וְאִם ־ שַׁ֝דַּ֗י יְעַוֵּֽת ־ צֶֽדֶק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Job 8:4",
      "text": "אִם ־ בָּנֶ֥יךָ חָֽטְאוּ ־ ל֑וֹ וַֽ֝יְשַׁלְּחֵ֗ם בְּיַד ־ פִּשְׁעָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Job 8:5",
      "text": "אִם ־ אַ֭תָּה תְּשַׁחֵ֣ר אֶל ־ אֵ֑ל וְאֶל ־ שַׁ֝דַּ֗י תִּתְחַנָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Job 8:6",
      "text": "אִם ־ זַ֥ךְ וְיָשָׁ֗ר אָ֥תָּה כִּי ־ עַ֭תָּה יָעִ֣יר עָלֶ֑יךָ וְ֝שִׁלַּ֗ם נְוַ֣ת צִדְקֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Job 8:7",
      "text": "וְהָיָ֣ה רֵאשִׁיתְךָ֣ מִצְעָ֑ר וְ֝אַחֲרִיתְךָ֗ יִשְׂגֶּ֥ה מְאֹֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Job 8:8",
      "text": "כִּֽי ־ שְׁאַל ־ נָ֭א לְדֹ֣ר רִישׁ֑וֹן וְ֝כוֹנֵ֗ן לְחֵ֣קֶר אֲבוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Job 8:9",
      "text": "כִּֽי ־ תְמ֣וֹל אֲ֭נַחְנוּ וְלֹ֣א נֵדָ֑ע כִּ֤י צֵ֖ל יָמֵ֣ינוּ עֲלֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Job 8:10",
      "text": "הֲלֹא ־ הֵ֣ם י֭וֹרוּךָ יֹ֣אמְרוּ לָ֑ךְ וּ֝מִלִּבָּ֗ם יוֹצִ֥אוּ מִלִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Job 8:11",
      "text": "הֲיִֽגְאֶה ־ גֹּ֭מֶא בְּלֹ֣א בִצָּ֑ה יִשְׂגֶּה ־ אָ֥חוּ בְלִי ־ מָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Job 8:12",
      "text": "עֹדֶ֣נּוּ בְ֭אִבּוֹ לֹ֣א יִקָּטֵ֑ף וְלִפְנֵ֖י כָל ־ חָצִ֣יר יִיבָֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Job 8:13",
      "text": "כֵּ֗ן אָ֭רְחוֹת כָּל ־ שֹׁ֣כְחֵי אֵ֑ל וְתִקְוַ֖ת חָנֵ֣ף תֹּאבֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Job 8:14",
      "text": "אֲשֶׁר ־ יָק֥וֹט כִּסְל֑וֹ וּבֵ֥ית עַ֝כָּבִ֗ישׁ מִבְטַחֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Job 8:15",
      "text": "יִשָּׁעֵ֣ן עַל ־ בֵּ֭יתוֹ וְלֹ֣א יַעֲמֹ֑ד יַחֲזִ֥יק בּ֝֗וֹ וְלֹ֣א יָקֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Job 8:16",
      "text": "רָטֹ֣ב ה֭וּא לִפְנֵי ־ שָׁ֑מֶשׁ וְעַ֥ל גַּ֝נָּת֗וֹ יֹֽנַקְתּ֥וֹ תֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Job 8:17",
      "text": "עַל ־ גַּ֭ל שָֽׁרָשָׁ֣יו יְסֻבָּ֑כוּ בֵּ֖ית אֲבָנִ֣ים יֶחֱזֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Job 8:18",
      "text": "אִם ־ יְבַלְּעֶ֥נּוּ מִמְּקוֹמ֑וֹ וְכִ֥חֶשׁ בּ֝֗וֹ לֹ֣א רְאִיתִֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Job 8:19",
      "text": "הֶן ־ ה֭וּא מְשׂ֣וֹשׂ דַּרְכּ֑וֹ וּ֝מֵעָפָ֗ר אַחֵ֥ר יִצְמָֽחוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Job 8:20",
      "text": "הֶן ־ אֵ֭ל לֹ֣א יִמְאַס ־ תָּ֑ם וְלֹֽא ־ יַ֝חֲזִ֗יק בְּיַד ־ מְרֵעִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Job 8:21",
      "text": "עַד ־ יְמַלֵּ֣ה שְׂח֣וֹק פִּ֑יךָ וּשְׂפָתֶ֥יךָ תְרוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.8.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Job 8:22",
      "text": "שֹׂנְאֶ֥יךָ יִלְבְּשׁוּ ־ בֹ֑שֶׁת וְאֹ֖הֶל רְשָׁעִ֣ים אֵינֶֽנּוּ ׃ פ",
      "paragraphStart": false
    }
  ]
}
