{
  "chapter": {
    "id": "wlc:job.39",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 39,
    "referenceLabel": "Job 39",
    "summary": "Source text for Job 39 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.39.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 1,
      "referenceLabel": "Job 39:1",
      "text": "הֲיָדַ֗עְתָּ עֵ֭ת לֶ֣דֶת יַעֲלֵי ־ סָ֑לַע חֹלֵ֖ל אַיָּל֣וֹת תִּשְׁמֹֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.39.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 2,
      "referenceLabel": "Job 39:2",
      "text": "תִּסְפֹּ֣ר יְרָחִ֣ים תְּמַלֶּ֑אנָה וְ֝יָדַ֗עְתָּ עֵ֣ת לִדְתָּֽנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 3,
      "referenceLabel": "Job 39:3",
      "text": "תִּ֭כְרַעְנָה יַלְדֵיהֶ֣ן תְּפַלַּ֑חְנָה חֶבְלֵיהֶ֥ם תְּשַׁלַּֽחְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 4,
      "referenceLabel": "Job 39:4",
      "text": "יַחְלְמ֣וּ בְ֭נֵיהֶם יִרְבּ֣וּ בַבָּ֑ר יָ֝צְא֗וּ וְלֹא ־ שָׁ֥בוּ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 5,
      "referenceLabel": "Job 39:5",
      "text": "מִֽי ־ שִׁלַּ֣ח פֶּ֣רֶא חָפְשִׁ֑י וּמֹסְר֥וֹת עָ֝ר֗וֹד מִ֣י פִתֵּֽחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 6,
      "referenceLabel": "Job 39:6",
      "text": "אֲשֶׁר ־ שַׂ֣מְתִּי עֲרָבָ֣ה בֵית֑וֹ וּֽמִשְׁכְּנוֹתָ֥יו מְלֵֽחָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 7,
      "referenceLabel": "Job 39:7",
      "text": "יִ֭שְׂחַק לַהֲמ֣וֹן קִרְיָ֑ה תְּשֻׁא֥וֹת נ֝וֹגֵ֗שׂ לֹ֣א יִשְׁמָֽע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 8,
      "referenceLabel": "Job 39:8",
      "text": "יְת֣וּר הָרִ֣ים מִרְעֵ֑הוּ וְאַחַ֖ר כָּל ־ יָר֣וֹק יִדְרֽוֹשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 9,
      "referenceLabel": "Job 39:9",
      "text": "הֲיֹ֣אבֶה רֵּ֣ים עָבְדֶ֑ךָ אִם ־ יָ֝לִ֗ין עַל ־ אֲבוּסֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 10,
      "referenceLabel": "Job 39:10",
      "text": "הֲֽתִקְשָׁר ־ רֵ֭ים בְּתֶ֣לֶם עֲבֹת֑וֹ אִם ־ יְשַׂדֵּ֖ד עֲמָקִ֣ים אַחֲרֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 11,
      "referenceLabel": "Job 39:11",
      "text": "הֲֽתִבְטַח ־ בּ֭וֹ כִּי ־ רַ֣ב כֹּח֑וֹ וְתַעֲזֹ֖ב אֵלָ֣יו יְגִיעֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 12,
      "referenceLabel": "Job 39:12",
      "text": "הֲתַאֲמִ֣ין בּ֭וֹ כִּי ־ ישוב זַרְעֶ֑ךָ וְֽגָרְנְךָ֥ יֶאֱסֹֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 13,
      "referenceLabel": "Job 39:13",
      "text": "כְּנַף ־ רְנָנִ֥ים נֶעֱלָ֑סָה אִם ־ אֶ֝בְרָ֗ה חֲסִידָ֥ה וְנֹצָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 14,
      "referenceLabel": "Job 39:14",
      "text": "כִּֽי ־ תַעֲזֹ֣ב לָאָ֣רֶץ בֵּצֶ֑יהָ וְֽעַל ־ עָפָ֥ר תְּחַמֵּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 15,
      "referenceLabel": "Job 39:15",
      "text": "וַ֭תִּשְׁכַּח כִּי ־ רֶ֣גֶל תְּזוּרֶ֑הָ וְחַיַּ֖ת הַשָּׂדֶ֣ה תְּדוּשֶֽׁהָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 16,
      "referenceLabel": "Job 39:16",
      "text": "הִקְשִׁ֣יחַ בָּנֶ֣יהָ לְּלֹא ־ לָ֑הּ לְרִ֖יק יְגִיעָ֣הּ בְּלִי ־ פָֽחַד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 17,
      "referenceLabel": "Job 39:17",
      "text": "כִּֽי ־ הִשָּׁ֣הּ אֱל֣וֹהַּ חָכְמָ֑ה וְלֹא ־ חָ֥לַק לָ֝֗הּ בַּבִּינָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 18,
      "referenceLabel": "Job 39:18",
      "text": "כָּ֭עֵת בַּמָּר֣וֹם תַּמְרִ֑יא תִּֽשְׂחַ֥ק לַ֝סּ֗וּס וּלְרֹֽכְבֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 19,
      "referenceLabel": "Job 39:19",
      "text": "הֲתִתֵּ֣ן לַסּ֣וּס גְּבוּרָ֑ה הֲתַלְבִּ֖ישׁ צַוָּאר֣וֹ רַעְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 20,
      "referenceLabel": "Job 39:20",
      "text": "הְֽ֭תַרְעִישֶׁנּוּ כָּאַרְבֶּ֑ה ה֖וֹד נַחְר֣וֹ אֵימָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 21,
      "referenceLabel": "Job 39:21",
      "text": "יַחְפְּר֣וּ בָ֭עֵמֶק וְיָשִׂ֣ישׂ בְּכֹ֑חַ יֵ֝צֵ֗א לִקְרַאת ־ נָֽשֶׁק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 22,
      "referenceLabel": "Job 39:22",
      "text": "יִשְׂחַ֣ק לְ֭פַחַד וְלֹ֣א יֵחָ֑ת וְלֹֽא ־ יָ֝שׁ֗וּב מִפְּנֵי ־ חָֽרֶב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 23,
      "referenceLabel": "Job 39:23",
      "text": "עָ֭לָיו תִּרְנֶ֣ה אַשְׁפָּ֑ה לַ֖הַב חֲנִ֣ית וְכִידֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 24,
      "referenceLabel": "Job 39:24",
      "text": "בְּרַ֣עַשׁ וְ֭רֹגֶז יְגַמֶּא ־ אָ֑רֶץ וְלֹֽא ־ יַ֝אֲמִ֗ין כִּי ־ ק֥וֹל שׁוֹפָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 25,
      "referenceLabel": "Job 39:25",
      "text": "בְּדֵ֤י שֹׁפָ֨ר ׀ יֹ֘אמַ֤ר הֶאָ֗ח וּֽ֭מֵרָחוֹק יָרִ֣יחַ מִלְחָמָ֑ה רַ֥עַם שָׂ֝רִים וּתְרוּעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 26,
      "referenceLabel": "Job 39:26",
      "text": "הֲֽ֭מִבִּינָ֣תְךָ יַֽאֲבֶר ־ נֵ֑ץ יִפְרֹ֖שׂ כנפו לְתֵימָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 27,
      "referenceLabel": "Job 39:27",
      "text": "אִם ־ עַל ־ פִּ֭יךָ יַגְבִּ֣יהַּ נָ֑שֶׁר וְ֝כִ֗י יָרִ֥ים קִנּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 28,
      "referenceLabel": "Job 39:28",
      "text": "סֶ֣לַע יִ֭שְׁכֹּן וְיִתְלֹנָ֑ן עַֽל ־ שֶׁן ־ סֶ֝֗לַע וּמְצוּדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 29,
      "referenceLabel": "Job 39:29",
      "text": "מִשָּׁ֥ם חָֽפַר ־ אֹ֑כֶל לְ֝מֵרָח֗וֹק עֵינָ֥יו יַבִּֽיטוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.39.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 30,
      "referenceLabel": "Job 39:30",
      "text": "ואפרחו יְעַלְעוּ ־ דָ֑ם וּבַאֲשֶׁ֥ר חֲ֝לָלִ֗ים שָׁ֣ם הֽוּא ׃ פ",
      "paragraphStart": false
    }
  ]
}
