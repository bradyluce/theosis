{
  "chapter": {
    "id": "wlc:job.22",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 22,
    "referenceLabel": "Job 22",
    "summary": "Source text for Job 22 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.22.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Job 22:1",
      "text": "וַ֭יַּעַן אֱלִיפַ֥ז הַֽתֵּמָנִ֗י וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.22.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Job 22:2",
      "text": "הַלְאֵ֥ל יִסְכָּן ־ גָּ֑בֶר כִּֽי ־ יִסְכֹּ֖ן עָלֵ֣ימוֹ מַשְׂכִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Job 22:3",
      "text": "הַחֵ֣פֶץ לְ֭שַׁדַּי כִּ֣י תִצְדָּ֑ק וְאִם ־ בֶּ֝֗צַע כִּֽי ־ תַתֵּ֥ם דְּרָכֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Job 22:4",
      "text": "הֲֽ֭מִיִּרְאָ֣תְךָ יֹכִיחֶ֑ךָ יָב֥וֹא עִ֝מְּךָ֗ בַּמִּשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Job 22:5",
      "text": "הֲלֹ֣א רָעָֽתְךָ֣ רַבָּ֑ה וְאֵֽין ־ קֵ֝֗ץ לַעֲוֺנֹתֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Job 22:6",
      "text": "כִּֽי ־ תַחְבֹּ֣ל אַחֶ֣יךָ חִנָּ֑ם וּבִגְדֵ֖י עֲרוּמִּ֣ים תַּפְשִֽׁיט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Job 22:7",
      "text": "לֹא ־ מַ֭יִם עָיֵ֣ף תַּשְׁקֶ֑ה וּ֝מֵרָעֵ֗ב תִּֽמְנַֽע ־ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Job 22:8",
      "text": "וְאִ֣ישׁ זְ֭רוֹעַ ל֣וֹ הָאָ֑רֶץ וּנְשׂ֥וּא פָ֝נִ֗ים יֵ֣שֶׁב בָּֽהּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Job 22:9",
      "text": "אַ֭לְמָנוֹת שִׁלַּ֣חְתָּ רֵיקָ֑ם וּזְרֹע֖וֹת יְתֹמִ֣ים יְדֻכָּֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Job 22:10",
      "text": "עַל ־ כֵּ֭ן סְבִיבוֹתֶ֣יךָ פַחִ֑ים וִֽ֝יבַהֶלְךָ פַּ֣חַד פִּתְאֹֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Job 22:11",
      "text": "אוֹ ־ חֹ֥שֶׁךְ לֹֽא ־ תִרְאֶ֑ה וְֽשִׁפְעַת ־ מַ֥יִם תְּכַסֶּֽךָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Job 22:12",
      "text": "הֲֽלֹא ־ אֱ֭לוֹהַּ גֹּ֣בַהּ שָׁמָ֑יִם וּרְאֵ֤ה רֹ֖אשׁ כּוֹכָבִ֣ים כִּי ־ רָֽמּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Job 22:13",
      "text": "וְֽ֭אָמַרְתָּ מַה ־ יָּ֣דַֽע אֵ֑ל הַבְעַ֖ד עֲרָפֶ֣ל יִשְׁפּֽוֹט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Job 22:14",
      "text": "עָבִ֣ים סֵֽתֶר ־ ל֭וֹ וְלֹ֣א יִרְאֶ֑ה וְח֥וּג שָׁ֝מַ֗יִם יִתְהַלָּֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Job 22:15",
      "text": "הַאֹ֣רַח עוֹלָ֣ם תִּשְׁמֹ֑ר אֲשֶׁ֖ר דָּרְכ֣וּ מְתֵי ־ אָֽוֶן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Job 22:16",
      "text": "אֲשֶֽׁר ־ קֻמְּט֥וּ וְלֹא ־ עֵ֑ת נָ֝הָ֗ר יוּצַ֥ק יְסוֹדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Job 22:17",
      "text": "הָאֹמְרִ֣ים לָ֭אֵל ס֣וּר מִמֶּ֑נּוּ וּמַה ־ יִּפְעַ֖ל שַׁדַּ֣י לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Job 22:18",
      "text": "וְה֤וּא מִלֵּ֣א בָתֵּיהֶ֣ם ט֑וֹב וַעֲצַ֥ת רְ֝שָׁעִ֗ים רָ֣חֲקָה מֶֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Job 22:19",
      "text": "יִרְא֣וּ צַדִּיקִ֣ים וְיִשְׂמָ֑חוּ וְ֝נָקִ֗י יִלְעַג ־ לָֽמוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Job 22:20",
      "text": "אִם ־ לֹ֣א נִכְחַ֣ד קִימָ֑נוּ וְ֝יִתְרָ֗ם אָ֣כְלָה אֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Job 22:21",
      "text": "הַסְכֶּן ־ נָ֣א עִמּ֑וֹ וּשְׁלם בָּ֝הֶ֗ם תְּֽבוֹאַתְךָ֥ טוֹבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Job 22:22",
      "text": "קַח ־ נָ֣א מִפִּ֣יו תּוֹרָ֑ה וְשִׂ֥ים אֲ֝מָרָ֗יו בִּלְבָבֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Job 22:23",
      "text": "אִם ־ תָּשׁ֣וּב עַד ־ שַׁ֭דַּי תִּבָּנֶ֑ה תַּרְחִ֥יק עַ֝וְלָ֗ה מֵאָהֳלֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Job 22:24",
      "text": "וְשִׁית ־ עַל ־ עָפָ֥ר בָּ֑צֶר וּבְצ֖וּר נְחָלִ֣ים אוֹפִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Job 22:25",
      "text": "וְהָיָ֣ה שַׁדַּ֣י בְּצָרֶ֑יךָ וְכֶ֖סֶף תּוֹעָפ֣וֹת לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Job 22:26",
      "text": "כִּי ־ אָ֭ז עַל ־ שַׁדַּ֣י תִּתְעַנָּ֑ג וְתִשָּׂ֖א אֶל ־ אֱל֣וֹהַּ פָּנֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Job 22:27",
      "text": "תַּעְתִּ֣יר אֵ֭לָיו וְיִשְׁמָעֶ֑ךָּ וּנְדָרֶ֥יךָ תְשַׁלֵּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Job 22:28",
      "text": "וְֽתִגְזַר ־ א֭וֹמֶר וְיָ֣קָם לָ֑ךְ וְעַל ־ דְּ֝רָכֶ֗יךָ נָ֣גַֽהּ אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Job 22:29",
      "text": "כִּֽי ־ הִ֭שְׁפִּילוּ וַתֹּ֣אמֶר גֵּוָ֑ה וְשַׁ֖ח עֵינַ֣יִם יוֹשִֽׁעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.22.30",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Job 22:30",
      "text": "יְֽמַלֵּ֥ט אִֽי ־ נָקִ֑י וְ֝נִמְלַ֗ט בְּבֹ֣ר כַּפֶּֽיךָ ׃ פ",
      "paragraphStart": false
    }
  ]
}
