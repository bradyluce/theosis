{
  "chapter": {
    "id": "wlc:job.16",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 16,
    "referenceLabel": "Job 16",
    "summary": "Source text for Job 16 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.16.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Job 16:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.16.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Job 16:2",
      "text": "שָׁמַ֣עְתִּי כְאֵ֣לֶּה רַבּ֑וֹת מְנַחֲמֵ֖י עָמָ֣ל כֻּלְּכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Job 16:3",
      "text": "הֲקֵ֥ץ לְדִבְרֵי ־ ר֑וּחַ א֥וֹ מַה ־ יַּ֝מְרִֽיצְךָ֗ כִּ֣י תַעֲנֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Job 16:4",
      "text": "גַּ֤ם ׀ אָנֹכִי֮ כָּכֶ֪ם אֲדַ֫בֵּ֥רָה ל֤וּ ־ יֵ֪שׁ נַפְשְׁכֶ֡ם תַּ֤חַת נַפְשִׁ֗י אַחְבִּ֣ירָה עֲלֵיכֶ֣ם בְּמִלִּ֑ים וְאָנִ֥יעָה עֲ֝לֵיכֶ֗ם בְּמ֣וֹ רֹאשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Job 16:5",
      "text": "אֲאַמִּצְכֶ֥ם בְּמוֹ ־ פִ֑י וְנִ֖יד שְׂפָתַ֣י יַחְשֹֽׂךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Job 16:6",
      "text": "אִֽם ־ אֲ֭דַבְּרָה לֹא ־ יֵחָשֵׂ֣ךְ כְּאֵבִ֑י וְ֝אַחְדְּלָ֗ה מַה ־ מִנִּ֥י יַהֲלֹֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Job 16:7",
      "text": "אַךְ ־ עַתָּ֥ה הֶלְאָ֑נִי הֲ֝שִׁמּ֗וֹתָ כָּל ־ עֲדָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Job 16:8",
      "text": "וַֽ֭תִּקְמְטֵנִי לְעֵ֣ד הָיָ֑ה וַיָּ֥קָם בִּ֥י כַ֝חֲשִׁ֗י בְּפָנַ֥י יַעֲנֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Job 16:9",
      "text": "אַפּ֤וֹ טָרַ֨ף ׀ וַֽיִּשְׂטְמֵ֗נִי חָרַ֣ק עָלַ֣י בְּשִׁנָּ֑יו צָרִ֓י ׀ יִלְט֖וֹשׁ עֵינָ֣יו לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Job 16:10",
      "text": "פָּעֲר֬וּ עָלַ֨י ׀ בְּפִיהֶ֗ם בְּ֭חֶרְפָּה הִכּ֣וּ לְחָיָ֑י יַ֝֗חַד עָלַ֥י יִתְמַלָּאֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Job 16:11",
      "text": "יַסְגִּירֵ֣נִי אֵ֭ל אֶ֣ל עֲוִ֑יל וְעַל ־ יְדֵ֖י רְשָׁעִ֣ים יִרְטֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Job 16:12",
      "text": "שָׁ֘לֵ֤ו הָיִ֨יתִי ׀ וַֽיְפַרְפְּרֵ֗נִי וְאָחַ֣ז בְּ֭עָרְפִּי וַֽיְפַצְפְּצֵ֑נִי וַיְקִימֵ֥נִי ל֝֗וֹ לְמַטָּרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Job 16:13",
      "text": "יָ֘סֹ֤בּוּ עָלַ֨י ׀ רַבָּ֗יו יְפַלַּ֣ח כִּ֭לְיוֹתַי וְלֹ֣א יַחְמ֑וֹל יִשְׁפֹּ֥ךְ לָ֝אָ֗רֶץ מְרֵרָֽתִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Job 16:14",
      "text": "יִפְרְצֵ֣נִי פֶ֭רֶץ עַל ־ פְּנֵי ־ פָ֑רֶץ יָרֻ֖ץ עָלַ֣י כְּגִבּֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Job 16:15",
      "text": "שַׂ֣ק תָּ֭פַרְתִּי עֲלֵ֣י גִלְדִּ֑י וְעֹלַ֖לְתִּי בֶעָפָ֣ר קַרְנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Job 16:16",
      "text": "פָּנַ֣י חמרמרה מִנִּי ־ בֶ֑כִי וְעַ֖ל עַפְעַפַּ֣י צַלְמָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Job 16:17",
      "text": "עַ֭ל לֹא ־ חָמָ֣ס בְּכַפָּ֑י וּֽתְפִלָּתִ֥י זַכָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Job 16:18",
      "text": "אֶ֭רֶץ אַל ־ תְּכַסִּ֣י דָמִ֑י וְֽאַל ־ יְהִ֥י מָ֝ק֗וֹם לְזַעֲקָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Job 16:19",
      "text": "גַּם ־ עַ֭תָּה הִנֵּה ־ בַשָּׁמַ֣יִם עֵדִ֑י וְ֝שָׂהֲדִ֗י בַּמְּרוֹמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Job 16:20",
      "text": "מְלִיצַ֥י רֵעָ֑י אֶל ־ אֱ֝ל֗וֹהַ דָּלְפָ֥ה עֵינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Job 16:21",
      "text": "וְיוֹכַ֣ח לְגֶ֣בֶר עִם ־ אֱל֑וֹהַּ וּֽבֶן ־ אָדָ֥ם לְרֵעֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.16.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Job 16:22",
      "text": "כִּֽי ־ שְׁנ֣וֹת מִסְפָּ֣ר יֶאֱתָ֑יוּ וְאֹ֖רַח לֹא ־ אָשׁ֣וּב אֶהֱלֹֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
