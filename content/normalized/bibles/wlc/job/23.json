{
  "chapter": {
    "id": "wlc:job.23",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 23,
    "referenceLabel": "Job 23",
    "summary": "Source text for Job 23 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.23.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Job 23:1",
      "text": "וַיַּ֥עַן אִיּ֗וֹב וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.23.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Job 23:2",
      "text": "גַּם ־ הַ֭יּוֹם מְרִ֣י שִׂחִ֑י יָ֝דִ֗י כָּבְדָ֥ה עַל ־ אַנְחָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Job 23:3",
      "text": "מִֽי ־ יִתֵּ֣ן יָ֭דַעְתִּי וְאֶמְצָאֵ֑הוּ אָ֝ב֗וֹא עַד ־ תְּכוּנָתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Job 23:4",
      "text": "אֶעֶרְכָ֣ה לְפָנָ֣יו מִשְׁפָּ֑ט וּ֝פִ֗י אֲמַלֵּ֥א תוֹכָחֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Job 23:5",
      "text": "אֵ֭דְעָה מִלִּ֣ים יַעֲנֵ֑נִי וְ֝אָבִ֗ינָה מַה ־ יֹּ֥אמַר לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Job 23:6",
      "text": "הַבְּרָב ־ כֹּ֭חַ יָרִ֣יב עִמָּדִ֑י לֹ֥א אַךְ ־ ה֝֗וּא יָשִׂ֥ם בִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Job 23:7",
      "text": "שָׁ֗ם יָ֭שָׁר נוֹכָ֣ח עִמּ֑וֹ וַאֲפַלְּטָ֥ה לָ֝נֶ֗צַח מִשֹּׁפְטִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Job 23:8",
      "text": "הֵ֤ן קֶ֣דֶם אֶהֱלֹ֣ךְ וְאֵינֶ֑נּוּ וְ֝אָח֗וֹר וְֽלֹא ־ אָבִ֥ין לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Job 23:9",
      "text": "שְׂמֹ֣אול בַּעֲשֹׂת֣וֹ וְלֹא ־ אָ֑חַז יַעְטֹ֥ף יָ֝מִ֗ין וְלֹ֣א אֶרְאֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Job 23:10",
      "text": "כִּֽי ־ יָ֭דַע דֶּ֣רֶךְ עִמָּדִ֑י בְּ֝חָנַ֗נִי כַּזָּהָ֥ב אֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Job 23:11",
      "text": "בַּ֭אֲשֻׁרוֹ אָחֲזָ֣ה רַגְלִ֑י דַּרְכּ֖וֹ שָׁמַ֣רְתִּי וְלֹא ־ אָֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Job 23:12",
      "text": "מִצְוַ֣ת שְׂ֭פָתָיו וְלֹ֣א אָמִ֑ישׁ מֵ֝חֻקִּ֗י צָפַ֥נְתִּי אִמְרֵי ־ פִֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Job 23:13",
      "text": "וְה֣וּא בְ֭אֶחָד וּמִ֣י יְשִׁיבֶ֑נּוּ וְנַפְשׁ֖וֹ אִוְּתָ֣ה וַיָּֽעַשׂ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Job 23:14",
      "text": "כִּ֭י יַשְׁלִ֣ים חֻקִּ֑י וְכָהֵ֖נָּה רַבּ֣וֹת עִמּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Job 23:15",
      "text": "עַל ־ כֵּ֭ן מִפָּנָ֣יו אֶבָּהֵ֑ל אֶ֝תְבּוֹנֵ֗ן וְאֶפְחַ֥ד מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Job 23:16",
      "text": "וְ֭אֵל הֵרַ֣ךְ לִבִּ֑י וְ֝שַׁדַּ֗י הִבְהִילָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.23.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Job 23:17",
      "text": "כִּֽי ־ לֹ֣א נִ֭צְמַתִּי מִפְּנֵי ־ חֹ֑שֶׁךְ וּ֝מִפָּנַ֗י כִּסָּה ־ אֹֽפֶל ׃",
      "paragraphStart": false
    }
  ]
}
