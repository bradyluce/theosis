{
  "chapter": {
    "id": "wlc:job.20",
    "translationId": "wlc",
    "bookSlug": "job",
    "chapterNumber": 20,
    "referenceLabel": "Job 20",
    "summary": "Source text for Job 20 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:job.20.1",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Job 20:1",
      "text": "וַ֭יַּעַן צֹפַ֥ר הַנַּֽעֲמָתִ֗י וַיֹּאמַֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:job.20.2",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Job 20:2",
      "text": "לָ֭כֵן שְׂעִפַּ֣י יְשִׁיב֑וּנִי וּ֝בַעֲב֗וּר ח֣וּשִׁי בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.3",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Job 20:3",
      "text": "מוּסַ֣ר כְּלִמָּתִ֣י אֶשְׁמָ֑ע וְ֝ר֗וּחַ מִֽבִּינָתִ֥י יַעֲנֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.4",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Job 20:4",
      "text": "הֲזֹ֣את יָ֭דַעְתָּ מִנִּי ־ עַ֑ד מִנִּ֤י שִׂ֖ים אָדָ֣ם עֲלֵי ־ אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.5",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Job 20:5",
      "text": "כִּ֤י רִנְנַ֣ת רְ֭שָׁעִים מִקָּר֑וֹב וְשִׂמְחַ֖ת חָנֵ֣ף עֲדֵי ־ רָֽגַע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.6",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Job 20:6",
      "text": "אִם ־ יַעֲלֶ֣ה לַשָּׁמַ֣יִם שִׂיא֑וֹ וְ֝רֹאשׁ֗וֹ לָעָ֥ב יַגִּֽיעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.7",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Job 20:7",
      "text": "כְּֽ֭גֶלֲלוֹ לָנֶ֣צַח יֹאבֵ֑ד רֹ֝אָ֗יו יֹאמְר֥וּ אַיּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.8",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Job 20:8",
      "text": "כַּחֲל֣וֹם יָ֭עוּף וְלֹ֣א יִמְצָא֑וּהוּ וְ֝יֻדַּ֗ד כְּחֶזְי֥וֹן לָֽיְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.9",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Job 20:9",
      "text": "עַ֣יִן שְׁ֭זָפַתּוּ וְלֹ֣א תוֹסִ֑יף וְלֹא ־ ע֝֗וֹד תְּשׁוּרֶ֥נּוּ מְקוֹמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.10",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Job 20:10",
      "text": "בָּ֭נָיו יְרַצּ֣וּ דַלִּ֑ים וְ֝יָדָ֗יו תָּשֵׁ֥בְנָה אוֹנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.11",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Job 20:11",
      "text": "עַ֭צְמוֹתָיו מָלְא֣וּ עלומו וְ֝עִמּ֗וֹ עַל ־ עָפָ֥ר תִּשְׁכָּֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.12",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Job 20:12",
      "text": "אִם ־ תַּמְתִּ֣יק בְּפִ֣יו רָעָ֑ה יַ֝כְחִידֶ֗נָּה תַּ֣חַת לְשׁוֹנֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.13",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Job 20:13",
      "text": "יַחְמֹ֣ל עָ֭לֶיהָ וְלֹ֣א יַֽעַזְבֶ֑נָּה וְ֝יִמְנָעֶ֗נָּה בְּת֣וֹךְ חִכּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.14",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Job 20:14",
      "text": "לַ֭חְמוֹ בְּמֵעָ֣יו נֶהְפָּ֑ךְ מְרוֹרַ֖ת פְּתָנִ֣ים בְּקִרְבּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.15",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Job 20:15",
      "text": "חַ֣יִל בָּ֭לַע וַיְקִאֶ֑נּוּ מִ֝בִּטְנ֗וֹ יוֹרִשֶׁ֥נּוּ אֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.16",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Job 20:16",
      "text": "רֹאשׁ ־ פְּתָנִ֥ים יִינָ֑ק תַּֽ֝הַרְגֵ֗הוּ לְשׁ֣וֹן אֶפְעֶֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.17",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Job 20:17",
      "text": "אַל ־ יֵ֥רֶא בִפְלַגּ֑וֹת נַהֲרֵ֥י נַ֝חֲלֵ֗י דְּבַ֣שׁ וְחֶמְאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.18",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Job 20:18",
      "text": "מֵשִׁ֣יב יָ֭גָע וְלֹ֣א יִבְלָ֑ע כְּחֵ֥יל תְּ֝מוּרָת֗וֹ וְלֹ֣א יַעֲלֹֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.19",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Job 20:19",
      "text": "כִּֽי ־ רִ֭צַּץ עָזַ֣ב דַּלִּ֑ים בַּ֥יִת גָּ֝זַ֗ל וְלֹ֣א יִבֶנֵֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.20",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Job 20:20",
      "text": "כִּ֤י ׀ לֹא ־ יָדַ֣ע שָׁלֵ֣ו בְּבִטְנ֑וֹ בַּ֝חֲמוּד֗וֹ לֹ֣א יְמַלֵּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.21",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Job 20:21",
      "text": "אֵין ־ שָׂרִ֥יד לְאָכְל֑וֹ עַל ־ כֵּ֝֗ן לֹא ־ יָחִ֥יל טוּבֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.22",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Job 20:22",
      "text": "בִּמְלֹ֣אות שִׂ֭פְקוֹ יֵ֣צֶר ל֑וֹ כָּל ־ יַ֖ד עָמֵ֣ל תְּבוֹאֶֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.23",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Job 20:23",
      "text": "יְהִ֤י ׀ לְמַלֵּ֬א בִטְנ֗וֹ יְֽשַׁלַּח ־ בּ֭וֹ חֲר֣וֹן אַפּ֑וֹ וְיַמְטֵ֥ר עָ֝לֵ֗ימוֹ בִּלְחוּמֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.24",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Job 20:24",
      "text": "יִ֭בְרַח מִנֵּ֣שֶׁק בַּרְזֶ֑ל תַּ֝חְלְפֵ֗הוּ קֶ֣שֶׁת נְחוּשָֽׁה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.25",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Job 20:25",
      "text": "שָׁלַף֮ וַיֵּצֵ֪א מִגֵּ֫וָ֥ה וּ֭בָרָק מִֽמְּרֹרָת֥וֹ יַהֲלֹ֗ךְ עָלָ֥יו אֵמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.26",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Job 20:26",
      "text": "כָּל ־ חֹשֶׁךְ֮ טָמ֪וּן לִצְפּ֫וּנָ֥יו תְּ֭אָכְלֵהוּ אֵ֣שׁ לֹֽא ־ נֻפָּ֑ח יֵ֖רַע שָׂרִ֣יד בְּאָהֳלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.27",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Job 20:27",
      "text": "יְגַלּ֣וּ שָׁמַ֣יִם עֲוֺנ֑וֹ וְ֝אֶ֗רֶץ מִתְקוֹמָ֘מָ֥ה לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.28",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Job 20:28",
      "text": "יִ֭גֶל יְב֣וּל בֵּית֑וֹ נִ֝גָּר֗וֹת בְּי֣וֹם אַפּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:job.20.29",
      "translationId": "wlc",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Job 20:29",
      "text": "זֶ֤ה ׀ חֵֽלֶק ־ אָדָ֣ם רָ֭שָׁע מֵאֱלֹהִ֑ים וְנַחֲלַ֖ת אִמְר֣וֹ מֵאֵֽל ׃ פ",
      "paragraphStart": false
    }
  ]
}
