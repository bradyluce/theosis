  },
  "verses": [
    {
      "id": "wlc:leviticus.18.1",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 18:1",
      "text": "וַיְדַבֵּ֥ר יְהוָ֖ה אֶל ־ מֹשֶׁ֥ה לֵּאמֹֽר ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:leviticus.18.2",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 18:2",
      "text": "דַּבֵּר֙ אֶל ־ בְּנֵ֣י יִשְׂרָאֵ֔ל וְאָמַרְתָּ֖ אֲלֵהֶ֑ם אֲנִ֖י יְהוָ֥ה אֱלֹהֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.3",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 18:3",
      "text": "כְּמַעֲשֵׂ֧ה אֶֽרֶץ ־ מִצְרַ֛יִם אֲשֶׁ֥ר יְשַׁבְתֶּם ־ בָּ֖הּ לֹ֣א תַעֲשׂ֑וּ וּכְמַעֲשֵׂ֣ה אֶֽרֶץ ־ כְּנַ֡עַן אֲשֶׁ֣ר אֲנִי֩ מֵבִ֨יא אֶתְכֶ֥ם שָׁ֨מָּה֙ לֹ֣א תַעֲשׂ֔וּ וּבְחֻקֹּתֵיהֶ֖ם לֹ֥א תֵלֵֽכוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.4",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 18:4",
      "text": "אֶת ־ מִשְׁפָּטַ֧י תַּעֲשׂ֛וּ וְאֶת ־ חֻקֹּתַ֥י תִּשְׁמְר֖וּ לָלֶ֣כֶת בָּהֶ֑ם אֲנִ֖י יְהוָ֥ה אֱלֹהֵיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.5",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 18:5",
      "text": "וּשְׁמַרְתֶּ֤ם אֶת ־ חֻקֹּתַי֙ וְאֶת ־ מִשְׁפָּטַ֔י אֲשֶׁ֨ר יַעֲשֶׂ֥ה אֹתָ֛ם הָאָדָ֖ם וָחַ֣י בָּהֶ֑ם אֲנִ֖י יְהוָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.6",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 18:6",
      "text": "אִ֥ישׁ אִישׁ֙ אֶל ־ כָּל ־ שְׁאֵ֣ר בְּשָׂר֔וֹ לֹ֥א תִקְרְב֖וּ לְגַלּ֣וֹת עֶרְוָ֑ה אֲנִ֖י יְהוָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.7",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 18:7",
      "text": "עֶרְוַ֥ת אָבִ֛יךָ וְעֶרְוַ֥ת אִמְּךָ֖ לֹ֣א תְגַלֵּ֑ה אִמְּךָ֣ הִ֔וא לֹ֥א תְגַלֶּ֖ה עֶרְוָתָֽהּ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.8",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 18:8",
      "text": "עֶרְוַ֥ת אֵֽשֶׁת ־ אָבִ֖יךָ לֹ֣א תְגַלֵּ֑ה עֶרְוַ֥ת אָבִ֖יךָ הִֽוא ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.9",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 18:9",
      "text": "עֶרְוַ֨ת אֲחֽוֹתְךָ֤ בַת ־ אָבִ֨יךָ֙ א֣וֹ בַת ־ אִמֶּ֔ךָ מוֹלֶ֣דֶת בַּ֔יִת א֖וֹ מוֹלֶ֣דֶת ח֑וּץ לֹ֥א תְגַלֶּ֖ה עֶרְוָתָֽן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:leviticus.18.10",
      "translationId": "wlc",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 18:10",
      "text": "עֶרְוַ֤ת בַּת ־ בִּנְךָ֙ א֣וֹ בַֽת ־ בִּתְּךָ֔ לֹ֥א תְגַלֶּ֖ה עֶרְוָתָ֑ן כִּ֥י עֶרְוָתְךָ֖ הֵֽנָּה ׃ ס",
      "paragraphStart": false
    },
    {
