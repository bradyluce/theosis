{
  "chapter": {
    "id": "wlc:second-samuel.22",
    "translationId": "wlc",
    "bookSlug": "second-samuel",
    "chapterNumber": 22,
    "referenceLabel": "2 Samuel 22",
    "summary": "Source text for 2 Samuel 22 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:second-samuel.22.1",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "2 Samuel 22:1",
      "text": "וַיְדַבֵּ֤ר דָּוִד֙ לַֽיהוָ֔ה אֶת ־ דִּבְרֵ֖י הַשִּׁירָ֣ה הַזֹּ֑את בְּיוֹם֩ הִצִּ֨יל יְהוָ֥ה אֹת֛וֹ מִכַּ֥ף כָּל ־ אֹיְבָ֖יו וּמִכַּ֥ף שָׁאֽוּל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:second-samuel.22.2",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "2 Samuel 22:2",
      "text": "וַיֹּאמַ֑ר יְהוָ֛ה סַֽלְעִ֥י וּמְצֻדָתִ֖י וּמְפַלְטִי ־ לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.3",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "2 Samuel 22:3",
      "text": "אֱלֹהֵ֥י צוּרִ֖י אֶחֱסֶה ־ בּ֑וֹ מָגִנִּ֞י וְקֶ֣רֶן יִשְׁעִ֗י מִשְׂגַּבִּי֙ וּמְנוּסִ֔י מֹשִׁעִ֕י מֵחָמָ֖ס תֹּשִׁעֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.4",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "2 Samuel 22:4",
      "text": "מְהֻלָּ֖ל אֶקְרָ֣א יְהוָ֑ה וּמֵאֹיְבַ֖י אִוָּשֵֽׁעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.5",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "2 Samuel 22:5",
      "text": "כִּ֥י אֲפָפֻ֖נִי מִשְׁבְּרֵי ־ מָ֑וֶת נַחֲלֵ֥י בְלִיַּ֖עַל יְבַעֲתֻֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.6",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "2 Samuel 22:6",
      "text": "חֶבְלֵ֥י שְׁא֖וֹל סַבֻּ֑נִי קִדְּמֻ֖נִי מֹֽקְשֵׁי ־ מָֽוֶת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.7",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "2 Samuel 22:7",
      "text": "בַּצַּר ־ לִי֙ אֶקְרָ֣א יְהוָ֔ה וְאֶל ־ אֱלֹהַ֖י אֶקְרָ֑א וַיִּשְׁמַ֤ע מֵהֵֽיכָלוֹ֙ קוֹלִ֔י וְשַׁוְעָתִ֖י בְּאָזְנָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.8",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "2 Samuel 22:8",
      "text": "ותגעש וַתִּרְעַשׁ֙ הָאָ֔רֶץ מוֹסְד֥וֹת הַשָּׁמַ֖יִם יִרְגָּ֑זוּ וַיִּֽתְגָּעֲשׁ֖וּ כִּֽי ־ חָ֥רָה לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.9",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "2 Samuel 22:9",
      "text": "עָלָ֤ה עָשָׁן֙ בְּאַפּ֔וֹ וְאֵ֥שׁ מִפִּ֖יו תֹּאכֵ֑ל גֶּחָלִ֖ים בָּעֲר֥וּ מִמֶּֽנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.10",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "2 Samuel 22:10",
      "text": "וַיֵּ֥ט שָׁמַ֖יִם וַיֵּרַ֑ד וַעֲרָפֶ֖ל תַּ֥חַת רַגְלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.11",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "2 Samuel 22:11",
      "text": "וַיִּרְכַּ֥ב עַל ־ כְּר֖וּב וַיָּעֹ֑ף וַיֵּרָ֖א עַל ־ כַּנְפֵי ־ רֽוּחַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.12",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "2 Samuel 22:12",
      "text": "וַיָּ֥שֶׁת חֹ֛שֶׁךְ סְבִיבֹתָ֖יו סֻכּ֑וֹת חַֽשְׁרַת ־ מַ֖יִם עָבֵ֥י שְׁחָקִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.13",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "2 Samuel 22:13",
      "text": "מִנֹּ֖גַהּ נֶגְדּ֑וֹ בָּעֲר֖וּ גַּחֲלֵי ־ אֵֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.14",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "2 Samuel 22:14",
      "text": "יַרְעֵ֥ם מִן ־ שָׁמַ֖יִם יְהוָ֑ה וְעֶלְי֖וֹן יִתֵּ֥ן קוֹלֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.15",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "2 Samuel 22:15",
      "text": "וַיִּשְׁלַ֥ח חִצִּ֖ים וַיְפִיצֵ֑ם בָּרָ֖ק ויהמם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.16",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "2 Samuel 22:16",
      "text": "וַיֵּֽרָאוּ֙ אֲפִ֣קֵי יָ֔ם יִגָּל֖וּ מֹסְד֣וֹת תֵּבֵ֑ל בְּגַעֲרַ֣ת יְהוָ֔ה מִנִּשְׁמַ֖ת ר֥וּחַ אַפּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.17",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "2 Samuel 22:17",
      "text": "יִשְׁלַ֥ח מִמָּר֖וֹם יִקָּחֵ֑נִי יַֽמְשֵׁ֖נִי מִמַּ֥יִם רַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.18",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "2 Samuel 22:18",
      "text": "יַצִּילֵ֕נִי מֵאֹיְבִ֖י עָ֑ז מִשֹּׂ֣נְאַ֔י כִּ֥י אָמְצ֖וּ מִמֶּֽנִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.19",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "2 Samuel 22:19",
      "text": "יְקַדְּמֻ֖נִי בְּי֣וֹם אֵידִ֑י וַיְהִ֧י יְהוָ֛ה מִשְׁעָ֖ן לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.20",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "2 Samuel 22:20",
      "text": "וַיֹּצֵ֥א לַמֶּרְחָ֖ב אֹתִ֑י יְחַלְּצֵ֖נִי כִּי ־ חָ֥פֵֽץ בִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.21",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "2 Samuel 22:21",
      "text": "יִגְמְלֵ֥נִי יְהוָ֖ה כְּצִדְקָתִ֑י כְּבֹ֥ר יָדַ֖י יָשִׁ֥יב לִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.22",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "2 Samuel 22:22",
      "text": "כִּ֥י שָׁמַ֖רְתִּי דַּרְכֵ֣י יְהוָ֑ה וְלֹ֥א רָשַׁ֖עְתִּי מֵאֱלֹהָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.23",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "2 Samuel 22:23",
      "text": "כִּ֥י כָל ־ משפטו לְנֶגְדִּ֑י וְחֻקֹּתָ֖יו לֹא ־ אָס֥וּר מִמֶּֽנָּה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.24",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "2 Samuel 22:24",
      "text": "וָאֶהְיֶ֥ה תָמִ֖ים ל֑וֹ וָאֶשְׁתַּמְּרָ֖ה מֵעֲוֺנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.25",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "2 Samuel 22:25",
      "text": "וַיָּ֧שֶׁב יְהוָ֛ה לִ֖י כְּצִדְקָתִ֑י כְּבֹרִ֖י לְנֶ֥גֶד עֵינָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.26",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "2 Samuel 22:26",
      "text": "עִם ־ חָסִ֖יד תִּתְחַסָּ֑ד עִם ־ גִּבּ֥וֹר תָּמִ֖ים תִּתַּמָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.27",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "2 Samuel 22:27",
      "text": "עִם ־ נָבָ֖ר תִּתָּבָ֑ר וְעִם ־ עִקֵּ֖שׁ תִּתַּפָּֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.28",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "2 Samuel 22:28",
      "text": "וְאֶת ־ עַ֥ם עָנִ֖י תּוֹשִׁ֑יעַ וְעֵינֶ֖יךָ עַל ־ רָמִ֥ים תַּשְׁפִּֽיל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.29",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "2 Samuel 22:29",
      "text": "כִּֽי ־ אַתָּ֥ה נֵירִ֖י יְהוָ֑ה וַיהוָ֖ה יַגִּ֥יהַּ חָשְׁכִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.30",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "2 Samuel 22:30",
      "text": "כִּ֥י בְכָ֖ה אָר֣וּץ גְּד֑וּד בֵּאלֹהַ֖י אֲדַלֶּג ־ שֽׁוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.31",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "2 Samuel 22:31",
      "text": "הָאֵ֖ל תָּמִ֣ים דַּרְכּ֑וֹ אִמְרַ֤ת יְהוָה֙ צְרוּפָ֔ה מָגֵ֣ן ה֔וּא לְכֹ֖ל הַחֹסִ֥ים בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.32",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "2 Samuel 22:32",
      "text": "כִּ֥י מִי ־ אֵ֖ל מִבַּלְעֲדֵ֣י יְהוָ֑ה וּמִ֥י צ֖וּר מִֽבַּלְעֲדֵ֥י אֱלֹהֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.33",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "2 Samuel 22:33",
      "text": "הָאֵ֥ל מָעוּזִּ֖י חָ֑יִל וַיַּתֵּ֥ר תָּמִ֖ים דרכו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.34",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "2 Samuel 22:34",
      "text": "מְשַׁוֶּ֥ה רגליו כָּאַיָּל֑וֹת וְעַ֥ל בָּמוֹתַ֖י יַעֲמִדֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.35",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "2 Samuel 22:35",
      "text": "מְלַמֵּ֥ד יָדַ֖י לַמִּלְחָמָ֑ה וְנִחַ֥ת קֶֽשֶׁת ־ נְחוּשָׁ֖ה זְרֹעֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.36",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "2 Samuel 22:36",
      "text": "וַתִּתֶּן ־ לִ֖י מָגֵ֣ן יִשְׁעֶ֑ךָ וַעֲנֹתְךָ֖ תַּרְבֵּֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.37",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "2 Samuel 22:37",
      "text": "תַּרְחִ֥יב צַעֲדִ֖י תַּחְתֵּ֑נִי וְלֹ֥א מָעֲד֖וּ קַרְסֻלָּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.38",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "2 Samuel 22:38",
      "text": "אֶרְדְּפָ֥ה אֹיְבַ֖י וָאַשְׁמִידֵ֑ם וְלֹ֥א אָשׁ֖וּב עַד ־ כַּלּוֹתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.39",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "2 Samuel 22:39",
      "text": "וָאֲכַלֵּ֥ם וָאֶמְחָצֵ֖ם וְלֹ֣א יְקוּמ֑וּן וַֽיִּפְּל֖וּ תַּ֥חַת רַגְלָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:second-samuel.22.40",
      "translationId": "wlc",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "2 Samuel 22:40",
