{
  "chapter": {
    "id": "wlc:hosea.12",
    "translationId": "wlc",
    "bookSlug": "hosea",
    "chapterNumber": 12,
    "referenceLabel": "Hosea 12",
    "summary": "Source text for Hosea 12 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:hosea.12.1",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Hosea 12:1",
      "text": "סְבָבֻ֤נִי בְכַ֨חַשׁ֙ אֶפְרַ֔יִם וּבְמִרְמָ֖ה בֵּ֣ית יִשְׂרָאֵ֑ל וִֽיהוּדָ֗ה עֹ֥ד רָד֙ עִם ־ אֵ֔ל וְעִם ־ קְדוֹשִׁ֖ים נֶאֱמָֽן ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:hosea.12.2",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Hosea 12:2",
      "text": "אֶפְרַ֜יִם רֹעֶ֥ה ר֨וּחַ֙ וְרֹדֵ֣ף קָדִ֔ים כָּל ־ הַיּ֕וֹם כָּזָ֥ב וָשֹׁ֖ד יַרְבֶּ֑ה וּבְרִית֙ עִם ־ אַשּׁ֣וּר יִכְרֹ֔תוּ וְשֶׁ֖מֶן לְמִצְרַ֥יִם יוּבָֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.3",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Hosea 12:3",
      "text": "וְרִ֥יב לַֽיהוָ֖ה עִם ־ יְהוּדָ֑ה וְלִפְקֹ֤ד עַֽל ־ יַעֲקֹב֙ כִּדְרָכָ֔יו כְּמַעֲלָלָ֖יו יָשִׁ֥יב לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.4",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Hosea 12:4",
      "text": "בַּבֶּ֖טֶן עָקַ֣ב אֶת ־ אָחִ֑יו וּבְאוֹנ֖וֹ שָׂרָ֥ה אֶת ־ אֱלֹהִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.5",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Hosea 12:5",
      "text": "וָיָּ֤שַׂר אֶל ־ מַלְאָךְ֙ וַיֻּכָ֔ל בָּכָ֖ה וַיִּתְחַנֶּן ־ ל֑וֹ בֵּֽית ־ אֵל֙ יִמְצָאֶ֔נּוּ וְשָׁ֖ם יְדַבֵּ֥ר עִמָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.6",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Hosea 12:6",
      "text": "וַֽיהוָ֖ה אֱלֹהֵ֣י הַצְּבָא֑וֹת יְהוָ֖ה זִכְרֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.7",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Hosea 12:7",
      "text": "וְאַתָּ֖ה בֵּאלֹהֶ֣יךָ תָשׁ֑וּב חֶ֤סֶד וּמִשְׁפָּט֙ שְׁמֹ֔ר וְקַוֵּ֥ה אֶל ־ אֱלֹהֶ֖יךָ תָּמִֽיד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.8",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Hosea 12:8",
      "text": "כְּנַ֗עַן בְּיָד֛וֹ מֹאזְנֵ֥י מִרְמָ֖ה לַעֲשֹׁ֥ק אָהֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.9",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Hosea 12:9",
      "text": "וַיֹּ֣אמֶר אֶפְרַ֔יִם אַ֣ךְ עָשַׁ֔רְתִּי מָצָ֥אתִי א֖וֹן לִ֑י כָּל ־ יְגִיעַ֕י לֹ֥א יִמְצְאוּ ־ לִ֖י עָוֺ֥ן אֲשֶׁר ־ חֵֽטְא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.10",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Hosea 12:10",
      "text": "וְאָנֹכִ֛י יְהוָ֥ה אֱלֹהֶ֖יךָ מֵאֶ֣רֶץ מִצְרָ֑יִם עֹ֛ד אוֹשִֽׁיבְךָ֥ בָאֳהָלִ֖ים כִּימֵ֥י מוֹעֵֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.11",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Hosea 12:11",
      "text": "וְדִבַּ֨רְתִּי֙ עַל ־ הַנְּבִיאִ֔ים וְאָנֹכִ֖י חָז֣וֹן הִרְבֵּ֑יתִי וּבְיַ֥ד הַנְּבִיאִ֖ים אֲדַמֶּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.12",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Hosea 12:12",
      "text": "אִם ־ גִּלְעָ֥ד אָ֨וֶן֙ אַךְ ־ שָׁ֣וְא הָי֔וּ בַּגִּלְגָּ֖ל שְׁוָרִ֣ים זִבֵּ֑חוּ גַּ֤ם מִזְבְּחוֹתָם֙ כְּגַלִּ֔ים עַ֖ל תַּלְמֵ֥י שָׂדָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.13",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Hosea 12:13",
      "text": "וַיִּבְרַ֥ח יַעֲקֹ֖ב שְׂדֵ֣ה אֲרָ֑ם וַיַּעֲבֹ֤ד יִשְׂרָאֵל֙ בְּאִשָּׁ֔ה וּבְאִשָּׁ֖ה שָׁמָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.14",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Hosea 12:14",
      "text": "וּבְנָבִ֕יא הֶעֱלָ֧ה יְהוָ֛ה אֶת ־ יִשְׂרָאֵ֖ל מִמִּצְרָ֑יִם וּבְנָבִ֖יא נִשְׁמָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.12.15",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Hosea 12:15",
      "text": "הִכְעִ֥יס אֶפְרַ֖יִם תַּמְרוּרִ֑ים וְדָמָיו֙ עָלָ֣יו יִטּ֔וֹשׁ וְחֶ֨רְפָּת֔וֹ יָשִׁ֥יב ל֖וֹ אֲדֹנָֽיו ׃",
      "paragraphStart": false
    }
  ]
}
