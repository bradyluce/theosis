{
  "chapter": {
    "id": "wlc:hosea.8",
    "translationId": "wlc",
    "bookSlug": "hosea",
    "chapterNumber": 8,
    "referenceLabel": "Hosea 8",
    "summary": "Source text for Hosea 8 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:hosea.8.1",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Hosea 8:1",
      "text": "אֶל ־ חִכְּךָ֣ שֹׁפָ֔ר כַּנֶּ֖שֶׁר עַל ־ בֵּ֣ית יְהוָ֑ה יַ֚עַן עָבְר֣וּ בְרִיתִ֔י וְעַל ־ תּוֹרָתִ֖י פָּשָֽׁעוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:hosea.8.2",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Hosea 8:2",
      "text": "לִ֖י יִזְעָ֑קוּ אֱלֹהַ֥י יְֽדַעֲנ֖וּךָ יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.3",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Hosea 8:3",
      "text": "זָנַ֥ח יִשְׂרָאֵ֖ל ט֑וֹב אוֹיֵ֖ב יִרְדְּֽפוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.4",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Hosea 8:4",
      "text": "הֵ֤ם הִמְלִיכוּ֙ וְלֹ֣א מִמֶּ֔נִּי הֵשִׂ֖ירוּ וְלֹ֣א יָדָ֑עְתִּי כַּסְפָּ֣ם וּזְהָבָ֗ם עָשׂ֤וּ לָהֶם֙ עֲצַבִּ֔ים לְמַ֖עַן יִכָּרֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.5",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Hosea 8:5",
      "text": "זָנַח֙ עֶגְלֵ֣ךְ שֹֽׁמְר֔וֹן חָרָ֥ה אַפִּ֖י בָּ֑ם עַד ־ מָתַ֕י לֹ֥א יוּכְל֖וּ נִקָּיֹֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.6",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Hosea 8:6",
      "text": "כִּ֤י מִיִּשְׂרָאֵל֙ וְה֔וּא חָרָ֣שׁ עָשָׂ֔הוּ וְלֹ֥א אֱלֹהִ֖ים ה֑וּא כִּֽי ־ שְׁבָבִ֣ים יִֽהְיֶ֔ה עֵ֖גֶל שֹׁמְרֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.7",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Hosea 8:7",
      "text": "כִּ֛י ר֥וּחַ יִזְרָ֖עוּ וְסוּפָ֣תָה יִקְצֹ֑רוּ קָמָ֣ה אֵֽין ־ ל֗וֹ צֶ֚מַח בְּלִ֣י יַֽעֲשֶׂה ־ קֶּ֔מַח אוּלַ֣י יַֽעֲשֶׂ֔ה זָרִ֖ים יִבְלָעֻֽהוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.8",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Hosea 8:8",
      "text": "נִבְלַ֖ע יִשְׂרָאֵ֑ל עַתָּה֙ הָי֣וּ בַגּוֹיִ֔ם כִּכְלִ֖י אֵֽין ־ חֵ֥פֶץ בּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.9",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Hosea 8:9",
      "text": "כִּֽי ־ הֵ֨מָּה֙ עָל֣וּ אַשּׁ֔וּר פֶּ֖רֶא בּוֹדֵ֣ד ל֑וֹ אֶפְרַ֖יִם הִתְנ֥וּ אֲהָבִֽים",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.10",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Hosea 8:10",
      "text": "גַּ֛ם כִּֽי ־ יִתְנ֥וּ בַגּוֹיִ֖ם עַתָּ֣ה אֲקַבְּצֵ֑ם וַיָּחֵ֣לּוּ מְּעָ֔ט מִמַּשָּׂ֖א מֶ֥לֶךְ שָׂרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.11",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Hosea 8:11",
      "text": "כִּֽי ־ הִרְבָּ֥ה אֶפְרַ֛יִם מִזְבְּחֹ֖ת לַחֲטֹ֑א הָיוּ ־ ל֥וֹ מִזְבְּח֖וֹת לַחֲטֹֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.12",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Hosea 8:12",
      "text": "אכתוב ־ ל֔וֹ רבו תּֽוֹרָתִ֑י כְּמוֹ ־ זָ֖ר נֶחְשָֽׁבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.13",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Hosea 8:13",
      "text": "זִבְחֵ֣י הַבְהָבַ֗י יִזְבְּח֤וּ בָשָׂר֙ וַיֹּאכֵ֔לוּ יְהוָ֖ה לֹ֣א רָצָ֑ם עַתָּ֞ה יִזְכֹּ֤ר עֲוֺנָם֙ וְיִפְקֹ֣ד חַטֹּאותָ֔ם הֵ֖מָּה מִצְרַ֥יִם יָשֽׁוּבוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.8.14",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Hosea 8:14",
      "text": "וַיִּשְׁכַּ֨ח יִשְׂרָאֵ֜ל אֶת ־ עֹשֵׂ֗הוּ וַיִּ֨בֶן֙ הֵֽיכָל֔וֹת וִֽיהוּדָ֕ה הִרְבָּ֖ה עָרִ֣ים בְּצֻר֑וֹת וְשִׁלַּחְתִּי ־ אֵ֣שׁ בְּעָרָ֔יו וְאָכְלָ֖ה אַרְמְנֹתֶֽיהָ ׃ ס",
      "paragraphStart": false
    }
  ]
}
