{
  "chapter": {
    "id": "wlc:hosea.13",
    "translationId": "wlc",
    "bookSlug": "hosea",
    "chapterNumber": 13,
    "referenceLabel": "Hosea 13",
    "summary": "Source text for Hosea 13 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:hosea.13.1",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Hosea 13:1",
      "text": "כְּדַבֵּ֤ר אֶפְרַ֨יִם֙ רְתֵ֔ת נָשָׂ֥א ה֖וּא בְּיִשְׂרָאֵ֑ל וַיֶּאְשַׁ֥ם בַּבַּ֖עַל וַיָּמֹֽת ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:hosea.13.2",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Hosea 13:2",
      "text": "וְעַתָּ֣ה ׀ יוֹסִ֣פוּ לַחֲטֹ֗א וַיַּעְשׂ֣וּ לָהֶם֩ מַסֵּכָ֨ה מִכַּסְפָּ֤ם כִּתְבוּנָם֙ עֲצַבִּ֔ים מַעֲשֵׂ֥ה חָרָשִׁ֖ים כֻּלֹּ֑ה לָהֶם֙ הֵ֣ם אֹמְרִ֔ים זֹבְחֵ֣י אָדָ֔ם עֲגָלִ֖ים יִשָּׁקֽוּן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.3",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Hosea 13:3",
      "text": "לָכֵ֗ן יִֽהְיוּ֙ כַּעֲנַן ־ בֹּ֔קֶר וְכַטַּ֖ל מַשְׁכִּ֣ים הֹלֵ֑ךְ כְּמֹץ֙ יְסֹעֵ֣ר מִגֹּ֔רֶן וּכְעָשָׁ֖ן מֵאֲרֻבָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.4",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Hosea 13:4",
      "text": "וְאָנֹכִ֛י יְהוָ֥ה אֱלֹהֶ֖יךָ מֵאֶ֣רֶץ מִצְרָ֑יִם וֵאלֹהִ֤ים זֽוּלָתִי֙ לֹ֣א תֵדָ֔ע וּמוֹשִׁ֥יעַ אַ֖יִן בִּלְתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.5",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Hosea 13:5",
      "text": "אֲנִ֥י יְדַעְתִּ֖יךָ בַּמִּדְבָּ֑ר בְּאֶ֖רֶץ תַּלְאֻבֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.6",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Hosea 13:6",
      "text": "כְּמַרְעִיתָם֙ וַיִּשְׂבָּ֔עוּ שָׂבְע֖וּ וַיָּ֣רָם לִבָּ֑ם עַל ־ כֵּ֖ן שְׁכֵחֽוּנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.7",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Hosea 13:7",
      "text": "וָאֱהִ֥י לָהֶ֖ם כְּמוֹ ־ שָׁ֑חַל כְּנָמֵ֖ר עַל ־ דֶּ֥רֶךְ אָשֽׁוּר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.8",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Hosea 13:8",
      "text": "אֶפְגְּשֵׁם֙ כְּדֹ֣ב שַׁכּ֔וּל וְאֶקְרַ֖ע סְג֣וֹר לִבָּ֑ם וְאֹכְלֵ֥ם שָׁם֙ כְּלָבִ֔יא חַיַּ֥ת הַשָּׂדֶ֖ה תְּבַקְּעֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.9",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Hosea 13:9",
      "text": "שִֽׁחֶתְךָ֥ יִשְׂרָאֵ֖ל כִּֽי ־ בִ֥י בְעֶזְרֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.10",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Hosea 13:10",
      "text": "אֱהִ֤י מַלְכְּךָ֙ אֵפ֔וֹא וְיוֹשִֽׁיעֲךָ֖ בְּכָל ־ עָרֶ֑יךָ וְשֹׁ֣פְטֶ֔יךָ אֲשֶׁ֣ר אָמַ֔רְתָּ תְּנָה ־ לִּ֖י מֶ֥לֶךְ וְשָׂרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.11",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Hosea 13:11",
      "text": "אֶֽתֶּן ־ לְךָ֥ מֶ֨לֶךְ֙ בְּאַפִּ֔י וְאֶקַּ֖ח בְּעֶבְרָתִֽי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.12",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Hosea 13:12",
      "text": "צָרוּר֙ עֲוֺ֣ן אֶפְרָ֔יִם צְפוּנָ֖ה חַטָּאתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.13",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Hosea 13:13",
      "text": "חֶבְלֵ֥י יֽוֹלֵדָ֖ה יָבֹ֣אוּ ל֑וֹ הוּא ־ בֵן֙ לֹ֣א חָכָ֔ם כִּֽי ־ עֵ֥ת לֹֽא ־ יַעֲמֹ֖ד בְּמִשְׁבַּ֥ר בָּנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.14",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Hosea 13:14",
      "text": "מִיַּ֤ד שְׁאוֹל֙ אֶפְדֵּ֔ם מִמָּ֖וֶת אֶגְאָלֵ֑ם אֱהִ֨י דְבָרֶיךָ֜ מָ֗וֶת אֱהִ֤י קָֽטָבְךָ֙ שְׁא֔וֹל נֹ֖חַם יִסָּתֵ֥ר מֵעֵינָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.13.15",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Hosea 13:15",
      "text": "כִּ֣י ה֔וּא בֵּ֥ן אַחִ֖ים יַפְרִ֑יא יָב֣וֹא קָדִים֩ ר֨וּחַ יְהוָ֜ה מִמִּדְבָּ֣ר עֹלֶ֗ה וְיֵב֤וֹשׁ מְקוֹרוֹ֙ וְיֶחֱרַ֣ב מַעְיָנ֔וֹ ה֣וּא יִשְׁסֶ֔ה אוֹצַ֖ר כָּל ־ כְּלִ֥י חֶמְדָּֽה ׃",
      "paragraphStart": false
    }
  ]
}
