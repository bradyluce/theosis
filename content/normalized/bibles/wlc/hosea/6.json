{
  "chapter": {
    "id": "wlc:hosea.6",
    "translationId": "wlc",
    "bookSlug": "hosea",
    "chapterNumber": 6,
    "referenceLabel": "Hosea 6",
    "summary": "Source text for Hosea 6 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:hosea.6.1",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Hosea 6:1",
      "text": "לְכוּ֙ וְנָשׁ֣וּבָה אֶל ־ יְהוָ֔ה כִּ֛י ה֥וּא טָרָ֖ף וְיִרְפָּאֵ֑נוּ יַ֖ךְ וְיַחְבְּשֵֽׁנוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:hosea.6.2",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Hosea 6:2",
      "text": "יְחַיֵּ֖נוּ מִיֹּמָ֑יִם בַּיּוֹם֙ הַשְּׁלִישִׁ֔י יְקִמֵ֖נוּ וְנִחְיֶ֥ה לְפָנָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.3",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Hosea 6:3",
      "text": "וְנֵדְעָ֣ה נִרְדְּפָ֗ה לָדַ֨עַת֙ אֶת ־ יְהוָ֔ה כְּשַׁ֖חַר נָכ֣וֹן מֽוֹצָא֑וֹ וְיָב֤וֹא כַגֶּ֨שֶׁם֙ לָ֔נוּ כְּמַלְק֖וֹשׁ י֥וֹרֶה אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.4",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Hosea 6:4",
      "text": "מָ֤ה אֶֽעֱשֶׂה ־ לְּךָ֙ אֶפְרַ֔יִם מָ֥ה אֶעֱשֶׂה ־ לְּךָ֖ יְהוּדָ֑ה וְחַסְדְּכֶם֙ כַּֽעֲנַן ־ בֹּ֔קֶר וְכַטַּ֖ל מַשְׁכִּ֥ים הֹלֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.5",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Hosea 6:5",
      "text": "עַל ־ כֵּ֗ן חָצַ֨בְתִּי֙ בַּנְּבִיאִ֔ים הֲרַגְתִּ֖ים בְּאִמְרֵי ־ פִ֑י וּמִשְׁפָּטֶ֖יךָ א֥וֹר יֵצֵֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.6",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Hosea 6:6",
      "text": "כִּ֛י חֶ֥סֶד חָפַ֖צְתִּי וְלֹא ־ זָ֑בַח וְדַ֥עַת אֱלֹהִ֖ים מֵעֹלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.7",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Hosea 6:7",
      "text": "וְהֵ֕מָּה כְּאָדָ֖ם עָבְר֣וּ בְרִ֑ית שָׁ֖ם בָּ֥גְדוּ בִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.8",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Hosea 6:8",
      "text": "גִּלְעָ֕ד קִרְיַ֖ת פֹּ֣עֲלֵי אָ֑וֶן עֲקֻבָּ֖ה מִדָּֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.9",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Hosea 6:9",
      "text": "וּכְחַכֵּ֨י אִ֜ישׁ גְּדוּדִ֗ים חֶ֚בֶר כֹּֽהֲנִ֔ים דֶּ֖רֶךְ יְרַצְּחוּ ־ שֶׁ֑כְמָה כִּ֥י זִמָּ֖ה עָשֽׂוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.10",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Hosea 6:10",
      "text": "בְּבֵית֙ יִשְׂרָאֵ֔ל רָאִ֖יתִי שעריריה שָׁ֚ם זְנ֣וּת לְאֶפְרַ֔יִם נִטְמָ֖א יִשְׂרָאֵֽל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:hosea.6.11",
      "translationId": "wlc",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Hosea 6:11",
      "text": "גַּם ־ יְהוּדָ֕ה שָׁ֥ת קָצִ֖יר לָ֑ךְ בְּשׁוּבִ֖י שְׁב֥וּת עַמִּֽי ׃ פ",
      "paragraphStart": false
    }
  ]
}
