{
  "chapter": {
    "id": "wlc:lamentations.3",
    "translationId": "wlc",
    "bookSlug": "lamentations",
    "chapterNumber": 3,
    "referenceLabel": "Lamentations 3",
    "summary": "Source text for Lamentations 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:lamentations.3.1",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 3:1",
      "text": "אֲנִ֤י הַגֶּ֨בֶר֙ רָאָ֣ה עֳנִ֔י בְּשֵׁ֖בֶט עֶבְרָתֽוֹ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:lamentations.3.2",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 3:2",
      "text": "אוֹתִ֥י נָהַ֛ג וַיֹּלַ֖ךְ חֹ֥שֶׁךְ וְלֹא ־ אֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.3",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 3:3",
      "text": "אַ֣ךְ בִּ֥י יָשֻׁ֛ב יַהֲפֹ֥ךְ יָד֖וֹ כָּל ־ הַיּֽוֹם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.4",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 3:4",
      "text": "בִּלָּ֤ה בְשָׂרִי֙ וְעוֹרִ֔י שִׁבַּ֖ר עַצְמוֹתָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.5",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 3:5",
      "text": "בָּנָ֥ה עָלַ֛י וַיַּקַּ֖ף רֹ֥אשׁ וּתְלָאָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.6",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 3:6",
      "text": "בְּמַחֲשַׁכִּ֥ים הוֹשִׁיבַ֖נִי כְּמֵתֵ֥י עוֹלָֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.7",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 3:7",
      "text": "גָּדַ֧ר בַּעֲדִ֛י וְלֹ֥א אֵצֵ֖א הִכְבִּ֥יד נְחָשְׁתִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.8",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 3:8",
      "text": "גַּ֣ם כִּ֤י אֶזְעַק֙ וַאֲשַׁוֵּ֔עַ שָׂתַ֖ם תְּפִלָּתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.9",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 3:9",
      "text": "גָּדַ֤ר דְּרָכַי֙ בְּגָזִ֔ית נְתִיבֹתַ֖י עִוָּֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.10",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 3:10",
      "text": "דֹּ֣ב אֹרֵ֥ב הוּא֙ לִ֔י אריה בְּמִסְתָּרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.11",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 3:11",
      "text": "דְּרָכַ֥י סוֹרֵ֛ר וַֽיְפַשְּׁחֵ֖נִי שָׂמַ֥נִי שֹׁמֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.12",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 3:12",
      "text": "דָּרַ֤ךְ קַשְׁתוֹ֙ וַיַּצִּיבֵ֔נִי כַּמַּטָּרָ֖א לַחֵֽץ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.13",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 3:13",
      "text": "הֵבִיא֙ בְּכִלְיוֹתָ֔י בְּנֵ֖י אַשְׁפָּתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.14",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 3:14",
      "text": "הָיִ֤יתִי שְּׂחֹק֙ לְכָל ־ עַמִּ֔י נְגִינָתָ֖ם כָּל ־ הַיּֽוֹם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.15",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 3:15",
      "text": "הִשְׂבִּיעַ֥נִי בַמְּרוֹרִ֖ים הִרְוַ֥נִי לַעֲנָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.16",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 3:16",
      "text": "וַיַּגְרֵ֤ס בֶּֽחָצָץ֙ שִׁנָּ֔י הִכְפִּישַׁ֖נִי בָּאֵֽפֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.17",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 3:17",
      "text": "וַתִּזְנַ֧ח מִשָּׁל֛וֹם נַפְשִׁ֖י נָשִׁ֥יתִי טוֹבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.18",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 3:18",
      "text": "וָאֹמַר֙ אָבַ֣ד נִצְחִ֔י וְתוֹחַלְתִּ֖י מֵיְהוָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.19",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 3:19",
      "text": "זְכָר ־ עָנְיִ֥י וּמְרוּדִ֖י לַעֲנָ֥ה וָרֹֽאשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.20",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 3:20",
      "text": "זָכ֣וֹר תִּזְכּ֔וֹר ותשיח עָלַ֖י נַפְשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.21",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 3:21",
      "text": "זֹ֛את אָשִׁ֥יב אֶל ־ לִבִּ֖י עַל ־ כֵּ֥ן אוֹחִֽיל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.22",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 3:22",
      "text": "חַֽסְדֵ֤י יְהוָה֙ כִּ֣י לֹא ־ תָ֔מְנוּ כִּ֥י לֹא ־ כָל֖וּ רַחֲמָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.23",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Lamentations 3:23",
      "text": "חֲדָשִׁים֙ לַבְּקָרִ֔ים רַבָּ֖ה אֱמוּנָתֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.24",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Lamentations 3:24",
      "text": "חֶלְקִ֤י יְהוָה֙ אָמְרָ֣ה נַפְשִׁ֔י עַל ־ כֵּ֖ן אוֹחִ֥יל לֽוֹ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.25",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Lamentations 3:25",
      "text": "ט֤וֹב יְהוָה֙ לְקוָֹ֔ו לְנֶ֖פֶשׁ תִּדְרְשֶֽׁנּוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.26",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Lamentations 3:26",
      "text": "ט֤וֹב וְיָחִיל֙ וְדוּמָ֔ם לִתְשׁוּעַ֖ת יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.27",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Lamentations 3:27",
      "text": "ט֣וֹב לַגֶּ֔בֶר כִּֽי ־ יִשָּׂ֥א עֹ֖ל בִּנְעוּרָֽיו ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.28",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Lamentations 3:28",
      "text": "יֵשֵׁ֤ב בָּדָד֙ וְיִדֹּ֔ם כִּ֥י נָטַ֖ל עָלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.29",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Lamentations 3:29",
      "text": "יִתֵּ֤ן בֶּֽעָפָר֙ פִּ֔יהוּ אוּלַ֖י יֵ֥שׁ תִּקְוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.30",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Lamentations 3:30",
      "text": "יִתֵּ֧ן לְמַכֵּ֛הוּ לֶ֖חִי יִשְׂבַּ֥ע בְּחֶרְפָּֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.31",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Lamentations 3:31",
      "text": "כִּ֣י לֹ֥א יִזְנַ֛ח לְעוֹלָ֖ם אֲדֹנָֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.32",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Lamentations 3:32",
      "text": "כִּ֣י אִם ־ הוֹגָ֔ה וְרִחַ֖ם כְּרֹ֥ב חסדו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.33",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Lamentations 3:33",
      "text": "כִּ֣י לֹ֤א עִנָּה֙ מִלִּבּ֔וֹ וַיַּגֶּ֖ה בְנֵי ־ אִֽישׁ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.34",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Lamentations 3:34",
      "text": "לְדַכֵּא֙ תַּ֣חַת רַגְלָ֔יו כֹּ֖ל אֲסִ֥ירֵי אָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.35",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Lamentations 3:35",
      "text": "לְהַטּוֹת֙ מִשְׁפַּט ־ גָּ֔בֶר נֶ֖גֶד פְּנֵ֥י עֶלְיֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.36",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Lamentations 3:36",
      "text": "לְעַוֵּ֤ת אָדָם֙ בְּרִיב֔וֹ אֲדֹנָ֖י לֹ֥א רָאָֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.37",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Lamentations 3:37",
      "text": "מִ֣י זֶ֤ה אָמַר֙ וַתֶּ֔הִי אֲדֹנָ֖י לֹ֥א צִוָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.38",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Lamentations 3:38",
      "text": "מִפִּ֤י עֶלְיוֹן֙ לֹ֣א תֵצֵ֔א הָרָע֖וֹת וְהַטּֽוֹב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.39",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Lamentations 3:39",
      "text": "מַה ־ יִּתְאוֹנֵן֙ אָדָ֣ם חָ֔י גֶּ֖בֶר עַל ־ חטאו ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.40",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Lamentations 3:40",
      "text": "נַחְפְּשָׂ֤ה דְרָכֵ֨ינוּ֙ וְֽנַחְקֹ֔רָה וְנָשׁ֖וּבָה עַד ־ יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.41",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Lamentations 3:41",
      "text": "נִשָּׂ֤א לְבָבֵ֨נוּ֙ אֶל ־ כַּפָּ֔יִם אֶל ־ אֵ֖ל בַּשָּׁמָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.42",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Lamentations 3:42",
      "text": "נַ֤חְנוּ פָשַׁ֨עְנוּ֙ וּמָרִ֔ינוּ אַתָּ֖ה לֹ֥א סָלָֽחְתָּ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.43",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Lamentations 3:43",
      "text": "סַכֹּ֤תָה בָאַף֙ וַֽתִּרְדְּפֵ֔נוּ הָרַ֖גְתָּ לֹ֥א חָמָֽלְתָּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.44",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Lamentations 3:44",
      "text": "סַכּ֤וֹתָה בֶֽעָנָן֙ לָ֔ךְ מֵעֲב֖וֹר תְּפִלָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.45",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Lamentations 3:45",
      "text": "סְחִ֧י וּמָא֛וֹס תְּשִׂימֵ֖נוּ בְּקֶ֥רֶב הָעַמִּֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.46",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Lamentations 3:46",
      "text": "פָּצ֥וּ עָלֵ֛ינוּ פִּיהֶ֖ם כָּל ־ אֹיְבֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.3.47",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Lamentations 3:47",
