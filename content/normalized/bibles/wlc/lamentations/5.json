{
  "chapter": {
    "id": "wlc:lamentations.5",
    "translationId": "wlc",
    "bookSlug": "lamentations",
    "chapterNumber": 5,
    "referenceLabel": "Lamentations 5",
    "summary": "Source text for Lamentations 5 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:lamentations.5.1",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 5:1",
      "text": "זְכֹ֤ר יְהוָה֙ מֶֽה ־ הָ֣יָה לָ֔נוּ הביט וּרְאֵ֥ה אֶת ־ חֶרְפָּתֵֽנוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:lamentations.5.2",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 5:2",
      "text": "נַחֲלָתֵ֨נוּ֙ נֶֽהֶפְכָ֣ה לְזָרִ֔ים בָּתֵּ֖ינוּ לְנָכְרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.3",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 5:3",
      "text": "יְתוֹמִ֤ים הָיִ֨ינוּ֙ אין אָ֔ב אִמֹּתֵ֖ינוּ כְּאַלְמָנֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.4",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 5:4",
      "text": "מֵימֵ֨ינוּ֙ בְּכֶ֣סֶף שָׁתִ֔ינוּ עֵצֵ֖ינוּ בִּמְחִ֥יר יָבֹֽאוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.5",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 5:5",
      "text": "עַ֤ל צַוָּארֵ֨נוּ֙ נִרְדָּ֔פְנוּ יָגַ֖עְנוּ לא הֽוּנַ֖ח לָֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.6",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 5:6",
      "text": "מִצְרַ֨יִם֙ נָתַ֣נּוּ יָ֔ד אַשּׁ֖וּר לִשְׂבֹּ֥עַֽ לָֽחֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.7",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 5:7",
      "text": "אֲבֹתֵ֤ינוּ חָֽטְאוּ֙ אינם אנחנו עֲוֺנֹתֵיהֶ֥ם סָבָֽלְנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.8",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 5:8",
      "text": "עֲבָדִים֙ מָ֣שְׁלוּ בָ֔נוּ פֹּרֵ֖ק אֵ֥ין מִיָּדָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.9",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 5:9",
      "text": "בְּנַפְשֵׁ֨נוּ֙ נָבִ֣יא לַחְמֵ֔נוּ מִפְּנֵ֖י חֶ֥רֶב הַמִּדְבָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.10",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 5:10",
      "text": "עוֹרֵ֨נוּ֙ כְּתַנּ֣וּר נִכְמָ֔רוּ מִפְּנֵ֖י זַלְעֲפ֥וֹת רָעָֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.11",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 5:11",
      "text": "נָשִׁים֙ בְּצִיּ֣וֹן עִנּ֔וּ בְּתֻלֹ֖ת בְּעָרֵ֥י יְהוּדָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.12",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 5:12",
      "text": "שָׂרִים֙ בְּיָדָ֣ם נִתְל֔וּ פְּנֵ֥י זְקֵנִ֖ים לֹ֥א נֶהְדָּֽרוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.13",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 5:13",
      "text": "בַּחוּרִים֙ טְח֣וֹן נָשָׂ֔אוּ וּנְעָרִ֖ים בָּעֵ֥ץ כָּשָֽׁלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.14",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 5:14",
      "text": "זְקֵנִים֙ מִשַּׁ֣עַר שָׁבָ֔תוּ בַּחוּרִ֖ים מִנְּגִינָתָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.15",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 5:15",
      "text": "שָׁבַת֙ מְשׂ֣וֹשׂ לִבֵּ֔נוּ נֶהְפַּ֥ךְ לְאֵ֖בֶל מְחֹלֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.16",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 5:16",
      "text": "נָֽפְלָה֙ עֲטֶ֣רֶת רֹאשֵׁ֔נוּ אֽוֹי ־ נָ֥א לָ֖נוּ כִּ֥י חָטָֽאנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.17",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 5:17",
      "text": "עַל ־ זֶ֗ה הָיָ֤ה דָוֶה֙ לִבֵּ֔נוּ עַל ־ אֵ֖לֶּה חָשְׁכ֥וּ עֵינֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.18",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 5:18",
      "text": "עַ֤ל הַר ־ צִיּוֹן֙ שֶׁשָּׁמֵ֔ם שׁוּעָלִ֖ים הִלְּכוּ ־ בֽוֹ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.19",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 5:19",
      "text": "אַתָּ֤ה יְהוָה֙ לְעוֹלָ֣ם תֵּשֵׁ֔ב כִּסְאֲךָ֖ לְדֹ֥ר וָדֽוֹר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.20",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 5:20",
      "text": "לָ֤מָּה לָנֶ֨צַח֙ תִּשְׁכָּחֵ֔נוּ תַּֽעַזְבֵ֖נוּ לְאֹ֥רֶךְ יָמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.21",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 5:21",
      "text": "הֲשִׁיבֵ֨נוּ יְהוָ֤ה ׀ אֵלֶ֨יךָ֙ ונשוב חַדֵּ֥שׁ יָמֵ֖ינוּ כְּקֶֽדֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:lamentations.5.22",
      "translationId": "wlc",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 5:22",
      "text": "כִּ֚י אִם ־ מָאֹ֣ס מְאַסְתָּ֔נוּ קָצַ֥פְתָּ עָלֵ֖ינוּ עַד ־ מְאֹֽד ׃",
      "paragraphStart": false
    }
  ]
}
