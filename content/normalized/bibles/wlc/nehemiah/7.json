  "verses": [
    {
      "id": "wlc:nehemiah.7.1",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 7:1",
      "text": "וַיְהִ֗י כַּאֲשֶׁ֤ר נִבְנְתָה֙ הַחוֹמָ֔ה וָאַעֲמִ֖יד הַדְּלָת֑וֹת וַיִּפָּֽקְד֛וּ הַשּׁוֹעֲרִ֥ים וְהַמְשֹׁרְרִ֖ים וְהַלְוִיִּֽם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:nehemiah.7.2",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 7:2",
      "text": "וָאֲצַוֶּ֞ה אֶת ־ חֲנָ֣נִי אָחִ֗י וְאֶת ־ חֲנַנְיָ֛ה שַׂ֥ר הַבִּירָ֖ה עַל ־ יְרוּשָׁלִָ֑ם כִּי ־ הוּא֙ כְּאִ֣ישׁ אֱמֶ֔ת וְיָרֵ֥א אֶת ־ הָאֱלֹהִ֖ים מֵרַבִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.7.3",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 7:3",
      "text": "ויאמר לָהֶ֗ם לֹ֣א יִפָּֽתְח֞וּ שַׁעֲרֵ֤י יְרוּשָׁלִַ֨ם֙ עַד ־ חֹ֣ם הַשֶּׁ֔מֶשׁ וְעַ֨ד הֵ֥ם עֹמְדִ֛ים יָגִ֥יפוּ הַדְּלָת֖וֹת וֶאֱחֹ֑זוּ וְהַעֲמֵ֗יד מִשְׁמְרוֹת֙ יֹשְׁבֵ֣י יְרוּשָׁלִַ֔ם אִ֚ישׁ בְּמִשְׁמָר֔וֹ וְאִ֖ישׁ נֶ֥גֶד בֵּיתֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.7.4",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 7:4",
      "text": "וְהָעִ֞יר רַחֲבַ֤ת יָדַ֨יִם֙ וּגְדוֹלָ֔ה וְהָעָ֥ם מְעַ֖ט בְּתוֹכָ֑הּ וְאֵ֥ין בָּתִּ֖ים בְּנוּיִֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.7.5",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 7:5",
      "text": "וַיִּתֵּ֤ן אֱלֹהַי֙ אֶל ־ לִבִּ֔י וָאֶקְבְּצָ֞ה אֶת ־ הַחֹרִ֧ים וְאֶת ־ הַסְּגָנִ֛ים וְאֶת ־ הָעָ֖ם לְהִתְיַחֵ֑שׂ וָֽאֶמְצָ֗א סֵ֤פֶר הַיַּ֨חַשׂ֙ הָעוֹלִ֣ים בָּרִאשׁוֹנָ֔ה וָאֶמְצָ֖א כָּת֥וּב בּֽוֹ ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.7.6",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 7:6",
      "text": "אֵ֣לֶּה ׀ בְּנֵ֣י הַמְּדִינָ֗ה הָעֹלִים֙ מִשְּׁבִ֣י הַגּוֹלָ֔ה אֲשֶׁ֣ר הֶגְלָ֔ה נְבוּכַדְנֶצַּ֖ר מֶ֣לֶךְ בָּבֶ֑ל וַיָּשׁ֧וּבוּ לִֽירוּשָׁלִַ֛ם וְלִיהוּדָ֖ה אִ֥ישׁ לְעִירֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.7.7",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 7:7",
      "text": "הַבָּאִ֣ים עִם ־ זְרֻבָּבֶ֗ל יֵשׁ֡וּעַ נְחֶמְיָ֡ה עֲ֠זַרְיָה רַֽעַמְיָ֨ה נַחֲמָ֜נִי מָרְדֳּכַ֥י בִּלְשָׁ֛ן מִסְפֶּ֥רֶת בִּגְוַ֖י נְח֣וּם בַּעֲנָ֑ה מִסְפַּ֕ר אַנְשֵׁ֖י עַ֥ם יִשְׂרָאֵֽל ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.7.8",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 7:8",
      "text": "בְּנֵ֣י פַרְעֹ֔שׁ אַלְפַּ֕יִם מֵאָ֖ה וְשִׁבְעִ֥ים וּשְׁנָֽיִם ׃ ס",
      "paragraphStart": false
    },
    {
