      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 10:28",
      "text": "מַלּ֥וּךְ חָרִ֖ם בַּעֲנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.29",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 10:29",
      "text": "וּשְׁאָ֣ר הָעָ֡ם הַכֹּהֲנִ֣ים הַ֠לְוִיִּם הַשּׁוֹעֲרִ֨ים הַמְשֹׁרְרִ֜ים הַנְּתִינִ֗ים וְֽכָל ־ הַנִּבְדָּ֞ל מֵעַמֵּ֤י הָאֲרָצוֹת֙ אֶל ־ תּוֹרַ֣ת הָאֱלֹהִ֔ים נְשֵׁיהֶ֖ם בְּנֵיהֶ֣ם וּבְנֹתֵיהֶ֑ם כֹּ֖ל יוֹדֵ֥עַ מֵבִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.30",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 10:30",
      "text": "מַחֲזִיקִ֣ים עַל ־ אֲחֵיהֶם֮ אַדִּירֵיהֶם֒ וּבָאִ֞ים בְּאָלָ֣ה וּבִשְׁבוּעָ֗ה לָלֶ֨כֶת֙ בְּתוֹרַ֣ת הָאֱלֹהִ֔ים אֲשֶׁ֣ר נִתְּנָ֔ה בְּיַ֖ד מֹשֶׁ֣ה עֶֽבֶד ־ הָֽאֱלֹהִ֑ים וְלִשְׁמ֣וֹר וְלַעֲשׂ֗וֹת אֶת ־ כָּל ־ מִצְוֺת֙ יְהוָ֣ה אֲדֹנֵ֔ינוּ וּמִשְׁפָּטָ֖יו וְחֻקָּֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.31",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 10:31",
      "text": "וַאֲשֶׁ֛ר לֹא ־ נִתֵּ֥ן בְּנֹתֵ֖ינוּ לְעַמֵּ֣י הָאָ֑רֶץ וְאֶת ־ בְּנֹ֣תֵיהֶ֔ם לֹ֥א נִקַּ֖ח לְבָנֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.32",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 10:32",
      "text": "וְעַמֵּ֣י הָאָ֡רֶץ הַֽמְבִיאִים֩ אֶת ־ הַמַּקָּח֨וֹת וְכָל ־ שֶׁ֜בֶר בְּי֤וֹם הַשַּׁבָּת֙ לִמְכּ֔וֹר לֹא ־ נִקַּ֥ח מֵהֶ֛ם בַּשַּׁבָּ֖ת וּבְי֣וֹם קֹ֑דֶשׁ וְנִטֹּ֛שׁ אֶת ־ הַשָּׁנָ֥ה הַשְּׁבִיעִ֖ית וּמַשָּׁ֥א כָל ־ יָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.33",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 10:33",
      "text": "וְהֶעֱמַ֤דְנוּ עָלֵ֨ינוּ֙ מִצְוֺ֔ת לָתֵ֥ת עָלֵ֛ינוּ שְׁלִשִׁ֥ית הַשֶּׁ֖קֶל בַּשָּׁנָ֑ה לַעֲבֹדַ֖ת בֵּ֥ית אֱלֹהֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.34",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 10:34",
      "text": "לְלֶ֣חֶם הַֽמַּעֲרֶ֡כֶת וּמִנְחַ֣ת הַתָּמִ֣יד וּלְעוֹלַ֣ת הַ֠תָּמִיד הַשַּׁבָּת֨וֹת הֶחֳדָשִׁ֜ים לַמּוֹעֲדִ֗ים וְלַקֳּדָשִׁים֙ וְלַ֣חַטָּא֔וֹת לְכַפֵּ֖ר עַל ־ יִשְׂרָאֵ֑ל וְכֹ֖ל מְלֶ֥אכֶת בֵּית ־ אֱלֹהֵֽינוּ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.35",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 10:35",
      "text": "וְהַגּוֹרָל֨וֹת הִפַּ֜לְנוּ עַל ־ קֻרְבַּ֣ן הָעֵצִ֗ים הַכֹּהֲנִ֣ים הַלְוִיִּם֮ וְהָעָם֒ לְ֠הָבִיא לְבֵ֨ית אֱלֹהֵ֧ינוּ לְבֵית ־ אֲבֹתֵ֛ינוּ לְעִתִּ֥ים מְזֻמָּנִ֖ים שָׁנָ֣ה בְשָׁנָ֑ה לְבַעֵ֗ר עַל ־ מִזְבַּח֙ יְהוָ֣ה אֱלֹהֵ֔ינוּ כַּכָּת֖וּב בַּתּוֹרָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.36",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 10:36",
      "text": "וּלְהָבִ֞יא אֶת ־ בִּכּוּרֵ֣י אַדְמָתֵ֗נוּ וּבִכּוּרֵ֛י כָּל ־ פְּרִ֥י כָל ־ עֵ֖ץ שָׁנָ֣ה בְשָׁנָ֑ה לְבֵ֖ית יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.37",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 10:37",
      "text": "וְאֶת ־ בְּכֹר֤וֹת בָּנֵ֨ינוּ֙ וּבְהֶמְתֵּ֔ינוּ כַּכָּת֖וּב בַּתּוֹרָ֑ה וְאֶת ־ בְּכוֹרֵ֨י בְקָרֵ֜ינוּ וְצֹאנֵ֗ינוּ לְהָבִיא֙ לְבֵ֣ית אֱלֹהֵ֔ינוּ לַכֹּ֣הֲנִ֔ים הַמְשָׁרְתִ֖ים בְּבֵ֥ית אֱלֹהֵֽינוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:nehemiah.10.38",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
