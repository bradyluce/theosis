  "verses": [
    {
      "id": "wlc:nehemiah.10.1",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 10:1",
      "text": "וּבְכָל ־ זֹ֕את אֲנַ֛חְנוּ כֹּרְתִ֥ים אֲמָנָ֖ה וְכֹתְבִ֑ים וְעַל֙ הֶֽחָת֔וּם שָׂרֵ֥ינוּ לְוִיֵּ֖נוּ כֹּהֲנֵֽינוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:nehemiah.10.2",
      "translationId": "wlc",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 10:2",
      "text": "וְעַ֖ל הַחֲתוּמִ֑ים נְחֶמְיָ֧ה הַתִּרְשָׁ֛תָא בֶּן ־ חֲכַלְיָ֖ה וְצִדְקִיָּֽה ׃",
      "paragraphStart": false
    },
    {
