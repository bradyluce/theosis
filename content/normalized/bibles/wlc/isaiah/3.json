{
  "chapter": {
    "id": "wlc:isaiah.3",
    "translationId": "wlc",
    "bookSlug": "isaiah",
    "chapterNumber": 3,
    "referenceLabel": "Isaiah 3",
    "summary": "Source text for Isaiah 3 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:isaiah.3.1",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Isaiah 3:1",
      "text": "כִּי֩ הִנֵּ֨ה הָאָד֜וֹן יְהוָ֣ה צְבָא֗וֹת מֵסִ֤יר מִירוּשָׁלִַ֨ם֙ וּמִ֣יהוּדָ֔ה מַשְׁעֵ֖ן וּמַשְׁעֵנָ֑ה כֹּ֚ל מִשְׁעַן ־ לֶ֔חֶם וְכֹ֖ל מִשְׁעַן ־ מָֽיִם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:isaiah.3.2",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Isaiah 3:2",
      "text": "גִּבּ֖וֹר וְאִ֣ישׁ מִלְחָמָ֑ה שׁוֹפֵ֥ט וְנָבִ֖יא וְקֹסֵ֥ם וְזָקֵֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.3",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Isaiah 3:3",
      "text": "שַׂר ־ חֲמִשִּׁ֖ים וּנְשׂ֣וּא פָנִ֑ים וְיוֹעֵ֛ץ וַחֲכַ֥ם חֲרָשִׁ֖ים וּנְב֥וֹן לָֽחַשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.4",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Isaiah 3:4",
      "text": "וְנָתַתִּ֥י נְעָרִ֖ים שָׂרֵיהֶ֑ם וְתַעֲלוּלִ֖ים יִמְשְׁלוּ ־ בָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.5",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Isaiah 3:5",
      "text": "וְנִגַּ֣שׂ הָעָ֔ם אִ֥ישׁ בְּאִ֖ישׁ וְאִ֣ישׁ בְּרֵעֵ֑הוּ יִרְהֲב֗וּ הַנַּ֨עַר֙ בַּזָּקֵ֔ן וְהַנִּקְלֶ֖ה בַּנִּכְבָּֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.6",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Isaiah 3:6",
      "text": "כִּֽי ־ יִתְפֹּ֨שׂ אִ֤ישׁ בְּאָחִיו֙ בֵּ֣ית אָבִ֔יו שִׂמְלָ֣ה לְכָ֔ה קָצִ֖ין תִּֽהְיֶה ־ לָּ֑נוּ וְהַמַּכְשֵׁלָ֥ה הַזֹּ֖את תַּ֥חַת יָדֶֽךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.7",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Isaiah 3:7",
      "text": "יִשָּׂא֩ בַיּ֨וֹם הַה֤וּא ׀ לֵאמֹר֙ לֹא ־ אֶהְיֶ֣ה חֹבֵ֔שׁ וּבְבֵיתִ֕י אֵ֥ין לֶ֖חֶם וְאֵ֣ין שִׂמְלָ֑ה לֹ֥א תְשִׂימֻ֖נִי קְצִ֥ין עָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.8",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Isaiah 3:8",
      "text": "כִּ֤י כָשְׁלָה֙ יְר֣וּשָׁלִַ֔ם וִיהוּדָ֖ה נָפָ֑ל כִּֽי ־ לְשׁוֹנָ֤ם וּמַֽעַלְלֵיהֶם֙ אֶל ־ יְהוָ֔ה לַמְר֖וֹת עֵנֵ֥י כְבוֹדֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.9",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Isaiah 3:9",
      "text": "הַכָּרַ֤ת פְּנֵיהֶם֙ עָ֣נְתָה בָּ֔ם וְחַטָּאתָ֛ם כִּסְדֹ֥ם הִגִּ֖ידוּ לֹ֣א כִחֵ֑דוּ א֣וֹי לְנַפְשָׁ֔ם כִּֽי ־ גָמְל֥וּ לָהֶ֖ם רָעָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.10",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Isaiah 3:10",
      "text": "אִמְר֥וּ צַדִּ֖יק כִּי ־ ט֑וֹב כִּֽי ־ פְרִ֥י מַעַלְלֵיהֶ֖ם יֹאכֵֽלוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.11",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Isaiah 3:11",
      "text": "א֖וֹי לְרָשָׁ֣ע רָ֑ע כִּֽי ־ גְמ֥וּל יָדָ֖יו יֵעָ֥שֶׂה לּֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.12",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Isaiah 3:12",
      "text": "עַמִּי֙ נֹגְשָׂ֣יו מְעוֹלֵ֔ל וְנָשִׁ֖ים מָ֣שְׁלוּ ב֑וֹ עַמִּי֙ מְאַשְּׁרֶ֣יךָ מַתְעִ֔ים וְדֶ֥רֶךְ אֹֽרְחֹתֶ֖יךָ בִּלֵּֽעוּ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.13",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Isaiah 3:13",
      "text": "נִצָּ֥ב לָרִ֖יב יְהוָ֑ה וְעֹמֵ֖ד לָדִ֥ין עַמִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.14",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Isaiah 3:14",
      "text": "יְהוָה֙ בְּמִשְׁפָּ֣ט יָב֔וֹא עִם ־ זִקְנֵ֥י עַמּ֖וֹ וְשָׂרָ֑יו וְאַתֶּם֙ בִּֽעַרְתֶּ֣ם הַכֶּ֔רֶם גְּזֵלַ֥ת הֶֽעָנִ֖י בְּבָתֵּיכֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.15",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Isaiah 3:15",
      "text": "מלכם תְּדַכְּא֣וּ עַמִּ֔י וּפְנֵ֥י עֲנִיִּ֖ים תִּטְחָ֑נוּ נְאֻם ־ אֲדֹנָ֥י יְהוִ֖ה צְבָאֽוֹת ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.16",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Isaiah 3:16",
      "text": "וַיֹּ֣אמֶר יְהוָ֗ה יַ֚עַן כִּ֤י גָֽבְהוּ֙ בְּנ֣וֹת צִיּ֔וֹן וַתֵּלַ֨כְנָה֙ נטוות גָּר֔וֹן וּֽמְשַׂקְּר֖וֹת עֵינָ֑יִם הָל֤וֹךְ וְטָפֹף֙ תֵּלַ֔כְנָה וּבְרַגְלֵיהֶ֖ם תְּעַכַּֽסְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.17",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Isaiah 3:17",
      "text": "וְשִׂפַּ֣ח אֲדֹנָ֔י קָדְקֹ֖ד בְּנ֣וֹת צִיּ֑וֹן וַיהוָ֖ה פָּתְהֵ֥ן יְעָרֶֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.18",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Isaiah 3:18",
      "text": "בַּיּ֨וֹם הַה֜וּא יָסִ֣יר אֲדֹנָ֗י אֵ֣ת תִּפְאֶ֧רֶת הָעֲכָסִ֛ים וְהַשְּׁבִיסִ֖ים וְהַשַּׂהֲרֹנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.19",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Isaiah 3:19",
      "text": "הַנְּטִיפ֥וֹת וְהַשֵּׁיר֖וֹת וְהָֽרְעָלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.20",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Isaiah 3:20",
      "text": "הַפְּאֵרִ֤ים וְהַצְּעָדוֹת֙ וְהַקִּשֻּׁרִ֔ים וּבָתֵּ֥י הַנֶּ֖פֶשׁ וְהַלְּחָשִֽׁים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.21",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Isaiah 3:21",
      "text": "הַטַּבָּע֖וֹת וְנִזְמֵ֥י הָאָֽף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.22",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Isaiah 3:22",
      "text": "הַמַּֽחֲלָצוֹת֙ וְהַמַּ֣עֲטָפ֔וֹת וְהַמִּטְפָּח֖וֹת וְהָחֲרִיטִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.23",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Isaiah 3:23",
      "text": "וְהַגִּלְיֹנִים֙ וְהַסְּדִינִ֔ים וְהַצְּנִיפ֖וֹת וְהָרְדִידִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.24",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Isaiah 3:24",
      "text": "וְהָיָה֩ תַ֨חַת בֹּ֜שֶׂם מַ֣ק יִֽהְיֶ֗ה וְתַ֨חַת חֲגוֹרָ֤ה נִקְפָּה֙ וְתַ֨חַת מַעֲשֶׂ֤ה מִקְשֶׁה֙ קָרְחָ֔ה וְתַ֥חַת פְּתִיגִ֖יל מַחֲגֹ֣רֶת שָׂ֑ק כִּי ־ תַ֖חַת יֹֽפִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.25",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Isaiah 3:25",
      "text": "מְתַ֖יִךְ בַּחֶ֣רֶב יִפֹּ֑לוּ וּגְבוּרָתֵ֖ךְ בַּמִּלְחָמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.3.26",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Isaiah 3:26",
      "text": "וְאָנ֥וּ וְאָבְל֖וּ פְּתָחֶ֑יהָ וְנִקָּ֖תָה לָאָ֥רֶץ תֵּשֵֽׁב ׃",
      "paragraphStart": false
    }
  ]
}
