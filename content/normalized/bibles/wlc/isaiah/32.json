{
  "chapter": {
    "id": "wlc:isaiah.32",
    "translationId": "wlc",
    "bookSlug": "isaiah",
    "chapterNumber": 32,
    "referenceLabel": "Isaiah 32",
    "summary": "Source text for Isaiah 32 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:isaiah.32.1",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Isaiah 32:1",
      "text": "הֵ֥ן לְצֶ֖דֶק יִמְלָךְ ־ מֶ֑לֶךְ וּלְשָׂרִ֖ים לְמִשְׁפָּ֥ט יָשֹֽׂרוּ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:isaiah.32.2",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Isaiah 32:2",
      "text": "וְהָיָה ־ אִ֥ישׁ כְּמַֽחֲבֵא ־ ר֖וּחַ וְסֵ֣תֶר זָ֑רֶם כְּפַלְגֵי ־ מַ֣יִם בְּצָי֔וֹן כְּצֵ֥ל סֶֽלַע ־ כָּבֵ֖ד בְּאֶ֥רֶץ עֲיֵפָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.3",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Isaiah 32:3",
      "text": "וְלֹ֥א תִשְׁעֶ֖ינָה עֵינֵ֣י רֹאִ֑ים וְאָזְנֵ֥י שֹׁמְעִ֖ים תִּקְשַֽׁבְנָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.4",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Isaiah 32:4",
      "text": "וּלְבַ֥ב נִמְהָרִ֖ים יָבִ֣ין לָדָ֑עַת וּלְשׁ֣וֹן עִלְּגִ֔ים תְּמַהֵ֖ר לְדַבֵּ֥ר צָחֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.5",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Isaiah 32:5",
      "text": "לֹֽא ־ יִקָּרֵ֥א ע֛וֹד לְנָבָ֖ל נָדִ֑יב וּלְכִילַ֕י לֹ֥א יֵֽאָמֵ֖ר שֽׁוֹעַ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.6",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Isaiah 32:6",
      "text": "כִּ֤י נָבָל֙ נְבָלָ֣ה יְדַבֵּ֔ר וְלִבּ֖וֹ יַעֲשֶׂה ־ אָ֑וֶן לַעֲשׂ֣וֹת חֹ֗נֶף וּלְדַבֵּ֤ר אֶל ־ יְהוָה֙ תּוֹעָ֔ה לְהָרִיק֙ נֶ֣פֶשׁ רָעֵ֔ב וּמַשְׁקֶ֥ה צָמֵ֖א יַחְסִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.7",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Isaiah 32:7",
      "text": "וְכֵלַ֖י כֵּלָ֣יו רָעִ֑ים ה֚וּא זִמּ֣וֹת יָעָ֔ץ לְחַבֵּ֤ל ענוים בְּאִמְרֵי ־ שֶׁ֔קֶר וּבְדַבֵּ֥ר אֶבְי֖וֹן מִשְׁפָּֽט ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.8",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Isaiah 32:8",
      "text": "וְנָדִ֖יב נְדִיב֣וֹת יָעָ֑ץ וְה֖וּא עַל ־ נְדִיב֥וֹת יָקֽוּם ׃ פ",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.9",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Isaiah 32:9",
      "text": "נָשִׁים֙ שַֽׁאֲנַנּ֔וֹת קֹ֖מְנָה שְׁמַ֣עְנָה קוֹלִ֑י בָּנוֹת֙ בֹּֽטח֔וֹת הַאְזֵ֖נָּה אִמְרָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.10",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Isaiah 32:10",
      "text": "יָמִים֙ עַל ־ שָׁנָ֔ה תִּרְגַּ֖זְנָה בֹּֽטְח֑וֹת כִּ֚י כָּלָ֣ה בָצִ֔יר אֹ֖סֶף בְּלִ֥י יָבֽוֹא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.11",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Isaiah 32:11",
      "text": "חִרְדוּ֙ שַֽׁאֲנַנּ֔וֹת רְגָ֖זָה בֹּֽטְח֑וֹת פְּשֹׁ֣טָֽה וְעֹ֔רָה וַחֲג֖וֹרָה עַל ־ חֲלָצָֽיִם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.12",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Isaiah 32:12",
      "text": "עַל ־ שָׁדַ֖יִם סֹֽפְדִ֑ים עַל ־ שְׂדֵי ־ חֶ֕מֶד עַל ־ גֶּ֖פֶן פֹּרִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.13",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Isaiah 32:13",
      "text": "עַ֚ל אַדְמַ֣ת עַמִּ֔י ק֥וֹץ שָׁמִ֖יר תַּֽעֲלֶ֑ה כִּ֚י עַל ־ כָּל ־ בָּתֵּ֣י מָשׂ֔וֹשׂ קִרְיָ֖ה עַלִּיזָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.14",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Isaiah 32:14",
      "text": "כִּֽי ־ אַרְמ֣וֹן נֻטָּ֔שׁ הֲמ֥וֹן עִ֖יר עֻזָּ֑ב עֹ֣פֶל וָבַ֜חַן הָיָ֨ה בְעַ֤ד מְעָרוֹת֙ עַד ־ עוֹלָ֔ם מְשׂ֥וֹשׂ פְּרָאִ֖ים מִרְעֵ֥ה עֲדָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.15",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Isaiah 32:15",
      "text": "עַד ־ יֵ֨עָרֶ֥ה עָלֵ֛ינוּ ר֖וּחַ מִמָּר֑וֹם וְהָיָ֤ה מִדְבָּר֙ לַכַּרְמֶ֔ל וכרמל לַיַּ֥עַר יֵחָשֵֽׁב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.16",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Isaiah 32:16",
      "text": "וְשָׁכַ֥ן בַּמִּדְבָּ֖ר מִשְׁפָּ֑ט וּצְדָקָ֖ה בַּכַּרְמֶ֥ל תֵּשֵֽׁב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.17",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Isaiah 32:17",
      "text": "וְהָיָ֛ה מַעֲשֵׂ֥ה הַצְּדָקָ֖ה שָׁל֑וֹם וַֽעֲבֹדַת֙ הַצְּדָקָ֔ה הַשְׁקֵ֥ט וָבֶ֖טַח עַד ־ עוֹלָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.18",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Isaiah 32:18",
      "text": "וְיָשַׁ֥ב עַמִּ֖י בִּנְוֵ֣ה שָׁל֑וֹם וּֽבְמִשְׁכְּנוֹת֙ מִבְטַחִ֔ים וּבִמְנוּחֹ֖ת שַׁאֲנַנּֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.19",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Isaiah 32:19",
      "text": "וּבָרַ֖ד בְּרֶ֣דֶת הַיָּ֑עַר וּבַשִּׁפְלָ֖ה תִּשְׁפַּ֥ל הָעִֽיר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:isaiah.32.20",
      "translationId": "wlc",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Isaiah 32:20",
      "text": "אַשְׁרֵיכֶ֕ם זֹרְעֵ֖י עַל ־ כָּל ־ מָ֑יִם מְשַׁלְּחֵ֥י רֶֽגֶל ־ הַשּׁ֖וֹר וְהַחֲמֽוֹר ׃ ס",
      "paragraphStart": false
    }
  ]
}
