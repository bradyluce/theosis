{
  "chapter": {
    "id": "wlc:song-of-solomon.5",
    "translationId": "wlc",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 5,
    "referenceLabel": "Song of Solomon 5",
    "summary": "Source text for Song of Solomon 5 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:song-of-solomon.5.1",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 5:1",
      "text": "בָּ֣אתִי לְגַנִּי֮ אֲחֹתִ֣י כַלָּה֒ אָרִ֤יתִי מוֹרִי֙ עִם ־ בְּשָׂמִ֔י אָכַ֤לְתִּי יַעְרִי֙ עִם ־ דִּבְשִׁ֔י שָׁתִ֥יתִי יֵינִ֖י עִם ־ חֲלָבִ֑י אִכְל֣וּ רֵעִ֔ים שְׁת֥וּ וְשִׁכְר֖וּ דּוֹדִֽים ׃ ס",
      "paragraphStart": true
    },
    {
      "id": "wlc:song-of-solomon.5.2",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 5:2",
      "text": "אֲנִ֥י יְשֵׁנָ֖ה וְלִבִּ֣י עֵ֑ר ק֣וֹל ׀ דּוֹדִ֣י דוֹפֵ֗ק פִּתְחִי ־ לִ֞י אֲחֹתִ֤י רַעְיָתִי֙ יוֹנָתִ֣י תַמָּתִ֔י שֶׁרֹּאשִׁי֙ נִמְלָא ־ טָ֔ל קְוֻּצּוֹתַ֖י רְסִ֥יסֵי לָֽיְלָה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.3",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 5:3",
      "text": "פָּשַׁ֨טְתִּי֙ אֶת ־ כֻּתָּנְתִּ֔י אֵיכָ֖כָה אֶלְבָּשֶׁ֑נָּה רָחַ֥צְתִּי אֶת ־ רַגְלַ֖י אֵיכָ֥כָה אֲטַנְּפֵֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.4",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 5:4",
      "text": "דּוֹדִ֗י שָׁלַ֤ח יָדוֹ֙ מִן ־ הַחֹ֔ר וּמֵעַ֖י הָמ֥וּ עָלָֽיו ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.5",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 5:5",
      "text": "קַ֥מְתִּֽי אֲנִ֖י לִפְתֹּ֣חַ לְדוֹדִ֑י וְיָדַ֣י נָֽטְפוּ ־ מ֗וֹר וְאֶצְבְּעֹתַי֙ מ֣וֹר עֹבֵ֔ר עַ֖ל כַּפּ֥וֹת הַמַּנְעֽוּל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.6",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 5:6",
      "text": "פָּתַ֤חְתִּֽי אֲנִי֙ לְדוֹדִ֔י וְדוֹדִ֖י חָמַ֣ק עָבָ֑ר נַפְשִׁי֙ יָֽצְאָ֣ה בְדַבְּר֔וֹ בִּקַּשְׁתִּ֨יהוּ֙ וְלֹ֣א מְצָאתִ֔יהוּ קְרָאתִ֖יו וְלֹ֥א עָנָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.7",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 5:7",
      "text": "מְצָאֻ֧נִי הַשֹּׁמְרִ֛ים הַסֹּבְבִ֥ים בָּעִ֖יר הִכּ֣וּנִי פְצָע֑וּנִי נָשְׂא֤וּ אֶת ־ רְדִידִי֙ מֵֽעָלַ֔י שֹׁמְרֵ֖י הַחֹמֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.8",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 5:8",
      "text": "הִשְׁבַּ֥עְתִּי אֶתְכֶ֖ם בְּנ֣וֹת יְרוּשָׁלִָ֑ם אִֽם ־ תִּמְצְאוּ֙ אֶת ־ דּוֹדִ֔י מַה ־ תַּגִּ֣ידוּ ל֔וֹ שֶׁחוֹלַ֥ת אַהֲבָ֖ה אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.9",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 5:9",
      "text": "מַה ־ דּוֹדֵ֣ךְ מִדּ֔וֹד הַיָּפָ֖ה בַּנָּשִׁ֑ים מַה ־ דּוֹדֵ֣ךְ מִדּ֔וֹד שֶׁכָּ֖כָה הִשְׁבַּעְתָּֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.10",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 5:10",
      "text": "דּוֹדִ֥י צַח֙ וְאָד֔וֹם דָּג֖וּל מֵרְבָבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.11",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 5:11",
      "text": "רֹאשׁ֖וֹ כֶּ֣תֶם פָּ֑ז קְוּצּוֹתָיו֙ תַּלְתַּלִּ֔ים שְׁחֹר֖וֹת כָּעוֹרֵֽב ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.12",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 5:12",
      "text": "עֵינָ֕יו כְּיוֹנִ֖ים עַל ־ אֲפִ֣יקֵי מָ֑יִם רֹֽחֲצוֹת֙ בֶּֽחָלָ֔ב יֹשְׁב֖וֹת עַל ־ מִלֵּֽאת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.13",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 5:13",
      "text": "לְחָיָו֙ כַּעֲרוּגַ֣ת הַבֹּ֔שֶׂם מִגְדְּל֖וֹת מֶרְקָחִ֑ים שִׂפְתוֹתָיו֙ שֽׁוֹשַׁנִּ֔ים נֹטְפ֖וֹת מ֥וֹר עֹבֵֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.14",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 5:14",
      "text": "יָדָיו֙ גְּלִילֵ֣י זָהָ֔ב מְמֻלָּאִ֖ים בַּתַּרְשִׁ֑ישׁ מֵעָיו֙ עֶ֣שֶׁת שֵׁ֔ן מְעֻלֶּ֖פֶת סַפִּירִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.15",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 5:15",
      "text": "שׁוֹקָיו֙ עַמּ֣וּדֵי שֵׁ֔שׁ מְיֻסָּדִ֖ים עַל ־ אַדְנֵי ־ פָ֑ז מַרְאֵ֨הוּ֙ כַּלְּבָנ֔וֹן בָּח֖וּר כָּאֲרָזִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.5.16",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 5:16",
      "text": "חִכּוֹ֙ מַֽמְתַקִּ֔ים וְכֻלּ֖וֹ מַחֲּמַדִּ֑ים זֶ֤ה דוֹדִי֙ וְזֶ֣ה רֵעִ֔י בְּנ֖וֹת יְרוּשָׁלִָֽם ׃",
      "paragraphStart": false
    }
  ]
}
