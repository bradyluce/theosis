{
  "chapter": {
    "id": "wlc:song-of-solomon.4",
    "translationId": "wlc",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 4,
    "referenceLabel": "Song of Solomon 4",
    "summary": "Source text for Song of Solomon 4 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:song-of-solomon.4.1",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 4:1",
      "text": "הִנָּ֨ךְ יָפָ֤ה רַעְיָתִי֙ הִנָּ֣ךְ יָפָ֔ה עֵינַ֣יִךְ יוֹנִ֔ים מִבַּ֖עַד לְצַמָּתֵ֑ךְ שַׂעְרֵךְ֙ כְּעֵ֣דֶר הָֽעִזִּ֔ים שֶׁגָּלְשׁ֖וּ מֵהַ֥ר גִּלְעָֽד ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:song-of-solomon.4.2",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 4:2",
      "text": "שִׁנַּ֨יִךְ֙ כְּעֵ֣דֶר הַקְּצוּב֔וֹת שֶׁעָל֖וּ מִן ־ הָרַחְצָ֑ה שֶׁכֻּלָּם֙ מַתְאִימ֔וֹת וְשַׁכֻּלָ֖ה אֵ֥ין בָּהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.3",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 4:3",
      "text": "כְּח֤וּט הַשָּׁנִי֙ שִׂפְתֹתַ֔יִךְ וּמִדְבָּרֵ֖יךְ נָאוֶ֑ה כְּפֶ֤לַח הָֽרִמּוֹן֙ רַקָּתֵ֔ךְ מִבַּ֖עַד לְצַמָּתֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.4",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 4:4",
      "text": "כְּמִגְדַּ֤ל דָּוִיד֙ צַוָּארֵ֔ךְ בָּנ֖וּי לְתַלְפִּיּ֑וֹת אֶ֤לֶף הַמָּגֵן֙ תָּל֣וּי עָלָ֔יו כֹּ֖ל שִׁלְטֵ֥י הַגִּבּוֹרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.5",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 4:5",
      "text": "שְׁנֵ֥י שָׁדַ֛יִךְ כִּשְׁנֵ֥י עֳפָרִ֖ים תְּאוֹמֵ֣י צְבִיָּ֑ה הָרוֹעִ֖ים בַּשּׁוֹשַׁנִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.6",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 4:6",
      "text": "עַ֤ד שֶׁיָּפ֨וּחַ֙ הַיּ֔וֹם וְנָ֖סוּ הַצְּלָלִ֑ים אֵ֤לֶךְ לִי֙ אֶל ־ הַ֣ר הַמּ֔וֹר וְאֶל ־ גִּבְעַ֖ת הַלְּבוֹנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.7",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 4:7",
      "text": "כֻּלָּ֤ךְ יָפָה֙ רַעְיָתִ֔י וּמ֖וּם אֵ֥ין בָּֽךְ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.8",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 4:8",
      "text": "אִתִּ֤י מִלְּבָנוֹן֙ כַּלָּ֔ה אִתִּ֖י מִלְּבָנ֣וֹן תָּב֑וֹאִי תָּשׁ֣וּרִי ׀ מֵרֹ֣אשׁ אֲמָנָ֗ה מֵרֹ֤אשׁ שְׂנִיר֙ וְחֶרְמ֔וֹן מִמְּעֹנ֣וֹת אֲרָי֔וֹת מֵֽהַרְרֵ֖י נְמֵרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.9",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 4:9",
      "text": "לִבַּבְתִּ֖נִי אֲחֹתִ֣י כַלָּ֑ה לִבַּבְתִּ֨ינִי֙ באחד מֵעֵינַ֔יִךְ בְּאַחַ֥ד עֲנָ֖ק מִצַּוְּרֹנָֽיִךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.10",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 4:10",
      "text": "מַה ־ יָּפ֥וּ דֹדַ֖יִךְ אֲחֹתִ֣י כַלָּ֑ה מַה ־ טֹּ֤בוּ דֹדַ֨יִךְ֙ מִיַּ֔יִן וְרֵ֥יחַ שְׁמָנַ֖יִךְ מִכָּל ־ בְּשָׂמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.11",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 4:11",
      "text": "נֹ֛פֶת תִּטֹּ֥פְנָה שִׂפְתוֹתַ֖יִךְ כַּלָּ֑ה דְּבַ֤שׁ וְחָלָב֙ תַּ֣חַת לְשׁוֹנֵ֔ךְ וְרֵ֥יחַ שַׂלְמֹתַ֖יִךְ כְּרֵ֥יחַ לְבָנֽוֹן ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.12",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 4:12",
      "text": "גַּ֥ן ׀ נָע֖וּל אֲחֹתִ֣י כַלָּ֑ה גַּ֥ל נָע֖וּל מַעְיָ֥ן חָתֽוּם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.13",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 4:13",
      "text": "שְׁלָחַ֨יִךְ֙ פַּרְדֵּ֣ס רִמּוֹנִ֔ים עִ֖ם פְּרִ֣י מְגָדִ֑ים כְּפָרִ֖ים עִם ־ נְרָדִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.14",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 4:14",
      "text": "נֵ֣רְדְּ ׀ וְכַרְכֹּ֗ם קָנֶה֙ וְקִנָּמ֔וֹן עִ֖ם כָּל ־ עֲצֵ֣י לְבוֹנָ֑ה מֹ֚ר וַאֲהָל֔וֹת עִ֖ם כָּל ־ רָאשֵׁ֥י בְשָׂמִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.15",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 4:15",
      "text": "מַעְיַ֣ן גַּנִּ֔ים בְּאֵ֖ר מַ֣יִם חַיִּ֑ים וְנֹזְלִ֖ים מִן ־ לְבָנֽוֹן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.4.16",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 4:16",
      "text": "ע֤וּרִי צָפוֹן֙ וּב֣וֹאִי תֵימָ֔ן הָפִ֥יחִי גַנִּ֖י יִזְּל֣וּ בְשָׂמָ֑יו יָבֹ֤א דוֹדִי֙ לְגַנּ֔וֹ וְיֹאכַ֖ל פְּרִ֥י מְגָדָֽיו ׃",
      "paragraphStart": false
    }
  ]
}
