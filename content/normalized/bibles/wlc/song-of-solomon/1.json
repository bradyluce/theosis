{
  "chapter": {
    "id": "wlc:song-of-solomon.1",
    "translationId": "wlc",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 1,
    "referenceLabel": "Song of Solomon 1",
    "summary": "Source text for Song of Solomon 1 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:song-of-solomon.1.1",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 1:1",
      "text": "שִׁ֥יר הַשִּׁירִ֖ים אֲשֶׁ֥ר לִשְׁלֹמֹֽה ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:song-of-solomon.1.2",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 1:2",
      "text": "יִשָּׁקֵ֨נִי֙ מִנְּשִׁיק֣וֹת פִּ֔יהוּ כִּֽי ־ טוֹבִ֥ים דֹּדֶ֖יךָ מִיָּֽיִן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.3",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 1:3",
      "text": "לְרֵ֨יחַ֙ שְׁמָנֶ֣יךָ טוֹבִ֔ים שֶׁ֖מֶן תּוּרַ֣ק שְׁמֶ֑ךָ עַל ־ כֵּ֖ן עֲלָמ֥וֹת אֲהֵבֽוּךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.4",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 1:4",
      "text": "מָשְׁכֵ֖נִי אַחֲרֶ֣יךָ נָּר֑וּצָה הֱבִיאַ֨נִי הַמֶּ֜לֶךְ חֲדָרָ֗יו נָגִ֤ילָה וְנִשְׂמְחָה֙ בָּ֔ךְ נַזְכִּ֤ירָה דֹדֶ֨יךָ֙ מִיַּ֔יִן מֵישָׁרִ֖ים אֲהֵבֽוּךָ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.5",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 1:5",
      "text": "שְׁחוֹרָ֤ה אֲנִי֙ וְֽנָאוָ֔ה בְּנ֖וֹת יְרוּשָׁלִָ֑ם כְּאָהֳלֵ֣י קֵדָ֔ר כִּירִיע֖וֹת שְׁלֹמֹֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.6",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 1:6",
      "text": "אַל ־ תִּרְא֨וּנִי֙ שֶׁאֲנִ֣י שְׁחַרְחֹ֔רֶת שֶׁשֱּׁזָפַ֖תְנִי הַשָּׁ֑מֶשׁ בְּנֵ֧י אִמִּ֣י נִֽחֲרוּ ־ בִ֗י שָׂמֻ֨נִי֙ נֹטֵרָ֣ה אֶת ־ הַכְּרָמִ֔ים כַּרְמִ֥י שֶׁלִּ֖י לֹ֥א נָטָֽרְתִּי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.7",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 1:7",
      "text": "הַגִּ֣ידָה לִּ֗י שֶׁ֤אָהֲבָה֙ נַפְשִׁ֔י אֵיכָ֣ה תִרְעֶ֔ה אֵיכָ֖ה תַּרְבִּ֣יץ בַּֽצָּהֳרָ֑יִם שַׁלָּמָ֤ה אֶֽהְיֶה֙ כְּעֹ֣טְיָ֔ה עַ֖ל עֶדְרֵ֥י חֲבֵרֶֽיךָ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.8",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 1:8",
      "text": "אִם ־ לֹ֤א תֵדְעִי֙ לָ֔ךְ הַיָּפָ֖ה בַּנָּשִׁ֑ים צְֽאִי ־ לָ֞ךְ בְּעִקְבֵ֣י הַצֹּ֗אן וּרְעִי֙ אֶת ־ גְּדִיֹּתַ֔יִךְ עַ֖ל מִשְׁכְּנ֥וֹת הָרֹעִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.9",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 1:9",
      "text": "לְסֻסָתִי֙ בְּרִכְבֵ֣י פַרְעֹ֔ה דִּמִּיתִ֖יךְ רַעְיָתִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.10",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 1:10",
      "text": "נָאו֤וּ לְחָיַ֨יִךְ֙ בַּתֹּרִ֔ים צַוָּארֵ֖ךְ בַּחֲרוּזִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.11",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 1:11",
      "text": "תּוֹרֵ֤י זָהָב֙ נַעֲשֶׂה ־ לָּ֔ךְ עִ֖ם נְקֻדּ֥וֹת הַכָּֽסֶף ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.12",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 1:12",
      "text": "עַד ־ שֶׁ֤הַמֶּ֨לֶךְ֙ בִּמְסִבּ֔וֹ נִרְדִּ֖י נָתַ֥ן רֵיחֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.13",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 1:13",
      "text": "צְר֨וֹר הַמֹּ֤ר ׀ דּוֹדִי֙ לִ֔י בֵּ֥ין שָׁדַ֖י יָלִֽין ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.14",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 1:14",
      "text": "אֶשְׁכֹּ֨ל הַכֹּ֤פֶר ׀ דּוֹדִי֙ לִ֔י בְּכַרְמֵ֖י עֵ֥ין גֶּֽדִי ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.15",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 1:15",
      "text": "הִנָּ֤ךְ יָפָה֙ רַעְיָתִ֔י הִנָּ֥ךְ יָפָ֖ה עֵינַ֥יִךְ יוֹנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.16",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 1:16",
      "text": "הִנְּךָ֨ יָפֶ֤ה דוֹדִי֙ אַ֣ף נָעִ֔ים אַף ־ עַרְשֵׂ֖נוּ רַעֲנָנָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.1.17",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 1:17",
      "text": "קֹר֤וֹת בָּתֵּ֨ינוּ֙ אֲרָזִ֔ים רחיטנו בְּרוֹתִֽים ׃",
      "paragraphStart": false
    }
  ]
}
