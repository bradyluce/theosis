{
  "chapter": {
    "id": "wlc:song-of-solomon.2",
    "translationId": "wlc",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:song-of-solomon.2.1",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "אֲנִי֙ חֲבַצֶּ֣לֶת הַשָּׁר֔וֹן שֽׁוֹשַׁנַּ֖ת הָעֲמָקִֽים ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:song-of-solomon.2.2",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "כְּשֽׁוֹשַׁנָּה֙ בֵּ֣ין הַחוֹחִ֔ים כֵּ֥ן רַעְיָתִ֖י בֵּ֥ין הַבָּנֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.3",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "כְּתַפּ֨וּחַ֙ בַּעֲצֵ֣י הַיַּ֔עַר כֵּ֥ן דּוֹדִ֖י בֵּ֣ין הַבָּנִ֑ים בְּצִלּוֹ֙ חִמַּ֣דְתִּי וְיָשַׁ֔בְתִּי וּפִרְי֖וֹ מָת֥וֹק לְחִכִּֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.4",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "הֱבִיאַ֨נִי֙ אֶל ־ בֵּ֣ית הַיָּ֔יִן וְדִגְל֥וֹ עָלַ֖י אַהֲבָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.5",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "סַמְּכ֨וּנִי֙ בָּֽאֲשִׁישׁ֔וֹת רַפְּד֖וּנִי בַּתַּפּוּחִ֑ים כִּי ־ חוֹלַ֥ת אַהֲבָ֖ה אָֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.6",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "שְׂמֹאלוֹ֙ תַּ֣חַת לְרֹאשִׁ֔י וִימִינ֖וֹ תְּחַבְּקֵֽנִי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.7",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "הִשְׁבַּ֨עְתִּי אֶתְכֶ֜ם בְּנ֤וֹת יְרוּשָׁלִַ֨ם֙ בִּצְבָא֔וֹת א֖וֹ בְּאַיְל֣וֹת הַשָּׂדֶ֑ה אִם ־ תָּעִ֧ירוּ ׀ וְֽאִם ־ תְּעֽוֹרְר֛וּ אֶת ־ הָאַהֲבָ֖ה עַ֥ד שֶׁתֶּחְפָּֽץ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.8",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "ק֣וֹל דּוֹדִ֔י הִנֵּה ־ זֶ֖ה בָּ֑א מְדַלֵּג֙ עַל ־ הֶ֣הָרִ֔ים מְקַפֵּ֖ץ עַל ־ הַגְּבָעֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.9",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "דּוֹמֶ֤ה דוֹדִי֙ לִצְבִ֔י א֖וֹ לְעֹ֣פֶר הָֽאַיָּלִ֑ים הִנֵּה ־ זֶ֤ה עוֹמֵד֙ אַחַ֣ר כָּתְלֵ֔נוּ מַשְׁגִּ֨יחַ֙ מִן ־ הַֽחֲלֹּנ֔וֹת מֵצִ֖יץ מִן ־ הַֽחֲרַכִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.10",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "עָנָ֥ה דוֹדִ֖י וְאָ֣מַר לִ֑י ק֥וּמִי לָ֛ךְ רַעְיָתִ֥י יָפָתִ֖י וּלְכִי ־ לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.11",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "כִּֽי ־ הִנֵּ֥ה הסתו עָבָ֑ר הַגֶּ֕שֶׁם חָלַ֖ף הָלַ֥ךְ לֽוֹ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.12",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "הַנִּצָּנִים֙ נִרְא֣וּ בָאָ֔רֶץ עֵ֥ת הַזָּמִ֖יר הִגִּ֑יעַ וְק֥וֹל הַתּ֖וֹר נִשְׁמַ֥ע בְּאַרְצֵֽנוּ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.13",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "הַתְּאֵנָה֙ חָֽנְטָ֣ה פַגֶּ֔יהָ וְהַגְּפָנִ֥ים ׀ סְמָדַ֖ר נָ֣תְנוּ רֵ֑יחַ ק֥וּמִי לכי רַעְיָתִ֥י יָפָתִ֖י וּלְכִי ־ לָֽךְ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.14",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "יוֹנָתִ֞י בְּחַגְוֵ֣י הַסֶּ֗לַע בְּסֵ֨תֶר֙ הַמַּדְרֵגָ֔ה הַרְאִ֨ינִי֙ אֶתּ ־ מַרְאַ֔יִךְ הַשְׁמִיעִ֖ינִי אֶת ־ קוֹלֵ֑ךְ כִּי ־ קוֹלֵ֥ךְ עָרֵ֖ב וּמַרְאֵ֥יךְ נָאוֶֽה ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.15",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "אֶֽחֱזוּ ־ לָ֨נוּ֙ שֽׁוּעָלִ֔ים שֽׁוּעָלִ֥ים קְטַנִּ֖ים מְחַבְּלִ֣ים כְּרָמִ֑ים וּכְרָמֵ֖ינוּ סְמָדַֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.16",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "דּוֹדִ֥י לִי֙ וַאֲנִ֣י ל֔וֹ הָרֹעֶ֖ה בַּשּׁוֹשַׁנִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.2.17",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "עַ֤ד שֶׁיָּפ֨וּחַ֙ הַיּ֔וֹם וְנָ֖סוּ הַצְּלָלִ֑ים סֹב֩ דְּמֵה ־ לְךָ֨ דוֹדִ֜י לִצְבִ֗י א֛וֹ לְעֹ֥פֶר הָאַיָּלִ֖ים עַל ־ הָ֥רֵי בָֽתֶר ׃ ס",
      "paragraphStart": false
    }
  ]
}
