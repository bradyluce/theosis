{
  "chapter": {
    "id": "wlc:song-of-solomon.7",
    "translationId": "wlc",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 7,
    "referenceLabel": "Song of Solomon 7",
    "summary": "Source text for Song of Solomon 7 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:song-of-solomon.7.1",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 7:1",
      "text": "שׁ֤וּבִי שׁ֨וּבִי֙ הַשּׁ֣וּלַמִּ֔ית שׁ֥וּבִי שׁ֖וּבִי וְנֶחֱזֶה ־ בָּ֑ךְ מַֽה ־ תֶּחֱזוּ֙ בַּשּׁ֣וּלַמִּ֔ית כִּמְחֹלַ֖ת הַֽמַּחֲנָֽיִם ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:song-of-solomon.7.2",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 7:2",
      "text": "מַה ־ יָּפ֧וּ פְעָמַ֛יִךְ בַּנְּעָלִ֖ים בַּת ־ נָדִ֑יב חַמּוּקֵ֣י יְרֵכַ֔יִךְ כְּמ֣וֹ חֲלָאִ֔ים מַעֲשֵׂ֖ה יְדֵ֥י אָמָּֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.3",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 7:3",
      "text": "שָׁרְרֵךְ֙ אַגַּ֣ן הַסַּ֔הַר אַל ־ יֶחְסַ֖ר הַמָּ֑זֶג בִּטְנֵךְ֙ עֲרֵמַ֣ת חִטִּ֔ים סוּגָ֖ה בַּשּׁוֹשַׁנִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.4",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 7:4",
      "text": "שְׁנֵ֥י שָׁדַ֛יִךְ כִּשְׁנֵ֥י עֳפָרִ֖ים תָּאֳמֵ֥י צְבִיָּֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.5",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 7:5",
      "text": "צַוָּארֵ֖ךְ כְּמִגְדַּ֣ל הַשֵּׁ֑ן עֵינַ֜יִךְ בְּרֵכ֣וֹת בְּחֶשְׁבּ֗וֹן עַל ־ שַׁ֨עַר֙ בַּת ־ רַבִּ֔ים אַפֵּךְ֙ כְּמִגְדַּ֣ל הַלְּבָנ֔וֹן צוֹפֶ֖ה פְּנֵ֥י דַמָּֽשֶׂק ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.6",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 7:6",
      "text": "רֹאשֵׁ֤ךְ עָלַ֨יִךְ֙ כַּכַּרְמֶ֔ל וְדַלַּ֥ת רֹאשֵׁ֖ךְ כָּאַרְגָּמָ֑ן מֶ֖לֶךְ אָס֥וּר בָּרְהָטִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.7",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 7:7",
      "text": "מַה ־ יָּפִית֙ וּמַה ־ נָּעַ֔מְתְּ אַהֲבָ֖ה בַּתַּֽעֲנוּגִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.8",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 7:8",
      "text": "זֹ֤את קֽוֹמָתֵךְ֙ דָּֽמְתָ֣ה לְתָמָ֔ר וְשָׁדַ֖יִךְ לְאַשְׁכֹּלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.9",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 7:9",
      "text": "אָמַ֨רְתִּי֙ אֶעֱלֶ֣ה בְתָמָ֔ר אֹֽחֲזָ֖ה בְּסַנְסִנָּ֑יו וְיִֽהְיוּ ־ נָ֤א שָׁדַ֨יִךְ֙ כְּאֶשְׁכְּל֣וֹת הַגֶּ֔פֶן וְרֵ֥יחַ אַפֵּ֖ךְ כַּתַּפּוּחִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.10",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 7:10",
      "text": "וְחִכֵּ֕ךְ כְּיֵ֥ין הַטּ֛וֹב הוֹלֵ֥ךְ לְדוֹדִ֖י לְמֵישָׁרִ֑ים דּוֹבֵ֖ב שִׂפְתֵ֥י יְשֵׁנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.11",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 7:11",
      "text": "אֲנִ֣י לְדוֹדִ֔י וְעָלַ֖י תְּשׁוּקָתֽוֹ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.12",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 7:12",
      "text": "לְכָ֤ה דוֹדִי֙ נֵצֵ֣א הַשָּׂדֶ֔ה נָלִ֖ינָה בַּכְּפָרִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.13",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 7:13",
      "text": "נַשְׁכִּ֨ימָה֙ לַכְּרָמִ֔ים נִרְאֶ֞ה אִם פָּֽרְחָ֤ה הַגֶּ֨פֶן֙ פִּתַּ֣ח הַסְּמָדַ֔ר הֵנֵ֖צוּ הָרִמּוֹנִ֑ים שָׁ֛ם אֶתֵּ֥ן אֶת ־ דֹּדַ֖י לָֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.7.14",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 7:14",
      "text": "הַֽדּוּדָאִ֣ים נָֽתְנוּ ־ רֵ֗יחַ וְעַל ־ פְּתָחֵ֨ינוּ֙ כָּל ־ מְגָדִ֔ים חֲדָשִׁ֖ים גַּם ־ יְשָׁנִ֑ים דּוֹדִ֖י צָפַ֥נְתִּי לָֽךְ ׃",
      "paragraphStart": false
    }
  ]
}
