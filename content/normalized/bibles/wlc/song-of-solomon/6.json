{
  "chapter": {
    "id": "wlc:song-of-solomon.6",
    "translationId": "wlc",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 6,
    "referenceLabel": "Song of Solomon 6",
    "summary": "Source text for Song of Solomon 6 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:song-of-solomon.6.1",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 6:1",
      "text": "אָ֚נָה הָלַ֣ךְ דּוֹדֵ֔ךְ הַיָּפָ֖ה בַּנָּשִׁ֑ים אָ֚נָה פָּנָ֣ה דוֹדֵ֔ךְ וּנְבַקְשֶׁ֖נּוּ עִמָּֽךְ ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:song-of-solomon.6.2",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 6:2",
      "text": "דּוֹדִי֙ יָרַ֣ד לְגַנּ֔וֹ לַעֲרוּג֖וֹת הַבֹּ֑שֶׂם לִרְעוֹת֙ בַּגַּנִּ֔ים וְלִלְקֹ֖ט שֽׁוֹשַׁנִּֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.3",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 6:3",
      "text": "אֲנִ֤י לְדוֹדִי֙ וְדוֹדִ֣י לִ֔י הָרֹעֶ֖ה בַּשׁוֹשַׁנִּֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.4",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 6:4",
      "text": "יָפָ֨ה אַ֤תְּ רַעְיָתִי֙ כְּתִרְצָ֔ה נָאוָ֖ה כִּירוּשָׁלִָ֑ם אֲיֻמָּ֖ה כַּנִּדְגָּלֽוֹת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.5",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 6:5",
      "text": "הָסֵ֤בִּי עֵינַ֨יִךְ֙ מִנֶּגְדִּ֔י שֶׁ֥הֵ֖ם הִרְהִיבֻ֑נִי שַׂעְרֵךְ֙ כְּעֵ֣דֶר הָֽעִזִּ֔ים שֶׁגָּלְשׁ֖וּ מִן ־ הַגִּלְעָֽד ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.6",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 6:6",
      "text": "שִׁנַּ֨יִךְ֙ כְּעֵ֣דֶר הָֽרְחֵלִ֔ים שֶׁעָל֖וּ מִן ־ הָרַחְצָ֑ה שֶׁכֻּלָּם֙ מַתְאִימ֔וֹת וְשַׁכֻּלָ֖ה אֵ֥ין בָּהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.7",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 6:7",
      "text": "כְּפֶ֤לַח הָרִמּוֹן֙ רַקָּתֵ֔ךְ מִבַּ֖עַד לְצַמָּתֵֽךְ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.8",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 6:8",
      "text": "שִׁשִּׁ֥ים הֵ֨מָּה֙ מְּלָכ֔וֹת וּשְׁמֹנִ֖ים פִּֽילַגְשִׁ֑ים וַעֲלָמ֖וֹת אֵ֥ין מִסְפָּֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.9",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 6:9",
      "text": "אַחַ֥ת הִיא֙ יוֹנָתִ֣י תַמָּתִ֔י אַחַ֥ת הִיא֙ לְאִמָּ֔הּ בָּרָ֥ה הִ֖יא לְיֽוֹלַדְתָּ֑הּ רָא֤וּהָ בָנוֹת֙ וַֽיְאַשְּׁר֔וּהָ מְלָכ֥וֹת וּפִֽילַגְשִׁ֖ים וַֽיְהַלְלֽוּהָ ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.10",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 6:10",
      "text": "מִי ־ זֹ֥את הַנִּשְׁקָפָ֖ה כְּמוֹ ־ שָׁ֑חַר יָפָ֣ה כַלְּבָנָ֗ה בָּרָה֙ כַּֽחַמָּ֔ה אֲיֻמָּ֖ה כַּנִּדְגָּלֽוֹת ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.11",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 6:11",
      "text": "אֶל ־ גִּנַּ֤ת אֱגוֹז֙ יָרַ֔דְתִּי לִרְא֖וֹת בְּאִבֵּ֣י הַנָּ֑חַל לִרְאוֹת֙ הֲפָֽרְחָ֣ה הַגֶּ֔פֶן הֵנֵ֖צוּ הָרִמֹּנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:song-of-solomon.6.12",
      "translationId": "wlc",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 6:12",
      "text": "לֹ֣א יָדַ֔עְתִּי נַפְשִׁ֣י שָׂמַ֔תְנִי מַרְכְּב֖וֹת עַמִּי ־ נָדִֽיב ׃",
      "paragraphStart": false
    }
  ]
}
