{
  "chapter": {
    "id": "wlc:genesis.10",
    "translationId": "wlc",
    "bookSlug": "genesis",
    "chapterNumber": 10,
    "referenceLabel": "Genesis 10",
    "summary": "Source text for Genesis 10 in Westminster Leningrad Codex."
  },
  "verses": [
    {
      "id": "wlc:genesis.10.1",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Genesis 10:1",
      "text": "וְאֵ֨לֶּה֙ תּוֹלְדֹ֣ת בְּנֵי ־ נֹ֔חַ שֵׁ֖ם חָ֣ם וָיָ֑פֶת וַיִּוָּלְד֥וּ לָהֶ֛ם בָּנִ֖ים אַחַ֥ר הַמַּבּֽוּל ׃",
      "paragraphStart": true
    },
    {
      "id": "wlc:genesis.10.2",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Genesis 10:2",
      "text": "בְּנֵ֣י יֶ֔פֶת גֹּ֣מֶר וּמָג֔וֹג וּמָדַ֖י וְיָוָ֣ן וְתֻבָ֑ל וּמֶ֖שֶׁךְ וְתִירָֽס ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.3",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Genesis 10:3",
      "text": "וּבְנֵ֖י גֹּ֑מֶר אַשְׁכֲּנַ֥ז וְרִיפַ֖ת וְתֹגַרְמָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.4",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Genesis 10:4",
      "text": "וּבְנֵ֥י יָוָ֖ן אֱלִישָׁ֣ה וְתַרְשִׁ֑ישׁ כִּתִּ֖ים וְדֹדָנִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.5",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Genesis 10:5",
      "text": "מֵ֠אֵלֶּה נִפְרְד֞וּ אִיֵּ֤י הַגּוֹיִם֙ בְּאַרְצֹתָ֔ם אִ֖ישׁ לִלְשֹׁנ֑וֹ לְמִשְׁפְּחֹתָ֖ם בְּגוֹיֵהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.6",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Genesis 10:6",
      "text": "וּבְנֵ֖י חָ֑ם כּ֥וּשׁ וּמִצְרַ֖יִם וּפ֥וּט וּכְנָֽעַן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.7",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Genesis 10:7",
      "text": "וּבְנֵ֣י כ֔וּשׁ סְבָא֙ וַֽחֲוִילָ֔ה וְסַבְתָּ֥ה וְרַעְמָ֖ה וְסַבְתְּכָ֑א וּבְנֵ֥י רַעְמָ֖ה שְׁבָ֥א וּדְדָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.8",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Genesis 10:8",
      "text": "וְכ֖וּשׁ יָלַ֣ד אֶת ־ נִמְרֹ֑ד ה֣וּא הֵחֵ֔ל לִֽהְי֥וֹת גִּבֹּ֖ר בָּאָֽרֶץ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.9",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Genesis 10:9",
      "text": "הֽוּא ־ הָיָ֥ה גִבֹּֽר ־ צַ֖יִד לִפְנֵ֣י יְהוָ֑ה עַל ־ כֵּן֙ יֵֽאָמַ֔ר כְּנִמְרֹ֛ד גִּבּ֥וֹר צַ֖יִד לִפְנֵ֥י יְהוָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.10",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Genesis 10:10",
      "text": "וַתְּהִ֨י רֵאשִׁ֤ית מַמְלַכְתּוֹ֙ בָּבֶ֔ל וְאֶ֖רֶךְ וְאַכַּ֣ד וְכַלְנֵ֑ה בְּאֶ֖רֶץ שִׁנְעָֽר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.11",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Genesis 10:11",
      "text": "מִן ־ הָאָ֥רֶץ הַהִ֖וא יָצָ֣א אַשּׁ֑וּר וַיִּ֨בֶן֙ אֶת ־ נִ֣ינְוֵ֔ה וְאֶת ־ רְחֹבֹ֥ת עִ֖יר וְאֶת ־ כָּֽלַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.12",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Genesis 10:12",
      "text": "וְֽאֶת ־ רֶ֔סֶן בֵּ֥ין נִֽינְוֵ֖ה וּבֵ֣ין כָּ֑לַח הִ֖וא הָעִ֥יר הַגְּדֹלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.13",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Genesis 10:13",
      "text": "וּמִצְרַ֡יִם יָלַ֞ד אֶת ־ לוּדִ֧ים וְאֶת ־ עֲנָמִ֛ים וְאֶת ־ לְהָבִ֖ים וְאֶת ־ נַפְתֻּחִֽים ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.14",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Genesis 10:14",
      "text": "וְֽאֶת ־ פַּתְרֻסִ֞ים וְאֶת ־ כַּסְלֻחִ֗ים אֲשֶׁ֨ר יָצְא֥וּ מִשָּׁ֛ם פְּלִשְׁתִּ֖ים וְאֶת ־ כַּפְתֹּרִֽים ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.15",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Genesis 10:15",
      "text": "וּכְנַ֗עַן יָלַ֛ד אֶת ־ צִידֹ֥ן בְּכֹר֖וֹ וְאֶת ־ חֵֽת ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.16",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Genesis 10:16",
      "text": "וְאֶת ־ הַיְבוּסִי֙ וְאֶת ־ הָ֣אֱמֹרִ֔י וְאֵ֖ת הַגִּרְגָּשִֽׁי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.17",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Genesis 10:17",
      "text": "וְאֶת ־ הַֽחִוִּ֥י וְאֶת ־ הַֽעַרְקִ֖י וְאֶת ־ הַסִּינִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.18",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Genesis 10:18",
      "text": "וְאֶת ־ הָֽאַרְוָדִ֥י וְאֶת ־ הַצְּמָרִ֖י וְאֶת ־ הַֽחֲמָתִ֑י וְאַחַ֣ר נָפֹ֔צוּ מִשְׁפְּח֖וֹת הַֽכְּנַעֲנִֽי ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.19",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Genesis 10:19",
      "text": "וַֽיְהִ֞י גְּב֤וּל הַֽכְּנַעֲנִי֙ מִצִּידֹ֔ן בֹּאֲכָ֥ה גְרָ֖רָה עַד ־ עַזָּ֑ה בֹּאֲכָ֞ה סְדֹ֧מָה וַעֲמֹרָ֛ה וְאַדְמָ֥ה וּצְבֹיִ֖ם עַד ־ לָֽשַׁע ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.20",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Genesis 10:20",
      "text": "אֵ֣לֶּה בְנֵי ־ חָ֔ם לְמִשְׁפְּחֹתָ֖ם לִלְשֹֽׁנֹתָ֑ם בְּאַרְצֹתָ֖ם בְּגוֹיֵהֶֽם ׃ ס",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.21",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Genesis 10:21",
      "text": "וּלְשֵׁ֥ם יֻלַּ֖ד גַּם ־ ה֑וּא אֲבִי֙ כָּל ־ בְּנֵי ־ עֵ֔בֶר אֲחִ֖י יֶ֥פֶת הַגָּדֽוֹל ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.22",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Genesis 10:22",
      "text": "בְּנֵ֥י שֵׁ֖ם עֵילָ֣ם וְאַשּׁ֑וּר וְאַרְפַּכְשַׁ֖ד וְל֥וּד וַֽאֲרָֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.23",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Genesis 10:23",
      "text": "וּבְנֵ֖י אֲרָ֑ם ע֥וּץ וְח֖וּל וְגֶ֥תֶר וָמַֽשׁ ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.24",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Genesis 10:24",
      "text": "וְאַרְפַּכְשַׁ֖ד יָלַ֣ד אֶת ־ שָׁ֑לַח וְשֶׁ֖לַח יָלַ֥ד אֶת ־ עֵֽבֶר ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.25",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Genesis 10:25",
      "text": "וּלְעֵ֥בֶר יֻלַּ֖ד שְׁנֵ֣י בָנִ֑ים שֵׁ֣ם הָֽאֶחָ֞ד פֶּ֗לֶג כִּ֤י בְיָמָיו֙ נִפְלְגָ֣ה הָאָ֔רֶץ וְשֵׁ֥ם אָחִ֖יו יָקְטָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.26",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Genesis 10:26",
      "text": "וְיָקְטָ֣ן יָלַ֔ד אֶת ־ אַלְמוֹדָ֖ד וְאֶת ־ שָׁ֑לֶף וְאֶת ־ חֲצַרְמָ֖וֶת וְאֶת ־ יָֽרַח ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.27",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Genesis 10:27",
      "text": "וְאֶת ־ הֲדוֹרָ֥ם וְאֶת ־ אוּזָ֖ל וְאֶת ־ דִּקְלָֽה ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.28",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Genesis 10:28",
      "text": "וְאֶת ־ עוֹבָ֥ל וְאֶת ־ אֲבִֽימָאֵ֖ל וְאֶת ־ שְׁבָֽא ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.29",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Genesis 10:29",
      "text": "וְאֶת ־ אוֹפִ֥ר וְאֶת ־ חֲוִילָ֖ה וְאֶת ־ יוֹבָ֑ב כָּל ־ אֵ֖לֶּה בְּנֵ֥י יָקְטָֽן ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.30",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Genesis 10:30",
      "text": "וַֽיְהִ֥י מוֹשָׁבָ֖ם מִמֵּשָׁ֑א בֹּאֲכָ֥ה סְפָ֖רָה הַ֥ר הַקֶּֽדֶם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.31",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Genesis 10:31",
      "text": "אֵ֣לֶּה בְנֵי ־ שֵׁ֔ם לְמִשְׁפְּחֹתָ֖ם לִלְשֹׁנֹתָ֑ם בְּאַרְצֹתָ֖ם לְגוֹיֵהֶֽם ׃",
      "paragraphStart": false
    },
    {
      "id": "wlc:genesis.10.32",
      "translationId": "wlc",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Genesis 10:32",
      "text": "אֵ֣לֶּה מִשְׁפְּחֹ֧ת בְּנֵי ־ נֹ֛חַ לְתוֹלְדֹתָ֖ם בְּגוֹיֵהֶ֑ם וּמֵאֵ֜לֶּה נִפְרְד֧וּ הַגּוֹיִ֛ם בָּאָ֖רֶץ אַחַ֥ר הַמַּבּֽוּל ׃ פ",
      "paragraphStart": false
    }
  ]
}
