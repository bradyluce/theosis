  "verses": [
    {
      "id": "vulgate:isaiah.12.1",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Isaiah 12:1",
      "text": "Et dices in die illa: Confitebor tibi, Domine, quoniam iratus es mihi; conversus est furor tuus, et consolatus es me.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:isaiah.12.2",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Isaiah 12:2",
      "text": "Ecce Deus salvator meus; fiducialiter agam, et non timebo: quia fortitudo mea et laus mea Dominus, et factus est mihi in salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.12.3",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Isaiah 12:3",
      "text": "Haurietis aquas in gaudio de fontibus salvatoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.12.4",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Isaiah 12:4",
      "text": "Et dicetis in die illa: Confitemini Domino et invocate nomen ejus; notas facite in populis adinventiones ejus; mementote quoniam excelsum est nomen ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.12.5",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Isaiah 12:5",
      "text": "Cantate Domino, quoniam magnifice fecit; annuntiate hoc in universa terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.12.6",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Isaiah 12:6",
      "text": "Exsulta et lauda, habitatio Sion, quia magnus in medio tui Sanctus Israël.",
      "paragraphStart": false
    }
  ]
}
