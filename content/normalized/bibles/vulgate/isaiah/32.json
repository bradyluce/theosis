{
  "chapter": {
    "id": "vulgate:isaiah.32",
    "translationId": "vulgate",
    "bookSlug": "isaiah",
    "chapterNumber": 32,
    "referenceLabel": "Isaiah 32",
    "summary": "Source text for Isaiah 32 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:isaiah.32.1",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Isaiah 32:1",
      "text": "Ecce in justitia regnabit rex, et principes in judicio præerunt.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:isaiah.32.2",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Isaiah 32:2",
      "text": "Et erit vir sicut qui absconditur a vento, et celat se a tempestate; sicut rivi aquarum in siti, et umbra petræ prominentis in terra deserta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.3",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Isaiah 32:3",
      "text": "Non caligabunt oculi videntium, et aures audientium diligenter auscultabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.4",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Isaiah 32:4",
      "text": "Et cor stultorum intelliget scientiam, et lingua balborum velociter loquetur et plane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.5",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Isaiah 32:5",
      "text": "Non vocabitur ultra is qui insipiens est, princeps, neque fraudulentus appellabitur major;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.6",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Isaiah 32:6",
      "text": "stultus enim fatua loquetur, et cor ejus faciet iniquitatem, ut perficiat simulationem, et loquatur ad Dominum fraudulenter, et vacuam faciat animam esurientis, et potum sitienti auferat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.7",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Isaiah 32:7",
      "text": "Fraudulenti vasa pessima sunt; ipse enim cogitationes concinnavit ad perdendos mites in sermone mendacii, cum loqueretur pauper judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.8",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Isaiah 32:8",
      "text": "Princeps vero ea quæ digna sunt principe cogitabit, et ipse super duces stabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.9",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Isaiah 32:9",
      "text": "Mulieres opulentæ, surgite, et audite vocem meam; filiæ confidentes, percipite auribus eloquium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.10",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Isaiah 32:10",
      "text": "Post dies enim et annum, vos conturbabimini confidentes; consummata est enim vindemia, collectio ultra non veniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.11",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Isaiah 32:11",
      "text": "Obstupescite, opulentæ; conturbamini, confidentes: exuite vos et confundimini; accingite lumbos vestros.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.12",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Isaiah 32:12",
      "text": "Super ubera plangite, super regione desiderabili, super vinea fertili.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.13",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Isaiah 32:13",
      "text": "Super humum populi mei spinæ et vepres ascendent: quanto magis super omnes domos gaudii civitatis exultantis!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.14",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Isaiah 32:14",
      "text": "Domus enim dimissa est, multitudo urbis relicta est, tenebræ et palpatio factæ sunt super speluncas usque in æternum; gaudium onagrorum, pascua gregum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.15",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Isaiah 32:15",
      "text": "Donec effundatur super nos spiritus de excelso, et erit desertum in carmel, et carmel in saltum reputabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.16",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Isaiah 32:16",
      "text": "Et habitabit in solitudine judicium, et justitia in carmel sedebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.17",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Isaiah 32:17",
      "text": "Et erit opus justitiæ pax, et cultus justitiæ silentium, et securitas usque in sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.18",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Isaiah 32:18",
      "text": "Et sedebit populus meus in pulchritudine pacis, et in tabernaculis fiduciæ, et in requie opulenta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.19",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Isaiah 32:19",
      "text": "Grando autem in descensione saltus, et humilitate humiliabitur civitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.32.20",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Isaiah 32:20",
      "text": "Beati qui seminatis super omnes aquas, immittentes pedem bovis et asini.",
      "paragraphStart": false
    }
  ]
}
