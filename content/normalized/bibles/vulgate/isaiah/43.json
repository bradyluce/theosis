{
  "chapter": {
    "id": "vulgate:isaiah.43",
    "translationId": "vulgate",
    "bookSlug": "isaiah",
    "chapterNumber": 43,
    "referenceLabel": "Isaiah 43",
    "summary": "Source text for Isaiah 43 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:isaiah.43.1",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 1,
      "referenceLabel": "Isaiah 43:1",
      "text": "Et nunc hæc dicit Dominus creans te, Jacob, et formans te, Israël: Noli timere, quia redemi te, et vocavi te nomine tuo: meus es tu.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:isaiah.43.2",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 2,
      "referenceLabel": "Isaiah 43:2",
      "text": "Cum transieris per aquas, tecum ero, et flumina non operient te; cum ambulaveris in igne, non combureris, et flamma non ardebit in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.3",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 3,
      "referenceLabel": "Isaiah 43:3",
      "text": "Quia ego Dominus Deus tuus, Sanctus Israël, salvator tuus, dedi propitiationem tuam Ægyptum, Æthopiam, et Saba, pro te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.4",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 4,
      "referenceLabel": "Isaiah 43:4",
      "text": "Ex quo honorabilis factus es in oculis meis, et gloriosus, ego dilexi te, et dabo homines pro te, et populos pro anima tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.5",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 5,
      "referenceLabel": "Isaiah 43:5",
      "text": "Noli timere, quia ego tecum sum; ab oriente adducam semen tuum, et ab occidente congregabo te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.6",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 6,
      "referenceLabel": "Isaiah 43:6",
      "text": "Dicam aquiloni: Da; et austro: Noli prohibere: affer filios meos de longinquo, et filias meas ab extremis terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.7",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 7,
      "referenceLabel": "Isaiah 43:7",
      "text": "Et omnem qui invocat nomen meum, in gloriam meam creavi eum, formavi eum, et feci eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.8",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 8,
      "referenceLabel": "Isaiah 43:8",
      "text": "Educ foras populum cæcum, et oculos habentem; surdum, et aures ei sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.9",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 9,
      "referenceLabel": "Isaiah 43:9",
      "text": "Omnes gentes congregatæ sunt simul, et collectæ sunt tribus. Quis in vobis annuntiet istud, et quæ prima sunt audire nos faciet? Dent testes eorum, justificentur, et audiant, et dicant: Vere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.10",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 10,
      "referenceLabel": "Isaiah 43:10",
      "text": "Vos testes mei, dicit Dominus, et servus meus quem elegi: ut sciatis, et credatis mihi, et intelligatis quia ego ipse sum; ante me non est formatus Deus, et post me non erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.11",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 11,
      "referenceLabel": "Isaiah 43:11",
      "text": "Ego sum, ego sum Dominus, et non est absque me salvator.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.12",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 12,
      "referenceLabel": "Isaiah 43:12",
      "text": "Ego annuntiavi, et salvavi; auditum feci, et non fuit in vobis alienus: vos testes mei, dicit Dominus, et ego Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.13",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 13,
      "referenceLabel": "Isaiah 43:13",
      "text": "Et ab initio ego ipse, et non est qui de manu mea eruat. Operabor, et quis avertet illud?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.14",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 14,
      "referenceLabel": "Isaiah 43:14",
      "text": "Hæc dicit Dominus, redemptor vester, Sanctus Israël: Propter vos misi in Babylonem, et detraxi vectes universos, et Chaldæos in navibus suis gloriantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.15",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 15,
      "referenceLabel": "Isaiah 43:15",
      "text": "Ego Dominus, Sanctus vester, creans Israël, rex vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.16",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 16,
      "referenceLabel": "Isaiah 43:16",
      "text": "Hæc dicit Dominus, qui dedit in mari viam, et in aquis torrentibus semitam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.17",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 17,
      "referenceLabel": "Isaiah 43:17",
      "text": "qui eduxit quadrigam et equum, agmen et robustum: simul obdormierunt, nec resurgent; contriti sunt quasi linum, et extincti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.18",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 18,
      "referenceLabel": "Isaiah 43:18",
      "text": "Ne memineritis priorum, et antiqua ne intueamini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.19",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 19,
      "referenceLabel": "Isaiah 43:19",
      "text": "Ecce ego facio nova, et nunc orientur, utique cognoscetis ea: ponam in deserto viam, et in invio flumina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.20",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 20,
      "referenceLabel": "Isaiah 43:20",
      "text": "Glorificabit me bestia agri, dracones, et struthiones: quia dedi in deserto aquas, flumina in invio, ut darem potum populo meo, electo meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.21",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 21,
      "referenceLabel": "Isaiah 43:21",
      "text": "Populum istum formavi mihi: laudem meam narrabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.22",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 22,
      "referenceLabel": "Isaiah 43:22",
      "text": "Non me invocasti, Jacob, nec laborasti in me, Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.23",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 23,
      "referenceLabel": "Isaiah 43:23",
      "text": "Non obtulisti mihi arietem holocausti tui, et victimis tuis non glorificasti me; non te servire feci in oblatione, nec laborem tibi præbui in thure.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.24",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 24,
      "referenceLabel": "Isaiah 43:24",
      "text": "Non emisti mihi argento calamum, et adipe victimarum tuarum non inebriasti me: verumtamen servire me fecisti in peccatis tuis; præbuisti mihi laborem in iniquitatibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.25",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 25,
      "referenceLabel": "Isaiah 43:25",
      "text": "Ego sum, ego sum ipse qui deleo iniquitates tuas propter me, et peccatorum tuorum non recordabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.26",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 26,
      "referenceLabel": "Isaiah 43:26",
      "text": "Reduc me in memoriam, et judicemur simul: narra si quid habes ut justificeris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.27",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 27,
      "referenceLabel": "Isaiah 43:27",
      "text": "Pater tuus primus peccavit, et interpretes tui prævaricati sunt in me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.43.28",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 43,
      "verseNumber": 28,
      "referenceLabel": "Isaiah 43:28",
      "text": "et contaminavi principes sanctos; dedi ad internecionem Jacob, et Israël in blasphemiam.",
      "paragraphStart": false
    }
  ]
}
