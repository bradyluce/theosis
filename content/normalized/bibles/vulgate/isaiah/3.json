{
  "chapter": {
    "id": "vulgate:isaiah.3",
    "translationId": "vulgate",
    "bookSlug": "isaiah",
    "chapterNumber": 3,
    "referenceLabel": "Isaiah 3",
    "summary": "Source text for Isaiah 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:isaiah.3.1",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Isaiah 3:1",
      "text": "Ecce enim Dominator, Dominus exercituum, auferet a Jerusalem et a Juda validum et fortem, omne robur panis, et omne robor aquæ;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:isaiah.3.2",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Isaiah 3:2",
      "text": "fortem, et virum bellatorem, judicem, et prophetam, et ariolum, et senem;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.3",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Isaiah 3:3",
      "text": "principem super quinquaginta, et honorabilem vultu et consiliarium, et sapientem de architectis, et prudentem eloquii mystici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.4",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Isaiah 3:4",
      "text": "Et dabo pueros principes eorum, et effeminati dominabuntur eis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.5",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Isaiah 3:5",
      "text": "et irruet populus, vir ad virum, et unusquisque ad proximum suum; tumultuabitur puer contra senem, et ignobilis contra nobilem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.6",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Isaiah 3:6",
      "text": "Apprehendet enim vir fratrem suum, domesticum patris sui: Vestimentum tibi est, princeps esto noster, ruina autem hæc sub manu tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.7",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Isaiah 3:7",
      "text": "Respondebit in die illa, dicens: Non sum medicus, et in domo mea non est panis neque vestimentum: nolite constituere me principem populi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.8",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Isaiah 3:8",
      "text": "Ruit enim Jerusalem, et Judas concidit, quia lingua eorum et adinventiones eorum contra Dominum, ut provocarent oculos majestatis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.9",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Isaiah 3:9",
      "text": "Agnitio vultus eorum respondit eis; et peccatum suum quasi Sodoma prædicaverunt, nec absconderunt. Væ animæ eorum, quoniam reddita sunt eis mala!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.10",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Isaiah 3:10",
      "text": "Dicite justo quoniam bene, quoniam fructum adinventionum suarum comedet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.11",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Isaiah 3:11",
      "text": "Væ impio in malum! retributio enim manuum ejus fiet ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.12",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Isaiah 3:12",
      "text": "Populum meum exactores sui spoliaverunt, et mulieres dominatæ sunt eis. Popule meus, qui te beatum dicunt, ipsi te decipiunt, et viam gressuum tuorum dissipant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.13",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Isaiah 3:13",
      "text": "Stat ad judicandum Dominus, et stat ad judicandos populos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.14",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Isaiah 3:14",
      "text": "Dominus ad judicium veniet cum senibus populi sui, et principibus ejus; vos enim depasti estis vineam, et rapina pauperis in domo vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.15",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Isaiah 3:15",
      "text": "Quare atteritis populum meum, et facies pauperum commolitis? dicit Dominus Deus exercituum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.16",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Isaiah 3:16",
      "text": "Et dixit Dominus: Pro eo quod elevatæ sunt filiæ Sion, et ambulaverunt extento collo, et nutibus oculorum ibant, et plaudebant, ambulabant pedibus suis, et composito gradu incedebant;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.17",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Isaiah 3:17",
      "text": "decalvabit Dominus verticem filiarum Sion, et Dominus crinem earum nudabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.18",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Isaiah 3:18",
      "text": "In die illa auferet Dominus ornamentum calceamentum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.19",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Isaiah 3:19",
      "text": "et lunulas, et torques, et monilia, et armillas, et mitras,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.20",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Isaiah 3:20",
      "text": "et discriminalia, et periscelidas, et murenulas, et olfactoriola, et inaures,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.21",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Isaiah 3:21",
      "text": "et annulos, et gemmas in fronte pendentes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.22",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Isaiah 3:22",
      "text": "et mutatoria, et palliola, et linteamina, et acus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.23",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Isaiah 3:23",
      "text": "et specula, et sindones, et vittas, et theristra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.24",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Isaiah 3:24",
      "text": "Et erit pro suavi odore fœtor, et pro zona funiculus, et pro crispanti crine calvitium, et pro fascia pectorali cilicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.25",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Isaiah 3:25",
      "text": "Pulcherrimi quoque viri tui gladio cadent, et fortes tui in prælio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:isaiah.3.26",
      "translationId": "vulgate",
      "bookSlug": "isaiah",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Isaiah 3:26",
      "text": "Et mœrebunt atque lugebunt portæ ejus, et desolata in terra sedebit.",
      "paragraphStart": false
    }
  ]
}
