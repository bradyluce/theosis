{
  "chapter": {
    "id": "vulgate:luke.23",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 23,
    "referenceLabel": "Luke 23",
    "summary": "Source text for Luke 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.23.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Luke 23:1",
      "text": "Et surgens omnis multitudo eorum, duxerunt illum ad Pilatum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.23.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Luke 23:2",
      "text": "Cœperunt autem illum accusare, dicentes: Hunc invenimus subvertentem gentem nostram, et prohibentem tributa dare Cæsari, et dicentem se Christum regem esse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Luke 23:3",
      "text": "Pilatus autem interrogavit eum, dicens: Tu es rex Judæorum? At ille respondens ait: Tu dicis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Luke 23:4",
      "text": "Ait autem Pilatus ad principes sacerdotum et turbas: Nihil invenio causæ in hoc homine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Luke 23:5",
      "text": "At illi invalescebant, dicentes: Commovet populum docens per universam Judæam, incipiens a Galilæa usque huc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Luke 23:6",
      "text": "Pilatus autem audiens Galilæam, interrogavit si homo Galilæus esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Luke 23:7",
      "text": "Et ut cognovit quod de Herodis potestate esset, remisit eum ad Herodem, qui et ipse Jerosolymis erat illis diebus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Luke 23:8",
      "text": "Herodes autem viso Jesu, gavisus est valde. Erat enim cupiens ex multo tempore videre eum, eo quod audierat multa de eo, et sperabat signum aliquod videre ab eo fieri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Luke 23:9",
      "text": "Interrogabat autem eum multis sermonibus. At ipse nihil illi respondebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Luke 23:10",
      "text": "Stabant autem principes sacerdotum et scribæ constanter accusantes eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Luke 23:11",
      "text": "Sprevit autem illum Herodes cum exercitu suo: et illusit indutum veste alba, et remisit ad Pilatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Luke 23:12",
      "text": "Et facti sunt amici Herodes et Pilatus in ipsa die: nam antea inimici erant ad invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Luke 23:13",
      "text": "Pilatus autem, convocatis principibus sacerdotum, et magistratibus, et plebe,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Luke 23:14",
      "text": "dixit ad illos: Obtulistis mihi hunc hominem, quasi avertentem populum, et ecce ego coram vobis interrogans, nullam causam inveni in homine isto ex his in quibus eum accusatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Luke 23:15",
      "text": "Sed neque Herodes: nam remisi vos ad illum, et ecce nihil dignum morte actum est ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Luke 23:16",
      "text": "Emendatum ergo illum dimittam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Luke 23:17",
      "text": "Necesse autem habebat dimittere eis per diem festum unum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Luke 23:18",
      "text": "Exclamavit autem simul universa turba, dicens: Tolle hunc, et dimitte nobis Barabbam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Luke 23:19",
      "text": "qui erat propter seditionem quamdam factam in civitate et homicidium missus in carcerem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Luke 23:20",
      "text": "Iterum autem Pilatus locutus est ad eos, volens dimittere Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Luke 23:21",
      "text": "At illi succlamabant, dicentes: Crucifige, crucifige eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Luke 23:22",
      "text": "Ille autem tertio dixit ad illos: Quid enim mali fecit iste? nullam causam mortis invenio in eo: corripiam ergo illum et dimittam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Luke 23:23",
      "text": "At illi instabant vocibus magnis postulantes ut crucifigeretur: et invalescebant voces eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Luke 23:24",
      "text": "Et Pilatus adjudicavit fieri petitionem eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Luke 23:25",
      "text": "Dimisit autem illis eum qui propter homicidium et seditionem missus fuerat in carcerem, quem petebant: Jesum vero tradidit voluntati eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Luke 23:26",
      "text": "Et cum ducerent eum, apprehenderunt Simonem quemdam Cyrenensem venientem de villa: et imposuerunt illi crucem portare post Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Luke 23:27",
      "text": "Sequebatur autem illum multa turba populi et mulierum, quæ plangebant et lamentabantur eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Luke 23:28",
      "text": "Conversus autem ad illas Jesus, dixit: Filiæ Jerusalem, nolite flere super me, sed super vos ipsas flete et super filios vestros.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Luke 23:29",
      "text": "Quoniam ecce venient dies in quibus dicent: Beatæ steriles, et ventres qui non genuerunt, et ubera quæ non lactaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Luke 23:30",
      "text": "Tunc incipient dicere montibus: Cadite super nos; et collibus: Operite nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Luke 23:31",
      "text": "Quia si in viridi ligno hæc faciunt, in arido quid fiet?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Luke 23:32",
      "text": "Ducebantur autem et alii duo nequam cum eo, ut interficerentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Luke 23:33",
      "text": "Et postquam venerunt in locum qui vocatur Calvariæ, ibi crucifixerunt eum: et latrones, unum a dextris, et alterum a sinistris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Luke 23:34",
      "text": "Jesus autem dicebat: Pater, dimitte illis: non enim sciunt quid faciunt. Dividentes vero vestimenta ejus, miserunt sortes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Luke 23:35",
      "text": "Et stabat populus spectans, et deridebant eum principes cum eis, dicentes: Alios salvos fecit, se salvum faciat, si hic est Christus Dei electus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 36,
      "referenceLabel": "Luke 23:36",
      "text": "Illudebant autem ei et milites accedentes, et acetum offerentes ei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 37,
      "referenceLabel": "Luke 23:37",
      "text": "et dicentes: Si tu es rex Judæorum, salvum te fac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 38,
      "referenceLabel": "Luke 23:38",
      "text": "Erat autem et superscriptio scripta super eum litteris græcis, et latinis, et hebraicis: Hic est rex Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 39,
      "referenceLabel": "Luke 23:39",
      "text": "Unus autem de his, qui pendebant, latronibus, blasphemabat eum, dicens: Si tu es Christus, salvum fac temetipsum et nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 40,
      "referenceLabel": "Luke 23:40",
      "text": "Respondens autem alter increpabat eum, dicens: Neque tu times Deum, quod in eadem damnatione es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 41,
      "referenceLabel": "Luke 23:41",
      "text": "Et nos quidem juste, nam digna factis recipimus: hic vero nihil mali gessit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 42,
      "referenceLabel": "Luke 23:42",
      "text": "Et dicebat ad Jesum: Domine, memento mei cum veneris in regnum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 43,
      "referenceLabel": "Luke 23:43",
      "text": "Et dixit illi Jesus: Amen dico tibi: hodie mecum eris in paradiso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 44,
      "referenceLabel": "Luke 23:44",
      "text": "Erat autem fere hora sexta, et tenebræ factæ sunt in universam terram usque ad horam nonam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 45,
      "referenceLabel": "Luke 23:45",
      "text": "Et obscuratus est sol, et velum templi scissum est medium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 46,
      "referenceLabel": "Luke 23:46",
      "text": "Et clamans voce magna Jesus ait: Pater, in manus tuas commendo spiritum meum. Et hæc dicens, expiravit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 47,
      "referenceLabel": "Luke 23:47",
      "text": "Videns autem centurio quod factum fuerat, glorificavit Deum, dicens: Vere hic homo justus erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 48,
      "referenceLabel": "Luke 23:48",
      "text": "Et omnis turba eorum, qui simul aderant ad spectaculum istud, et videbant quæ fiebant, percutientes pectora sua revertebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.49",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 49,
      "referenceLabel": "Luke 23:49",
      "text": "Stabant autem omnes noti ejus a longe, et mulieres, quæ secutæ eum erant a Galilæa, hæc videntes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.50",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 50,
      "referenceLabel": "Luke 23:50",
      "text": "Et ecce vir nomine Joseph, qui erat decurio, vir bonus et justus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.51",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 51,
      "referenceLabel": "Luke 23:51",
      "text": "hic non consenserat consilio, et actibus eorum: ab Arimathæa civitate Judææ, qui exspectabat et ipse regnum Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.52",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 52,
      "referenceLabel": "Luke 23:52",
      "text": "hic accessit ad Pilatum et petiit corpus Jesu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.53",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 53,
      "referenceLabel": "Luke 23:53",
      "text": "et depositum involvit sindone, et posuit eum in monumento exciso, in quo nondum quisquam positus fuerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.54",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 54,
      "referenceLabel": "Luke 23:54",
      "text": "Et dies erat parasceves, et sabbatum illucescebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.55",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 55,
      "referenceLabel": "Luke 23:55",
      "text": "Subsecutæ autem mulieres, quæ cum eo venerant de Galilæa, viderunt monumentum, et quemadmodum positum erat corpus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.23.56",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 23,
      "verseNumber": 56,
      "referenceLabel": "Luke 23:56",
      "text": "Et revertentes paraverunt aromata, et unguenta: et sabbato quidem siluerunt secundum mandatum.",
      "paragraphStart": false
    }
  ]
}
