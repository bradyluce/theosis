{
  "chapter": {
    "id": "vulgate:luke.17",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 17,
    "referenceLabel": "Luke 17",
    "summary": "Source text for Luke 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.17.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Luke 17:1",
      "text": "Et ait ad discipulos suos: Impossibile est ut non veniant scandala: væ autem illi per quem veniunt.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.17.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Luke 17:2",
      "text": "Utilius est illi si lapis molaris imponatur circa collum ejus, et projiciatur in mare quam ut scandalizet unum de pusillis istis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Luke 17:3",
      "text": "Attendite vobis: Si peccaverit in te frater tuus, increpa illum: et si pœnitentiam egerit, dimitte illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Luke 17:4",
      "text": "Et si septies in die peccaverit in te, et septies in die conversus fuerit ad te, dicens: Pœnitet me, dimitte illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Luke 17:5",
      "text": "Et dixerunt apostoli Domino: Adauge nobis fidem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Luke 17:6",
      "text": "Dixit autem Dominus: Si habueritis fidem sicut granum sinapis, dicetis huic arbori moro: Eradicare, et transplantare in mare, et obediet vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Luke 17:7",
      "text": "Quis autem vestrum habens servum arantem aut pascentem, qui regresso de agro dicat illi: Statim transi, recumbe:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Luke 17:8",
      "text": "et non dicat ei: Para quod cœnem, et præcinge te, et ministra mihi donec manducem, et bibam, et post hæc tu manducabis, et bibes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Luke 17:9",
      "text": "Numquid gratiam habet servo illi, quia fecit quæ ei imperaverat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Luke 17:10",
      "text": "non puto. Sic et vos cum feceritis omnia quæ præcepta sunt vobis, dicite: Servi inutiles sumus: quod debuimus facere, fecimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Luke 17:11",
      "text": "Et factum est, dum iret in Jerusalem, transibat per mediam Samariam et Galilæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Luke 17:12",
      "text": "Et cum ingrederetur quoddam castellum, occurrerunt ei decem viri leprosi, qui steterunt a longe:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Luke 17:13",
      "text": "et levaverunt vocem, dicentes: Jesu præceptor, miserere nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Luke 17:14",
      "text": "Quos ut vidit, dixit: Ite, ostendite vos sacerdotibus. Et factum est, dum irent, mundati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Luke 17:15",
      "text": "Unus autem ex illis, ut vidit quia mundatus est, regressus est, cum magna voce magnificans Deum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Luke 17:16",
      "text": "et cecidit in faciem ante pedes ejus, gratias agens: et hic erat Samaritanus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Luke 17:17",
      "text": "Respondens autem Jesus, dixit: Nonne decem mundati sunt? et novem ubi sunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Luke 17:18",
      "text": "Non est inventus qui rediret, et daret gloriam Deo, nisi hic alienigena.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Luke 17:19",
      "text": "Et ait illi: Surge, vade: quia fides tua te salvum fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Luke 17:20",
      "text": "Interrogatus autem a pharisæis: Quando venit regnum Dei? respondens eis, dixit: Non venit regnum Dei cum observatione:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Luke 17:21",
      "text": "neque dicent: Ecce hic, aut ecce illic. Ecce enim regnum Dei intra vos est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Luke 17:22",
      "text": "Et ait ad discipulos suos: Venient dies quando desideretis videre unum diem Filii hominis, et non videbitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Luke 17:23",
      "text": "Et dicent vobis: Ecce hic, et ecce illic. Nolite ire, neque sectemini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Luke 17:24",
      "text": "nam, sicut fulgur coruscans de sub cælo in ea quæ sub cælo sunt, fulget: ita erit Filius hominis in die sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Luke 17:25",
      "text": "Primum autem oportet illum multa pati, et reprobari a generatione hac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Luke 17:26",
      "text": "Et sicut factum est in diebus Noë, ita erit et in diebus Filii hominis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Luke 17:27",
      "text": "edebant et bibebant: uxores ducebant et dabantur ad nuptias, usque in diem, qua intravit Noë in arcam: et venit diluvium, et perdidit omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Luke 17:28",
      "text": "Similiter sicut factum est in diebus Lot: edebant et bibebant, emebant et vendebant, plantabant et ædificabant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 29,
      "referenceLabel": "Luke 17:29",
      "text": "qua die autem exiit Lot a Sodomis, pluit ignem et sulphur de cælo, et omnes perdidit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 30,
      "referenceLabel": "Luke 17:30",
      "text": "secundum hæc erit qua die Filius hominis revelabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 31,
      "referenceLabel": "Luke 17:31",
      "text": "In illa hora, qui fuerit in tecto, et vasa ejus in domo, ne descendat tollere illa: et qui in agro, similiter non redeat retro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 32,
      "referenceLabel": "Luke 17:32",
      "text": "Memores estote uxoris Lot.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 33,
      "referenceLabel": "Luke 17:33",
      "text": "Quicumque quæsierit animam suam salvam facere, perdet illam: et quicumque perdiderit illam, vivificabit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 34,
      "referenceLabel": "Luke 17:34",
      "text": "Dico vobis: In illa nocte erunt duo in lecto uno: unus assumetur, et alter relinquetur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 35,
      "referenceLabel": "Luke 17:35",
      "text": "duæ erunt molentes in unum: una assumetur, et altera relinquetur: duo in agro: unus assumetur, et alter relinquetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 36,
      "referenceLabel": "Luke 17:36",
      "text": "Respondentes dicunt illi: Ubi Domine?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.17.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 37,
      "referenceLabel": "Luke 17:37",
      "text": "Qui dixit illis: Ubicumque fuerit corpus, illuc congregabuntur et aquilæ.",
      "paragraphStart": false
    }
  ]
}
