{
  "chapter": {
    "id": "vulgate:luke.4",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 4,
    "referenceLabel": "Luke 4",
    "summary": "Source text for Luke 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.4.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Luke 4:1",
      "text": "Jesus autem plenus Spiritu Sancto regressus est a Jordane: et agebatur a Spiritu in desertum",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.4.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Luke 4:2",
      "text": "diebus quadraginta, et tentabatur a diabolo. Et nihil manducavit in diebus illis: et consummatis illis esuriit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Luke 4:3",
      "text": "Dixit autem illi diabolus: Si Filius Dei es, dic lapidi huic ut panis fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Luke 4:4",
      "text": "Et respondit ad illum Jesus: Scriptum est: Quia non in solo pane vivit homo, sed in omni verbo Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Luke 4:5",
      "text": "Et duxit illum diabolus in montem excelsum, et ostendit illi omnia regna orbis terræ in momento temporis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Luke 4:6",
      "text": "et ait illi: Tibi dabo potestatem hanc universam, et gloriam illorum: quia mihi tradita sunt, et cui volo do illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Luke 4:7",
      "text": "Tu ergo si adoraveris coram me, erunt tua omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Luke 4:8",
      "text": "Et respondens Jesus, dixit illi: Scriptum est: Dominum Deum tuum adorabis, et illi soli servies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Luke 4:9",
      "text": "Et duxit illum in Jerusalem, et statuit eum super pinnam templi, et dixit illi: Si Filius Dei es, mitte te hinc deorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Luke 4:10",
      "text": "Scriptum est enim quod angelis suis mandavit de te, ut conservent te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Luke 4:11",
      "text": "et quia in manibus tollent te, ne forte offendas ad lapidem pedem tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Luke 4:12",
      "text": "Et respondens Jesus, ait illi: Dictum est: Non tentabis Dominum Deum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Luke 4:13",
      "text": "Et consummata omni tentatione, diabolus recessit ab illo, usque ad tempus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Luke 4:14",
      "text": "Et regressus est Jesus in virtute Spiritus in Galilæam, et fama exiit per universam regionem de illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Luke 4:15",
      "text": "Et ipse docebat in synagogis eorum, et magnificabatur ab omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Luke 4:16",
      "text": "Et venit Nazareth, ubi erat nutritus, et intravit secundum consuetudinem suam die sabbati in synagogam, et surrexit legere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Luke 4:17",
      "text": "Et traditus est illi liber Isaiæ prophetæ. Et ut revolvit librum, invenit locum ubi scriptum erat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Luke 4:18",
      "text": "Spiritus Domini super me: propter quod unxit me, evangelizare pauperibus misit me, sanare contritos corde,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Luke 4:19",
      "text": "prædicare captivis remissionem, et cæcis visum, dimittere confractos in remissionem, prædicare annum Domini acceptum et diem retributionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Luke 4:20",
      "text": "Et cum plicuisset librum, reddit ministro, et sedit. Et omnium in synagoga oculi erant intendentes in eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Luke 4:21",
      "text": "Cœpit autem dicere ad illos: Quia hodie impleta est hæc scriptura in auribus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Luke 4:22",
      "text": "Et omnes testimonium illi dabant: et mirabantur in verbis gratiæ, quæ procedebant de ore ipsius, et dicebant: Nonne hic est filius Joseph?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Luke 4:23",
      "text": "Et ait illis: Utique dicetis mihi hanc similitudinem: Medice cura teipsum: quanta audivimus facta in Capharnaum, fac et hic in patria tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Luke 4:24",
      "text": "Ait autem: Amen dico vobis, quia nemo propheta acceptus est in patria sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Luke 4:25",
      "text": "In veritate dico vobis, multæ viduæ erant in diebus Eliæ in Israël, quando clausum est cælum annis tribus et mensibus sex, cum facta esset fames magna in omni terra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Luke 4:26",
      "text": "et ad nullam illarum missus est Elias, nisi in Sarepta Sidoniæ, ad mulierem viduam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Luke 4:27",
      "text": "Et multi leprosi erant in Israël sub Eliseo propheta: et nemo eorum mundatus est nisi Naaman Syrus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Luke 4:28",
      "text": "Et repleti sunt omnes in synagoga ira, hæc audientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Luke 4:29",
      "text": "Et surrexerunt, et ejecerunt illum extra civitatem: et duxerunt illum usque ad supercilium montis, super quem civitas illorum erat ædificata, ut præcipitarent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Luke 4:30",
      "text": "Ipse autem transiens per medium illorum, ibat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Luke 4:31",
      "text": "Et descendit in Capharnaum civitatem Galilææ, ibique docebat illos sabbatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Luke 4:32",
      "text": "Et stupebant in doctrina ejus, quia in potestate erat sermo ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Luke 4:33",
      "text": "Et in synagoga erat homo habens dæmonium immundum, et exclamavit voce magna,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "Luke 4:34",
      "text": "dicens: Sine, quid nobis et tibi, Jesu Nazarene? venisti perdere nos? scio te quis sis, Sanctus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "Luke 4:35",
      "text": "Et increpavit illum Jesus, dicens: Obmutesce, et exi ab eo. Et cum projecisset illum dæmonium in medium, exiit ab illo, nihilque illum nocuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "Luke 4:36",
      "text": "Et factus est pavor in omnibus, et colloquebantur ad invicem, dicentes: Quod est hoc verbum, quia in potestate et virtute imperat immundis spiritibus, et exeunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "Luke 4:37",
      "text": "Et divulgabatur fama de illo in omnem locum regionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "Luke 4:38",
      "text": "Surgens autem Jesus de synagoga, introivit in domum Simonis. Socrus autem Simonis tenebatur magnis febribus: et rogaverunt illum pro ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 39,
      "referenceLabel": "Luke 4:39",
      "text": "Et stans super illam imperavit febri: et dimisit illam. Et continuo surgens, ministrabat illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 40,
      "referenceLabel": "Luke 4:40",
      "text": "Cum autem sol occidisset, omnes qui habebant infirmos variis languoribus, ducebant illos ad eum. At ille singulis manus imponens, curabat eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 41,
      "referenceLabel": "Luke 4:41",
      "text": "Exibant autem dæmonia a multis clamantia, et dicentia: Quia tu es Filius Dei: et increpans non sinebat ea loqui: quia sciebant ipsum esse Christum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 42,
      "referenceLabel": "Luke 4:42",
      "text": "Facta autem die egressus ibat in desertum locum, et turbæ requirebant eum, et venerunt usque ad ipsum: et detinebant illum ne discederet ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 43,
      "referenceLabel": "Luke 4:43",
      "text": "Quibus ille ait: Quia et aliis civitatibus oportet me evangelizare regnum Dei: quia ideo missus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.4.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 4,
      "verseNumber": 44,
      "referenceLabel": "Luke 4:44",
      "text": "Et erat prædicans in synagogis Galilææ.",
      "paragraphStart": false
    }
  ]
}
