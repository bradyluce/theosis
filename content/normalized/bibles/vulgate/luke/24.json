{
  "chapter": {
    "id": "vulgate:luke.24",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 24,
    "referenceLabel": "Luke 24",
    "summary": "Source text for Luke 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.24.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Luke 24:1",
      "text": "Una autem sabbati valde diluculo venerunt ad monumentum, portantes quæ paraverant aromata:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.24.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Luke 24:2",
      "text": "et invenerunt lapidem revolutum a monumento.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Luke 24:3",
      "text": "Et ingressæ non invenerunt corpus Domini Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Luke 24:4",
      "text": "Et factum est, dum mente consternatæ essent de isto, ecce duo viri steterunt secus illas in veste fulgenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Luke 24:5",
      "text": "Cum timerent autem, et declinarent vultum in terram, dixerunt ad illas: Quid quæritis viventem cum mortuis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Luke 24:6",
      "text": "non est hic, sed surrexit: recordamini qualiter locutus est vobis, cum adhuc in Galilæa esset,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Luke 24:7",
      "text": "dicens: Quia oportet Filium hominis tradi in manus hominum peccatorum, et crucifigi, et die tertia resurgere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Luke 24:8",
      "text": "Et recordatæ sunt verborum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Luke 24:9",
      "text": "Et regressæ a monumento nuntiaverunt hæc omnia illis undecim, et ceteris omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Luke 24:10",
      "text": "Erat autem Maria Magdalene, et Joanna, et Maria Jacobi, et ceteræ quæ cum eis erant, quæ dicebant ad apostolos hæc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Luke 24:11",
      "text": "Et visa sunt ante illos sicut deliramentum verba ista, et non crediderunt illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Luke 24:12",
      "text": "Petrus autem surgens cucurrit ad monumentum: et procumbens vidit linteamina sola posita, et abiit secum mirans quod factum fuerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Luke 24:13",
      "text": "Et ecce duo ex illis ibant ipsa die in castellum, quod erat in spatio stadiorum sexaginta ab Jerusalem, nomine Emmaus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Luke 24:14",
      "text": "Et ipsi loquebantur ad invicem de his omnibus quæ acciderant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Luke 24:15",
      "text": "Et factum est, dum fabularentur, et secum quærerent: et ipse Jesus appropinquans ibat cum illis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Luke 24:16",
      "text": "oculi autem illorum tenebantur ne eum agnoscerent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Luke 24:17",
      "text": "Et ait ad illos: Qui sunt hi sermones, quos confertis ad invicem ambulantes, et estis tristes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Luke 24:18",
      "text": "Et respondens unus, cui nomen Cleophas, dixit ei: Tu solus peregrinus es in Jerusalem, et non cognovisti quæ facta sunt in illa his diebus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Luke 24:19",
      "text": "Quibus ille dixit: Quæ? Et dixerunt: De Jesu Nazareno, qui fuit vir propheta, potens in opere et sermone coram Deo et omni populo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Luke 24:20",
      "text": "et quomodo eum tradiderunt summi sacerdotes et principes nostri in damnationem mortis, et crucifixerunt eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Luke 24:21",
      "text": "nos autem sperabamus quia ipse esset redempturus Israël: et nunc super hæc omnia, tertia dies est hodie quod hæc facta sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Luke 24:22",
      "text": "Sed et mulieres quædam ex nostris terruerunt nos, quæ ante lucem fuerunt ad monumentum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Luke 24:23",
      "text": "et non invento corpore ejus, venerunt, dicentes se etiam visionem angelorum vidisse, qui dicunt eum vivere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Luke 24:24",
      "text": "Et abierunt quidam ex nostris ad monumentum: et ita invenerunt sicut mulieres dixerunt, ipsum vero non invenerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Luke 24:25",
      "text": "Et ipse dixit ad eos: O stulti, et tardi corde ad credendum in omnibus quæ locuti sunt prophetæ!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Luke 24:26",
      "text": "Nonne hæc oportuit pati Christum, et ita intrare in gloriam suam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Luke 24:27",
      "text": "Et incipiens a Moyse, et omnibus prophetis, interpretabatur illis in omnibus scripturis quæ de ipso erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Luke 24:28",
      "text": "Et appropinquaverunt castello quo ibant: et ipse se finxit longius ire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Luke 24:29",
      "text": "Et coëgerunt illum, dicentes: Mane nobiscum, quoniam advesperascit, et inclinata est jam dies. Et intravit cum illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Luke 24:30",
      "text": "Et factum est, dum recumberet cum eis, accepit panem, et benedixit, ac fregit, et porrigebat illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Luke 24:31",
      "text": "Et aperti sunt oculi eorum, et cognoverunt eum: et ipse evanuit ex oculis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Luke 24:32",
      "text": "Et dixerunt ad invicem: Nonne cor nostrum ardens erat in nobis dum loqueretur in via, et aperiret nobis Scripturas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Luke 24:33",
      "text": "Et surgentes eadem hora regressi sunt in Jerusalem: et invenerunt congregatos undecim, et eos qui cum illis erant,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Luke 24:34",
      "text": "dicentes: Quod surrexit Dominus vere, et apparuit Simoni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 35,
      "referenceLabel": "Luke 24:35",
      "text": "Et ipsi narrabant quæ gesta erant in via, et quomodo cognoverunt eum in fractione panis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 36,
      "referenceLabel": "Luke 24:36",
      "text": "Dum autem hæc loquuntur, stetit Jesus in medio eorum, et dicit eis: Pax vobis: ego sum, nolite timere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 37,
      "referenceLabel": "Luke 24:37",
      "text": "Conturbati vero et conterriti, existimabant se spiritum videre.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 38,
      "referenceLabel": "Luke 24:38",
      "text": "Et dixit eis: Quid turbati estis, et cogitationes ascendunt in corda vestra?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 39,
      "referenceLabel": "Luke 24:39",
      "text": "videte manus meas, et pedes, quia ego ipse sum; palpate et videte, quia spiritus carnem et ossa non habet, sicut me videtis habere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 40,
      "referenceLabel": "Luke 24:40",
      "text": "Et cum hoc dixisset, ostendit eis manus et pedes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 41,
      "referenceLabel": "Luke 24:41",
      "text": "Adhuc autem illis non credentibus, et mirantibus præ gaudio, dixit: Habetis hic aliquid quod manducetur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 42,
      "referenceLabel": "Luke 24:42",
      "text": "At illi obtulerunt ei partem piscis assi et favum mellis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 43,
      "referenceLabel": "Luke 24:43",
      "text": "Et cum manducasset coram eis, sumens reliquias dedit eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 44,
      "referenceLabel": "Luke 24:44",
      "text": "Et dixit ad eos: Hæc sunt verba quæ locutus sum ad vos cum adhuc essem vobiscum, quoniam necesse est impleri omnia quæ scripta sunt in lege Moysi, et prophetis, et Psalmis de me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 45,
      "referenceLabel": "Luke 24:45",
      "text": "Tunc aperuit illis sensum ut intelligerent Scripturas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 46,
      "referenceLabel": "Luke 24:46",
      "text": "et dixit eis: Quoniam sic scriptum est, et sic oportebat Christum pati, et resurgere a mortuis tertia die:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 47,
      "referenceLabel": "Luke 24:47",
      "text": "et prædicari in nomine ejus pœnitentiam, et remissionem peccatorum in omnes gentes, incipientibus ab Jerosolyma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 48,
      "referenceLabel": "Luke 24:48",
      "text": "Vos autem testes estis horum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.49",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 49,
      "referenceLabel": "Luke 24:49",
      "text": "Et ego mitto promissum Patris mei in vos; vos autem sedete in civitate, quoadusque induamini virtute ex alto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.50",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 50,
      "referenceLabel": "Luke 24:50",
      "text": "Eduxit autem eos foras in Bethaniam, et elevatis manibus suis benedixit eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.51",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 51,
      "referenceLabel": "Luke 24:51",
      "text": "Et factum est, dum benediceret illis, recessit ab eis, et ferebatur in cælum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.52",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 52,
      "referenceLabel": "Luke 24:52",
      "text": "Et ipsi adorantes regressi sunt in Jerusalem cum gaudio magno:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.24.53",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 53,
      "referenceLabel": "Luke 24:53",
      "text": "et erant semper in templo, laudantes et benedicentes Deum. Amen.",
      "paragraphStart": false
    }
  ]
}
