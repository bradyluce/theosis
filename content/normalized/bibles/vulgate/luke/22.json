{
  "chapter": {
    "id": "vulgate:luke.22",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 22,
    "referenceLabel": "Luke 22",
    "summary": "Source text for Luke 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.22.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Luke 22:1",
      "text": "Appropinquabat autem dies festus azymorum, qui dicitur Pascha:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.22.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Luke 22:2",
      "text": "et quærebant principes sacerdotum, et scribæ, quomodo Jesum interficerent: timebant vero plebem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Luke 22:3",
      "text": "Intravit autem Satanas in Judam, qui cognominabatur Iscariotes, unum de duodecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Luke 22:4",
      "text": "et abiit, et locutus est cum principibus sacerdotum, et magistratibus, quemadmodum illum traderet eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Luke 22:5",
      "text": "Et gavisi sunt, et pacti sunt pecuniam illi dare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Luke 22:6",
      "text": "Et spopondit, et quærebat opportunitatem ut traderet illum sine turbis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Luke 22:7",
      "text": "Venit autem dies azymorum, in qua necesse erat occidi pascha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Luke 22:8",
      "text": "Et misit Petrum et Joannem, dicens: Euntes parate nobis pascha, ut manducemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Luke 22:9",
      "text": "At illi dixerunt: Ubi vis paremus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Luke 22:10",
      "text": "Et dixit ad eos: Ecce introëuntibus vobis in civitatem occurret vobis homo quidam amphoram aquæ portans: sequimini eum in domum, in quam intrat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Luke 22:11",
      "text": "et dicetis patrifamilias domus: Dicit tibi Magister: Ubi est diversorium, ubi pascha cum discipulis meis manducem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Luke 22:12",
      "text": "Et ipse ostendet vobis cœnaculum magnum stratum, et ibi parate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Luke 22:13",
      "text": "Euntes autem invenerunt sicut dixit illis, et paraverunt pascha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Luke 22:14",
      "text": "Et cum facta esset hora, discubuit, et duodecim apostoli cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Luke 22:15",
      "text": "Et ait illis: Desiderio desideravi hoc pascha manducare vobiscum, antequam patiar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Luke 22:16",
      "text": "Dico enim vobis, quia ex hoc non manducabo illud, donec impleatur in regno Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Luke 22:17",
      "text": "Et accepto calice gratias egit, et dixit: Accipite, et dividite inter vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Luke 22:18",
      "text": "Dico enim vobis quod non bibam de generatione vitis donec regnum Dei veniat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Luke 22:19",
      "text": "Et accepto pane gratias egit, et fregit, et dedit eis, dicens: Hoc est corpus meum, quod pro vobis datur: hoc facite in meam commemorationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Luke 22:20",
      "text": "Similiter et calicem, postquam cœnavit, dicens: Hic est calix novum testamentum in sanguine meo, qui pro vobis fundetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Luke 22:21",
      "text": "Verumtamen ecce manus tradentis me, mecum est in mensa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Luke 22:22",
      "text": "Et quidem Filius hominis, secundum quod definitum est, vadit: verumtamen væ homini illi per quem tradetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Luke 22:23",
      "text": "Et ipsi cœperunt quærere inter se quis esset ex eis qui hoc facturus esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Luke 22:24",
      "text": "Facta est autem et contentio inter eos, quis eorum videretur esse major.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Luke 22:25",
      "text": "Dixit autem eis: Reges gentium dominantur eorum: et qui potestatem habent super eos, benefici vocantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Luke 22:26",
      "text": "Vos autem non sic: sed qui major est in vobis, fiat sicut minor: et qui præcessor est, sicut ministrator.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Luke 22:27",
      "text": "Nam quis major est, qui recumbit, an qui ministrat? nonne qui recumbit? Ego autem in medio vestrum sum, sicut qui ministrat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Luke 22:28",
      "text": "vos autem estis, qui permansistis mecum in tentationibus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Luke 22:29",
      "text": "Et ego dispono vobis sicut disposuit mihi Pater meus regnum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Luke 22:30",
      "text": "ut edatis et bibatis super mensam meam in regno meo, et sedeatis super thronos judicantes duodecim tribus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Luke 22:31",
      "text": "Ait autem Dominus: Simon, Simon, ecce Satanas expetivit vos ut cribraret sicut triticum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Luke 22:32",
      "text": "ego autem rogavi pro te ut non deficiat fides tua: et tu aliquando conversus, confirma fratres tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Luke 22:33",
      "text": "Qui dixit ei: Domine, tecum paratus sum et in carcerem et in mortem ire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "Luke 22:34",
      "text": "At ille dixit: Dico tibi, Petre, non cantabit hodie gallus, donec ter abneges nosse me. Et dixit eis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "Luke 22:35",
      "text": "Quando misi vos sine sacculo, et pera, et calceamentis, numquid aliquid defuit vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "Luke 22:36",
      "text": "At illi dixerunt: Nihil. Dixit ergo eis: Sed nunc qui habet sacculum, tollat; similiter et peram: et qui non habet, vendat tunicam suam et emat gladium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "Luke 22:37",
      "text": "Dico enim vobis, quoniam adhuc hoc quod scriptum est, oportet impleri in me: Et cum iniquis deputatus est. Etenim ea quæ sunt de me finem habent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "Luke 22:38",
      "text": "At illi dixerunt: Domine, ecce duo gladii hic. At ille dixit eis: Satis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "Luke 22:39",
      "text": "Et egressus ibat secundum consuetudinem in monte Olivarum. Secuti sunt autem illum et discipuli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "Luke 22:40",
      "text": "Et cum pervenisset ad locum, dixit illis: Orate ne intretis in tentationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 41,
      "referenceLabel": "Luke 22:41",
      "text": "Et ipse avulsus est ab eis quantum jactus est lapidis: et positis genibus orabat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 42,
      "referenceLabel": "Luke 22:42",
      "text": "dicens: Pater, si vis, transfer calicem istum a me: verumtamen non mea voluntas, sed tua fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 43,
      "referenceLabel": "Luke 22:43",
      "text": "Apparuit autem illi angelus de cælo, confortans eum. Et factus in agonia, prolixius orabat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 44,
      "referenceLabel": "Luke 22:44",
      "text": "Et factus est sudor ejus sicut guttæ sanguinis decurrentis in terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 45,
      "referenceLabel": "Luke 22:45",
      "text": "Et cum surrexisset ab oratione et venisset ad discipulos suos, invenit eos dormientes præ tristitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 46,
      "referenceLabel": "Luke 22:46",
      "text": "Et ait illis: Quid dormitis? surgite, orate, ne intretis in tentationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 47,
      "referenceLabel": "Luke 22:47",
      "text": "Adhuc eo loquente, ecce turba: et qui vocabatur Judas, unus de duodecim, antecedebat eos, et appropinquavit Jesu ut oscularetur eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 48,
      "referenceLabel": "Luke 22:48",
      "text": "Jesus autem dixit illi: Juda, osculo Filium hominis tradis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.49",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 49,
      "referenceLabel": "Luke 22:49",
      "text": "Videntes autem hi qui circa ipsum erant, quod futurum erat, dixerunt ei: Domine, si percutimus in gladio?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.50",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 50,
      "referenceLabel": "Luke 22:50",
      "text": "Et percussit unus ex illis servum principis sacerdotum, et amputavit auriculam ejus dexteram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.51",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 51,
      "referenceLabel": "Luke 22:51",
      "text": "Respondens autem Jesus, ait: Sinite usque huc. Et cum tetigisset auriculam ejus, sanavit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.52",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 52,
      "referenceLabel": "Luke 22:52",
      "text": "Dixit autem Jesus ad eos qui venerant ad se principes sacerdotum, et magistratus templi, et seniores: Quasi ad latronem existis cum gladiis et fustibus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.53",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 53,
      "referenceLabel": "Luke 22:53",
      "text": "Cum quotidie vobiscum fuerim in templo, non extendistis manus in me: sed hæc est hora vestra, et potestas tenebrarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.54",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 54,
      "referenceLabel": "Luke 22:54",
      "text": "Comprehendentes autem eum, duxerunt ad domum principis sacerdotum: Petrus vero sequebatur a longe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.55",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 55,
      "referenceLabel": "Luke 22:55",
      "text": "Accenso autem igne in medio atrii et circumsedentibus illis, erat Petrus in medio eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.56",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 56,
      "referenceLabel": "Luke 22:56",
      "text": "Quem cum vidisset ancilla quædam sedentem ad lumen, et eum fuisset intuita, dixit: Et hic cum illo erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.57",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 57,
      "referenceLabel": "Luke 22:57",
      "text": "At ille negavit eum, dicens: Mulier, non novi illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.58",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 58,
      "referenceLabel": "Luke 22:58",
      "text": "Et post pusillum alius videns eum, dixit: Et tu de illis es. Petrus vero ait: O homo, non sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.59",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 59,
      "referenceLabel": "Luke 22:59",
      "text": "Et intervallo facto quasi horæ unius, alius quidam affirmabat, dicens: Vere et hic cum illo erat: nam et Galilæus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.60",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 60,
      "referenceLabel": "Luke 22:60",
      "text": "Et ait Petrus: Homo, nescio quid dicis. Et continuo, adhuc illo loquente, cantavit gallus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.61",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 61,
      "referenceLabel": "Luke 22:61",
      "text": "Et conversus Dominus respexit Petrum, et recordatus est Petrus verbi Domini, sicut dixerat: Quia priusquam gallus cantet, ter me negabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.62",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 62,
      "referenceLabel": "Luke 22:62",
      "text": "Et egressus foras Petrus flevit amare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.22.63",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 22,
      "verseNumber": 63,
      "referenceLabel": "Luke 22:63",
      "text": "Et viri qui tenebant illum, illudebant ei, cædentes.",
      "paragraphStart": false
    },
    {
