{
  "chapter": {
    "id": "vulgate:luke.20",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 20,
    "referenceLabel": "Luke 20",
    "summary": "Source text for Luke 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.20.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Luke 20:1",
      "text": "Et factum est in una dierum, docente illo populum in templo, et evangelizante, convenerunt principes sacerdotum, et scribæ cum senioribus,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.20.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Luke 20:2",
      "text": "et aiunt dicentes ad illum: Dic nobis in qua potestate hæc facis? aut quis est qui dedit tibi hanc potestatem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Luke 20:3",
      "text": "Respondens autem Jesus, dixit ad illos: Interrogabo vos et ego unum verbum. Respondete mihi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Luke 20:4",
      "text": "baptismus Joannis de cælo erat, an ex hominibus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Luke 20:5",
      "text": "At illi cogitabant intra se, dicentes: Quia si dixerimus: De cælo, dicet: Quare ergo non credidistis illi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Luke 20:6",
      "text": "Si autem dixerimus: Ex hominibus, plebs universa lapidabit nos: certi sunt enim Joannem prophetam esse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Luke 20:7",
      "text": "Et responderunt se nescire unde esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Luke 20:8",
      "text": "Et Jesus ait illis: Neque ego dico vobis in qua potestate hæc facio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Luke 20:9",
      "text": "Cœpit autem dicere ad plebem parabolam hanc: Homo plantavit vineam, et locavit eam colonis: et ipse peregre fuit multis temporibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Luke 20:10",
      "text": "Et in tempore misit ad cultores servum, ut de fructu vineæ darent illi. Qui cæsum dimiserunt eum inanem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Luke 20:11",
      "text": "Et addidit alterum servum mittere. Illi autem hunc quoque cædentes, et afficientes contumelia, dimiserunt inanem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Luke 20:12",
      "text": "Et addidit tertium mittere: qui et illum vulnerantes ejecerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Luke 20:13",
      "text": "Dixit autem dominus vineæ: Quid faciam? Mittam filium meum dilectum: forsitan, cum hunc viderint, verebuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Luke 20:14",
      "text": "Quem cum vidissent coloni, cogitaverunt intra se, dicentes: Hic est hæres, occidamus illum, ut nostra fiat hæreditas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Luke 20:15",
      "text": "Et ejectum illum extra vineam, occiderunt. Quid ergo faciet illis dominus vineæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Luke 20:16",
      "text": "veniet, et perdet colonos istos, et dabit vineam aliis. Quo audito, dixerunt illi: Absit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Luke 20:17",
      "text": "Ille autem aspiciens eos, ait: Quid est ergo hoc quod scriptum est: Lapidem quem reprobaverunt ædificantes, hic factus est in caput anguli?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Luke 20:18",
      "text": "Omnis qui ceciderit super illum lapidem, conquassabitur: super quem autem ceciderit, comminuet illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Luke 20:19",
      "text": "Et quærebant principes sacerdotum et scribæ mittere in illum manus illa hora, et timuerunt populum: cognoverunt enim quod ad ipsos dixerit similitudinem hanc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Luke 20:20",
      "text": "Et observantes miserunt insidiatores, qui se justos simularent, ut caperent eum in sermone, ut traderent illum principatui, et potestati præsidis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Luke 20:21",
      "text": "Et interrogaverunt eum, dicentes: Magister, scimus quia recte dicis et doces: et non accipis personam, sed viam Dei in veritate doces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Luke 20:22",
      "text": "Licet nobis tributum dare Cæsari, an non?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Luke 20:23",
      "text": "Considerans autem dolum illorum, dixit ad eos: Quid me tentatis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Luke 20:24",
      "text": "ostendite mihi denarium. Cujus habet imaginem et inscriptionem? Respondentes dixerunt ei: Cæsaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Luke 20:25",
      "text": "Et ait illis: Reddite ergo quæ sunt Cæsaris, Cæsari: et quæ sunt Dei, Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Luke 20:26",
      "text": "Et non potuerunt verbum ejus reprehendere coram plebe: et mirati in responso ejus, tacuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Luke 20:27",
      "text": "Accesserunt autem quidam sadducæorum, qui negant esse resurrectionem, et interrogaverunt eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Luke 20:28",
      "text": "dicentes: Magister, Moyses scripsit nobis: Si frater alicujus mortuus fuerit habens uxorem, et hic sine liberis fuerit, ut accipiat eam frater ejus uxorem, et suscitet semen fratri suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Luke 20:29",
      "text": "Septem ergo fratres erant: et primus accepit uxorem, et mortuus est sine filiis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Luke 20:30",
      "text": "Et sequens accepit illam, et ipse mortuus est sine filio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Luke 20:31",
      "text": "Et tertius accepit illam. Similiter et omnes septem, et non reliquerunt semen, et mortui sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Luke 20:32",
      "text": "Novissime omnium mortua est et mulier.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Luke 20:33",
      "text": "In resurrectione ergo, cujus eorum erit uxor? siquidem septem habuerunt eam uxorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 34,
      "referenceLabel": "Luke 20:34",
      "text": "Et ait illis Jesus: Filii hujus sæculi nubunt, et traduntur ad nuptias:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 35,
      "referenceLabel": "Luke 20:35",
      "text": "illi vero qui digni habebuntur sæculo illo, et resurrectione ex mortuis, neque nubent, neque ducent uxores:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 36,
      "referenceLabel": "Luke 20:36",
      "text": "neque enim ultra mori potuerunt: æquales enim angelis sunt, et filii sunt Dei, cum sint filii resurrectionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 37,
      "referenceLabel": "Luke 20:37",
      "text": "Quia vero resurgant mortui, et Moyses ostendit secus rubum, sicut dicit Dominum, Deum Abraham, et Deum Isaac, et Deum Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 38,
      "referenceLabel": "Luke 20:38",
      "text": "Deus autem non est mortuorum, sed vivorum: omnes enim vivunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 39,
      "referenceLabel": "Luke 20:39",
      "text": "Respondentes autem quidam scribarum, dixerunt ei: Magister, bene dixisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 40,
      "referenceLabel": "Luke 20:40",
      "text": "Et amplius non audebant eum quidquam interrogare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 41,
      "referenceLabel": "Luke 20:41",
      "text": "Dixit autem ad illos: Quomodo dicunt Christum filium esse David?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 42,
      "referenceLabel": "Luke 20:42",
      "text": "et ipse David dicit in libro Psalmorum: Dixit Dominus Domino meo: sede a dextris meis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 43,
      "referenceLabel": "Luke 20:43",
      "text": "donec ponam inimicos tuos scabellum pedum tuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 44,
      "referenceLabel": "Luke 20:44",
      "text": "David ergo Dominum illum vocat: et quomodo filius ejus est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 45,
      "referenceLabel": "Luke 20:45",
      "text": "Audiente autem omni populo, dixit discipulis suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 46,
      "referenceLabel": "Luke 20:46",
      "text": "Attendite a scribis, qui volunt ambulare in stolis, et amant salutationes in foro, et primas cathedras in synagogis, et primos discubitus in conviviis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.20.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 20,
      "verseNumber": 47,
      "referenceLabel": "Luke 20:47",
      "text": "qui devorant domos viduarum, simulantes longam orationem: hi accipient damnationem majorem.",
      "paragraphStart": false
    }
  ]
}
