{
  "chapter": {
    "id": "vulgate:luke.3",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 3,
    "referenceLabel": "Luke 3",
    "summary": "Source text for Luke 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.3.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Luke 3:1",
      "text": "Anno autem quintodecimo imperii Tiberii Cæsaris, procurante Pontio Pilato Judæam, tetrarcha autem Galilææ Herode, Philippo autem fratre ejus tetrarcha Iturææ, et Trachonitidis regionis, et Lysania Abilinæ tetrarcha,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.3.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Luke 3:2",
      "text": "sub principibus sacerdotum Anna et Caipha: factum est verbum Domini super Joannem, Zachariæ filium, in deserto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Luke 3:3",
      "text": "Et venit in omnem regionem Jordanis, prædicans baptismum pœnitentiæ in remissionem peccatorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Luke 3:4",
      "text": "sicut scriptum est in libro sermonum Isaiæ prophetæ: Vox clamantis in deserto: Parate viam Domini; rectas facite semitas ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Luke 3:5",
      "text": "omnis vallis implebitur, et omnis mons, et collis humiliabitur: et erunt prava in directa, et aspera in vias planas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Luke 3:6",
      "text": "et videbit omnis caro salutare Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Luke 3:7",
      "text": "Dicebat ergo ad turbas quæ exibant ut baptizarentur ab ipso: Genimina viperarum, quis ostendit vobis fugere a ventura ira?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Luke 3:8",
      "text": "Facite ergo fructus dignos pœnitentiæ, et ne cœperitis dicere: Patrem habemus Abraham. Dico enim vobis quia potens est Deus de lapidibus istis suscitare filios Abrahæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Luke 3:9",
      "text": "Jam enim securis ad radicem arborum posita est. Omnis ergo arbor non faciens fructum bonum, excidetur, et in ignem mittetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Luke 3:10",
      "text": "Et interrogabant eum turbæ, dicentes: Quid ergo faciemus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Luke 3:11",
      "text": "Respondens autem dicebat illis: Qui habet duas tunicas, det non habenti: et qui habet escas, similiter faciat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Luke 3:12",
      "text": "Venerunt autem et publicani ut baptizarentur, et dixerunt ad illum: Magister, quid faciemus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Luke 3:13",
      "text": "At ille dixit ad eos: Nihil amplius, quam quod constitutum est vobis, faciatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Luke 3:14",
      "text": "Interrogabant autem eum et milites, dicentes: Quid faciemus et nos? Et ait illis: Neminem concutiatis, neque calumniam faciatis: et contenti estote stipendiis vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Luke 3:15",
      "text": "Existimante autem populo, et cogitantibus omnibus in cordibus suis de Joanne, ne forte ipse esset Christus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Luke 3:16",
      "text": "respondit Joannes, dicens omnibus: Ego quidem aqua baptizo vos: veniet autem fortior me, cujus non sum dignus solvere corrigiam calceamentorum ejus: ipse vos baptizabit in Spiritu Sancto et igni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Luke 3:17",
      "text": "cujus ventilabrum in manu ejus, et purgabit aream suam, et congregabit triticum in horreum suum, paleas autem comburet igni inextinguibili.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Luke 3:18",
      "text": "Multa quidem et alia exhortans evangelizabat populo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Luke 3:19",
      "text": "Herodes autem tetrarcha cum corriperetur ab illo de Herodiade uxore fratris sui, et de omnibus malis quæ fecit Herodes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Luke 3:20",
      "text": "adjecit et hoc super omnia, et inclusit Joannem in carcere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Luke 3:21",
      "text": "Factum est autem cum baptizaretur omnis populus, et Jesu baptizato, et orante, apertum est cælum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Luke 3:22",
      "text": "et descendit Spiritus Sanctus corporali specie sicut columba in ipsum: et vox de cælo facta est: Tu es filius meus dilectus, in te complacui mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Luke 3:23",
      "text": "Et ipse Jesus erat incipiens quasi annorum triginta, ut putabatur, filius Joseph, qui fuit Heli, qui fuit Mathat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Luke 3:24",
      "text": "qui fuit Levi, qui fuit Melchi, qui fuit Janne, qui fuit Joseph,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Luke 3:25",
      "text": "qui fuit Mathathiæ, qui fuit Amos, qui fuit Nahum, qui fuit Hesli, qui fuit Nagge,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Luke 3:26",
      "text": "qui fuit Mahath, qui fuit Mathathiæ, qui fuit Semei, qui fuit Joseph, qui fuit Juda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Luke 3:27",
      "text": "qui fuit Joanna, qui fuit Resa, qui fuit Zorobabel, qui fuit Salathiel, qui fuit Neri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Luke 3:28",
      "text": "qui fuit Melchi, qui fuit Addi, qui fuit Cosan, qui fuit Elmadan, qui fuit Her,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Luke 3:29",
      "text": "qui fuit Jesu, qui fuit Eliezer, qui fuit Jorim, qui fuit Mathat, qui fuit Levi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Luke 3:30",
      "text": "qui fuit Simeon, qui fuit Juda, qui fuit Joseph, qui fuit Jona, qui fuit Eliakim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Luke 3:31",
      "text": "qui fuit Melea, qui fuit Menna, qui fuit Mathatha, qui fuit Natham, qui fuit David,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Luke 3:32",
      "text": "qui fuit Jesse, qui fuit Obed, qui fuit Booz, qui fuit Salmon, qui fuit Naasson,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Luke 3:33",
      "text": "qui fuit Aminadab, qui fuit Aram, qui fuit Esron, qui fuit Phares, qui fuit Judæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Luke 3:34",
      "text": "qui fuit Jacob, qui fuit Isaac, qui fuit Abrahæ, qui fuit Thare, qui fuit Nachor,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Luke 3:35",
      "text": "qui fuit Sarug, qui fuit Ragau, qui fuit Phaleg, qui fuit Heber, qui fuit Sale,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Luke 3:36",
      "text": "qui fuit Cainan, qui fuit Arphaxad, qui fuit Sem, qui fuit Noë, qui fuit Lamech,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Luke 3:37",
      "text": "qui fuit Methusale, qui fuit Henoch, qui fuit Jared, qui fuit Malaleel, qui fuit Cainan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.3.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Luke 3:38",
      "text": "qui fuit Henos, qui fuit Seth, qui fuit Adam, qui fuit Dei.",
      "paragraphStart": false
    }
  ]
}
