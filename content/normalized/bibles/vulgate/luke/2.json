{
  "chapter": {
    "id": "vulgate:luke.2",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 2,
    "referenceLabel": "Luke 2",
    "summary": "Source text for Luke 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.2.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Luke 2:1",
      "text": "Factum est autem in diebus illis, exiit edictum a Cæsare Augusto ut describeretur universus orbis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.2.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Luke 2:2",
      "text": "Hæc descriptio prima facta est a præside Syriæ Cyrino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Luke 2:3",
      "text": "et ibant omnes ut profiterentur singuli in suam civitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Luke 2:4",
      "text": "Ascendit autem et Joseph a Galilæa de civitate Nazareth in Judæam, in civitatem David, quæ vocatur Bethlehem: eo quod esset de domo et familia David,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Luke 2:5",
      "text": "ut profiteretur cum Maria desponsata sibi uxore prægnante.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Luke 2:6",
      "text": "Factum est autem, cum essent ibi, impleti sunt dies ut pareret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Luke 2:7",
      "text": "Et peperit filium suum primogenitum, et pannis eum involvit, et reclinavit eum in præsepio: quia non erat eis locus in diversorio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Luke 2:8",
      "text": "Et pastores erant in regione eadem vigilantes, et custodientes vigilias noctis super gregem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Luke 2:9",
      "text": "Et ecce angelus Domini stetit juxta illos, et claritas Dei circumfulsit illos, et timuerunt timore magno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Luke 2:10",
      "text": "Et dixit illis angelus: Nolite timere: ecce enim evangelizo vobis gaudium magnum, quod erit omni populo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Luke 2:11",
      "text": "quia natus est vobis hodie Salvator, qui est Christus Dominus, in civitate David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Luke 2:12",
      "text": "Et hoc vobis signum: invenietis infantem pannis involutum, et positum in præsepio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Luke 2:13",
      "text": "Et subito facta est cum angelo multitudo militiæ cælestis laudantium Deum, et dicentium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Luke 2:14",
      "text": "Gloria in altissimis Deo, et in terra pax hominibus bonæ voluntatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Luke 2:15",
      "text": "Et factum est, ut discesserunt ab eis angeli in cælum: pastores loquebantur ad invicem: Transeamus usque Bethlehem, et videamus hoc verbum, quod factum est, quod Dominus ostendit nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Luke 2:16",
      "text": "Et venerunt festinantes: et invenerunt Mariam, et Joseph, et infantem positum in præsepio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Luke 2:17",
      "text": "Videntes autem cognoverunt de verbo, quod dictum erat illis de puero hoc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Luke 2:18",
      "text": "Et omnes qui audierunt, mirati sunt: et de his quæ dicta erant a pastoribus ad ipsos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Luke 2:19",
      "text": "Maria autem conservabat omnia verba hæc, conferens in corde suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Luke 2:20",
      "text": "Et reversi sunt pastores glorificantes et laudantes Deum in omnibus quæ audierant et viderant, sicut dictum est ad illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Luke 2:21",
      "text": "Et postquam consummati sunt dies octo, ut circumcideretur puer, vocatum est nomen ejus Jesus, quod vocatum est ab angelo priusquam in utero conciperetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Luke 2:22",
      "text": "Et postquam impleti sunt dies purgationis ejus secundum legem Moysi, tulerunt illum in Jerusalem, ut sisterent eum Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Luke 2:23",
      "text": "sicut scriptum est in lege Domini: Quia omne masculinum adaperiens vulvam, sanctum Domino vocabitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Luke 2:24",
      "text": "et ut darent hostiam secundum quod dictum est in lege Domini, par turturum, aut duos pullos columbarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Luke 2:25",
      "text": "Et ecce homo erat in Jerusalem, cui nomen Simeon, et homo iste justus, et timoratus, exspectans consolationem Israël: et Spiritus Sanctus erat in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Luke 2:26",
      "text": "Et responsum acceperat a Spiritu Sancto, non visurum se mortem, nisi prius videret Christum Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Luke 2:27",
      "text": "Et venit in spiritu in templum. Et cum inducerent puerum Jesum parentes ejus, ut facerent secundum consuetudinem legis pro eo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Luke 2:28",
      "text": "et ipse accepit eum in ulnas suas: et benedixit Deum, et dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Luke 2:29",
      "text": "Nunc dimittis servum tuum Domine, secundum verbum tuum in pace:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Luke 2:30",
      "text": "quia viderunt oculi mei salutare tuum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Luke 2:31",
      "text": "quod parasti ante faciem omnium populorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Luke 2:32",
      "text": "lumen ad revelationem gentium, et gloriam plebis tuæ Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Luke 2:33",
      "text": "Et erat pater ejus et mater mirantes super his quæ dicebantur de illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Luke 2:34",
      "text": "Et benedixit illis Simeon, et dixit ad Mariam matrem ejus: Ecce positus est hic in ruinam et in resurrectionem multorum in Israël, et in signum cui contradicetur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Luke 2:35",
      "text": "et tuam ipsius animam pertransibit gladius ut revelentur ex multis cordibus cogitationes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Luke 2:36",
      "text": "Et erat Anna prophetissa, filia Phanuel, de tribu Aser: hæc processerat in diebus multis, et vixerat cum viro suo annis septem a virginitate sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Luke 2:37",
      "text": "Et hæc vidua usque ad annos octoginta quatuor: quæ non discedebat de templo, jejuniis et obsecrationibus serviens nocte ac die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Luke 2:38",
      "text": "Et hæc, ipsa hora superveniens, confitebatur Domino: et loquebatur de illo omnibus, qui exspectabant redemptionem Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Luke 2:39",
      "text": "Et ut perfecerunt omnia secundum legem Domini, reversi sunt in Galilæam in civitatem suam Nazareth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Luke 2:40",
      "text": "Puer autem crescebat, et confortabatur plenus sapientia: et gratia Dei erat in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Luke 2:41",
      "text": "Et ibant parentes ejus per omnes annos in Jerusalem, in die solemni Paschæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Luke 2:42",
      "text": "Et cum factus esset annorum duodecim, ascendentibus illis Jerosolymam secundum consuetudinem diei festi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Luke 2:43",
      "text": "consummatisque diebus, cum redirent, remansit puer Jesus in Jerusalem, et non cognoverunt parentes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Luke 2:44",
      "text": "Existimantes autem illum esse in comitatu, venerunt iter diei, et requirebant eum inter cognatos et notos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Luke 2:45",
      "text": "Et non invenientes, regressi sunt in Jerusalem, requirentes eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Luke 2:46",
      "text": "Et factum est, post triduum invenerunt illum in templo sedentem in medio doctorum, audientem illos, et interrogantem eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Luke 2:47",
      "text": "Stupebant autem omnes qui eum audiebant, super prudentia et responsis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Luke 2:48",
      "text": "Et videntes admirati sunt. Et dixit mater ejus ad illum: Fili, quid fecisti nobis sic? ecce pater tuus et ego dolentes quærebamus te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.49",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Luke 2:49",
      "text": "Et ait ad illos: Quid est quod me quærebatis? nesciebatis quia in his quæ Patris mei sunt, oportet me esse?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.50",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Luke 2:50",
      "text": "Et ipsi non intellexerunt verbum quod locutus est ad eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.51",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Luke 2:51",
      "text": "Et descendit cum eis, et venit Nazareth: et erat subditus illis. Et mater ejus conservabat omnia verba hæc in corde suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.2.52",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Luke 2:52",
      "text": "Et Jesus proficiebat sapientia, et ætate, et gratia apud Deum et homines.",
      "paragraphStart": false
    }
  ]
}
