{
  "chapter": {
    "id": "vulgate:luke.21",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 21,
    "referenceLabel": "Luke 21",
    "summary": "Source text for Luke 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.21.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Luke 21:1",
      "text": "Respiciens autem, vidit eos qui mittebant munera sua in gazophylacium, divites.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.21.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Luke 21:2",
      "text": "Vidit autem et quamdam viduam pauperculam mittentem æra minuta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Luke 21:3",
      "text": "Et dixit: Vere dico vobis, quia vidua hæc pauper plus quam omnes misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Luke 21:4",
      "text": "Nam omnes hi ex abundanti sibi miserunt in munera Dei: hæc autem ex eo quod deest illi, omnem victum suum quem habuit, misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Luke 21:5",
      "text": "Et quibusdam dicentibus de templo quod bonis lapidibus et donis ornatum esset, dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Luke 21:6",
      "text": "Hæc quæ videtis, venient dies in quibus non relinquetur lapis super lapidem, qui non destruatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Luke 21:7",
      "text": "Interrogaverunt autem illum, dicentes: Præceptor, quando hæc erunt, et quod signum cum fieri incipient?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Luke 21:8",
      "text": "Qui dixit: Videte ne seducamini: multi enim venient in nomine meo, dicentes quia ego sum: et tempus appropinquavit: nolite ergo ire post eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Luke 21:9",
      "text": "Cum autem audieritis prælia et seditiones, nolite terreri: oportet primum hæc fieri, sed nondum statim finis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Luke 21:10",
      "text": "Tunc dicebat illis: Surget gens contra gentem, et regnum adversus regnum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Luke 21:11",
      "text": "Et terræmotus magni erunt per loca, et pestilentiæ, et fames, terroresque de cælo, et signa magna erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Luke 21:12",
      "text": "Sed ante hæc omnia injicient vobis manus suas, et persequentur tradentes in synagogas et custodias, trahentes ad reges et præsides propter nomen meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Luke 21:13",
      "text": "continget autem vobis in testimonium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Luke 21:14",
      "text": "Ponite ergo in cordibus vestris non præmeditari quemadmodum respondeatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Luke 21:15",
      "text": "ego enim dabo vobis os et sapientiam, cui non poterunt resistere et contradicere omnes adversarii vestri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Luke 21:16",
      "text": "Trademini autem a parentibus, et fratribus, et cognatis, et amicis, et morte afficient ex vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Luke 21:17",
      "text": "et eritis odio omnibus propter nomen meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Luke 21:18",
      "text": "et capillus de capite vestro non peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Luke 21:19",
      "text": "In patientia vestra possidebitis animas vestras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Luke 21:20",
      "text": "Cum autem videritis circumdari ab exercitu Jerusalem, tunc scitote quia appropinquavit desolatio ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Luke 21:21",
      "text": "tunc qui in Judæa sunt, fugiant ad montes, et qui in medio ejus, discedant: et qui in regionibus, non intrent in eam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Luke 21:22",
      "text": "quia dies ultionis hi sunt, ut impleantur omnia quæ scripta sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Luke 21:23",
      "text": "Væ autem prægnantibus et nutrientibus in illis diebus! erit enim pressura magna super terram, et ira populo huic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Luke 21:24",
      "text": "Et cadent in ore gladii, et captivi ducentur in omnes gentes, et Jerusalem calcabitur a gentibus, donec impleantur tempora nationum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Luke 21:25",
      "text": "Et erunt signa in sole, et luna, et stellis, et in terris pressura gentium præ confusione sonitus maris, et fluctuum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Luke 21:26",
      "text": "arescentibus hominibus præ timore, et exspectatione, quæ supervenient universo orbi: nam virtutes cælorum movebuntur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Luke 21:27",
      "text": "et tunc videbunt Filium hominis venientem in nube cum potestate magna et majestate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Luke 21:28",
      "text": "His autem fieri incipientibus, respicite, et levate capita vestra: quoniam appropinquat redemptio vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Luke 21:29",
      "text": "Et dixit illis similitudinem: Videte ficulneam, et omnes arbores:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Luke 21:30",
      "text": "cum producunt jam ex se fructum, scitis quoniam prope est æstas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Luke 21:31",
      "text": "Ita et vos cum videritis hæc fieri, scitote quoniam prope est regnum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Luke 21:32",
      "text": "Amen dico vobis, quia non præteribit generatio hæc, donec omnia fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Luke 21:33",
      "text": "Cælum et terra transibunt: verba autem mea non transibunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Luke 21:34",
      "text": "Attendite autem vobis, ne forte graventur corda vestra in crapula, et ebrietate, et curis hujus vitæ, et superveniat in vos repentina dies illa:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 35,
      "referenceLabel": "Luke 21:35",
      "text": "tamquam laqueus enim superveniet in omnes qui sedent super faciem omnis terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 36,
      "referenceLabel": "Luke 21:36",
      "text": "Vigilate itaque, omni tempore orantes, ut digni habeamini fugere ista omnia quæ futura sunt, et stare ante Filium hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 37,
      "referenceLabel": "Luke 21:37",
      "text": "Erat autem diebus docens in templo: noctibus vero exiens, morabatur in monte qui vocatur Oliveti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.21.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 21,
      "verseNumber": 38,
      "referenceLabel": "Luke 21:38",
      "text": "Et omnis populus manicabat ad eum in templo audire eum.",
      "paragraphStart": false
    }
  ]
}
