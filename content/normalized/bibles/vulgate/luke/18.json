{
  "chapter": {
    "id": "vulgate:luke.18",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 18,
    "referenceLabel": "Luke 18",
    "summary": "Source text for Luke 18 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.18.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Luke 18:1",
      "text": "Dicebat autem et parabolam ad illos, quoniam oportet semper orare et non deficere,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.18.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Luke 18:2",
      "text": "dicens: Judex quidam erat in quadam civitate, qui Deum non timebat, et hominem non reverebatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Luke 18:3",
      "text": "Vidua autem quædam erat in civitate illa, et veniebat ad eum, dicens: Vindica me de adversario meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Luke 18:4",
      "text": "Et nolebat per multum tempus. Post hæc autem dixit intra se: Etsi Deum non timeo, nec hominem revereor:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Luke 18:5",
      "text": "tamen quia molesta est mihi hæc vidua, vindicabo illam, ne in novissimo veniens sugillet me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Luke 18:6",
      "text": "Ait autem Dominus: Audite quid judex iniquitatis dicit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Luke 18:7",
      "text": "Deus autem non faciet vindictam electorum suorum clamantium ad se die ac nocte, et patientiam habebit in illis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Luke 18:8",
      "text": "Dico vobis quia cito faciet vindictam illorum. Verumtamen Filius hominis veniens, putas, inveniet fidem in terra?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Luke 18:9",
      "text": "Dixit autem et ad quosdam qui in se confidebant tamquam justi, et aspernabantur ceteros, parabolam istam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Luke 18:10",
      "text": "Duo homines ascenderunt in templum ut orarent: unus pharisæus et alter publicanus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Luke 18:11",
      "text": "Pharisæus stans, hæc apud se orabat: Deus, gratias ago tibi, quia non sum sicut ceteri hominum: raptores, injusti, adulteri, velut etiam hic publicanus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Luke 18:12",
      "text": "jejuno bis in sabbato, decimas do omnium quæ possideo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Luke 18:13",
      "text": "Et publicanus a longe stans, nolebat nec oculos ad cælum levare: sed percutiebat pectus suum, dicens: Deus propitius esto mihi peccatori.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Luke 18:14",
      "text": "Dico vobis, descendit hic justificatus in domum suam ab illo: quia omnis qui se exaltat, humiliabitur, et qui se humiliat, exaltabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Luke 18:15",
      "text": "Afferebant autem ad illum et infantes, ut eos tangeret. Quod cum viderent discipuli, increpabant illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Luke 18:16",
      "text": "Jesus autem convocans illos, dixit: Sinite pueros venire ad me, et nolite vetare eos: talium est enim regnum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Luke 18:17",
      "text": "Amen dico vobis, quicumque non acceperit regnum Dei sicut puer, non intrabit in illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Luke 18:18",
      "text": "Et interrogavit eum quidam princeps, dicens: Magister bone, quid faciens vitam æternam possidebo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Luke 18:19",
      "text": "Dixit autem ei Jesus: Quid me dicis bonum? nemo bonus nisi solus Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Luke 18:20",
      "text": "Mandata nosti: non occides; non mœchaberis; non furtum facies; non falsum testimonium dices; honora patrem tuum et matrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Luke 18:21",
      "text": "Qui ait: Hæc omnia custodivi a juventute mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Luke 18:22",
      "text": "Quo audito, Jesus ait ei: Adhuc unum tibi deest: omnia quæcumque habes vende, et da pauperibus, et habebis thesaurum in cælo: et veni, sequere me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Luke 18:23",
      "text": "His ille auditis, contristatus est: quia dives erat valde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Luke 18:24",
      "text": "Videns autem Jesus illum tristem factum, dixit: Quam difficile, qui pecunias habent, in regnum Dei intrabunt!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Luke 18:25",
      "text": "facilius est enim camelum per foramen acus transire quam divitem intrare in regnum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "Luke 18:26",
      "text": "Et dixerunt qui audiebant: Et quis potest salvus fieri?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "Luke 18:27",
      "text": "Ait illis: Quæ impossibilia sunt apud homines, possibilia sunt apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "Luke 18:28",
      "text": "Ait autem Petrus: Ecce nos dimisimus omnia et secuti sumus te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 29,
      "referenceLabel": "Luke 18:29",
      "text": "Qui dixit eis: Amen dico vobis, nemo est qui reliquit domum, aut parentes, aut fratres, aut uxorem, aut filios propter regnum Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 30,
      "referenceLabel": "Luke 18:30",
      "text": "et non recipiat multo plura in hoc tempore, et in sæculo venturo vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 31,
      "referenceLabel": "Luke 18:31",
      "text": "Assumpsit autem Jesus duodecim, et ait illis: Ecce ascendimus Jerosolymam, et consummabuntur omnia quæ scripta sunt per prophetas de Filio hominis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 32,
      "referenceLabel": "Luke 18:32",
      "text": "tradetur enim gentibus, et illudetur, et flagellabitur, et conspuetur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 33,
      "referenceLabel": "Luke 18:33",
      "text": "et postquam flagellaverint, occident eum, et tertia die resurget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 34,
      "referenceLabel": "Luke 18:34",
      "text": "Et ipsi nihil horum intellexerunt, et erat verbum istud absconditum ab eis, et non intelligebant quæ dicebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 35,
      "referenceLabel": "Luke 18:35",
      "text": "Factum est autem, cum appropinquaret Jericho, cæcus quidam sedebat secus viam, mendicans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 36,
      "referenceLabel": "Luke 18:36",
      "text": "Et cum audiret turbam prætereuntem, interrogabat quid hoc esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 37,
      "referenceLabel": "Luke 18:37",
      "text": "Dixerunt autem ei quod Jesus Nazarenus transiret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 38,
      "referenceLabel": "Luke 18:38",
      "text": "Et clamavit, dicens: Jesu, fili David, miserere mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 39,
      "referenceLabel": "Luke 18:39",
      "text": "Et qui præibant, increpabant eum ut taceret. Ipse vero multo magis clamabat: Fili David, miserere mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 40,
      "referenceLabel": "Luke 18:40",
      "text": "Stans autem Jesus jussit illum adduci ad se. Et cum appropinquasset, interrogavit illum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 41,
      "referenceLabel": "Luke 18:41",
      "text": "dicens: Quid tibi vis faciam? At ille dixit: Domine, ut videam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 42,
      "referenceLabel": "Luke 18:42",
      "text": "Et Jesus dixit illi: Respice, fides tua te salvum fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.18.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 18,
      "verseNumber": 43,
      "referenceLabel": "Luke 18:43",
      "text": "Et confestim vidit, et sequebatur illum magnificans Deum. Et omnis plebs ut vidit, dedit laudem Deo.",
      "paragraphStart": false
    }
  ]
}
