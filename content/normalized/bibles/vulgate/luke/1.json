{
  "chapter": {
    "id": "vulgate:luke.1",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 1,
    "referenceLabel": "Luke 1",
    "summary": "Source text for Luke 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.1.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Luke 1:1",
      "text": "Quoniam quidem multi conati sunt ordinare narrationem, quæ in nobis completæ sunt, rerum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.1.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Luke 1:2",
      "text": "sicut tradiderunt nobis, qui ab initio ipsi viderunt, et ministri fuerunt sermonis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Luke 1:3",
      "text": "visum est et mihi, assecuto omnia a principio diligenter, ex ordine tibi scribere, optime Theophile,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Luke 1:4",
      "text": "ut cognoscas eorum verborum, de quibus eruditus es, veritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Luke 1:5",
      "text": "Fuit in diebus Herodis, regis Judææ, sacerdos quidam nomine Zacharias de vice Abia, et uxor illius de filiabus Aaron, et nomen ejus Elisabeth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Luke 1:6",
      "text": "Erant autem justi ambo ante Deum, incedentes in omnibus mandatis et justificationibus Domini sine querela.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Luke 1:7",
      "text": "Et non erat illis filius, eo quod esset Elisabeth sterilis, et ambo processissent in diebus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Luke 1:8",
      "text": "Factum est autem, cum sacerdotio fungeretur in ordine vicis suæ ante Deum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Luke 1:9",
      "text": "secundum consuetudinem sacerdotii, sorte exiit ut incensum poneret, ingressus in templum Domini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Luke 1:10",
      "text": "et omnis multitudo populi erat orans foris hora incensi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Luke 1:11",
      "text": "Apparuit autem illi angelus Domini, stans a dextris altaris incensi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Luke 1:12",
      "text": "Et Zacharias turbatus est videns, et timor irruit super eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Luke 1:13",
      "text": "Ait autem ad illum angelus: Ne timeas, Zacharia, quoniam exaudita est deprecatio tua: et uxor tua Elisabeth pariet tibi filium, et vocabis nomen ejus Joannem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Luke 1:14",
      "text": "et erit gaudium tibi, et exsultatio, et multi in nativitate ejus gaudebunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Luke 1:15",
      "text": "erit enim magnus coram Domino: et vinum et siceram non bibet, et Spiritu Sancto replebitur adhuc ex utero matris suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Luke 1:16",
      "text": "et multos filiorum Israël convertet ad Dominum Deum ipsorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Luke 1:17",
      "text": "et ipse præcedet ante illum in spiritu et virtute Eliæ: ut convertat corda patrum in filios, et incredulos ad prudentiam justorum, parare Domino plebem perfectam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Luke 1:18",
      "text": "Et dixit Zacharias ad angelum: Unde hoc sciam? ego enim sum senex, et uxor mea processit in diebus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Luke 1:19",
      "text": "Et respondens angelus dixit ei: Ego sum Gabriel, qui asto ante Deum: et missus sum loqui ad te, et hæc tibi evangelizare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Luke 1:20",
      "text": "Et ecce eris tacens, et non poteris loqui usque in diem quo hæc fiant, pro eo quod non credidisti verbis meis, quæ implebuntur in tempore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Luke 1:21",
      "text": "Et erat plebs exspectans Zachariam: et mirabantur quod tardaret ipse in templo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Luke 1:22",
      "text": "Egressus autem non poterat loqui ad illos, et cognoverunt quod visionem vidisset in templo. Et ipse erat innuens illis, et permansit mutus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Luke 1:23",
      "text": "Et factum est, ut impleti sunt dies officii ejus, abiit in domum suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Luke 1:24",
      "text": "post hos autem dies concepit Elisabeth uxor ejus, et occultabat se mensibus quinque, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Luke 1:25",
      "text": "Quia sic fecit mihi Dominus in diebus, quibus respexit auferre opprobrium meum inter homines.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Luke 1:26",
      "text": "In mense autem sexto, missus est angelus Gabriel a Deo in civitatem Galilææ, cui nomen Nazareth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Luke 1:27",
      "text": "ad virginem desponsatam viro, cui nomen erat Joseph, de domo David: et nomen virginis Maria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Luke 1:28",
      "text": "Et ingressus angelus ad eam dixit: Ave gratia plena: Dominus tecum: benedicta tu in mulieribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Luke 1:29",
      "text": "Quæ cum audisset, turbata est in sermone ejus, et cogitabat qualis esset ista salutatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Luke 1:30",
      "text": "Et ait angelus ei: Ne timeas, Maria: invenisti enim gratiam apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Luke 1:31",
      "text": "Ecce concipies in utero, et paries filium, et vocabis nomen ejus Jesum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Luke 1:32",
      "text": "hic erit magnus, et Filius Altissimi vocabitur, et dabit illi Dominus Deus sedem David patris ejus: et regnabit in domo Jacob in æternum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Luke 1:33",
      "text": "et regni ejus non erit finis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Luke 1:34",
      "text": "Dixit autem Maria ad angelum: Quomodo fiet istud, quoniam virum non cognosco?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Luke 1:35",
      "text": "Et respondens angelus dixit ei: Spiritus Sanctus superveniet in te, et virtus Altissimi obumbrabit tibi. Ideoque et quod nascetur ex te sanctum, vocabitur Filius Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Luke 1:36",
      "text": "Et ecce Elisabeth cognata tua, et ipsa concepit filium in senectute sua: et hic mensis sextus est illi, quæ vocatur sterilis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Luke 1:37",
      "text": "quia non erit impossibile apud Deum omne verbum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Luke 1:38",
      "text": "Dixit autem Maria: Ecce ancilla Domini: fiat mihi secundum verbum tuum. Et discessit ab illa angelus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Luke 1:39",
      "text": "Exsurgens autem Maria in diebus illis, abiit in montana cum festinatione, in civitatem Juda:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Luke 1:40",
      "text": "et intravit in domum Zachariæ, et salutavit Elisabeth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "Luke 1:41",
      "text": "Et factum est, ut audivit salutationem Mariæ Elisabeth, exsultavit infans in utero ejus: et repleta est Spiritu Sancto Elisabeth:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "Luke 1:42",
      "text": "et exclamavit voce magna, et dixit: Benedicta tu inter mulieres, et benedictus fructus ventris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "Luke 1:43",
      "text": "Et unde hoc mihi, ut veniat mater Domini mei ad me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "Luke 1:44",
      "text": "Ecce enim ut facta est vox salutationis tuæ in auribus meis, exsultavit in gaudio infans in utero meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "Luke 1:45",
      "text": "Et beata, quæ credidisti, quoniam perficientur ea, quæ dicta sunt tibi a Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "Luke 1:46",
      "text": "Et ait Maria: Magnificat anima mea Dominum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "Luke 1:47",
      "text": "et exsultavit spiritus meus in Deo salutari meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "Luke 1:48",
      "text": "Quia respexit humilitatem ancillæ suæ: ecce enim ex hoc beatam me dicent omnes generationes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.49",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "Luke 1:49",
      "text": "quia fecit mihi magna qui potens est: et sanctum nomen ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.50",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "Luke 1:50",
      "text": "et misericordia ejus a progenie in progenies timentibus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.51",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "Luke 1:51",
      "text": "Fecit potentiam in brachio suo: dispersit superbos mente cordis sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.52",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "Luke 1:52",
      "text": "Deposuit potentes de sede, et exaltavit humiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.53",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "Luke 1:53",
      "text": "Esurientes implevit bonis: et divites dimisit inanes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.54",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "Luke 1:54",
      "text": "Suscepit Israël puerum suum, recordatus misericordiæ suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.55",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 55,
      "referenceLabel": "Luke 1:55",
      "text": "sicut locutus est ad patres nostros, Abraham et semini ejus in sæcula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.56",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 56,
      "referenceLabel": "Luke 1:56",
      "text": "Mansit autem Maria cum illa quasi mensibus tribus: et reversa est in domum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.57",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 57,
      "referenceLabel": "Luke 1:57",
      "text": "Elisabeth autem impletum est tempus pariendi, et peperit filium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.58",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 58,
      "referenceLabel": "Luke 1:58",
      "text": "Et audierunt vicini et cognati ejus quia magnificavit Dominus misericordiam suam cum illa, et congratulabantur ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.59",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 59,
      "referenceLabel": "Luke 1:59",
      "text": "Et factum est in die octavo, venerunt circumcidere puerum, et vocabant eum nomine patris sui Zachariam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.60",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 60,
      "referenceLabel": "Luke 1:60",
      "text": "Et respondens mater ejus, dixit: Nequaquam, sed vocabitur Joannes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.61",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 61,
      "referenceLabel": "Luke 1:61",
      "text": "Et dixerunt ad illam: Quia nemo est in cognatione tua, qui vocetur hoc nomine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.62",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 62,
      "referenceLabel": "Luke 1:62",
      "text": "Innuebant autem patri ejus, quem vellet vocari eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.63",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 63,
      "referenceLabel": "Luke 1:63",
      "text": "Et postulans pugillarem scripsit, dicens: Joannes est nomen ejus. Et mirati sunt universi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.64",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 64,
      "referenceLabel": "Luke 1:64",
      "text": "Apertum est autem illico os ejus, et lingua ejus, et loquebatur benedicens Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.1.65",
