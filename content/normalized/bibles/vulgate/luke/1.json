      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 69,
      "referenceLabel": "Luke 1:69",
      "text": "et erexit cornu salutis nobis in domo David pueri sui,",
