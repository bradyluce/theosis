{
  "chapter": {
    "id": "vulgate:luke.14",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 14,
    "referenceLabel": "Luke 14",
    "summary": "Source text for Luke 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.14.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Luke 14:1",
      "text": "Et factum est cum intraret Jesus in domum cujusdam principis pharisæorum sabbato manducare panem, et ipsi observabant eum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.14.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Luke 14:2",
      "text": "Et ecce homo quidam hydropicus erat ante illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Luke 14:3",
      "text": "Et respondens Jesus dixit ad legisperitos et pharisæos, dicens: Si licet sabbato curare?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Luke 14:4",
      "text": "At illi tacuerunt. Ipse vero apprehensum sanavit eum, ac dimisit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Luke 14:5",
      "text": "Et respondens ad illos dixit: Cujus vestrum asinus, aut bos in puteum cadet, et non continuo extrahet illum die sabbati?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Luke 14:6",
      "text": "Et non poterant ad hæc respondere illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Luke 14:7",
      "text": "Dicebat autem et ad invitatos parabolam, intendens quomodo primos accubitus eligerent, dicens ad illos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Luke 14:8",
      "text": "Cum invitatus fueris ad nuptias, non discumbas in primo loco, ne forte honoratior te sit invitatus ab illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Luke 14:9",
      "text": "Et veniens is, qui te et illum vocavit, dicat tibi: Da huic locum: et tunc incipias cum rubore novissimum locum tenere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Luke 14:10",
      "text": "Sed cum vocatus fueris, vade, recumbe in novissimo loco: ut, cum venerit qui te invitavit, dicat tibi: Amice, ascende superius. Tunc erit tibi gloria coram simul discumbentibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Luke 14:11",
      "text": "quia omnis, qui se exaltat, humiliabitur: et qui se humiliat, exaltabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Luke 14:12",
      "text": "Dicebat autem et ei, qui invitaverat: Cum facis prandium, aut cœnam, noli vocare amicos tuos, neque fratres tuos, neque cognatos, neque vicinos divites: ne forte te et ipsi reinvitent, et fiat tibi retributio;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Luke 14:13",
      "text": "sed cum facis convivium, voca pauperes, debiles, claudos, et cæcos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Luke 14:14",
      "text": "et beatus eris, quia non habent retribuere tibi: retribuetur enim tibi in resurrectione justorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Luke 14:15",
      "text": "Hæc cum audisset quidam de simul discumbentibus, dixit illi: Beatus qui manducabit panem in regno Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Luke 14:16",
      "text": "At ipse dixit ei: Homo quidam fecit cœnam magnam, et vocavit multos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Luke 14:17",
      "text": "Et misit servum suum hora cœnæ dicere invitatis ut venirent, quia jam parata sunt omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Luke 14:18",
      "text": "Et cœperunt simul omnes excusare. Primus dixit ei: Villam emi, et necesse habeo exire, et videre illam: rogo te, habe me excusatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Luke 14:19",
      "text": "Et alter dixit: Juga boum emi quinque, et eo probare illa: rogo te, habe me excusatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Luke 14:20",
      "text": "Et alius dixit: Uxorem duxi, et ideo non possum venire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Luke 14:21",
      "text": "Et reversus servus nuntiavit hæc domino suo. Tunc iratus paterfamilias, dixit servo suo: Exi cito in plateas et vicos civitatis: et pauperes, ac debiles, et cæcos, et claudos introduc huc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Luke 14:22",
      "text": "Et ait servus: Domine, factum est ut imperasti, et adhuc locus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Luke 14:23",
      "text": "Et ait dominus servo: Exi in vias, et sæpes: et compelle intrare, ut impleatur domus mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Luke 14:24",
      "text": "Dico autem vobis quod nemo virorum illorum qui vocati sunt, gustabit cœnam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Luke 14:25",
      "text": "Ibant autem turbæ multæ cum eo: et conversus dixit ad illos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Luke 14:26",
      "text": "Si quis venit ad me, et non odit patrem suum, et matrem, et uxorem, et filios, et fratres, et sorores, adhuc autem et animam suam, non potest meus esse discipulus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Luke 14:27",
      "text": "Et qui non bajulat crucem suam, et venit post me, non potest meus esse discipulus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Luke 14:28",
      "text": "Quis enim ex vobis volens turrim ædificare, non prius sedens computat sumptus, qui necessarii sunt, si habeat ad perficiendum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Luke 14:29",
      "text": "ne, posteaquam posuerit fundamentum, et non potuerit perficere, omnes qui vident, incipiant illudere ei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Luke 14:30",
      "text": "dicentes: Quia hic homo cœpit ædificare, et non potuit consummare?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Luke 14:31",
      "text": "Aut quis rex iturus committere bellum adversus alium regem, non sedens prius cogitat, si possit cum decem millibus occurrere ei, qui cum viginti millibus venit ad se?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Luke 14:32",
      "text": "Alioquin adhuc illo longe agente, legationem mittens rogat ea quæ pacis sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Luke 14:33",
      "text": "Sic ergo omnis ex vobis, qui non renuntiat omnibus quæ possidet, non potest meus esse discipulus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Luke 14:34",
      "text": "Bonum est sal: si autem sal evanuerit, in quo condietur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.14.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Luke 14:35",
      "text": "Neque in terram, neque in sterquilinium utile est, sed foras mittetur. Qui habet aures audiendi, audiat.",
      "paragraphStart": false
    }
  ]
}
