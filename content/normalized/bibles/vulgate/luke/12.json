{
  "chapter": {
    "id": "vulgate:luke.12",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 12,
    "referenceLabel": "Luke 12",
    "summary": "Source text for Luke 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.12.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Luke 12:1",
      "text": "Multis autem turbis circumstantibus, ita ut se invicem conculcarent, cœpit dicere ad discipulos suos: Attendite a fermento pharisæorum, quod est hypocrisis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.12.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Luke 12:2",
      "text": "Nihil autem opertum est, quod non reveletur: neque absconditum, quod non sciatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Luke 12:3",
      "text": "Quoniam quæ in tenebris dixistis, in lumine dicentur: et quod in aurem locuti estis in cubiculis, prædicabitur in tectis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Luke 12:4",
      "text": "Dico autem vobis amicis meis: Ne terreamini ab his qui occidunt corpus, et post hæc non habent amplius quid faciant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Luke 12:5",
      "text": "Ostendam autem vobis quem timeatis: timete eum qui, postquam occiderit, habet potestatem mittere in gehennam: ita dico vobis, hunc timete.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Luke 12:6",
      "text": "Nonne quinque passeres veneunt dipondio, et unus ex illis non est in oblivione coram Deo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Luke 12:7",
      "text": "sed et capilli capitis vestri omnes numerati sunt. Nolite ergo timere: multis passeribus pluris estis vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Luke 12:8",
      "text": "Dico autem vobis: Omnis quicumque confessus fuerit me coram hominibus, et Filius hominis confitebitur illum coram angelis Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Luke 12:9",
      "text": "qui autem negaverit me coram hominibus, negabitur coram angelis Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Luke 12:10",
      "text": "Et omnis qui dicit verbum in Filium hominis, remittetur illi: ei autem qui in Spiritum Sanctum blasphemaverit, non remittetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Luke 12:11",
      "text": "Cum autem inducent vos in synagogas, et ad magistratus, et potestates, nolite solliciti esse qualiter, aut quid respondeatis, aut quid dicatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Luke 12:12",
      "text": "Spiritus enim Sanctus docebit vos in ipsa hora quid oporteat vos dicere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Luke 12:13",
      "text": "Ait autem ei quidam de turba: Magister, dic fratri meo ut dividat mecum hæreditatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Luke 12:14",
      "text": "At ille dixit illi: Homo, quis me constituit judicem, aut divisorem super vos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Luke 12:15",
      "text": "Dixitque ad illos: Videte, et cavete ab omni avaritia: quia non in abundantia cujusquam vita ejus est ex his quæ possidet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Luke 12:16",
      "text": "Dixit autem similitudinem ad illos, dicens: Hominis cujusdam divitis uberes fructus ager attulit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Luke 12:17",
      "text": "et cogitabat intra se dicens: Quid faciam, quia non habeo quo congregem fructus meos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Luke 12:18",
      "text": "Et dixit: Hoc faciam: destruam horrea mea, et majora faciam: et illuc congregabo omnia quæ nata sunt mihi, et bona mea,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Luke 12:19",
      "text": "et dicam animæ meæ: Anima, habes multa bona posita in annos plurimos: requiesce, comede, bibe, epulare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Luke 12:20",
      "text": "Dixit autem illi Deus: Stulte, hac nocte animam tuam repetunt a te: quæ autem parasti, cujus erunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Luke 12:21",
      "text": "Sic est qui sibi thesaurizat, et non est in Deum dives.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Luke 12:22",
      "text": "Dixitque ad discipulos suos: Ideo dico vobis, nolite solliciti esse animæ vestræ quid manducetis, neque corpori quid induamini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Luke 12:23",
      "text": "Anima plus est quam esca, et corpus plus quam vestimentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Luke 12:24",
      "text": "Considerate corvos, quia non seminant, neque metunt, quibus non est cellarium, neque horreum, et Deus pascit illos. Quanto magis vos pluris estis illis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Luke 12:25",
      "text": "Quis autem vestrum cogitando potest adjicere ad staturam suam cubitum unum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Luke 12:26",
      "text": "Si ergo neque quod minimum est potestis, quid de ceteris solliciti estis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Luke 12:27",
      "text": "Considerate lilia quomodo crescunt: non laborant, neque nent: dico autem vobis, nec Salomon in omni gloria sua vestiebatur sicut unum ex istis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Luke 12:28",
      "text": "Si autem fœnum, quod hodie est in agro, et cras in clibanum mittitur, Deus sic vestit: quanto magis vos pusillæ fidei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Luke 12:29",
      "text": "Et vos nolite quærere quid manducetis, aut quid bibatis: et nolite in sublime tolli:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "Luke 12:30",
      "text": "hæc enim omnia gentes mundi quærunt. Pater autem vester scit quoniam his indigetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "Luke 12:31",
      "text": "Verumtamen quærite primum regnum Dei, et justitiam ejus: et hæc omnia adjicientur vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "Luke 12:32",
      "text": "Nolite timere pusillus grex, quia complacuit Patri vestro dare vobis regnum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "Luke 12:33",
      "text": "Vendite quæ possidetis, et date eleemosynam. Facite vobis sacculos, qui non veterascunt, thesaurum non deficientem in cælis: quo fur non appropriat, neque tinea corrumpit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "Luke 12:34",
      "text": "Ubi enim thesaurus vester est, ibi et cor vestrum erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "Luke 12:35",
      "text": "Sint lumbi vestri præcincti, et lucernæ ardentes in manibus vestris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "Luke 12:36",
      "text": "et vos similes hominibus exspectantibus dominum suum quando revertatur a nuptiis: ut, cum venerit et pulsaverit, confestim aperiant ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "Luke 12:37",
      "text": "Beati servi illi quos, cum venerit dominus, invenerit vigilantes: amen dico vobis, quod præcinget se, et faciet illos discumbere, et transiens ministrabit illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "Luke 12:38",
      "text": "Et si venerit in secunda vigilia, et si in tertia vigilia venerit, et ita invenerit, beati sunt servi illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "Luke 12:39",
      "text": "Hoc autem scitote, quoniam si sciret paterfamilias, qua hora fur veniret, vigilaret utique, et non sineret perfodi domum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "Luke 12:40",
      "text": "Et vos estote parati: quia qua hora non putatis, Filius hominis veniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "Luke 12:41",
      "text": "Ait autem ei Petrus: Domine, ad nos dicis hanc parabolam, an et ad omnes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "Luke 12:42",
      "text": "Dixit autem Dominus: Quis, putas, est fidelis dispensator, et prudens, quem constituit dominus supra familiam suam, ut det illis in tempore tritici mensuram?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "Luke 12:43",
      "text": "Beatus ille servus quem, cum venerit dominus, invenerit ita facientem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "Luke 12:44",
      "text": "Vere dico vobis, quoniam supra omnia quæ possidet, constituet illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "Luke 12:45",
      "text": "Quod si dixerit servus ille in corde suo: Moram facit dominus meus venire: et cœperit percutere servos, et ancillas, et edere, et bibere, et inebriari:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "Luke 12:46",
      "text": "veniet dominus servi illius in die qua non sperat, et hora qua nescit, et dividet eum, partemque ejus cum infidelibus ponet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "Luke 12:47",
      "text": "Ille autem servus qui cognovit voluntatem domini sui, et non præparavit, et non facit secundum voluntatem ejus, vapulabit multis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 48,
      "referenceLabel": "Luke 12:48",
      "text": "qui autem non cognovit, et fecit digna plagis, vapulabit paucis. Omni autem cui multum datum est, multum quæretur ab eo: et cui commendaverunt multum, plus petent ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.49",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 49,
      "referenceLabel": "Luke 12:49",
      "text": "Ignem veni mittere in terram, et quid volo nisi ut accendatur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.50",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 50,
      "referenceLabel": "Luke 12:50",
      "text": "Baptismo autem habeo baptizari: et quomodo coarctor usque dum perficiatur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.51",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 51,
      "referenceLabel": "Luke 12:51",
      "text": "Putatis quia pacem veni dare in terram? non, dico vobis, sed separationem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.52",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 52,
      "referenceLabel": "Luke 12:52",
      "text": "erunt enim ex hoc quinque in domo una divisi, tres in duos, et duo in tres",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.53",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 53,
      "referenceLabel": "Luke 12:53",
      "text": "dividentur: pater in filium, et filius in patrem suum, mater in filiam, et filia in matrem, socrus in nurum suam, et nurus in socrum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.54",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 54,
      "referenceLabel": "Luke 12:54",
      "text": "Dicebat autem et ad turbas: Cum videritis nubem orientem ab occasu, statim dicitis: Nimbus venit: et ita fit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.55",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 55,
      "referenceLabel": "Luke 12:55",
      "text": "Et cum austrum flantem, dicitis: Quia æstus erit: et fit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.56",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 56,
      "referenceLabel": "Luke 12:56",
      "text": "Hypocritæ! faciem cæli et terræ nostis probare: hoc autem tempus quomodo non probatis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.57",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 57,
      "referenceLabel": "Luke 12:57",
      "text": "quid autem et a vobis ipsis non judicatis quod justum est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.58",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 58,
      "referenceLabel": "Luke 12:58",
      "text": "Cum autem vadis cum adversario tuo ad principem, in via da operam liberari ab illo, ne forte trahat te ad judicem, et judex tradat te exactori, et exactor mittat te in carcerem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.12.59",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 59,
      "referenceLabel": "Luke 12:59",
      "text": "Dico tibi, non exies inde, donec etiam novissimum minutum reddas.",
      "paragraphStart": false
    }
  ]
}
