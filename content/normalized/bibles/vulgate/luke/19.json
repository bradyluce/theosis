{
  "chapter": {
    "id": "vulgate:luke.19",
    "translationId": "vulgate",
    "bookSlug": "luke",
    "chapterNumber": 19,
    "referenceLabel": "Luke 19",
    "summary": "Source text for Luke 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:luke.19.1",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Luke 19:1",
      "text": "Et ingressus perambulabat Jericho.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:luke.19.2",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Luke 19:2",
      "text": "Et ecce vir nomine Zachæus: et hic princeps erat publicanorum, et ipse dives:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.3",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Luke 19:3",
      "text": "et quærebat videre Jesum, quis esset: et non poterat præ turba, quia statura pusillus erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.4",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Luke 19:4",
      "text": "Et præcurrens ascendit in arborem sycomorum ut videret eum: quia inde erat transiturus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.5",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Luke 19:5",
      "text": "Et cum venisset ad locum, suspiciens Jesus vidit illum, et dixit ad eum: Zachæe, festinans descende: quia hodie in domo tua oportet me manere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.6",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Luke 19:6",
      "text": "Et festinans descendit, et excepit illum gaudens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.7",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Luke 19:7",
      "text": "Et cum viderent omnes, murmurabant, dicentes quod ad hominem peccatorem divertisset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.8",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Luke 19:8",
      "text": "Stans autem Zachæus, dixit ad Dominum: Ecce dimidium bonorum meorum, Domine, do pauperibus: et si quid aliquem defraudavi, reddo quadruplum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.9",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Luke 19:9",
      "text": "Ait Jesus ad eum: Quia hodie salus domui huic facta est: eo quod et ipse filius sit Abrahæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.10",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Luke 19:10",
      "text": "Venit enim Filius hominis quærere, et salvum facere quod perierat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.11",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Luke 19:11",
      "text": "Hæc illis audientibus adjiciens, dixit parabolam, eo quod esset prope Jerusalem: et quia existimarent quod confestim regnum Dei manifestaretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.12",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Luke 19:12",
      "text": "Dixit ergo: Homo quidam nobilis abiit in regionem longinquam accipere sibi regnum, et reverti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.13",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Luke 19:13",
      "text": "Vocatis autem decem servis suis, dedit eis decem mnas, et ait ad illos: Negotiamini dum venio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.14",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Luke 19:14",
      "text": "Cives autem ejus oderant eum: et miserunt legationem post illum, dicentes: Nolumus hunc regnare super nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.15",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Luke 19:15",
      "text": "Et factum est ut rediret accepto regno: et jussit vocari servos, quibus dedit pecuniam, ut sciret quantum quisque negotiatus esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.16",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Luke 19:16",
      "text": "Venit autem primus dicens: Domine, mna tua decem mnas acquisivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.17",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Luke 19:17",
      "text": "Et ait illi: Euge bone serve, quia in modico fuisti fidelis, eris potestatem habens super decem civitates.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.18",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Luke 19:18",
      "text": "Et alter venit, dicens: Domine, mna tua fecit quinque mnas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.19",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Luke 19:19",
      "text": "Et huic ait: Et tu esto super quinque civitates.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.20",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Luke 19:20",
      "text": "Et alter venit, dicens: Domine, ecce mna tua, quam habui repositam in sudario:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.21",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Luke 19:21",
      "text": "timui enim te, quia homo austerus es: tollis quod non posuisti, et metis quod non seminasti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.22",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Luke 19:22",
      "text": "Dicit ei: De ore tuo te judico, serve nequam. Sciebas quod ego homo austerus sum, tollens quod non posui, et metens quod non seminavi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.23",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Luke 19:23",
      "text": "et quare non dedisti pecuniam meam ad mensam, ut ego veniens cum usuris utique exegissem illam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.24",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Luke 19:24",
      "text": "Et astantibus dixit: Auferte ab illo mnam, et date illi qui decem mnas habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.25",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Luke 19:25",
      "text": "Et dixerunt ei: Domine, habet decem mnas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.26",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Luke 19:26",
      "text": "Dico autem vobis, quia omni habenti dabitur, et abundabit: ab eo autem qui non habet, et quod habet auferetur ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.27",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Luke 19:27",
      "text": "Verumtamen inimicos meos illos, qui noluerunt me regnare super se, adducite huc: et interficite ante me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.28",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Luke 19:28",
      "text": "Et his dictis, præcedebat ascendens Jerosolymam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.29",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Luke 19:29",
      "text": "Et factum est, cum appropinquasset ad Bethphage et Bethaniam, ad montem qui vocatur Oliveti, misit duos discipulos suos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.30",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Luke 19:30",
      "text": "dicens: Ite in castellum quod contra est: in quod introëuntes, invenietis pullum asinæ alligatum, cui nemo umquam hominum sedit: solvite illum, et adducite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.31",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Luke 19:31",
      "text": "Et si quis vos interrogaverit: Quare solvitis? sic dicetis ei: Quia Dominus operam ejus desiderat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.32",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Luke 19:32",
      "text": "Abierunt autem qui missi erant: et invenerunt, sicut dixit illis, stantem pullum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.33",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Luke 19:33",
      "text": "Solventibus autem illis pullum, dixerunt domini ejus ad illos: Quid solvitis pullum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.34",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Luke 19:34",
      "text": "At illi dixerunt: Quia Dominus eum necessarium habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.35",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 35,
      "referenceLabel": "Luke 19:35",
      "text": "Et duxerunt illum ad Jesum. Et jactantes vestimenta sua supra pullum, imposuerunt Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.36",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 36,
      "referenceLabel": "Luke 19:36",
      "text": "Eunte autem illo, substernebant vestimenta sua in via:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.37",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 37,
      "referenceLabel": "Luke 19:37",
      "text": "et cum appropinquaret jam ad descensum montis Oliveti, cœperunt omnes turbæ discipulorum gaudentes laudare Deum voce magna super omnibus, quas viderant, virtutibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.38",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 38,
      "referenceLabel": "Luke 19:38",
      "text": "dicentes: Benedictus, qui venit rex in nomine Domini: pax in cælo, et gloria in excelsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.39",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 39,
      "referenceLabel": "Luke 19:39",
      "text": "Et quidam pharisæorum de turbis dixerunt ad illum: Magister, increpa discipulos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.40",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 40,
      "referenceLabel": "Luke 19:40",
      "text": "Quibus ipse ait: Dico vobis, quia si hi tacuerint, lapides clamabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.41",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 41,
      "referenceLabel": "Luke 19:41",
      "text": "Et ut appropinquavit, videns civitatem flevit super illam, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.42",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 42,
      "referenceLabel": "Luke 19:42",
      "text": "Quia si cognovisses et tu, et quidem in hac die tua, quæ ad pacem tibi: nunc autem abscondita sunt ab oculis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.43",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 43,
      "referenceLabel": "Luke 19:43",
      "text": "Quia venient dies in te: et circumdabunt te inimici tui vallo, et circumdabunt te: et coangustabunt te undique:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.44",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 44,
      "referenceLabel": "Luke 19:44",
      "text": "et ad terram prosternent te, et filios tuos, qui in te sunt, et non relinquent in te lapidem super lapidem: eo quod non cognoveris tempus visitationis tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.45",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 45,
      "referenceLabel": "Luke 19:45",
      "text": "Et ingressus in templum, cœpit ejicere vendentes in illo, et ementes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.46",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 46,
      "referenceLabel": "Luke 19:46",
      "text": "dicens illis: Scriptum est: Quia domus mea domus orationis est: vos autem fecistis illam speluncam latronum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.47",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 47,
      "referenceLabel": "Luke 19:47",
      "text": "Et erat docens quotidie in templo. Principes autem sacerdotum, et scribæ, et princeps plebis quærebant illum perdere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:luke.19.48",
      "translationId": "vulgate",
      "bookSlug": "luke",
      "chapterNumber": 19,
      "verseNumber": 48,
      "referenceLabel": "Luke 19:48",
      "text": "et non inveniebant quid facerent illi. Omnis enim populus suspensus erat, audiens illum.",
      "paragraphStart": false
    }
  ]
}
