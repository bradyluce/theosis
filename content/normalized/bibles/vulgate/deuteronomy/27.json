{
  "chapter": {
    "id": "vulgate:deuteronomy.27",
    "translationId": "vulgate",
    "bookSlug": "deuteronomy",
    "chapterNumber": 27,
    "referenceLabel": "Deuteronomy 27",
    "summary": "Source text for Deuteronomy 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:deuteronomy.27.1",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Deuteronomy 27:1",
      "text": "Præcepit autem Moyses et seniores Israël populo, dicentes: Custodite omne mandatum quod præcipio vobis hodie.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:deuteronomy.27.2",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Deuteronomy 27:2",
      "text": "Cumque transieritis Jordanem in terram, quam Dominus Deus tuus dabit tibi, eriges ingentes lapides, et calce lævigabis eos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.3",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Deuteronomy 27:3",
      "text": "ut possis in eis scribere omnia verba legis hujus, Jordane transmisso: ut introëas terram, quam Dominus Deus tuus dabit tibi, terram lacte et melle manantem, sicut juravit patribus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.4",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Deuteronomy 27:4",
      "text": "Quando ergo transieritis Jordanem, erigite lapides, quos ego hodie præcipio vobis in monte Hebal, et lævigabis eos calce:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.5",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Deuteronomy 27:5",
      "text": "et ædificabis ibi altare Domino Deo tuo de lapidibus, quos ferrum non tetigit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.6",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Deuteronomy 27:6",
      "text": "et de saxis informibus et impolitis: et offeres super eo holocausta Domino Deo tuo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.7",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Deuteronomy 27:7",
      "text": "et immolabis hostias pacificas, comedesque ibi, et epulaberis coram Domino Deo tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.8",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Deuteronomy 27:8",
      "text": "Et scribes super lapides omnia verba legis hujus plane et lucide.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.9",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Deuteronomy 27:9",
      "text": "Dixeruntque Moyses et sacerdotes Levitici generis ad omnem Israëlem: Attende, et audi, Israël: hodie factus es populus Domini Dei tui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.10",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Deuteronomy 27:10",
      "text": "audies vocem ejus, et facies mandata atque justitias, quas ego præcipio tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.11",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Deuteronomy 27:11",
      "text": "Præcepitque Moyses populo in die illo, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.12",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Deuteronomy 27:12",
      "text": "Hi stabunt ad benedicendum populo super montem Garizim, Jordane transmisso: Simeon, Levi, Judas, Issachar, Joseph, et Benjamin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.13",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Deuteronomy 27:13",
      "text": "Et e regione isti stabunt ad maledicendum in monte Hebal: Ruben, Gad, et Aser, et Zabulon, Dan, et Nephthali.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.14",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Deuteronomy 27:14",
      "text": "Et pronuntiabunt Levitæ, dicentque ad omnes viros Israël excelsa voce:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.15",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Deuteronomy 27:15",
      "text": "Maledictus homo qui facit sculptile et conflatile, abominationem Domini, opus manuum artificum, ponetque illud in abscondito: et respondebit omnis populus, et dicet: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.16",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Deuteronomy 27:16",
      "text": "Maledictus qui non honorat patrem suum, et matrem: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.17",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Deuteronomy 27:17",
      "text": "Maledictus qui transfert terminos proximi sui: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.18",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Deuteronomy 27:18",
      "text": "Maledictus qui errare facit cæcum in itinere: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.19",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Deuteronomy 27:19",
      "text": "Maledictus qui pervertit judicium advenæ, pupilli et viduæ: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.20",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Deuteronomy 27:20",
      "text": "Maledictus qui dormit cum uxore patris sui, et revelat operimentum lectuli ejus: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.21",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Deuteronomy 27:21",
      "text": "Maledictus qui dormit cum omni jumento: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.22",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Deuteronomy 27:22",
      "text": "Maledictus qui dormit cum sorore sua, filia patris sui, vel matris suæ: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.23",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Deuteronomy 27:23",
      "text": "Maledictus qui dormit cum socru sua: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.24",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Deuteronomy 27:24",
      "text": "Maledictus qui clam percusserit proximum suum: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.25",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Deuteronomy 27:25",
      "text": "Maledictus qui accipit munera, ut percutiat animam sanguinis innocentis: et dicet omnis populus: Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.27.26",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Deuteronomy 27:26",
      "text": "Maledictus qui non permanet in sermonibus legis hujus, nec eos opere perficit: et dicet omnis populus: Amen.",
      "paragraphStart": false
    }
  ]
}
