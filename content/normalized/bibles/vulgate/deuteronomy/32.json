{
  "chapter": {
    "id": "vulgate:deuteronomy.32",
    "translationId": "vulgate",
    "bookSlug": "deuteronomy",
    "chapterNumber": 32,
    "referenceLabel": "Deuteronomy 32",
    "summary": "Source text for Deuteronomy 32 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:deuteronomy.32.1",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Deuteronomy 32:1",
      "text": "Audite, cæli, quæ loquor: audiat terra verba oris mei.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:deuteronomy.32.2",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Deuteronomy 32:2",
      "text": "Concrescat ut pluvia doctrina mea, fluat ut ros eloquium meum, quasi imber super herbam, et quasi stillæ super gramina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.3",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Deuteronomy 32:3",
      "text": "Quia nomen Domini invocabo: date magnificentiam Deo nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.4",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Deuteronomy 32:4",
      "text": "Dei perfecta sunt opera, et omnes viæ ejus judicia: Deus fidelis, et absque ulla iniquitate, justus et rectus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.5",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Deuteronomy 32:5",
      "text": "Peccaverunt ei, et non filii ejus in sordibus: generatio prava atque perversa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.6",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Deuteronomy 32:6",
      "text": "Hæccine reddis Domino, popule stulte et insipiens? numquid non ipse est pater tuus, qui possedit te, et fecit, et creavit te?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.7",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Deuteronomy 32:7",
      "text": "Memento dierum antiquorum, cogita generationes singulas: interroga patrem tuum, et annuntiabit tibi: majores tuos, et dicent tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.8",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Deuteronomy 32:8",
      "text": "Quando dividebat Altissimus gentes, quando separabat filios Adam, constituit terminos populorum juxta numerum filiorum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.9",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Deuteronomy 32:9",
      "text": "Pars autem Domini, populus ejus: Jacob funiculus hæreditatis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.10",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Deuteronomy 32:10",
      "text": "Invenit eum in terra deserta, in loco horroris, et vastæ solitudinis: circumduxit eum, et docuit: et custodivit quasi pupillam oculi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.11",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Deuteronomy 32:11",
      "text": "Sicut aquila provocans ad volandum pullos suos, et super eos volitans, expandit alas suas, et assumpsit eum, atque portavit in humeris suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.12",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Deuteronomy 32:12",
      "text": "Dominus solus dux ejus fuit, et non erat cum eo deus alienus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.13",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Deuteronomy 32:13",
      "text": "constituit eum super excelsam terram, ut comederet fructus agrorum: ut sugeret mel de petra, oleumque de saxo durissimo;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.14",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Deuteronomy 32:14",
      "text": "butyrum de armento, et lac de ovibus cum adipe agnorum, et arietum filiorum Basan: et hircos cum medulla tritici, et sanguinem uvæ biberet meracissimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.15",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Deuteronomy 32:15",
      "text": "Incrassatus est dilectus, et recalcitravit: incrassatus, impinguatus, dilatatus, dereliquit Deum factorem suum, et recessit a Deo salutari suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.16",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Deuteronomy 32:16",
      "text": "Provocaverunt eum in diis alienis, et in abominationibus ad iracundiam concitaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.17",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Deuteronomy 32:17",
      "text": "Immolaverunt dæmoniis et non Deo, diis quos ignorabant: novi recentesque venerunt, quos non coluerunt patres eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.18",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Deuteronomy 32:18",
      "text": "Deum qui te genuit dereliquisti, et oblitus es Domini creatoris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.19",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Deuteronomy 32:19",
      "text": "Vidit Dominus, et ad iracundiam concitatus est: quia provocaverunt eum filii sui et filiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.20",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Deuteronomy 32:20",
      "text": "Et ait: Abscondam faciem meam ab eis, et considerabo novissima eorum: generatio enim perversa est, et infideles filii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.21",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Deuteronomy 32:21",
      "text": "Ipsi me provocaverunt in eo qui non erat Deus, et irritaverunt in vanitatibus suis: et ego provocabo eos in eo qui non est populus, et in gente stulta irritabo illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.22",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Deuteronomy 32:22",
      "text": "Ignis succensus est in furore meo, et ardebit usque ad inferni novissima: devorabitque terram cum germine suo, et montium fundamenta comburet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.23",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 23,
      "referenceLabel": "Deuteronomy 32:23",
      "text": "Congregabo super eos mala, et sagittas meas complebo in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.24",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 24,
      "referenceLabel": "Deuteronomy 32:24",
      "text": "Consumentur fame, et devorabunt eos aves morsu amarissimo: dentes bestiarum immittam in eos, cum furore trahentium super terram, atque serpentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.25",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 25,
      "referenceLabel": "Deuteronomy 32:25",
      "text": "Foris vastabit eos gladius, et intus pavor, juvenem simul ac virginem, lactentem cum homine sene.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.26",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 26,
      "referenceLabel": "Deuteronomy 32:26",
      "text": "Dixi: Ubinam sunt? cessare faciam ex hominibus memoriam eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.27",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 27,
      "referenceLabel": "Deuteronomy 32:27",
      "text": "Sed propter iram inimicorum distuli: ne forte superbirent hostes eorum, et dicerent: Manus nostra excelsa, et non Dominus, fecit hæc omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.28",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 28,
      "referenceLabel": "Deuteronomy 32:28",
      "text": "Gens absque consilio est, et sine prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.29",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 29,
      "referenceLabel": "Deuteronomy 32:29",
      "text": "Utinam saperent, et intelligerent, ac novissima providerent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.30",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 30,
      "referenceLabel": "Deuteronomy 32:30",
      "text": "Quomodo persequatur unus mille, et duo fugent decem millia? nonne ideo, quia Deus suus vendidit eos, et Dominus conclusit illos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.31",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 31,
      "referenceLabel": "Deuteronomy 32:31",
      "text": "Non enim est Deus noster ut dii eorum: et inimici nostri sunt judices.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.32",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 32,
      "referenceLabel": "Deuteronomy 32:32",
      "text": "De vinea Sodomorum, vinea eorum, et de suburbanis Gomorrhæ: uva eorum, uva fellis, et botri amarissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.33",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 33,
      "referenceLabel": "Deuteronomy 32:33",
      "text": "Fel draconum vinum eorum, et venenum aspidum insanabile.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.34",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 34,
      "referenceLabel": "Deuteronomy 32:34",
      "text": "Nonne hæc condita sunt apud me, et signata in thesauris meis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.35",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 35,
      "referenceLabel": "Deuteronomy 32:35",
      "text": "Mea est ultio, et ego retribuam in tempore, ut labatur pes eorum: juxta est dies perditionis, et adesse festinant tempora.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.36",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 36,
      "referenceLabel": "Deuteronomy 32:36",
      "text": "Judicabit Dominus populum suum, et in servis suis miserebitur: videbit quod infirmata sit manus, et clausi quoque defecerunt, residuique consumpti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.37",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 37,
      "referenceLabel": "Deuteronomy 32:37",
      "text": "Et dicet: Ubi sunt dii eorum, in quibus habebant fiduciam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.38",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 38,
      "referenceLabel": "Deuteronomy 32:38",
      "text": "de quorum victimis comedebant adipes, et bibebant vinum libaminum: surgant, et opitulentur vobis, et in necessitate vos protegant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.39",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 39,
      "referenceLabel": "Deuteronomy 32:39",
      "text": "Videte quod ego sim solus, et non sit alius deus præter me: ego occidam, et ego vivere faciam: percutiam, et ego sanabo, et non est qui de manu mea possit eruere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.40",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 40,
      "referenceLabel": "Deuteronomy 32:40",
      "text": "Levabo ad cælum manum meam, et dicam: Vivo ego in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.41",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 41,
      "referenceLabel": "Deuteronomy 32:41",
      "text": "Si acuero ut fulgur gladium meum, et arripuerit judicium manus mea: reddam ultionem hostibus meis, et his qui oderunt me retribuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.42",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 42,
      "referenceLabel": "Deuteronomy 32:42",
      "text": "Inebriabo sagittas meas sanguine, et gladius meus devorabit carnes; de cruore occisorum et de captivitate, nudati inimicorum capitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.43",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 43,
      "referenceLabel": "Deuteronomy 32:43",
      "text": "Laudate, gentes, populum ejus, quia sanguinem servorum suorum ulciscetur: et vindictam retribuet in hostes eorum, et propitius erit terræ populi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.44",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 44,
      "referenceLabel": "Deuteronomy 32:44",
      "text": "Venit ergo Moyses, et locutus est omnia verba cantici hujus in auribus populi, ipse et Josue filius Nun.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.45",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 45,
      "referenceLabel": "Deuteronomy 32:45",
      "text": "Complevitque omnes sermones istos, loquens ad universum Israël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.46",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 46,
      "referenceLabel": "Deuteronomy 32:46",
      "text": "et dixit ad eos: Ponite corda vestra in omnia verba, quæ ego testificor vobis hodie: ut mandetis ea filiis vestris custodire et facere, et implere universa quæ scripta sunt legis hujus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.47",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 47,
      "referenceLabel": "Deuteronomy 32:47",
      "text": "quia non incassum præcepta sunt vobis, sed ut singuli in eis viverent: quæ facientes longo perseveretis tempore in terra, ad quam, Jordane transmisso, ingredimini possidendam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.48",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 48,
      "referenceLabel": "Deuteronomy 32:48",
      "text": "Locutusque est Dominus ad Moysen in eadem die, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.49",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 49,
      "referenceLabel": "Deuteronomy 32:49",
      "text": "Ascende in montem istum Abarim, id est, transitum, in montem Nebo, qui est in terra Moab contra Jericho: et vide terram Chanaan, quam ego tradam filiis Israël obtinendam, et morere in monte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.50",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 50,
      "referenceLabel": "Deuteronomy 32:50",
      "text": "Quem conscendens jungeris populis tuis, sicut mortuus est Aaron frater tuus in monte Hor, et appositus populis suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.51",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 51,
      "referenceLabel": "Deuteronomy 32:51",
      "text": "quia prævaricati estis contra me in medio filiorum Israël ad aquas contradictionis in Cades deserti Sin: et non sanctificastis me inter filios Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:deuteronomy.32.52",
      "translationId": "vulgate",
      "bookSlug": "deuteronomy",
      "chapterNumber": 32,
      "verseNumber": 52,
      "referenceLabel": "Deuteronomy 32:52",
      "text": "E contra videbis terram, et non ingredieris in eam, quam ego dabo filiis Israël.",
      "paragraphStart": false
    }
  ]
}
