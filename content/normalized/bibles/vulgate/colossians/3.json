{
  "chapter": {
    "id": "vulgate:colossians.3",
    "translationId": "vulgate",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:colossians.3.1",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "Igitur, si consurrexistis cum Christo: quæ sursum sunt quærite, ubi Christus est in dextera Dei sedens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:colossians.3.2",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "quæ sursum sunt sapite, non quæ super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.3",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "Mortui enim estis, et vita vestra est abscondita cum Christo in Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.4",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "Cum Christus apparuerit, vita vestra: tunc et vos apparebitis cum ipso in gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.5",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "Mortificate ergo membra vestra, quæ sunt super terram: fornicationem, immunditiam, libidinem, concupiscentiam malam, et avaritiam, quæ est simulacrorum servitus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.6",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "propter quæ venit ira Dei super filios incredulitatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.7",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "in quibus et vos ambulastis aliquando, cum viveretis in illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.8",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "Nunc autem deponite et vos omnia: iram, indignationem, malitiam, blasphemiam, turpem sermonem de ore vestro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.9",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "Nolite mentiri invicem, expoliantes vos veterem hominem cum actibus suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.10",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "et induentes novum eum, qui renovatur in agnitionem secundum imaginem ejus qui creavit illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.11",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "ubi non est gentilis et Judæus, circumcisio et præputium, Barbarus et Scytha, servus et liber: sed omnia, et in omnibus Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.12",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "Induite vos ergo, sicut electi Dei, sancti, et dilecti, viscera misericordiæ, benignitatem, humilitatem, modestiam, patientiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.13",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "supportantes invicem, et donantes vobismetipsis si quis adversus aliquem habet querelam: sicut et Dominus donavit vobis, ita et vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.14",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "Super omnia autem hæc, caritatem habete, quod est vinculum perfectionis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.15",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "et pax Christi exsultet in cordibus vestris, in qua et vocati estis in uno corpore: et grati estote.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.16",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "Verbum Christi habitet in vobis abundanter, in omni sapientia, docentes, et commonentes vosmetipsos, psalmis, hymnis, et canticis spiritualibus, in gratia cantantes in cordibus vestris Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.17",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "Omne, quodcumque facitis in verbo aut in opere, omnia in nomine Domini Jesu Christi, gratias agentes Deo et Patri per ipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.18",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "Mulieres, subditæ estote viris, sicut oportet, in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.19",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "Viri, diligite uxores vestras, et nolite amari esse ad illas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.20",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "Filii, obedite parentibus per omnia: hoc enim placitum est in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.21",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "Patres, nolite ad indignationem provocare filios vestros, ut non pusillo animo fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.22",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "Servi, obedite per omnia dominis carnalibus, non ad oculum servientes, quasi hominibus placentes, sed in simplicitate cordis, timentes Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.23",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "Quodcumque facitis, ex animo operamini sicut Domino, et non hominibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.24",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "scientes quod a Domino accipietis retributionem hæreditatis. Domino Christo servite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.3.25",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "Qui enim injuriam facit, recipiet id quod inique gessit: et non est personarum acceptio apud Deum.",
      "paragraphStart": false
    }
  ]
}
