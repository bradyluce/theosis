{
  "chapter": {
    "id": "vulgate:colossians.2",
    "translationId": "vulgate",
    "bookSlug": "colossians",
    "chapterNumber": 2,
    "referenceLabel": "Colossians 2",
    "summary": "Source text for Colossians 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:colossians.2.1",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Colossians 2:1",
      "text": "Volo enim vos scire qualem sollicitudinem habeam pro vobis, et pro iis qui sunt Laodiciæ, et quicumque non viderunt faciem meam in carne:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:colossians.2.2",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Colossians 2:2",
      "text": "ut consolentur corda ipsorum, instructi in caritate, et in omnes divitias plenitudinis intellectus, in agnitionem mysterii Dei Patris et Christi Jesu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.3",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Colossians 2:3",
      "text": "in quo sunt omnes thesauri sapientiæ et scientiæ absconditi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.4",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Colossians 2:4",
      "text": "Hoc autem dico, ut nemo vos decipiat in sublimitate sermonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.5",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Colossians 2:5",
      "text": "Nam etsi corpore absens sum, sed spiritu vobiscum sum: gaudens, et videns ordinem vestrum, et firmamentum ejus, quæ in Christo est, fidei vestræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.6",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Colossians 2:6",
      "text": "Sicut ergo accepistis Jesum Christum Dominum, in ipso ambulate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.7",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Colossians 2:7",
      "text": "radicati, et superædificati in ipso, et confirmati fide, sicut et didicistis, abundantes in illo in gratiarum actione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.8",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Colossians 2:8",
      "text": "Videte ne quis vos decipiat per philosophiam, et inanem fallaciam secundum traditionem hominum, secundum elementa mundi, et non secundum Christum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.9",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Colossians 2:9",
      "text": "quia in ipso inhabitat omnis plenitudo divinitatis corporaliter:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.10",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Colossians 2:10",
      "text": "et estis in illo repleti, qui est caput omnis principatus et potestatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.11",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Colossians 2:11",
      "text": "in quo et circumcisi estis circumcisione non manu facta in expoliatione corporis carnis, sed in circumcisione Christi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.12",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Colossians 2:12",
      "text": "consepulti ei in baptismo, in quo et resurrexistis per fidem operationis Dei, qui suscitavit illum a mortuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.13",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Colossians 2:13",
      "text": "Et vos cum mortui essetis in delictis, et præputio carnis vestræ, convivificavit cum illo, donans vobis omnia delicta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.14",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Colossians 2:14",
      "text": "delens quod adversus nos erat chirographum decreti, quod erat contrarium nobis, et ipsum tulit de medio, affigens illud cruci:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.15",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Colossians 2:15",
      "text": "et expolians principatus, et potestates traduxit confidenter, palam triumphans illos in semetipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.16",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Colossians 2:16",
      "text": "Nemo ergo vos judicet in cibo, aut in potu, aut in parte diei festi, aut neomeniæ, aut sabbatorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.17",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Colossians 2:17",
      "text": "quæ sunt umbra futurorum: corpus autem Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.18",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Colossians 2:18",
      "text": "Nemo vos seducat, volens in humilitate, et religione angelorum, quæ non vidit ambulans, frustra inflatus sensu carnis suæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.19",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Colossians 2:19",
      "text": "et non tenens caput, ex quo totum corpus per nexus, et conjunctiones subministratum, et constructum crescit in augmentum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.20",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Colossians 2:20",
      "text": "Si ergo mortui estis cum Christo ab elementis hujus mundi: quid adhuc tamquam viventes in mundo decernitis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.21",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Colossians 2:21",
      "text": "Ne tetigeritis, neque gustaveritis, neque contrectaveritis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.22",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Colossians 2:22",
      "text": "quæ sunt omnia in interitum ipso usu, secundum præcepta et doctrinas hominum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.2.23",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Colossians 2:23",
      "text": "quæ sunt rationem quidem habentia sapientiæ in superstitione, et humilitate, et non ad parcendum corpori, non in honore aliquo ad saturitatem carnis.",
      "paragraphStart": false
    }
  ]
}
