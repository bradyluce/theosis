{
  "chapter": {
    "id": "vulgate:colossians.4",
    "translationId": "vulgate",
    "bookSlug": "colossians",
    "chapterNumber": 4,
    "referenceLabel": "Colossians 4",
    "summary": "Source text for Colossians 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:colossians.4.1",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Colossians 4:1",
      "text": "Domini, quod justum est et æquum, servis præstate: scientes quod et vos Dominum habetis in cælo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:colossians.4.2",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Colossians 4:2",
      "text": "Orationi instate, vigilantes in ea in gratiarum actione:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.3",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Colossians 4:3",
      "text": "orantes simul et pro nobis, ut Deus aperiat nobis ostium sermonis ad loquendum mysterium Christi (propter quod etiam vinctus sum),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.4",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Colossians 4:4",
      "text": "ut manifestem illud ita ut oportet me loqui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.5",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Colossians 4:5",
      "text": "In sapientia ambulate ad eos, qui foris sunt: tempus redimentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.6",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Colossians 4:6",
      "text": "Sermo vester semper in gratia sale sit conditus, ut sciatis quomodo oporteat vos unicuique respondere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.7",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Colossians 4:7",
      "text": "Quæ circa me sunt, omnia vobis nota faciet Tychicus, carissimus frater, et fidelis minister, et conservus in Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.8",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Colossians 4:8",
      "text": "quem misi ad vos ad hoc ipsum, ut cognoscat quæ circa vos sunt, et consoletur corda vestra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.9",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Colossians 4:9",
      "text": "cum Onesimo carissimo, et fideli fratre, qui ex vobis est. Omnia, quæ hic aguntur, nota facient vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.10",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Colossians 4:10",
      "text": "Salutat vos Aristarchus concaptivus meus, et Marcus consobrinus Barnabæ, de quo accepistis mandata: si venerit ad vos, excipite illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.11",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Colossians 4:11",
      "text": "et Jesus, qui dicitur Justus: qui sunt ex circumcisione: hi soli sunt adjutores mei in regno Dei, qui mihi fuerunt solatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.12",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Colossians 4:12",
      "text": "Salutat vos Epaphras, qui ex vobis est, servus Christi Jesu, semper sollicitus pro vobis in orationibus, ut stetis perfecti, et pleni in omni voluntate Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.13",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Colossians 4:13",
      "text": "Testimonium enim illi perhibeo quod habet multum laborem pro vobis, et pro iis qui sunt Laodiciæ, et qui Hierapoli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.14",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Colossians 4:14",
      "text": "Salutat vos Lucas, medicus carissimus, et Demas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.15",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Colossians 4:15",
      "text": "Salutate fratres, qui sunt Laodiciæ, et Nympham, et quæ in domo ejus est, ecclesiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.16",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Colossians 4:16",
      "text": "Et cum lecta fuerit apud vos epistola hæc, facite ut et in Laodicensium ecclesia legatur: et eam, quæ Laodicensium est, vos legatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.17",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Colossians 4:17",
      "text": "Et dicite Archippo: Vide ministerium, quod accepisti in Domino, ut illud impleas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:colossians.4.18",
      "translationId": "vulgate",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Colossians 4:18",
      "text": "Salutatio, mea manu Pauli. Memores estote vinculorum meorum. Gratia vobiscum. Amen.",
      "paragraphStart": false
    }
  ]
}
