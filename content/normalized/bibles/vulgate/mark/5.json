{
  "chapter": {
    "id": "vulgate:mark.5",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 5,
    "referenceLabel": "Mark 5",
    "summary": "Source text for Mark 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.5.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Mark 5:1",
      "text": "Et venerunt trans fretum maris in regionem Gerasenorum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.5.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Mark 5:2",
      "text": "Et exeunti ei de navi, statim occurrit de monumentis homo in spiritu immundo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Mark 5:3",
      "text": "qui domicilium habebat in monumentis, et neque catenis jam quisquam poterat eum ligare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Mark 5:4",
      "text": "quoniam sæpe compedibus et catenis vinctus, dirupisset catenas, et compedes comminuisset, et nemo poterat eum domare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Mark 5:5",
      "text": "et semper die ac nocte in monumentis, et in montibus erat, clamans, et concidens se lapidibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Mark 5:6",
      "text": "Videns autem Jesum a longe, cucurrit, et adoravit eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Mark 5:7",
      "text": "et clamans voce magna dixit: Quid mihi et tibi, Jesu Fili Dei altissimi? adjuro te per Deum, ne me torqueas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Mark 5:8",
      "text": "Dicebat enim illi: Exi spiritus immunde ab homine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Mark 5:9",
      "text": "Et interrogabat eum: Quod tibi nomen est? Et dicit ei: Legio mihi nomen est, quia multi sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Mark 5:10",
      "text": "Et deprecabatur eum multum, ne se expelleret extra regionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Mark 5:11",
      "text": "Erat autem ibi circa montem grex porcorum magnus, pascens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Mark 5:12",
      "text": "Et deprecabantur eum spiritus, dicentes: Mitte nos in porcos ut in eos introëamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Mark 5:13",
      "text": "Et concessit eis statim Jesus. Et exeuntes spiritus immundi introierunt in porcos: et magno impetu grex præcipitatus est in mare ad duo millia, et suffocati sunt in mari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Mark 5:14",
      "text": "Qui autem pascebant eos, fugerunt, et nuntiaverunt in civitatem et in agros. Et egressi sunt videre quid esset factum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Mark 5:15",
      "text": "et veniunt ad Jesum: et vident illum qui a dæmonio vexabatur, sedentem, vestitum, et sanæ mentis, et timuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Mark 5:16",
      "text": "Et narraverunt illis, qui viderant, qualiter factum esset ei qui dæmonium habuerat, et de porcis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Mark 5:17",
      "text": "Et rogare cœperunt eum ut discederet de finibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Mark 5:18",
      "text": "Cumque ascenderet navim, cœpit illum deprecari, qui a dæmonio vexatus fuerat, ut esset cum illo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Mark 5:19",
      "text": "et non admisit eum, sed ait illi: Vade in domum tuam ad tuos, et annuntia illis quanta tibi Dominus fecerit, et misertus sit tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Mark 5:20",
      "text": "Et abiit, et cœpit prædicare in Decapoli, quanta sibi fecisset Jesus: et omnes mirabantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Mark 5:21",
      "text": "Et cum transcendisset Jesus in navi rursum trans fretum, convenit turba multa ad eum, et erat circa mare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Mark 5:22",
      "text": "Et venit quidam de archisynagogis nomine Jairus, et videns eum procidit ad pedes ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Mark 5:23",
      "text": "et deprecabatur eum multum, dicens: Quoniam filia mea in extremis est, veni, impone manum super eam, ut salva sit, et vivat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Mark 5:24",
      "text": "Et abiit cum illo, et sequebatur eum turba multa, et comprimebant eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Mark 5:25",
      "text": "Et mulier, quæ erat in profluvio sanguinis annis duodecim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Mark 5:26",
      "text": "et fuerat multa perpessa a compluribus medicis: et erogaverat omnia sua, nec quidquam profecerat, sed magis deterius habebat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Mark 5:27",
      "text": "cum audisset de Jesu, venit in turba retro, et tetigit vestimentum ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Mark 5:28",
      "text": "dicebat enim: Quia si vel vestimentum ejus tetigero, salva ero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Mark 5:29",
      "text": "Et confestim siccatus est fons sanguinis ejus: et sensit corpore quia sanata esset a plaga.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Mark 5:30",
      "text": "Et statim Jesus in semetipso cognoscens virtutem quæ exierat de illo, conversus ad turbam, aiebat: Quis tetigit vestimenta mea?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Mark 5:31",
      "text": "Et dicebant ei discipuli sui: Vides turbam comprimentem te, et dicis: Quis me tetigit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Mark 5:32",
      "text": "Et circumspiciebat videre eam, quæ hoc fecerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Mark 5:33",
      "text": "Mulier vero timens et tremens, sciens quod factum esset in se, venit et procidit ante eum, et dixit ei omnem veritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Mark 5:34",
      "text": "Ille autem dixit ei: Filia, fides tua te salvam fecit: vade in pace, et esto sana a plaga tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "Mark 5:35",
      "text": "Adhuc eo loquente, veniunt ab archisynagogo, dicentes: Quia filia tua mortua est: quid ultra vexas magistrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "Mark 5:36",
      "text": "Jesus autem audito verbo quod dicebatur, ait archisynagogo: Noli timere: tantummodo crede.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "Mark 5:37",
      "text": "Et non admisit quemquam se sequi nisi Petrum, et Jacobum, et Joannem fratrem Jacobi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 38,
      "referenceLabel": "Mark 5:38",
      "text": "Et veniunt in domum archisynagogi, et videt tumultum, et flentes, et ejulantes multum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 39,
      "referenceLabel": "Mark 5:39",
      "text": "Et ingressus, ait illis: Quid turbamini, et ploratis? puella non est mortua, sed dormit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.40",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 40,
      "referenceLabel": "Mark 5:40",
      "text": "Et irridebant eum. Ipse vero ejectis omnibus assumit patrem, et matrem puellæ, et qui secum erant, et ingreditur ubi puella erat jacens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.41",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 41,
      "referenceLabel": "Mark 5:41",
      "text": "Et tenens manum puellæ, ait illi: Talitha cumi, quod est interpretatum: Puella (tibi dico), surge.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.42",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 42,
      "referenceLabel": "Mark 5:42",
      "text": "Et confestim surrexit puella, et ambulabat: erat autem annorum duodecim: et obstupuerunt stupore magno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.5.43",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 43,
      "referenceLabel": "Mark 5:43",
      "text": "Et præcepit illis vehementer ut nemo id sciret: et dixit dari illi manducare.",
      "paragraphStart": false
    }
  ]
}
