{
  "chapter": {
    "id": "vulgate:mark.7",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 7,
    "referenceLabel": "Mark 7",
    "summary": "Source text for Mark 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.7.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Mark 7:1",
      "text": "Et conveniunt ad eum pharisæi, et quidam de scribis, venientes ab Jerosolymis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.7.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Mark 7:2",
      "text": "Et cum vidissent quosdam ex discipulis ejus communibus manibus, id est non lotis, manducare panes, vituperaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Mark 7:3",
      "text": "Pharisæi enim, et omnes Judæi, nisi crebro laverint manus, non manducant, tenentes traditionem seniorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Mark 7:4",
      "text": "et a foro nisi baptizentur, non comedunt: et alia multa sunt, quæ tradita sunt illis servare, baptismata calicum, et urceorum, et æramentorum, et lectorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Mark 7:5",
      "text": "et interrogabant eum pharisæi et scribæ: Quare discipuli tui non ambulant juxta traditionem seniorum, sed communibus manibus manducant panem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Mark 7:6",
      "text": "At ille respondens, dixit eis: Bene prophetavit Isaias de vobis hypocritis, sicut scriptum est: Populus hic labiis me honorat, cor autem eorum longe est a me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Mark 7:7",
      "text": "in vanum autem me colunt, docentes doctrinas, et præcepta hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Mark 7:8",
      "text": "Relinquentes enim mandatum Dei, tenetis traditionem hominum, baptismata urceorum et calicum: et alia similia his facitis multa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Mark 7:9",
      "text": "Et dicebat illis: Bene irritum facitis præceptum Dei, ut traditionem vestram servetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Mark 7:10",
      "text": "Moyses enim dixit: Honora patrem tuum, et matrem tuam. Et: Qui maledixerit patri, vel matri, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Mark 7:11",
      "text": "Vos autem dicitis: Si dixerit homo patri, aut matri, Corban (quod est donum) quodcumque ex me, tibi profuerit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Mark 7:12",
      "text": "et ultra non dimittitis eum quidquam facere patri suo, aut matri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Mark 7:13",
      "text": "rescindentes verbum Dei per traditionem vestram, quam tradidistis: et similia hujusmodi multa facitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Mark 7:14",
      "text": "Et advocans iterum turbam, dicebat illis: Audite me omnes, et intelligite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Mark 7:15",
      "text": "Nihil est extra hominem introiens in eum, quod possit eum coinquinare, sed quæ de homine procedunt illa sunt quæ communicant hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Mark 7:16",
      "text": "Si quis habet aures audiendi, audiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Mark 7:17",
      "text": "Et cum introisset in domum a turba, interrogabant eum discipuli ejus parabolam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Mark 7:18",
      "text": "Et ait illis: Sic et vos imprudentes estis? Non intelligitis quia omne extrinsecus introiens in hominem, non potest eum communicare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Mark 7:19",
      "text": "quia non intrat in cor ejus, sed in ventrum vadit, et in secessum exit, purgans omnes escas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Mark 7:20",
      "text": "Dicebat autem, quoniam quæ de homine exeunt, illa communicant hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Mark 7:21",
      "text": "Ab intus enim de corde hominum malæ cogitationes procedunt, adulteria, fornicationes, homicidia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Mark 7:22",
      "text": "furta, avaritiæ, nequitiæ, dolus, impudicitiæ, oculus malus, blasphemia, superbia, stultitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Mark 7:23",
      "text": "Omnia hæc mala ab intus procedunt, et communicant hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Mark 7:24",
      "text": "Et inde surgens abiit in fines Tyri et Sidonis: et ingressus domum, neminem voluit scire, et non potuit latere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Mark 7:25",
      "text": "Mulier enim statim ut audivit de eo, cujus filia habebat spiritum immundum, intravit, et procidit ad pedes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Mark 7:26",
      "text": "Erat enim mulier gentilis, Syrophœnissa genere. Et rogabat eum ut dæmonium ejiceret de filia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Mark 7:27",
      "text": "Qui dixit illi: Sine prius saturari filios: non est enim bonum sumere panem filiorum, et mittere canibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Mark 7:28",
      "text": "At illa respondit, et dixit illi: Utique Domine, nam et catelli comedunt sub mensa de micis puerorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Mark 7:29",
      "text": "Et ait illi: Propter hunc sermonem vade: exiit dæmonium a filia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Mark 7:30",
      "text": "Et cum abiisset domum suam, invenit puellam jacentem supra lectum, et dæmonium exiisse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Mark 7:31",
      "text": "Et iterum exiens de finibus Tyri, venit per Sidonem ad mare Galilææ inter medios fines Decapoleos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Mark 7:32",
      "text": "Et adducunt ei surdum, et mutum, et deprecabantur eum, ut imponat illi manum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Mark 7:33",
      "text": "Et apprehendens eum de turba seorsum, misit digitos suos in auriculas ejus: et exspuens, tetigit linguam ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Mark 7:34",
      "text": "et suscipiens in cælum, ingemuit, et ait illi: Ephphetha, quod est, Adaperire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Mark 7:35",
      "text": "Et statim apertæ sunt aures ejus, et solutum est vinculum linguæ ejus, et loquebatur recte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Mark 7:36",
      "text": "Et præcepit illis ne cui dicerent. Quanto autem eis præcipiebat, tanto magis plus prædicabant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.7.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Mark 7:37",
      "text": "et eo amplius admirabantur, dicentes: Bene omnia fecit: et surdos fecit audire, et mutos loqui.",
      "paragraphStart": false
    }
  ]
}
