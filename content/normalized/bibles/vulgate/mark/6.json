{
  "chapter": {
    "id": "vulgate:mark.6",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 6,
    "referenceLabel": "Mark 6",
    "summary": "Source text for Mark 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.6.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Mark 6:1",
      "text": "Et egressus inde, abiit in patriam suam: et sequebantur eum discipuli sui:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.6.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Mark 6:2",
      "text": "et facto sabbato cœpit in synagoga docere: et multi audientes admirabantur in doctrina ejus, dicentes: Unde huic hæc omnia? et quæ est sapientia, quæ data est illi, et virtutes tales, quæ per manus ejus efficiuntur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Mark 6:3",
      "text": "Nonne hic est faber, filius Mariæ, frater Jacobi, et Joseph, et Judæ, et Simonis? nonne et sorores ejus hic nobiscum sunt? Et scandalizabantur in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Mark 6:4",
      "text": "Et dicebat illis Jesus: Quia non est propheta sine honore nisi in patria sua, et in domo sua, et in cognatione sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Mark 6:5",
      "text": "Et non poterat ibi virtutem ullam facere, nisi paucos infirmos impositis manibus curavit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Mark 6:6",
      "text": "et mirabatur propter incredulitatem eorum, et circuibat castella in circuitu docens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Mark 6:7",
      "text": "Et vocavit duodecim: et cœpit eos mittere binos, et dabat illis potestatem spirituum immundorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Mark 6:8",
      "text": "Et præcepit eis ne quid tollerent in via, nisi virgam tantum: non peram, non panem, neque in zona æs,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Mark 6:9",
      "text": "sed calceatos sandaliis, et ne induerentur duabus tunicis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Mark 6:10",
      "text": "Et dicebat eis: Quocumque introieritis in domum, illic manete donec exeatis inde:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Mark 6:11",
      "text": "et quicumque non receperint vos, nec audierint vos, exeuntes inde, excutite pulverem de pedibus vestris in testimonium illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Mark 6:12",
      "text": "Et exeuntes prædicabant ut pœnitentiam agerent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Mark 6:13",
      "text": "et dæmonia multa ejiciebant, et ungebant oleo multos ægros, et sanabant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Mark 6:14",
      "text": "Et audivit rex Herodes (manifestum enim factum est nomen ejus), et dicebat: Quia Joannes Baptista resurrexit a mortuis: et propterea virtutes operantur in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Mark 6:15",
      "text": "Alii autem dicebant: Quia Elias est; alii vero dicebant: Quia propheta est, quasi unus ex prophetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Mark 6:16",
      "text": "Quo audito Herodes ait: Quem ego decollavi Joannem, hic a mortuis resurrexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Mark 6:17",
      "text": "Ipse enim Herodes misit, ac tenuit Joannem, et vinxit eum in carcere propter Herodiadem uxorem Philippi fratris sui, quia duxerat eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Mark 6:18",
      "text": "Dicebat enim Joannes Herodi: Non licet tibi habere uxorem fratris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Mark 6:19",
      "text": "Herodias autem insidiabatur illi: et volebat occidere eum, nec poterat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Mark 6:20",
      "text": "Herodes enim metuebat Joannem, sciens eum virum justum et sanctum: et custodiebat eum, et audito eo multa faciebat, et libenter eum audiebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Mark 6:21",
      "text": "Et cum dies opportunus accidisset, Herodes natalis sui cœnam fecit principibus, et tribunis, et primis Galilææ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Mark 6:22",
      "text": "cumque introisset filia ipsius Herodiadis, et saltasset, et placuisset Herodi, simulque recumbentibus, rex ait puellæ: Pete a me quod vis, et dabo tibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Mark 6:23",
      "text": "et juravit illi: Quia quidquid petieris dabo tibi, licet dimidium regni mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Mark 6:24",
      "text": "Quæ cum exisset, dixit matri suæ: Quid petam? At illa dixit: Caput Joannis Baptistæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Mark 6:25",
      "text": "Cumque introisset statim cum festinatione ad regem, petivit dicens: Volo ut protinus des mihi in disco caput Joannis Baptistæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Mark 6:26",
      "text": "Et contristatus est rex: propter jusjurandum, et propter simul discumbentes, noluit eam contristare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Mark 6:27",
      "text": "sed misso spiculatore præcepit afferri caput ejus in disco. Et decollavit eum in carcere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Mark 6:28",
      "text": "et attulit caput ejus in disco: et dedit illud puellæ, et puella dedit matri suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Mark 6:29",
      "text": "Quo audito, discipuli ejus venerunt, et tulerunt corpus ejus: et posuerunt illud in monumento.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Mark 6:30",
      "text": "Et convenientes Apostoli ad Jesum, renuntiaverunt ei omnia quæ egerant, et docuerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Mark 6:31",
      "text": "Et ait illis: Venite seorsum in desertum locum, et requiescite pusillum. Erant enim qui veniebant et redibant multi: et nec spatium manducandi habebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Mark 6:32",
      "text": "Et ascendentes in navim, abierunt in desertum locum seorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Mark 6:33",
      "text": "Et viderunt eos abeuntes, et cognoverunt multi: et pedestres de omnibus civitatibus concurrerunt illuc, et prævenerunt eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Mark 6:34",
      "text": "Et exiens vidit turbam multam Jesus: et misertus est super eos, quia erant sicut oves non habentes pastorem, et cœpit docere multa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Mark 6:35",
      "text": "Et cum jam hora multa fieret, accesserunt discipuli ejus, dicentes: Desertus est locus hic, et jam hora præteriit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "Mark 6:36",
      "text": "dimitte illos, ut euntes in proximas villas et vicos, emant sibi cibos, quos manducent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "Mark 6:37",
      "text": "Et respondens ait illis: Date illis vos manducare. Et dixerunt ei: Euntes emamus ducentis denariis panes, et dabimus illis manducare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "Mark 6:38",
      "text": "Et dicit eis: Quot panes habetis? ite, et videte. Et cum cognovissent, dicunt: Quinque, et duos pisces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "Mark 6:39",
      "text": "Et præcepit illis ut accumbere facerent omnes secundum contubernia super viride fœnum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.40",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 40,
      "referenceLabel": "Mark 6:40",
      "text": "Et discubuerunt in partes per centenos et quinquagenos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.41",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 41,
      "referenceLabel": "Mark 6:41",
      "text": "Et acceptis quinque panibus et duobus piscibus, intuens in cælum, benedixit, et fregit panes, et dedit discipulis suis, ut ponerent ante eos: et duos pisces divisit omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.42",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 42,
      "referenceLabel": "Mark 6:42",
      "text": "Et manducaverunt omnes, et saturati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.43",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 43,
      "referenceLabel": "Mark 6:43",
      "text": "Et sustulerunt reliquias, fragmentorum duodecim cophinos plenos, et de piscibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.44",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 44,
      "referenceLabel": "Mark 6:44",
      "text": "Erant autem qui manducaverunt quinque millia virorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.45",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 45,
      "referenceLabel": "Mark 6:45",
      "text": "Et statim coëgit discipulos suos ascendere navim, ut præcederent eum trans fretum ad Bethsaidam, dum ipse dimitteret populum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.46",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 46,
      "referenceLabel": "Mark 6:46",
      "text": "Et cum dimisisset eos, abiit in montem orare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.47",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 47,
      "referenceLabel": "Mark 6:47",
      "text": "Et cum sero esset, erat navis in medio mari et ipse solus in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.48",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 48,
      "referenceLabel": "Mark 6:48",
      "text": "Et videns eos laborantes in remigando (erat enim ventus contrarius eis) et circa quartam vigiliam noctis venit ad eos ambulans supra mare: et volebat præterire eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.49",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 49,
      "referenceLabel": "Mark 6:49",
      "text": "At illi ut viderunt eum ambulantem supra mare, putaverunt phantasma esse, et exclamaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.50",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 50,
      "referenceLabel": "Mark 6:50",
      "text": "Omnes enim viderunt eum, et conturbati sunt. Et statim locutus est cum eis, et dixit eis: Confidite, ego sum: nolite timere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.51",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 51,
      "referenceLabel": "Mark 6:51",
      "text": "Et ascendit ad illos in navim, et cessavit ventus. Et plus magis intra se stupebant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.52",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 52,
      "referenceLabel": "Mark 6:52",
      "text": "non enim intellexerunt de panibus: erat enim cor eorum obcæcatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.53",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 53,
      "referenceLabel": "Mark 6:53",
      "text": "Et cum transfretassent, venerunt in terram Genesareth, et applicuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.54",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 54,
      "referenceLabel": "Mark 6:54",
      "text": "Cumque egressi essent de navi, continuo cognoverunt eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.55",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 55,
      "referenceLabel": "Mark 6:55",
      "text": "et percurrentes universam regionem illam, cœperunt in grabatis eos, qui se male habebant, circumferre, ubi audiebant eum esse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.6.56",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 56,
      "referenceLabel": "Mark 6:56",
      "text": "Et quocumque introibat, in vicos, vel in villas aut civitates, in plateis ponebant infirmos, et deprecabantur eum, ut vel fimbriam vestimenti ejus tangerent, et quotquot tangebant eum, salvi fiebant.",
      "paragraphStart": false
    }
  ]
}
