{
  "chapter": {
    "id": "vulgate:mark.8",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 8,
    "referenceLabel": "Mark 8",
    "summary": "Source text for Mark 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.8.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Mark 8:1",
      "text": "In diebus illis iterum cum turba multa esset, nec haberent quod manducarent, convocatis discipulis, ait illis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.8.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Mark 8:2",
      "text": "Misereor super turbam: quia ecce jam triduo sustinent me, nec habent quod manducent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Mark 8:3",
      "text": "et si dimisero eos jejunos in domum suam, deficient in via: quidam enim ex eis de longe venerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Mark 8:4",
      "text": "Et responderunt ei discipuli sui: Unde illos quis poterit saturare panibus in solitudine?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Mark 8:5",
      "text": "Et interrogavit eos: Quot panes habetis? Qui dixerunt: Septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Mark 8:6",
      "text": "Et præcepit turbæ discumbere super terram. Et accipiens septem panes, gratias agens fregit, et dabat discipulis suis ut apponerent, et apposuerunt turbæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Mark 8:7",
      "text": "Et habebant pisciculos paucos: et ipsos benedixit, et jussit apponi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Mark 8:8",
      "text": "Et manducaverunt, et saturati sunt, et sustulerunt quod superaverat de fragmentis, septem sportas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Mark 8:9",
      "text": "Erant autem qui manducaverunt, quasi quatuor millia: et dimisit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Mark 8:10",
      "text": "Et statim ascendens navim cum discipulis suis, venit in partes Dalmanutha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Mark 8:11",
      "text": "Et exierunt pharisæi, et cœperunt conquirere cum eo, quærentes ab illo signum de cælo, tentantes eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Mark 8:12",
      "text": "Et ingemiscens spiritu, ait: Quid generatio ista signum quærit? Amen dico vobis, si dabitur generationi isti signum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Mark 8:13",
      "text": "Et dimittens eos, ascendit iterum navim et abiit trans fretum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Mark 8:14",
      "text": "Et obliti sunt panes sumere: et nisi unum panem non habebant secum in navi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Mark 8:15",
      "text": "Et præcipiebat eis, dicens: Videte, et cavete a fermento pharisæorum, et fermento Herodis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Mark 8:16",
      "text": "Et cogitabant ad alterutrum, dicentes: quia panes non habemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Mark 8:17",
      "text": "Quo cognito, ait illis Jesus: Quid cogitatis, quia panes non habetis? nondum cognoscetis nec intelligitis? adhuc cæcatum habetis cor vestrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Mark 8:18",
      "text": "oculos habentes non videtis? et aures habentes non auditis? nec recordamini,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Mark 8:19",
      "text": "quando quinque panes fregi in quinque millia: quot cophinos fragmentorum plenos sustulistis? Dicunt ei: Duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Mark 8:20",
      "text": "Quando et septem panes in quatuor millia: quot sportas fragmentorum tulistis? Et dicunt ei: Septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Mark 8:21",
      "text": "Et dicebat eis: Quomodo nondum intelligitis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Mark 8:22",
      "text": "Et veniunt Bethsaidam, et adducunt ei cæcum, et rogabant eum ut illum tangeret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Mark 8:23",
      "text": "Et apprehensa manu cæci, eduxit eum extra vicum: et exspuens in oculos ejus impositis manibus suis, interrogavit eum si quid videret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Mark 8:24",
      "text": "Et aspiciens, ait: Video homines velut arbores ambulantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Mark 8:25",
      "text": "Deinde iterum imposuit manus super oculos ejus: et cœpit videre: et restitutus est ita ut clare videret omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Mark 8:26",
      "text": "Et misit illum in domum suam, dicens: Vade in domum tuam: et si in vicum introieris, nemini dixeris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Mark 8:27",
      "text": "Et egressus est Jesus, et discipuli ejus in castella Cæsareæ Philippi: et in via interrogabat discipulos suos, dicens eis: Quem me dicunt esse homines?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Mark 8:28",
      "text": "Qui responderunt illi, dicentes: Joannem Baptistam, alii Eliam, alii vero quasi unum de prophetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Mark 8:29",
      "text": "Tunc dicit illis: Vos vero quem me esse dicitis? Respondens Petrus, ait ei: Tu es Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Mark 8:30",
      "text": "Et comminatus est eis, ne cui dicerent de illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Mark 8:31",
      "text": "Et cœpit docere eos quoniam oportet Filium hominis pati multa, et reprobari a senioribus, et a summis sacerdotibus et scribis, et occidi: et post tres dies resurgere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Mark 8:32",
      "text": "Et palam verbum loquebatur. Et apprehendens eum Petrus, cœpit increpare eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Mark 8:33",
      "text": "Qui conversus, et videns discipulos suos, comminatus est Petro, dicens: Vade retro me Satana, quoniam non sapis quæ Dei sunt, sed quæ sunt hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Mark 8:34",
      "text": "Et convocata turba cum discipulis suis, dixit eis: Si quis vult me sequi, deneget semetipsum: et tollat crucem suam, et sequatur me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Mark 8:35",
      "text": "Qui enim voluerit animam suam salvam facere, perdet eam: qui autem perdiderit animam suam propter me, et Evangelium, salvam faciet eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Mark 8:36",
      "text": "Quid enim proderit homini, si lucretur mundum totum et detrimentum animæ suæ faciat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "Mark 8:37",
      "text": "Aut quid dabit homo commutationis pro anima sua?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "Mark 8:38",
      "text": "Qui enim me confusus fuerit, et verba mea in generatione ista adultera et peccatrice, et Filius hominis confundetur eum, cum venerit in gloria Patris sui cum angelis sanctis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.8.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "Mark 8:39",
      "text": "Et dicebat illis: Amen dico vobis, quia sunt quidam de hic stantibus, qui non gustabunt mortem donec videant regnum Dei veniens in virtute.",
      "paragraphStart": false
    }
  ]
}
