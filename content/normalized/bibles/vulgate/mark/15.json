{
  "chapter": {
    "id": "vulgate:mark.15",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 15,
    "referenceLabel": "Mark 15",
    "summary": "Source text for Mark 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.15.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Mark 15:1",
      "text": "Et confestim mane consilium facientes summi sacerdotes cum senioribus, et scribis, et universo concilio, vincientes Jesum, duxerunt, et tradiderunt Pilato.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.15.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Mark 15:2",
      "text": "Et interrogavit eum Pilatus: Tu es rex Judæorum? At ille respondens, ait illi: Tu dicis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Mark 15:3",
      "text": "Et accusabant eum summi sacerdotes in multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Mark 15:4",
      "text": "Pilatus autem rursum interrogavit eum, dicens: Non respondes quidquam? vide in quantis te accusant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Mark 15:5",
      "text": "Jesus autem amplius nihil respondit, ita ut miraretur Pilatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Mark 15:6",
      "text": "Per diem autem festum solebat dimittere illis unum ex vinctis, quemcumque petissent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Mark 15:7",
      "text": "Erat autem qui dicebatur Barrabas, qui cum seditiosis erat vinctus, qui in seditione fecerat homicidium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Mark 15:8",
      "text": "Et cum ascendisset turba, cœpit rogare, sicut semper faciebat illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Mark 15:9",
      "text": "Pilatus autem respondit eis, et dixit: Vultis dimittam vobis regem Judæorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Mark 15:10",
      "text": "Sciebat enim quod per invidiam tradidissent eum summi sacerdotes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Mark 15:11",
      "text": "Pontifices autem concitaverunt turbam, ut magis Barabbam dimitteret eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Mark 15:12",
      "text": "Pilatus autem iterum respondens, ait illis: Quid ergo vultis faciam regi Judæorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Mark 15:13",
      "text": "At illi iterum clamaverunt: Crucifige eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Mark 15:14",
      "text": "Pilatus vero dicebat illis: Quid enim mali fecit? At illi magis clamabant: Crucifige eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Mark 15:15",
      "text": "Pilatus autem volens populo satisfacere, dimisit illis Barabbam, et tradidit Jesum flagellis cæsum, ut crucifigeretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Mark 15:16",
      "text": "Milites autem duxerunt eum in atrium prætorii, et convocant totam cohortem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Mark 15:17",
      "text": "et induunt eum purpura, et imponunt ei plectentes spineam coronam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Mark 15:18",
      "text": "Et cœperunt salutare eum: Ave rex Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Mark 15:19",
      "text": "Et percutiebant caput ejus arundine: et conspuebant eum, et ponentes genua, adorabant eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Mark 15:20",
      "text": "Et postquam illuserunt ei, exuerunt illum purpura, et induerunt eum vestimentis suis: et educunt illum ut crucifigerent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Mark 15:21",
      "text": "Et angariaverunt prætereuntem quempiam, Simonem Cyrenæum venientem de villa, patrem Alexandri et Rufi, ut tolleret crucem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Mark 15:22",
      "text": "Et perducunt illum in Golgotha locum: quod est interpretatum Calvariæ locus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Mark 15:23",
      "text": "Et dabant ei bibere myrrhatum vinum: et non accepit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Mark 15:24",
      "text": "Et crucifigentes eum, diviserunt vestimenta ejus, mittentes sortem super eis, quis quid tolleret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Mark 15:25",
      "text": "Erat autem hora tertia: et crucifixerunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Mark 15:26",
      "text": "Et erat titulus causæ ejus inscriptus: Rex Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Mark 15:27",
      "text": "Et cum eo crucifigunt duos latrones: unum a dextris, et alium a sinistris ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Mark 15:28",
      "text": "Et impleta est Scriptura, quæ dicit: Et cum iniquis reputatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Mark 15:29",
      "text": "Et prætereuntes blasphemabant eum, moventes capita sua, et dicentes: Vah! qui destruis templum Dei, et in tribus diebus reædificas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Mark 15:30",
      "text": "salvum fac temetipsum descendens de cruce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Mark 15:31",
      "text": "Similiter et summi sacerdotes illudentes, ad alterutrum cum scribis dicebant: Alios salvos fecit; seipsum non potest salvum facere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Mark 15:32",
      "text": "Christus rex Israël descendat nunc de cruce, ut videamus, et credamus. Et qui cum eo crucifixi erant, convitiabantur ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Mark 15:33",
      "text": "Et facta hora sexta, tenebræ factæ sunt per totam terram usque in horam nonam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Mark 15:34",
      "text": "Et hora nona exclamavit Jesus voce magna, dicens: Eloi, eloi, lamma sabacthani? quod est interpretatum: Deus meus, Deus meus, ut quid dereliquisti me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Mark 15:35",
      "text": "Et quidam de circumstantibus audientes, dicebant: Ecce Eliam vocat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Mark 15:36",
      "text": "Currens autem unus, et implens spongiam aceto, circumponensque calamo, potum dabat ei, dicens: Sinite, videamus si veniat Elias ad deponendum eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Mark 15:37",
      "text": "Jesus autem emissa voce magna expiravit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Mark 15:38",
      "text": "Et velum templi scissum est in duo, a summo usque deorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Mark 15:39",
      "text": "Videns autem centurio, qui ex adverso stabat, quia sic clamans expirasset, ait: Vere hic homo Filius Dei erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.40",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "Mark 15:40",
      "text": "Erant autem et mulieres de longe aspicientes: inter quas erat Maria Magdalene, et Maria Jacobi minoris, et Joseph mater, et Salome:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.41",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 41,
      "referenceLabel": "Mark 15:41",
      "text": "et cum esset in Galilæa, sequebantur eum, et ministrabant ei, et aliæ multæ, quæ simul cum eo ascenderant Jerosolymam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.42",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 42,
      "referenceLabel": "Mark 15:42",
      "text": "Et cum jam sero esset factum (quia erat parasceve, quod est ante sabbatum),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.43",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 43,
      "referenceLabel": "Mark 15:43",
      "text": "venit Joseph ab Arimathæa nobilis decurio, qui et ipse erat exspectans regnum Dei, et audacter introivit ad Pilatum, et petiit corpus Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.44",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 44,
      "referenceLabel": "Mark 15:44",
      "text": "Pilatus autem mirabatur si jam obiisset. Et accersito centurione, interrogavit eum si jam mortuus esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.45",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 45,
      "referenceLabel": "Mark 15:45",
      "text": "Et cum cognovisset a centurione, donavit corpus Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.46",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 46,
      "referenceLabel": "Mark 15:46",
      "text": "Joseph autem mercatus sindonem, et deponens eum involvit sindone, et posuit eum in monumento quod erat excisum de petra, et advolvit lapidem ad ostium monumenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.15.47",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 47,
      "referenceLabel": "Mark 15:47",
      "text": "Maria autem Magdalene et Maria Joseph aspiciebant ubi poneretur.",
      "paragraphStart": false
    }
  ]
}
