{
  "chapter": {
    "id": "vulgate:mark.3",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 3,
    "referenceLabel": "Mark 3",
    "summary": "Source text for Mark 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.3.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Mark 3:1",
      "text": "Et introivit iterum in synagogam: et erat ibi homo habens manum aridam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.3.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Mark 3:2",
      "text": "Et observabant eum, si sabbatis curaret, ut accusarent illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Mark 3:3",
      "text": "Et ait homini habenti manum aridam: Surge in medium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Mark 3:4",
      "text": "Et dicit eis: Licet sabbatis benefacere, an male? animam salvam facere, an perdere? At illi tacebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Mark 3:5",
      "text": "Et circumspiciens eos cum ira, contristatus super cæcitate cordis eorum, dicit homini: Extende manum tuam. Et extendit, et restituta est manus illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Mark 3:6",
      "text": "Exeuntes autem pharisæi, statim cum Herodianis consilium faciebant adversus eum quomodo eum perderent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Mark 3:7",
      "text": "Jesus autem cum discipulis suis secessit ad mare: et multa turba a Galilæa et Judæa secuta est eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Mark 3:8",
      "text": "et ab Jerosolymis, et ab Idumæa, et trans Jordanem: et qui circa Tyrum et Sidonem multitudo magna, audientes quæ faciebat, venerunt ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Mark 3:9",
      "text": "Et dicit discipulis suis ut navicula sibi deserviret propter turbam, ne comprimerent eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Mark 3:10",
      "text": "multos enim sanabat, ita ut irruerent in eum ut illum tangerent, quotquot habebant plagas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Mark 3:11",
      "text": "Et spiritus immundi, cum illum videbant, procidebant ei: et clamabant, dicentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Mark 3:12",
      "text": "Tu es Filius Dei. Et vehementer comminabatur eis ne manifestarent illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Mark 3:13",
      "text": "Et ascendens in montem vocavit ad se quos voluit ipse: et venerunt ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Mark 3:14",
      "text": "Et fecit ut essent duodecim cum illo: et ut mitteret eos prædicare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Mark 3:15",
      "text": "Et dedit illis potestatem curandi infirmitates et ejiciendi dæmonia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Mark 3:16",
      "text": "Et imposuit Simoni nomen Petrus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Mark 3:17",
      "text": "et Jacobum Zebedæi, et Joannem fratrem Jacobi, et imposuit eis nomina Boanerges, quod est, Filii tonitrui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Mark 3:18",
      "text": "et Andræam, et Philippum, et Bartholomæum, et Matthæum, et Thomam, et Jacobum Alphæi, et Thaddæum, et Simonem Cananæum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Mark 3:19",
      "text": "et Judam Iscariotem, qui et tradidit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Mark 3:20",
      "text": "Et veniunt ad domum: et convenit iterum turba, ita ut non possent neque panem manducare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Mark 3:21",
      "text": "Et cum audissent sui, exierunt tenere eum: dicebant enim: Quoniam in furorem versus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Mark 3:22",
      "text": "Et scribæ, qui ab Jerosolymis descenderant, dicebant: Quoniam Beelzebub habet, et quia in principe dæmoniorum ejicit dæmonia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Mark 3:23",
      "text": "Et convocatis eis in parabolis dicebat illis: Quomodo potest Satanas Satanam ejicere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Mark 3:24",
      "text": "Et si regnum in se dividatur, non potest regnum illud stare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Mark 3:25",
      "text": "Et si domus super semetipsam dispertiatur, non potest domus illa stare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Mark 3:26",
      "text": "Et si Satanas consurrexerit in semetipsum, dispertitus est, et non poterit stare, sed finem habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Mark 3:27",
      "text": "Nemo potest vasa fortis ingressus in domum diripere, nisi prius fortem alliget, et tunc domum ejus diripiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Mark 3:28",
      "text": "Amen dico vobis, quoniam omnia dimittentur filiis hominum peccata, et blasphemiæ quibus blasphemaverint:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Mark 3:29",
      "text": "qui autem blasphemaverit in Spiritum Sanctum, non habebit remissionem in æternum, sed reus erit æterni delicti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Mark 3:30",
      "text": "Quoniam dicebant: Spiritum immundum habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Mark 3:31",
      "text": "Et veniunt mater ejus et fratres: et foris stantes miserunt ad eum vocantes eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Mark 3:32",
      "text": "et sedebat circa eum turba: et dicunt ei: Ecce mater tua et fratres tui foris quærunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Mark 3:33",
      "text": "Et respondens eis, ait: Quæ est mater mea et fratres mei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Mark 3:34",
      "text": "Et circumspiciens eos, qui in circuitu ejus sedebant, ait: Ecce mater mea et fratres mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.3.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Mark 3:35",
      "text": "Qui enim fecerit voluntatem Dei, hic frater meus, et soror mea, et mater est.",
      "paragraphStart": false
    }
  ]
}
