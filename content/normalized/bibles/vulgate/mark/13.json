{
  "chapter": {
    "id": "vulgate:mark.13",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 13,
    "referenceLabel": "Mark 13",
    "summary": "Source text for Mark 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.13.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Mark 13:1",
      "text": "Et cum egrederetur de templo, ait illi unus ex discipulis suis: Magister, aspice quales lapides, et quales structuræ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.13.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Mark 13:2",
      "text": "Et respondens Jesus, ait illi: Vides has omnes magnas ædificationes? Non relinquetur lapis super lapidem, qui non destruatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Mark 13:3",
      "text": "Et cum sederet in monte Olivarum contra templum, interrogabant eum separatim Petrus, et Jacobus, et Joannes, et Andreas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Mark 13:4",
      "text": "Dic nobis, quando ista fient? et quod signum erit, quando hæc omnia incipient consummari?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Mark 13:5",
      "text": "Et respondens Jesus cœpit dicere illis: Videte ne quid vos seducat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Mark 13:6",
      "text": "multi enim venient in nomine meo, dicentes quia ego sum: et multos seducent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Mark 13:7",
      "text": "Cum audieritis autem bella, et opiniones bellorum, ne timueritis: oportet enim hæc fieri: sed nondum finis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Mark 13:8",
      "text": "Exsurget enim gens contra gentem, et regnum super regnum, et erunt terræmotus per loca, et fames. Initium dolorum hæc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Mark 13:9",
      "text": "Videte autem vosmetipsos. Tradent enim vos in consiliis, et in synagogis vapulabitis, et ante præsides et reges stabitis propter me, in testimonium illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Mark 13:10",
      "text": "Et in omnes gentes primum oportet prædicari Evangelium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Mark 13:11",
      "text": "Et cum duxerint vos tradentes, nolite præcogitare quid loquamini: sed quod datum vobis fuerit in illa hora, id loquimini: non enim vos estis loquentes, sed Spiritus Sanctus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Mark 13:12",
      "text": "Tradet autem frater fratrem in mortem, et pater filium: et consurgent filii in parentes, et morte afficient eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Mark 13:13",
      "text": "Et eritis odio omnibus propter nomen meum. Qui autem sustinuerit in finem, hic salvus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Mark 13:14",
      "text": "Cum autem videritis abominationem desolationis stantem, ubi non debet, qui legit, intelligat: tunc qui in Judæa sunt, fugiant in montes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Mark 13:15",
      "text": "et qui super tectum, ne descendat in domum, nec introëat ut tollat quid de domo sua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Mark 13:16",
      "text": "et qui in agro erit, non revertatur retro tollere vestimentum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Mark 13:17",
      "text": "Væ autem prægnantibus et nutrientibus in illis diebus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Mark 13:18",
      "text": "Orate vero ut hieme non fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Mark 13:19",
      "text": "Erunt enim dies illi tribulationes tales quales non fuerunt ab initio creaturæ, quam condidit Deus usque nunc, neque fient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Mark 13:20",
      "text": "Et nisi breviasset Dominus dies, non fuisset salva omnis caro: sed propter electos, quos elegit, breviavit dies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Mark 13:21",
      "text": "Et tunc si quis vobis dixerit: Ecce hic est Christus, ecce illic, ne credideritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Mark 13:22",
      "text": "Exsurgent enim pseudochristi et pseudoprophetæ, et dabunt signa et portenta ad seducendos, si fieri potest, etiam electos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Mark 13:23",
      "text": "Vos ergo videte: ecce prædixi vobis omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Mark 13:24",
      "text": "Sed in illis diebus, post tribulationem illam, sol contenebrabitur, et luna non dabit splendorem suum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Mark 13:25",
      "text": "et stellæ cæli erunt decidentes, et virtutes, quæ in cælis sunt, movebuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Mark 13:26",
      "text": "Et tunc videbunt Filium hominis venientem in nubibus cum virtute multa et gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Mark 13:27",
      "text": "Et tunc mittet angelos suos, et congregabit electos suos a quatuor ventis, a summo terræ usque ad summum cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Mark 13:28",
      "text": "A ficu autem discite parabolam. Cum jam ramus ejus tener fuerit, et nata fuerint folia, cognoscitis quia in proximo sit æstas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Mark 13:29",
      "text": "sic et vos cum videritis hæc fieri, scitote quod in proximo sit, in ostiis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Mark 13:30",
      "text": "Amen dico vobis, quoniam non transibit generatio hæc, donec omnia ista fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Mark 13:31",
      "text": "Cælum et terra transibunt, verba autem mea non transibunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Mark 13:32",
      "text": "De die autem illo vel hora nemo scit, neque angeli in cælo, neque Filius, nisi Pater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Mark 13:33",
      "text": "Videte, vigilate, et orate: nescitis enim quando tempus sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Mark 13:34",
      "text": "Sicut homo qui peregre profectus reliquit domum suam, et dedit servis suis potestatem cujusque operis, et janitori præcepit ut vigilet,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "Mark 13:35",
      "text": "vigilate ergo (nescitis enim quando dominus domus veniat: sero, an media nocte, an galli cantu, an mane),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "Mark 13:36",
      "text": "ne, cum venerit repente, inveniat vos dormientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.13.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "Mark 13:37",
      "text": "Quod autem vobis dico, omnibus dico: Vigilate.",
      "paragraphStart": false
    }
  ]
}
