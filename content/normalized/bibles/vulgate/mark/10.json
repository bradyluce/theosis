{
  "chapter": {
    "id": "vulgate:mark.10",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 10,
    "referenceLabel": "Mark 10",
    "summary": "Source text for Mark 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.10.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Mark 10:1",
      "text": "Et inde exsurgens venit in fines Judææ ultra Jordanem: et conveniunt iterum turbæ ad eum: et sicut consueverat, iterum docebat illos.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.10.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Mark 10:2",
      "text": "Et accedentes pharisæi interrogabant eum: Si licet viro uxorem dimittere: tentantes eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Mark 10:3",
      "text": "At ille respondens, dixit eis: Quid vobis præcepit Moyses?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Mark 10:4",
      "text": "Qui dixerunt: Moyses permisit libellum repudii scribere, et dimittere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Mark 10:5",
      "text": "Quibus respondens Jesus, ait: Ad duritiam cordis vestri scripsit vobis præceptum istud:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Mark 10:6",
      "text": "ab initio autem creaturæ masculum et feminam fecit eos Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Mark 10:7",
      "text": "Propter hoc relinquet homo patrem suum et matrem, et adhærebit ad uxorem suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Mark 10:8",
      "text": "et erunt duo in carne una. Itaque jam non sunt duo, sed una caro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Mark 10:9",
      "text": "Quod ergo Deus conjunxit, homo non separet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Mark 10:10",
      "text": "Et in domo iterum discipuli ejus de eodem interrogaverunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Mark 10:11",
      "text": "Et ait illis: Quicumque dimiserit uxorem suam, et aliam duxerit, adulterium committit super eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Mark 10:12",
      "text": "Et si uxor dimiserit virum suum, et alii nupserit, mœchatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Mark 10:13",
      "text": "Et offerebant illi parvulos ut tangeret illos. Discipuli autem comminabantur offerentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Mark 10:14",
      "text": "Quos cum videret Jesus, indigne tulit, et ait illis: Sinite parvulos venire ad me, et ne prohibueritis eos: talium enim est regnum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Mark 10:15",
      "text": "Amen dico vobis: Quisquis non receperit regnum Dei velut parvulus, non intrabit in illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Mark 10:16",
      "text": "Et complexans eos, et imponens manus super illos, benedicebat eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Mark 10:17",
      "text": "Et cum egressus esset in viam, procurrens quidam genu flexo ante eum, rogabat eum: Magister bone, quid faciam ut vitam æternam percipiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Mark 10:18",
      "text": "Jesus autem dixit ei: Quid me dicis bonum? nemo bonus, nisi unus Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Mark 10:19",
      "text": "Præcepta nosti: ne adulteres, ne occidas, ne fureris, ne falsum testimonium dixeris, ne fraudem feceris, honora patrem tuum et matrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Mark 10:20",
      "text": "At ille respondens, ait illi: Magister, hæc omnia observavi a juventute mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Mark 10:21",
      "text": "Jesus autem intuitus eum, dilexit eum, et dixit ei: Unum tibi deest: vade, quæcumque habes vende, et da pauperibus, et habebis thesaurum in cælo: et veni, sequere me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Mark 10:22",
      "text": "Qui contristatus in verbo, abiit mœrens: erat enim habens multas possessiones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Mark 10:23",
      "text": "Et circumspiciens Jesus, ait discipulis suis: Quam difficile qui pecunias habent, in regnum Dei introibunt!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Mark 10:24",
      "text": "Discipuli autem obstupescebant in verbis ejus. At Jesus rursus respondens ait illis: Filioli, quam difficile est, confidentes in pecuniis, in regnum Dei introire!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Mark 10:25",
      "text": "Facilius est camelum per foramen acus transire, quam divitem intrare in regnum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Mark 10:26",
      "text": "Qui magis admirabantur, dicentes ad semetipsos: Et quis potest salvus fieri?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Mark 10:27",
      "text": "Et intuens illos Jesus, ait: Apud homines impossibile est, sed non apud Deum: omnia enim possibilia sunt apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Mark 10:28",
      "text": "Et cœpit ei Petrus dicere: Ecce nos dimisimus omnia, et secuti sumus te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Mark 10:29",
      "text": "Respondens Jesus, ait: Amen dico vobis: Nemo est qui reliquerit domum, aut fratres, aut sorores, aut patrem, aut matrem, aut filios, aut agros propter me et propter Evangelium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Mark 10:30",
      "text": "qui non accipiat centies tantum, nunc in tempore hoc: domos, et fratres, et sorores, et matres, et filios, et agros, cum persecutionibus, et in sæculo futuro vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Mark 10:31",
      "text": "Multi autem erunt primi novissimi, et novissimi primi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Mark 10:32",
      "text": "Erant autem in via ascendentes Jerosolymam: et præcedebat illos Jesus, et stupebant: et sequentes timebant. Et assumens iterum duodecim, cœpit illis dicere quæ essent ei eventura.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Mark 10:33",
      "text": "Quia ecce ascendimus Jerosolymam, et Filius hominis tradetur principibus sacerdotum, et scribis, et senioribus, et damnabunt eum morte, et tradent eum gentibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Mark 10:34",
      "text": "et illudent ei, et conspuent eum, et flagellabunt eum, et interficient eum: et tertia die resurget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Mark 10:35",
      "text": "Et accedunt ad eum Jacobus et Joannes filii Zebedæi, dicentes: Magister, volumus ut quodcumque petierimus, facias nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Mark 10:36",
      "text": "At ille dixit eis: Quid vultis ut faciam vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Mark 10:37",
      "text": "Et dixerunt: Da nobis ut unus ad dexteram tuam, et alius ad sinistram tuam sedeamus in gloria tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Mark 10:38",
      "text": "Jesus autem ait eis: Nescitis quid petatis: potestis bibere calicem, quem ego bibo, aut baptismo, quo ego baptizor, baptizari?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Mark 10:39",
      "text": "At illi dixerunt ei: Possumus. Jesus autem ait eis: Calicem quidem, quem ego bibo, bibetis; et baptismo, quo ego baptizor, baptizabimini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.40",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 40,
      "referenceLabel": "Mark 10:40",
      "text": "sedere autem ad dexteram meam, vel ad sinistram, non est meum dare vobis, sed quibus paratum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.41",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 41,
      "referenceLabel": "Mark 10:41",
      "text": "Et audientes decem, cœperunt indignari de Jacobo et Joanne.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.42",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 42,
      "referenceLabel": "Mark 10:42",
      "text": "Jesus autem vocans eos, ait illis: Scitis quia hi, qui videntur principari gentibus, dominantur eis: et principes eorum potestatem habent ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.43",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 43,
      "referenceLabel": "Mark 10:43",
      "text": "Non ita est autem in vobis, sed quicumque voluerit fieri major, erit vester minister:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.44",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 44,
      "referenceLabel": "Mark 10:44",
      "text": "et quicumque voluerit in vobis primus esse, erit omnium servus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.45",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 45,
      "referenceLabel": "Mark 10:45",
      "text": "Nam et Filius hominis non venit ut ministraretur ei, sed ut ministraret, et daret animam suam redemptionem pro multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.46",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 46,
      "referenceLabel": "Mark 10:46",
      "text": "Et veniunt Jericho: et proficiscente eo de Jericho, et discipulis ejus, et plurima multitudine, filius Timæi Bartimæus cæcus, sedebat juxta viam mendicans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.47",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 47,
      "referenceLabel": "Mark 10:47",
      "text": "Qui cum audisset quia Jesus Nazarenus est, cœpit clamare, et dicere: Jesu fili David, miserere mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.48",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 48,
      "referenceLabel": "Mark 10:48",
      "text": "Et comminabantur ei multi ut taceret. At ille multo magis clamabat: Fili David, miserere mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.49",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 49,
      "referenceLabel": "Mark 10:49",
      "text": "Et stans Jesus præcepit illum vocari. Et vocant cæcum, dicentes ei: Animæquior esto: surge, vocat te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.50",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 50,
      "referenceLabel": "Mark 10:50",
      "text": "Qui projecto vestimento suo exiliens, venit ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.51",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 51,
      "referenceLabel": "Mark 10:51",
      "text": "Et respondens Jesus dixit illi: Quid tibi vis faciam? Cæcus autem dixit ei: Rabboni, ut videam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.10.52",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 52,
      "referenceLabel": "Mark 10:52",
      "text": "Jesus autem ait illi: Vade, fides tua te salvum fecit. Et confestim vidit, et sequebatur eum in via.",
      "paragraphStart": false
    }
  ]
}
