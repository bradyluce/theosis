{
  "chapter": {
    "id": "vulgate:mark.11",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 11,
    "referenceLabel": "Mark 11",
    "summary": "Source text for Mark 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.11.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Mark 11:1",
      "text": "Et cum appropinquarent Jerosolymæ et Bethaniæ ad montem Olivarum, mittit duos ex discipulis suis,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.11.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Mark 11:2",
      "text": "et ait illis: Ite in castellum, quod contra vos est, et statim introëuntes illuc, invenietis pullum ligatum, super quem nemo adhuc hominum sedit: solvite illum, et adducite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Mark 11:3",
      "text": "Et si quis vobis dixerit: Quid facitis? dicite, quia Domino necessarius est: et continuo illum dimittet huc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Mark 11:4",
      "text": "Et abeuntes invenerunt pullum ligatum ante januam foris in bivio: et solvunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Mark 11:5",
      "text": "Et quidam de illic stantibus dicebant illis: Quid facitis solventes pullum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Mark 11:6",
      "text": "Qui dixerunt eis sicut præceperat illis Jesus, et dimiserunt eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Mark 11:7",
      "text": "Et duxerunt pullum ad Jesum: et imponunt illi vestimenta sua, et sedit super eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Mark 11:8",
      "text": "Multi autem vestimenta sua straverunt in via: alii autem frondes cædebant de arboribus, et sternebant in via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Mark 11:9",
      "text": "Et qui præibant, et qui sequebantur, clamabant, dicentes: Hosanna: benedictus qui venit in nomine Domini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Mark 11:10",
      "text": "benedictum quod venit regnum patris nostri David: hosanna in excelsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Mark 11:11",
      "text": "Et introivit Jerosolymam in templum: et circumspectis omnibus, cum jam vespera esset hora, exiit in Bethaniam cum duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Mark 11:12",
      "text": "Et alia die cum exirent a Bethania, esuriit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Mark 11:13",
      "text": "Cumque vidisset a longe ficum habentem folia, venit si quid forte inveniret in ea: et cum venisset ad eam, nihil invenit præter folia: non enim erat tempus ficorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Mark 11:14",
      "text": "Et respondens dixit ei: Jam non amplius in æternum ex te fructum quisquam manducet. Et audiebant discipuli ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Mark 11:15",
      "text": "Et veniunt in Jerosolymam. Et cum introisset in templum, cœpit ejicere vendentes et ementes in templo: et mensas numulariorum, et cathedras vendentium columbas evertit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Mark 11:16",
      "text": "et non sinebat ut quisquam transferret vas per templum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Mark 11:17",
      "text": "et docebat, dicens eis: Nonne scriptum est: Quia domus mea, domus orationis vocabitur omnibus gentibus? vos autem fecistis eam speluncam latronum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Mark 11:18",
      "text": "Quo audito principes sacerdotum et scribæ, quærebant quomodo eum perderent: timebant enim eum, quoniam universa turba admirabatur super doctrina ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Mark 11:19",
      "text": "Et cum vespera facta esset, egrediebatur de civitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Mark 11:20",
      "text": "Et cum mane transirent, viderunt ficum aridam factam a radicibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Mark 11:21",
      "text": "Et recordatus Petrus, dixit ei: Rabbi, ecce ficus, cui maledixisti, aruit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Mark 11:22",
      "text": "Et respondens Jesus ait illis: Habete fidem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Mark 11:23",
      "text": "Amen dico vobis, quia quicumque dixerit huic monti: Tollere, et mittere in mare, et non hæsitaverit in corde suo, sed crediderit, quia quodcumque dixerit fiat, fiet ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Mark 11:24",
      "text": "Propterea dico vobis, omnia quæcumque orantes petitis, credite quia accipietis, et evenient vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Mark 11:25",
      "text": "Et cum stabitis ad orandum, dimittite si quis habetis adversus aliquem: ut et Pater vester, qui in cælis est, dimittat vobis peccata vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Mark 11:26",
      "text": "Quod si vos non dimiseritis: nec Pater vester, qui in cælis est, dimittet vobis peccata vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Mark 11:27",
      "text": "Et veniunt rursus Jerosolymam. Et cum ambularet in templo, accedunt ad eum summi sacerdotes, et scribæ, et seniores:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Mark 11:28",
      "text": "et dicunt ei: In qua potestate hæc facis? et quis dedit tibi hanc potestatem ut ista facias?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Mark 11:29",
      "text": "Jesus autem respondens, ait illis: Interrogabo vos et ego unum verbum, et respondete mihi: et dicam vobis in qua potestate hæc faciam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Mark 11:30",
      "text": "Baptismus Joannis, de cælo erat, an ex hominibus? Respondete mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Mark 11:31",
      "text": "At illi cogitabant secum, dicentes: Si dixerimus: De cælo, dicet: Quare ergo non credidistis ei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Mark 11:32",
      "text": "Si dixerimus: Ex hominibus, timemus populum: omnes enim habebant Joannem quia vere propheta esset.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.11.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Mark 11:33",
      "text": "Et respondentes dicunt Jesu: Nescimus. Et respondens Jesus ait illis: Neque ego dico vobis in qua potestate hæc faciam.",
      "paragraphStart": false
    }
  ]
}
