{
  "chapter": {
    "id": "vulgate:mark.14",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 14,
    "referenceLabel": "Mark 14",
    "summary": "Source text for Mark 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.14.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Mark 14:1",
      "text": "Erat autem Pascha et azyma post biduum: et quærebant summi sacerdotes et scribæ quomodo eum dolo tenerent, et occiderent.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.14.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Mark 14:2",
      "text": "Dicebant autem: Non in die festo, ne forte tumultus fieret in populo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Mark 14:3",
      "text": "Et cum esset Bethaniæ in domo Simonis leprosi, et recumberet, venit mulier habens alabastrum unguenti nardi spicati pretiosi: et fracto alabastro, effudit super caput ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Mark 14:4",
      "text": "Erant autem quidam indigne ferentes intra semetipsos, et dicentes: Ut quid perditio ista unguenti facta est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Mark 14:5",
      "text": "poterat enim unguentum istud venundari plus quam trecentis denariis, et dari pauperibus. Et fremebant in eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Mark 14:6",
      "text": "Jesus autem dixit: Sinite eam, quid illi molesti estis? Bonum opus operata est in me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Mark 14:7",
      "text": "semper enim pauperes habetis vobiscum: et cum volueritis, potestis illis benefacere: me autem non semper habetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Mark 14:8",
      "text": "Quod habuit hæc, fecit: prævenit ungere corpus meum in sepulturam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Mark 14:9",
      "text": "Amen dico vobis: Ubicumque prædicatum fuerit Evangelium istud in universo mundo, et quod fecit hæc, narrabitur in memoriam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Mark 14:10",
      "text": "Et Judas Iscariotes, unus de duodecim, abiit ad summos sacerdotes, ut proderet eum illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Mark 14:11",
      "text": "Qui audientes gavisi sunt: et promiserunt ei pecuniam se daturos. Et quærebat quomodo illum opportune traderet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Mark 14:12",
      "text": "Et primo die azymorum quando Pascha immolabant, dicunt ei discipuli: Quo vis eamus, et paremus tibi ut manduces Pascha?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Mark 14:13",
      "text": "Et mittit duos ex discipulis suis, et dicit eis: Ite in civitatem, et occurret vobis homo lagenam aquæ bajulans: sequimini eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Mark 14:14",
      "text": "et quocumque introierit, dicite domino domus, quia magister dicit: Ubi est refectio mea, ubi Pascha cum discipulis meis manducem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Mark 14:15",
      "text": "Et ipse vobis demonstrabit cœnaculum grande, stratum: et illic parate nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Mark 14:16",
      "text": "Et abierunt discipuli ejus, et venerunt in civitatem: et invenerunt sicut dixerat illis, et paraverunt Pascha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Mark 14:17",
      "text": "Vespere autem facto, venit cum duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Mark 14:18",
      "text": "Et discumbentibus eis, et manducantibus, ait Jesus: Amen dico vobis, quia unus ex vobis tradet me, qui manducat mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Mark 14:19",
      "text": "At illi cœperunt contristari, et dicere ei singulatim: Numquid ego?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Mark 14:20",
      "text": "Qui ait illis: Unus ex duodecim, qui intingit mecum manum in catino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Mark 14:21",
      "text": "Et Filius quidem hominis vadit sicut scriptum est de eo: væ autem homini illi per quem Filius hominis tradetur! bonum erat ei, si non esset natus homo ille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Mark 14:22",
      "text": "Et manducantibus illis, accepit Jesus panem: et benedicens fregit, et dedit eis, et ait: Sumite, hoc est corpus meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Mark 14:23",
      "text": "Et accepto calice, gratias agens dedit eis: et biberunt ex illo omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Mark 14:24",
      "text": "Et ait illis: Hic est sanguis meus novi testamenti, qui pro multis effundetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Mark 14:25",
      "text": "Amen dico vobis, quia jam non bibam de hoc genimine vitis usque in diem illum, cum illud bibam novum in regno Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Mark 14:26",
      "text": "Et hymno dicto exierunt in montem Olivarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Mark 14:27",
      "text": "Et ait eis Jesus: Omnes scandalizabimini in me in nocte ista: quia scriptum est: Percutiam pastorem, et dispergentur oves.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Mark 14:28",
      "text": "Sed postquam resurrexero, præcedam vos in Galilæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Mark 14:29",
      "text": "Petrus autem ait illi: Et si omnes scandalizati fuerint in te, sed non ego.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Mark 14:30",
      "text": "Et ait illi Jesus: Amen dico tibi, quia tu hodie in nocte hac, priusquam gallus vocem bis dederit, ter me es negaturus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Mark 14:31",
      "text": "At ille amplius loquebatur: Et si oportuerit me simul commori tibi, non te negabo. Similiter autem et omnes dicebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Mark 14:32",
      "text": "Et veniunt in prædium, cui nomen Gethsemani. Et ait discipulis suis: Sedete hic donec orem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Mark 14:33",
      "text": "Et assumit Petrum, et Jacobum, et Joannem secum: et cœpit pavere et tædere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Mark 14:34",
      "text": "Et ait illis: Tristis est anima mea usque ad mortem: sustinete hic, et vigilate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Mark 14:35",
      "text": "Et cum processisset paululum, procidit super terram, et orabat ut, si fieri posset, transiret ab eo hora.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Mark 14:36",
      "text": "Et dixit: Abba pater, omnia tibi possibilia sunt: transfer calicem hunc a me: sed non quod ego volo, sed quod tu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 37,
      "referenceLabel": "Mark 14:37",
      "text": "Et venit, et invenit eos dormientes. Et ait Petro: Simon, dormis? non potuisti una hora vigilare?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 38,
      "referenceLabel": "Mark 14:38",
      "text": "vigilate et orate, ut non intretis in tentationem. Spiritus quidem promptus est, caro vero infirma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 39,
      "referenceLabel": "Mark 14:39",
      "text": "Et iterum abiens oravit, eumdem sermonem dicens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.40",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 40,
      "referenceLabel": "Mark 14:40",
      "text": "Et reversus, denuo invenit eos dormientes (erant enim oculi eorum gravati), et ignorabant quid responderent ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.41",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 41,
      "referenceLabel": "Mark 14:41",
      "text": "Et venit tertio, et ait illis: Dormite jam, et requiescite. Sufficit: venit hora: ecce Filius hominis tradetur in manus peccatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.42",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 42,
      "referenceLabel": "Mark 14:42",
      "text": "Surgite, eamus: ecce qui me tradet, prope est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.43",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 43,
      "referenceLabel": "Mark 14:43",
      "text": "Et, adhuc eo loquente, venit Judas Iscariotes unus de duodecim, et cum eo turba multa cum gladiis et lignis, a summis sacerdotibus, et scribis, et senioribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.44",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 44,
      "referenceLabel": "Mark 14:44",
      "text": "Dederat autem traditor ejus signum eis, dicens: Quemcumque osculatus fuero, ipse est, tenete eum, et ducite caute.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.45",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 45,
      "referenceLabel": "Mark 14:45",
      "text": "Et cum venisset, statim accedens ad eum, ait: Ave Rabbi: et osculatus est eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.46",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 46,
      "referenceLabel": "Mark 14:46",
      "text": "At illi manus injecerunt in eum, et tenuerunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.47",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 47,
      "referenceLabel": "Mark 14:47",
      "text": "Unus autem quidam de circumstantibus educens gladium, percussit servum summi sacerdotis, et amputavit illi auriculam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.48",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 48,
      "referenceLabel": "Mark 14:48",
      "text": "Et respondens Jesus, ait illis: Tamquam ad latronem existis cum gladiis et lignis comprehendere me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.49",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 49,
      "referenceLabel": "Mark 14:49",
      "text": "quotidie eram apud vos in templo docens, et non me tenuistis. Sed ut impleantur Scripturæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.50",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 50,
      "referenceLabel": "Mark 14:50",
      "text": "Tunc discipuli ejus relinquentes eum, omnes fugerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.51",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 51,
      "referenceLabel": "Mark 14:51",
      "text": "Adolescens autem quidam sequebatur eum amictus sindone super nudo: et tenuerunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.52",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 52,
      "referenceLabel": "Mark 14:52",
      "text": "At ille rejecta sindone, nudus profugit ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.53",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 53,
      "referenceLabel": "Mark 14:53",
      "text": "Et adduxerunt Jesum ad summum sacerdotem: et convenerunt omnes sacerdotes, et scribæ, et seniores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.54",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 54,
      "referenceLabel": "Mark 14:54",
      "text": "Petrus autem a longe secutus est eum usque intro in atrium summi sacerdotis: et sedebat cum ministris ad ignem, et calefaciebat se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.55",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 55,
      "referenceLabel": "Mark 14:55",
      "text": "Summi vero sacerdotes et omne concilium quærebant adversus Jesum testimonium ut eum morti traderent: nec inveniebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.56",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 56,
      "referenceLabel": "Mark 14:56",
      "text": "Multi enim testimonium falsum dicebant adversus eum: et convenientia testimonia non erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.57",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 57,
      "referenceLabel": "Mark 14:57",
      "text": "Et quidam surgentes, falsum testimonium ferebant adversus eum, dicentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.58",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 58,
      "referenceLabel": "Mark 14:58",
      "text": "Quoniam nos audivimus eum dicentem: Ego dissolvam templum hoc manu factum, et per triduum aliud non manu factum ædificabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.59",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 59,
      "referenceLabel": "Mark 14:59",
      "text": "Et non erat conveniens testimonium illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.60",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 60,
      "referenceLabel": "Mark 14:60",
      "text": "Et exsurgens summus sacerdos in medium, interrogavit Jesum, dicens: Non respondes quidquam ad ea quæ tibi objiciuntur ab his?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.61",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 61,
      "referenceLabel": "Mark 14:61",
      "text": "Ille autem tacebat, et nihil respondit. Rursum summus sacerdos interrogabat eum, et dixit ei: Tu es Christus Filius Dei benedicti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.62",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 62,
      "referenceLabel": "Mark 14:62",
      "text": "Jesus autem dixit illi: Ego sum: et videbitis Filium hominis sedentem a dextris virtutis Dei, et venientem cum nubibus cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.14.63",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 63,
      "referenceLabel": "Mark 14:63",
      "text": "Summus autem sacerdos scindens vestimenta sua, ait: Quid adhuc desideramus testes?",
      "paragraphStart": false
