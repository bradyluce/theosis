      "id": "vulgate:mark.14.64",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 64,
      "referenceLabel": "Mark 14:64",
      "text": "Audistis blasphemiam: quid vobis videtur? Qui omnes condemnaverunt eum esse reum mortis.",
      "paragraphStart": false
