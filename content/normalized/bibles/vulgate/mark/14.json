      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 67,
      "referenceLabel": "Mark 14:67",
      "text": "et cum vidisset Petrum calefacientem se, aspiciens illum, ait: Et tu cum Jesu Nazareno eras.",
      "paragraphStart": false
