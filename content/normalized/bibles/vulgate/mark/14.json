      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 69,
      "referenceLabel": "Mark 14:69",
      "text": "Rursus autem cum vidisset illum ancilla, cœpit dicere circumstantibus: Quia hic ex illis est.",
