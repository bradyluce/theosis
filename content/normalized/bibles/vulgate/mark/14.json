    {
      "id": "vulgate:mark.14.68",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 68,
      "referenceLabel": "Mark 14:68",
      "text": "At ille negavit, dicens: Neque scio, neque novi quid dicas. Et exiit foras ante atrium, et gallus cantavit.",
      "paragraphStart": false
