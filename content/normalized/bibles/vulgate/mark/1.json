{
  "chapter": {
    "id": "vulgate:mark.1",
    "translationId": "vulgate",
    "bookSlug": "mark",
    "chapterNumber": 1,
    "referenceLabel": "Mark 1",
    "summary": "Source text for Mark 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:mark.1.1",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Mark 1:1",
      "text": "Initium Evangelii Jesu Christi, Filii Dei.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:mark.1.2",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Mark 1:2",
      "text": "Sicut scriptum est in Isaia propheta: Ecce ego mitto angelum meum ante faciem tuam, qui præparabit viam tuam ante te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.3",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Mark 1:3",
      "text": "Vox clamantis in deserto: Parate viam Domini, rectas facite semitas ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.4",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Mark 1:4",
      "text": "Fuit Joannes in deserto baptizans, et prædicans baptismum pœnitentiæ in remissionem peccatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.5",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Mark 1:5",
      "text": "Et egrediebatur ad eum omnis Judææ regio, et Jerosolymitæ universi, et baptizabantur ab illo in Jordanis flumine, confitentes peccata sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.6",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Mark 1:6",
      "text": "Et erat Joannes vestitus pilis cameli, et zona pellicea circa lumbos ejus, et locustas et mel silvestre edebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.7",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Mark 1:7",
      "text": "Et prædicabat dicens: Venit fortior me post me, cujus non sum dignus procumbens solvere corrigiam calceamentorum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.8",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Mark 1:8",
      "text": "Ego baptizavi vos aqua, ille vero baptizabit vos Spiritu Sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.9",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Mark 1:9",
      "text": "Et factum est: in diebus illis venit Jesus a Nazareth Galilææ: et baptizatus est a Joanne in Jordane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.10",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Mark 1:10",
      "text": "Et statim ascendens de aqua, vidit cælos apertos, et Spiritum tamquam columbam descendentem, et manentem in ipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.11",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Mark 1:11",
      "text": "Et vox facta est de cælis: Tu es Filius meus dilectus, in te complacui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.12",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Mark 1:12",
      "text": "Et statim Spiritus expulit eum in desertum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.13",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Mark 1:13",
      "text": "Et erat in deserto quadraginta diebus, et quadraginta noctibus: et tentabatur a Satana: eratque cum bestiis, et angeli ministrabant illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.14",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Mark 1:14",
      "text": "Postquam autem traditus est Joannes, venit Jesus in Galilæam, prædicans Evangelium regni Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.15",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Mark 1:15",
      "text": "et dicens: Quoniam impletum est tempus, et appropinquavit regnum Dei: pœnitemini, et credite Evangelio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.16",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Mark 1:16",
      "text": "Et præteriens secus mare Galilææ, vidit Simonem, et Andream fratrem ejus, mittentes retia in mare (erant enim piscatores),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.17",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Mark 1:17",
      "text": "et dixit eis Jesus: Venite post me, et faciam vos fieri piscatores hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.18",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Mark 1:18",
      "text": "Et protinus relictis retibus, secuti sunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.19",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Mark 1:19",
      "text": "Et progressus inde pusillum, vidit Jacobum Zebedæi, et Joannem fratrem ejus, et ipsos componentes retia in navi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.20",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Mark 1:20",
      "text": "et statim vocavit illos. Et relicto patre suo Zebedæo in navi cum mercenariis, secuti sunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.21",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Mark 1:21",
      "text": "Et ingrediuntur Capharnaum: et statim sabbatis ingressus in synagogam, docebat eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.22",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Mark 1:22",
      "text": "Et stupebant super doctrina ejus: erat enim docens eos quasi potestatem habens, et non sicut scribæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.23",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Mark 1:23",
      "text": "Et erat in synagoga eorum homo in spiritu immundo: et exclamavit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.24",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Mark 1:24",
      "text": "dicens: Quid nobis et tibi, Jesu Nazarene? venisti perdere nos? scio qui sis, Sanctus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.25",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Mark 1:25",
      "text": "Et comminatus est ei Jesus, dicens: Obmutesce, et exi de homine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.26",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Mark 1:26",
      "text": "Et discerpens eum spiritus immundus, et exclamans voce magna, exiit ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.27",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Mark 1:27",
      "text": "Et mirati sunt omnes, ita ut conquirerent inter se dicentes: Quidnam est hoc? quænam doctrina hæc nova? quia in potestate etiam spiritibus immundis imperat, et obediunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.28",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Mark 1:28",
      "text": "Et processit rumor ejus statim in omnem regionem Galilææ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.29",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Mark 1:29",
      "text": "Et protinus egredientes de synagoga, venerunt in domum Simonis et Andreæ, cum Jacobo et Joanne.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.30",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Mark 1:30",
      "text": "Decumbebat autem socrus Simonis febricitans: et statim dicunt ei de illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.31",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Mark 1:31",
      "text": "Et accedens elevavit eam, apprehensa manu ejus: et continuo dimisit eam febris, et ministrabat eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.32",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Mark 1:32",
      "text": "Vespere autem facto cum occidisset sol, afferebant ad eum omnes male habentes, et dæmonia habentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.33",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Mark 1:33",
      "text": "et erat omnis civitas congregata ad januam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.34",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Mark 1:34",
      "text": "Et curavit multos, qui vexabantur variis languoribus, et dæmonia multa ejiciebat, et non sinebat ea loqui, quoniam sciebant eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.35",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Mark 1:35",
      "text": "Et diluculo valde surgens, egressus abiit in desertum locum, ibique orabat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.36",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Mark 1:36",
      "text": "Et prosecutus est eum Simon, et qui cum illo erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.37",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Mark 1:37",
      "text": "Et cum invenissent eum, dixerunt ei: Quia omnes quærunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.38",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Mark 1:38",
      "text": "Et ait illis: Eamus in proximos vicos, et civitates, ut et ibi prædicem: ad hoc enim veni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.39",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Mark 1:39",
      "text": "Et erat prædicans in synagogis eorum, et in omni Galilæa, et dæmonia ejiciens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.40",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Mark 1:40",
      "text": "Et venit ad eum leprosus deprecans eum: et genu flexo dixit ei: Si vis, potes me mundare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.41",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "Mark 1:41",
      "text": "Jesus autem misertus ejus, extendit manum suam: et tangens eum, ait illi: Volo: mundare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.42",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "Mark 1:42",
      "text": "Et cum dixisset, statim discessit ab eo lepra, et mundatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.43",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "Mark 1:43",
      "text": "Et comminatus est ei, statimque ejecit illum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.44",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "Mark 1:44",
      "text": "et dicit ei: Vide nemini dixeris: sed vade, ostende te principi sacerdotum, et offer pro emundatione tua, quæ præcepit Moyses in testimonium illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:mark.1.45",
      "translationId": "vulgate",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "Mark 1:45",
      "text": "At ille egressus cœpit prædicare, et diffamare sermonem, ita ut jam non posset manifeste introire in civitatem, sed foris in desertis locis esset, et conveniebant ad eum undique.",
      "paragraphStart": false
    }
  ]
}
