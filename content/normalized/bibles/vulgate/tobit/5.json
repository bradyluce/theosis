{
  "chapter": {
    "id": "vulgate:tobit.5",
    "translationId": "vulgate",
    "bookSlug": "tobit",
    "chapterNumber": 5,
    "referenceLabel": "Tobit 5",
    "summary": "Source text for Tobit 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:tobit.5.1",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Tobit 5:1",
      "text": "Tunc respondit Tobias patri suo, et dixit: Omnia quæcumque præcepisti mihi faciam, pater.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:tobit.5.2",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Tobit 5:2",
      "text": "Quomodo autem pecuniam hanc requiram, ignoro: ille me nescit, et ego eum ignoro: quod signum dabo ei? sed neque viam per quam pergatur illuc aliquando cognovi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.3",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Tobit 5:3",
      "text": "Tunc pater suus respondit illi, et dixit: Chirographum quidem illius penes me habeo: quod dum illi ostenderis, statim restituet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.4",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Tobit 5:4",
      "text": "Sed perge nunc, et inquire tibi aliquem fidelem virum, qui eat tecum salva mercede sua, ut dum adhuc vivo, recipias eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.5",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Tobit 5:5",
      "text": "Tunc egressus Tobias, invenit juvenem splendidum stantem præcinctum, et quasi paratum ad ambulandum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.6",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Tobit 5:6",
      "text": "Et ignorans quod angelus Dei esset, salutavit eum, et dixit: Unde te habemus, bone juvenis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.7",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Tobit 5:7",
      "text": "At ille respondit: Ex filiis Israël. Et Tobias dixit ei: Nosti viam quæ ducit in regionem Medorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.8",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Tobit 5:8",
      "text": "Cui respondit: Novi: et omnia itinera ejus frequenter ambulavi, et mansi apud Gabelum fratrem nostrum, qui moratur in Rages civitate Medorum, quæ posita est in monte Ecbatanis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.9",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Tobit 5:9",
      "text": "Cui Tobias ait: Sustine me obsecro, donec hæc ipsa nuntiem patri meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.10",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Tobit 5:10",
      "text": "Tunc ingressus Tobias, indicavit universa hæc patri suo. Super quæ admiratus pater, rogavit ut introiret ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.11",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Tobit 5:11",
      "text": "Ingressus itaque salutavit eum, et dixit: Gaudium tibi sit semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.12",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Tobit 5:12",
      "text": "Et ait Tobias: Quale gaudium mihi erit, qui in tenebris sedeo, et lumen cæli non video?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.13",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Tobit 5:13",
      "text": "Cui ait juvenis: Forti animo esto: in proximo est ut a Deo cureris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.14",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Tobit 5:14",
      "text": "Dixit itaque illi Tobias: Numquid poteris perducere filium meum ad Gabelum in Rages civitatem Medorum? et cum redieris, restituam tibi mercedem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.15",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Tobit 5:15",
      "text": "Et dixit ei angelus: Ego ducam, et reducam eum ad te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.16",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Tobit 5:16",
      "text": "Cui Tobias respondit: Rogo te, indica mihi de qua domo aut de qua tribu es tu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.17",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Tobit 5:17",
      "text": "Cui Raphaël angelus dixit: Genus quæris mercenarii, an ipsum mercenarium qui cum filio tuo eat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.18",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Tobit 5:18",
      "text": "sed ne forte sollicitum te reddam, ego sum Azarias Ananiæ magni filius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.19",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Tobit 5:19",
      "text": "Et Tobias respondit: Ex magno genere es tu. Sed peto ne irascaris quod voluerim cognoscere genus tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.20",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Tobit 5:20",
      "text": "Dixit autem illi angelus: Ego sanum ducam, et sanum tibi reducam filium tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.21",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Tobit 5:21",
      "text": "Respondens autem Tobias, ait: Bene ambuletis, et sit Deus in itinere vestro, et angelus ejus comitetur vobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.22",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Tobit 5:22",
      "text": "Tunc paratis omnibus quæ erant in via portanda, fecit Tobias vale patri suo et matri suæ, et ambulaverunt ambo simul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.23",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Tobit 5:23",
      "text": "Cumque profecti essent, cœpit mater ejus flere, et dicere: Baculum senectutis nostræ tulisti, et transmisisti a nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.24",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Tobit 5:24",
      "text": "Numquam fuisset ipsa pecunia, pro qua misisti eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.25",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Tobit 5:25",
      "text": "sufficiebat enim nobis paupertas nostra, ut divitias computaremus hoc, quod videbamus filium nostrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.26",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Tobit 5:26",
      "text": "Dixitque ei Tobias: Noli flere: salvus perveniet filius noster, et salvus revertetur ad nos, et oculi tui videbunt illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.27",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Tobit 5:27",
      "text": "Credo enim quod angelus Dei bonus comitetur ei, et bene disponat omnia quæ circa eum geruntur, ita ut cum gaudio revertatur ad nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:tobit.5.28",
      "translationId": "vulgate",
      "bookSlug": "tobit",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Tobit 5:28",
      "text": "Ad hanc vocem cessavit mater ejus flere, et tacuit.",
      "paragraphStart": false
    }
  ]
}
