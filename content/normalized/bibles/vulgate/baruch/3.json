{
  "chapter": {
    "id": "vulgate:baruch.3",
    "translationId": "vulgate",
    "bookSlug": "baruch",
    "chapterNumber": 3,
    "referenceLabel": "Baruch 3",
    "summary": "Source text for Baruch 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:baruch.3.1",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Baruch 3:1",
      "text": "Et nunc, Domine omnipotens, Deus Israël, anima in angustiis, et spiritus anxius clamat ad te.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:baruch.3.2",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Baruch 3:2",
      "text": "Audi, Domine, et miserere, quia Deus es misericors: et miserere nostri, quia peccavimus ante te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.3",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Baruch 3:3",
      "text": "quia tu sedes in sempiternum, et nos, peribimus in ævum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.4",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Baruch 3:4",
      "text": "Domine omnipotens, Deus Israël, audi nunc orationem mortuorum Israël, et filiorum ipsorum qui peccaverunt ante te, et non audierunt vocem Domini Dei sui, et agglutinata sunt nobis mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.5",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Baruch 3:5",
      "text": "Noli meminisse iniquitatum patrum nostrorum, sed memento manus tuæ et nominis tui in tempore isto:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.6",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Baruch 3:6",
      "text": "quia tu es Dominus Deus noster, et laudabimus te, Domine:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.7",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Baruch 3:7",
      "text": "quia propter hoc dedisti timorem tuum in cordibus nostris, et ut invocemus nomen tuum, et laudemus te in captivitate nostra, quia convertimur ab iniquitate patrum nostrorum, qui peccaverunt ante te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.8",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Baruch 3:8",
      "text": "Et ecce nos in captivitate nostra sumus hodie, qua nos dispersisti in improperium, et in maledictum, et in peccatum, secundum omnes iniquitates patrum nostrorum, qui recesserunt a te, Domine Deus noster.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.9",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Baruch 3:9",
      "text": "Audi, Israël, mandata vitæ: auribus percipe, ut scias prudentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.10",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Baruch 3:10",
      "text": "Quid est, Israël, quod in terra inimicorum es,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.11",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Baruch 3:11",
      "text": "inveterasti in terra aliena, coinquinatus es cum mortuis, deputatus es cum descendentibus in infernum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.12",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Baruch 3:12",
      "text": "Dereliquisti fontem sapientiæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.13",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Baruch 3:13",
      "text": "nam si in via Dei ambulasses, habitasses utique in pace sempiterna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.14",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Baruch 3:14",
      "text": "Disce ubi sit prudentia, ubi sit virtus, ubi sit intellectus, ut scias simul ubi sit longiturnitas vitæ et victus, ubi sit lumen oculorum, et pax.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.15",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Baruch 3:15",
      "text": "Quis invenit locum ejus? et quis intravit in thesauros ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.16",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Baruch 3:16",
      "text": "Ubi sunt principes gentium, et qui dominantur super bestias quæ sunt super terram?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.17",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Baruch 3:17",
      "text": "qui in avibus cæli ludunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.18",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Baruch 3:18",
      "text": "qui argentum thesaurizant, et aurum, in quo confidunt homines, et non est finis acquisitionis eorum? qui argentum fabricant, et solliciti sunt, nec est inventio operum illorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.19",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Baruch 3:19",
      "text": "Exterminati sunt, et ad inferos descenderunt, et alii loco eorum surrexerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.20",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Baruch 3:20",
      "text": "Juvenes viderunt lumen, et habitaverunt super terram, viam autem disciplinæ ignoraverunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.21",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Baruch 3:21",
      "text": "neque intellexerunt semitas ejus, neque filii eorum susceperunt eam: a facie ipsorum longe facta est;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.22",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Baruch 3:22",
      "text": "non est audita in terra Chanaan, neque visa est in Theman.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.23",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Baruch 3:23",
      "text": "Filii quoque Agar, qui exquirunt prudentiam quæ de terra est, negotiatores Merrhæ et Theman, et fabulatores, et exquisitores prudentiæ et intelligentiæ: viam autem sapientiæ nescierunt, neque commemorati sunt semitas ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.24",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Baruch 3:24",
      "text": "O Israël, quam magna est domus Dei, et ingens locus possessionis ejus!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.25",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Baruch 3:25",
      "text": "magnus est, et non habet finem: excelsus, et immensus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.26",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Baruch 3:26",
      "text": "Ibi fuerunt gigantes nominati illi, qui ab initio fuerunt, statura magna, scientes bellum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.27",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Baruch 3:27",
      "text": "Non hos elegit Dominus, neque viam disciplinæ invenerunt: propterea perierunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.28",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Baruch 3:28",
      "text": "et quoniam non habuerunt sapientiam, interierunt propter suam insipientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.29",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Baruch 3:29",
      "text": "Quis ascendit in cælum, et accepit eam, et eduxit eam de nubibus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.30",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Baruch 3:30",
      "text": "Quis transfretavit mare, et invenit illam, et attulit illam super aurum electum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.31",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Baruch 3:31",
      "text": "Non est qui possit scire vias ejus, neque qui exquirat semitas ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.32",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Baruch 3:32",
      "text": "sed qui scit universa novit eam, et adinvenit eam prudentia sua qui præparavit terram in æterno tempore: et replevit eam pecudibus et quadrupedibus",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.33",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Baruch 3:33",
      "text": "qui emittit lumen, et vadit, et vocavit illud, et obedit illi in tremore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.34",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Baruch 3:34",
      "text": "Stellæ autem dederunt lumen in custodiis suis, et lætatæ sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.35",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Baruch 3:35",
      "text": "vocatæ sunt, et dixerunt: Adsumus, et luxerunt ei cum jucunditate, qui fecit illas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.36",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Baruch 3:36",
      "text": "Hic est Deus noster, et non æstimabitur alius adversus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.37",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Baruch 3:37",
      "text": "Hic adinvenit omnem viam disciplinæ, et tradidit illam Jacob puero suo, et Israël dilecto suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:baruch.3.38",
      "translationId": "vulgate",
      "bookSlug": "baruch",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Baruch 3:38",
      "text": "Post hæc in terris visus est, et cum hominibus conversatus est.",
      "paragraphStart": false
    }
  ]
}
