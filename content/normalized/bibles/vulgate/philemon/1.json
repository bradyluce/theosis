{
  "chapter": {
    "id": "vulgate:philemon.1",
    "translationId": "vulgate",
    "bookSlug": "philemon",
    "chapterNumber": 1,
    "referenceLabel": "Philemon 1",
    "summary": "Source text for Philemon 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:philemon.1.1",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Philemon 1:1",
      "text": "Paulus vinctus Christi Jesu, et Timotheus frater, Philemoni dilecto, et adjutori nostro,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:philemon.1.2",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Philemon 1:2",
      "text": "et Appiæ sorori carissimæ, et Archippo commilitoni nostro, et ecclesiæ, quæ in domo tua est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.3",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Philemon 1:3",
      "text": "Gratia vobis, et pax a Deo Patre nostro, et Domino Jesu Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.4",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Philemon 1:4",
      "text": "Gratias ago Deo meo, semper memoriam tui faciens in orationibus meis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.5",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Philemon 1:5",
      "text": "audiens caritatem tuam, et fidem, quam habes in Domino Jesu, et in omnes sanctos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.6",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Philemon 1:6",
      "text": "ut communicatio fidei tuæ evidens fiat in agnitione omnis operis boni, quod est in vobis in Christo Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.7",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Philemon 1:7",
      "text": "Gaudium enim magnum habui, et consolationem in caritate tua: quia viscera sanctorum requieverunt per te, frater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.8",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Philemon 1:8",
      "text": "Propter quod multam fiduciam habens in Christo Jesu imperandi tibi quod ad rem pertinet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.9",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Philemon 1:9",
      "text": "propter caritatem magis obsecro, cum sis talis, ut Paulus senex, nunc autem et vinctus Jesu Christi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.10",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Philemon 1:10",
      "text": "obsecro te pro meo filio, quem genui in vinculis, Onesimo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.11",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Philemon 1:11",
      "text": "qui tibi aliquando inutilis fuit, nunc autem et mihi et tibi utilis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.12",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Philemon 1:12",
      "text": "quem remisi tibi. Tu autem illum, ut mea viscera, suscipe:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.13",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Philemon 1:13",
      "text": "quem ego volueram mecum detinere, ut pro te mihi ministraret in vinculis Evangelii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.14",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Philemon 1:14",
      "text": "sine consilio autem tuo nihil volui facere, uti ne velut ex necessitate bonum tuum esset, sed voluntarium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.15",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Philemon 1:15",
      "text": "Forsitan enim ideo discessit ad horam a te, ut æternum illum reciperes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.16",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Philemon 1:16",
      "text": "jam non ut servum, sed pro servo carissimum fratrem, maxime mihi: quanto autem magis tibi et in carne, et in Domino?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.17",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Philemon 1:17",
      "text": "Si ergo habes me socium, suscipe illum sicut me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.18",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Philemon 1:18",
      "text": "si autem aliquid nocuit tibi, aut debet, hoc mihi imputa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.19",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Philemon 1:19",
      "text": "Ego Paulus scripsi mea manu: ego reddam, ut non dicam tibi, quod et teipsum mihi debes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.20",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Philemon 1:20",
      "text": "ita, frater. Ego te fruar in Domino: refice viscera mea in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.21",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Philemon 1:21",
      "text": "Confidens in obedientia tua scripsi tibi: sciens quoniam et super id, quod dico, facies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.22",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Philemon 1:22",
      "text": "Simul autem et para mihi hospitium: nam spero per orationes vestras donari me vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.23",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Philemon 1:23",
      "text": "Salutat te Epaphras concaptivus meus in Christo Jesu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.24",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Philemon 1:24",
      "text": "Marcus, Aristarchus, Demas, et Lucas, adjutores mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:philemon.1.25",
      "translationId": "vulgate",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Philemon 1:25",
      "text": "Gratia Domini nostri Jesu Christi cum spiritu vestro. Amen.",
      "paragraphStart": false
    }
  ]
}
