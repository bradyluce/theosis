{
  "chapter": {
    "id": "vulgate:judith.16",
    "translationId": "vulgate",
    "bookSlug": "judith",
    "chapterNumber": 16,
    "referenceLabel": "Judith 16",
    "summary": "Source text for Judith 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:judith.16.1",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Judith 16:1",
      "text": "Tunc cantavit canticum hoc Domino Judith, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:judith.16.2",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Judith 16:2",
      "text": "Incipite Domino in tympanis; cantate Domino in cymbalis; modulamini illi psalmum novum: exaltate, et invocate nomen ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.3",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Judith 16:3",
      "text": "Dominus conterens bella, Dominus nomen est illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.4",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Judith 16:4",
      "text": "Qui posuit castra sua in medio populi sui, ut eriperet nos de manu omnium inimicorum nostrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.5",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Judith 16:5",
      "text": "Venit Assur ex montibus ab aquilone in multitudine fortitudinis suæ: cujus multitudo obturavit torrentes, et equi eorum cooperuerunt valles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.6",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Judith 16:6",
      "text": "Dixit se incensurum fines meos, et juvenes meos occisurum gladio; infantes meos dare in prædam, et virgines in captivitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.7",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Judith 16:7",
      "text": "Dominus autem omnipotens nocuit eum, et tradidit eum in manus feminæ, et confodit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.8",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Judith 16:8",
      "text": "Non enim cecidit potens eorum a juvenibus, nec filii Titan percusserunt eum, nec excelsi gigantes opposuerunt se illi: sed Judith filia Merari in specie faciei suæ dissolvit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.9",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Judith 16:9",
      "text": "Exuit enim se vestimento viduitatis, et induit se vestimento lætitiæ in exultatione filiorum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.10",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Judith 16:10",
      "text": "Unxit faciem suam unguento, et colligavit cincinnos suos mitra; accepit stolam novam ad decipiendum illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.11",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Judith 16:11",
      "text": "Sandalia ejus rapuerunt oculos ejus; pulchritudo ejus captivam fecit animam ejus: amputavit pugione cervicem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.12",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Judith 16:12",
      "text": "Horruerunt Persæ constantiam ejus, et Medi audaciam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.13",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Judith 16:13",
      "text": "Tunc ululaverunt castra Assyriorum, quando apparuerunt humiles mei, arescentes in siti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.14",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Judith 16:14",
      "text": "Filii puellarum compunxerunt eos, et sicut pueros fugientes occiderunt eos: perierunt in prælio a facie Domini Dei mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.15",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Judith 16:15",
      "text": "Hymnum cantemus Domino; hymnum novum cantemus Deo nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.16",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Judith 16:16",
      "text": "Adonai Domine, magnus es tu, et præclarus in virtute tua: et quem superare nemo potest.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.17",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Judith 16:17",
      "text": "Tibi serviat omnis creatura tua, quia dixisti, et facta sunt; misisti spiritum tuum, et creata sunt: et non est qui resistat voci tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.18",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Judith 16:18",
      "text": "Montes a fundamentis movebuntur cum aquis; petræ, sicut cera, liquescent ante faciem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.19",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Judith 16:19",
      "text": "Qui autem timent te, magni erunt apud te per omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.20",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Judith 16:20",
      "text": "Væ genti insurgenti super genus meum: Dominus enim omnipotens vindicabit in eis; in die judicii visitabit illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.21",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Judith 16:21",
      "text": "Dabit enim ignem et vermes in carnes eorum, ut urantur et sentiant usque in sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.22",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Judith 16:22",
      "text": "Et factum est post hæc, omnis populus post victoriam venit in Jerusalem adorare Dominum: et mox ut purificati sunt, obtulerunt omnes holocausta, et vota, et repromissiones suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.23",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Judith 16:23",
      "text": "Porro Judith universa vasa bellica Holofernis, quæ dedit illi populus, et conopeum quod ipsa sustulerat de cubili ipsius, obtulit in anathema oblivionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.24",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Judith 16:24",
      "text": "Erat autem populus jucundus secundum faciem sanctorum: et per tres menses gaudium hujus victoriæ celebratum est cum Judith.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.25",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Judith 16:25",
      "text": "Post dies autem illos, unusquisque rediit in domum suam: et Judith magna facta est in Bethulia, et præclarior erat universæ terræ Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.26",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Judith 16:26",
      "text": "Erat enim virtuti castitas adjuncta, ita ut non cognosceret virum omnibus diebus vitæ suæ, ex quo defunctus est Manasses vir ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.27",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Judith 16:27",
      "text": "Erat autem, diebus festis, procedens cum magna gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.28",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Judith 16:28",
      "text": "Mansit autem in domo viri sui annos centum quinque, et dimisit abram suam liberam: et defuncta est ac sepulta cum viro suo in Bethulia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.29",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Judith 16:29",
      "text": "Luxitque illam omnis populus diebus septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.30",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Judith 16:30",
      "text": "In omni autem spatio vitæ ejus non fuit qui perturbaret Israël, et post mortem ejus annis multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:judith.16.31",
      "translationId": "vulgate",
      "bookSlug": "judith",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Judith 16:31",
      "text": "Dies autem victoriæ hujus festivitatis ab Hebræis in numero sanctorum dierum accipitur, et colitur a Judæis ex illo tempore usque in præsentem diem.",
      "paragraphStart": false
    }
  ]
}
