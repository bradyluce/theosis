{
  "chapter": {
    "id": "vulgate:second-thessalonians.1",
    "translationId": "vulgate",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 1,
    "referenceLabel": "2 Thessalonians 1",
    "summary": "Source text for 2 Thessalonians 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-thessalonians.1.1",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 1:1",
      "text": "Paulus, et Sylvanus, et Timotheus, ecclesiæ Thessalonicensium in Deo Patre nostro, et Domino Jesu Christo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-thessalonians.1.2",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 1:2",
      "text": "Gratia vobis, et pax a Deo Patre nostro, et Domino Jesu Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.3",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 1:3",
      "text": "Gratias agere debemus semper Deo pro vobis, fratres, ita ut dignum est, quoniam supercrescit fides vestra, et abundat caritas uniuscujusque vestrum in invicem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.4",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 1:4",
      "text": "ita ut et nos ipsi in vobis gloriemur in ecclesiis Dei, pro patientia vestra, et fide, et in omnibus persecutionibus vestris, et tribulationibus, quas sustinetis",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.5",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 1:5",
      "text": "in exemplum justi judicii Dei, ut digni habeamini in regno Dei, pro quo et patimini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.6",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 1:6",
      "text": "Si tamen justum est apud Deum retribuere tribulationem iis qui vos tribulant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.7",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 1:7",
      "text": "et vobis, qui tribulamini, requiem nobiscum in revelatione Domini Jesu de cælo cum angelis virtutis ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.8",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 1:8",
      "text": "in flamma ignis dantis vindictam iis qui non noverunt Deum, et qui non obediunt Evangelio Domini nostri Jesu Christi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.9",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 1:9",
      "text": "qui pœnas dabunt in interitu æternas a facie Domini, et a gloria virtutis ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.10",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 1:10",
      "text": "cum venerit glorificari in sanctis suis, et admirabilis fieri in omnibus, qui crediderunt, quia creditum est testimonium nostrum super vos in die illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.11",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 1:11",
      "text": "In quo etiam oramus semper pro vobis: ut dignetur vos vocatione sua Deus noster, et impleat omnem voluntatem bonitatis, et opus fidei in virtute,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.1.12",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 1:12",
      "text": "ut clarificetur nomen Domini nostri Jesu Christi in vobis, et vos in illo secundum gratiam Dei nostri, et Domini Jesu Christi.",
      "paragraphStart": false
    }
  ]
}
