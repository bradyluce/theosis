{
  "chapter": {
    "id": "vulgate:second-thessalonians.3",
    "translationId": "vulgate",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 3,
    "referenceLabel": "2 Thessalonians 3",
    "summary": "Source text for 2 Thessalonians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-thessalonians.3.1",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 3:1",
      "text": "De cetero fratres, orate pro nobis ut sermo Dei currat, et clarificetur, sicut et apud vos:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-thessalonians.3.2",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 3:2",
      "text": "et ut liberemur ab importunis, et malis hominibus: non enim omnium est fides.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.3",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 3:3",
      "text": "Fidelis autem Deus est, qui confirmabit vos, et custodiet a malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.4",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 3:4",
      "text": "Confidimus autem de vobis, in Domino, quoniam quæ præcepimus, et facitis, et facietis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.5",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 3:5",
      "text": "Dominus autem dirigat corda vestra in caritate Dei, et patientia Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.6",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 3:6",
      "text": "Denuntiamus autem vobis, fratres, in nomine Domini nostri Jesu Christi, ut subtrahatis vos ab omni fratre ambulante inordinate, et non secundum traditionem, quam acceperunt a nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.7",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 3:7",
      "text": "Ipsi enim scitis quemadmodum oporteat imitari nos: quoniam non inquieti fuimus inter vos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.8",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 3:8",
      "text": "neque gratis panem manducavimus ab aliquo, sed in labore, et in fatigatione, nocte et die operantes, ne quem vestrum gravaremus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.9",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 3:9",
      "text": "Non quasi non habuerimus potestatem, sed ut nosmetipsos formam daremus vobis ad imitandum nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.10",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 3:10",
      "text": "Nam et cum essemus apud vos, hoc denuntiabamus vobis: quoniam si quis non vult operari, nec manducet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.11",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 3:11",
      "text": "Audivimus enim inter vos quosdam ambulare inquiete, nihil operantes, sed curiose agentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.12",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 3:12",
      "text": "Iis autem, qui ejusmodi sunt, denuntiemus, et obsecramus in Domino Jesu Christo, ut cum silentio operantes, suum panem manducent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.13",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 3:13",
      "text": "Vos autem, fratres, nolite deficere benefacientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.14",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 3:14",
      "text": "Quod si quis non obedit verbo nostro per epistolam, hunc notate, et ne commisceamini cum illo ut confundatur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.15",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 3:15",
      "text": "et nolite quasi inimicum existimare, sed corripite ut fratrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.16",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 3:16",
      "text": "Ipse autem Dominus pacis det vobis pacem sempiternam in omni loco. Dominus sit cum omnibus vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.17",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 3:17",
      "text": "Salutatio, mea manu Pauli: quod est signum in omni epistola, ita scribo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.3.18",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Thessalonians 3:18",
      "text": "Gratia Domini nostri Jesu Christi cum omnibus vobis. Amen.",
      "paragraphStart": false
    }
  ]
}
