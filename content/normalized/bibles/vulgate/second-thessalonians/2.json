{
  "chapter": {
    "id": "vulgate:second-thessalonians.2",
    "translationId": "vulgate",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 2,
    "referenceLabel": "2 Thessalonians 2",
    "summary": "Source text for 2 Thessalonians 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-thessalonians.2.1",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 2:1",
      "text": "Rogamus autem vos, fratres, per adventum Domini nostri Jesu Christi, et nostræ congregationis in ipsum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-thessalonians.2.2",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 2:2",
      "text": "ut non cito moveamini a vestro sensu, neque terreamini, neque per spiritum, neque per sermonem, neque per epistolam tamquam per nos missam, quasi instet dies Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.3",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 2:3",
      "text": "Ne quis vos seducat ullo modo: quoniam nisi venerit discessio primum, et revelatus fuerit homo peccati filius perditionis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.4",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 2:4",
      "text": "qui adversatur, et extollitur supra omne, quod dicitur Deus, aut quod colitur, ita ut in templo Dei sedeat ostendens se tamquam sit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.5",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 2:5",
      "text": "Non retinetis quod cum adhuc essem apud vos, hæc dicebam vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.6",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 2:6",
      "text": "et nunc quid detineat scitis, ut reveletur in suo tempore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.7",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 2:7",
      "text": "Nam mysterium jam operatur iniquitatis: tantum ut qui tenet nunc, teneat, donec de medio fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.8",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 2:8",
      "text": "Et tunc revelabitur ille iniquus, quem Dominus Jesus interficiet spiritu oris sui, et destruet illustratione adventus sui eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.9",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 2:9",
      "text": "cujus est adventus secundum operationem Satanæ in omni virtute, et signis, et prodigiis mendacibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.10",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 2:10",
      "text": "et in omni seductione iniquitatis iis qui pereunt: eo quod caritatem veritatis non receperunt ut salvi fierent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.11",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 2:11",
      "text": "Ideo mittet illis Deus operationem erroris ut credant mendacio,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.12",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 2:12",
      "text": "ut judicentur omnes qui non crediderunt veritati, sed consenserunt iniquitati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.13",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 2:13",
      "text": "Nos autem debemus gratias agere Deo semper pro vobis, fratres dilecti a Deo, quod elegerit vos Deus primitias in salutem in sanctificatione spiritus, et in fide veritatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.14",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 2:14",
      "text": "in qua et vocavit vos per Evangelium nostrum in acquisitionem gloriæ Domini nostri Jesu Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.15",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 2:15",
      "text": "Itaque fratres, state: et tenete traditiones, quas didicistis, sive per sermonem, sive per epistolam nostram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.16",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 2:16",
      "text": "Ipse autem Dominus noster Jesus Christus, et Deus et Pater noster, qui dilexit nos, et dedit consolationem æternam, et spem bonam in gratia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-thessalonians.2.17",
      "translationId": "vulgate",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 2:17",
      "text": "exhortetur corda vestra, et confirmet in omni opere et sermone bono.",
      "paragraphStart": false
    }
  ]
}
