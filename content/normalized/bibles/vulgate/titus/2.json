{
  "chapter": {
    "id": "vulgate:titus.2",
    "translationId": "vulgate",
    "bookSlug": "titus",
    "chapterNumber": 2,
    "referenceLabel": "Titus 2",
    "summary": "Source text for Titus 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:titus.2.1",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Titus 2:1",
      "text": "Tu autem loquere quæ decent sanam doctrinam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:titus.2.2",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Titus 2:2",
      "text": "senes ut sobrii sint, pudici, prudentes, sani in fide, in dilectione, in patientia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.3",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Titus 2:3",
      "text": "anus similiter in habitu sancto, non criminatrices, non multo vino servientes, bene docentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.4",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Titus 2:4",
      "text": "ut prudentiam doceant adolescentulas, ut viros suos ament, filios suos diligant,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.5",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Titus 2:5",
      "text": "prudentes, castas, sobrias, domus curam habentes, benignas, subditas viris suis, ut non blasphemetur verbum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.6",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Titus 2:6",
      "text": "Juvenes similiter hortare ut sobrii sint.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.7",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Titus 2:7",
      "text": "In omnibus teipsum præbe exemplum bonorum operum, in doctrina, in integritate, in gravitate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.8",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Titus 2:8",
      "text": "verbum sanum, irreprehensibile: ut is qui ex adverso est, vereatur, nihil habens malum dicere de nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.9",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Titus 2:9",
      "text": "Servos dominis suis subditos esse, in omnibus placentes, non contradicentes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.10",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Titus 2:10",
      "text": "non fraudantes, sed in omnibus fidem bonam ostendentes: ut doctrinam Salvatoris nostri Dei ornent in omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.11",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Titus 2:11",
      "text": "Apparuit enim gratia Dei Salvatoris nostri omnibus hominibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.12",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Titus 2:12",
      "text": "erudiens nos, ut abnegantes impietatem, et sæcularia desideria, sobrie, et juste, et pie vivamus in hoc sæculo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.13",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Titus 2:13",
      "text": "exspectantes beatam spem, et adventum gloriæ magni Dei, et Salvatoris nostri Jesu Christi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.14",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Titus 2:14",
      "text": "qui dedit semetipsum pro nobis, ut nos redimeret ab omni iniquitate, et mundaret sibi populum acceptabilem, sectatorem bonorum operum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.2.15",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Titus 2:15",
      "text": "Hæc loquere, et exhortare, et argue cum omni imperio. Nemo te contemnat.",
      "paragraphStart": false
    }
  ]
}
