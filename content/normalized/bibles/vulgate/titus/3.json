{
  "chapter": {
    "id": "vulgate:titus.3",
    "translationId": "vulgate",
    "bookSlug": "titus",
    "chapterNumber": 3,
    "referenceLabel": "Titus 3",
    "summary": "Source text for Titus 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:titus.3.1",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Titus 3:1",
      "text": "Admone illos principibus, et potestatibus subditos esse, dicto obedire, ad omne opus bonum paratos esse:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:titus.3.2",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Titus 3:2",
      "text": "neminem blasphemare, non litigiosos esse, sed modestos, omnem ostendentes mansuetudinem ad omnes homines.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.3",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Titus 3:3",
      "text": "Eramus enim aliquando et nos insipientes, increduli, errantes, servientes desideriis, et voluptatibus variis, in malitia et invidia agentes, odibiles, odientes invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.4",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Titus 3:4",
      "text": "Cum autem benignitas et humanitas apparuit Salvatoris nostri Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.5",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Titus 3:5",
      "text": "non ex operibus justitiæ, quæ fecimus nos, sed secundum suam misericordiam salvos nos fecit per lavacrum regenerationis et renovationis Spiritus Sancti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.6",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Titus 3:6",
      "text": "quem effudit in nos abunde per Jesum Christum Salvatorem nostrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.7",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Titus 3:7",
      "text": "ut justificati gratia ipsius, hæredes simus secundum spem vitæ æternæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.8",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Titus 3:8",
      "text": "Fidelis sermo est: et de his volo te confirmare: ut curent bonis operibus præesse qui credunt Deo. Hæc sunt bona, et utilia hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.9",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Titus 3:9",
      "text": "Stultas autem quæstiones, et genealogias, et contentiones, et pugnas legis devita: sunt enim inutiles, et vanæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.10",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Titus 3:10",
      "text": "Hæreticum hominem post unam et secundam correptionem devita:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.11",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Titus 3:11",
      "text": "sciens quia subversus est, qui ejusmodi est, et delinquit, cum sit proprio judicio condemnatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.12",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Titus 3:12",
      "text": "Cum misero ad te Artemam, aut Tychicum, festina ad me venire Nicopolim: ibi enim statui hiemare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.13",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Titus 3:13",
      "text": "Zenam legisperitum et Apollo sollicite præmitte, ut nihil illis desit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.14",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Titus 3:14",
      "text": "Discant autem et nostri bonis operibus præesse ad usus necessarios: ut non sint infructuosi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:titus.3.15",
      "translationId": "vulgate",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Titus 3:15",
      "text": "Salutant te qui mecum sunt omnes: saluta eos qui nos amant in fide. Gratia Dei cum omnibus vobis. Amen.",
      "paragraphStart": false
    }
  ]
}
