{
  "chapter": {
    "id": "vulgate:jonah.2",
    "translationId": "vulgate",
    "bookSlug": "jonah",
    "chapterNumber": 2,
    "referenceLabel": "Jonah 2",
    "summary": "Source text for Jonah 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:jonah.2.1",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Jonah 2:1",
      "text": "Et præparavit Dominus piscem grandem ut deglutiret Jonam: et erat Jonas in ventre piscis tribus diebus et tribus noctibus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:jonah.2.2",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Jonah 2:2",
      "text": "Et oravit Jonas ad Dominum Deum suum de ventre piscis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.3",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Jonah 2:3",
      "text": "et dixit: Clamavi de tribulatione mea ad Dominum, et exaudivit me; de ventre inferi clamavi, et exaudisti vocem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.4",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Jonah 2:4",
      "text": "Et projecisti me in profundum in corde maris, et flumen circumdedit me: omnes gurgites tui, et fluctus tui super me transierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.5",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Jonah 2:5",
      "text": "Et ego dixi: Abjectus sum a conspectu oculorum tuorum; verumtamen rursus videbo templum sanctum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.6",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Jonah 2:6",
      "text": "Circumdederunt me aquæ usque ad animam: abyssus vallavit me, pelagus operuit caput meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.7",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Jonah 2:7",
      "text": "Ad extrema montium descendi; terræ vectes concluserunt me in æternum: et sublevabis de corruptione vitam meam, Domine Deus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.8",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Jonah 2:8",
      "text": "Cum angustiaretur in me anima mea, Domini recordatus sum: ut veniat ad te oratio mea, ad templum sanctum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.9",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Jonah 2:9",
      "text": "Qui custodiunt vanitates frustra, misericordiam suam derelinquunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.10",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Jonah 2:10",
      "text": "Ego autem in voce laudis immolabo tibi: quæcumque vovi, reddam pro salute Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:jonah.2.11",
      "translationId": "vulgate",
      "bookSlug": "jonah",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Jonah 2:11",
      "text": "Et dixit Dominus pisci, et evomuit Jonam in aridam.",
      "paragraphStart": false
    }
  ]
}
