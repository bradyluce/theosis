{
  "chapter": {
    "id": "vulgate:first-maccabees.2",
    "translationId": "vulgate",
    "bookSlug": "first-maccabees",
    "chapterNumber": 2,
    "referenceLabel": "1 Maccabees 2",
    "summary": "Source text for 1 Maccabees 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-maccabees.2.1",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Maccabees 2:1",
      "text": "In diebus illis surrexit Mathathias filius Joannis filii Simeonis, sacerdos ex filiis Joarib, ab Jerusalem, et consedit in monte Modin:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-maccabees.2.2",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Maccabees 2:2",
      "text": "et habebat filios quinque, Joannem, qui cognominabatur Gaddis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.3",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Maccabees 2:3",
      "text": "et Simonem, qui cognominabatur Thasi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.4",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Maccabees 2:4",
      "text": "et Judam, qui vocabatur Machabæus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.5",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Maccabees 2:5",
      "text": "et Eleazarum, qui cognominabatur Abaron: et Jonathan, qui cognominabatur Apphus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.6",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Maccabees 2:6",
      "text": "hi viderunt mala, quæ fiebant in populo Juda, et in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.7",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Maccabees 2:7",
      "text": "Et dixit Mathathias: Væ mihi! ut quid natus sum videre contritionem populi mei, et contritionem civitatis sanctæ, et sedere illic, cum datur in manibus inimicorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.8",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Maccabees 2:8",
      "text": "Sancta in manu extraneorum facta sunt: templum ejus sicut homo ignobilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.9",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Maccabees 2:9",
      "text": "Vasa gloriæ ejus captiva abducta sunt: trucidati sunt senes ejus in plateis, et juvenes ejus ceciderunt in gladio inimicorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.10",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Maccabees 2:10",
      "text": "Quæ gens non hæreditavit regnum ejus et non obtinuit spolia ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.11",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Maccabees 2:11",
      "text": "Omnis compositio ejus ablata est. Quæ erat libera, facta est ancilla.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.12",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Maccabees 2:12",
      "text": "Et ecce sancta nostra, et pulchritudo nostra, et claritas nostra desolata est, et coinquinaverunt ea gentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.13",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Maccabees 2:13",
      "text": "Quo ergo nobis adhuc vivere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.14",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Maccabees 2:14",
      "text": "Et scidit vestimenta sua Mathathias, et filii ejus: et operuerunt se ciliciis, et planxerunt valde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.15",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Maccabees 2:15",
      "text": "Et venerunt illuc qui missi erant a rege Antiocho, ut cogerent eos, qui confugerant in civitatem Modin, immolare, et accendere thura, et a lege Dei discedere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.16",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Maccabees 2:16",
      "text": "Et multi de populo Israël consentientes accesserunt ad eos: sed Mathathias et filii ejus constanter steterunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.17",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 Maccabees 2:17",
      "text": "Et respondentes qui missi erant ab Antiocho, dixerunt Mathathiæ: Princeps, et clarissimus et magnus es in hac civitate, et ornatus filiis et fratribus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.18",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 Maccabees 2:18",
      "text": "ergo accede prior, et fac jussum regis, sicut fecerunt omnes gentes, et viri Juda, et qui remanserunt in Jerusalem: et eris tu, et filii tui, inter amicos regis, et amplificatus auro, et argento, et muneribus multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.19",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 Maccabees 2:19",
      "text": "Et respondit Mathathias, et dixit magna voce: Etsi omnes gentes regi Antiocho obediunt, ut discedat unusquisque a servitute legis patrum suorum, et consentiat mandatis ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.20",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 Maccabees 2:20",
      "text": "ego et filii mei, et fratres mei, obediemus legi patrum nostrorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.21",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "1 Maccabees 2:21",
      "text": "propitius sit nobis Deus: non est nobis utile relinquere legem, et justitias Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.22",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "1 Maccabees 2:22",
      "text": "non audiemus verba regis Antiochi, nec sacrificabimus transgredientes legis nostræ mandata, ut eamus altera via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.23",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "1 Maccabees 2:23",
      "text": "Et ut cessavit loqui verba hæc, accessit quidam Judæus in omnium oculis sacrificare idolis super aram in civitate Modin, secundum jussum regis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.24",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "1 Maccabees 2:24",
      "text": "et vidit Mathathias, et doluit, et contremuerunt renes ejus, et accensus est furor ejus secundum judicium legis, et insiliens trucidavit eum super aram:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.25",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "1 Maccabees 2:25",
      "text": "sed et virum, quem rex Antiochus miserat, qui cogebat immolare, occidit in ipso tempore, et aram destruxit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.26",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "1 Maccabees 2:26",
      "text": "et zelatus est legem, sicut fecit Phinees Zamri filio Salomi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.27",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "1 Maccabees 2:27",
      "text": "Et exclamavit Mathathias voce magna in civitate, dicens: Omnis qui zelum habet legis, statuens testamentum, exeat post me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.28",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "1 Maccabees 2:28",
      "text": "Et fugit ipse, et filii ejus in montes, et reliquerunt quæcumque habebant in civitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.29",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "1 Maccabees 2:29",
      "text": "Tunc descenderunt multi quærentes judicium, et justitiam, in desertum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.30",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "1 Maccabees 2:30",
      "text": "et sederunt ibi ipsi, et filii eorum, et mulieres eorum, et pecora eorum: quoniam inundaverunt super eos mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.31",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "1 Maccabees 2:31",
      "text": "Et renuntiatum est viris regis, et exercitui qui erat in Jerusalem civitate David, quoniam discessissent viri quidam, qui dissipaverunt mandatum regis, in loca occulta in deserto, et abiissent post illos multi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.32",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "1 Maccabees 2:32",
      "text": "Et statim perrexerunt ad eos, et constituerunt adversus eos prælium in die sabbatorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.33",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "1 Maccabees 2:33",
      "text": "et dixerunt ad eos: Resistitis et nunc adhuc? exite, et facite secundum verbum regis Antiochi, et vivetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.34",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "1 Maccabees 2:34",
      "text": "Et dixerunt: Non exibimus, neque faciemus verbum regis, ut polluamus diem sabbatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.35",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "1 Maccabees 2:35",
      "text": "Et concitaverunt adversus eos prælium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.36",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "1 Maccabees 2:36",
      "text": "Et non responderunt eis, nec lapidem miserunt in eos, nec oppilaverunt loca occulta,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.37",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "1 Maccabees 2:37",
      "text": "dicentes: Moriamur omnes in simplicitate nostra: et testes erunt super nos cælum et terra, quod injuste perditis nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.38",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "1 Maccabees 2:38",
      "text": "Et intulerunt illis bellum sabbatis: et mortui sunt ipsi, et uxores eorum, et filii eorum, et pecora eorum usque ad mille animas hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.39",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "1 Maccabees 2:39",
      "text": "Et cognovit Mathathias et amici ejus, et luctum habuerunt super eos valde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.40",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "1 Maccabees 2:40",
      "text": "Et dixit vir proximo suo: Si omnes fecerimus sicut fratres nostri fecerunt, et non pugnaverimus adversus gentes pro animabus nostris et justificationibus nostris, nunc citius disperdent nos a terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.41",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "1 Maccabees 2:41",
      "text": "Et cogitaverunt in die illa, dicentes: Omnis homo, quicumque venerit ad nos in bello die sabbatorum, pugnemus adversus eum: et non moriemur omnes, sicut mortui sunt fratres nostri in occultis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.42",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "1 Maccabees 2:42",
      "text": "Tunc congregata est ad eos synagoga Assidæorum fortis viribus ex Israël, omnis voluntarius in lege:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.43",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "1 Maccabees 2:43",
      "text": "et omnes, qui fugiebant a malis, additi sunt ad eos, et facti sunt illis ad firmamentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.44",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "1 Maccabees 2:44",
      "text": "Et collegerunt exercitum, et percusserunt peccatores in ira sua, et viros iniquos in indignatione sua: et ceteri fugerunt ad nationes, ut evaderent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.45",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "1 Maccabees 2:45",
      "text": "Et circuivit Mathathias et amici ejus, et destruxerunt aras:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.46",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "1 Maccabees 2:46",
      "text": "et circumciderunt pueros incircumcisos quotquot invenerunt in finibus Israël: et in fortitudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.47",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "1 Maccabees 2:47",
      "text": "Et persecuti sunt filios superbiæ, et prosperatum est opus in manibus eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.48",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "1 Maccabees 2:48",
      "text": "et obtinuerunt legem de manibus gentium, et de manibus regum, et non dederant cornu peccatori.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.49",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "1 Maccabees 2:49",
      "text": "Et appropinquaverunt dies Mathathiæ moriendi, et dixit filiis suis: Nunc confortata est superbia, et castigatio, et tempus eversionis, et ira indignationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.50",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "1 Maccabees 2:50",
      "text": "Nunc ergo, o filii, æmulatores estote legis, et date animas vestras pro testamento patrum vestrorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.51",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "1 Maccabees 2:51",
      "text": "et mementote operum patrum, quæ fecerunt in generationibus suis: et accipietis gloriam magnam, et nomen æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.52",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "1 Maccabees 2:52",
      "text": "Abraham nonne in tentatione inventus est fidelis, et reputatum est ei ad justitiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.53",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "1 Maccabees 2:53",
      "text": "Joseph in tempore angustiæ suæ custodivit mandatum, et factus est dominus Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.54",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "1 Maccabees 2:54",
      "text": "Phinees pater noster, zelando zelum Dei, accepit testamentum sacerdotii æterni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.55",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "1 Maccabees 2:55",
      "text": "Jesus dum implevit verbum, factus est dux in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.56",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 56,
      "referenceLabel": "1 Maccabees 2:56",
      "text": "Caleb dum testificatur in ecclesia, accepit hæreditatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.57",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 57,
      "referenceLabel": "1 Maccabees 2:57",
      "text": "David in sua misericordia consecutus est sedem regni in sæcula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.58",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 58,
      "referenceLabel": "1 Maccabees 2:58",
      "text": "Elias, dum zelat zelum legis, receptus est in cælum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.59",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 59,
      "referenceLabel": "1 Maccabees 2:59",
      "text": "Ananias et Azarias et Misaël credentes, liberati sunt de flamma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.60",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 60,
      "referenceLabel": "1 Maccabees 2:60",
      "text": "Daniel in sua simplicitate liberatus est de ore leonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.61",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 61,
      "referenceLabel": "1 Maccabees 2:61",
      "text": "Et ita cogitate per generationem et generationem: quia omnes qui sperant in eum, non infirmantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.62",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 62,
      "referenceLabel": "1 Maccabees 2:62",
      "text": "Et a verbis viri peccatoris ne timueritis, quia gloria ejus stercus et vermis est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.63",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 63,
      "referenceLabel": "1 Maccabees 2:63",
      "text": "hodie extollitur, et cras non invenietur: quia conversus est in terram suam, et cogitatio ejus periit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.64",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 64,
      "referenceLabel": "1 Maccabees 2:64",
      "text": "Vos ergo filii, confortamini, et viriliter agite in lege: quia in ipsa gloriosi eritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.65",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 65,
      "referenceLabel": "1 Maccabees 2:65",
      "text": "Et ecce Simon frater vester, scio quod vir consilii est: ipsum audite semper, et ipse erit vobis pater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.66",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 66,
      "referenceLabel": "1 Maccabees 2:66",
      "text": "Et Judas Machabæus, fortis viribus a juventute sua, sit vobis princeps militiæ, et ipse aget bellum populi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.67",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 67,
      "referenceLabel": "1 Maccabees 2:67",
      "text": "Et adducetis ad vos omnes factores legis: et vindicate vindictam populi vestri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.68",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 68,
      "referenceLabel": "1 Maccabees 2:68",
      "text": "Retribuite retributionem gentibus, et intendite in præceptum legis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.69",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 69,
      "referenceLabel": "1 Maccabees 2:69",
      "text": "Et benedixit eos, et appositus est ad patres suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.2.70",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 2,
      "verseNumber": 70,
      "referenceLabel": "1 Maccabees 2:70",
      "text": "Et defunctus est anno centesimo et quadragesimo sexto: et sepultus est a filiis suis in sepulchris patrum suorum in Modin, et planxerunt eum omnis Israël planctu magno.",
      "paragraphStart": false
    }
  ]
}
