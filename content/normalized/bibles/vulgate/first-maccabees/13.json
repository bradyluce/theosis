{
  "chapter": {
    "id": "vulgate:first-maccabees.13",
    "translationId": "vulgate",
    "bookSlug": "first-maccabees",
    "chapterNumber": 13,
    "referenceLabel": "1 Maccabees 13",
    "summary": "Source text for 1 Maccabees 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-maccabees.13.1",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "1 Maccabees 13:1",
      "text": "Et audivit Simon quod congregavit Tryphon exercitum copiosum ut veniret in terram Juda, et attereret eam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-maccabees.13.2",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "1 Maccabees 13:2",
      "text": "Videns quia in tremore populus est, et in timore, ascendit Jerusalem, et congregavit populum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.3",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "1 Maccabees 13:3",
      "text": "et adhortans dixit: Vos scitis quanta ego, et fratres mei, et domus patris mei, fecimus pro legibus et pro sanctis, prælia, et angustias quales vidimus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.4",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "1 Maccabees 13:4",
      "text": "horum gratia perierunt fratres mei omnes propter Israël, et relictus sum ego solus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.5",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "1 Maccabees 13:5",
      "text": "Et nunc non mihi contingat parcere animæ meæ in omni tempore tribulationis: non enim melior sum fratribus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.6",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "1 Maccabees 13:6",
      "text": "Vindicabo itaque gentem meam, et sancta, natos quoque nostros, et uxores: quia congregatæ sunt universæ gentes conterere nos inimicitiæ gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.7",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "1 Maccabees 13:7",
      "text": "Et accensus est spiritus populi simul ut audivit sermones istos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.8",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "1 Maccabees 13:8",
      "text": "et responderunt voce magna, dicentes: Tu es dux noster loco Judæ, et Jonathæ fratris tui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.9",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "1 Maccabees 13:9",
      "text": "pugna prælium nostrum: et omnia, quæcumque dixeris nobis, faciemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.10",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "1 Maccabees 13:10",
      "text": "Et congregans omnes viros bellatores, acceleravit consummare universos muros Jerusalem, et munivit eam in gyro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.11",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "1 Maccabees 13:11",
      "text": "Et misit Jonathan filium Absalomi, et cum eo exercitum novum in Joppen, et ejectis his qui erant in ea, remansit illic ipse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.12",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "1 Maccabees 13:12",
      "text": "Et movit Tryphon a Ptolemaida cum exercitu multo, ut veniret in terram Juda, et Jonathas cum eo in custodia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.13",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "1 Maccabees 13:13",
      "text": "Simon autem applicuit in Addus contra faciem campi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.14",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "1 Maccabees 13:14",
      "text": "Et ut cognovit Tryphon quia surrexit Simon loco fratris sui Jonathæ, et quia commissurus esset cum eo prælium, misit ad eum legatos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.15",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "1 Maccabees 13:15",
      "text": "dicens: Pro argento, quod debebat frater tuus Jonathas in ratione regis propter negotia quæ habuit, detinuimus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.16",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "1 Maccabees 13:16",
      "text": "Et nunc mitte argenti talenta centum, et duos filios ejus obsides, ut non dimissus fugiat a nobis, et remittemus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.17",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "1 Maccabees 13:17",
      "text": "Et cognovit Simon quia cum dolo loqueretur secum: jussit tamen dari argentum et pueros, ne inimicitiam magnam sumeret ad populum Israël, dicentem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.18",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "1 Maccabees 13:18",
      "text": "Quia non misit ei argentum, et pueros, propterea periit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.19",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "1 Maccabees 13:19",
      "text": "Et misit pueros, et centum talenta: et mentitus est, et non dimisit Jonathan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.20",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "1 Maccabees 13:20",
      "text": "Et post hæc venit Tryphon intra regionem, ut contereret eam: et gyraverunt per viam quæ ducit Ador: et Simon et castra ejus ambulabant in omnem locum quocumque ibant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.21",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "1 Maccabees 13:21",
      "text": "Qui autem in arce erant, miserunt ad Tryphonem legatos, ut festinaret venire per desertum, et mitteret illis alimonias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.22",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "1 Maccabees 13:22",
      "text": "Et paravit Tryphon omnem equitatum, ut veniret illa nocte: erat autem nix multa valde, et non venit in Galaaditim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.23",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "1 Maccabees 13:23",
      "text": "Et cum appropinquasset Bascaman, occidit Jonathan et filios ejus illic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.24",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "1 Maccabees 13:24",
      "text": "Et convertit Tryphon, et abiit in terram suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.25",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "1 Maccabees 13:25",
      "text": "Et misit Simon, et accepit ossa Jonathæ fratris sui, et sepelivit ea in Modin civitate patrum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.26",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "1 Maccabees 13:26",
      "text": "Et planxerunt eum omnis Israël planctu magno, et luxerunt eum dies multos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.27",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "1 Maccabees 13:27",
      "text": "Et ædificavit Simon super sepulchrum patris sui et fratrum suorum ædificium altum visu, lapide polito retro et ante.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.28",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "1 Maccabees 13:28",
      "text": "Et statuit septem pyramidas, unam contra unam, patri et matri, et quatuor fratribus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.29",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "1 Maccabees 13:29",
      "text": "et his circumposuit columnas magnas: et super columnas arma, ad memoriam æternam: et juxta arma naves sculptas, quæ viderentur ab omnibus navigantibus mare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.30",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "1 Maccabees 13:30",
      "text": "hoc est sepulchrum, quod fecit in Modin usque in hunc diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.31",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "1 Maccabees 13:31",
      "text": "Tryphon autem cum iter faceret cum Antiocho rege adolescente, dolo occidit eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.32",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "1 Maccabees 13:32",
      "text": "et regnavit loco ejus, et imposuit sibi diadema Asiæ, et fecit plagam magnam in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.33",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "1 Maccabees 13:33",
      "text": "Et ædificavit Simon præsidia Judææ, muniens ea turribus excelsis, et muris magnis, et portis, et seris: et posuit alimenta in munitionibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.34",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "1 Maccabees 13:34",
      "text": "Et elegit Simon viros, et misit ad Demetrium regem ut faceret remissionem regioni: quia actus omnes Tryphonis per direptionem fuerant gesti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.35",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "1 Maccabees 13:35",
      "text": "Et Demetrius rex ad verba ista respondit ei, et scripsit epistolam talem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.36",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "1 Maccabees 13:36",
      "text": "Rex Demetrius Simoni summo sacerdoti et amico regum, et senioribus, et genti Judæorum, salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.37",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "1 Maccabees 13:37",
      "text": "Coronam auream, et bahem, quam misistis, suscepimus: et parati sumus facere vobiscum pacem magnam, et scribere præpositis regis remittere vobis quæ indulsimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.38",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 38,
      "referenceLabel": "1 Maccabees 13:38",
      "text": "Quæcumque enim constituimus, vobis constant: munitiones, quas ædificastis, vobis sint:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.39",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 39,
      "referenceLabel": "1 Maccabees 13:39",
      "text": "remittimus quoque ignorantias et peccata usque in hodiernum diem, et coronam quam debebatis: et si quid aliud erat tributarium in Jerusalem, jam non sit tributarium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.40",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 40,
      "referenceLabel": "1 Maccabees 13:40",
      "text": "Et si qui ex vobis apti sunt conscribi inter nostros, conscribantur, et sit inter nos pax.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.41",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 41,
      "referenceLabel": "1 Maccabees 13:41",
      "text": "Anno centesimo septuagesimo, ablatum est jugum gentium ab Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.42",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 42,
      "referenceLabel": "1 Maccabees 13:42",
      "text": "Et cœpit populus Israël scribere in tabulis, et gestis publicis, anno primo sub Simone summo sacerdote, magno duce, et principe Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.43",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 43,
      "referenceLabel": "1 Maccabees 13:43",
      "text": "In diebus illis applicuit Simon ad Gazam, et circumdedit eam castris, et fecit machinas, et applicuit ad civitatem, et percussit turrem unam, et comprehendit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.44",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 44,
      "referenceLabel": "1 Maccabees 13:44",
      "text": "Et eruperant qui erant intra machinam in civitatem, et factus est motus magnus in civitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.45",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 45,
      "referenceLabel": "1 Maccabees 13:45",
      "text": "Et ascenderunt qui erant in civitate cum uxoribus et filiis supra murum, scissis tunicis suis, et clamaverunt voce magna, postulantes a Simone dextras sibi dari,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.46",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 46,
      "referenceLabel": "1 Maccabees 13:46",
      "text": "et dixerunt: Non nobis reddas secundum malitias nostras, sed secundum misericordias tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.47",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 47,
      "referenceLabel": "1 Maccabees 13:47",
      "text": "Et flexus Simon, non debellavit eos: ejecit tamen eos de civitate, et mundavit ædes in quibus fuerant simulacra, et tunc intravit in eam cum hymnis benedicens Dominum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.48",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 48,
      "referenceLabel": "1 Maccabees 13:48",
      "text": "et ejecta ab ea omni immunditia, collocavit in ea viros qui legem facerent: et munivit eam, et fecit sibi habitationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.49",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 49,
      "referenceLabel": "1 Maccabees 13:49",
      "text": "Qui autem erant in arce Jerusalem, prohibebantur egredi et ingredi regionem, et emere ac vendere: et esurierunt valde, et multi ex eis fame perierunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.50",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 50,
      "referenceLabel": "1 Maccabees 13:50",
      "text": "et clamaverunt ad Simonem ut dextras acciperent: et dedit illis: et ejecit eos inde, et mundavit arcem a contaminationibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.51",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 51,
      "referenceLabel": "1 Maccabees 13:51",
      "text": "et intraverunt in eam tertia et vigesima die secundi mensis, anno centesimo septuagesimo primo, cum laude, et ramis palmarum, et cinyris, et cymbalis, et nablis, et hymnis, et canticis, quia contritus est inimicus magnus ex Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.52",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 52,
      "referenceLabel": "1 Maccabees 13:52",
      "text": "Et constituit ut omnibus annis agerentur dies hi cum lætitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.53",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 53,
      "referenceLabel": "1 Maccabees 13:53",
      "text": "Et munivit montem templi, qui erat secus arcem, et habitavit ibi ipse, et qui cum eo erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.13.54",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 13,
      "verseNumber": 54,
      "referenceLabel": "1 Maccabees 13:54",
      "text": "Et vidit Simon Joannem filium suum, quod fortis prælii vir esset: et posuit eum ducem virtutum universarum: et habitavit in Gazaris.",
      "paragraphStart": false
    }
  ]
}
