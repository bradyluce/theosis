{
  "chapter": {
    "id": "vulgate:first-maccabees.4",
    "translationId": "vulgate",
    "bookSlug": "first-maccabees",
    "chapterNumber": 4,
    "referenceLabel": "1 Maccabees 4",
    "summary": "Source text for 1 Maccabees 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-maccabees.4.1",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Maccabees 4:1",
      "text": "Et assumpsit Gorgias quinque millia virorum, et mille equites electos: et moverunt castra nocte,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-maccabees.4.2",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Maccabees 4:2",
      "text": "ut applicarent ad castra Judæorum, et percuterent eos subito: et filii, qui erant ex arce, erant illis duces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.3",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Maccabees 4:3",
      "text": "Et audivit Judas, et surrexit ipse et potentes percutere virtutem exercituum regis, qui erant in Emmaum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.4",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Maccabees 4:4",
      "text": "adhuc enim dispersus erat exercitus a castris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.5",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Maccabees 4:5",
      "text": "Et venit Gorgias in castra Judæ noctu, et neminem invenit: et quærebat eos in montibus, quoniam dixit: Fugiunt hi a nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.6",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Maccabees 4:6",
      "text": "Et cum dies factus esset, apparuit Judas in campo cum tribus millibus virorum tantum, qui tegumenta et gladios non habebant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.7",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Maccabees 4:7",
      "text": "et viderunt castra gentium valida, et loricatos et equitatus in circuitu eorum, et hi docti ad prælium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.8",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Maccabees 4:8",
      "text": "Et ait Judas viris, qui secum erant: Ne timueritis multitudinem eorum, et impetum eorum ne formidetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.9",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Maccabees 4:9",
      "text": "Mementote qualiter salvi facti sunt patres nostri in mari Rubro, cum sequeretur eos Pharao cum exercitu multo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.10",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Maccabees 4:10",
      "text": "Et nunc clamemus in cælum: et miserebitur nostri Dominus, et memor erit testamenti patrum nostrorum, et conteret exercitum istum ante faciem nostram hodie:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.11",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Maccabees 4:11",
      "text": "et scient omnes gentes quia est qui redimat et liberet Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.12",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Maccabees 4:12",
      "text": "Et elevaverunt alienigenæ oculos suos, et viderunt eos venientes ex adverso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.13",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Maccabees 4:13",
      "text": "Et exierunt de castris in prælium, et tuba cecinerunt hi qui erant cum Juda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.14",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Maccabees 4:14",
      "text": "Et congressi sunt: et contritæ sunt gentes, et fugerunt in campum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.15",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Maccabees 4:15",
      "text": "Novissimi autem omnes ceciderunt in gladio, et persecuti sunt eos usque Gezeron, et usque in campos Idumææ, et Azoti, et Jamniæ: et ceciderunt ex illis usque ad tria millia virorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.16",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Maccabees 4:16",
      "text": "Et reversus est Judas, et exercitus ejus sequens eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.17",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Maccabees 4:17",
      "text": "Dixitque ad populum: Non concupiscatis spolia: quia bellum contra nos est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.18",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Maccabees 4:18",
      "text": "et Gorgias et exercitus ejus prope nos in monte: sed state nunc contra inimicos nostros, et expugnate eos, et sumetis postea spolia securi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.19",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Maccabees 4:19",
      "text": "Et adhuc loquente Juda hæc, ecce apparuit pars quædam prospiciens de monte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.20",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 Maccabees 4:20",
      "text": "Et vidit Gorgias quod in fugam conversi sunt sui, et succenderunt castra: fumus enim, qui videbatur, declarabat quod factum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.21",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 Maccabees 4:21",
      "text": "Quibus illi conspectis timuerunt valde, aspicientes simul et Judam, et exercitum in campo paratum ad prælium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.22",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "1 Maccabees 4:22",
      "text": "Et fugerunt omnes in campum alienigenarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.23",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "1 Maccabees 4:23",
      "text": "et Judas reversus est ad spolia castrorum, et acceperunt aurum multum, et argentum, et hyacinthinum, et purpuram marinam, et opes magnas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.24",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "1 Maccabees 4:24",
      "text": "Et conversi, hymnum canebant, et benedicebant Deum in cælum, quoniam bonus est, quoniam in sæculum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.25",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "1 Maccabees 4:25",
      "text": "Et facta est salus magna in Israël in die illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.26",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "1 Maccabees 4:26",
      "text": "Quicumque autem alienigenarum evaserunt, venerunt, et nuntiaverunt Lysiæ universa quæ acciderant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.27",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "1 Maccabees 4:27",
      "text": "Quibus ille auditis, consternatus animo deficiebat: quod non qualia voluit, talia contigerunt in Israël, et qualia mandavit rex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.28",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "1 Maccabees 4:28",
      "text": "Et sequenti anno, congregavit Lysias virorum electorum sexaginta millia, et equitum quinque millia, ut debellaret eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.29",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "1 Maccabees 4:29",
      "text": "Et venerunt in Judæam, et castra posuerunt in Bethoron, et occurrit illis Judas cum decem millibus viris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.30",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "1 Maccabees 4:30",
      "text": "Et viderunt exercitum fortem, et oravit, et dixit: Benedictus es, salvator Israël, qui contrivisti impetum potentis in manu servi tui David, et tradidisti castra alienigenarum in manu Jonathæ filii Saul, et armigeri ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.31",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "1 Maccabees 4:31",
      "text": "Conclude exercitum istum in manu populi tui Israël, et confundantur in exercitu suo et equitibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.32",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "1 Maccabees 4:32",
      "text": "Da illis formidinem, et tabefac audaciam virtutis eorum, et commoveantur contritione sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.33",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "1 Maccabees 4:33",
      "text": "Dejice illos gladio diligentium te: et collaudent te omnes, qui noverunt nomen tuum, in hymnis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.34",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "1 Maccabees 4:34",
      "text": "Et commiserunt prælium: et ceciderunt de exercitu Lysiæ quinque millia virorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.35",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "1 Maccabees 4:35",
      "text": "Videns autem Lysias fugam suorum, et Judæorum audaciam, et quod parati sunt aut vivere, aut mori fortiter, abiit Antiochiam, et elegit milites, ut multiplicati rursus venirent in Judæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.36",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "1 Maccabees 4:36",
      "text": "Dixit autem Judas, et fratres ejus: Ecce contriti sunt inimici nostri: ascendamus nunc mundare sancta, et renovare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.37",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "1 Maccabees 4:37",
      "text": "Et congregatus est omnis exercitus, et ascenderunt in montem Sion.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.38",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "1 Maccabees 4:38",
      "text": "Et viderunt sanctificationem desertam, et altare profanatum, et portas exustas, et in atriis virgulta nata sicut in saltu vel in montibus, et pastophoria diruta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.39",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 39,
      "referenceLabel": "1 Maccabees 4:39",
      "text": "Et sciderunt vestimenta sua, et planxerunt planctu magno, et imposuerunt cinerem super caput suum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.40",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 40,
      "referenceLabel": "1 Maccabees 4:40",
      "text": "et ceciderunt in faciem super terram, et exclamaverunt tubis signorum, et clamaverunt in cælum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.41",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 41,
      "referenceLabel": "1 Maccabees 4:41",
      "text": "Tunc ordinavit Judas viros ut pugnarent adversus eos qui erant in arce, donec emundarent sancta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.42",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 42,
      "referenceLabel": "1 Maccabees 4:42",
      "text": "Et elegit sacerdotes sine macula, voluntatem habentes in lege Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.43",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 43,
      "referenceLabel": "1 Maccabees 4:43",
      "text": "et mundaverunt sancta, et tulerunt lapides contaminationis in locum immundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.44",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 44,
      "referenceLabel": "1 Maccabees 4:44",
      "text": "Et cogitavit de altari holocaustorum, quod profanatum erat, quid de eo faceret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.45",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 45,
      "referenceLabel": "1 Maccabees 4:45",
      "text": "Et incidit illis consilium bonum ut destruerent illud: ne forte illis esset in opprobrium, quia contaminaverunt illud gentes, et demoliti sunt illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.46",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 46,
      "referenceLabel": "1 Maccabees 4:46",
      "text": "Et reposuerunt lapides in monte domus in loco apto, quoadusque veniret propheta, et responderet de eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.47",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 47,
      "referenceLabel": "1 Maccabees 4:47",
      "text": "Et acceperunt lapides integros secundum legem, et ædificaverunt altare novum secundum illud quod fuit prius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.48",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 48,
      "referenceLabel": "1 Maccabees 4:48",
      "text": "et ædificaverunt sancta, et quæ intra domum erant intrinsecus: et ædem, et atria sanctificaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.49",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 49,
      "referenceLabel": "1 Maccabees 4:49",
      "text": "Et fecerunt vasa sancta nova, et intulerunt candelabrum, et altare incensorum, et mensam, in templum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.50",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 50,
      "referenceLabel": "1 Maccabees 4:50",
      "text": "Et incensum posuerunt super altare, et accenderunt lucernas quæ super candelabrum erant, et lucebant in templo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.51",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 51,
      "referenceLabel": "1 Maccabees 4:51",
      "text": "Et posuerunt super mensam panes, et appenderunt vela, et consummaverunt omnia opera quæ fecerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.52",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 52,
      "referenceLabel": "1 Maccabees 4:52",
      "text": "Et ante matutinum surrexerunt quinta et vigesima die mensis noni (hic est mensis Casleu) centesimi quadragesimi octavi anni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.53",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 53,
      "referenceLabel": "1 Maccabees 4:53",
      "text": "et obtulerunt sacrificium secundum legem super altare holocaustorum novum, quod fecerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.54",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 54,
      "referenceLabel": "1 Maccabees 4:54",
      "text": "Secundum tempus et secundum diem in qua contaminaverunt illud gentes, in ipsa renovatum est in canticis, et citharis, et cinyris, et in cymbalis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.55",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 55,
      "referenceLabel": "1 Maccabees 4:55",
      "text": "Et cecidit omnis populus in faciem, et adoraverunt, et benedixerunt in cælum eum, qui prosperavit eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.56",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 4,
      "verseNumber": 56,
      "referenceLabel": "1 Maccabees 4:56",
      "text": "Et fecerunt dedicationem altaris diebus octo, et obtulerunt holocausta cum lætitia, et sacrificium salutaris et laudis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.4.57",
