{
  "chapter": {
    "id": "vulgate:first-maccabees.12",
    "translationId": "vulgate",
    "bookSlug": "first-maccabees",
    "chapterNumber": 12,
    "referenceLabel": "1 Maccabees 12",
    "summary": "Source text for 1 Maccabees 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-maccabees.12.1",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "1 Maccabees 12:1",
      "text": "Et vidit Jonathas quia tempus eum juvat, et elegit viros, et misit eos Romam statuere et renovare cum eis amicitiam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-maccabees.12.2",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "1 Maccabees 12:2",
      "text": "et ad Spartiatas, et ad alia loca misit epistolas secundum eamdem formam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.3",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "1 Maccabees 12:3",
      "text": "et abierunt Romam, et intraverunt curiam, et dixerunt: Jonathas summus sacerdos, et gens Judæorum miserunt nos, ut renovaremus amicitiam et societatem secundum pristinum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.4",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "1 Maccabees 12:4",
      "text": "Et dederunt illis epistolas ad ipsos per loca, ut deducerent eos in terram Juda cum pace.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.5",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "1 Maccabees 12:5",
      "text": "Et hoc est exemplum epistolarum, quas scripsit Jonathas Spartiatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.6",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "1 Maccabees 12:6",
      "text": "Jonathas summus sacerdos, et seniores gentis, et sacerdotes, et reliquus populus Judæorum, Spartiatis fratribus salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.7",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "1 Maccabees 12:7",
      "text": "Jampridem missæ erant epistolæ ad Oniam summum sacerdotem ab Ario, qui regnabat apud vos, quoniam estis fratres nostri, sicut rescriptum continet, quod subjectum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.8",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "1 Maccabees 12:8",
      "text": "Et suscepit Onias virum, qui missus fuerat, cum honore: et accepit epistolas, in quibus significabatur de societate et amicitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.9",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "1 Maccabees 12:9",
      "text": "Nos cum nullo horum indigeremus, habentes solatio sanctos libros, qui sunt in manibus nostris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.10",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "1 Maccabees 12:10",
      "text": "maluimus mittere ad vos renovare fraternitatem et amicitiam, ne forte alieni efficiamur a vobis: multa enim tempora transierunt, ex quo misistis ad nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.11",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "1 Maccabees 12:11",
      "text": "Nos ergo in omni tempore sine intermissione in diebus solemnibus, et ceteris, quibus oportet, memores sumus vestri in sacrificiis quæ offerimus, et in observationibus, sicut fas est, et decet meminisse fratrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.12",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "1 Maccabees 12:12",
      "text": "Lætamur itaque de gloria vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.13",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "1 Maccabees 12:13",
      "text": "Nos autem circumdederunt multæ tribulationes, et multa prælia, et impugnaverunt nos reges qui sunt in circuitu nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.14",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "1 Maccabees 12:14",
      "text": "Noluimus ergo vobis molesti esse, neque ceteris sociis et amicis nostris in his præliis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.15",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "1 Maccabees 12:15",
      "text": "habuimus enim de cælo auxilium, et liberati sumus nos, et humiliati sunt inimici nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.16",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "1 Maccabees 12:16",
      "text": "Elegimus itaque Numenium Antiochi filium, et Antipatrem Jasonis filium, et misimus ad Romanos renovare cum eis amicitiam et societatem pristinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.17",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "1 Maccabees 12:17",
      "text": "Mandavimus itaque eis ut veniant etiam ad vos, et salutent vos, et reddant vobis epistolas nostras de innovatione fraternitatis nostræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.18",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "1 Maccabees 12:18",
      "text": "Et nunc benefacietis respondentes nobis ad hæc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.19",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "1 Maccabees 12:19",
      "text": "Et hoc est rescriptum epistolarum quod miserat Oniæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.20",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "1 Maccabees 12:20",
      "text": "Arius rex Spartiatarum Oniæ sacerdoti magno salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.21",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "1 Maccabees 12:21",
      "text": "Inventum est in scriptura de Spartiatis, et Judæis, quoniam sunt fratres, et quod sunt de genere Abraham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.22",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "1 Maccabees 12:22",
      "text": "Et nunc ex quo hæc cognovimus, benefacitis scribentes nobis de pace vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.23",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "1 Maccabees 12:23",
      "text": "Sed et nos rescripsimus vobis: Pecora nostra, et possessiones nostræ, vestræ sunt: et vestræ, nostræ: mandavimus itaque hæc nuntiari vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.24",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "1 Maccabees 12:24",
      "text": "Et audivit Jonathas quoniam regressi sunt principes Demetrii cum exercitu multo supra quam prius, pugnare adversus eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.25",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "1 Maccabees 12:25",
      "text": "et exiit ab Jerusalem, et occurrit eis in Amathite regione: non enim dederat eis spatium ut ingrederentur regionem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.26",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "1 Maccabees 12:26",
      "text": "Et misit speculatores in castra eorum: et reversi renuntiaverunt quod constituunt supervenire illis nocte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.27",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "1 Maccabees 12:27",
      "text": "Cum occidisset autem sol, præcepit Jonathas suis vigilare, et esse in armis paratos ad pugnam tota nocte: et posuit custodes per circuitum castrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.28",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "1 Maccabees 12:28",
      "text": "Et audierunt adversarii quod paratus est Jonathas cum suis in bello: et timuerunt, et formidaverunt in corde suo: et accenderunt focos in castris suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.29",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "1 Maccabees 12:29",
      "text": "Jonathas autem, et qui cum eo erant, non cognoverunt usque mane: videbant autem luminaria ardentia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.30",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "1 Maccabees 12:30",
      "text": "et secutus est eos Jonathas, et non comprehendit eos: transierant enim flumen Eleutherum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.31",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "1 Maccabees 12:31",
      "text": "Et divertit Jonathas ad Arabas, qui vocantur Zabadæi: et percussit eos, et accepit spolia eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.32",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "1 Maccabees 12:32",
      "text": "Et junxit, et venit Damascum, et perambulabat omnem regionem illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.33",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "1 Maccabees 12:33",
      "text": "Simon autem exiit, et venit usque ad Ascalonem, et ad proxima præsidia: et declinavit in Joppen, et occupavit eam",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.34",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "1 Maccabees 12:34",
      "text": "(audivit enim quod vellent præsidium tradere partibus Demetrii), et posuit ibi custodes ut custodirent eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.35",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "1 Maccabees 12:35",
      "text": "Et reversus est Jonathas, et convocavit seniores populi, et cogitavit cum eis ædificare præsidia in Judæa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.36",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "1 Maccabees 12:36",
      "text": "et ædificare muros in Jerusalem, et exaltare altitudinem magnam inter medium arcis et civitatis, ut separaret eam a civitate, ut esset ipsa singulariter, et neque emant, neque vendant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.37",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "1 Maccabees 12:37",
      "text": "Et convenerunt ut ædificarent civitatem: et cecidit murus qui erat super torrentem ab ortu solis, et reparavit eum, qui vocatur Caphetetha:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.38",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "1 Maccabees 12:38",
      "text": "et Simon ædificavit Adiada in Sephela, et munivit eam, et imposuit portas et seras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.39",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "1 Maccabees 12:39",
      "text": "Et cum cogitasset Tryphon regnare Asiæ, et assumere diadema, et extendere manum in Antiochum regem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.40",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "1 Maccabees 12:40",
      "text": "timens ne forte non permitteret eum Jonathas, sed pugnaret adversus eum, quærebat comprehendere eum, et occidere. Et exsurgens abiit in Bethsan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.41",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "1 Maccabees 12:41",
      "text": "Et exivit Jonathas obviam illi cum quadraginta millibus virorum electorum in prælium, et venit Bethsan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.42",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "1 Maccabees 12:42",
      "text": "Et vidit Tryphon quia venit Jonathas cum exercitu multo ut extenderet in eum manus: timuit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.43",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "1 Maccabees 12:43",
      "text": "et excepit eum cum honore, et commendavit eum omnibus amicis suis, et dedit ei munera: et præcepit exercitibus suis ut obedirent ei, sicut sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.44",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "1 Maccabees 12:44",
      "text": "Et dixit Jonathæ: Ut quid vexasti universum populum, cum bellum nobis non sit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.45",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "1 Maccabees 12:45",
      "text": "et nunc remitte eos in domos suas: elige autem tibi viros paucos, qui tecum sint, et veni mecum Ptolemaidam, et tradam eam tibi, et reliqua præsidia, et exercitum, et universos præpositos negotii: et conversus abibo: propterea enim veni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.46",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "1 Maccabees 12:46",
      "text": "Et credidit ei, et fecit sicut dixit: et dimisit exercitum, et abierunt in terram Juda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.47",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "1 Maccabees 12:47",
      "text": "Retinuit autem secum tria millia virorum: ex quibus remisit in Galilæam duo millia: mille autem venerunt cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.48",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 48,
      "referenceLabel": "1 Maccabees 12:48",
      "text": "Ut autem intravit Ptolemaidam Jonathas, clauserunt portas civitatis Ptolemenses, et comprehenderunt eum: et omnes qui cum eo intraverant, gladio interfecerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.49",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 49,
      "referenceLabel": "1 Maccabees 12:49",
      "text": "Et misit Tryphon exercitum et equites in Galilæam et in campum magnum, ut perderent omnes socios Jonathæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.50",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 50,
      "referenceLabel": "1 Maccabees 12:50",
      "text": "At illi cum cognovissent quia comprehensus est Jonathas, et periit, et omnes qui cum eo erant, hortati sunt semetipsos, et exierunt parati in prælium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.51",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 51,
      "referenceLabel": "1 Maccabees 12:51",
      "text": "Et videntes hi qui insecuti fuerant, quia pro anima res est illis, reversi sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.52",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 52,
      "referenceLabel": "1 Maccabees 12:52",
      "text": "illi autem venerunt omnes cum pace in terram Juda. Et planxerunt Jonathan, et eos qui cum ipso fuerant, valde: et luxit Israël luctu magno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.53",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 53,
      "referenceLabel": "1 Maccabees 12:53",
      "text": "Et quæsierunt omnes gentes quæ erant in circuitu eorum conterere eos: dixerunt enim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.12.54",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 12,
      "verseNumber": 54,
      "referenceLabel": "1 Maccabees 12:54",
      "text": "Non habent principem et adjuvantem: nunc ergo expugnemus illos, et tollamus de hominibus memoriam eorum.",
      "paragraphStart": false
    }
  ]
}
