{
  "chapter": {
    "id": "vulgate:first-maccabees.1",
    "translationId": "vulgate",
    "bookSlug": "first-maccabees",
    "chapterNumber": 1,
    "referenceLabel": "1 Maccabees 1",
    "summary": "Source text for 1 Maccabees 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-maccabees.1.1",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Maccabees 1:1",
      "text": "Et factum est, postquam percussit Alexander Philippi Macedo, qui primus regnavit in Græcia, egressus de terra Cethim, Darium regem Persarum et Medorum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-maccabees.1.2",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Maccabees 1:2",
      "text": "constituit prælia multa, et obtinuit omnium munitiones, et interfecit reges terræ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.3",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Maccabees 1:3",
      "text": "et pertransiit usque ad fines terræ: et accepit spolia multitudinis gentium, et siluit terra in conspectu ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.4",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Maccabees 1:4",
      "text": "Et congregavit virtutem, et exercitum fortem nimis: et exaltatum est, et elevatum cor ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.5",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Maccabees 1:5",
      "text": "et obtinuit regiones gentium, et tyrannos: et facti sunt illi in tributum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.6",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Maccabees 1:6",
      "text": "Et post hæc decidit in lectum, et cognovit quia moreretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.7",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Maccabees 1:7",
      "text": "Et vocavit pueros suos nobiles, qui secum erant nutriti a juventute: et divisit illis regnum suum, cum adhuc viveret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.8",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Maccabees 1:8",
      "text": "Et regnavit Alexander annis duodecim, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.9",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Maccabees 1:9",
      "text": "Et obtinuerunt pueri ejus regnum, unusquisque in loco suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.10",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Maccabees 1:10",
      "text": "et imposuerunt omnes sibi diademata post mortem ejus, et filii eorum post eos annis multis, et multiplicata sunt mala in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.11",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Maccabees 1:11",
      "text": "Et exiit ex eis radix peccatrix, Antiochus illustris, filius Antiochi regis, qui fuerat Romæ obses: et regnavit in anno centesimo trigesimo septimo regni Græcorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.12",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Maccabees 1:12",
      "text": "In diebus illis, exierunt ex Israël filii iniqui, et suaserunt multis, dicentes: Eamus, et disponamus testamentum cum gentibus, quæ circa nos sunt: quia ex quo recessimus ab eis, invenerunt nos multa mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.13",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Maccabees 1:13",
      "text": "Et bonus visus est sermo in oculis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.14",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Maccabees 1:14",
      "text": "Et destinaverunt aliqui de populo, et abierunt ad regem: et dedit illis potestatem ut facerent justitiam gentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.15",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Maccabees 1:15",
      "text": "Et ædificaverunt gymnasium in Jerosolymis secundum leges nationum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.16",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Maccabees 1:16",
      "text": "et fecerunt sibi præputia, et recesserunt a testamento sancto, et juncti sunt nationibus, et venundati sunt ut facerent malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.17",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Maccabees 1:17",
      "text": "Et paratum est regnum in conspectu Antiochi, et cœpit regnare in terra Ægypti ut regnaret super duo regna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.18",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Maccabees 1:18",
      "text": "Et intravit in Ægyptum in multitudine gravi, in curribus, et elephantis, et equitibus, et copiosa navium multitudine:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.19",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Maccabees 1:19",
      "text": "et constituit bellum adversus Ptolemæum regem Ægypti, et veritus est Ptolemæus a facie ejus, et fugit, et ceciderunt vulnerati multi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.20",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Maccabees 1:20",
      "text": "Et comprehendit civitates munitas in terra Ægypti, et accepit spolia terræ Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.21",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Maccabees 1:21",
      "text": "Et convertit Antiochus, postquam percussit Ægyptum in centesimo et quadragesimo tertio anno: et ascendit ad Israël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.22",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Maccabees 1:22",
      "text": "et ascendit Jerosolymam in multitudine gravi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.23",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Maccabees 1:23",
      "text": "Et intravit in sanctificationem cum superbia, et accepit altare aureum, et candelabrum luminis, et universa vasa ejus, et mensam propositionis, et libatoria, et phialas, et mortariola aurea, et velum, et coronas, et ornamentum aureum, quod in facie templi erat: et comminuit omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.24",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Maccabees 1:24",
      "text": "Et accepit argentum, et aurum, et vasa concupiscibilia: et accepit thesauros occultos, quos invenit: et sublatis omnibus, abiit in terram suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.25",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Maccabees 1:25",
      "text": "Et fecit cædem hominum, et locutus est in superbia magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.26",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Maccabees 1:26",
      "text": "Et factus est planctus magnus in Israël, et in omni loco eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.27",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Maccabees 1:27",
      "text": "et ingemuerunt principes et seniores; virgines et juvenes infirmati sunt: et speciositas mulierum immutata est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.28",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Maccabees 1:28",
      "text": "Omnis maritus sumpsit lamentum, et quæ sedebant in thoro maritali, lugebant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.29",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Maccabees 1:29",
      "text": "et commota est terra super habitantes in ea, et universa domus Jacob induit confusionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.30",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Maccabees 1:30",
      "text": "Et post duos annos dierum, misit rex principem tributorum in civitates Juda, et venit Jerusalem cum turba magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.31",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Maccabees 1:31",
      "text": "Et locutus est ad eos verba pacifica in dolo: et crediderunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.32",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Maccabees 1:32",
      "text": "Et irruit super civitatem repente, et percussit eam plaga magna, et perdidit populum multum ex Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.33",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Maccabees 1:33",
      "text": "Et accepit spolia civitatis: et succendit eam igni, et destruxit domos ejus, et muros ejus in circuitu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.34",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Maccabees 1:34",
      "text": "et captivas duxerunt mulieres, et natos et pecora possederunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.35",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Maccabees 1:35",
      "text": "Et ædificaverunt civitatem David muro magno et firmo, et turribus firmis, et facta est illis in arcem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.36",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Maccabees 1:36",
      "text": "et posuerunt illic gentem peccatricem viros iniquos, et convaluerunt in ea: et posuerunt arma, et escas, et congregaverunt spolia Jerusalem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.37",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Maccabees 1:37",
      "text": "et reposuerunt illic: et facti sunt in laqueum magnum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.38",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Maccabees 1:38",
      "text": "Et factum est hoc ad insidias sanctificationi, et in diabolum malum in Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.39",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Maccabees 1:39",
      "text": "et effuderunt sanguinem innocentem per circuitum sanctificationis, et contaminaverunt sanctificationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.40",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Maccabees 1:40",
      "text": "Et fugerunt habitatores Jerusalem propter eos, et facta est habitatio exterorum, et facta est extera semini suo, et nati ejus reliquerunt eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.41",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Maccabees 1:41",
      "text": "Sanctificatio ejus desolata est sicut solitudo; dies festi ejus conversi sunt in luctum, sabbata ejus in opprobrium, honores ejus in nihilum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.42",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Maccabees 1:42",
      "text": "Secundum gloriam ejus multiplicata est ignominia ejus, et sublimitas ejus conversa est in luctum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.43",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Maccabees 1:43",
      "text": "Et scripsit rex Antiochus omni regno suo ut esset omnis populus unus: et relinqueret unusquisque legem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.44",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Maccabees 1:44",
      "text": "Et consenserunt omnes gentes secundum verbum regis Antiochi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.45",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Maccabees 1:45",
      "text": "et multi ex Israël consenserunt servituti ejus, et sacrificaverunt idolis, et coinquinaverunt sabbatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.46",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Maccabees 1:46",
      "text": "Et misit rex libros per manus nuntiorum in Jerusalem, et in omnes civitates Juda, ut sequerentur leges gentium terræ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.47",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Maccabees 1:47",
      "text": "et prohiberent holocausta et sacrificia, et placationes fieri in templo Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.48",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Maccabees 1:48",
      "text": "et prohiberent celebrari sabbatum, et dies solemnes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.49",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Maccabees 1:49",
      "text": "et jussit coinquinari sancta, et sanctum populum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.50",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Maccabees 1:50",
      "text": "Et jussit ædificari aras, et templa, et idola, et immolari carnes suillas, et pecora communia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.51",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Maccabees 1:51",
      "text": "et relinquere filios suos incircumcisos, et coinquinari animas eorum in omnibus immundis, et abominationibus, ita ut obliviscerentur legem, et immutarent omnes justificationes Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.52",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Maccabees 1:52",
      "text": "et quicumque non fecissent secundum verbum regis Antiochi, morerentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.53",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Maccabees 1:53",
      "text": "Secundum omnia verba hæc scripsit omni regno suo: et præposuit principes populo, qui hæc fieri cogerent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.54",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Maccabees 1:54",
      "text": "Et jusserunt civitatibus Juda sacrificare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.55",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 55,
      "referenceLabel": "1 Maccabees 1:55",
      "text": "Et congregati sunt multi de populo ad eos qui dereliquerant legem Domini, et fecerunt mala super terram:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.56",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 56,
      "referenceLabel": "1 Maccabees 1:56",
      "text": "et effugaverunt populum Israël in abditis, et in absconditis fugitivorum locis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.1.57",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 1,
      "verseNumber": 57,
      "referenceLabel": "1 Maccabees 1:57",
