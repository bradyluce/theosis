{
  "chapter": {
    "id": "vulgate:first-maccabees.7",
    "translationId": "vulgate",
    "bookSlug": "first-maccabees",
    "chapterNumber": 7,
    "referenceLabel": "1 Maccabees 7",
    "summary": "Source text for 1 Maccabees 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-maccabees.7.1",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "1 Maccabees 7:1",
      "text": "Anno centesimo quinquagesimo primo, exiit Demetrius Seleuci filius ab urbe Roma, et ascendit cum paucis viris in civitatem maritimam, et regnavit illic.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-maccabees.7.2",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "1 Maccabees 7:2",
      "text": "Et factum est, ut ingressus est domum regni patrum suorum, comprehendit exercitus Antiochum et Lysiam, ut adducerent eos ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.3",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "1 Maccabees 7:3",
      "text": "Et res ei innotuit, et ait: Nolite mihi ostendere faciem eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.4",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "1 Maccabees 7:4",
      "text": "Et occidit eos exercitus. Et sedit Demetrius super sedem regni sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.5",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "1 Maccabees 7:5",
      "text": "Et venerunt ad eum viri iniqui et impii ex Israël: et Alcimus dux eorum, qui volebat fieri sacerdos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.6",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "1 Maccabees 7:6",
      "text": "Et accusaverunt populum apud regem, dicentes: Perdidit Judas et fratres ejus omnes amicos tuos, et nos dispersit de terra nostra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.7",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "1 Maccabees 7:7",
      "text": "Nunc ergo mitte virum, cui credis, ut eat, et videat exterminium omne quod fecit nobis, et regionibus regis: et puniat omnes amicos ejus, et adjutores eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.8",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "1 Maccabees 7:8",
      "text": "Et elegit rex ex amicis suis Bacchidem, qui dominabatur trans flumen magnum in regno, et fidelem regi: et misit eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.9",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "1 Maccabees 7:9",
      "text": "ut videret exterminium quod fecit Judas: sed et Alcimum impium constituit in sacerdotium, et mandavit ei facere ultionem in filios Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.10",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "1 Maccabees 7:10",
      "text": "Et surrexerunt, et venerunt cum exercitu magno in terram Juda: et miserunt nuntios, et locuti sunt ad Judam et ad fratres ejus verbis pacificis in dolo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.11",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "1 Maccabees 7:11",
      "text": "Et non intenderunt sermonibus eorum: viderunt enim quia venerunt cum exercitu magno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.12",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "1 Maccabees 7:12",
      "text": "Et convenerunt ad Alcimum et Bacchidem congregatio scribarum requirere quæ justa sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.13",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "1 Maccabees 7:13",
      "text": "et primi, Assidæi qui erant in filiis Israël: et exquirebant ab eis pacem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.14",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "1 Maccabees 7:14",
      "text": "Dixerunt enim: Homo sacerdos de semine Aaron venit; non decipiet nos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.15",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "1 Maccabees 7:15",
      "text": "et locutus est cum eis verba pacifica, et juravit illis, dicens: Non inferemus vobis malum, neque amicis vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.16",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "1 Maccabees 7:16",
      "text": "Et crediderunt ei: et comprehendit ex eis sexaginta viros, et occidit eos in una die, secundum verbum quod scriptum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.17",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "1 Maccabees 7:17",
      "text": "Carnes sanctorum tuorum, et sanguinem ipsorum effuderunt in circuitu Jerusalem, et non erat qui sepeliret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.18",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "1 Maccabees 7:18",
      "text": "Et incubuit timor et tremor in omnem populum: quia dixerunt: Non est veritas, et judicium in eis: transgressi sunt enim constitutum, et jusjurandum quod juraverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.19",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "1 Maccabees 7:19",
      "text": "Et movit Bacchides castra ab Jerusalem, et applicuit in Bethzecha: et misit, et comprehendit multos ex eis qui a se effugerant: et quosdam de populo mactavit, et in puteum magnum projecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.20",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "1 Maccabees 7:20",
      "text": "Et commisit regionem Alcimo, et reliquit cum eo auxilium in adjutorium ipsi. Et abiit Bacchides ad regem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.21",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "1 Maccabees 7:21",
      "text": "et satis agebat Alcimus pro principatu sacerdotii sui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.22",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "1 Maccabees 7:22",
      "text": "et convenerunt ad eum omnes, qui perturbabant populum suum, et obtinuerunt terram Juda, et fecerunt plagam magnam in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.23",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "1 Maccabees 7:23",
      "text": "Et vidit Judas omnia mala quæ fecit Alcimus et qui cum eo erant filiis Israël, multo plus quam gentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.24",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "1 Maccabees 7:24",
      "text": "et exiit in omnes fines Judææ in circuitu, et fecit vindictam in viros desertores, et cessaverunt ultra exire in regionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.25",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "1 Maccabees 7:25",
      "text": "Vidit autem Alcimus quod prævaluit Judas et qui cum eo erant, et cognovit quia non potest sustinere eos: et regressus est ad regem, et accusavit eos multis criminibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.26",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "1 Maccabees 7:26",
      "text": "Et misit rex Nicanorem, unum ex principibus suis nobilioribus, qui erat inimicitias exercens contra Israël: et mandavit ei evertere populum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.27",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "1 Maccabees 7:27",
      "text": "Et venit Nicanor in Jerusalem cum exercitu magno, et misit ad Judam et ad fratres ejus verbis pacificis cum dolo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.28",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "1 Maccabees 7:28",
      "text": "dicens: Non sit pugna inter me et vos: veniam cum viris paucis, ut videam facies vestras cum pace.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.29",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "1 Maccabees 7:29",
      "text": "Et venit ad Judam, et salutaverunt se invicem pacifice: et hostes parati erant rapere Judam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.30",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "1 Maccabees 7:30",
      "text": "Et innotuit sermo Judæ quoniam cum dolo venerat ad eum: et conterritus est ab eo, et amplius noluit videre faciem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.31",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "1 Maccabees 7:31",
      "text": "Et cognovit Nicanor quoniam denudatum est consilium ejus: et exivit obviam Judæ in pugnam juxta Capharsalama.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.32",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "1 Maccabees 7:32",
      "text": "Et ceciderunt de Nicanoris exercitu fere quinque millia viri, et fugerunt in civitatem David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.33",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "1 Maccabees 7:33",
      "text": "Et post hæc verba ascendit Nicanor in montem Sion: et exierunt de sacerdotibus populi salutare eum in pace, et demonstrare ei holocautomata, quæ offerebantur pro rege.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.34",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "1 Maccabees 7:34",
      "text": "Et irridens sprevit eos, et polluit: et locutus est superbe,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.35",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "1 Maccabees 7:35",
      "text": "et juravit cum ira, dicens: Nisi traditus fuerit Judas et exercitus ejus in manus meas, continuo cum regressus fuero in pace, succendam domum istam. Et exiit cum ira magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.36",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "1 Maccabees 7:36",
      "text": "Et intraverunt sacerdotes, et steterunt ante faciem altaris et templi, et flentes dixerunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.37",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "1 Maccabees 7:37",
      "text": "Tu, Domine, elegisti domum istam ad invocandum nomen tuum in ea, ut esset domus orationis et obsecrationis populo tuo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.38",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "1 Maccabees 7:38",
      "text": "fac vindictam in homine isto et exercitu ejus, et cadant in gladio: memento blasphemias eorum, et ne dederis eis ut permaneant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.39",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "1 Maccabees 7:39",
      "text": "Et exiit Nicanor ab Jerusalem, et castra applicuit ad Bethoron: et occurrit illi exercitus Syriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.40",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "1 Maccabees 7:40",
      "text": "Et Judas applicuit in Adarsa cum tribus millibus viris: et oravit Judas, et dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.41",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 41,
      "referenceLabel": "1 Maccabees 7:41",
      "text": "Qui missi erant a rege Sennacherib, Domine, quia blasphemaverunt te, exiit angelus, et percussit ex eis centum octoginta quinque millia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.42",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 42,
      "referenceLabel": "1 Maccabees 7:42",
      "text": "sic contere exercitum istum in conspectu nostro hodie: et sciant ceteri quia male locutus est super sancta tua: et judica illum secundum malitiam illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.43",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 43,
      "referenceLabel": "1 Maccabees 7:43",
      "text": "Et commiserunt exercitus prælium tertiadecima die mensis Adar: et contrita sunt castra Nicanoris, et cecidit ipse primus in prælio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.44",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 44,
      "referenceLabel": "1 Maccabees 7:44",
      "text": "Ut autem vidit exercitus ejus quia cecidisset Nicanor, projecerunt arma sua, et fugerunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.45",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 45,
      "referenceLabel": "1 Maccabees 7:45",
      "text": "et persecuti sunt eos viam unius diei ab Adazer usquequo veniatur in Gazara, et tubis cecinerunt post eos cum significationibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.46",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 46,
      "referenceLabel": "1 Maccabees 7:46",
      "text": "et exierunt de omnibus castellis Judææ in circuitu, et ventilabant eos cornibus, et convertebantur iterum ad eos, et ceciderunt omnes gladio, et non est relictus ex eis nec unus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.47",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 47,
      "referenceLabel": "1 Maccabees 7:47",
      "text": "Et acceperunt spolia eorum in prædam: et caput Nicanoris amputaverunt, et dexteram ejus, quam extenderat superbe, et attulerunt, et suspenderunt contra Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.48",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 48,
      "referenceLabel": "1 Maccabees 7:48",
      "text": "Et lætatus est populus valde, et egerunt diem illam in lætitia magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.49",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 49,
      "referenceLabel": "1 Maccabees 7:49",
      "text": "Et constituit agi omnibus annis diem istam tertiadecima die mensis Adar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-maccabees.7.50",
      "translationId": "vulgate",
      "bookSlug": "first-maccabees",
      "chapterNumber": 7,
      "verseNumber": 50,
      "referenceLabel": "1 Maccabees 7:50",
      "text": "Et siluit terra Juda dies paucos.",
      "paragraphStart": false
    }
  ]
}
