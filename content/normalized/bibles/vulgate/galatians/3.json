{
  "chapter": {
    "id": "vulgate:galatians.3",
    "translationId": "vulgate",
    "bookSlug": "galatians",
    "chapterNumber": 3,
    "referenceLabel": "Galatians 3",
    "summary": "Source text for Galatians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:galatians.3.1",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Galatians 3:1",
      "text": "O insensati Galatæ, quis vos fascinavit non obedire veritati, ante quorum oculos Jesus Christus præscriptus est, in vobis crucifixus?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:galatians.3.2",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Galatians 3:2",
      "text": "Hoc solum a vobis volo discere: ex operibus legis Spiritum accepistis, an ex auditu fidei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.3",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Galatians 3:3",
      "text": "sic stulti estis, ut cum Spiritu cœperitis, nunc carne consummemini?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.4",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Galatians 3:4",
      "text": "tanta passi estis sine causa? si tamen sine causa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.5",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Galatians 3:5",
      "text": "Qui ergo tribuit vobis Spiritum, et operatur virtutes in vobis: ex operibus legis, an ex auditu fidei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.6",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Galatians 3:6",
      "text": "Sicut scriptum est: Abraham credidit Deo, et reputatum est illi ad justitiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.7",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Galatians 3:7",
      "text": "cognoscite ergo quia qui ex fide sunt, ii sunt filii Abrahæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.8",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Galatians 3:8",
      "text": "Providens autem Scriptura quia ex fide justificat gentes Deus, prænuntiavit Abrahæ: Quia benedicentur in te omnes gentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.9",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Galatians 3:9",
      "text": "Igitur qui ex fide sunt, benedicentur cum fideli Abraham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.10",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Galatians 3:10",
      "text": "Quicumque enim ex operibus legis sunt, sub maledicto sunt. Scriptum est enim: Maledictus omnis qui non permanserit in omnibus quæ scripta sunt in libro legis ut faciat ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.11",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Galatians 3:11",
      "text": "Quoniam autem in lege nemo justificatur apud Deum, manifestum est: quia justus ex fide vivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.12",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Galatians 3:12",
      "text": "Lex autem non est ex fide, sed: Qui fecerit ea, vivet in illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.13",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Galatians 3:13",
      "text": "Christus nos redemit de maledicto legis, factus pro nobis maledictum: quia scriptum est: Maledictus omnis qui pendet in ligno:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.14",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Galatians 3:14",
      "text": "ut in gentibus benedictio Abrahæ fieret in Christo Jesu, ut pollicitationem Spiritus accipiamus per fidem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.15",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Galatians 3:15",
      "text": "Fratres (secundum hominem dico) tamen hominis confirmatum testamentum nemo spernit, aut superordinat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.16",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Galatians 3:16",
      "text": "Abrahæ dictæ sunt promissiones, et semini ejus. Non dicit: Et seminibus, quasi in multis: sed quasi in uno: Et semini tuo, qui est Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.17",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Galatians 3:17",
      "text": "Hoc autem dico, testamentum confirmatum a Deo: quæ post quadringentos et triginta annos facta est lex, non irritum facit ad evacuandam promissionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.18",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Galatians 3:18",
      "text": "Nam si ex lege hæreditas, jam non ex promissione. Abrahæ autem per repromissionem donavit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.19",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Galatians 3:19",
      "text": "Quid igitur lex? Propter transgressiones posita est donec veniret semen, cui promiserat, ordinata per angelos in manu mediatoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.20",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Galatians 3:20",
      "text": "Mediator autem unius non est: Deus autem unus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.21",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Galatians 3:21",
      "text": "Lex ergo adversus promissa Dei? Absit. Si enim data esset lex, quæ posset vivificare, vere ex lege esset justitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.22",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Galatians 3:22",
      "text": "Sed conclusit Scriptura omnia sub peccato, ut promissio ex fide Jesu Christi daretur credentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.23",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Galatians 3:23",
      "text": "Prius autem quam veniret fides, sub lege custodiebamur conclusi in eam fidem quæ revelanda erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.24",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Galatians 3:24",
      "text": "Itaque lex pædagogus noster fuit in Christo, ut ex fide justificemur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.25",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Galatians 3:25",
      "text": "At ubi venit fides, jam non sumus sub pædagogo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.26",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Galatians 3:26",
      "text": "Omnes enim filii Dei estis per fidem, quæ est in Christo Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.27",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Galatians 3:27",
      "text": "Quicumque enim in Christo baptizati estis, Christum induistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.28",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Galatians 3:28",
      "text": "Non est Judæus, neque Græcus: non est servus, neque liber: non est masculus, neque femina. Omnes enim vos unum estis in Christo Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.3.29",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Galatians 3:29",
      "text": "Si autem vos Christi, ergo semen Abrahæ estis, secundum promissionem hæredes.",
      "paragraphStart": false
    }
  ]
}
