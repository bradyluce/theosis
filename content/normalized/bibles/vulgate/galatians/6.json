{
  "chapter": {
    "id": "vulgate:galatians.6",
    "translationId": "vulgate",
    "bookSlug": "galatians",
    "chapterNumber": 6,
    "referenceLabel": "Galatians 6",
    "summary": "Source text for Galatians 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:galatians.6.1",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Galatians 6:1",
      "text": "Fratres, etsi præoccupatus fuerit homo in aliquo delicto, vos, qui spirituales estis, hujusmodi instruite in spiritu lenitatis, considerans teipsum, ne et tu tenteris.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:galatians.6.2",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Galatians 6:2",
      "text": "Alter alterius onera portate, et sic adimplebitis legem Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.3",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Galatians 6:3",
      "text": "Nam si quis existimat se aliquid esse, cum nihil sit, ipse se seducit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.4",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Galatians 6:4",
      "text": "Opus autem suum probet unusquisque, et sic in semetipso tantum gloriam habebit, et non in altero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.5",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Galatians 6:5",
      "text": "Unusquisque enim onus suum portabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.6",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Galatians 6:6",
      "text": "Communicet autem is qui catechizatur verbo, ei qui se catechizat, in omnibus bonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.7",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Galatians 6:7",
      "text": "Nolite errare: Deus non irridetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.8",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Galatians 6:8",
      "text": "Quæ enim seminaverit homo, hæc et metet. Quoniam qui seminat in carne sua, de carne et metet corruptionem: qui autem seminat in spiritu, de spiritu metet vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.9",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Galatians 6:9",
      "text": "Bonum autem facientes, non deficiamus: tempore enim suo metemus non deficientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.10",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Galatians 6:10",
      "text": "Ergo dum tempus habemus, operemur bonum ad omnes, maxime autem ad domesticos fidei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.11",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Galatians 6:11",
      "text": "Videte qualibus litteris scripsi vobis mea manu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.12",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Galatians 6:12",
      "text": "Quicumque enim volunt placere in carne, hi cogunt vos circumcidi, tantum ut crucis Christi persecutionem non patiantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.13",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Galatians 6:13",
      "text": "Neque enim qui circumciduntur, legem custodiunt: sed volunt vos circumcidi, ut in carne vestra glorientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.14",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Galatians 6:14",
      "text": "Mihi autem absit gloriari, nisi in cruce Domini nostri Jesu Christi: per quem mihi mundus crucifixus est, et ego mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.15",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Galatians 6:15",
      "text": "In Christo enim Jesu neque circumcisio aliquid valet, neque præputium, sed nova creatura.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.16",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Galatians 6:16",
      "text": "Et quicumque hanc regulam secuti fuerint, pax super illos, et misericordia, et super Israël Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.17",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Galatians 6:17",
      "text": "De cetero, nemo mihi molestus sit: ego enim stigmata Domini Jesu in corpore meo porto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.6.18",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Galatians 6:18",
      "text": "Gratia Domini nostri Jesu Christi cum spiritu vestro, fratres. Amen.",
      "paragraphStart": false
    }
  ]
}
