{
  "chapter": {
    "id": "vulgate:galatians.5",
    "translationId": "vulgate",
    "bookSlug": "galatians",
    "chapterNumber": 5,
    "referenceLabel": "Galatians 5",
    "summary": "Source text for Galatians 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:galatians.5.1",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Galatians 5:1",
      "text": "State, et nolite iterum jugo servitutis contineri.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:galatians.5.2",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Galatians 5:2",
      "text": "Ecce ego Paulus dico vobis: quoniam si circumcidamini, Christus vobis nihil proderit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.3",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Galatians 5:3",
      "text": "Testificor autem rursus omni homini circumcidenti se, quoniam debitor est universæ legis faciendæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.4",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Galatians 5:4",
      "text": "Evacuati estis a Christo, qui in lege justificamini: a gratia excidistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.5",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Galatians 5:5",
      "text": "Nos enim spiritu ex fide, spem justitiæ exspectamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.6",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Galatians 5:6",
      "text": "Nam in Christo Jesu neque circumcisio aliquid valet, neque præputium: sed fides, quæ per caritatem operatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.7",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Galatians 5:7",
      "text": "Currebatis bene: quis vos impedivit veritati non obedire?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.8",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Galatians 5:8",
      "text": "persuasio hæc non est ex eo, qui vocat vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.9",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Galatians 5:9",
      "text": "Modicum fermentum totam massam corrumpit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.10",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Galatians 5:10",
      "text": "Ego confido in vobis in Domino, quod nihil aliud sapietis: qui autem conturbat vos, portabit judicium, quicumque est ille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.11",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Galatians 5:11",
      "text": "Ego autem, fratres, si circumcisionem adhuc prædico: quid adhuc persecutionem patior? ergo evacuatum est scandalum crucis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.12",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Galatians 5:12",
      "text": "Utinam et abscindantur qui vos conturbant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.13",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Galatians 5:13",
      "text": "Vos enim in libertatem vocati estis, fratres: tantum ne libertatem in occasionem detis carnis, sed per caritatem Spiritus servite invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.14",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Galatians 5:14",
      "text": "Omnis enim lex in uno sermone impletur: Diliges proximum tuum sicut teipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.15",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Galatians 5:15",
      "text": "Quod si invicem mordetis, et comeditis: videte ne ab invicem consumamini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.16",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Galatians 5:16",
      "text": "Dico autem: Spiritu ambulate, et desideria carnis non perficietis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.17",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Galatians 5:17",
      "text": "Caro enim concupiscit adversus spiritum, spiritus autem adversus carnem: hæc enim sibi invicem adversantur, ut non quæcumque vultis, illa faciatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.18",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Galatians 5:18",
      "text": "Quod si Spiritu ducimini, non estis sub lege.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.19",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Galatians 5:19",
      "text": "Manifesta sunt autem opera carnis, quæ sunt fornicatio, immunditia, impudicitia, luxuria,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.20",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Galatians 5:20",
      "text": "idolorum servitus, veneficia, inimicitiæ, contentiones, æmulationes, iræ, rixæ, dissensiones, sectæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.21",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Galatians 5:21",
      "text": "invidiæ, homicidia, ebrietates, comessationes, et his similia, quæ prædico vobis, sicut prædixi: quoniam qui talia agunt, regnum Dei non consequentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.22",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Galatians 5:22",
      "text": "Fructus autem Spiritus est caritas, gaudium, pax, patientia, benignitas, bonitas, longanimitas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.23",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Galatians 5:23",
      "text": "mansuetudo, fides, modestia, continentia, castitas. Adversus hujusmodi non est lex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.24",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Galatians 5:24",
      "text": "Qui autem sunt Christi, carnem suam crucifixerunt cum vitiis et concupiscentiis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.25",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Galatians 5:25",
      "text": "Si Spiritu vivimus, Spiritu et ambulemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.5.26",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Galatians 5:26",
      "text": "Non efficiamur inanis gloriæ cupidi, invicem provocantes, invicem invidentes.",
      "paragraphStart": false
    }
  ]
}
