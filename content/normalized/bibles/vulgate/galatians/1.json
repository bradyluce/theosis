{
  "chapter": {
    "id": "vulgate:galatians.1",
    "translationId": "vulgate",
    "bookSlug": "galatians",
    "chapterNumber": 1,
    "referenceLabel": "Galatians 1",
    "summary": "Source text for Galatians 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:galatians.1.1",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Galatians 1:1",
      "text": "Paulus, Apostolus non ab hominibus, neque per hominem, sed per Jesum Christum, et Deum Patrem, qui suscitavit eum a mortuis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:galatians.1.2",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Galatians 1:2",
      "text": "et qui mecum sunt omnes fratres, ecclesiis Galatiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.3",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Galatians 1:3",
      "text": "Gratia vobis, et pax a Deo Patre, et Domino nostro Jesu Christo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.4",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Galatians 1:4",
      "text": "qui dedit semetipsum pro peccatis nostris, ut eriperet nos de præsenti sæculo nequam, secundum voluntatem Dei et Patris nostri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.5",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Galatians 1:5",
      "text": "cui est gloria in sæcula sæculorum. Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.6",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Galatians 1:6",
      "text": "Miror quod sic tam cito transferimini ab eo qui vos vocavit in gratiam Christi in aliud Evangelium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.7",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Galatians 1:7",
      "text": "quod non est aliud, nisi sunt aliqui qui vos conturbant, et volunt convertere Evangelium Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.8",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Galatians 1:8",
      "text": "Sed licet nos aut angelus de cælo evangelizet vobis præterquam quod evangelizavimus vobis, anathema sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.9",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Galatians 1:9",
      "text": "Sicut prædiximus, et nunc iterum dico: si quis vobis evangelizaverit præter id quod accepistis, anathema sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.10",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Galatians 1:10",
      "text": "Modo enim hominibus suadeo, an Deo? an quæro hominibus placere? si adhuc hominibus placerem, Christi servus non essem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.11",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Galatians 1:11",
      "text": "Notum enim vobis facio, fratres, Evangelium, quod evangelizatum est a me, quia non est secundum hominem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.12",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Galatians 1:12",
      "text": "neque enim ego ab homine accepi illud, neque didici, sed per revelationem Jesu Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.13",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Galatians 1:13",
      "text": "Audistis enim conversationem meam aliquando in Judaismo: quoniam supra modum persequebar Ecclesiam Dei, et expugnabam illam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.14",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Galatians 1:14",
      "text": "et proficiebam in Judaismo supra multos coætaneos meos in genere meo, abundantius æmulator existens paternarum mearum traditionum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.15",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Galatians 1:15",
      "text": "Cum autem placuit ei, qui me segregavit ex utero matris meæ, et vocavit per gratiam suam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.16",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Galatians 1:16",
      "text": "ut revelaret Filium suum in me, ut evangelizarem illum in gentibus: continuo non acquievi carni et sanguini,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.17",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Galatians 1:17",
      "text": "neque veni Jerosolymam ad antecessores meos Apostolos: sed abii in Arabiam, et iterum reversus sum Damascum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.18",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Galatians 1:18",
      "text": "deinde post annos tres veni Jerosolymam videre Petrum, et mansi apud eum diebus quindecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.19",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Galatians 1:19",
      "text": "alium autem Apostolorum vidi neminem, nisi Jacobum fratrem Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.20",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Galatians 1:20",
      "text": "Quæ autem scribo vobis, ecce coram Deo, quia non mentior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.21",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Galatians 1:21",
      "text": "Deinde veni in partes Syriæ, et Ciliciæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.22",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Galatians 1:22",
      "text": "Eram autem ignotus facie ecclesiis Judææ, quæ erant in Christo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.23",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Galatians 1:23",
      "text": "tantum autem auditum habebant quoniam qui persequebatur nos aliquando, nunc evangelizat fidem, quam aliquando expugnabat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.1.24",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Galatians 1:24",
      "text": "et in me clarificabant Deum.",
      "paragraphStart": false
    }
  ]
}
