{
  "chapter": {
    "id": "vulgate:galatians.4",
    "translationId": "vulgate",
    "bookSlug": "galatians",
    "chapterNumber": 4,
    "referenceLabel": "Galatians 4",
    "summary": "Source text for Galatians 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:galatians.4.1",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Galatians 4:1",
      "text": "Dico autem: quanto tempore hæres parvulus est, nihil differt a servo, cum sit dominus omnium:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:galatians.4.2",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Galatians 4:2",
      "text": "sed sub tutoribus et actoribus est usque ad præfinitum tempus a patre:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.3",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Galatians 4:3",
      "text": "ita et nos cum essemus parvuli, sub elementis mundi eramus servientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.4",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Galatians 4:4",
      "text": "At ubi venit plenitudo temporis, misit Deus Filium suum factum ex muliere, factum sub lege,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.5",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Galatians 4:5",
      "text": "ut eos, qui sub lege erant, redimeret, ut adoptionem filiorum reciperemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.6",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Galatians 4:6",
      "text": "Quoniam autem estis filii, misit Deus Spiritum Filii sui in corda vestra, clamantem: Abba, Pater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.7",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Galatians 4:7",
      "text": "Itaque jam non est servus, sed filius: quod si filius, et hæres per Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.8",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Galatians 4:8",
      "text": "Sed tunc quidem ignorantes Deum, iis, qui natura non sunt dii, serviebatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.9",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Galatians 4:9",
      "text": "Nunc autem cum cognoveritis Deum, immo cogniti sitis a Deo: quomodo convertimini iterum ad infirma et egena elementa, quibus denuo servire vultis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.10",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Galatians 4:10",
      "text": "Dies observatis, et menses, et tempora, et annos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.11",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Galatians 4:11",
      "text": "Timeo vos, ne forte sine causa laboraverim in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.12",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Galatians 4:12",
      "text": "Estote sicut ego, quia et ego sicut vos: fratres, obsecro vos. Nihil me læsistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.13",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Galatians 4:13",
      "text": "Scitis autem quia per infirmitatem carnis evangelizavi vobis jampridem: et tentationem vestram in carne mea",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.14",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Galatians 4:14",
      "text": "non sprevistis, neque respuistis: sed sicut angelum Dei excepistis me, sicut Christum Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.15",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Galatians 4:15",
      "text": "Ubi est ergo beatitudo vestra? testimonium enim perhibeo vobis, quia, si fieri posset, oculos vestros eruissetis, et dedissetis mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.16",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Galatians 4:16",
      "text": "Ergo inimicus vobis factus sum, verum dicens vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.17",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Galatians 4:17",
      "text": "Æmulantur vos non bene: sed excludere vos volunt, ut illos æmulemini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.18",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Galatians 4:18",
      "text": "Bonum autem æmulamini in bono semper: et non tantum cum præsens sum apud vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.19",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Galatians 4:19",
      "text": "Filioli mei, quos iterum parturio, donec formetur Christus in vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.20",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Galatians 4:20",
      "text": "vellem autem esse apud vos modo, et mutare vocem meam: quoniam confundor in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.21",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Galatians 4:21",
      "text": "Dicite mihi qui sub lege vultis esse: legem non legistis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.22",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Galatians 4:22",
      "text": "Scriptum est enim: Quoniam Abraham duos filios habuit: unum de ancilla, et unum de libera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.23",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Galatians 4:23",
      "text": "Sed qui de ancilla, secundum carnem natus est: qui autem de libera, per repromissionem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.24",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Galatians 4:24",
      "text": "quæ sunt per allegoriam dicta. Hæc enim sunt duo testamenta. Unum quidem in monte Sina, in servitutem generans, quæ est Agar:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.25",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Galatians 4:25",
      "text": "Sina enim mons est in Arabia, qui conjunctus est ei quæ nunc est Jerusalem, et servit cum filiis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.26",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Galatians 4:26",
      "text": "Illa autem, quæ sursum est Jerusalem, libera est, quæ est mater nostra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.27",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Galatians 4:27",
      "text": "Scriptum est enim: Lætare, sterilis, quæ non paris; erumpe et clama, quæ non parturis: quia multi filii desertæ, magis quam ejus quæ habet virum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.28",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Galatians 4:28",
      "text": "Nos autem, fratres, secundum Isaac promissionis filii sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.29",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Galatians 4:29",
      "text": "Sed quomodo tunc is, qui secundum carnem natus fuerat, persequebatur eum qui secundum spiritum: ita et nunc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.30",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Galatians 4:30",
      "text": "Sed quid dicit Scriptura? Ejice ancillam, et filium ejus: non enim hæres erit filius ancillæ cum filio liberæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:galatians.4.31",
      "translationId": "vulgate",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Galatians 4:31",
      "text": "Itaque, fratres, non sumus ancillæ filii, sed liberæ: qua libertate Christus nos liberavit.",
      "paragraphStart": false
    }
  ]
}
