{
  "chapter": {
    "id": "vulgate:genesis.15",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 15,
    "referenceLabel": "Genesis 15",
    "summary": "Source text for Genesis 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.15.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Genesis 15:1",
      "text": "His itaque transactis, factus est sermo Domini ad Abram per visionem dicens: Noli timere, Abram: ego protector tuus sum, et merces tua magna nimis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.15.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Genesis 15:2",
      "text": "Dixitque Abram: Domine Deus, quid dabis mihi? ego vadam absque liberis, et filius procuratoris domus meæ iste Damascus Eliezer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Genesis 15:3",
      "text": "Addiditque Abram: Mihi autem non dedisti semen, et ecce vernaculus meus, hæres meus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Genesis 15:4",
      "text": "Statimque sermo Domini factus est ad eum, dicens: Non erit hic hæres tuus, sed qui egredietur de utero tuo, ipsum habebis hæredem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Genesis 15:5",
      "text": "Eduxitque eum foras, et ait illi: Suspice cælum, et numera stellas, si potes. Et dixit ei: Sic erit semen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Genesis 15:6",
      "text": "Credidit Abram Deo, et reputatum est illi ad justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Genesis 15:7",
      "text": "Dixitque ad eum: Ego Dominus qui eduxi te de Ur Chaldæorum ut darem tibi terram istam, et possideres eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Genesis 15:8",
      "text": "At ille ait: Domine Deus, unde scire possum quod possessurus sim eam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Genesis 15:9",
      "text": "Et respondens Dominus: Sume, inquit, mihi vaccam triennem, et capram trimam, et arietem annorum trium, turturem quoque et columbam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Genesis 15:10",
      "text": "Qui tollens universa hæc, divisit ea per medium, et utrasque partes contra se altrinsecus posuit; aves autem non divisit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Genesis 15:11",
      "text": "Descenderuntque volucres super cadavera, et abigebat eas Abram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Genesis 15:12",
      "text": "Cumque sol occumberet, sopor irruit super Abram, et horror magnus et tenebrosus invasit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Genesis 15:13",
      "text": "Dictumque est ad eum: Scito prænoscens quod peregrinum futurum sit semen tuum in terra non sua, et subjicient eos servituti, et affligent quadringentis annis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Genesis 15:14",
      "text": "Verumtamen gentem, cui servituri sunt, ego judicabo: et post hæc egredientur cum magna substantia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Genesis 15:15",
      "text": "Tu autem ibis ad patres tuos in pace, sepultus in senectute bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Genesis 15:16",
      "text": "Generatione autem quarta revertentur huc: necdum enim completæ sunt iniquitates Amorrhæorum usque ad præsens tempus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Genesis 15:17",
      "text": "Cum ergo occubuisset sol, facta est caligo tenebrosa, et apparuit clibanus fumans, et lampas ignis transiens inter divisiones illas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Genesis 15:18",
      "text": "In illo die pepigit Dominus fœdus cum Abram, dicens: Semini tuo dabo terram hanc a fluvio Ægypti usque ad fluvium magnum Euphraten,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Genesis 15:19",
      "text": "Cinæos, et Cenezæos, Cedmonæos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Genesis 15:20",
      "text": "et Hethæos, et Pherezæos, Raphaim quoque,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.15.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Genesis 15:21",
      "text": "et Amorrhæos, et Chananæos, et Gergesæos, et Jebusæos.",
      "paragraphStart": false
    }
  ]
}
