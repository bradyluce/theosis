{
  "chapter": {
    "id": "vulgate:genesis.46",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 46,
    "referenceLabel": "Genesis 46",
    "summary": "Source text for Genesis 46 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.46.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Genesis 46:1",
      "text": "Profectusque Israël cum omnibus quæ habebat, venit ad Puteum juramenti: et mactatis ibi victimis Deo patris sui Isaac,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.46.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Genesis 46:2",
      "text": "audivit eum per visionem noctis vocantem se, et dicentem sibi: Jacob, Jacob. Cui respondit: Ecce adsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Genesis 46:3",
      "text": "Ait illi Deus: Ego sum fortissimus Deus patris tui: noli timere, descende in Ægyptum, quia in gentem magnam faciam te ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Genesis 46:4",
      "text": "Ego descendam tecum illuc, et ego inde adducam te revertentem: Joseph quoque ponet manus suas super oculos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Genesis 46:5",
      "text": "Surrexit autem Jacob a Puteo juramenti: tuleruntque eum filii cum parvulis et uxoribus suis in plaustris quæ miserat Pharao ad portandum senem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Genesis 46:6",
      "text": "et omnia quæ possederat in terra Chanaan: venitque in Ægyptum cum omni semine suo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Genesis 46:7",
      "text": "filii ejus, et nepotes, filiæ, et cuncta simul progenies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Genesis 46:8",
      "text": "Hæc sunt autem nomina filiorum Israël, qui ingressi sunt in Ægyptum, ipse cum liberis suis. Primogenitus Ruben.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Genesis 46:9",
      "text": "Filii Ruben: Henoch et Phallu et Hesron et Charmi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Genesis 46:10",
      "text": "Filii Simeon: Jamuel et Jamin et Ahod, et Jachin et Sohar, et Saul filius Chanaanitidis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Genesis 46:11",
      "text": "Filii Levi: Gerson et Caath et Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 12,
      "referenceLabel": "Genesis 46:12",
      "text": "Filii Juda: Her et Onan et Sela et Phares et Zara; mortui sunt autem Her et Onan in terra Chanaan. Natique sunt filii Phares: Hesron et Hamul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 13,
      "referenceLabel": "Genesis 46:13",
      "text": "Filii Issachar: Thola et Phua et Job et Semron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 14,
      "referenceLabel": "Genesis 46:14",
      "text": "Filii Zabulon: Sared et Elon et Jahelel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 15,
      "referenceLabel": "Genesis 46:15",
      "text": "Hi filii Liæ quos genuit in Mesopotamia Syriæ cum Dina filia sua: omnes animæ filiorum ejus et filiarum, triginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 16,
      "referenceLabel": "Genesis 46:16",
      "text": "Filii Gad: Sephion et Haggi et Suni et Esebon et Heri et Arodi et Areli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 17,
      "referenceLabel": "Genesis 46:17",
      "text": "Filii Aser: Jamne et Jesua et Jessui et Beria, Sara quoque soror eorum. Filii Beria: Heber et Melchiel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 18,
      "referenceLabel": "Genesis 46:18",
      "text": "Hi filii Zelphæ, quam dedit Laban Liæ filiæ suæ: et hos genuit Jacob sedecim animas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 19,
      "referenceLabel": "Genesis 46:19",
      "text": "Filii Rachel uxoris Jacob: Joseph et Benjamin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 20,
      "referenceLabel": "Genesis 46:20",
      "text": "Natique sunt Joseph filii in terra Ægypti, quos genuit ei Aseneth filia Putiphare sacerdotis Heliopoleos: Manasses et Ephraim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 21,
      "referenceLabel": "Genesis 46:21",
      "text": "Filii Benjamin: Bela et Bechor et Asbel et Gera et Naaman et Echi et Ros et Mophim et Ophim et Ared.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 22,
      "referenceLabel": "Genesis 46:22",
      "text": "Hi filii Rachel quos genuit Jacob: omnes animæ, quatuordecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 23,
      "referenceLabel": "Genesis 46:23",
      "text": "Filii Dan: Husim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 24,
      "referenceLabel": "Genesis 46:24",
      "text": "Filii Nephthali: Jasiel et Guni et Jeser et Sallem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 25,
      "referenceLabel": "Genesis 46:25",
      "text": "Hi filii Balæ, quam dedit Laban Racheli filiæ suæ: et hos genuit Jacob: omnes animæ, septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 26,
      "referenceLabel": "Genesis 46:26",
      "text": "Cunctæ animæ, quæ ingressæ sunt cum Jacob in Ægyptum, et egressæ sunt de femore illius, absque uxoribus filiorum ejus, sexaginta sex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 27,
      "referenceLabel": "Genesis 46:27",
      "text": "Filii autem Joseph, qui nati sunt ei in terra Ægypti, animæ duæ. Omnes animæ domus Jacob, quæ ingressæ sunt in Ægyptum, fuere septuaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 28,
      "referenceLabel": "Genesis 46:28",
      "text": "Misit autem Judam ante se ad Joseph, ut nuntiaret ei, et occurreret in Gessen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 29,
      "referenceLabel": "Genesis 46:29",
      "text": "Quo cum pervenisset, juncto Joseph curro suo, ascendit obviam patri suo ad eumdem locum: vidensque eum, irruit super collum ejus, et inter amplexus flevit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 30,
      "referenceLabel": "Genesis 46:30",
      "text": "Dixitque pater ad Joseph: Jam lætus moriar, quia vidi faciem tuam, et superstitem te relinquo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 31,
      "referenceLabel": "Genesis 46:31",
      "text": "At ille locutus est ad fratres suos, et ad omnem domum patris sui: Ascendam, et nuntiabo Pharaoni, dicamque ei: Fratres mei, et domus patris mei, qui erant in terra Chanaan, venerunt ad me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 32,
      "referenceLabel": "Genesis 46:32",
      "text": "et sunt viri pastores ovium, curamque habent alendorum gregum: pecora sua, et armenta, et omnia quæ habere potuerunt, adduxerunt secum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.33",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 33,
      "referenceLabel": "Genesis 46:33",
      "text": "Cumque vocaverit vos, et dixerit: Quod est opus vestrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.46.34",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 46,
      "verseNumber": 34,
      "referenceLabel": "Genesis 46:34",
      "text": "respondebitis: Viri pastores sumus servi tui, ab infantia nostra usque in præsens, et nos et patres nostri. Hæc autem dicetis, ut habitare possitis in terra Gessen: quia detestantur Ægyptii omnes pastores ovium.",
      "paragraphStart": false
    }
  ]
}
