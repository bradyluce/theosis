{
  "chapter": {
    "id": "vulgate:genesis.49",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 49,
    "referenceLabel": "Genesis 49",
    "summary": "Source text for Genesis 49 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.49.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 1,
      "referenceLabel": "Genesis 49:1",
      "text": "Vocavit autem Jacob filios suos, et ait eis: Congregamini, ut annuntiem quæ ventura sunt vobis in diebus novissimis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.49.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 2,
      "referenceLabel": "Genesis 49:2",
      "text": "Congregamini, et audite, filii Jacob, audite Israël patrem vestrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 3,
      "referenceLabel": "Genesis 49:3",
      "text": "Ruben, primogenitus meus, tu fortitudo mea, et principium doloris mei; prior in donis, major in imperio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 4,
      "referenceLabel": "Genesis 49:4",
      "text": "Effusus es sicut aqua, non crescas: quia ascendisti cubile patris tui, et maculasti stratum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 5,
      "referenceLabel": "Genesis 49:5",
      "text": "Simeon et Levi fratres vasa iniquitatis bellantia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 6,
      "referenceLabel": "Genesis 49:6",
      "text": "In consilium eorum non veniat anima mea, et in cœtu illorum non sit gloria mea: quia in furore suo occiderunt virum, et in voluntate sua suffoderunt murum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 7,
      "referenceLabel": "Genesis 49:7",
      "text": "Maledictus furor eorum, quia pertinax: et indignatio eorum, quia dura: dividam eos in Jacob, et dispergam eos in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 8,
      "referenceLabel": "Genesis 49:8",
      "text": "Juda, te laudabunt fratres tui: manus tua in cervicibus inimicorum tuorum, adorabunt te filii patris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 9,
      "referenceLabel": "Genesis 49:9",
      "text": "Catulus leonis Juda: ad prædam, fili mi, ascendisti: requiescens accubuisti ut leo, et quasi leæna: quis suscitabit eum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 10,
      "referenceLabel": "Genesis 49:10",
      "text": "Non auferetur sceptrum de Juda, et dux de femore ejus, donec veniat qui mittendus est, et ipse erit expectatio gentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 11,
      "referenceLabel": "Genesis 49:11",
      "text": "Ligans ad vineam pullum suum, et ad vitem, o fili mi, asinam suam, lavabit in vino stolam suam et in sanguine uvæ pallium suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 12,
      "referenceLabel": "Genesis 49:12",
      "text": "Pulchriores sunt oculi ejus vino, et dentes ejus lacte candidiores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 13,
      "referenceLabel": "Genesis 49:13",
      "text": "Zabulon in littore maris habitabit, et in statione navium pertingens usque ad Sidonem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 14,
      "referenceLabel": "Genesis 49:14",
      "text": "Issachar asinus fortis accubans inter terminos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 15,
      "referenceLabel": "Genesis 49:15",
      "text": "Vidit requiem, quod esset bona et terram, quod optima: et supposuit humerum suum ad portandum, factusque est tributis serviens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 16,
      "referenceLabel": "Genesis 49:16",
      "text": "Dan judicabit populum suum sicut et alia tribus in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 17,
      "referenceLabel": "Genesis 49:17",
      "text": "Fiat Dan coluber in via, cerastes in semita, mordens ungulas equi, ut cadat ascensor ejus retro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 18,
      "referenceLabel": "Genesis 49:18",
      "text": "Salutare tuum expectabo, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 19,
      "referenceLabel": "Genesis 49:19",
      "text": "Gad, accinctus præliabitur ante eum: et ipse accingetur retrorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 20,
      "referenceLabel": "Genesis 49:20",
      "text": "Aser, pinguis panis ejus, et præbebit delicias regibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 21,
      "referenceLabel": "Genesis 49:21",
      "text": "Nephthali, cervus emissus, et dans eloquia pulchritudinis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 22,
      "referenceLabel": "Genesis 49:22",
      "text": "Filius accrescens Joseph, filius accrescens et decorus aspectu: filiæ discurrerunt super murum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 23,
      "referenceLabel": "Genesis 49:23",
      "text": "Sed exasperaverunt eum et jurgati sunt, invideruntque illi habentes jacula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 24,
      "referenceLabel": "Genesis 49:24",
      "text": "Sedit in forti arcus ejus, et dissoluta sunt vincula brachiorum et manuum illius per manus potentis Jacob: inde pastor egressus est, lapis Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 25,
      "referenceLabel": "Genesis 49:25",
      "text": "Deus patris tui erit adjutor tuus, et omnipotens benedicet tibi benedictionibus cæli desuper, benedictionibus abyssi jacentis deorsum, benedictionibus uberum et vulvæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 26,
      "referenceLabel": "Genesis 49:26",
      "text": "Benedictiones patris tui confortatæ sunt benedictionibus patrum ejus, donec veniret desiderium collium æternorum: fiant in capite Joseph, et in vertice Nazaræi inter fratres suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 27,
      "referenceLabel": "Genesis 49:27",
      "text": "Benjamin lupus rapax, mane comedat prædam, et vespere dividet spolia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 28,
      "referenceLabel": "Genesis 49:28",
      "text": "Omnes hi in tribubus Israël duodecim: hæc locutus est eis pater suus, benedixitque singulis benedictionibus propriis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 29,
      "referenceLabel": "Genesis 49:29",
      "text": "Et præcepit eis, dicens: Ego congregor ad populum meum: sepelite me cum patribus meis in spelunca duplici quæ est in agro Ephron Hethæi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 30,
      "referenceLabel": "Genesis 49:30",
      "text": "contra Mambre in terra Chanaan, quam emit Abraham cum agro ab Ephron Hethæo in possessionem sepulchri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 31,
      "referenceLabel": "Genesis 49:31",
      "text": "Ibi sepelierunt eum, et Saram uxorem ejus: ibi sepultus est Isaac cum Rebecca conjuge sua: ibi et Lia condita jacet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.49.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 49,
      "verseNumber": 32,
      "referenceLabel": "Genesis 49:32",
      "text": "Finitisque mandatis quibus filios instruebat, collegit pedes suos super lectulum, et obiit: appositusque est ad populum suum.",
      "paragraphStart": false
    }
  ]
}
