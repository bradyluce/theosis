{
  "chapter": {
    "id": "vulgate:genesis.36",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 36,
    "referenceLabel": "Genesis 36",
    "summary": "Source text for Genesis 36 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.36.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Genesis 36:1",
      "text": "Hæ sunt autem generationes Esau, ipse est Edom.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.36.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Genesis 36:2",
      "text": "Esau accepit uxores de filiabus Chanaan: Ada filiam Elon Hethæi, et Oolibama filiam Anæ filiæ Sebeon Hevæi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Genesis 36:3",
      "text": "Basemath quoque filiam Ismaël sororem Nabaioth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Genesis 36:4",
      "text": "Peperit autem Ada Eliphaz: Basemath genuit Rahuel:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Genesis 36:5",
      "text": "Oolibama genuit Jehus et Ihelon et Core. Hi filii Esau qui nati sunt ei in terra Chanaan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Genesis 36:6",
      "text": "Tulit autem Esau uxores suas et filios et filias, et omnem animam domus suæ, et substantiam, et pecora, et cuncta quæ habere poterat in terra Chanaan: et abiit in alteram regionem, recessitque a fratre suo Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Genesis 36:7",
      "text": "Divites enim erant valde, et simul habitare non poterant: nec sustinebat eos terra peregrinationis eorum præ multitudine gregum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Genesis 36:8",
      "text": "Habitavitque Esau in monte Seir, ipse est Edom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Genesis 36:9",
      "text": "Hæ autem sunt generationes Esau patris Edom in monte Seir,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Genesis 36:10",
      "text": "et hæc nomina filiorum ejus: Eliphaz filius Ada uxoris Esau: Rahuel quoque filius Basemath uxoris ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Genesis 36:11",
      "text": "Fueruntque Eliphaz filii: Theman, Omar, Sepho, et Gatham, et Cenez.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Genesis 36:12",
      "text": "Erat autem Thamna concubina Eliphaz filii Esau: quæ peperit ei Amalech. Hi sunt filii Ada uxoris Esau.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Genesis 36:13",
      "text": "Filii autem Rahuel: Nahath et Zara, Samma et Meza: hi filii Basemath uxoris Esau.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Genesis 36:14",
      "text": "Isti quoque erant filii Oolibama filiæ Anæ filiæ Sebeon, uxoris Esau, quos genuit ei, Jehus et Ihelon et Core.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Genesis 36:15",
      "text": "Hi duces filiorum Esau: filii Eliphaz primogeniti Esau: dux Theman, dux Omra, dux Sepho, dux Cenez,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Genesis 36:16",
      "text": "dux Core, dux Gathan, dux Amalech. Hi filii Eliphaz in terra Edom, et hi filii Ada.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Genesis 36:17",
      "text": "Hi quoque filii Rahuel filii Esau: dux Nahath, dux Zara, dux Samma, dux Meza: hi autem duces Rahuel in terra Edom: isti filii Basemath uxoris Esau.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Genesis 36:18",
      "text": "Hi autem filii Oolibama uxoris Esau: dux Jehus, dux Ihelon, dux Core: hi duces Oolibama filiæ Anæ uxoris Esau.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Genesis 36:19",
      "text": "Isti sunt filii Esau, et hi duces eorum: ipse est Edom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Genesis 36:20",
      "text": "Isti sunt filii Seir Horræi, habitatores terræ: Lotan, et Sobal, et Sebeon, et Ana,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Genesis 36:21",
      "text": "et Dison, et Eser, et Disan: hi duces Horræi, filii Seir in terra Edom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Genesis 36:22",
      "text": "Facti sunt autem filii Lotan: Hori et Heman. Erat autem soror Lotan, Thamna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Genesis 36:23",
      "text": "Et isti filii Sobal: Alvan et Manahat et Ebal, et Sepho et Onam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Genesis 36:24",
      "text": "Et hi filii Sebeon: Aja et Ana. Iste est Ana qui invenit aquas calidas in solitudine, cum pasceret asinos Sebeon patris sui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Genesis 36:25",
      "text": "habuitque filium Dison, et filiam Oolibama.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Genesis 36:26",
      "text": "Et isti filii Dison: Hamdan, et Eseban, et Jethram, et Charan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Genesis 36:27",
      "text": "Hi quoque filii Eser: Balaan, et Zavan, et Acan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Genesis 36:28",
      "text": "Habuit autem filios Disan: Hus et Aram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Genesis 36:29",
      "text": "Hi duces Horræorum: dux Lotan, dux Sobal, dux Sebeon, dux Ana,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Genesis 36:30",
      "text": "dux Dison, dux Eser, dux Disan: isti duces Horræorum qui imperaverunt in terra Seir.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Genesis 36:31",
      "text": "Reges autem qui regnaverunt in terra Edom antequam haberent regem filii Israël, fuerunt hi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Genesis 36:32",
      "text": "Bela filius Beor, nomenque urbis ejus Denaba.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.33",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Genesis 36:33",
      "text": "Mortuus est autem Bela, et regnavit pro eo Jobab filius Zaræ de Bosra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.34",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 34,
      "referenceLabel": "Genesis 36:34",
      "text": "Cumque mortuus esset Jobab, regnavit pro eo Husam de terra Themanorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.35",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 35,
      "referenceLabel": "Genesis 36:35",
      "text": "Hoc quoque mortuo, regnavit pro eo Adad filius Badad, qui percussit Madian in regione Moab: et nomen urbis ejus Avith.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.36",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 36,
      "referenceLabel": "Genesis 36:36",
      "text": "Cumque mortuus esset Adad, regnavit pro eo Semla de Masreca.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.37",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 37,
      "referenceLabel": "Genesis 36:37",
      "text": "Hoc quoque mortuo regnavit pro eo Saul de fluvio Rohoboth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.38",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 38,
      "referenceLabel": "Genesis 36:38",
      "text": "Cumque et hic obiisset, successit in regnum Balanan filius Achobor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.39",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 39,
      "referenceLabel": "Genesis 36:39",
      "text": "Isto quoque mortuo regnavit pro eo Adar, nomenque urbis ejus Phau: et appellabatur uxor ejus Meetabel, filia Matred filiæ Mezaab.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.40",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 40,
      "referenceLabel": "Genesis 36:40",
      "text": "Hæc ergo nomina ducum Esau in cognationibus, et locis, et vocabulis suis: dux Thamna, dux Alva, dux Jetheth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.41",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 41,
      "referenceLabel": "Genesis 36:41",
      "text": "dux Oolibama, dux Ela, dux Phinon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.42",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 42,
      "referenceLabel": "Genesis 36:42",
      "text": "dux Cenez, dux Theman, dux Mabsar,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.36.43",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 36,
      "verseNumber": 43,
      "referenceLabel": "Genesis 36:43",
      "text": "dux Magdiel, dux Hiram: hi duces Edom habitantes in terra imperii sui, ipse est Esau pater Idumæorum.",
      "paragraphStart": false
    }
  ]
}
