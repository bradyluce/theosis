{
  "chapter": {
    "id": "vulgate:genesis.11",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 11,
    "referenceLabel": "Genesis 11",
    "summary": "Source text for Genesis 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.11.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Genesis 11:1",
      "text": "Erat autem terra labii unius, et sermonum eorumdem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.11.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Genesis 11:2",
      "text": "Cumque proficiscerentur de oriente, invenerunt campum in terra Sennaar, et habitaverunt in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Genesis 11:3",
      "text": "Dixitque alter ad proximum suum: Venite, faciamus lateres, et coquamus eos igni. Habueruntque lateres pro saxis, et bitumen pro cæmento:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Genesis 11:4",
      "text": "et dixerunt: Venite, faciamus nobis civitatem et turrim, cujus culmen pertingat ad cælum: et celebremus nomen nostrum antequam dividamur in universas terras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Genesis 11:5",
      "text": "Descendit autem Dominus ut videret civitatem et turrim, quam ædificabant filii Adam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Genesis 11:6",
      "text": "et dixit: Ecce, unus est populus, et unum labium omnibus: cœperuntque hoc facere, nec desistent a cogitationibus suis, donec eas opere compleant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Genesis 11:7",
      "text": "Venite igitur, descendamus, et confundamus ibi linguam eorum, ut non audiat unusquisque vocem proximi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Genesis 11:8",
      "text": "Atque ita divisit eos Dominus ex illo loco in universas terras, et cessaverunt ædificare civitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Genesis 11:9",
      "text": "Et idcirco vocatum est nomen ejus Babel, quia ibi confusum est labium universæ terræ: et inde dispersit eos Dominus super faciem cunctarum regionum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Genesis 11:10",
      "text": "Hæ sunt generationes Sem: Sem erat centum annorum quando genuit Arphaxad, biennio post diluvium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Genesis 11:11",
      "text": "Vixitque Sem, postquam genuit Arphaxad, quingentis annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Genesis 11:12",
      "text": "Porro Arphaxad vixit triginta quinque annis, et genuit Sale.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Genesis 11:13",
      "text": "Vixitque Arphaxad, postquam genuit Sale, trecentis tribus annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Genesis 11:14",
      "text": "Sale quoque vixit triginta annis, et genuit Heber.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Genesis 11:15",
      "text": "Vixitque Sale, postquam genuit Heber, quadringentis tribus annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Genesis 11:16",
      "text": "Vixit autem Heber triginta quatuor annis, et genuit Phaleg.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Genesis 11:17",
      "text": "Et vixit Heber postquam genuit Phaleg, quadringentis triginta annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Genesis 11:18",
      "text": "Vixit quoque Phaleg triginta annis, et genuit Reu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Genesis 11:19",
      "text": "Vixitque Phaleg, postquam genuit Reu, ducentis novem annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Genesis 11:20",
      "text": "Vixit autem Reu triginta duobus annis, et genuit Sarug.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Genesis 11:21",
      "text": "Vixit quoque Reu, postquam genuit Sarug, ducentis septem annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Genesis 11:22",
      "text": "Vixit vero Sarug triginta annis, et genuit Nachor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Genesis 11:23",
      "text": "Vixitque Sarug, postquam genuit Nachor, ducentis annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Genesis 11:24",
      "text": "Vixit autem Nachor viginti novem annis, et genuit Thare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Genesis 11:25",
      "text": "Vixitque Nachor, postquam genuit Thare, centum decem et novem annis: et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Genesis 11:26",
      "text": "Vixitque Thare septuaginta annis, et genuit Abram, et Nachor, et Aran.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Genesis 11:27",
      "text": "Hæ sunt autem generationes Thare: Thare genuit Abram, Nachor et Aran. Porro Aran genuit Lot.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Genesis 11:28",
      "text": "Mortuusque est Aran ante Thare patrem suum, in terra nativitatis suæ, in Ur Chaldæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Genesis 11:29",
      "text": "Duxerunt autem Abram et Nachor uxores: nomen uxoris Abram, Sarai: et nomen uxoris Nachor, Melcha filia Aran, patris Melchæ, et patris Jeschæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Genesis 11:30",
      "text": "Erat autem Sarai sterilis, nec habebat liberos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Genesis 11:31",
      "text": "Tulit itaque Thare Abram filium suum, et Lot filium Aran, filium filii sui, et Sarai nurum suam, uxorem Abram filii sui, et eduxit eos de Ur Chaldæorum, ut irent in terram Chanaan: veneruntque usque Haran, et habitaverunt ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.11.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Genesis 11:32",
      "text": "Et facti sunt dies Thare ducentorum quinque annorum, et mortuus est in Haran.",
      "paragraphStart": false
    }
  ]
}
