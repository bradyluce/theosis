{
  "chapter": {
    "id": "vulgate:genesis.35",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 35,
    "referenceLabel": "Genesis 35",
    "summary": "Source text for Genesis 35 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.35.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Genesis 35:1",
      "text": "Interea locutus est Deus ad Jacob: Surge, et ascende Bethel, et habita ibi, facque altare Deo qui apparuit tibi quando fugiebas Esau fratrem tuum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.35.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Genesis 35:2",
      "text": "Jacob vero convocata omni domo sua, ait: Abjicite deos alienos qui in medio vestri sunt, et mundamini, ac mutate vestimenta vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Genesis 35:3",
      "text": "Surgite, et ascendamus in Bethel, ut faciamus ibi altare Deo: qui exaudivit me in die tribulationis meæ, et socius fuit itineris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Genesis 35:4",
      "text": "Dederunt ergo ei omnes deos alienos quos habebant, et inaures quæ erant in auribus eorum: at ille infodit ea subter terebinthum, quæ est post urbem Sichem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Genesis 35:5",
      "text": "Cumque profecti essent, terror Dei invasit omnes per circuitum civitates, et non sunt ausi persequi recedentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Genesis 35:6",
      "text": "Venit igitur Jacob Luzam, quæ est in terra Chanaan, cognomento Bethel: ipse et omnis populus cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Genesis 35:7",
      "text": "Ædificavitque ibi altare, et appellavit nomen loci illius, Domus Dei: ibi enim apparuit ei Deus cum fugeret fratrem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Genesis 35:8",
      "text": "Eodem tempore mortua est Debora nutrix Rebeccæ, et sepulta est ad radices Bethel subter quercum: vocatumque est nomen loci illius, Quercus fletus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Genesis 35:9",
      "text": "Apparuit autem iterum Deus Jacob postquam reversus est de Mesopotamia Syriæ, benedixitque ei",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Genesis 35:10",
      "text": "dicens: Non vocaberis ultra Jacob, sed Israël erit nomen tuum. Et appellavit eum Israël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Genesis 35:11",
      "text": "dixitque ei: Ego Deus omnipotens: cresce, et multiplicare: gentes et populi nationum ex te erunt, reges de lumbis tuis egredientur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Genesis 35:12",
      "text": "terramque quam dedi Abraham et Isaac, dabo tibi et semini tuo post te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Genesis 35:13",
      "text": "Et recessit ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Genesis 35:14",
      "text": "Ille vero erexit titulum lapideum in loco quo locutus fuerat ei Deus: libans super eum libamina, et effundens oleum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Genesis 35:15",
      "text": "vocansque nomen loci illius Bethel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Genesis 35:16",
      "text": "Egressus autem inde, venit verno tempore ad terram quæ ducit Ephratam: in qua cum parturiret Rachel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Genesis 35:17",
      "text": "ob difficultatem partus periclitari cœpit. Dixitque ei obstetrix: Noli timere, quia et hunc habebis filium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Genesis 35:18",
      "text": "Egrediente autem anima præ dolore, et imminente jam morte, vocavit nomen filii sui Benomi, id est, Filius doloris mei: pater vero appellavit eum Benjamin, id est, Filius dextræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Genesis 35:19",
      "text": "Mortua est ergo Rachel, et sepulta est in via quæ ducit Ephratam, hæc est Bethlehem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Genesis 35:20",
      "text": "Erexitque Jacob titulum super sepulchrum ejus: hic est titulus monumenti Rachel, usque in præsentem diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Genesis 35:21",
      "text": "Egressus inde, fixit tabernaculum trans Turrem gregis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Genesis 35:22",
      "text": "Cumque habitaret in illa regione, abiit Ruben, et dormivit cum Bala concubina patris sui: quod illum minime latuit. Erant autem filii Jacob duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Genesis 35:23",
      "text": "Filii Liæ: primogenitus Ruben, et Simeon, et Levi, et Judas, et Issachar, et Zabulon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Genesis 35:24",
      "text": "Filii Rachel: Joseph et Benjamin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Genesis 35:25",
      "text": "Filii Balæ ancillæ Rachelis: Dan et Nephthali.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Genesis 35:26",
      "text": "Filii Zelphæ ancillæ Liæ: Gad et Aser: hi sunt filii Jacob, qui nati sunt ei in Mesopotamia Syriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Genesis 35:27",
      "text": "Venit etiam ad Isaac patrem suum in Mambre, civitatem Arbee, hæc est Hebron, in qua peregrinatus est Abraham et Isaac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Genesis 35:28",
      "text": "Et completi sunt dies Isaac centum octoginta annorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.35.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 35,
      "verseNumber": 29,
      "referenceLabel": "Genesis 35:29",
      "text": "Consumptusque ætate mortuus est: et appositus est populo suo senex et plenus dierum: et sepelierunt eum Esau et Jacob filii sui.",
      "paragraphStart": false
    }
  ]
}
