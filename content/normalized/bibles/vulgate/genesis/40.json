{
  "chapter": {
    "id": "vulgate:genesis.40",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 40,
    "referenceLabel": "Genesis 40",
    "summary": "Source text for Genesis 40 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.40.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Genesis 40:1",
      "text": "His ita gestis, accidit ut peccarent duo eunuchi, pincerna regis Ægypti, et pistor, domino suo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.40.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Genesis 40:2",
      "text": "Iratusque contra eos Pharao (nam alter pincernis præerat, alter pistoribus),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Genesis 40:3",
      "text": "misit eos in carcerem principis militum, in quo erat vinctus et Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Genesis 40:4",
      "text": "At custos carceris tradidit eos Joseph, qui et ministrabat eis: aliquantulum temporis fluxerat, et illi in custodia tenebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Genesis 40:5",
      "text": "Videruntque ambo somnium nocte una, juxta interpretationem congruam sibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Genesis 40:6",
      "text": "ad quos cum introisset Joseph mane, et vidisset eos tristes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Genesis 40:7",
      "text": "sciscitatus est eos, dicens: Cur tristior est hodie solito facies vestra?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Genesis 40:8",
      "text": "Qui responderunt: Somnium vidimus, et non est qui interpretetur nobis. Dixitque ad eos Joseph: Numquid non Dei est interpretatio? referte mihi quid videritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Genesis 40:9",
      "text": "Narravit prior, præpositus pincernarum, somnium suum: Videbam coram me vitem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Genesis 40:10",
      "text": "in qua erant tres propagines, crescere paulatim in gemmas, et post flores uvas maturescere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Genesis 40:11",
      "text": "calicemque Pharaonis in manu mea: tuli ergo uvas, et expressi in calicem quem tenebam, et tradidi poculum Pharaoni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Genesis 40:12",
      "text": "Respondit Joseph: Hæc est interpretatio somnii: tres propagines, tres adhuc dies sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Genesis 40:13",
      "text": "post quos recordabitur Pharao ministerii tui, et restituet te in gradum pristinum: dabisque ei calicem juxta officium tuum, sicut ante facere consueveras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Genesis 40:14",
      "text": "Tantum memento mei, cum bene tibi fuerit, et facias mecum misericordiam: ut suggeras Pharaoni ut educat me de isto carcere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 15,
      "referenceLabel": "Genesis 40:15",
      "text": "quia furto sublatus sum de terra Hebræorum, et hic innocens in lacum missus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 16,
      "referenceLabel": "Genesis 40:16",
      "text": "Videns pistorum magister quod prudenter somnium dissolvisset, ait: Et ego vidi somnium: quod tria canistra farinæ haberem super caput meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 17,
      "referenceLabel": "Genesis 40:17",
      "text": "et in uno canistro quod erat excelsius, portare me omnes cibos qui fiunt arte pistoria, avesque comedere ex eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 18,
      "referenceLabel": "Genesis 40:18",
      "text": "Respondit Joseph: Hæc est interpretatio somnii: tria canistra, tres adhuc dies sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 19,
      "referenceLabel": "Genesis 40:19",
      "text": "post quos auferet Pharao caput tuum, ac suspendet te in cruce, et lacerabunt volucres carnes tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 20,
      "referenceLabel": "Genesis 40:20",
      "text": "Exinde dies tertius natalitius Pharaonis erat: qui faciens grande convivium pueris suis, recordatus est inter epulas magistri pincernarum, et pistorum principis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 21,
      "referenceLabel": "Genesis 40:21",
      "text": "Restituitque alterum in locum suum, ut porrigeret ei poculum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 22,
      "referenceLabel": "Genesis 40:22",
      "text": "alterum suspendit in patibulo, ut conjectoris veritas probaretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.40.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 40,
      "verseNumber": 23,
      "referenceLabel": "Genesis 40:23",
      "text": "Et tamen succedentibus prosperis, præpositus pincernarum oblitus est interpretis sui.",
      "paragraphStart": false
    }
  ]
}
