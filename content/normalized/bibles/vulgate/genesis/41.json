{
  "chapter": {
    "id": "vulgate:genesis.41",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 41,
    "referenceLabel": "Genesis 41",
    "summary": "Source text for Genesis 41 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.41.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Genesis 41:1",
      "text": "Post duos annos vidit Pharao somnium. Putabat se stare super fluvium,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.41.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Genesis 41:2",
      "text": "de quo ascendebant septem boves, pulchræ et crassæ nimis: et pascebantur in locis palustribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Genesis 41:3",
      "text": "Aliæ quoque septem emergebant de flumine, fœdæ confectæque macie: et pascebantur in ipsa amnis ripa in locis virentibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Genesis 41:4",
      "text": "devoraveruntque eas, quarum mira species et habitudo corporum erat. Expergefactus Pharao,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Genesis 41:5",
      "text": "rursum dormivit, et vidit alterum somnium: septem spicæ pullulabant in culmo uno plenæ atque formosæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Genesis 41:6",
      "text": "aliæ quoque totidem spicæ tenues, et percussæ uredine oriebantur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Genesis 41:7",
      "text": "devorantes omnium priorum pulchritudinem. Evigilans Pharao post quietem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Genesis 41:8",
      "text": "et facto mane, pavore perterritus, misit ad omnes conjectores Ægypti, cunctosque sapientes, et accersitis narravit somnium, nec erat qui interpretaretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Genesis 41:9",
      "text": "Tunc demum reminiscens pincernarum magister, ait: Confiteor peccatum meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Genesis 41:10",
      "text": "iratus rex servis suis, me et magistrum pistorum retrudi jussit in carcerem principis militum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Genesis 41:11",
      "text": "ubi una nocte uterque vidimus somnium præsagum futurorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Genesis 41:12",
      "text": "Erat ibi puer hebræus, ejusdem ducis militum famulus: cui narrantes somnia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Genesis 41:13",
      "text": "audivimus quidquid postea rei probavit eventus; ego enim redditus sum officio meo, et ille suspensus est in cruce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 14,
      "referenceLabel": "Genesis 41:14",
      "text": "Protinus ad regis imperium eductum de carcere Joseph totonderunt: ac veste mutata obtulerunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 15,
      "referenceLabel": "Genesis 41:15",
      "text": "Cui ille ait: Vidi somnia, nec est qui edisserat: quæ audivi te sapientissime conjicere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 16,
      "referenceLabel": "Genesis 41:16",
      "text": "Respondit Joseph: Absque me Deus respondebit prospera Pharaoni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 17,
      "referenceLabel": "Genesis 41:17",
      "text": "Narravit ergo Pharao quod viderat: Putabam me stare super ripam fluminis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 18,
      "referenceLabel": "Genesis 41:18",
      "text": "et septem boves de amne conscendere, pulchras nimis, et obesis carnibus: quæ in pastu paludis virecta carpebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 19,
      "referenceLabel": "Genesis 41:19",
      "text": "Et ecce, has sequebantur aliæ septem boves, in tantum deformes et macilentæ, ut numquam tales in terra Ægypti viderim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 20,
      "referenceLabel": "Genesis 41:20",
      "text": "quæ, devoratis et consumptis prioribus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 21,
      "referenceLabel": "Genesis 41:21",
      "text": "nullum saturitatis dedere vestigium: sed simili macie et squalore torpebant. Evigilans, rursus sopore depressus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 22,
      "referenceLabel": "Genesis 41:22",
      "text": "vidi somnium. Septem spicæ pullulabant in culmo uno plenæ atque pulcherrimæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 23,
      "referenceLabel": "Genesis 41:23",
      "text": "Aliæ quoque septem tenues et percussæ uredine, oriebantur e stipula:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 24,
      "referenceLabel": "Genesis 41:24",
      "text": "quæ priorum pulchritudinem devoraverunt. Narravi conjectoribus somnium, et nemo est qui edisserat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 25,
      "referenceLabel": "Genesis 41:25",
      "text": "Respondit Joseph: Somnium regis unum est: quæ facturus est Deus, ostendit Pharaoni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 26,
      "referenceLabel": "Genesis 41:26",
      "text": "Septem boves pulchræ, et septem spicæ plenæ, septem ubertatis anni sunt: eamdemque vim somnii comprehendunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 27,
      "referenceLabel": "Genesis 41:27",
      "text": "Septem quoque boves tenues atque macilentæ, quæ ascenderunt post eas, et septem spicæ tenues, et vento urente percussæ, septem anni venturæ sunt famis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 28,
      "referenceLabel": "Genesis 41:28",
      "text": "Qui hoc ordine complebuntur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 29,
      "referenceLabel": "Genesis 41:29",
      "text": "ecce septem anni venient fertilitatis magnæ in universa terra Ægypti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 30,
      "referenceLabel": "Genesis 41:30",
      "text": "quos sequentur septem anni alii tantæ sterilitatis, ut oblivioni tradatur cuncta retro abundantia: consumptura est enim fames omnem terram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 31,
      "referenceLabel": "Genesis 41:31",
      "text": "et ubertatis magnitudinem perditura est inopiæ magnitudo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 32,
      "referenceLabel": "Genesis 41:32",
      "text": "Quod autem vidisti secundo ad eamdem rem pertinens somnium: firmitatis indicium est, eo quod fiat sermo Dei, et velocius impleatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.33",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 33,
      "referenceLabel": "Genesis 41:33",
      "text": "Nunc ergo provideat rex virum sapientem et industrium, et præficiat eum terræ Ægypti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.34",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 34,
      "referenceLabel": "Genesis 41:34",
      "text": "qui constituat præpositos per cunctas regiones: et quintam partem fructuum per septem annos fertilitatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.35",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 35,
      "referenceLabel": "Genesis 41:35",
      "text": "qui jam nunc futuri sunt, congreget in horrea: et omne frumentum sub Pharaonis potestate condatur, serveturque in urbibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.36",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 36,
      "referenceLabel": "Genesis 41:36",
      "text": "Et præparetur futuræ septem annorum fami, quæ oppressura est Ægyptum, et non consumetur terra inopia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.37",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 37,
      "referenceLabel": "Genesis 41:37",
      "text": "Placuit Pharaoni consilium et cunctis ministris ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.38",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 38,
      "referenceLabel": "Genesis 41:38",
      "text": "locutusque est ad eos: Num invenire poterimus talem virum, qui spiritu Dei plenus sit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.39",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 39,
      "referenceLabel": "Genesis 41:39",
      "text": "Dixit ergo ad Joseph: Quia ostendit tibi Deus omnia quæ locutus es, numquid sapientiorem et consimilem tui invenire potero?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.40",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 40,
      "referenceLabel": "Genesis 41:40",
      "text": "Tu eris super domum meam, et ad tui oris imperium cunctus populus obediet: uno tantum regni solio te præcedam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.41",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 41,
      "referenceLabel": "Genesis 41:41",
      "text": "Dixitque rursus Pharao ad Joseph: Ecce, constitui te super universam terram Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.42",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 42,
      "referenceLabel": "Genesis 41:42",
      "text": "Tulitque annulum de manu sua, et dedit eum in manu ejus: vestivitque eum stola byssina, et collo torquem auream circumposuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.43",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 43,
      "referenceLabel": "Genesis 41:43",
      "text": "Fecitque eum ascendere super currum suum secundum, clamante præcone, ut omnes coram eo genu flecterent, et præpositum esse scirent universæ terræ Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.44",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 44,
      "referenceLabel": "Genesis 41:44",
      "text": "Dixit quoque rex ad Joseph: Ego sum Pharao: absque tuo imperio non movebit quisquam manum aut pedem in omni terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.45",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 45,
      "referenceLabel": "Genesis 41:45",
      "text": "Vertitque nomen ejus, et vocavit eum, lingua ægyptiaca, Salvatorem mundi. Deditque illi uxorem Aseneth filiam Putiphare sacerdotis Heliopoleos. Egressus est itaque Joseph ad terram Ægypti",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.46",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 46,
      "referenceLabel": "Genesis 41:46",
      "text": "(triginta autem annorum erat quando stetit in conspectu regis Pharaonis), et circuivit omnes regiones Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.47",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 47,
      "referenceLabel": "Genesis 41:47",
      "text": "Venitque fertilitas septem annorum: et in manipulos redactæ segetes congregatæ sunt in horrea Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.48",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 48,
      "referenceLabel": "Genesis 41:48",
      "text": "Omnis etiam frugum abundantia in singulis urbibus condita est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.49",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 49,
      "referenceLabel": "Genesis 41:49",
      "text": "Tantaque fuit abundantia tritici, ut arenæ maris coæquaretur, et copia mensuram excederet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.50",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 50,
      "referenceLabel": "Genesis 41:50",
      "text": "Nati sunt autem Joseph filii duo antequam veniret fames: quos peperit ei Aseneth filia Putiphare sacerdotis Heliopoleos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.51",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 51,
      "referenceLabel": "Genesis 41:51",
      "text": "Vocavitque nomen primogeniti Manasses, dicens: Oblivisci me fecit Deus omnium laborum meorum, et domus patris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.52",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 52,
      "referenceLabel": "Genesis 41:52",
      "text": "Nomen quoque secundi appellavit Ephraim, dicens: Crescere me fecit Deus in terra paupertatis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.53",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 53,
      "referenceLabel": "Genesis 41:53",
      "text": "Igitur transactis septem ubertatis annis, qui fuerant in Ægypto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.54",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 54,
      "referenceLabel": "Genesis 41:54",
      "text": "cœperunt venire septem anni inopiæ, quos prædixerat Joseph: et in universo orbe fames prævaluit, in cuncta autem terra Ægypti panis erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.55",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 55,
      "referenceLabel": "Genesis 41:55",
      "text": "Qua esuriente, clamavit populus ad Pharaonem, alimenta petens. Quibus ille respondit: Ite ad Joseph: et quidquid ipse vobis dixerit, facite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.56",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 56,
      "referenceLabel": "Genesis 41:56",
      "text": "Crescebat autem quotidie fames in omni terra: aperuitque Joseph universa horrea, et vendebat Ægyptiis: nam et illos oppresserat fames.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.41.57",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 41,
      "verseNumber": 57,
      "referenceLabel": "Genesis 41:57",
      "text": "Omnesque provinciæ veniebant in Ægyptum, ut emerent escas, et malum inopiæ temperarent.",
      "paragraphStart": false
    }
  ]
}
