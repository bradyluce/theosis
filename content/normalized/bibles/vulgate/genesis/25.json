{
  "chapter": {
    "id": "vulgate:genesis.25",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 25,
    "referenceLabel": "Genesis 25",
    "summary": "Source text for Genesis 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.25.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Genesis 25:1",
      "text": "Abraham vero aliam duxit uxorem nomine Ceturam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.25.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Genesis 25:2",
      "text": "quæ peperit ei Zamran et Jecsan, et Madan, et Madian, et Jesboc, et Sue.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Genesis 25:3",
      "text": "Jecsan quoque genuit Saba et Dadan. Filii Dadan fuerunt Assurim, et Latusim, et Loomin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Genesis 25:4",
      "text": "At vero ex Madian ortus est Epha, et Opher, et Henoch, et Abida, et Eldaa: omnes hi filii Ceturæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Genesis 25:5",
      "text": "Deditque Abraham cuncta quæ possederat, Isaac:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Genesis 25:6",
      "text": "filiis autem concubinarum largitus est munera, et separavit eos ab Isaac filio suo, dum adhuc ipse viveret, ad plagam orientalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Genesis 25:7",
      "text": "Fuerunt autem dies vitæ Abrahæ, centum septuaginta quinque anni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Genesis 25:8",
      "text": "Et deficiens mortuus est in senectute bona, provectæque ætatis et plenus dierum: congregatusque est ad populum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Genesis 25:9",
      "text": "Et sepelierunt eum Isaac et Ismaël filii sui in spelunca duplici, quæ sita est in agro Ephron filii Seor Hethæi, e regione Mambre,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Genesis 25:10",
      "text": "quem emerat a filiis Heth: ibi sepultus est ipse, et Sara uxor ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Genesis 25:11",
      "text": "Et post obitum illius benedixit Deus Isaac filio ejus, qui habitabat juxta puteum nomine Viventis et videntis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Genesis 25:12",
      "text": "Hæ sunt generationes Ismaël filii Abrahæ, quem peperit ei Agar Ægyptia, famula Saræ: et",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Genesis 25:13",
      "text": "hæc nomina filiorum ejus in vocabulis et generationibus suis. Primogenitus Ismaëlis Nabaioth, deinde Cedar, et Adbeel, et Mabsam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Genesis 25:14",
      "text": "Masma quoque, et Duma, et Massa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Genesis 25:15",
      "text": "Hadar, et Thema, et Jethur, et Naphis, et Cedma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Genesis 25:16",
      "text": "Isti sunt filii Ismaëlis: et hæc nomina per castella et oppida eorum, duodecim principes tribuum suarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Genesis 25:17",
      "text": "Et facti sunt anni vitæ Ismaëlis centum triginta septem, deficiensque mortuus est, et appositus ad populum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Genesis 25:18",
      "text": "Habitavit autem ab Hevila usque Sur, quæ respicit Ægyptum introëuntibus Assyrios; coram cunctis fratribus suis obiit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Genesis 25:19",
      "text": "Hæ quoque sunt generationes Isaac filii Abraham: Abraham genuit Isaac:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Genesis 25:20",
      "text": "qui cum quadraginta esset annorum, duxit uxorem Rebeccam filiam Bathuelis Syri de Mesopotamia, sororem Laban.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Genesis 25:21",
      "text": "Deprecatusque est Isaac Dominum pro uxore sua, eo quod esset sterilis: qui exaudivit eum, et dedit conceptum Rebeccæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Genesis 25:22",
      "text": "Sed collidebantur in utero ejus parvuli; quæ ait: Si sic mihi futurum erat, quid necesse fuit concipere? perrexitque ut consuleret Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Genesis 25:23",
      "text": "Qui respondens ait: Duæ gentes sunt in utero tuo, et duo populi ex ventre tuo dividentur, populusque populum superabit, et major serviet minori.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Genesis 25:24",
      "text": "Jam tempus pariendi advenerat, et ecce gemini in utero ejus reperti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Genesis 25:25",
      "text": "Qui prior egressus est, rufus erat, et totus in morem pellis hispidus: vocatumque est nomen ejus Esau. Protinus alter egrediens, plantam fratris tenebat manu: et idcirco appellavit eum Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Genesis 25:26",
      "text": "Sexagenarius erat Isaac quando nati sunt ei parvuli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Genesis 25:27",
      "text": "Quibus adultis, factus est Esau vir gnarus venandi, et homo agricola: Jacob autem vir simplex habitabat in tabernaculis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Genesis 25:28",
      "text": "Isaac amabat Esau, eo quod de venationibus illius vesceretur: et Rebecca diligebat Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "Genesis 25:29",
      "text": "Coxit autem Jacob pulmentum: ad quem cum venisset Esau de agro lassus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 30,
      "referenceLabel": "Genesis 25:30",
      "text": "ait: Da mihi de coctione hac rufa, quia oppido lassus sum. Quam ob causam vocatum est nomen ejus Edom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 31,
      "referenceLabel": "Genesis 25:31",
      "text": "Cui dixit Jacob: Vende mihi primogenita tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 32,
      "referenceLabel": "Genesis 25:32",
      "text": "Ille respondit: En morior, quid mihi proderunt primogenita?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.33",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 33,
      "referenceLabel": "Genesis 25:33",
      "text": "Ait Jacob: Jura ergo mihi. Juravit ei Esau et vendidit primogenita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.25.34",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 25,
      "verseNumber": 34,
      "referenceLabel": "Genesis 25:34",
      "text": "Et sic, accepto pane et lentis edulio, comedit et bibit, et abiit, parvipendens quod primogenita vendidisset.",
      "paragraphStart": false
    }
  ]
}
