{
  "chapter": {
    "id": "vulgate:genesis.10",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 10,
    "referenceLabel": "Genesis 10",
    "summary": "Source text for Genesis 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.10.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Genesis 10:1",
      "text": "Hæ sunt generationes filiorum Noë, Sem, Cham et Japheth: natique sunt eis filii post diluvium.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.10.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Genesis 10:2",
      "text": "Filii Japheth: Gomer, et Magog, et Madai, et Javan, et Thubal, et Mosoch, et Thiras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Genesis 10:3",
      "text": "Porro filii Gomer: Ascenez et Riphath et Thogorma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Genesis 10:4",
      "text": "Filii autem Javan: Elisa et Tharsis, Cetthim et Dodanim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Genesis 10:5",
      "text": "Ab his divisæ sunt insulæ gentium in regionibus suis, unusquisque secundum linguam suam et familias suas in nationibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Genesis 10:6",
      "text": "Filii autem Cham: Chus, et Mesraim, et Phuth, et Chanaan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Genesis 10:7",
      "text": "Filii Chus: Saba, et Hevila, et Sabatha, et Regma, et Sabatacha. Filii Regma: Saba et Dadan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Genesis 10:8",
      "text": "Porro Chus genuit Nemrod: ipse cœpit esse potens in terra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Genesis 10:9",
      "text": "et erat robustus venator coram Domino. Ob hoc exivit proverbium: Quasi Nemrod robustus venator coram Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Genesis 10:10",
      "text": "Fuit autem principium regni ejus Babylon, et Arach et Achad, et Chalanne, in terra Sennaar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Genesis 10:11",
      "text": "De terra illa egressus est Assur, et ædificavit Niniven, et plateas civitatis, et Chale.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Genesis 10:12",
      "text": "Resen quoque inter Niniven et Chale: hæc est civitas magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Genesis 10:13",
      "text": "At vero Mesraim genuit Ludim, et Anamim et Laabim, Nephthuim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Genesis 10:14",
      "text": "et Phetrusim, et Chasluim: de quibus egressi sunt Philisthiim et Caphtorim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Genesis 10:15",
      "text": "Chanaan autem genuit Sidonem primogenitum suum. Hethæum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Genesis 10:16",
      "text": "et Jebusæum, et Amorrhæum, Gergesæum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Genesis 10:17",
      "text": "Hevæum, et Aracæum: Sinæum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Genesis 10:18",
      "text": "et Aradium, Samaræum, et Amathæum: et post hæc disseminati sunt populi Chananæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Genesis 10:19",
      "text": "Factique sunt termini Chanaan venientibus a Sidone Geraram usque Gazam, donec ingrediaris Sodomam et Gomorrham, et Adamam, et Seboim usque Lesa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Genesis 10:20",
      "text": "Hi sunt filii Cham in cognationibus, et linguis, et generationibus, terrisque et gentibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Genesis 10:21",
      "text": "De Sem quoque nati sunt, patre omnium filiorum Heber, fratre Japheth majore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Genesis 10:22",
      "text": "Filii Sem: Ælam, et Assur, et Arphaxad, et Lud, et Aram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Genesis 10:23",
      "text": "Filii Aram: Us, et Hul, et Gether, et Mes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Genesis 10:24",
      "text": "At vero Arphaxad genuit Sale, de quo ortus est Heber.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Genesis 10:25",
      "text": "Natique sunt Heber filii duo: nomen uni Phaleg, eo quod in diebus ejus divisa sit terra: et nomen fratris ejus Jectan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Genesis 10:26",
      "text": "Qui Jectan genuit Elmodad, et Saleph, et Asarmoth, Jare,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Genesis 10:27",
      "text": "et Aduram, et Uzal, et Decla,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Genesis 10:28",
      "text": "et Ebal, et Abimaël, Saba,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Genesis 10:29",
      "text": "et Ophir, et Hevila, et Jobab: omnes isti, filii Jectan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Genesis 10:30",
      "text": "Et facta est habitatio eorum de Messa pergentibus usque Sephar montem orientalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Genesis 10:31",
      "text": "Isti filii Sem secundum cognationes, et linguas, et regiones in gentibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.10.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Genesis 10:32",
      "text": "Hæ familiæ Noë juxta populos et nationes suas. Ab his divisæ sunt gentes in terra post diluvium.",
      "paragraphStart": false
    }
  ]
}
