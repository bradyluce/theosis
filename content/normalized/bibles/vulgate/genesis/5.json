{
  "chapter": {
    "id": "vulgate:genesis.5",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 5,
    "referenceLabel": "Genesis 5",
    "summary": "Source text for Genesis 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.5.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Genesis 5:1",
      "text": "Hic est liber generationis Adam. In die qua creavit Deus hominem, ad similitudinem Dei fecit illum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.5.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Genesis 5:2",
      "text": "Masculum et feminam creavit eos, et benedixit illis: et vocavit nomen eorum Adam, in die quo creati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Genesis 5:3",
      "text": "Vixit autem Adam centum triginta annis: et genuit ad imaginem et similitudinem suam, vocavitque nomen ejus Seth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Genesis 5:4",
      "text": "Et facti sunt dies Adam, postquam genuit Seth, octingenti anni: genuitque filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Genesis 5:5",
      "text": "Et factum est omne tempus quod vixit Adam, anni nongenti triginta, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Genesis 5:6",
      "text": "Vixit quoque Seth centum quinque annis, et genuit Enos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Genesis 5:7",
      "text": "Vixitque Seth, postquam genuit Enos, octingentis septem annis, genuitque filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Genesis 5:8",
      "text": "Et facti sunt omnes dies Seth nongentorum duodecim annorum, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Genesis 5:9",
      "text": "Vixit vero Enos nonaginta annis, et genuit Cainan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Genesis 5:10",
      "text": "Post cujus ortum vixit octingentis quindecim annis, et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Genesis 5:11",
      "text": "Factique sunt omnes dies Enos nongenti quinque anni, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Genesis 5:12",
      "text": "Vixit quoque Cainan septuaginta annis, et genuit Malaleel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Genesis 5:13",
      "text": "Et vixit Cainan, postquam genuit Malaleel, octingentis quadraginta annis, genuitque filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Genesis 5:14",
      "text": "Et facti sunt omnes dies Cainan nongenti decem anni, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Genesis 5:15",
      "text": "Vixit autem Malaleel sexaginta quinque annis, et genuit Jared.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Genesis 5:16",
      "text": "Et vixit Malaleel, postquam genuit Jared, octingentis triginta annis, et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Genesis 5:17",
      "text": "Et facti sunt omnes dies Malaleel octingenti nonaginta quinque anni, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Genesis 5:18",
      "text": "Vixitque Jared centum sexaginta duobus annis, et genuit Henoch.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Genesis 5:19",
      "text": "Et vixit Jared, postquam genuit Henoch, octingentis annis, et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Genesis 5:20",
      "text": "Et facti sunt omnes dies Jared nongenti sexaginta duo anni, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Genesis 5:21",
      "text": "Porro Henoch vixit sexaginta quinque annis, et genuit Mathusalam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Genesis 5:22",
      "text": "Et ambulavit Henoch cum Deo: et vixit, postquam genuit Mathusalam, trecentis annis, et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Genesis 5:23",
      "text": "Et facti sunt omnes dies Henoch trecenti sexaginta quinque anni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Genesis 5:24",
      "text": "Ambulavitque cum Deo, et non apparuit: quia tulit eum Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Genesis 5:25",
      "text": "Vixit quoque Mathusala centum octoginta septem annis, et genuit Lamech.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Genesis 5:26",
      "text": "Et vixit Mathusala, postquam genuit Lamech, septingentis octoginta duobus annis, et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Genesis 5:27",
      "text": "Et facti sunt omnes dies Mathusala nongenti sexaginta novem anni, et mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Genesis 5:28",
      "text": "Vixit autem Lamech centum octoginta duobus annis, et genuit filium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Genesis 5:29",
      "text": "vocavitque nomen ejus Noë, dicens: Iste consolabitur nos ab operibus et laboribus manuum nostrarum in terra, cui maledixit Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Genesis 5:30",
      "text": "Vixitque Lamech, postquam genuit Noë, quingentis nonaginta quinque annis, et genuit filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.5.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Genesis 5:31",
      "text": "Et facti sunt omnes dies Lamech septingenti septuaginta septem anni, et mortuus est. Noë vero cum quingentorum esset annorum, genuit Sem, Cham et Japheth.",
      "paragraphStart": false
    }
  ]
}
