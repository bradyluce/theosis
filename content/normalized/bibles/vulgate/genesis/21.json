{
  "chapter": {
    "id": "vulgate:genesis.21",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 21,
    "referenceLabel": "Genesis 21",
    "summary": "Source text for Genesis 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.21.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Genesis 21:1",
      "text": "Visitavit autem Dominus Saram, sicut promiserat: et implevit quæ locutus est.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.21.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Genesis 21:2",
      "text": "Concepitque et peperit filium in senectute sua, tempore quo prædixerat ei Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Genesis 21:3",
      "text": "Vocavitque Abraham nomen filii sui, quem genuit ei Sara, Isaac:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Genesis 21:4",
      "text": "et circumcidit eum octavo die, sicut præceperat ei Deus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Genesis 21:5",
      "text": "cum centum esset annorum: hac quippe ætate patris, natus est Isaac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Genesis 21:6",
      "text": "Dixitque Sara: Risum fecit mihi Deus: quicumque audierit, corridebit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Genesis 21:7",
      "text": "Rursumque ait: Quis auditurus crederet Abraham quod Sara lactaret filium, quem peperit ei jam seni?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Genesis 21:8",
      "text": "Crevit igitur puer, et ablactatus est: fecitque Abraham grande convivium in die ablactationis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Genesis 21:9",
      "text": "Cumque vidisset Sara filium Agar Ægyptiæ ludentem cum Isaac filio suo, dixit ad Abraham:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Genesis 21:10",
      "text": "Ejice ancillam hanc, et filium ejus: non enim erit hæres filius ancillæ cum filio meo Isaac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Genesis 21:11",
      "text": "Dure accepit hoc Abraham pro filio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Genesis 21:12",
      "text": "Cui dixit Deus: Non tibi videatur asperum super puero, et super ancilla tua: omnia quæ dixerit tibi Sara, audi vocem ejus: quia in Isaac vocabitur tibi semen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Genesis 21:13",
      "text": "Sed et filium ancillæ faciam in gentem magnam, quia semen tuum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Genesis 21:14",
      "text": "Surrexit itaque Abraham mane, et tollens panem et utrem aquæ, imposuit scapulæ ejus, tradiditque puerum, et dimisit eam. Quæ cum abiisset, errabat in solitudine Bersabee.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Genesis 21:15",
      "text": "Cumque consumpta esset aqua in utre, abjecit puerum subter unam arborum, quæ ibi erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Genesis 21:16",
      "text": "Et abiit, seditque e regione procul quantum potest arcus jacere: dixit enim: Non videbo morientem puerum: et sedens contra, levavit vocem suam et flevit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Genesis 21:17",
      "text": "Exaudivit autem Deus vocem pueri: vocavitque angelus Dei Agar de cælo, dicens: Quid agis Agar? noli timere: exaudivit enim Deus vocem pueri de loco in quo est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Genesis 21:18",
      "text": "Surge, tolle puerum, et tene manum illius: quia in gentem magnam faciam eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Genesis 21:19",
      "text": "Aperuitque oculos ejus Deus: quæ videns puteum aquæ, abiit, et implevit utrem, deditque puero bibere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Genesis 21:20",
      "text": "Et fuit cum eo: qui crevit, et moratus est in solitudine, factusque est juvenis sagittarius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Genesis 21:21",
      "text": "Habitavitque in deserto Pharan, et accepit illi mater sua uxorem de terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Genesis 21:22",
      "text": "Eodem tempore dixit Abimelech, et Phicol princeps exercitus ejus, ad Abraham: Deus tecum est in universis quæ agis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Genesis 21:23",
      "text": "Jura ergo per Deum, ne noceas mihi, et posteris meis, stirpique meæ: sed juxta misericordiam, quam feci tibi, facies mihi, et terræ in qua versatus es advena.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Genesis 21:24",
      "text": "Dixitque Abraham: Ego jurabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Genesis 21:25",
      "text": "Et increpavit Abimelech propter puteum aquæ quem vi abstulerunt servi ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Genesis 21:26",
      "text": "Responditque Abimelech: Nescivi quis fecerit hanc rem: sed et tu non indicasti mihi, et ego non audivi præter hodie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Genesis 21:27",
      "text": "Tulit itaque Abraham oves et boves, et dedit Abimelech: percusseruntque ambo fœdus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Genesis 21:28",
      "text": "Et statuit Abraham septem agnas gregis seorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Genesis 21:29",
      "text": "Cui dixit Abimelech: Quid sibi volunt septem agnæ istæ, quas stare fecisti seorsum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Genesis 21:30",
      "text": "At ille: Septem, inquit, agnas accipies de manu mea: ut sint mihi in testimonium, quoniam ego fodi puteum istum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Genesis 21:31",
      "text": "Idcirco vocatus est locus ille Bersabee: quia ibi uterque juravit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Genesis 21:32",
      "text": "Et inierunt fœdus pro puteo juramenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.33",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Genesis 21:33",
      "text": "Surrexit autem Abimelech, et Phicol princeps exercitus ejus, reversique sunt in terram Palæstinorum. Abraham vero plantavit nemus in Bersabee, et invocavit ibi nomen Domini Dei æterni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.21.34",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Genesis 21:34",
      "text": "Et fuit colonus terræ Palæstinorum diebus multis.",
      "paragraphStart": false
    }
  ]
}
