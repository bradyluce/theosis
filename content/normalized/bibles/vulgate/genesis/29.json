{
  "chapter": {
    "id": "vulgate:genesis.29",
    "translationId": "vulgate",
    "bookSlug": "genesis",
    "chapterNumber": 29,
    "referenceLabel": "Genesis 29",
    "summary": "Source text for Genesis 29 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:genesis.29.1",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Genesis 29:1",
      "text": "Profectus ergo Jacob venit in terram orientalem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:genesis.29.2",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Genesis 29:2",
      "text": "Et vidit puteum in agro, tres quoque greges ovium accubantes juxta eum: nam ex illo adaquabantur pecora, et os ejus grandi lapide claudebatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.3",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Genesis 29:3",
      "text": "Morisque erat ut cunctis ovibus congregatis devolverent lapidem, et refectis gregibus rursum super os putei ponerent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.4",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Genesis 29:4",
      "text": "Dixitque ad pastores: Fratres, unde estis? Qui responderunt: De Haran.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.5",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Genesis 29:5",
      "text": "Quos interrogans, Numquid, ait, nostis Laban filium Nachor? Dixerunt: Novimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.6",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Genesis 29:6",
      "text": "Sanusne est? inquit. Valet, inquiunt: et ecce Rachel filia ejus venit cum grege suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.7",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Genesis 29:7",
      "text": "Dixitque Jacob: Adhuc multum diei superest, nec est tempus ut reducantur ad caulas greges: date ante potum ovibus, et sic eas ad pastum reducite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.8",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Genesis 29:8",
      "text": "Qui responderunt: Non possumus, donec omnia pecora congregentur, et amoveamus lapidem de ore putei, ut adaquemus greges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.9",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Genesis 29:9",
      "text": "Adhuc loquebantur, et ecce Rachel veniebat cum ovibus patris sui: nam gregem ipsa pascebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.10",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Genesis 29:10",
      "text": "Quam cum vidisset Jacob, et sciret consobrinam suam, ovesque Laban avunculi sui, amovit lapidem quo puteus claudebatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.11",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Genesis 29:11",
      "text": "Et adaquato grege, osculatus est eam: et elevata voce flevit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.12",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Genesis 29:12",
      "text": "et indicavit ei quod frater esset patris sui, et filius Rebeccæ: at illa festinans nuntiavit patri suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.13",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Genesis 29:13",
      "text": "Qui cum audisset venisse Jacob filium sororis suæ, cucurrit obviam ei: complexusque eum, et in oscula ruens, duxit in domum suam. Auditis autem causis itineris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.14",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Genesis 29:14",
      "text": "respondit: Os meum es, et caro mea. Et postquam impleti sunt dies mensis unius,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.15",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Genesis 29:15",
      "text": "dixit ei: Num quia frater meus es, gratis servies mihi? dic quid mercedis accipias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.16",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Genesis 29:16",
      "text": "Habebat vero duas filias: nomen majoris Lia, minor vero appellabatur Rachel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.17",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Genesis 29:17",
      "text": "Sed Lia lippis erat oculis: Rachel decora facie, et venusto aspectu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.18",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Genesis 29:18",
      "text": "Quam diligens Jacob, ait: Serviam tibi pro Rachel filia tua minore, septem annis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.19",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Genesis 29:19",
      "text": "Respondit Laban: Melius est ut tibi eam dem quam alteri viro: mane apud me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.20",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Genesis 29:20",
      "text": "Servivit ergo Jacob pro Rachel septem annis: et videbantur illi pauci dies præ amoris magnitudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.21",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Genesis 29:21",
      "text": "Dixitque ad Laban: Da mihi uxorem meam: quia jam tempus impletum est, ut ingrediar ad illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.22",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Genesis 29:22",
      "text": "Qui vocatis multis amicorum turbis ad convivium, fecit nuptias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.23",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Genesis 29:23",
      "text": "Et vespere Liam filiam suam introduxit ad eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.24",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Genesis 29:24",
      "text": "dans ancillam filiæ, Zelpham nomine. Ad quam cum ex more Jacob fuisset ingressus, facto mane vidit Liam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.25",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Genesis 29:25",
      "text": "et dixit ad socerum suum: Quid est quod facere voluisti? nonne pro Rachel servivi tibi? quare imposuisti mihi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.26",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Genesis 29:26",
      "text": "Respondit Laban: Non est in loco nostro consuetudinis, ut minores ante tradamus ad nuptias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.27",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Genesis 29:27",
      "text": "Imple hebdomadam dierum hujus copulæ: et hanc quoque dabo tibi pro opere quo serviturus es mihi septem annis aliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.28",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 28,
      "referenceLabel": "Genesis 29:28",
      "text": "Acquievit placito: et hebdomada transacta, Rachel duxit uxorem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.29",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 29,
      "referenceLabel": "Genesis 29:29",
      "text": "cui pater servam Balam tradiderat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.30",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 30,
      "referenceLabel": "Genesis 29:30",
      "text": "Tandemque potitus optatis nuptiis, amorem sequentis priori prætulit, serviens apud eum septem annis aliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.31",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 31,
      "referenceLabel": "Genesis 29:31",
      "text": "Videns autem Dominus quod despiceret Liam, aperuit vulvam ejus, sorore sterili permanente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.32",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 32,
      "referenceLabel": "Genesis 29:32",
      "text": "Quæ conceptum genuit filium, vocavitque nomen ejus Ruben, dicens: Vidit Dominus humilitatem meam: nunc amabit me vir meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.33",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 33,
      "referenceLabel": "Genesis 29:33",
      "text": "Rursumque concepit et peperit filium, et ait: Quoniam audivit me Dominus haberi contemptui, dedit etiam istum mihi; vocavitque nomen ejus Simeon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.34",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 34,
      "referenceLabel": "Genesis 29:34",
      "text": "Concepitque tertio, et genuit alium filium: dixitque: Nunc quoque copulabitur mihi maritus meus: eo quod pepererim ei tres filios: et idcirco appellavit nomen ejus Levi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:genesis.29.35",
      "translationId": "vulgate",
      "bookSlug": "genesis",
      "chapterNumber": 29,
      "verseNumber": 35,
      "referenceLabel": "Genesis 29:35",
      "text": "Quarto concepit, et peperit filium, et ait: Modo confitebor Domino, et ob hoc vocavit eum Judam: cessavitque parere.",
      "paragraphStart": false
    }
  ]
}
