{
  "chapter": {
    "id": "vulgate:numbers.2",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 2,
    "referenceLabel": "Numbers 2",
    "summary": "Source text for Numbers 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.2.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Numbers 2:1",
      "text": "Locutusque est Dominus ad Moysen et Aaron, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.2.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Numbers 2:2",
      "text": "Singuli per turmas, signa, atque vexilla, et domos cognationum suarum, castrametabuntur filii Israël, per gyrum tabernaculi fœderis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Numbers 2:3",
      "text": "Ad orientem Judas figet tentoria per turmas exercitus sui: eritque princeps filiorum ejus Nahasson filius Aminadab.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Numbers 2:4",
      "text": "Et omnis de stirpe ejus summa pugnantium, septuaginta quatuor millia sexcenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Numbers 2:5",
      "text": "Juxta eum castrametati sunt de tribu Issachar, quorum princeps fuit Nathanaël filius Suar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Numbers 2:6",
      "text": "Et omnis numerus pugnatorum ejus quinquaginta quatuor millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Numbers 2:7",
      "text": "In tribu Zabulon princeps fuit Eliab filius Helon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Numbers 2:8",
      "text": "Omnis de stirpe ejus exercitus pugnatorum, quinquaginta septem millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Numbers 2:9",
      "text": "Universi qui in castris Judæ enumerati sunt, fuerunt centum octoginta sex millia quadringenti: et per turmas suas primi egredientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Numbers 2:10",
      "text": "In castris filiorum Ruben ad meridianam plagam erit princeps Elisur filius Sedeur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Numbers 2:11",
      "text": "Et cunctus exercitus pugnatorum ejus qui numerati sunt, quadraginta sex millia quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Numbers 2:12",
      "text": "Juxta eum castrametati sunt de tribu Simeon: quorum princeps fuit Salamiel filius Surisaddai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Numbers 2:13",
      "text": "Et cunctus exercitus pugnatorum ejus qui numerati sunt, quinquaginta novem millia trecenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Numbers 2:14",
      "text": "In tribu Gad princeps fuit Eliasaph filius Duel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Numbers 2:15",
      "text": "Et cunctus exercitus pugnatorum ejus, qui numerati sunt, quadraginta quinque millia sexcenti quinquaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Numbers 2:16",
      "text": "Omnes qui recensiti sunt in castris Ruben, centum quinquaginta millia et mille quadringenti quinquaginta per turmas suas: in secundo loco proficiscentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Numbers 2:17",
      "text": "Levabitur autem tabernaculum testimonii per officia Levitarum, et turmas eorum: quomodo erigetur, ita et deponetur. Singuli per loca et ordines suos proficiscentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Numbers 2:18",
      "text": "Ad occidentalem plagam erunt castra filiorum Ephraim, quorum princeps fuit Elisama filius Ammiud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Numbers 2:19",
      "text": "Cunctus exercitus pugnatorum ejus, qui numerati sunt, quadraginta millia quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Numbers 2:20",
      "text": "Et cum eis tribus filiorum Manasse, quorum princeps fuit Gamaliel filius Phadassur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Numbers 2:21",
      "text": "Cunctusque exercitus pugnatorum ejus, qui numerati sunt, triginta duo millia ducenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Numbers 2:22",
      "text": "In tribu filiorum Benjamin princeps fuit Abidan filius Gedeonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Numbers 2:23",
      "text": "Et cunctus exercitus pugnatorum ejus, qui recensiti sunt, triginta quinque millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Numbers 2:24",
      "text": "Omnes qui numerati sunt in castris Ephraim, centum octo millia centum per turmas suas: tertii proficiscentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Numbers 2:25",
      "text": "Ad aquilonis partem castrametati sunt filii Dan: quorum princeps fuit Ahiezer filius Ammisaddai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Numbers 2:26",
      "text": "Cunctus exercitus pugnatorum ejus, qui numerati sunt, sexaginta duo millia septingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Numbers 2:27",
      "text": "Juxta eum fixere tentoria de tribu Aser: quorum princeps fuit Phegiel filius Ochran.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Numbers 2:28",
      "text": "Cunctus exercitus pugnatorum ejus, qui numerati sunt, quadraginta millia et mille quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Numbers 2:29",
      "text": "De tribu filiorum Nephthali princeps fuit Ahira filius Enan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Numbers 2:30",
      "text": "Cunctus exercitus pugnatorum ejus, quinquaginta tria millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Numbers 2:31",
      "text": "Omnes qui numerati sunt in castris Dan, fuerunt centum quinquaginta septem millia sexcenti: et novissimi proficiscentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Numbers 2:32",
      "text": "Hic numerus filiorum Israël, per domos cognationum suarum et turmas divisi exercitus, sexcenta tria millia quingenti quinquaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Numbers 2:33",
      "text": "Levitæ autem non sunt numerati inter filios Israël: sic enim præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.2.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Numbers 2:34",
      "text": "Feceruntque filii Israël juxta omnia quæ mandaverat Dominus. Castrametati sunt per turmas suas, et profecti per familias ac domos patrum suorum.",
      "paragraphStart": false
    }
  ]
}
