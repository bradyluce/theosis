{
  "chapter": {
    "id": "vulgate:numbers.25",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 25,
    "referenceLabel": "Numbers 25",
    "summary": "Source text for Numbers 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.25.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Numbers 25:1",
      "text": "Morabatur autem eo tempore Israël in Settim, et fornicatus est populus cum filiabus Moab,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.25.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Numbers 25:2",
      "text": "quæ vocaverunt eos ad sacrificia sua. At ille comederunt et adoraverunt deos earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Numbers 25:3",
      "text": "Initiatusque est Israël Beelphegor: et iratus Dominus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Numbers 25:4",
      "text": "ait ad Moysen: Tolle cunctos principes populi, et suspende eos contra solem in patibulis, ut avertatur furor meus ab Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Numbers 25:5",
      "text": "Dixitque Moyses ad judices Israël: Occidat unusquisque proximos suos, qui initiati sunt Beelphegor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Numbers 25:6",
      "text": "Et ecce unus de filiis Israël intravit coram fratribus suis ad scortum Madianitidem, vidente Moyse, et omni turba filiorum Israël, qui flebant ante fores tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Numbers 25:7",
      "text": "Quod cum vidisset Phinees filius Eleazari filii Aaron sacerdotis, surrexit de medio multitudinis, et arrepto pugione,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Numbers 25:8",
      "text": "ingressus est post virum Israëlitem in lupanar, et perfodit ambos simul, virum scilicet et mulierem in locis genitalibus. Cessavitque plaga a filiis Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Numbers 25:9",
      "text": "et occisi sunt viginti quatuor millia hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Numbers 25:10",
      "text": "Dixitque Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Numbers 25:11",
      "text": "Phinees filius Eleazari filii Aaron sacerdotis avertit iram meam a filiis Israël: quia zelo meo commotus est contra eos, ut non ipse delerem filios Israël in zelo meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Numbers 25:12",
      "text": "Idcirco loquere ad eum: Ecce do ei pacem fœderis mei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Numbers 25:13",
      "text": "et erit tam ipsi quam semini ejus pactum sacerdotii sempiternum: quia zelatus est pro Deo suo, et expiavit scelus filiorum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Numbers 25:14",
      "text": "Erat autem nomen viri Israëlitæ, qui occisus est cum Madianitide, Zambri filius Salu, dux de cognatione et tribu Simeonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Numbers 25:15",
      "text": "Porro mulier Madianitis, quæ pariter interfecta est, vocabatur Cozbi filia Sur principis nobilissimi Madianitarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Numbers 25:16",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Numbers 25:17",
      "text": "Hostes vos sentiant Madianitæ, et percutite eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.25.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Numbers 25:18",
      "text": "quia et ipsi hostiliter egerunt contra vos, et decepere insidiis per idolum Phogor, et Cozbi filiam ducis Madian sororem suam, quæ percussa est in die plagæ pro sacrilegio Phogor.",
      "paragraphStart": false
    }
  ]
}
