{
  "chapter": {
    "id": "vulgate:numbers.3",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 3,
    "referenceLabel": "Numbers 3",
    "summary": "Source text for Numbers 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.3.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Numbers 3:1",
      "text": "Hæ sunt generationes Aaron et Moysi in die qua locutus est Dominus ad Moysen in monte Sinai.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.3.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Numbers 3:2",
      "text": "Et hæc nomina filiorum Aaron: primogenitus ejus Nadab, deinde Abiu, et Eleazar, et Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Numbers 3:3",
      "text": "Hæc nomina filiorum Aaron sacerdotum qui uncti sunt, et quorum repletæ et consecratæ manus ut sacerdotio fungerentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Numbers 3:4",
      "text": "Mortui sunt enim Nadab et Abiu cum offerrent ignem alienum in conspectu Domini in deserto Sinai, absque liberis: functique sunt sacerdotio Eleazar et Ithamar coram Aaron patre suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Numbers 3:5",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Numbers 3:6",
      "text": "Applica tribum Levi, et fac stare in conspectu Aaron sacerdotis ut ministrent ei, et excubent,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Numbers 3:7",
      "text": "et observent quidquid ad cultum pertinet multitudinis coram tabernaculo testimonii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Numbers 3:8",
      "text": "et custodiant vasa tabernaculi, servientes in ministerio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Numbers 3:9",
      "text": "Dabisque dono Levitas",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Numbers 3:10",
      "text": "Aaron et filiis ejus, quibus traditi sunt a filiis Israël. Aaron autem et filios ejus constitues super cultum sacerdotii. Externus, qui ad ministrandum accesserit, morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Numbers 3:11",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Numbers 3:12",
      "text": "Ego tuli Levitas a filiis Israël pro omni primogenito, qui aperit vulvam in filiis Israël, eruntque Levitæ mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Numbers 3:13",
      "text": "Meum est enim omne primogenitum: ex quo percussi primogenitos in terra Ægypti, sanctificavi mihi quidquid primum nascitur in Israël: ab homine usque ad pecus, mei sunt. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Numbers 3:14",
      "text": "Locutusque est Dominus ad Moysen in deserto Sinai, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Numbers 3:15",
      "text": "Numera filios Levi per domos patrum suorum et familias, omnem masculum ab uno mense et supra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Numbers 3:16",
      "text": "Numeravit Moyses, ut præceperat Dominus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Numbers 3:17",
      "text": "et inventi sunt filii Levi per nomina sua, Gerson et Caath et Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Numbers 3:18",
      "text": "Filii Gerson: Lebni et Semei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Numbers 3:19",
      "text": "Filii Caath: Amram et Jesaar, Hebron et Oziel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Numbers 3:20",
      "text": "Filii Merari: Moholi et Musi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Numbers 3:21",
      "text": "De Gerson fuere familiæ duæ, Lebnitica, et Semeitica:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Numbers 3:22",
      "text": "quarum numeratus est populus sexus masculini ab uno mense et supra, septem millia quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Numbers 3:23",
      "text": "Hi post tabernaculum metabuntur ad occidentem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Numbers 3:24",
      "text": "sub principe Eliasaph filio Laël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Numbers 3:25",
      "text": "Et habebunt excubias in tabernaculo fœderis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Numbers 3:26",
      "text": "ipsum tabernaculum et operimentum ejus, tentorium quod trahitur ante fores tecti fœderis, et cortinas atrii: tentorium quoque quod appenditur in introitu atrii tabernaculi, et quidquid ad ritum altaris pertinet, funes tabernaculi et omnia utensilia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Numbers 3:27",
      "text": "Cognatio Caath habebit populos Amramitas et Jesaaritas et Hebronitas et Ozielitas. Hæ sunt familiæ Caathitarum recensitæ per nomina sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Numbers 3:28",
      "text": "Omnes generis masculini ab uno mense et supra, octo millia sexcenti habebunt excubias sanctuarii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Numbers 3:29",
      "text": "et castrametabuntur ad meridianam plagam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Numbers 3:30",
      "text": "Princepsque eorum erit Elisaphan filius Oziel:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Numbers 3:31",
      "text": "et custodient arcam, mensamque et candelabrum, altaria et vasa sanctuarii, in quibus ministratur, et velum, cunctamque hujuscemodi supellectilem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Numbers 3:32",
      "text": "Princeps autem principum Levitarum Eleazar filius Aaron sacerdotis, erit super excubitores custodiæ sanctuarii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Numbers 3:33",
      "text": "At vero de Merari erunt populi Moholitæ et Musitæ recensiti per nomina sua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Numbers 3:34",
      "text": "omnes generis masculini ab uno mense et supra, sex millia ducenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Numbers 3:35",
      "text": "Princeps eorum Suriel filius Abihaiel: in plaga septentrionali castrametabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Numbers 3:36",
      "text": "Erunt sub custodia eorum tabulæ tabernaculi et vectes, et columnæ ac bases earum, et omnia quæ ad cultum hujuscemodi pertinent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.37",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Numbers 3:37",
      "text": "columnæque atrii per circuitum cum basibus suis, et paxilli cum funibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.38",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Numbers 3:38",
      "text": "Castrametabuntur ante tabernaculum fœderis, id est, ad orientalem plagam, Moyses et Aaron cum filiis suis, habentes custodiam sanctuarii in medio filiorum Israël. Quisquis alienus accesserit, morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.39",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Numbers 3:39",
      "text": "Omnes Levitæ, quos numeraverunt Moyses et Aaron juxta præceptum Domini per familias suas in genere masculino a mense uno et supra, fuerunt viginti duo millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.40",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Numbers 3:40",
      "text": "Et ait Dominus ad Moysen: Numera primogenitos sexus masculini de filiis Israël ab uno mense et supra, et habebis summam eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.41",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Numbers 3:41",
      "text": "Tollesque Levitas mihi pro omni primogenito filiorum Israël: ego sum Dominus: et pecora eorum pro universis primogenitis pecorum filiorum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.42",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Numbers 3:42",
      "text": "Recensuit Moyses, sicut præceperat Dominus, primogenitos filiorum Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.43",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Numbers 3:43",
      "text": "et fuerunt masculi per nomina sua, a mense uno et supra, viginti duo millia ducenti septuaginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.44",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Numbers 3:44",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.45",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Numbers 3:45",
      "text": "Tolle Levitas pro primogenitis filiorum Israël, et pecora Levitarum pro pecoribus eorum, eruntque Levitæ mei. Ego sum Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.46",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Numbers 3:46",
      "text": "In pretio autem ducentorum septuaginta trium, qui excedunt numerum Levitarum de primogenitis filiorum Israël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.47",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Numbers 3:47",
      "text": "accipies quinque siclos per singula capita ad mensuram sanctuarii (siclus habet viginti obolos):",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.48",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 48,
      "referenceLabel": "Numbers 3:48",
      "text": "dabisque pecuniam Aaron et filiis ejus pretium eorum qui supra sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.49",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 49,
      "referenceLabel": "Numbers 3:49",
      "text": "Tulit igitur Moyses pecuniam eorum, qui fuerant amplius, et quos redemerant a Levitis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.50",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 50,
      "referenceLabel": "Numbers 3:50",
      "text": "pro primogenitis filiorum Israël, mille trecentorum sexaginta quinque siclorum juxta pondus sanctuarii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.3.51",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 3,
      "verseNumber": 51,
      "referenceLabel": "Numbers 3:51",
      "text": "et dedit eam Aaron et filiis ejus juxta verbum quod præceperat sibi Dominus.",
      "paragraphStart": false
    }
  ]
}
