{
  "chapter": {
    "id": "vulgate:numbers.23",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 23,
    "referenceLabel": "Numbers 23",
    "summary": "Source text for Numbers 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.23.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Numbers 23:1",
      "text": "Dixitque Balaam ad Balac: Ædifica mihi hic septem aras, et para totidem vitulos, ejusdemque numeri arietes.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.23.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Numbers 23:2",
      "text": "Cumque fecisset juxta sermonem Balaam, imposuerunt simul vitulum et arietem super aram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Numbers 23:3",
      "text": "Dixitque Balaam ad Balac: Sta paulisper juxta holocaustum tuum, donec vadam, si forte occurrat mihi Dominus, et quodcumque imperaverit, loquar tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Numbers 23:4",
      "text": "Cumque abiisset velociter, occurrit illi Deus. Locutusque ad eum Balaam: Septem, inquit, aras erexi, et imposui vitulum et arietem desuper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Numbers 23:5",
      "text": "Dominus autem posuit verbum in ore ejus, et ait: Revertere ad Balac, et hæc loqueris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Numbers 23:6",
      "text": "Reversus invenit stantem Balac juxta holocaustum suum, et omnes principes Moabitarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Numbers 23:7",
      "text": "assumptaque parabola sua, dixit: De Aram adduxit me Balac rex Moabitarum, de montibus orientis: Veni, inquit, et maledic Jacob; propera, et detestare Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Numbers 23:8",
      "text": "Quomodo maledicam, cui non maledixit Deus? qua ratione detester, quem Dominus non detestatur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Numbers 23:9",
      "text": "De summis silicibus videbo eum, et de collibus considerabo illum. Populus solus habitabit, et inter gentes non reputabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Numbers 23:10",
      "text": "Quis dinumerare possit pulverem Jacob, et nosse numerum stirpis Israël? Moriatur anima mea morte justorum, et fiant novissima mea horum similia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Numbers 23:11",
      "text": "Dixitque Balac ad Balaam: Quid est hoc quod agis? ut malediceres inimicis meis vocavi te, et tu e contrario benedicis eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Numbers 23:12",
      "text": "Cui ille respondit: Num aliud possum loqui, nisi quod jusserit Dominus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Numbers 23:13",
      "text": "Dixit ergo Balac: Veni mecum in alterum locum unde partem Israël videas, et totum videre non possis: inde maledicito ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Numbers 23:14",
      "text": "Cumque duxisset eum in locum sublimem, super verticem montis Phasga, ædificavit Balaam septem aras, et impositis supra vitulo atque ariete,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Numbers 23:15",
      "text": "dixit ad Balac: Sta hic juxta holocaustum tuum, donec ego obvius pergam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Numbers 23:16",
      "text": "Cui cum Dominus occurrisset, posuissetque verbum in ore ejus, ait: Revertere ad Balac, et hæc loqueris ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Numbers 23:17",
      "text": "Reversus invenit eum stantem juxta holocaustum suum, et principes Moabitarum cum eo. Ad quem Balac: Quid, inquit, locutus est Dominus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Numbers 23:18",
      "text": "At ille, assumpta parabola sua, ait: Sta, Balac, et ausculta; audi, fili Sephor:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Numbers 23:19",
      "text": "non est Deus quasi homo, ut mentiatur, nec ut filius hominis, ut mutetur. Dixit ergo, et non faciet? locutus est, et non implebit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Numbers 23:20",
      "text": "Ad benedicendum adductus sum: benedictionem prohibere non valeo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Numbers 23:21",
      "text": "Non est idolum in Jacob, nec videtur simulacrum in Israël. Dominus Deus ejus cum eo est, et clangor victoriæ regis in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Numbers 23:22",
      "text": "Deus eduxit illum de Ægypto, cujus fortitudo similis est rhinocerotis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Numbers 23:23",
      "text": "Non est augurium in Jacob, nec divinatio in Israël: temporibus suis dicetur Jacob et Israëli quid operatus sit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Numbers 23:24",
      "text": "Ecce populus ut leæna consurget, et quasi leo erigetur: non accubabit donec devoret prædam, et occisorum sanguinem bibat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Numbers 23:25",
      "text": "Dixitque Balac ad Balaam: Nec maledicas ei, nec benedicas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Numbers 23:26",
      "text": "Et ille ait: Nonne dixi tibi quod quidquid mihi Deus imperaret, hoc facerem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Numbers 23:27",
      "text": "Et ait Balac ad eum: Veni, et ducam te ad alium locum: si forte placeat Deo ut inde maledicas eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Numbers 23:28",
      "text": "Cumque duxisset eum super verticem montis Phogor, qui respicit solitudinem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Numbers 23:29",
      "text": "dixit ei Balaam: Ædifica mihi hic septem aras, et para totidem vitulos, ejusdemque numeri arietes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.23.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Numbers 23:30",
      "text": "Fecit Balac ut Balaam dixerat: imposuitque vitulos et arietes per singulas aras.",
      "paragraphStart": false
    }
  ]
}
