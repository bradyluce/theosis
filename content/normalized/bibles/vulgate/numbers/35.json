{
  "chapter": {
    "id": "vulgate:numbers.35",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 35,
    "referenceLabel": "Numbers 35",
    "summary": "Source text for Numbers 35 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.35.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Numbers 35:1",
      "text": "Hæc quoque locutus est Dominus ad Moysen in campes tribus Moab supra Jordanem, contra Jericho:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.35.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Numbers 35:2",
      "text": "Præcipe filiis Israël ut dent Levitis de possessionibus suis",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Numbers 35:3",
      "text": "urbes ad habitandum, et suburbana earum per circuitum: ut ipsi in oppidis maneant, et suburbana sint pecoribus ac jumentis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Numbers 35:4",
      "text": "quæ a muris civitatum forinsecus, per circuitum, mille passuum spatio tendentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Numbers 35:5",
      "text": "Contra orientem duo millia erunt cubiti, et contra meridiem similiter erunt duo millia: ad mare quoque, quod respicit ad occidentem, eadem mensura erit, et septentrionalis plaga æquali termino finietur, eruntque urbes in medio, et foris suburbana.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Numbers 35:6",
      "text": "De ipsis autem oppidis, quæ Levitis dabitis, sex erunt in fugitivorum auxilia separata, ut fugiat ad ea qui fuderit sanguinem: et exceptis his, alia quadraginta duo oppida,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Numbers 35:7",
      "text": "id est, simul quadraginta octo cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Numbers 35:8",
      "text": "Ipsæque urbes, quæ dabuntur de possessionibus filiorum Israël, ab his qui plus habent, plures auferentur: et qui minus, pauciores: singuli juxta mensuram hæreditatis suæ dabunt oppida Levitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Numbers 35:9",
      "text": "Ait Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Numbers 35:10",
      "text": "Loquere filiis Israël, et dices ad eos: Quando transgressi fueritis Jordanem in terram Chanaan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Numbers 35:11",
      "text": "decernite quæ urbes esse debeant in præsidia fugitivorum, qui nolentes sanguinem fuderint:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Numbers 35:12",
      "text": "in quibus cum fuerit profugus, cognatus occisi non poterit eum occidere, donec stet in conspectu multitudinis, et causa illius judicetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Numbers 35:13",
      "text": "De ipsis autem urbibus, quæ ad fugitivorum subsidia separantur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Numbers 35:14",
      "text": "tres erunt trans Jordanem, et tres in terra Chanaan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Numbers 35:15",
      "text": "tam filiis Israël quam advenis atque peregrinis, ut confugiat ad eas qui nolens sanguinem fuderit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Numbers 35:16",
      "text": "Si quis ferro percusserit, et mortuus fuerit qui percussus est, reus erit homicidii, et ipse morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Numbers 35:17",
      "text": "Si lapidem jecerit, et ictus occubuerit, similiter punietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Numbers 35:18",
      "text": "Si ligno percussus interierit, percussoris sanguine vindicabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Numbers 35:19",
      "text": "Propinquus occisi, homicidam interficiet: statim ut apprehenderit eum, interficiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Numbers 35:20",
      "text": "Si per odium quis hominem impulerit, vel jecerit quippiam in eum per insidias:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Numbers 35:21",
      "text": "aut cum esset inimicus, manu percusserit, et ille mortuus fuerit: percussor homicidii reus erit: cognatus occisi statim ut invenerit eum, jugulabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Numbers 35:22",
      "text": "Quod si fortuitu, et absque odio",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Numbers 35:23",
      "text": "et inimicitiis quidquam horum fecerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Numbers 35:24",
      "text": "et hoc audiente populo fuerit comprobatum, atque inter percussorem et propinquum sanguinis quæstio ventilata:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Numbers 35:25",
      "text": "liberabitur innocens de ultoris manu, et reducetur per sententiam in urbem, ad quam confugerat, manebitque ibi, donec sacerdos magnus, qui oleo sancto unctus est, moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Numbers 35:26",
      "text": "Si interfector extra fines urbium, quæ exulibus deputatæ sunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Numbers 35:27",
      "text": "fuerit inventus, et percussus ab eo qui ultor est sanguinis: absque noxa erit qui eum occiderit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Numbers 35:28",
      "text": "Debuerat enim profugus usque ad mortem pontificis in urbe residere. Postquam autem ille obierit, homicida revertetur in terram suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 29,
      "referenceLabel": "Numbers 35:29",
      "text": "Hæc sempiterna erunt, et legitima in cunctis habitationibus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 30,
      "referenceLabel": "Numbers 35:30",
      "text": "Homicida sub testibus punietur: ad unius testimonium nullus condemnabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 31,
      "referenceLabel": "Numbers 35:31",
      "text": "Non accipietis pretium ab eo qui reus est sanguinis, statim et ipse morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 32,
      "referenceLabel": "Numbers 35:32",
      "text": "Exules et profugi ante mortem pontificis nullo modo in urbes suas reverti poterunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 33,
      "referenceLabel": "Numbers 35:33",
      "text": "ne polluatis terram habitationis vestræ, quæ insontium cruore maculatur: nec aliter expiari potest, nisi per ejus sanguinem, qui alterius sanguinem fuderit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.35.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 35,
      "verseNumber": 34,
      "referenceLabel": "Numbers 35:34",
      "text": "Atque ita emundabitur vestra possessio me commorante vobiscum. Ego enim sum Dominus qui habito inter filios Israël.",
      "paragraphStart": false
    }
  ]
}
