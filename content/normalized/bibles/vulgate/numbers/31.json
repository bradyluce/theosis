{
  "chapter": {
    "id": "vulgate:numbers.31",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 31,
    "referenceLabel": "Numbers 31",
    "summary": "Source text for Numbers 31 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.31.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Numbers 31:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.31.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Numbers 31:2",
      "text": "Ulciscere prius filios Israël de Madianitis, et sic colligeris ad populum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Numbers 31:3",
      "text": "Statimque Moyses: Armate, inquit, ex vobis viros ad pugnam, qui possint ultionem Domini expetere de Madianitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Numbers 31:4",
      "text": "Mille viri de singulis tribubus eligantur ex Israël qui mittantur ad bellum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Numbers 31:5",
      "text": "Dederuntque millenos de singulis tribubus, id est, duodecim millia expeditorum ad pugnam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Numbers 31:6",
      "text": "quos misit Moyses cum Phinees filio Eleazari sacerdotis, vasa quoque sancta, et tubas ad clangendum tradidit ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Numbers 31:7",
      "text": "Cumque pugnassent contra Madianitas atque vicissent, omnes mares occiderunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Numbers 31:8",
      "text": "et reges eorum, Evi, et Recem, et Sur, et Hur, et Rebe, quinque principes gentis: Balaam quoque filium Beor interfecerunt gladio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Numbers 31:9",
      "text": "Ceperuntque mulieres eorum, et parvulos, omniaque pecora, et cunctam supellectilem: quidquid habere potuerant depopulati sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Numbers 31:10",
      "text": "tam urbes quam viculos et castella flamma consumpsit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Numbers 31:11",
      "text": "Et tulerunt prædam, et universa quæ ceperant tam ex hominibus quam ex jumentis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Numbers 31:12",
      "text": "et adduxerunt ad Moysen, et Eleazarum sacerdotem, et ad omnem multitudinem filiorum Israël: reliqua autem utensilia portaverunt ad castra in campestribus Moab juxta Jordanem contra Jericho.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Numbers 31:13",
      "text": "Egressi sunt autem Moyses et Eleazar sacerdos, et omnes principes synagogæ, in occursum eorum extra castra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Numbers 31:14",
      "text": "Iratusque Moyses principibus exercitus, tribunis, et centurionibus qui venerant de bello,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Numbers 31:15",
      "text": "ait: Cur feminas reservastis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Numbers 31:16",
      "text": "nonne istæ sunt, quæ deceperunt filios Israël ad suggestionem Balaam, et prævaricari vos fecerunt in Domino super peccato Phogor, unde et percussus est populus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Numbers 31:17",
      "text": "ergo cunctos interficite quidquid est generis masculini, etiam in parvulis: et mulieres, quæ noverunt viros in coitu, jugulate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Numbers 31:18",
      "text": "puellas autem et omnes feminas virgines reservate vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Numbers 31:19",
      "text": "et manete extra castra septem diebus. Qui occiderit hominem, vel occisum tetigerit, lustrabitur die tertio et septimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Numbers 31:20",
      "text": "Et de omni præda, sive vestimentum fuerit, sive vas, et aliquid in utensilia præparatum, de caprarum pellibus, et pilis, et ligno, expiabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Numbers 31:21",
      "text": "Eleazar quoque sacerdos ad viros exercitus, qui pugnaverunt, sic locutus est: Hoc est præceptum legis, quod mandavit Dominus Moysi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Numbers 31:22",
      "text": "aurum, et argentum, et æs, et ferrum, et plumbum, et stannum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Numbers 31:23",
      "text": "et omne, quod potest transire per flammas, igne purgabitur: quidquid autem ignem non potest sustinere, aqua expiationis sanctificabitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Numbers 31:24",
      "text": "et lavabitis vestimenta vestra die septimo, et purificati postea castra intrabitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Numbers 31:25",
      "text": "Dixit quoque Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Numbers 31:26",
      "text": "Tollite summam eorum quæ capta sunt, ab homine usque ad pecus, tu et Eleazar sacerdos et principes vulgi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Numbers 31:27",
      "text": "dividesque ex æquo prædam inter eos qui pugnaverunt egressique sunt ad bellum, et inter omnem reliquam multitudinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Numbers 31:28",
      "text": "Et separabis partem Domino ab his qui pugnaverunt et fuerunt in bello, unam animam de quingentis, tam ex hominibus quam ex bobus et asinis et ovibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Numbers 31:29",
      "text": "et dabis eam Eleazaro sacerdoti, quia primitiæ Domini sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Numbers 31:30",
      "text": "Ex media quoque parte filiorum Israël accipies quinquagesimum caput hominum, et boum, et asinorum, et ovium, cunctorum animantium, et dabis ea Levitis, qui excubant in custodiis tabernaculi Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Numbers 31:31",
      "text": "Feceruntque Moyses et Eleazar sicut præceperat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 32,
      "referenceLabel": "Numbers 31:32",
      "text": "Fuit autem præda, quam exercitus ceperat, ovium sexcenta septuaginta quinque millia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 33,
      "referenceLabel": "Numbers 31:33",
      "text": "boum septuaginta duo millia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 34,
      "referenceLabel": "Numbers 31:34",
      "text": "asinorum sexaginta millia et mille:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 35,
      "referenceLabel": "Numbers 31:35",
      "text": "animæ hominum sexus feminei, quæ non cognoverant viros, triginta duo millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 36,
      "referenceLabel": "Numbers 31:36",
      "text": "Dataque est media pars his qui in prælio fuerant, ovium trecenta triginta septem millia quingentæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.37",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 37,
      "referenceLabel": "Numbers 31:37",
      "text": "e quibus in partem Domini supputatæ sunt oves sexcentæ septuaginta quinque:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.38",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 38,
      "referenceLabel": "Numbers 31:38",
      "text": "et de bobus triginta sex millibus, boves septuaginta et duo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.39",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 39,
      "referenceLabel": "Numbers 31:39",
      "text": "de asinis triginta millibus quingentis, asini sexaginta unus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.40",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 40,
      "referenceLabel": "Numbers 31:40",
      "text": "de animabus hominum sedecim millibus, cesserunt in partem Domini triginta duæ animæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.41",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 41,
      "referenceLabel": "Numbers 31:41",
      "text": "Tradiditque Moyses numerum primitiarum Domini Eleazaro sacerdoti, sicut fuerat ei imperatum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.42",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 42,
      "referenceLabel": "Numbers 31:42",
      "text": "ex media parte filiorum Israël, quam separaverat his qui in prælio fuerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.43",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 43,
      "referenceLabel": "Numbers 31:43",
      "text": "De media vero parte, quæ contigerat reliquæ multitudini, id est, de ovibus trecentis triginta septem millibus quingentis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.44",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 44,
      "referenceLabel": "Numbers 31:44",
      "text": "et de bobus triginta sex millibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.45",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 45,
      "referenceLabel": "Numbers 31:45",
      "text": "et de asinis triginta millibus quingentis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.46",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 46,
      "referenceLabel": "Numbers 31:46",
      "text": "et de hominibus sedecim millibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.47",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 47,
      "referenceLabel": "Numbers 31:47",
      "text": "tulit Moyses quinquagesimum caput, et dedit Levitis, qui excubabant in tabernaculo Domini, sicut præceperat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.48",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 48,
      "referenceLabel": "Numbers 31:48",
      "text": "Cumque accessissent principes exercitus ad Moysen, et tribuni, centurionesque, dixerunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.49",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 49,
      "referenceLabel": "Numbers 31:49",
      "text": "Nos servi tui recensuimus numerum pugnatorum, quos habuimus sub manu nostra: et ne unus quidem defuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.50",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 50,
      "referenceLabel": "Numbers 31:50",
      "text": "Ob hanc causam offerimus in donariis Domini singuli quod in præda auri potuimus invenire, periscelides et armillas, annulos et dextralia, ac murænulas, ut depreceris pro nobis Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.51",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 51,
      "referenceLabel": "Numbers 31:51",
      "text": "Susceperuntque Moyses et Eleazar sacerdos omne aurum in diversis speciebus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.52",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 52,
      "referenceLabel": "Numbers 31:52",
      "text": "pondo sedecim millia septingentos quinquaginta siclos, a tribunis et centurionibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.53",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 53,
      "referenceLabel": "Numbers 31:53",
      "text": "Unusquisque enim quod in præda rapuerat, suum erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.31.54",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 31,
      "verseNumber": 54,
      "referenceLabel": "Numbers 31:54",
      "text": "Et susceptum intulerunt in tabernaculum testimonii, in monimentum filiorum Israël coram Domino.",
      "paragraphStart": false
    }
  ]
}
