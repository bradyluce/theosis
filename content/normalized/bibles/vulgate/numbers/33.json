{
  "chapter": {
    "id": "vulgate:numbers.33",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 33,
    "referenceLabel": "Numbers 33",
    "summary": "Source text for Numbers 33 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.33.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Numbers 33:1",
      "text": "Hæ sunt mansiones filiorum Israël, qui egressi sunt de Ægypto per turmas suas in manu Moysi et Aaron,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.33.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Numbers 33:2",
      "text": "quas descripsit Moyses juxta castrorum loca, quæ Domini jussione mutabant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Numbers 33:3",
      "text": "Profecti igitur de Ramesse mense primo, quintadecima die mensis primi, altera die Phase, filii Israël in manu excelsa, videntibus cunctis Ægyptiis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Numbers 33:4",
      "text": "et sepelientibus primogenitos, quos percusserat Dominus (nam et in diis eorum exercuerat ultionem),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Numbers 33:5",
      "text": "castrametati sunt in Soccoth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Numbers 33:6",
      "text": "Et de Soccoth venerunt in Etham, quæ est in extremis finibus solitudinis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Numbers 33:7",
      "text": "Inde egressi venerunt contra Phihahiroth, quæ respicit Beelsephon, et castrametati sunt ante Magdalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Numbers 33:8",
      "text": "Profectique de Phihahiroth, transierunt per medium mare in solitudinem: et ambulantes tribus diebus per desertum Etham, castrametati sunt in Mara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Numbers 33:9",
      "text": "Profectique de Mara, venerunt in Elim, ubi erant duodecim fontes aquarum, et palmæ septuaginta: ibique castrametati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Numbers 33:10",
      "text": "Sed et inde egressi, fixerunt tentoria super mare Rubrum. Profectique de mari Rubro,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Numbers 33:11",
      "text": "castrametati sunt in deserto Sin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Numbers 33:12",
      "text": "Unde egressi, venerunt in Daphca.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Numbers 33:13",
      "text": "Profectique de Daphca, castrametati sunt in Alus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Numbers 33:14",
      "text": "Egressique de Alus, in Raphidim fixere tentoria, ubi populo defuit aqua ad bibendum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Numbers 33:15",
      "text": "Profectique de Raphidim, castrametati sunt in deserto Sinai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Numbers 33:16",
      "text": "Sed et de solitudine Sinai egressi, venerunt ad sepulchra concupiscentiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Numbers 33:17",
      "text": "Profectique de sepulchris concupiscentiæ, castrametati sunt in Haseroth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Numbers 33:18",
      "text": "Et de Haseroth venerunt in Rethma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Numbers 33:19",
      "text": "Profectique de Rethma, castrametati sunt in Remmomphares.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Numbers 33:20",
      "text": "Unde egressi venerunt in Lebna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Numbers 33:21",
      "text": "De Lebna castrametati sunt in Ressa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Numbers 33:22",
      "text": "Egressique de Ressa, venerunt in Ceelatha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Numbers 33:23",
      "text": "Unde profecti, castrametati sunt in monte Sepher.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 24,
      "referenceLabel": "Numbers 33:24",
      "text": "Egressi de monte Sepher, venerunt in Arada.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 25,
      "referenceLabel": "Numbers 33:25",
      "text": "Inde proficiscentes, castrametati sunt in Maceloth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 26,
      "referenceLabel": "Numbers 33:26",
      "text": "Profectique de Maceloth, venerunt in Thahath.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 27,
      "referenceLabel": "Numbers 33:27",
      "text": "De Thahath, castrametati sunt in Thare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 28,
      "referenceLabel": "Numbers 33:28",
      "text": "Unde egressi, fixere tentoria in Methca.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 29,
      "referenceLabel": "Numbers 33:29",
      "text": "Et de Methca, castrametati sunt in Hesmona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 30,
      "referenceLabel": "Numbers 33:30",
      "text": "Profectique de Hesmona, venerunt in Moseroth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 31,
      "referenceLabel": "Numbers 33:31",
      "text": "Et de Moseroth, castrametati sunt in Benejaacan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 32,
      "referenceLabel": "Numbers 33:32",
      "text": "Profectique de Benejaacan, venerunt in montem Gadgad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 33,
      "referenceLabel": "Numbers 33:33",
      "text": "Unde profecti, castrametati sunt in Jetebatha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 34,
      "referenceLabel": "Numbers 33:34",
      "text": "Et de Jetebatha venerunt in Hebrona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 35,
      "referenceLabel": "Numbers 33:35",
      "text": "Egressique de Hebrona, castrametati sunt in Asiongaber.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 36,
      "referenceLabel": "Numbers 33:36",
      "text": "Inde profecti, venerunt in desertum Sin, hæc est Cades.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.37",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 37,
      "referenceLabel": "Numbers 33:37",
      "text": "Egressique de Cades, castrametati sunt in monte Hor, in extremis finibus terræ Edom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.38",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 38,
      "referenceLabel": "Numbers 33:38",
      "text": "Ascenditque Aaron sacerdos in montem Hor jubente Domino: et ibi mortuus est anno quadragesimo egressionis filiorum Israël ex Ægypto, mense quinto, prima die mensis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.39",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 39,
      "referenceLabel": "Numbers 33:39",
      "text": "cum esset annorum centum viginti trium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.40",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 40,
      "referenceLabel": "Numbers 33:40",
      "text": "Audivitque Chananæus rex Arad, qui habitabat ad meridiem, in terram Chanaan venisse filios Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.41",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 41,
      "referenceLabel": "Numbers 33:41",
      "text": "Et profecti de monte Hor, castrametati sunt in Salmona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.42",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 42,
      "referenceLabel": "Numbers 33:42",
      "text": "Unde egressi, venerunt in Phunon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.43",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 43,
      "referenceLabel": "Numbers 33:43",
      "text": "Profectique de Phunon, castrametati sunt in Oboth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.44",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 44,
      "referenceLabel": "Numbers 33:44",
      "text": "Et de Oboth venerunt in Ijeabarim, quæ est in finibus Moabitarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.45",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 45,
      "referenceLabel": "Numbers 33:45",
      "text": "Profectique de Ijeabarim, fixere tentoria in Dibongad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.46",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 46,
      "referenceLabel": "Numbers 33:46",
      "text": "Unde egressi, castrametati sunt in Helmondeblathaim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.47",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 47,
      "referenceLabel": "Numbers 33:47",
      "text": "Egressique de Helmondeblathaim, venerunt ad montes Abarim contra Nabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.48",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 48,
      "referenceLabel": "Numbers 33:48",
      "text": "Profectique de montibus Abarim, transierunt ad campestria Moab, supra Jordanem, contra Jericho.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.49",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 49,
      "referenceLabel": "Numbers 33:49",
      "text": "Ibique castrametati sunt de Bethsimoth usque ad Abelsatim in planioribus locis Moabitarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.50",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 50,
      "referenceLabel": "Numbers 33:50",
      "text": "Ubi locutus est Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.51",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 51,
      "referenceLabel": "Numbers 33:51",
      "text": "Præcipe filiis Israël, et dic ad eos: Quando transieritis Jordanem, intrantes terram Chanaan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.52",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 52,
      "referenceLabel": "Numbers 33:52",
      "text": "disperdite cunctos habitatores terræ illius: confringite titulos, et statuas comminuite, atque omnia excelsa vastate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.53",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 53,
      "referenceLabel": "Numbers 33:53",
      "text": "mundantes terram, et habitantes in ea. Ego enim dedi vobis illam in possessionem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.54",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 54,
      "referenceLabel": "Numbers 33:54",
      "text": "quam dividetis vobis sorte. Pluribus dabitis latiorem, et paucis angustiorem. Singulis ut sors ceciderit, ita tribuetur hæreditas. Per tribus et familias possessio dividetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.55",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 55,
      "referenceLabel": "Numbers 33:55",
      "text": "Sin autem nolueritis interficere habitatores terræ: qui remanserint, erunt vobis quasi clavi in oculis, et lanceæ in lateribus, et adversabuntur vobis in terra habitationis vestræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.33.56",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 33,
      "verseNumber": 56,
      "referenceLabel": "Numbers 33:56",
      "text": "et quidquid illis cogitaveram facere, vobis faciam.",
      "paragraphStart": false
    }
  ]
}
