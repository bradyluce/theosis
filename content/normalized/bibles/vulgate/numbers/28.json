{
  "chapter": {
    "id": "vulgate:numbers.28",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 28,
    "referenceLabel": "Numbers 28",
    "summary": "Source text for Numbers 28 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.28.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Numbers 28:1",
      "text": "Dixit quoque Dominus ad Moysen:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.28.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Numbers 28:2",
      "text": "Præcipe filiis Israël, et dices ad eos: Oblationem meam et panes, et incensum odoris suavissimi offerte per tempora sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Numbers 28:3",
      "text": "Hæc sunt sacrificia quæ offerre debetis: agnos anniculos immaculatos duos quotidie in holocaustum sempiternum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Numbers 28:4",
      "text": "unum offeretis mane, et alterum ad vesperum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Numbers 28:5",
      "text": "decimam partem ephi similæ, quæ conspersa sit oleo purissimo, et habeat quartam partem hin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Numbers 28:6",
      "text": "Holocaustum juge est quod obtulistis in monte Sinai in odorem suavissimum incensi Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Numbers 28:7",
      "text": "Et libabitis vini quartam partem hin per agnos singulos in sanctuario Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Numbers 28:8",
      "text": "Alterumque agnum similiter offeretis ad vesperam juxta omnem ritum sacrificii matutini, et libamentorum ejus, oblationem suavissimi odoris Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Numbers 28:9",
      "text": "Die autem sabbati offeretis duos agnos anniculos immaculatos, et duas decimas similæ oleo conspersæ in sacrificio, et liba:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Numbers 28:10",
      "text": "quæ rite funduntur per singula sabbata in holocaustum sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Numbers 28:11",
      "text": "In calendis autem offeretis holocaustum Domino, vitulos de armento duos, arietem unum, agnos anniculos septem immaculatos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Numbers 28:12",
      "text": "et tres decimas similæ oleo conspersæ in sacrificio per singulos vitulos: et duas decimas similæ oleo conspersæ per singulos arietes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Numbers 28:13",
      "text": "et decimam decimæ similæ ex oleo in sacrificio per agnos singulos: holocaustum suavissimi odoris atque incensi est Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Numbers 28:14",
      "text": "Libamenta autem vini, quæ per singulas fundenda sunt victimas, ista erunt: media pars hin per singulos vitulos, tertia per arietem, quarta per agnum. Hoc erit holocaustum per omnes menses, qui sibi anno vertente succedunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Numbers 28:15",
      "text": "Hircus quoque offeretur Domino pro peccatis in holocaustum sempiternum cum libamentis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Numbers 28:16",
      "text": "Mense autem primo, quartadecima die mensis, Phase Domini erit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Numbers 28:17",
      "text": "et quintadecima die solemnitas: septem diebus vescentur azymis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Numbers 28:18",
      "text": "Quarum dies prima venerabilis et sancta erit: omne opus servile non facietis in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Numbers 28:19",
      "text": "Offeretisque incensum holocaustum Domino, vitulos de armento duos, arietem unum, agnos anniculos immaculatos septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Numbers 28:20",
      "text": "et sacrificia singulorum ex simila quæ conspersa sit oleo, tres decimas per singulos vitulos, et duas decimas per arietem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Numbers 28:21",
      "text": "et decimam decimæ per agnos singulos, id est, per septem agnos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Numbers 28:22",
      "text": "Et hircum pro peccato unum, ut expietur pro vobis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Numbers 28:23",
      "text": "præter holocaustum matutinum, quod semper offeretis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Numbers 28:24",
      "text": "Ita facietis per singulos dies septem dierum in fomitem ignis, et in odorem suavissimum Domino, qui surget de holocausto, et de libationibus singulorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Numbers 28:25",
      "text": "Dies quoque septimus celeberrimus et sanctus erit vobis: omne opus servile non facietis in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Numbers 28:26",
      "text": "Dies etiam primitivorum, quando offeretis novas fruges Domino, expletis hebdomadibus, venerabilis et sancta erit: omne opus servile non facietis in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Numbers 28:27",
      "text": "Offeretisque holocaustum in odorem suavissimum Domino, vitulos de armento duos, arietem unum, et agnos anniculos immaculatos septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Numbers 28:28",
      "text": "atque in sacrificiis eorum, similæ oleo conspersæ tres decimas per singulos vitulos, per arietes duas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 29,
      "referenceLabel": "Numbers 28:29",
      "text": "per agnos decimam decimæ, qui simul sunt agni septem. Hircum quoque,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 30,
      "referenceLabel": "Numbers 28:30",
      "text": "qui mactatur pro expiatione: præter holocaustum sempiternum et liba ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.28.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 28,
      "verseNumber": 31,
      "referenceLabel": "Numbers 28:31",
      "text": "Immaculata offeretis omnia cum libationibus suis.",
      "paragraphStart": false
    }
  ]
}
