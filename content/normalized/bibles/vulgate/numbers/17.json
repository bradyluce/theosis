{
  "chapter": {
    "id": "vulgate:numbers.17",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 17,
    "referenceLabel": "Numbers 17",
    "summary": "Source text for Numbers 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.17.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Numbers 17:1",
      "text": "Et locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.17.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Numbers 17:2",
      "text": "Loquere ad filios Israël, et accipe ab eis virgas singulas per cognationes suas, a cunctis principibus tribuum, virgas duodecim, et uniuscujusque nomen superscribes virgæ suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Numbers 17:3",
      "text": "Nomen autem Aaron erit in tribu Levi, et una virga cunctas seorsum familias continebit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Numbers 17:4",
      "text": "ponesque eas in tabernaculo fœderis coram testimonio, ubi loquar ad te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Numbers 17:5",
      "text": "Quem ex his elegero, germinabit virga ejus: et cohibebo a me querimonias filiorum Israël, quibus contra vos murmurant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Numbers 17:6",
      "text": "Locutusque est Moyses ad filios Israël: et dederunt ei omnes principes virgas per singulas tribus: fueruntque virgæ duodecim absque virga Aaron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Numbers 17:7",
      "text": "Quas cum posuisset Moyses coram Domino in tabernaculo testimonii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Numbers 17:8",
      "text": "sequenti die regressus invenit germinasse virgam Aaron in domo Levi: et turgentibus gemmis eruperant flores, qui, foliis dilatatis, in amygdalas deformati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Numbers 17:9",
      "text": "Protulit ergo Moyses omnes virgas de conspectu Domini ad cunctos filios Israël: videruntque, et receperunt singuli virgas suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Numbers 17:10",
      "text": "Dixitque Dominus ad Moysen: Refer virgam Aaron in tabernaculum testimonii, ut servetur ibi in signum rebellium filiorum Israël, et quiescant querelæ eorum a me, ne moriantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Numbers 17:11",
      "text": "Fecitque Moyses sicut præceperat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Numbers 17:12",
      "text": "Dixerunt autem filii Israël ad Moysen: Ecce consumpti sumus, omnes perivimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.17.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Numbers 17:13",
      "text": "Quicumque accedit ad tabernaculum Domini, moritur. Num usque ad internecionem cuncti delendi sumus?",
      "paragraphStart": false
    }
  ]
}
