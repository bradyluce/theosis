{
  "chapter": {
    "id": "vulgate:numbers.1",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 1,
    "referenceLabel": "Numbers 1",
    "summary": "Source text for Numbers 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.1.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Numbers 1:1",
      "text": "Locutusque est Dominus ad Moysen in deserto Sinai in tabernaculo fœderis, prima die mensis secundi, anno altero egressionis eorum ex Ægypto, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.1.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Numbers 1:2",
      "text": "Tollite summam universæ congregationis filiorum Israël per cognationes et domos suas, et nomina singulorum, quidquid sexus est masculini",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Numbers 1:3",
      "text": "a vigesimo anno et supra, omnium virorum fortium ex Israël, et numerabitis eos per turmas suas, tu et Aaron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Numbers 1:4",
      "text": "Eruntque vobiscum principes tribuum ac domorum in cognationibus suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Numbers 1:5",
      "text": "quorum ista sunt nomina: de Ruben, Elisur, filius Sedeur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Numbers 1:6",
      "text": "de Simeon, Salamiel filius Surisaddai;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Numbers 1:7",
      "text": "de Juda, Nahasson filius Aminadab;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Numbers 1:8",
      "text": "de Issachar, Nathanaël filius Suar;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Numbers 1:9",
      "text": "de Zabulon, Eliab filius Helon;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Numbers 1:10",
      "text": "filiorum autem Joseph, de Ephraim, Elisama filius Ammiud; de Manasse, Gamaliel filius Phadassur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Numbers 1:11",
      "text": "de Benjamin, Abidan filius Gedeonis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Numbers 1:12",
      "text": "de Dan, Ahiezer filius Ammisaddai;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Numbers 1:13",
      "text": "de Aser, Phegiel filius Ochran;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Numbers 1:14",
      "text": "de Gad, Eliasaph filius Duel;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Numbers 1:15",
      "text": "de Nephthali, Ahira filius Enan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Numbers 1:16",
      "text": "Hi nobilissimi principes multitudinis per tribus et cognationes suas, et capita exercitus Israël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Numbers 1:17",
      "text": "quos tulerunt Moyses et Aaron cum omni vulgi multitudine:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Numbers 1:18",
      "text": "et congregaverunt primo die mensis secundi, recensentes eos per cognationes, et domos, ac familias, et capita, et nomina singulorum a vigesimo anno et supra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Numbers 1:19",
      "text": "sicut præceperat Dominus Moysi. Numeratique sunt in deserto Sinai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Numbers 1:20",
      "text": "De Ruben primogenito Israëlis per generationes et familias ac domos suas, et nomina capitum singulorum, omne quod sexus est masculini a vigesimo anno et supra, procedentium ad bellum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Numbers 1:21",
      "text": "quadraginta sex millia quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Numbers 1:22",
      "text": "De filiis Simeon per generationes et familias ac domos cognationum suarum recensiti sunt per nomina et capita singulorum, omne quod sexus est masculini a vigesimo anno et supra, procedentium ad bellum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Numbers 1:23",
      "text": "quinquaginta novem millia trecenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Numbers 1:24",
      "text": "De filiis Gad per generationes et familias ac domos cognationum suarum recensiti sunt per nomina singulorum a viginti annis et supra, omnes qui ad bella procederent,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Numbers 1:25",
      "text": "quadraginta quinque millia sexcenti quinquaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Numbers 1:26",
      "text": "De filiis Juda per generationes et familias ac domos cognationum suarum, per nomina singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Numbers 1:27",
      "text": "recensiti sunt septuaginta quatuor millia sexcenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Numbers 1:28",
      "text": "De filiis Issachar, per generationes et familias ac domos cognationum suarum, per nomina singulorum a vigesimo anno et supra, omnes qui ad bella procederent,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Numbers 1:29",
      "text": "recensiti sunt quinquaginta quatuor millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Numbers 1:30",
      "text": "De filiis Zabulon per generationes et familias ac domos cognationum suarum recensiti sunt per nomina singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Numbers 1:31",
      "text": "quinquaginta septem millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Numbers 1:32",
      "text": "De filiis Joseph, filiorum Ephraim per generationes et familias ac domos cognationum suarum recensiti sunt per nomina singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Numbers 1:33",
      "text": "quadraginta millia quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Numbers 1:34",
      "text": "Porro filiorum Manasse per generationes et familias ac domos cognationum suarum recensiti sunt per nomina singulorum a viginti annis et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Numbers 1:35",
      "text": "triginta duo millia ducenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Numbers 1:36",
      "text": "De filiis Benjamin per generationes et familias ac domos cognationum suarum recensiti sunt nominibus singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.37",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Numbers 1:37",
      "text": "triginta quinque millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.38",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Numbers 1:38",
      "text": "De filiis Dan per generationes et familias ac domos cognationum suarum recensiti sunt nominibus singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.39",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Numbers 1:39",
      "text": "sexaginta duo millia septingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.40",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Numbers 1:40",
      "text": "De filiis Aser per generationes et familias ac domos cognationum suarum recensiti sunt per nomina singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.41",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "Numbers 1:41",
      "text": "quadraginta millia et mille quingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.42",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "Numbers 1:42",
      "text": "De filiis Nephthali per generationes et familias ac domos cognationum suarum recensiti sunt nominibus singulorum a vigesimo anno et supra, omnes qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.43",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "Numbers 1:43",
      "text": "quinquaginta tria millia quadringenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.44",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "Numbers 1:44",
      "text": "Hi sunt, quos numeraverunt Moyses et Aaron, et duodecim principes Israël, singulos per domos cognationum suarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.45",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "Numbers 1:45",
      "text": "Fueruntque omnis numerus filiorum Israël per domos et familias suas a vigesimo anno et supra, qui poterant ad bella procedere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.46",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "Numbers 1:46",
      "text": "sexcenta tria millia virorum quingenti quinquaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.47",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "Numbers 1:47",
      "text": "Levitæ autem in tribu familiarum suarum non sunt numerati cum eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.48",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "Numbers 1:48",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.49",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "Numbers 1:49",
      "text": "Tribum Levi noli numerare, neque pones summam eorum cum filiis Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.50",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "Numbers 1:50",
      "text": "sed constitue eos super tabernaculum testimonii et cuncta vasa ejus, et quidquid ad cæremonias pertinet. Ipsi portabunt tabernaculum et omnia utensilia ejus: et erunt in ministerio, ac per gyrum tabernaculi metabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.51",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "Numbers 1:51",
      "text": "Cum proficiscendum fuerit, deponent Levitæ tabernaculum; cum castrametandum, erigent. Quisquis externorum accesserit, occidetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.52",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "Numbers 1:52",
      "text": "Metabuntur autem castra filii Israël unusquisque per turmas et cuneos atque exercitum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.53",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "Numbers 1:53",
      "text": "Porro Levitæ per gyrum tabernaculi figent tentoria, ne fiat indignatio super multitudinem filiorum Israël, et excubabunt in custodiis tabernaculi testimonii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.1.54",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "Numbers 1:54",
      "text": "Fecerunt ergo filii Israël juxta omnia quæ præceperat Dominus Moysi.",
      "paragraphStart": false
    }
  ]
}
