{
  "chapter": {
    "id": "vulgate:numbers.13",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 13,
    "referenceLabel": "Numbers 13",
    "summary": "Source text for Numbers 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.13.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Numbers 13:1",
      "text": "Profectusque est populus de Haseroth, fixis tentoriis in deserto Pharan.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.13.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Numbers 13:2",
      "text": "Ibique locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Numbers 13:3",
      "text": "Mitte viros, qui considerent terram Chanaan, quam daturus sum filiis Israël, singulos de singulis tribubus, ex principibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Numbers 13:4",
      "text": "Fecit Moyses quod Dominus imperaverat, de deserto Pharan mittens principes viros, quorum ista sunt nomina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Numbers 13:5",
      "text": "De tribu Ruben, Sammua filium Zechur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Numbers 13:6",
      "text": "De tribu Simeon, Saphat filium Huri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Numbers 13:7",
      "text": "De tribu Juda, Caleb filium Jephone.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Numbers 13:8",
      "text": "De tribu Issachar, Igal filium Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Numbers 13:9",
      "text": "De tribu Ephraim, Osee filium Nun.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Numbers 13:10",
      "text": "De tribu Benjamin, Phalti filium Raphu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Numbers 13:11",
      "text": "De tribu Zabulon, Geddiel filium Sodi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Numbers 13:12",
      "text": "De tribu Joseph, sceptri Manasse, Gaddi filium Susi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Numbers 13:13",
      "text": "De tribu Dan, Ammiel filium Gemalli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Numbers 13:14",
      "text": "De tribu Aser, Sthur filium Michaël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Numbers 13:15",
      "text": "De tribu Nephthali, Nahabi filium Vapsi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Numbers 13:16",
      "text": "De tribu Gad, Guel filium Machi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Numbers 13:17",
      "text": "Hæc sunt nomina virorum, quos misit Moyses ad considerandam terram: vocavitque Osee filium Nun, Josue.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Numbers 13:18",
      "text": "Misit ergo eos Moyses ad considerandam terram Chanaan, et dixit ad eos: Ascendite per meridianam plagam. Cumque veneritis ad montes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Numbers 13:19",
      "text": "considerate terram, qualis sit: et populum qui habitator est ejus, utrum fortis sit an infirmus: si pauci numero an plures:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Numbers 13:20",
      "text": "ipsa terra, bona an mala: urbes quales, muratæ an absque muris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Numbers 13:21",
      "text": "humus, pinguis an sterilis, nemorosa an absque arboribus. Confortamini, et afferte nobis de fructibus terræ. Erat autem tempus quando jam præcoquæ uvæ vesci possunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Numbers 13:22",
      "text": "Cumque ascendissent, exploraverunt terram a deserto Sin, usque Rohob intrantibus Emath.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Numbers 13:23",
      "text": "Ascenderuntque ad meridiem, et venerunt in Hebron, ubi erant Achiman et Sisai et Tholmai filii Enac: nam Hebron septem annis ante Tanim urbem Ægypti condita est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Numbers 13:24",
      "text": "Pergentesque usque ad Torrentem botri, absciderunt palmitem cum uva sua, quem portaverunt in vecte duo viri. De malis quoque granatis et de ficis loci illius tulerunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Numbers 13:25",
      "text": "qui appellatus est Nehelescol, id est Torrens botri, eo quod botrum portassent inde filii Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Numbers 13:26",
      "text": "Reversique exploratores terræ post quadraginta dies, omni regione circuita,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Numbers 13:27",
      "text": "venerunt ad Moysen et Aaron et ad omnem cœtum filiorum Israël in desertum Pharan, quod est in Cades. Locutique eis et omni multitudini ostenderunt fructus terræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Numbers 13:28",
      "text": "et narraverunt, dicentes: Venimus in terram, ad quam misisti nos, quæ revera fluit lacte et melle, ut ex his fructibus cognosci potest:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Numbers 13:29",
      "text": "sed cultores fortissimos habet, et urbes grandes atque muratas. Stirpem Enac vidimus ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Numbers 13:30",
      "text": "Amalec habitat in meridie, Hethæus et Jebusæus et Amorrhæus in montanis: Chananæus vero moratur juxta mare et circa fluenta Jordanis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Numbers 13:31",
      "text": "Inter hæc Caleb compescens murmur populi, qui oriebatur contra Moysen, ait: Ascendamus, et possideamus terram, quoniam poterimus obtinere eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Numbers 13:32",
      "text": "Alii vero, qui fuerant cum eo, dicebant: Nequaquam ad hunc populum valemus ascendere, quia fortior nobis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Numbers 13:33",
      "text": "Detraxeruntque terræ, quam inspexerant, apud filios Israël, dicentes: Terra, quam lustravimus, devorat habitatores suos: populus, quem aspeximus, proceræ staturæ est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.13.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Numbers 13:34",
      "text": "Ibi vidimus monstra quædam filiorum Enac de genere giganteo: quibus comparati, quasi locustæ videbamur.",
      "paragraphStart": false
    }
  ]
}
