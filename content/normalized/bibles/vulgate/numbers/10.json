{
  "chapter": {
    "id": "vulgate:numbers.10",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 10,
    "referenceLabel": "Numbers 10",
    "summary": "Source text for Numbers 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.10.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Numbers 10:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.10.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Numbers 10:2",
      "text": "Fac tibi duas tubas argenteas ductiles, quibus convocare possis multitudinem quando movenda sunt castra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Numbers 10:3",
      "text": "Cumque increpueris tubis, congregabitur ad te omnis turba ad ostium tabernaculi fœderis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Numbers 10:4",
      "text": "Si semel clangueris, venient ad te principes, et capita multitudinis Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Numbers 10:5",
      "text": "Si autem prolixior atque concisus clangor increpuerit, movebunt castra primi qui sunt ad orientalem plagam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Numbers 10:6",
      "text": "In secundo autem sonitu et pari ululatu tubæ, levabunt tentoria qui habitant ad meridiem; et juxta hunc modum reliqui facient, ululantibus tubis in profectionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Numbers 10:7",
      "text": "Quando autem congregandus est populus, simplex tubarum clangor erit, et non concise ululabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Numbers 10:8",
      "text": "Filii autem Aaron sacerdotes clangent tubis: eritque hoc legitimum sempiternum in generationibus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Numbers 10:9",
      "text": "Si exieritis ad bellum de terra vestra contra hostes qui dimicant adversum vos, clangetis ululantibus tubis, et erit recordatio vestri coram Domino Deo vestro, ut eruamini de manibus inimicorum vestrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Numbers 10:10",
      "text": "Siquando habebitis epulum, et dies festos, et calendas, canetis tubis super holocaustis, et pacificis victimis, ut sint vobis in recordationem Dei vestri. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Numbers 10:11",
      "text": "Anno secundo, mense secundo, vigesima die mensis, elevata est nubes de tabernaculo fœderis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Numbers 10:12",
      "text": "profectique sunt filii Israël per turmas suas de deserto Sinai, et recubuit nubes in solitudine Pharan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Numbers 10:13",
      "text": "Moveruntque castra primi juxta imperium Domini in manu Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Numbers 10:14",
      "text": "Filii Juda per turmas suas: quorum princeps erat Nahasson filius Aminadab.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Numbers 10:15",
      "text": "In tribu filiorum Issachar fuit princeps Nathanaël filius Suar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Numbers 10:16",
      "text": "In tribu Zabulon erat princeps Eliab filius Helon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Numbers 10:17",
      "text": "Depositumque est tabernaculum, quod portantes egressi sunt filii Gerson et Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Numbers 10:18",
      "text": "Profectique sunt et filii Ruben, per turmas et ordinem suum: quorum princeps erat Helisur filius Sedeur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Numbers 10:19",
      "text": "In tribu autem filiorum Simeon, princeps fuit Salamiel filius Surisaddai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Numbers 10:20",
      "text": "Porro in tribu Gad erat princeps Eliasaph filius Duel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Numbers 10:21",
      "text": "Profectique sunt et Caathitæ portantes sanctuarium. Tamdiu tabernaculum portabatur, donec venirent ad erectionis locum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Numbers 10:22",
      "text": "Moverunt castra et filii Ephraim per turmas suas, in quorum exercitu princeps erat Elisama filius Ammiud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Numbers 10:23",
      "text": "In tribu autem filiorum Manasse princeps fuit Gamaliel filius Phadassur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Numbers 10:24",
      "text": "Et in tribu Benjamin erat dux Abidan filius Gedeonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Numbers 10:25",
      "text": "Novissimi castrorum omnium profecti sunt filii Dan per turmas suas, in quorum exercitu princeps fuit Ahiezer filius Ammisaddai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Numbers 10:26",
      "text": "In tribu autem filiorum Aser erat princeps Phegiel filius Ochran.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Numbers 10:27",
      "text": "Et in tribu filiorum Nephthali princeps fuit Ahira filius Enan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Numbers 10:28",
      "text": "Hæc sunt castra, et profectiones filiorum Israël per turmas suas quando egrediebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Numbers 10:29",
      "text": "Dixitque Moyses Hobab filio Raguel Madianitæ, cognato suo: Proficiscimur ad locum quem Dominus daturus est nobis: veni nobiscum, ut benefaciamus tibi, quia Dominus bona promisit Israëli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Numbers 10:30",
      "text": "Cui ille respondit: Non vadam tecum, sed revertar in terram meam, in qua natus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Numbers 10:31",
      "text": "Et ille: Noli, inquit, nos relinquere: tu enim nosti in quibus locis per desertum castra ponere debeamus, et eris ductor noster.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Numbers 10:32",
      "text": "Cumque nobiscum veneris, quidquid optimum fuerit ex opibus, quas nobis traditurus est Dominus, dabimus tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Numbers 10:33",
      "text": "Profecti sunt ergo de monte Domini viam trium dierum, arcaque fœderis Domini præcedebat eos, per dies tres providens castrorum locum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Numbers 10:34",
      "text": "Nubes quoque Domini super eos erat per diem cum incederent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Numbers 10:35",
      "text": "Cumque elevaretur arca, dicebat Moyses: Surge, Domine, et dissipentur inimici tui, et fugiant qui oderunt te, a facie tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.10.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Numbers 10:36",
      "text": "Cum autem deponeretur, aiebat: Revertere, Domine, ad multitudinem exercitus Israël.",
      "paragraphStart": false
    }
  ]
}
