{
  "chapter": {
    "id": "vulgate:numbers.34",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 34,
    "referenceLabel": "Numbers 34",
    "summary": "Source text for Numbers 34 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.34.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Numbers 34:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.34.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Numbers 34:2",
      "text": "Præcipe filiis Israël, et dices ad eos: Cum ingressi fueritis terram Chanaan, et in possessionem vobis sorte ceciderit, his finibus terminabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Numbers 34:3",
      "text": "Pars meridiana incipiet a solitudine Sin, quæ est juxta Edom: et habebit terminos contra orientem mare salsissimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Numbers 34:4",
      "text": "Qui circuibunt australem plagam per ascensum Scorpionis, ita ut transeant in Senna, et perveniant a meridie usque ad Cadesbarne, unde egredientur confinia ad villam nomine Adar, et tendent usque ad Asemona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Numbers 34:5",
      "text": "Ibitque per gyrum terminus ab Asemona usque ad torrentem Ægypti, et maris magni littore finietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Numbers 34:6",
      "text": "Plaga autem occidentalis a mari magno incipiet, et ipso fine claudetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Numbers 34:7",
      "text": "Porro ad septentrionalem plagam a mari magno termini incipient, pervenientes usque ad montem altissimum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Numbers 34:8",
      "text": "a quo venient in Emath usque ad terminos Sedada:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Numbers 34:9",
      "text": "ibuntque confinia usque ad Zephrona, et villam Enan. Hi erunt termini in parte aquilonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Numbers 34:10",
      "text": "Inde metabuntur fines contra orientalem plagam de villa Enan usque Sephama,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Numbers 34:11",
      "text": "et de Sephama descendent termini in Rebla contra fontem Daphnim: inde pervenient contra orientem ad mare Cenereth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Numbers 34:12",
      "text": "et tendent usque ad Jordanem, et ad ultimum salsissimo claudentur mari. Hanc habebitis terram per fines suos in circuitu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Numbers 34:13",
      "text": "Præcepitque Moyses filiis Israël, dicens: Hæc erit terra, quam possidebitis sorte, et quam jussit Dominus dari novem tribubus, et dimidiæ tribui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Numbers 34:14",
      "text": "Tribus enim filiorum Ruben per familias suas, et tribus filiorum Gad juxta cognationum numerum, media quoque tribus Manasse,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Numbers 34:15",
      "text": "id est, duæ semis tribus, acceperunt partem suam trans Jordanem contra Jericho ad orientalem plagam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Numbers 34:16",
      "text": "Et ait Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Numbers 34:17",
      "text": "Hæc sunt nomina virorum qui terram vobis divident, Eleazar sacerdos, et Josue filius Nun,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Numbers 34:18",
      "text": "et singuli principes de tribubus singulis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Numbers 34:19",
      "text": "quorum ista sunt vocabula. De tribu Juda, Caleb filius Jephone.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Numbers 34:20",
      "text": "De tribu Simeon, Samuel filius Ammiud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Numbers 34:21",
      "text": "De tribu Benjamin, Elidad filius Chaselon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Numbers 34:22",
      "text": "De tribu filiorum Dan, Bocci filius Jogli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Numbers 34:23",
      "text": "Filiorum Joseph de tribu Manasse, Hanniel filius Ephod.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Numbers 34:24",
      "text": "De tribu Ephraim, Camuel filius Sephthan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Numbers 34:25",
      "text": "De tribu Zabulon, Elisaphan filius Pharnach.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Numbers 34:26",
      "text": "De tribu Issachar, dux Phaltiel filius Ozan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Numbers 34:27",
      "text": "De tribu Aser, Ahiud filius Salomi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Numbers 34:28",
      "text": "De tribu Nephthali, Phedaël filius Ammiud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.34.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Numbers 34:29",
      "text": "Hi sunt, quibus præcepit Dominus ut dividerent filiis Israël terram Chanaan.",
      "paragraphStart": false
    }
  ]
}
