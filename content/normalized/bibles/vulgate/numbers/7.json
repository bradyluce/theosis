{
  "chapter": {
    "id": "vulgate:numbers.7",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 7,
    "referenceLabel": "Numbers 7",
    "summary": "Source text for Numbers 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.7.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Numbers 7:1",
      "text": "Factum est autem in die qua complevit Moyses tabernaculum, et erexit illud, unxitque et sanctificavit cum omnibus vasis suis, altare similiter et omnia vasa ejus:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.7.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Numbers 7:2",
      "text": "obtulerunt principes Israël et capita familiarum, qui erant per singulas tribus, præfectique eorum, qui numerati fuerant,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Numbers 7:3",
      "text": "munera coram Domino sex plaustra tecta cum duodecim bobus. Unum plaustrum obtulere duo duces, et unum bovem singuli, obtuleruntque ea in conspectu tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Numbers 7:4",
      "text": "Ait autem Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Numbers 7:5",
      "text": "Suscipe ab eis ut serviant in ministerio tabernaculi, et trades ea Levitis juxta ordinem ministerii sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Numbers 7:6",
      "text": "Itaque cum suscepisset Moyses plaustra et boves, tradidit eos Levitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Numbers 7:7",
      "text": "Duo plaustra et quatuor boves dedit filiis Gerson, juxta id quod habebant necessarium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Numbers 7:8",
      "text": "Quatuor alia plaustra et octo boves dedit filiis Merari secundum officia et cultum suum, sub manu Ithamar filii Aaron sacerdotis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Numbers 7:9",
      "text": "Filiis autem Caath non dedit plaustra et boves: quia in sanctuario serviunt, et onera propriis portant humeris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Numbers 7:10",
      "text": "Igitur obtulerunt duces in dedicationem altaris, die qua unctum est, oblationem suam ante altare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Numbers 7:11",
      "text": "Dixitque Dominus ad Moysen: Singuli duces per singulos dies offerant munera in dedicationem altaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Numbers 7:12",
      "text": "Primo die obtulit oblationem suam Nahasson filius Aminadab de tribu Juda:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Numbers 7:13",
      "text": "fueruntque in ea acetabulum argenteum pondo centum triginta siclorum, phiala argentea habens septuaginta siclos, juxta pondus sanctuarii, utrumque plenum simila conspersa oleo in sacrificium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Numbers 7:14",
      "text": "mortariolum ex decem siclis aureis plenum incenso:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Numbers 7:15",
      "text": "bovem de armento, et arietem, et agnum anniculum in holocaustum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Numbers 7:16",
      "text": "hircumque pro peccato:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Numbers 7:17",
      "text": "et in sacrificio pacificorum boves duos, arietes quinque, hircos quinque, agnos anniculos quinque. Hæc est oblatio Nahasson filii Aminadab.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Numbers 7:18",
      "text": "Secundo die obtulit Nathanaël filius Suar, dux de tribu Issachar,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.7.19",
