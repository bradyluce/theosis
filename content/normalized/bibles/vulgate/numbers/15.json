{
  "chapter": {
    "id": "vulgate:numbers.15",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 15,
    "referenceLabel": "Numbers 15",
    "summary": "Source text for Numbers 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.15.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Numbers 15:1",
      "text": "Locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.15.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Numbers 15:2",
      "text": "Loquere ad filios Israël, et dices ad eos: Cum ingressi fueritis terram habitationis vestræ, quam ego dabo vobis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Numbers 15:3",
      "text": "et feceritis oblationem Domino in holocaustum, aut victimam, vota solventes, vel sponte offerentes munera, aut in solemnitatibus vestris adolentes odorem suavitatis Domino, de bobus sive de ovibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Numbers 15:4",
      "text": "offeret quicumque immolaverit victimam, sacrificium similæ, decimam partem ephi, conspersæ oleo, quod mensuram habebit quartam partem hin:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Numbers 15:5",
      "text": "et vinum ad liba fundenda ejusdem mensuræ dabit in holocaustum sive in victimam. Per agnos singulos",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Numbers 15:6",
      "text": "et arietes erit sacrificium similæ duarum decimarum, quæ conspersa sit oleo tertiæ partis hin:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Numbers 15:7",
      "text": "et vinum ad libamentum tertiæ partis ejusdem mensuræ offeret in odorem suavitatis Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Numbers 15:8",
      "text": "Quando vero de bobus feceris holocaustum aut hostiam, ut impleas votum vel pacificas victimas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Numbers 15:9",
      "text": "dabis per singulos boves similæ tres decimas conspersæ oleo, quod habeat medium mensuræ hin:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Numbers 15:10",
      "text": "et vinum ad liba fundenda ejusdem mensuræ in oblationem suavissimi odoris Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Numbers 15:11",
      "text": "Sic facies",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Numbers 15:12",
      "text": "per singulos boves et arietis et agnos et hædos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Numbers 15:13",
      "text": "Tam indigenæ quam peregrini",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Numbers 15:14",
      "text": "eodem ritu offerent sacrificia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Numbers 15:15",
      "text": "Unum præceptum erit atque judicium tam vobis quam advenis terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Numbers 15:16",
      "text": "Locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Numbers 15:17",
      "text": "Loquere filiis Israël, et dices ad eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Numbers 15:18",
      "text": "Cum veneritis in terram, quam dabo vobis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Numbers 15:19",
      "text": "et comederitis de panibus regionis illius, separabitis primitias Domino",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Numbers 15:20",
      "text": "de cibis vestris. Sicut de areis primitias separatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Numbers 15:21",
      "text": "ita et de pulmentis dabitis primitiva Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Numbers 15:22",
      "text": "Quod si per ignorantiam præterieritis quidquam horum, quæ locutus est Dominus ad Moysen,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Numbers 15:23",
      "text": "et mandavit per eum ad vos, a die qua cœpit jubere et ultra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Numbers 15:24",
      "text": "oblitaque fuerit facere multitudo: offeret vitulum de armento, holocaustum in odorem suavissimum Domino, et sacrificum ejus ac liba, ut cæremoniæ postulant, hircumque pro peccato:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Numbers 15:25",
      "text": "et rogabit sacerdos pro omni multitudine filiorum Israël, et dimittetur eis, quoniam non sponte peccaverunt, nihilominus offerentes incensum Domino pro se et pro peccato atque errore suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Numbers 15:26",
      "text": "et dimittetur universæ plebi filiorum Israël, et advenis qui peregrinantur inter eos: quoniam culpa est omnis populi per ignorantiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Numbers 15:27",
      "text": "Quod si anima una nesciens peccaverit, offeret capram anniculam pro peccato suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Numbers 15:28",
      "text": "et deprecabitur pro ea sacerdos, quod inscia peccaverit coram Domino: impetrabitque ei veniam, et dimittetur illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Numbers 15:29",
      "text": "Tam indigenis quam advenis una lex erit omnium, qui peccaverint ignorantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Numbers 15:30",
      "text": "Anima vero, quæ per superbiam aliquid commiserit, sive civis sit ille, sive peregrinus (quoniam adversus Dominum rebellis fuit), peribit de populo suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Numbers 15:31",
      "text": "verbum enim Domini contempsit, et præceptum illius fecit irritum: idcirco delebitur, et portabit iniquitatem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Numbers 15:32",
      "text": "Factum est autem, cum essent filii Israël in solitudine, et invenissent hominem colligentem ligna in die sabbati,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Numbers 15:33",
      "text": "obtulerunt eum Moysi et Aaron et universæ multitudini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Numbers 15:34",
      "text": "Qui recluserunt eum in carcerem, nescientes quid super eo facere deberent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Numbers 15:35",
      "text": "Dixitque Dominus ad Moysen: Morte moriatur homo iste: obruat eum lapidibus omnis turba extra castra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Numbers 15:36",
      "text": "Cumque eduxissent eum foras, obruerunt lapidibus, et mortuus est, sicut præceperat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.37",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Numbers 15:37",
      "text": "Dixit quoque Dominus ad Moysen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.38",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Numbers 15:38",
      "text": "Loquere filiis Israël, et dices ad eos ut faciant sibi fimbrias per angulos palliorum, ponentes in eis vittas hyacinthinas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.39",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Numbers 15:39",
      "text": "quas cum viderint, recordentur omnium mandatorum Domini, nec sequantur cogitationes suas et oculos per res varias fornicantes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.40",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "Numbers 15:40",
      "text": "sed magis memores præceptorum Domini faciant ea, sintque sancti Deo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.15.41",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 15,
      "verseNumber": 41,
      "referenceLabel": "Numbers 15:41",
      "text": "Ego Dominus Deus vester, qui eduxi vos de terra Ægypti, ut essem Deus vester.",
      "paragraphStart": false
    }
  ]
}
