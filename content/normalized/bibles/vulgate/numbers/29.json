{
  "chapter": {
    "id": "vulgate:numbers.29",
    "translationId": "vulgate",
    "bookSlug": "numbers",
    "chapterNumber": 29,
    "referenceLabel": "Numbers 29",
    "summary": "Source text for Numbers 29 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:numbers.29.1",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Numbers 29:1",
      "text": "Mensis etiam septimi prima dies venerabilis et sancta erit vobis. Omne opus servile non facietis in ea, quia dies clangoris est et tubarum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:numbers.29.2",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Numbers 29:2",
      "text": "Offeretisque holocaustum in odorem suavissimum Domino, vitulum de armento unum, arietem unum, et agnos anniculos immaculatos septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.3",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Numbers 29:3",
      "text": "et in sacrificiis eorum, similæ oleo conspersæ tres decimas per singulos vitulos, duas decimas per arietem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.4",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Numbers 29:4",
      "text": "unam decimam per agnum, qui simul sunt agni septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.5",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Numbers 29:5",
      "text": "et hircum pro peccato, qui offertur in expiationem populi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.6",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Numbers 29:6",
      "text": "præter holocaustum calendarum cum sacrificiis suis, et holocaustum sempiternum cum libationibus solitis: eisdem cæremoniis offeretis in odorem suavissimum incensum Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.7",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Numbers 29:7",
      "text": "Decima quoque dies mensis hujus septimi erit vobis sancta atque venerabilis, et affligetis animas vestras: omne opus servile non facietis in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.8",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Numbers 29:8",
      "text": "Offeretisque holocaustum Domino in odorem suavissimum, vitulum de armento unum, arietem unum, agnos anniculos immaculatos septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.9",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Numbers 29:9",
      "text": "et in sacrificiis eorum similæ oleo conspersæ tres decimas per singulos vitulos, duas decimas per arietem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.10",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Numbers 29:10",
      "text": "decimam decimæ per agnos singulos, qui sunt simul agni septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.11",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Numbers 29:11",
      "text": "et hircum pro peccato, absque his quæ offerri pro delicto solent in expiationem, et holocaustum sempiternum, cum sacrificio et libaminibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.12",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Numbers 29:12",
      "text": "Quintadecima vero die mensis septimi, quæ vobis sancta erit atque venerabilis, omne opus servile non facietis in ea, sed celebrabitis solemnitatem Domino septem diebus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.13",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Numbers 29:13",
      "text": "Offeretisque holocaustum in odorem suavissimum Domino, vitulos de armento tredecim, arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.14",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Numbers 29:14",
      "text": "et in libamentis eorum, similæ oleo conspersæ tres decimas per vitulos singulos, qui sunt simul vituli tredecim, et duas decimas arieti uno, id est, simul arietibus duobus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.15",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Numbers 29:15",
      "text": "et decimam decimæ agnis singulis, qui sunt simul agni quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.16",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Numbers 29:16",
      "text": "et hircum pro peccato, absque holocausto sempiterno, et sacrificio, et libamine ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.17",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Numbers 29:17",
      "text": "In die altero offeretis vitulos de armento duodecim, arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.18",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Numbers 29:18",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.19",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Numbers 29:19",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque et libamine ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.20",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Numbers 29:20",
      "text": "Die tertio offeretis vitulos undecim, arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.21",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Numbers 29:21",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.22",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Numbers 29:22",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque et libamine ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.23",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Numbers 29:23",
      "text": "Die quarto offeretis vitulos decem, arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.24",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Numbers 29:24",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.25",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Numbers 29:25",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque ejus et libamine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.26",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Numbers 29:26",
      "text": "Die quinto offeretis vitulos novem, arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.27",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Numbers 29:27",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.28",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 28,
      "referenceLabel": "Numbers 29:28",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque ejus et libamine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.29",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 29,
      "referenceLabel": "Numbers 29:29",
      "text": "Die sexto offeretis vitulos octo, arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.30",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 30,
      "referenceLabel": "Numbers 29:30",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.31",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 31,
      "referenceLabel": "Numbers 29:31",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque ejus et libamine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.32",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 32,
      "referenceLabel": "Numbers 29:32",
      "text": "Die septimo offeretis vitulos septem, et arietes duos, agnos anniculos immaculatos quatuordecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.33",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 33,
      "referenceLabel": "Numbers 29:33",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.34",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 34,
      "referenceLabel": "Numbers 29:34",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque ejus et libamine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.35",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 35,
      "referenceLabel": "Numbers 29:35",
      "text": "Die octavo, qui est celeberrimus, omne opus servile non facietis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.36",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 36,
      "referenceLabel": "Numbers 29:36",
      "text": "offerentes holocaustum in odorem suavissimum Domino, vitulum unum, arietem unum, agnos anniculos immaculatos septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.37",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 37,
      "referenceLabel": "Numbers 29:37",
      "text": "sacrificiaque et libamina singulorum, per vitulos, et arietes, et agnos rite celebrabitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.38",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 38,
      "referenceLabel": "Numbers 29:38",
      "text": "et hircum pro peccato, absque holocausto sempiterno, sacrificioque ejus et libamine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:numbers.29.39",
      "translationId": "vulgate",
      "bookSlug": "numbers",
      "chapterNumber": 29,
      "verseNumber": 39,
      "referenceLabel": "Numbers 29:39",
      "text": "Hæc offeretis Domino in solemnitatibus vestris: præter vota et oblationes spontaneas in holocausto, in sacrificio, in libamine, et in hostiis pacificis.",
      "paragraphStart": false
    }
  ]
}
