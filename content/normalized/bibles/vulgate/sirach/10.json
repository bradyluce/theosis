{
  "chapter": {
    "id": "vulgate:sirach.10",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 10,
    "referenceLabel": "Sirach 10",
    "summary": "Source text for Sirach 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.10.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Sirach 10:1",
      "text": "Judex sapiens judicabit populum suum, et principatus sensati stabilis erit.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.10.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Sirach 10:2",
      "text": "Secundum judicem populi, sic et ministri ejus: et qualis rector est civitatis, tales et inhabitantes in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Sirach 10:3",
      "text": "Rex insipiens perdet populum suum: et civitates inhabitabuntur per sensum potentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Sirach 10:4",
      "text": "In manu Dei potestas terræ: et utilem rectorem suscitabit in tempus super illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Sirach 10:5",
      "text": "In manu Dei prosperitas hominis, et super faciem scribæ imponet honorem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Sirach 10:6",
      "text": "Omnis injuriæ proximi ne memineris, et nihil agas in operibus injuriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Sirach 10:7",
      "text": "Odibilis coram Deo est et hominibus superbia, et execrabilis omnis iniquitas gentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Sirach 10:8",
      "text": "Regnum a gente in gentem transfertur propter injustitias, et injurias, et contumelias, et diversos dolos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Sirach 10:9",
      "text": "Avaro autem nihil est scelestius. Quid superbit terra et cinis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Sirach 10:10",
      "text": "Nihil est iniquius quam amare pecuniam: hic enim et animam suam venalem habet, quoniam in vita sua projecit intima sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Sirach 10:11",
      "text": "Omnis potentatus brevis vita; languor prolixior gravat medicum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Sirach 10:12",
      "text": "Brevem languorem præcidit medicus: sic et rex hodie est, et cras morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Sirach 10:13",
      "text": "Cum enim morietur homo, hæreditabit serpentes, et bestias, et vermes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Sirach 10:14",
      "text": "Initium superbiæ hominis apostatare a Deo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Sirach 10:15",
      "text": "quoniam ab eo qui fecit illum recessit cor ejus, quoniam initium omnis peccati est superbia. Qui tenuerit illam adimplebitur maledictis, et subvertet eum in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Sirach 10:16",
      "text": "Propterea exhonoravit Dominus conventus malorum, et destruxit eos usque in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Sirach 10:17",
      "text": "Sedes ducum superborum destruxit Deus, et sedere fecit mites pro eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Sirach 10:18",
      "text": "Radices gentium superbarum arefecit Deus, et plantavit humiles ex ipsis gentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Sirach 10:19",
      "text": "Terras gentium evertit Dominus, et perdidit eas usque ad fundamentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Sirach 10:20",
      "text": "Arefecit ex ipsis, et disperdidit eos, et cessare fecit memoriam eorum a terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Sirach 10:21",
      "text": "Memoria superborum perdidit Deus, et reliquit memoriam humilium sensu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Sirach 10:22",
      "text": "Non est creata hominibus superbia, neque iracundia nationi mulierum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Sirach 10:23",
      "text": "Semen hominum honorabitur hoc, quod timet Deum: semen autem hoc exhonorabitur, quod præterit mandata Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Sirach 10:24",
      "text": "In medio fratrum rector illorum in honore: et qui timent Dominum erunt in oculis illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Sirach 10:25",
      "text": "Gloria divitum, honoratorum, et pauperum, timor Dei est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Sirach 10:26",
      "text": "Noli despicere hominem justum pauperem, et noli magnificare virum peccatorem divitem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Sirach 10:27",
      "text": "Magnus, et judex, et potens est in honore: et non est major illo qui timet Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Sirach 10:28",
      "text": "Servo sensato liberi servient: et vir prudens et disciplinatus non murmurabit correptus, et inscius non honorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Sirach 10:29",
      "text": "Noli extollere te in faciendo opere tuo, et noli cunctari in tempore angustiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Sirach 10:30",
      "text": "Melior est qui operatur et abundat in omnibus, quam qui gloriatur et eget pane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Sirach 10:31",
      "text": "Fili, in mansuetudine serva animam tuam, et da illi honorem secundum meritum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Sirach 10:32",
      "text": "Peccantem in animam suam quis justificabit? et quis honorificabit exhonorantem animam suam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Sirach 10:33",
      "text": "Pauper gloriatur per disciplinam et timorem suum: et est homo qui honorificatur propter substantiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.10.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Sirach 10:34",
      "text": "Qui autem gloriatur in paupertate, quanto magis in substantia! et qui gloriatur in substantia, paupertatem vereatur.",
      "paragraphStart": false
    }
  ]
}
