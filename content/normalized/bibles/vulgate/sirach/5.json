{
  "chapter": {
    "id": "vulgate:sirach.5",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 5,
    "referenceLabel": "Sirach 5",
    "summary": "Source text for Sirach 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.5.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Sirach 5:1",
      "text": "Noli attendere ad possessiones iniquas, et ne dixeris: Est mihi sufficiens vita: nihil enim proderit in tempore vindictæ et obductionis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.5.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Sirach 5:2",
      "text": "Ne sequaris in fortitudine tua concupiscentiam cordis tui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Sirach 5:3",
      "text": "et ne dixeris: Quomodo potui? aut, Quis me subjiciet propter facta mea? Deus enim vindicans vindicabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Sirach 5:4",
      "text": "Ne dixeris: Peccavi: et quid mihi accidit triste? Altissimus enim est patiens redditor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Sirach 5:5",
      "text": "De propitiatio peccato noli esse sine metu, neque adjicias peccatum super peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Sirach 5:6",
      "text": "Et ne dicas: Miseratio Domini magna est, multitudinis peccatorum meorum miserebitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Sirach 5:7",
      "text": "misericordia enim et ira ab illo cito proximant, et in peccatores respicit ira illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Sirach 5:8",
      "text": "Non tardes converti ad Dominum, et ne differas de die in diem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Sirach 5:9",
      "text": "subito enim veniet ira illius, et in tempore vindictæ disperdet te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Sirach 5:10",
      "text": "Noli anxius esse in divitiis injustis: non enim proderunt tibi in die obductionis et vindictæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Sirach 5:11",
      "text": "Non ventiles te in omnem ventum, et non eas in omnem viam: sic enim omnis peccator probatur in duplici lingua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Sirach 5:12",
      "text": "Esto firmus in via Domini, et in veritate sensus tui et scientia: et prosequatur te verbum pacis et justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Sirach 5:13",
      "text": "Esto mansuetus ad audiendum verbum, ut intelligas, et cum sapientia proferas responsum verum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Sirach 5:14",
      "text": "Si est tibi intellectus, responde proximo: sin autem, sit manus tua super os tuum, ne capiaris in verbo indisciplinato, et confundaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Sirach 5:15",
      "text": "Honor et gloria in sermone sensati: lingua vero imprudentis subversio est ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Sirach 5:16",
      "text": "Non appelleris susurro, et lingua tua ne capiaris et confundaris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Sirach 5:17",
      "text": "super furem enim est confusio et pœnitentia, et denotatio pessima super bilinguem: susurratori autem odium, et inimicitia, et contumelia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.5.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Sirach 5:18",
      "text": "Justifica pusillum et magnum similiter.",
      "paragraphStart": false
    }
  ]
}
