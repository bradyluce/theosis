{
  "chapter": {
    "id": "vulgate:sirach.34",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 34,
    "referenceLabel": "Sirach 34",
    "summary": "Source text for Sirach 34 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.34.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Sirach 34:1",
      "text": "Vana spes et mendacium viro insensato: et somnia extollunt imprudentes.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.34.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Sirach 34:2",
      "text": "Quasi qui apprehendit umbram et persequitur ventum, sic et qui attendit ad visa mendacia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Sirach 34:3",
      "text": "Hoc secundum hoc visio somniorum, ante faciem hominis similitudo hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Sirach 34:4",
      "text": "Ab immundo, quid mundabitur? et a mendace, quid verum dicetur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Sirach 34:5",
      "text": "Divinatio erroris, et auguria mendacia, et somnia malefacientium, vanitas est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Sirach 34:6",
      "text": "et sicut parturientis, cor tuum phantasias patitur. Nisi ab Altissimo fuerit emissa visitatio, ne dederis in illis cor tuum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Sirach 34:7",
      "text": "multos enim errare fecerunt somnia, et exciderunt sperantes in illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Sirach 34:8",
      "text": "Sine mendacio consummabitur verbum legis, et sapientia in ore fidelis complanabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Sirach 34:9",
      "text": "Qui non est tentatus quid scit? vir in multis expertus cogitabit multa: et qui multa didicit enarrabit intellectum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Sirach 34:10",
      "text": "Qui non est expertus pauca recognoscit: qui autem in multis factus est, multiplicat malitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Sirach 34:11",
      "text": "Qui tentatus non est qualia scit? qui implanatus est abundabit nequitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Sirach 34:12",
      "text": "Multa vidi errando, et plurimas verborum consuetudines.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Sirach 34:13",
      "text": "Aliquoties usque ad mortem periclitatus sum horum causa, et liberatus sum gratia Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Sirach 34:14",
      "text": "Spiritus timentium Deum quæritur, et in respectu illius benedicetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Sirach 34:15",
      "text": "Spes enim illorum in salvantem illos, et oculi Dei in diligentes se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Sirach 34:16",
      "text": "Qui timet Dominum nihil trepidabit: et non pavebit, quoniam ipse est spes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Sirach 34:17",
      "text": "Timentis Dominum, beata est anima ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Sirach 34:18",
      "text": "Ad quem respicit, et quis est fortitudo ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Sirach 34:19",
      "text": "Oculi Domini super timentes eum: protector potentiæ, firmamentum virtutis, tegimen ardoris, et umbraculum meridiani:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Sirach 34:20",
      "text": "deprecatio offensionis, et adjutorium casus: exaltans animam, et illuminans oculos, dans sanitatem, et vitam, et benedictionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Sirach 34:21",
      "text": "Immolantis ex iniquo oblatio est maculata, et non sunt beneplacitæ subsannationes injustorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Sirach 34:22",
      "text": "Dominus solus sustinentibus se in via veritatis et justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Sirach 34:23",
      "text": "Dona iniquorum non probat Altissimus, nec respicit in oblationes iniquorum, nec in multitudine sacrificiorum eorum propitiabitur peccatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Sirach 34:24",
      "text": "Qui offert sacrificium ex substantia pauperum, quasi qui victimat filium in conspectu patris sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Sirach 34:25",
      "text": "Panis egentium vita pauperum est: qui defraudat illum homo sanguinis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Sirach 34:26",
      "text": "Qui aufert in sudore panem, quasi qui occidit proximum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Sirach 34:27",
      "text": "Qui effundit sanguinem, et qui fraudem facit mercenario, fratres sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Sirach 34:28",
      "text": "Unus ædificans, et unus destruens: quid prodest illis, nisi labor?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Sirach 34:29",
      "text": "Unus orans, et unus maledicens: cujus vocem exaudiet Deus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 30,
      "referenceLabel": "Sirach 34:30",
      "text": "Qui baptizatur a mortuo, et iterum tangit eum, quid proficit lavatio illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.34.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 34,
      "verseNumber": 31,
      "referenceLabel": "Sirach 34:31",
      "text": "Sic homo qui jejunat in peccatis suis, et iterum eadem faciens: quid proficit humiliando se? orationem illius quis exaudiet?",
      "paragraphStart": false
    }
  ]
}
