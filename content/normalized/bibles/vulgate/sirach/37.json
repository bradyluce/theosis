{
  "chapter": {
    "id": "vulgate:sirach.37",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 37,
    "referenceLabel": "Sirach 37",
    "summary": "Source text for Sirach 37 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.37.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Sirach 37:1",
      "text": "Omnis amicus dicet: Et ego amicitiam copulavi: sed est amicus solo nomine amicus. Nonne tristitia inest usque ad mortem?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.37.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Sirach 37:2",
      "text": "sodalis autem et amicus ad inimicitiam convertentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Sirach 37:3",
      "text": "O præsumptio nequissima, unde creata es cooperire aridam malitia et dolositate illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Sirach 37:4",
      "text": "Sodalis amico conjucundatur in oblectationibus, et in tempore tribulationis adversarius erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Sirach 37:5",
      "text": "Sodalis amico condolet causa ventris, et contra hostem accipiet scutum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Sirach 37:6",
      "text": "Non obliviscaris amici tui in animo tuo, et non immemor sis illius in opibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Sirach 37:7",
      "text": "Noli consiliari cum eo qui tibi insidiatur, et a zelantibus te absconde consilium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Sirach 37:8",
      "text": "Omnis consiliarius prodit consilium, sed est consiliarius in semetipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Sirach 37:9",
      "text": "A consiliario serva animam tuam: prius scito quæ sit illius necessitas: et ipse enim animo suo cogitabit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Sirach 37:10",
      "text": "ne forte mittat sudem in terram, et dicat tibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Sirach 37:11",
      "text": "Bona est via tua: et stet e contrario videre quid tibi eveniat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Sirach 37:12",
      "text": "Cum viro irreligioso tracta de sanctitate, et cum injusto de justitia, et cum muliere de ea quæ æmulatur, cum timido de bello, cum negotiatore de trajectione, cum emptore de venditione, cum viro livido de gratiis agendis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Sirach 37:13",
      "text": "cum impio de pietate, cum inhonesto de honestate, cum operario agrario de omni opere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Sirach 37:14",
      "text": "cum operario annuali de consummatione anni, cum servo pigro de multa operatione. Non attendas his in omni consilio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Sirach 37:15",
      "text": "sed cum viro sancto assiduus esto, quemcumque cognoveris observantem timorem Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Sirach 37:16",
      "text": "cujus anima est secundum animam tuam, et qui, cum titubaveris in tenebris, condolebit tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Sirach 37:17",
      "text": "Cor boni consilii statue tecum: non est enim tibi aliud pluris illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Sirach 37:18",
      "text": "Anima viri sancti enuntiat aliquando vera, quam septem circumspectores sedentes in excelso ad speculandum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Sirach 37:19",
      "text": "Et in his omnibus deprecare Altissimum, ut dirigat in veritate viam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Sirach 37:20",
      "text": "Ante omnia opera verbum verax præcedat te, et ante omnem actum consilium stabile.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Sirach 37:21",
      "text": "Verbum nequam immutabit cor: ex quo partes quatuor oriuntur: bonum et malum, vita et mors: et dominatrix illorum est assidua lingua. Est vir astutus multorum eruditor, et animæ suæ inutilis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Sirach 37:22",
      "text": "Vir peritus multos erudivit, et animæ suæ suavis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Sirach 37:23",
      "text": "Qui sophistice loquitur odibilis est: in omni re defraudabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Sirach 37:24",
      "text": "Non est illi data a Domino gratia, omni enim sapientia defraudatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 25,
      "referenceLabel": "Sirach 37:25",
      "text": "Est sapiens animæ suæ sapiens, et fructus sensus illius laudabilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 26,
      "referenceLabel": "Sirach 37:26",
      "text": "Vir sapiens plebem suam erudit, et fructus sensus illius fideles sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 27,
      "referenceLabel": "Sirach 37:27",
      "text": "Vir sapiens implebitur benedictionibus, et videntes illum laudabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 28,
      "referenceLabel": "Sirach 37:28",
      "text": "Vita viri in numero dierum: dies autem Israël innumerabiles sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 29,
      "referenceLabel": "Sirach 37:29",
      "text": "Sapiens in populo hæreditabit honorem, et nomen illius erit vivens in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 30,
      "referenceLabel": "Sirach 37:30",
      "text": "Fili, in vita tua tenta animam tuam, et si fuerit nequam non des illi potestatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 31,
      "referenceLabel": "Sirach 37:31",
      "text": "non enim omnia omnibus expediunt, et non omni animæ omne genus placet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 32,
      "referenceLabel": "Sirach 37:32",
      "text": "Noli avidus esse in omni epulatione, et non te effundas super omnem escam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 33,
      "referenceLabel": "Sirach 37:33",
      "text": "in multis enim escis erit infirmitas, et aviditas appropinquabit usque ad choleram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.37.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 37,
      "verseNumber": 34,
      "referenceLabel": "Sirach 37:34",
      "text": "Propter crapulam multi obierunt: qui autem abstinens est adjiciet vitam.",
      "paragraphStart": false
    }
  ]
}
