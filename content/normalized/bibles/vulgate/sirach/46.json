{
  "chapter": {
    "id": "vulgate:sirach.46",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 46,
    "referenceLabel": "Sirach 46",
    "summary": "Source text for Sirach 46 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.46.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Sirach 46:1",
      "text": "Fortis in bello Jesus Nave, successor Moysi in prophetis, qui fuit magnus secundum nomen suum,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.46.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Sirach 46:2",
      "text": "maximus in salutem electorum Dei, expugnare insurgentes hostes, ut consequeretur hæreditatem Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Sirach 46:3",
      "text": "Quam gloriam adeptus est in tollendo manus suas, et jactando contra civitates rhomphæas!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Sirach 46:4",
      "text": "Quis ante illum sic restitit? nam hostes ipse Dominus perduxit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Sirach 46:5",
      "text": "An non in iracundia ejus impeditus est sol, et una dies facta est quasi duo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Sirach 46:6",
      "text": "Invocavit Altissimum potentem, in oppugnando inimicos undique: et audivit illum magnus et sanctus Deus, in saxis grandinis virtutis valde fortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Sirach 46:7",
      "text": "Impetum fecit contra gentem hostilem, et in descensu perdidit contrarios:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Sirach 46:8",
      "text": "ut cognoscant gentes potentiam ejus, quia contra Deum pugnare non est facile. Et secutus est a tergo potentis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Sirach 46:9",
      "text": "et in diebus Moysi misericordiam fecit, ipse, et Caleb filius Jephone, stare contra hostem, et prohibere gentem a peccatis, et perfringere murmur malitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Sirach 46:10",
      "text": "Et ipsi duo constituti a periculo liberati sunt a numero sexcentorum millium peditum, inducere illos in hæreditatem, in terram quæ manat lac et mel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Sirach 46:11",
      "text": "Et dedit Dominus ipsi Caleb fortitudinem, et usque in senectutem permansit illi virtus, ut ascenderet in excelsum terræ locum, et semen ipsius obtinuit hæreditatem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 12,
      "referenceLabel": "Sirach 46:12",
      "text": "ut viderent omnes filii Israël quia bonum est obsequi sancto Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 13,
      "referenceLabel": "Sirach 46:13",
      "text": "Et judices singuli suo nomine, quorum non est corruptum cor, qui non aversi sunt a Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 14,
      "referenceLabel": "Sirach 46:14",
      "text": "ut sit memoria illorum in benedictione, et ossa eorum pullulent de loco suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 15,
      "referenceLabel": "Sirach 46:15",
      "text": "et nomen eorum permaneat in æternum, permanens ad filios illorum, sanctorum virorum gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 16,
      "referenceLabel": "Sirach 46:16",
      "text": "Dilectus a Domino Deo suo Samuel, propheta Domini, renovavit imperium, et unxit principes in gente sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 17,
      "referenceLabel": "Sirach 46:17",
      "text": "In lege Domini congregationem judicavit, et vidit Deus Jacob: et in fide sua probatus est propheta,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 18,
      "referenceLabel": "Sirach 46:18",
      "text": "et cognitus est in verbis suis fidelis, quia vidit Deum lucis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 19,
      "referenceLabel": "Sirach 46:19",
      "text": "Et invocavit Dominum omnipotentem, in oppugnando hostes circumstantes undique, in oblatione agni inviolati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 20,
      "referenceLabel": "Sirach 46:20",
      "text": "Et intonuit de cælo Dominus, et in sonitu magno auditam fecit vocem suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 21,
      "referenceLabel": "Sirach 46:21",
      "text": "et contrivit principes Tyriorum, et omnes duces Philisthiim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 22,
      "referenceLabel": "Sirach 46:22",
      "text": "et ante tempus finis vitæ suæ et sæculi, testimonium præbuit in conspectu Domini et christi: pecunias et usque ad calceamenta ab omni carne non accepit, et non accusavit illum homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.46.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 46,
      "verseNumber": 23,
      "referenceLabel": "Sirach 46:23",
      "text": "Et post hoc dormivit: et notum fecit regi, et ostendit illi finem vitæ suæ: et exaltavit vocem suam de terra in prophetia, delere impietatem gentis.",
      "paragraphStart": false
    }
  ]
}
