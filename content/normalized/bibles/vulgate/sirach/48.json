{
  "chapter": {
    "id": "vulgate:sirach.48",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 48,
    "referenceLabel": "Sirach 48",
    "summary": "Source text for Sirach 48 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.48.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Sirach 48:1",
      "text": "Et surrexit Elias propheta quasi ignis, et verbum ipsius quasi facula ardebat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.48.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Sirach 48:2",
      "text": "Qui induxit in illos famem: et irritantes illum invidia sua pauci facti sunt: non enim poterant sustinere præcepta Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Sirach 48:3",
      "text": "Verbo Domini continuit cælum, et dejecit de cælo ignem ter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Sirach 48:4",
      "text": "Sic amplificatus est Elias in mirabilibus suis. Et quis potest similiter sic gloriari tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Sirach 48:5",
      "text": "qui sustulisti mortuum ab inferis de sorte mortis, in verbo Domini Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Sirach 48:6",
      "text": "qui dejecisti reges ad pernicem, et confregisti facile potentiam ipsorum, et gloriosos de lecto suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Sirach 48:7",
      "text": "qui audis in Sina judicium, et in Horeb judicia defensionis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Sirach 48:8",
      "text": "qui ungis reges ad pœnitentiam, et prophetas facis successores post te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Sirach 48:9",
      "text": "qui receptus es in turbine ignis, in curru equorum igneorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Sirach 48:10",
      "text": "qui scriptus es in judiciis temporum, lenire iracundiam Domini, conciliare cor patris ad filium, et restituere tribus Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Sirach 48:11",
      "text": "Beati sunt qui te viderunt, et in amicitia tua decorati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Sirach 48:12",
      "text": "Nam nos vita vivimus tantum: post mortem autem non erit tale nomen nostrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Sirach 48:13",
      "text": "Elias quidem in turbine tectus est, et in Eliseo completus est spiritus ejus: in diebus suis non pertimuit principem, et potentia nemo vicit illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Sirach 48:14",
      "text": "nec superavit illum verbum aliquod, et mortuum prophetavit corpus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 15,
      "referenceLabel": "Sirach 48:15",
      "text": "In vita sua fecit monstra, et in morte mirabilia operatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 16,
      "referenceLabel": "Sirach 48:16",
      "text": "In omnibus istis non pœnituit populus, et non recesserunt a peccatis suis, usque dum ejecti sunt de terra sua, et dispersi sunt in omnem terram:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 17,
      "referenceLabel": "Sirach 48:17",
      "text": "et relicta est gens perpauca, et princeps in domo David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 18,
      "referenceLabel": "Sirach 48:18",
      "text": "Quidam ipsorum fecerunt quod placeret Deo: alii autem multa commiserunt peccata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 19,
      "referenceLabel": "Sirach 48:19",
      "text": "Ezechias munivit civitatem suam, et induxit in medium ipsius aquam: et fodit ferro rupem, et ædificavit ad aquam puteum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 20,
      "referenceLabel": "Sirach 48:20",
      "text": "In diebus ipsius ascendit Sennacherib, et misit Rabsacen, et sustulit manum suam contra illos: et extulit manum suam in Sion, et superbus factus est potentia sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 21,
      "referenceLabel": "Sirach 48:21",
      "text": "Tunc mota sunt corda et manus ipsorum: et doluerunt quasi parturientes mulieres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 22,
      "referenceLabel": "Sirach 48:22",
      "text": "Et invocaverunt Dominum misericordem, et expandentes manus suas extulerunt ad cælum: et Sanctus, Dominus Deus, audivit cito vocem ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 23,
      "referenceLabel": "Sirach 48:23",
      "text": "Non est commemoratus peccatorum illorum, neque dedit illos inimicis suis: sed purgavit eos in manu Isaiæ sancti prophetæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 24,
      "referenceLabel": "Sirach 48:24",
      "text": "Dejecit castra Assyriorum, et contrivit illos angelus Domini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 25,
      "referenceLabel": "Sirach 48:25",
      "text": "nam fecit Ezechias quod placuit Deo, et fortiter ivit in via David patris sui, quam mandavit illi Isaias, propheta magnus, et fidelis in conspectu Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 26,
      "referenceLabel": "Sirach 48:26",
      "text": "In diebus ipsius retro rediit sol, et addidit regi vitam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 27,
      "referenceLabel": "Sirach 48:27",
      "text": "Spiritu magno vidit ultima, et consolatus est lugentes in Sion usque in sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.48.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 48,
      "verseNumber": 28,
      "referenceLabel": "Sirach 48:28",
      "text": "Ostendit futura, et abscondita antequam evenirent.",
      "paragraphStart": false
    }
  ]
}
