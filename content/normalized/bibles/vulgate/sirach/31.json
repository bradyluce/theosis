{
  "chapter": {
    "id": "vulgate:sirach.31",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 31,
    "referenceLabel": "Sirach 31",
    "summary": "Source text for Sirach 31 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.31.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Sirach 31:1",
      "text": "Vigilia honestatis tabefaciet carnes, et cogitatus illius auferet somnum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.31.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Sirach 31:2",
      "text": "Cogitatus præscientiæ avertit sensum, et infirmitas gravis sobriam facit animam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Sirach 31:3",
      "text": "Laboravit dives in congregatione substantiæ, et in requie sua replebitur bonis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Sirach 31:4",
      "text": "Laboravit pauper in diminutione victus, et in fine inops fit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Sirach 31:5",
      "text": "Qui aurum diligit non justificabitur, et qui insequitur consumptionem replebitur ex ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Sirach 31:6",
      "text": "Multi dati sunt in auri casus, et facta est in specie ipsius perditio illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Sirach 31:7",
      "text": "Lignum offensionis est aurum sacrificantium: væ illis qui sectantur illud! et omnis imprudens deperiet in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Sirach 31:8",
      "text": "Beatus dives qui inventus est sine macula, et qui post aurum non abiit, nec speravit in pecunia et thesauris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Sirach 31:9",
      "text": "Quis est hic? et laudabimus eum: fecit enim mirabilia in vita sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Sirach 31:10",
      "text": "Qui probatus est in illo, et perfectus est, erit illi gloria æterna: qui potuit transgredi, et non est transgressus; facere mala, et non fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Sirach 31:11",
      "text": "Ideo stabilita sunt bona illius in Domino, et eleemosynas illius enarrabit omnis ecclesia sanctorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Sirach 31:12",
      "text": "Supra mensam magnam sedisti? non aperias super illam faucem tuam prior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Sirach 31:13",
      "text": "Non dicas sic: Multa sunt, quæ super illam sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Sirach 31:14",
      "text": "Memento quoniam malus est oculus nequam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Sirach 31:15",
      "text": "Nequius oculo quid creatum est? ideo ab omni facie sua lacrimabitur, cum viderit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Sirach 31:16",
      "text": "Ne extendas manum tuam prior, et invidia contaminatus erubescas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Sirach 31:17",
      "text": "Ne comprimaris in convivio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Sirach 31:18",
      "text": "Intellige quæ sunt proximi tui ex teipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Sirach 31:19",
      "text": "Utere quasi homo frugi his quæ tibi apponuntur: ne, cum manducas multum, odio habearis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Sirach 31:20",
      "text": "Cessa prior causa disciplinæ: et noli nimius esse, ne forte offendas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Sirach 31:21",
      "text": "Et si in medio multorum sedisti, prior illis ne extendas manum tuam, nec prior poscas bibere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Sirach 31:22",
      "text": "Quam sufficiens est homini erudito vinum exiguum! et in dormiendo non laborabis ab illo, et non senties dolorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Sirach 31:23",
      "text": "Vigilia, cholera et tortura viro infrunito,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Sirach 31:24",
      "text": "somnus sanitatis in homine parco: dormiet usque mane, et anima illius cum ipso delectabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Sirach 31:25",
      "text": "Et si coactus fueris in edendo multum, surge e medio, evome, et refrigerabit te, et non adduces corpori tuo infirmitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Sirach 31:26",
      "text": "Audi me, fili, et ne spernas me, et in novissimo invenies verba mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Sirach 31:27",
      "text": "In omnibus operibus tuis esto velox, et omnis infirmitas non occurret tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Sirach 31:28",
      "text": "Splendidum in panibus benedicent labia multorum, et testimonium veritatis illius fidele.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Sirach 31:29",
      "text": "Nequissimo in pane murmurabit civitas, et testimonium nequitiæ illius verum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Sirach 31:30",
      "text": "Diligentes in vino noli provocare: multos enim exterminavit vinum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Sirach 31:31",
      "text": "Ignis probat ferrum durum: sic vinum corda superborum arguet in ebrietate potatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 32,
      "referenceLabel": "Sirach 31:32",
      "text": "Æqua vita hominibus vinum in sobrietate: si bibas illud moderate, eris sobrius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 33,
      "referenceLabel": "Sirach 31:33",
      "text": "Quæ vita est ei qui minuitur vino?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 34,
      "referenceLabel": "Sirach 31:34",
      "text": "Quid defraudat vitam? mors.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 35,
      "referenceLabel": "Sirach 31:35",
      "text": "Vinum in jucunditatem creatum est, et non in ebrietatem ab initio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 36,
      "referenceLabel": "Sirach 31:36",
      "text": "Exsultatio animæ et cordis vinum moderate potatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 37,
      "referenceLabel": "Sirach 31:37",
      "text": "Sanitas est animæ et corpori sobrius potus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 38,
      "referenceLabel": "Sirach 31:38",
      "text": "Vinum multum potatum irritationem, et iram, et ruinas multas facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.39",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 39,
      "referenceLabel": "Sirach 31:39",
      "text": "Amaritudo animæ vinum multum potatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.40",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 40,
      "referenceLabel": "Sirach 31:40",
      "text": "Ebrietatis animositas, imprudentis offensio, minorans virtutem, et faciens vulnera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.41",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 41,
      "referenceLabel": "Sirach 31:41",
      "text": "In convivio vini non arguas proximum, et non despicias eum in jucunditate illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.31.42",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 31,
      "verseNumber": 42,
      "referenceLabel": "Sirach 31:42",
      "text": "Verba improperii non dicas illi, et non premas illum repetendo.",
      "paragraphStart": false
    }
  ]
}
