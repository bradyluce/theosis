{
  "chapter": {
    "id": "vulgate:sirach.8",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 8,
    "referenceLabel": "Sirach 8",
    "summary": "Source text for Sirach 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.8.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Sirach 8:1",
      "text": "Non litiges cum homine potente, ne forte incidas in manus illius.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.8.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Sirach 8:2",
      "text": "Non contendas cum viro locuplete, ne forte contra te constituat litem tibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Sirach 8:3",
      "text": "multos enim perdidit aurum et argentum, et usque ad cor regum extendit et convertit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Sirach 8:4",
      "text": "Non litiges cum homine linguato, et non strues in ignem illius ligna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Sirach 8:5",
      "text": "Non communices homini indocto, ne male de progenie tua loquatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Sirach 8:6",
      "text": "Ne despicias hominem avertentem se a peccato, neque improperes ei: memento quoniam omnes in correptione sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Sirach 8:7",
      "text": "Ne spernas hominem in sua senectute, etenim ex nobis senescunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Sirach 8:8",
      "text": "Noli de mortuo inimico tuo gaudere: sciens quoniam omnes morimur, et in gaudium nolumus venire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Sirach 8:9",
      "text": "Ne despicias narrationem presbyterorum sapientium, et in proverbiis eorum conversare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Sirach 8:10",
      "text": "ab ipsis enim disces sapientiam et doctrinam intellectus, et servire magnatis sine querela.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Sirach 8:11",
      "text": "Non te prætereat narratio seniorum, ipsi enim didicerunt a patribus suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Sirach 8:12",
      "text": "quoniam ab ipsis disces intellectum, et in tempore necessitatis dare responsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Sirach 8:13",
      "text": "Non incendas carbones peccatorum arguens eos, et ne incendaris flamma ignis peccatorum illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Sirach 8:14",
      "text": "Ne contra faciem stes contumeliosi, ne sedeat quasi insidiator ori tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Sirach 8:15",
      "text": "Noli fœnerari homini fortiori te: quod si fœneraveris, quasi perditum habe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Sirach 8:16",
      "text": "Non spondeas super virtutem tuam: quod si spoponderis, quasi restituens cogita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Sirach 8:17",
      "text": "Non judices contra judicem, quoniam secundum quod justum est judicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Sirach 8:18",
      "text": "Cum audace non eas in via, ne forte gravet mala sua in te: ipse enim secundum voluntatem suam vadit, et simul cum stultitia illius peries.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Sirach 8:19",
      "text": "Cum iracundo non facias rixam, et cum audace non eas in desertum: quoniam quasi nihil est ante illum sanguis, et ubi non est adjutorium, elidet te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Sirach 8:20",
      "text": "Cum fatuis consilium non habeas: non enim poterunt diligere nisi quæ eis placent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Sirach 8:21",
      "text": "Coram extraneo ne facias consilium: nescis enim quid pariet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.8.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Sirach 8:22",
      "text": "Non omni homini cor tuum manifestes, ne forte inferat tibi gratiam falsam, et convicietur tibi.",
      "paragraphStart": false
    }
  ]
}
