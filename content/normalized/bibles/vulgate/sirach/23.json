{
  "chapter": {
    "id": "vulgate:sirach.23",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 23,
    "referenceLabel": "Sirach 23",
    "summary": "Source text for Sirach 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.23.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Sirach 23:1",
      "text": "Domine, pater et dominator vitæ meæ, ne derelinquas me in consilio eorum, nec sinas me cadere in illis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.23.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Sirach 23:2",
      "text": "Quis superponet in cogitatu meo flagella, et in corde meo doctrinam sapientiæ, ut ignorationibus eorum non parcant mihi, et non appareant delicta eorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Sirach 23:3",
      "text": "et ne adincrescant ignorantiæ meæ, et multiplicentur delicta mea, et peccata mea abundent, et incidam in conspectu adversariorum meorum, et gaudeat super me inimicus meus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Sirach 23:4",
      "text": "Domine, pater et Deus vitæ meæ, ne derelinquas me in cogitatu illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Sirach 23:5",
      "text": "Extollentiam oculorum meorum ne dederis mihi, et omne desiderium averte a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Sirach 23:6",
      "text": "Aufer a me ventris concupiscentias, et concubitus concupiscentiæ ne apprehendant me, et animæ irreverenti et infrunitæ ne tradas me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Sirach 23:7",
      "text": "Doctrinam oris audite, filii: et qui custodierit illam non periet labiis, nec scandalizabitur in operibus nequissimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Sirach 23:8",
      "text": "In vanitate sua apprehenditur peccator: et superbus et maledicus scandalizabitur in illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Sirach 23:9",
      "text": "Jurationi non assuescat os tuum: multi enim casus in illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Sirach 23:10",
      "text": "Nominatio vero Dei non sit assidua in ore tuo, et nominibus sanctorum non admiscearis, quoniam non erit immunis ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Sirach 23:11",
      "text": "Sicut enim servus interrogatus assidue a livore non minuitur, sic omnis jurans et nominans in toto a peccato non purgabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Sirach 23:12",
      "text": "Vir multum jurans implebitur iniquitate, et non discedet a domo illius plaga.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Sirach 23:13",
      "text": "Et si frustraverit, delictum illius super ipsum erit: et si dissimulaverit, delinquit dupliciter:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Sirach 23:14",
      "text": "et si in vacuum juraverit, non justificabitur: replebitur enim retributione domus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Sirach 23:15",
      "text": "Est et alia loquela contraria morti: non inveniatur in hæreditate Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Sirach 23:16",
      "text": "Etenim a misericordibus omnia hæc auferentur, et in delictis non volutabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Sirach 23:17",
      "text": "Indisciplinatæ loquelæ non assuescat os tuum: est enim in illa verbum peccati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Sirach 23:18",
      "text": "Memento patris et matris tuæ: in medio enim magnatorum consistis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Sirach 23:19",
      "text": "ne forte obliviscatur te Deus in conspectu illorum, et assiduitate tua infatuatus, improperium patiaris, et maluisses non nasci, et diem nativitatis tuæ maledicas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Sirach 23:20",
      "text": "Homo assuetus in verbis improperii in omnibus diebus suis non erudietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Sirach 23:21",
      "text": "Duo genera abundant in peccatis, et tertium adducit iram et perditionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Sirach 23:22",
      "text": "Anima calida quasi ignis ardens, non extinguetur donec aliquid glutiat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Sirach 23:23",
      "text": "et homo nequam in ore carnis suæ non desinet donec incendat ignem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Sirach 23:24",
      "text": "Homini fornicario omnis panis dulcis: non fatigabitur transgrediens usque ad finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Sirach 23:25",
      "text": "Omnis homo qui transgreditur lectum suum, contemnens in animam suam, et dicens: Quis me videt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Sirach 23:26",
      "text": "Tenebræ circumdant me, et parietes cooperiunt me, et nemo circumspicit me: quem vereor? delictorum meorum non memorabitur Altissimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Sirach 23:27",
      "text": "Et non intelligit quoniam omnia videt oculus illius, quoniam expellit a se timorem Dei hujusmodi hominis timor, et oculi hominum timentes illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Sirach 23:28",
      "text": "et non cognovit quoniam oculi Domini multo plus lucidiores sunt super solem, circumspicientes omnes vias hominum, et profundum abyssi, et hominum corda, intuentes in absconditas partes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Sirach 23:29",
      "text": "Domino enim Deo antequam crearentur omnia sunt agnita: sic et post perfectum respicit omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Sirach 23:30",
      "text": "Hic in plateis civitatis vindicabitur, et quasi pullus equinus fugabitur, et ubi non speravit apprehendetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Sirach 23:31",
      "text": "Et erit dedecus omnibus, eo quod non intellexerit timorem Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Sirach 23:32",
      "text": "Sic et mulier omnis relinquens virum suum, et statuens hæreditatem ex alieno matrimonio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Sirach 23:33",
      "text": "primo enim in lege Altissimi incredibilis fuit: secundo in virum suum deliquit: tertio in adulterio fornicata est, et ex alio viro filios statuit sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Sirach 23:34",
      "text": "Hæc in ecclesiam adducetur, et in filios ejus respicietur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Sirach 23:35",
      "text": "non tradent filii ejus radices, et rami ejus non dabunt fructum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 36,
      "referenceLabel": "Sirach 23:36",
      "text": "derelinquet in maledictum memoriam ejus, et dedecus illius non delebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 37,
      "referenceLabel": "Sirach 23:37",
      "text": "Et agnoscent qui derelicti sunt, quoniam nihil melius est quam timor Dei, et nihil dulcius quam respicere in mandatis Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.23.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 23,
      "verseNumber": 38,
      "referenceLabel": "Sirach 23:38",
      "text": "Gloria magna est sequi Dominum: longitudo enim dierum assumetur ab eo.",
      "paragraphStart": false
    }
  ]
}
