{
  "chapter": {
    "id": "vulgate:sirach.47",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 47,
    "referenceLabel": "Sirach 47",
    "summary": "Source text for Sirach 47 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.47.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Sirach 47:1",
      "text": "Post hæc surrexit Nathan, propheta in diebus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.47.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Sirach 47:2",
      "text": "Et quasi adeps separatus a carne, sic David a filiis Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Sirach 47:3",
      "text": "Cum leonibus lusit quasi cum agnis, et in ursis similiter fecit sicut in agnis ovium, in juventute sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Sirach 47:4",
      "text": "Numquid non occidit gigantem, et abstulit opprobrium de gente?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Sirach 47:5",
      "text": "In tollendo manum, saxo fundæ dejecit exsultationem Goliæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Sirach 47:6",
      "text": "nam invocavit Dominum omnipotentem, et dedit in dextera ejus tollere hominem fortem in bello, et exaltare cornu gentis suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Sirach 47:7",
      "text": "Sic in decem millibus glorificavit eum: et laudavit eum in benedictionibus Domini, in offerendo illi coronam gloriæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Sirach 47:8",
      "text": "contrivit enim inimicos undique, et extirpavit Philisthiim contrarios usque in hodiernum diem: contrivit cornu ipsorum usque in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Sirach 47:9",
      "text": "In omni opere dedit confessionem Sancto, et Excelso in verbo gloriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 10,
      "referenceLabel": "Sirach 47:10",
      "text": "De omni corde suo laudavit Dominum: et dilexit Deum, qui fecit illum, et dedit illi contra inimicos potentiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 11,
      "referenceLabel": "Sirach 47:11",
      "text": "et stare fecit cantores contra altare, et in sono eorum dulces fecit modos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 12,
      "referenceLabel": "Sirach 47:12",
      "text": "Et dedit in celebrationibus decus, et ornavit tempora usque ad consummationem vitæ, ut laudarent nomen sanctum Domini, et amplificarent mane Dei sanctitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 13,
      "referenceLabel": "Sirach 47:13",
      "text": "Dominus purgavit peccata ipsius, et exaltavit in æternum cornu ejus: et dedit illi testamentum regni, et sedem gloriæ in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 14,
      "referenceLabel": "Sirach 47:14",
      "text": "Post ipsum surrexit filius sensatus, et propter illum dejecit omnem potentiam inimicorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 15,
      "referenceLabel": "Sirach 47:15",
      "text": "Salomon imperavit in diebus pacis, cui subjecit Deus omnes hostes, ut conderet domum in nomine suo, et pararet sanctitatem in sempiternum. Quemadmodum eruditus es in juventute tua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 16,
      "referenceLabel": "Sirach 47:16",
      "text": "et impletus es, quasi flumen, sapientia, et terram retexit anima tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 17,
      "referenceLabel": "Sirach 47:17",
      "text": "Et replesti in comparationibus ænigmata: ad insulas longe divulgatum est nomen tuum, et dilectus es in pace tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 18,
      "referenceLabel": "Sirach 47:18",
      "text": "In cantilenis, et proverbiis, et comparationibus, et interpretationibus, miratæ sunt terræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 19,
      "referenceLabel": "Sirach 47:19",
      "text": "et in nomine Domini Dei, cui est cognomen Deus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 20,
      "referenceLabel": "Sirach 47:20",
      "text": "Collegisti quasi auricalcum aurum, et ut plumbum complesti argentum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 21,
      "referenceLabel": "Sirach 47:21",
      "text": "et inclinasti femora tua mulieribus: potestatem habuisti in corpore tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 22,
      "referenceLabel": "Sirach 47:22",
      "text": "Dedisti maculam in gloria tua, et profanasti semen tuum, inducere iracundiam ad liberos tuos, et incitari stultitiam tuam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 23,
      "referenceLabel": "Sirach 47:23",
      "text": "ut faceres imperium bipartitum, et ex Ephraim imperare imperium durum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 24,
      "referenceLabel": "Sirach 47:24",
      "text": "Deus autem non derelinquet misericordiam suam: et non corrumpet, nec delebit opera sua, neque perdet a stirpe nepotes electi sui, et semen ejus qui diligit Dominum non corrumpet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 25,
      "referenceLabel": "Sirach 47:25",
      "text": "Dedit autem reliquum Jacob, et David de ipsa stirpe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 26,
      "referenceLabel": "Sirach 47:26",
      "text": "Et finem habuit Salomon cum patribus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 27,
      "referenceLabel": "Sirach 47:27",
      "text": "Et dereliquit post se de semine suo, gentis stultitiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 28,
      "referenceLabel": "Sirach 47:28",
      "text": "et imminutum a prudentia, Roboam, qui avertit gentem consilio suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 29,
      "referenceLabel": "Sirach 47:29",
      "text": "et Jeroboam filium Nabat, qui peccare fecit Israël, et dedit viam peccandi Ephraim: et plurima redundaverunt peccata ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 30,
      "referenceLabel": "Sirach 47:30",
      "text": "Valde averterunt illos a terra sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.47.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 47,
      "verseNumber": 31,
      "referenceLabel": "Sirach 47:31",
      "text": "Et quæsivit omnes nequitias, usque dum perveniret ad illos defensio, et ab omnibus peccatis liberavit eos.",
      "paragraphStart": false
    }
  ]
}
