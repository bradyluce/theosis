{
  "chapter": {
    "id": "vulgate:sirach.14",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 14,
    "referenceLabel": "Sirach 14",
    "summary": "Source text for Sirach 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.14.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Sirach 14:1",
      "text": "Beatus vir qui non est lapsus verbo ex ore suo, et non est stimulatus in tristitia delicti.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.14.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Sirach 14:2",
      "text": "Felix qui non habuit animi sui tristitiam, et non excidit a spe sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Sirach 14:3",
      "text": "Viro cupido et tenaci sine ratione est substantia: et homini livido ad quid aurum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Sirach 14:4",
      "text": "Qui acervat ex animo suo injuste, aliis congregat, et in bonis illius alius luxuriabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Sirach 14:5",
      "text": "Qui sibi nequam est, cui alii bonus erit? et non jucundabitur in bonis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Sirach 14:6",
      "text": "Qui sibi invidet, nihil est illo nequius: et hæc redditio est malitiæ illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Sirach 14:7",
      "text": "Et si bene fecerit, ignoranter et non volens facit: et in novissimo manifestat malitiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Sirach 14:8",
      "text": "Nequam est oculus lividi: et avertens faciem suam, et despiciens animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Sirach 14:9",
      "text": "Insatiabilis oculus cupidi in parte iniquitatis: non satiabitur donec consumat arefaciens animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Sirach 14:10",
      "text": "Oculus malus ad mala, et non saturabitur pane, sed indigens et in tristitia erit super mensam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Sirach 14:11",
      "text": "Fili, si habes, benefac tecum, et Deo dignas oblationes offer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Sirach 14:12",
      "text": "Memor esto quoniam mors non tardat, et testamentum inferorum, quia demonstratum est tibi: testamentum enim hujus mundi morte morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Sirach 14:13",
      "text": "Ante mortem benefac amico tuo, et secundum vires tuas exporrigens da pauperi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Sirach 14:14",
      "text": "Non defrauderis a die bono, et particula boni doni non te prætereat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Sirach 14:15",
      "text": "Nonne aliis relinques dolores et labores tuos in divisione sortis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Sirach 14:16",
      "text": "Da et accipe, et justifica animam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Sirach 14:17",
      "text": "Ante obitum tuum operare justitiam, quoniam non est apud inferos invenire cibum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Sirach 14:18",
      "text": "Omnis caro sicut fœnum veterascet, et sicut folium fructificans in arbore viridi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Sirach 14:19",
      "text": "Alia generantur, et alia dejiciuntur: sic generatio carnis et sanguinis, alia finitur, et alia nascitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Sirach 14:20",
      "text": "Omne opus corruptibile in fine deficiet, et qui illud operatur ibit cum illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Sirach 14:21",
      "text": "Et omne opus electum justificabitur, et qui operatur illud honorabitur in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Sirach 14:22",
      "text": "Beatus vir qui in sapientia morabitur, et qui in justitia sua meditabitur, et in sensu cogitabit circumspectionem Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Sirach 14:23",
      "text": "qui excogitat vias illius in corde suo, et in absconditis suis intelligens, vadens post illam quasi investigator, et in viis illius consistens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Sirach 14:24",
      "text": "qui respicit per fenestras illius, et in januis illius audiens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Sirach 14:25",
      "text": "qui requiescit juxta domum illius, et in parietibus illius figens palum, statuet casulam suam ad manus illius, et requiescent in casula illius bona per ævum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Sirach 14:26",
      "text": "Statuet filios suos sub tegmine illius, et sub ramis ejus morabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.14.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Sirach 14:27",
      "text": "Protegetur sub tegmine illius a fervore, et in gloria ejus requiescet.",
      "paragraphStart": false
    }
  ]
}
