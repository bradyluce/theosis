{
  "chapter": {
    "id": "vulgate:sirach.40",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 40,
    "referenceLabel": "Sirach 40",
    "summary": "Source text for Sirach 40 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.40.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Sirach 40:1",
      "text": "Occupatio magna creata est omnibus hominibus, et jugum grave super filios Adam, a die exitus de ventre matris eorum usque in diem sepulturæ in matrem omnium.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.40.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Sirach 40:2",
      "text": "Cogitationes eorum, et timores cordis, adinventio exspectationis, et dies finitionis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Sirach 40:3",
      "text": "a residente super sedem gloriosam, usque ad humiliatum in terra et cinere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Sirach 40:4",
      "text": "ab eo qui utitur hyacintho et portat coronam, usque ad eum qui operitur lino crudo: furor, zelus, tumultus, fluctuatio, et timor mortis, iracundia perseverans, et contentio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Sirach 40:5",
      "text": "et in tempore refectionis in cubili, somnus noctis immutat scientiam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Sirach 40:6",
      "text": "Modicum tamquam nihil in requie, et ab eo in somnis, quasi in die respectus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Sirach 40:7",
      "text": "Conturbatus est in visu cordis sui, tamquam qui evaserit in die belli: in tempore salutis suæ exsurrexit, et admirans ad nullum timorem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Sirach 40:8",
      "text": "cum omni carne, ab homine usque ad pecus, et super peccatores septuplum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Sirach 40:9",
      "text": "Ad hæc mors, sanguis, contentio, et rhomphæa, oppressiones, fames, et contritio, et flagella:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Sirach 40:10",
      "text": "super iniquos creata sunt hæc omnia: et propter illos factus est cataclysmus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Sirach 40:11",
      "text": "Omnia quæ de terra sunt in terram convertentur, et omnes aquæ in mare revertentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Sirach 40:12",
      "text": "Omne munus et iniquitas delebitur, et fides in sæculum stabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Sirach 40:13",
      "text": "Substantiæ injustorum sicut fluvius siccabuntur, et sicut tonitruum magnum in pluvia personabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Sirach 40:14",
      "text": "In aperiendo manus suas lætabitur: sic prævaricatores in consummatione tabescent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 15,
      "referenceLabel": "Sirach 40:15",
      "text": "Nepotes impiorum non multiplicabunt ramos: et radices immundæ super cacumen petræ sonant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 16,
      "referenceLabel": "Sirach 40:16",
      "text": "Super omnem aquam viriditas, et ad oram fluminis ante omne fœnum evelletur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 17,
      "referenceLabel": "Sirach 40:17",
      "text": "Gratia sicut paradisus in benedictionibus, et misericordia in sæculum permanet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 18,
      "referenceLabel": "Sirach 40:18",
      "text": "Vita sibi sufficientis operarii condulcabitur, et in ea invenies thesaurum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 19,
      "referenceLabel": "Sirach 40:19",
      "text": "Filii et ædificatio civitatis confirmabit nomen: et super hæc mulier immaculata computabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 20,
      "referenceLabel": "Sirach 40:20",
      "text": "Vinum et musica lætificant cor: et super utraque dilectio sapientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 21,
      "referenceLabel": "Sirach 40:21",
      "text": "Tibiæ et psalterium suavem faciunt melodiam: et super utraque lingua suavis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 22,
      "referenceLabel": "Sirach 40:22",
      "text": "Gratiam et speciem desiderabit oculus tuus: et super hæc virides sationes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 23,
      "referenceLabel": "Sirach 40:23",
      "text": "Amicus et sodalis in tempore convenientes, et super utrosque mulier cum viro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 24,
      "referenceLabel": "Sirach 40:24",
      "text": "Fratres in adjutorium in tempore tribulationis: et super eos misericordia liberabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 25,
      "referenceLabel": "Sirach 40:25",
      "text": "Aurum et argentum est constitutio pedum: et super utrumque consilium beneplacitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 26,
      "referenceLabel": "Sirach 40:26",
      "text": "Facultates et virtutes exaltant cor, et super hæc timor Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 27,
      "referenceLabel": "Sirach 40:27",
      "text": "Non est in timore Domini minoratio: et non est in eo inquirere adjutorium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 28,
      "referenceLabel": "Sirach 40:28",
      "text": "Timor Domini sicut paradisus benedictionis, et super omnem gloriam operuerunt illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 29,
      "referenceLabel": "Sirach 40:29",
      "text": "Fili, in tempore vitæ tuæ ne indigeas: melius est enim mori quam indigere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 30,
      "referenceLabel": "Sirach 40:30",
      "text": "Vir respiciens in mensam alienam, non est vita ejus in cogitatione victus: alit enim animam suam cibis alienis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 31,
      "referenceLabel": "Sirach 40:31",
      "text": "vir autem disciplinatus et eruditus custodiet se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.40.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 40,
      "verseNumber": 32,
      "referenceLabel": "Sirach 40:32",
      "text": "In ore imprudentis condulcabitur inopia, et in ventre ejus ignis ardebit.",
      "paragraphStart": false
    }
  ]
}
