{
  "chapter": {
    "id": "vulgate:sirach.43",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 43,
    "referenceLabel": "Sirach 43",
    "summary": "Source text for Sirach 43 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.43.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 1,
      "referenceLabel": "Sirach 43:1",
      "text": "Altitudinis firmamentum pulchritudo ejus est, species cæli in visione gloriæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.43.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 2,
      "referenceLabel": "Sirach 43:2",
      "text": "Sol in aspectu annuntians in exitu, vas admirabile, opus Excelsi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 3,
      "referenceLabel": "Sirach 43:3",
      "text": "In meridiano exurit terram, et in conspectu ardoris ejus quis poterit sustinere? fornacem custodiens in operibus ardoris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 4,
      "referenceLabel": "Sirach 43:4",
      "text": "tripliciter sol exurens montes, radios igneos exsufflans, et refulgens radiis suis obcæcat oculos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 5,
      "referenceLabel": "Sirach 43:5",
      "text": "Magnus Dominus qui fecit illum, et in sermonibus ejus festinavit iter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 6,
      "referenceLabel": "Sirach 43:6",
      "text": "Et luna in omnibus in tempore suo, ostensio temporis, et signum ævi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 7,
      "referenceLabel": "Sirach 43:7",
      "text": "A luna signum diei festi: luminare quod minuitur in consummatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 8,
      "referenceLabel": "Sirach 43:8",
      "text": "Mensis secundum nomen ejus est, crescens mirabiliter in consummatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 9,
      "referenceLabel": "Sirach 43:9",
      "text": "Vas castrorum in excelsis, in firmamento cæli resplendens gloriose.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 10,
      "referenceLabel": "Sirach 43:10",
      "text": "Species cæli gloria stellarum: mundum illuminans in excelsis Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 11,
      "referenceLabel": "Sirach 43:11",
      "text": "In verbis Sancti stabunt ad judicium, et non deficient in vigiliis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 12,
      "referenceLabel": "Sirach 43:12",
      "text": "Vide arcum, et benedic eum qui fecit illum: valde speciosus est in splendore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 13,
      "referenceLabel": "Sirach 43:13",
      "text": "Gyravit cælum in circuitu gloriæ suæ: manus Excelsi aperuerunt illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 14,
      "referenceLabel": "Sirach 43:14",
      "text": "Imperio suo acceleravit nivem, et accelerat coruscationes emittere judicii sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 15,
      "referenceLabel": "Sirach 43:15",
      "text": "Propterea aperti sunt thesauri, et evolaverunt nebulæ sicut aves.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 16,
      "referenceLabel": "Sirach 43:16",
      "text": "In magnitudine sua posuit nubes, et confracti sunt lapides grandinis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 17,
      "referenceLabel": "Sirach 43:17",
      "text": "In conspectu ejus commovebuntur montes, et in voluntate ejus aspirabit notus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 18,
      "referenceLabel": "Sirach 43:18",
      "text": "Vox tonitrui ejus verberavit terram, tempestas aquilonis, et congregatio spiritus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 19,
      "referenceLabel": "Sirach 43:19",
      "text": "et sicut avis deponens ad sedendum, aspergit nivem, et sicut locusta demergens descensus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 20,
      "referenceLabel": "Sirach 43:20",
      "text": "Pulchritudinem candoris ejus admirabitur oculus, et super imbrem ejus expavescet cor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 21,
      "referenceLabel": "Sirach 43:21",
      "text": "Gelu sicut salem effundet super terram: et dum gelaverit, fiet tamquam cacumina tribuli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 22,
      "referenceLabel": "Sirach 43:22",
      "text": "Frigidus ventus aquilo flavit, et gelavit crystallus ab aqua: super omnem congregationem aquarum requiescet, et sicut lorica induet se aquis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 23,
      "referenceLabel": "Sirach 43:23",
      "text": "et devorabit montes, et exuret desertum, et extinguet viride, sicut igne.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 24,
      "referenceLabel": "Sirach 43:24",
      "text": "Medicina omnium in festinatione nebulæ: et ros obvians ab ardore venienti humilem efficiet eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 25,
      "referenceLabel": "Sirach 43:25",
      "text": "In sermone ejus siluit ventus, et cogitatione sua placavit abyssum: et plantavit in illa Dominus insulas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 26,
      "referenceLabel": "Sirach 43:26",
      "text": "Qui navigant mare enarrent pericula ejus, et audientes auribus nostris admirabimur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 27,
      "referenceLabel": "Sirach 43:27",
      "text": "Illic præclara opera et mirabilia, varia bestiarum genera, et omnium pecorum, et creatura belluarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 28,
      "referenceLabel": "Sirach 43:28",
      "text": "Propter ipsum confirmatus est itineris finis, et in sermone ejus composita sunt omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 29,
      "referenceLabel": "Sirach 43:29",
      "text": "Multa dicemus, et deficiemus in verbis: consummatio autem sermonum ipse est in omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 30,
      "referenceLabel": "Sirach 43:30",
      "text": "Gloriantes ad quid valebimus? ipse enim omnipotens super omnia opera sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 31,
      "referenceLabel": "Sirach 43:31",
      "text": "Terribilis Dominus, et magnus vehementer, et mirabilis potentia ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 32,
      "referenceLabel": "Sirach 43:32",
      "text": "Glorificantes Dominum quantumcumque potueritis, supervalebit enim adhuc: et admirabilis magnificentia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 33,
      "referenceLabel": "Sirach 43:33",
      "text": "Benedicentes Dominum, exaltate illum quantum potestis: major enim est omni laude.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 34,
      "referenceLabel": "Sirach 43:34",
      "text": "Exaltantes eum, replemini virtute, ne laboretis, non enim comprehendetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 35,
      "referenceLabel": "Sirach 43:35",
      "text": "Quis videbit eum et enarrabit? et quis magnificabit eum sicut est ab initio?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 36,
      "referenceLabel": "Sirach 43:36",
      "text": "Multa abscondita sunt majora his: pauca enim vidimus operum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.43.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 43,
      "verseNumber": 37,
      "referenceLabel": "Sirach 43:37",
      "text": "Omnia autem Dominus fecit, et pie agentibus dedit sapientiam.",
      "paragraphStart": false
    }
  ]
}
