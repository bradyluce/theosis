{
  "chapter": {
    "id": "vulgate:sirach.27",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 27,
    "referenceLabel": "Sirach 27",
    "summary": "Source text for Sirach 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.27.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Sirach 27:1",
      "text": "Propter inopiam multi deliquerunt: et qui quærit locupletari avertit oculum suum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.27.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Sirach 27:2",
      "text": "Sicut in medio compaginis lapidum palus figitur, sic et inter medium venditionis et emptionis angustiabitur peccatum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Sirach 27:3",
      "text": "conteretur cum delinquente delictum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Sirach 27:4",
      "text": "Si non in timore Domini tenueris te instanter, cito subvertetur domus tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Sirach 27:5",
      "text": "Sicut in percussura cribri remanebit pulvis, sic aporia hominis in cogitatu illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Sirach 27:6",
      "text": "Vasa figuli probat fornax, et homines justos tentatio tribulationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Sirach 27:7",
      "text": "Sicut rusticatio de ligno ostendit fructum illius, sic verbum ex cogitatu cordis hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Sirach 27:8",
      "text": "Ante sermonem non laudes virum: hæc enim tentatio est hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Sirach 27:9",
      "text": "Si sequaris justitiam, apprehendes illam, et indues quasi poderem honoris: et inhabitabis cum ea, et proteget te in sempiternum, et in die agnitionis invenies firmamentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Sirach 27:10",
      "text": "Volatilia ad sibi similia conveniunt: et veritas ad eos qui operantur illam revertetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Sirach 27:11",
      "text": "Leo venationi insidiatur semper: sic peccata operantibus iniquitates.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Sirach 27:12",
      "text": "Homo sanctus in sapientia manet sicut sol: nam stultus sicut luna mutatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Sirach 27:13",
      "text": "In medio insensatorum serva verbum tempori: in medio autem cogitantium assiduus esto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Sirach 27:14",
      "text": "Narratio peccantium odiosa, et risus illorum in deliciis peccati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Sirach 27:15",
      "text": "Loquela multum jurans horripilationem capiti statuet, et irreverentia ipsius obturatio aurium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Sirach 27:16",
      "text": "Effusio sanguinis in rixa superborum, et maledictio illorum auditus gravis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Sirach 27:17",
      "text": "Qui denudat arcana amici fidem perdit, et non inveniet amicum ad animum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Sirach 27:18",
      "text": "Dilige proximum, et conjungere fide cum illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Sirach 27:19",
      "text": "Quod si denudaveris absconsa illius, non persequeris post eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Sirach 27:20",
      "text": "Sicut enim homo qui perdit amicum suum, sic et qui perdit amicitiam proximi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Sirach 27:21",
      "text": "Et sicut qui dimittit avem de manu sua, sic dereliquisti proximum tuum, et non eum capies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Sirach 27:22",
      "text": "Non illum sequaris, quoniam longe abest: effugit enim quasi caprea de laqueo, quoniam vulnerata est anima ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Sirach 27:23",
      "text": "ultra eum non poteris colligare. Et maledicti est concordatio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Sirach 27:24",
      "text": "denudare autem amici mysteria, desperatio est animæ infelicis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Sirach 27:25",
      "text": "Annuens oculo fabricat iniqua, et nemo eum abjiciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Sirach 27:26",
      "text": "In conspectu oculorum tuorum condulcabit os suum, et super sermones tuos admirabitur: novissime autem pervertet os suum, et in verbis tuis dabit scandalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Sirach 27:27",
      "text": "Multa odivi, et non coæquavi ei, et Dominus odiet illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 28,
      "referenceLabel": "Sirach 27:28",
      "text": "Qui in altum mittit lapidem, super caput ejus cadet: et plaga dolosa dolosi dividet vulnera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 29,
      "referenceLabel": "Sirach 27:29",
      "text": "Et qui foveam fodit incidet in eam: et qui statuit lapidem proximo offendet in eo: et qui laqueum alii ponit, peribit in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 30,
      "referenceLabel": "Sirach 27:30",
      "text": "Facienti nequissimum consilium, super ipsum devolvetur, et non agnoscet unde adveniat illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 31,
      "referenceLabel": "Sirach 27:31",
      "text": "Illusio et improperium superborum, et vindicta sicut leo insidiabitur illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 32,
      "referenceLabel": "Sirach 27:32",
      "text": "Laqueo peribunt qui oblectantur casu justorum, dolor autem consumet illos antequam moriantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.27.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 27,
      "verseNumber": 33,
      "referenceLabel": "Sirach 27:33",
      "text": "Ira et furor utraque execrabilia sunt, et vir peccator continens erit illorum.",
      "paragraphStart": false
    }
  ]
}
