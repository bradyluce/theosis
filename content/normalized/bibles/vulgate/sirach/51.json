{
  "chapter": {
    "id": "vulgate:sirach.51",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 51,
    "referenceLabel": "Sirach 51",
    "summary": "Source text for Sirach 51 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.51.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Sirach 51:1",
      "text": "Oratio Jesu filii Sirach. Confitebor tibi, Domine rex, et collaudabo te Deum salvatorem meum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.51.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Sirach 51:2",
      "text": "Confitebor nomini tuo, quoniam adjutor et protector factus es mihi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Sirach 51:3",
      "text": "et liberasti corpus meum a perditione: a laqueo linguæ iniquæ, et a labiis operantium mendacium: et in conspectu astantium factus es mihi adjutor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Sirach 51:4",
      "text": "Et liberasti me, secundum multitudinem misericordiæ nominis tui, a rugientibus præparatis ad escam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Sirach 51:5",
      "text": "de manibus quærentium animam meam, et de portis tribulationum quæ circumdederunt me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Sirach 51:6",
      "text": "a pressura flammæ quæ circumdedit me, et in medio ignis non sum æstuatus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Sirach 51:7",
      "text": "de altitudine ventris inferi, et a lingua coinquinata, et a verbo mendacii, a rege iniquo, et a lingua injusta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Sirach 51:8",
      "text": "Laudabit usque ad mortem anima mea Dominum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Sirach 51:9",
      "text": "et vita mea appropinquans erat in inferno deorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Sirach 51:10",
      "text": "Circumdederunt me undique, et non erat qui adjuvaret: respiciens eram ad adjutorium hominum, et non erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Sirach 51:11",
      "text": "Memoratus sum misericordiæ tuæ Domine, et operationis tuæ, quæ a sæculo sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 12,
      "referenceLabel": "Sirach 51:12",
      "text": "quoniam eruis sustinentes te, Domine, et liberas eos de manibus gentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 13,
      "referenceLabel": "Sirach 51:13",
      "text": "Exaltasti super terram habitationem meam, et pro morte defluente deprecatus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 14,
      "referenceLabel": "Sirach 51:14",
      "text": "Invocavi Dominum patrem Domini mei, ut non derelinquat me in die tribulationis meæ, et in tempore superborum, sine adjutorio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 15,
      "referenceLabel": "Sirach 51:15",
      "text": "Laudabo nomen tuum assidue, et collaudabo illud in confessione: et exaudita est oratio mea,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 16,
      "referenceLabel": "Sirach 51:16",
      "text": "et liberasti me de perditione, et eripuisti me de tempore iniquo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 17,
      "referenceLabel": "Sirach 51:17",
      "text": "Propterea confitebor, et laudem dicam tibi, et benedicam nomini Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 18,
      "referenceLabel": "Sirach 51:18",
      "text": "Cum adhuc junior essem, priusquam oberrarem, quæsivi sapientiam palam in oratione mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 19,
      "referenceLabel": "Sirach 51:19",
      "text": "Ante templum postulabam pro illis, et usque in novissimis inquiram eam: et effloruit tamquam præcox uva.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 20,
      "referenceLabel": "Sirach 51:20",
      "text": "Lætatum est cor meum in ea: ambulavit pes meus iter rectum: a juventute mea investigabam eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 21,
      "referenceLabel": "Sirach 51:21",
      "text": "Inclinavi modico aurem meam, et excepi illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 22,
      "referenceLabel": "Sirach 51:22",
      "text": "Multam inveni in meipso sapientiam, et multum profeci in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 23,
      "referenceLabel": "Sirach 51:23",
      "text": "Danti mihi sapientiam dabo gloriam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 24,
      "referenceLabel": "Sirach 51:24",
      "text": "consiliatus sum enim ut facerem illam. Zelatus sum bonum, et non confundar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 25,
      "referenceLabel": "Sirach 51:25",
      "text": "Colluctata est anima mea in illa, et in faciendo eam confirmatus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 26,
      "referenceLabel": "Sirach 51:26",
      "text": "Manus meas extendi in altum, et insipientiam ejus luxi;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 27,
      "referenceLabel": "Sirach 51:27",
      "text": "animam meam direxi ad illam, et in agnitione inveni eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 28,
      "referenceLabel": "Sirach 51:28",
      "text": "Possedi cum ipsa cor ab initio: propter hoc, non derelinquar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 29,
      "referenceLabel": "Sirach 51:29",
      "text": "Venter meus conturbatus est quærendo illam: propterea bonam possidebo possessionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 30,
      "referenceLabel": "Sirach 51:30",
      "text": "Dedit mihi Dominus linguam mercedem meam, et in ipsa laudabo eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 31,
      "referenceLabel": "Sirach 51:31",
      "text": "Appropiate ad me, indocti, et congregate vos in domum disciplinæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 32,
      "referenceLabel": "Sirach 51:32",
      "text": "Quid adhuc retardatis? et quid dicitis in his? animæ vestræ sitiunt vehementer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 33,
      "referenceLabel": "Sirach 51:33",
      "text": "Aperui os meum, et locutus sum: Comparate vobis sine argento,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 34,
      "referenceLabel": "Sirach 51:34",
      "text": "et collum vestrum subjicite jugo: et suscipiat anima vestra disciplinam: in proximo est enim invenire eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 35,
      "referenceLabel": "Sirach 51:35",
      "text": "Videte oculis vestris, quia modicum laboravi, et inveni mihi multam requiem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 36,
      "referenceLabel": "Sirach 51:36",
      "text": "Assumite disciplinam in multo numero argenti, et copiosum aurum possidete in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 37,
      "referenceLabel": "Sirach 51:37",
      "text": "Lætetur anima vestra in misericordia ejus, et non confundemini in laude ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.51.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 51,
      "verseNumber": 38,
      "referenceLabel": "Sirach 51:38",
      "text": "Operamini opus vestrum ante tempus, et dabit vobis mercedem vestram in tempore suo.",
      "paragraphStart": false
    }
  ]
}
