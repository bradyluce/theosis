{
  "chapter": {
    "id": "vulgate:sirach.24",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 24,
    "referenceLabel": "Sirach 24",
    "summary": "Source text for Sirach 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.24.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Sirach 24:1",
      "text": "Sapientia laudabit animam suam, et in Deo honorabitur, et in medio populi sui gloriabitur,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.24.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Sirach 24:2",
      "text": "et in ecclesiis Altissimi aperiet os suum, et in conspectu virtutis illius gloriabitur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Sirach 24:3",
      "text": "et in medio populi sui exaltabitur, et in plenitudine sancta admirabitur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Sirach 24:4",
      "text": "et in multitudine electorum habebit laudem, et inter benedictos benedicetur, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Sirach 24:5",
      "text": "Ego ex ore Altissimi prodivi, primogenita ante omnem creaturam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Sirach 24:6",
      "text": "Ego feci in cælis ut oriretur lumen indeficiens, et sicut nebula texi omnem terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Sirach 24:7",
      "text": "Ego in altissimis habitavi, et thronus meus in columna nubis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Sirach 24:8",
      "text": "Gyrum cæli circuivi sola, et profundum abyssi penetravi: in fluctibus maris ambulavi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Sirach 24:9",
      "text": "Et in omni terra steti: et in omni populo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Sirach 24:10",
      "text": "et in omni gente primatum habui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Sirach 24:11",
      "text": "et omnium excellentium et humilium corda virtute calcavi. Et in his omnibus requiem quæsivi, et in hæreditate Domini morabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Sirach 24:12",
      "text": "Tunc præcepit, et dixit mihi Creator omnium: et qui creavit me, requievit in tabernaculo meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Sirach 24:13",
      "text": "Et dixit mihi: In Jacob inhabita, et in Israël hæreditare, et in electis meis mitte radices.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Sirach 24:14",
      "text": "Ab initio et ante sæcula creata sum, et usque ad futurum sæculum non desinam: et in habitatione sancta coram ipso ministravi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Sirach 24:15",
      "text": "Et sic in Sion firmata sum, et in civitate sanctificata similiter requievi, et in Jerusalem potestas mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Sirach 24:16",
      "text": "Et radicavi in populo honorificato, et in parte Dei mei hæreditas illius, et in plenitudine sanctorum detentio mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Sirach 24:17",
      "text": "Quasi cedrus exaltata sum in Libano, et quasi cypressus in monte Sion:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Sirach 24:18",
      "text": "quasi palma exaltata sum in Cades, et quasi plantatio rosæ in Jericho:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Sirach 24:19",
      "text": "quasi oliva speciosa in campis, et quasi platanus exaltata sum juxta aquam in plateis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Sirach 24:20",
      "text": "Sicut cinnamomum et balsamum aromatizans odorem dedi; quasi myrrha electa dedi suavitatem odoris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Sirach 24:21",
      "text": "et quasi storax, et galbanus, et ungula, et gutta, et quasi Libanus non incisus vaporavi habitationem meam, et quasi balsamum non mistum odor meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Sirach 24:22",
      "text": "Ego quasi terebinthus extendi ramos meos, et rami mei honoris et gratiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Sirach 24:23",
      "text": "Ego quasi vitis fructificavi suavitatem odoris: et flores mei fructus honoris et honestatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Sirach 24:24",
      "text": "Ego mater pulchræ dilectionis, et timoris, et agnitionis, et sanctæ spei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Sirach 24:25",
      "text": "In me gratia omnis viæ et veritatis: in me omnis spes vitæ et virtutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Sirach 24:26",
      "text": "Transite ad me, omnes qui concupiscitis me, et a generationibus meis implemini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Sirach 24:27",
      "text": "spiritus enim meus super mel dulcis, et hæreditas mea super mel et favum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Sirach 24:28",
      "text": "Memoria mea in generatione sæculorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Sirach 24:29",
      "text": "Qui edunt me, adhuc esurient, et qui bibunt me, adhuc sitient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Sirach 24:30",
      "text": "Qui audit me non confundetur, et qui operantur in me non peccabunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Sirach 24:31",
      "text": "qui elucidant me, vitam æternam habebunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Sirach 24:32",
      "text": "Hæc omnia liber vitæ, et testamentum Altissimi, et agnitio veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Sirach 24:33",
      "text": "Legem mandavit Moyses in præceptis justitiarum, et hæreditatem domui Jacob, et Israël promissiones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Sirach 24:34",
      "text": "Posuit David, puero suo, excitare regem ex ipso fortissimum, et in throno honoris sedentem in sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 35,
      "referenceLabel": "Sirach 24:35",
      "text": "Qui implet quasi Phison sapientiam, et sicut Tigris in diebus novorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 36,
      "referenceLabel": "Sirach 24:36",
      "text": "qui adimplet quasi Euphrates sensum, qui multiplicat quasi Jordanis in tempore messis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 37,
      "referenceLabel": "Sirach 24:37",
      "text": "qui mittit disciplinam sicut lucem, et assistens quasi Gehon in die vindemiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 38,
      "referenceLabel": "Sirach 24:38",
      "text": "Qui perficit primus scire ipsam, et infirmior non investigabit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.39",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 39,
      "referenceLabel": "Sirach 24:39",
      "text": "A mari enim abundavit cogitatio ejus, et consilium illius ab abysso magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.40",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 40,
      "referenceLabel": "Sirach 24:40",
      "text": "Ego sapientiam effudi flumina:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.41",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 41,
      "referenceLabel": "Sirach 24:41",
      "text": "ego quasi trames aquæ immensæ de fluvio: ego quasi fluvii dioryx, et sicut aquæductus exivi de paradiso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.42",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 42,
      "referenceLabel": "Sirach 24:42",
      "text": "Dixi: Rigabo hortum meum plantationum, et inebriabo prati mei fructum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.43",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 43,
      "referenceLabel": "Sirach 24:43",
      "text": "Et ecce factus est mihi trames abundans, et fluvius meus appropinquavit ad mare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.44",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 44,
      "referenceLabel": "Sirach 24:44",
      "text": "quoniam doctrinam quasi antelucanum illumino omnibus, et enarrabo illam usque ad longinquum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.45",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 45,
      "referenceLabel": "Sirach 24:45",
      "text": "Penetrabo omnes inferiores partes terræ, et inspiciam omnes dormientes, et illuminabo omnes sperantes in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.46",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 46,
      "referenceLabel": "Sirach 24:46",
      "text": "Adhuc doctrinam quasi prophetiam effundam, et relinquam illam quærentibus sapientiam, et non desinam in progenies illorum usque in ævum sanctum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.24.47",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 24,
      "verseNumber": 47,
      "referenceLabel": "Sirach 24:47",
      "text": "Videte quoniam non soli mihi laboravi, sed omnibus exquirentibus veritatem.",
      "paragraphStart": false
    }
  ]
}
