{
  "chapter": {
    "id": "vulgate:sirach.16",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 16,
    "referenceLabel": "Sirach 16",
    "summary": "Source text for Sirach 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.16.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Sirach 16:1",
      "text": "Ne jucunderis in filiis impiis, si multiplicentur: nec oblecteris super ipsos, si non est timor Dei in illis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.16.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Sirach 16:2",
      "text": "Non credas vitæ illorum, et ne respexeris in labores eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Sirach 16:3",
      "text": "Melior est enim unus timens Deum, quam mille filii impii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Sirach 16:4",
      "text": "et utile est mori sine filiis, quam relinquere filios impios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Sirach 16:5",
      "text": "Ab uno sensato inhabitabitur patria: tribus impiorum deseretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Sirach 16:6",
      "text": "Multa talia vidit oculis meus, et fortiora horum audivit auris mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Sirach 16:7",
      "text": "In synagoga peccantium exardebit ignis, et in gente incredibili exardescet ira.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Sirach 16:8",
      "text": "Non exoraverunt pro peccatis suis antiqui gigantes, qui destructi sunt confidentes suæ virtuti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Sirach 16:9",
      "text": "Et non pepercit peregrinationi Lot, et execratus est eos præ superbia verbi illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Sirach 16:10",
      "text": "Non misertus est illis, gentem totam perdens, et extollentem se in peccatis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Sirach 16:11",
      "text": "Et sicut sexcenta millia peditum, qui congregati sunt in duritia cordis sui: et si unus fuisset cervicatus, mirum si fuisset immunis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Sirach 16:12",
      "text": "Misericordia enim et ira est cum illo: potens exoratio, et effundens iram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Sirach 16:13",
      "text": "Secundum misericordiam suam, sic correptio illius homines secundum opera sua judicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Sirach 16:14",
      "text": "Non effugiet in rapina peccator, et non retardabit sufferentia misericordiam facientis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Sirach 16:15",
      "text": "Omnis misericordia faciet locum unicuique, secundum meritum operum suorum, et secundum intellectum peregrinationis ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Sirach 16:16",
      "text": "Non dicas: A Deo abscondar: et ex summo, quis mei memorabitur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Sirach 16:17",
      "text": "in populo magno non agnoscar: quæ est enim anima mea in tam immensa creatura?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Sirach 16:18",
      "text": "Ecce cælum et cæli cælorum, abyssus, et universa terra, et quæ in eis sunt, in conspectu illius commovebuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Sirach 16:19",
      "text": "Montes simul, et colles, et fundamenta terræ, cum conspexerit illa Deus, tremore concutientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Sirach 16:20",
      "text": "Et in omnibus his insensatum est cor, et omne cor intelligitur ab illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Sirach 16:21",
      "text": "Et vias illius quis intelligit, et procellam quam nec oculus videbit hominis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Sirach 16:22",
      "text": "Nam plurima illius opera sunt in absconsis: sed opera justitiæ ejus quis enuntiabit, aut quis sustinebit? longe enim est testamentum a quibusdam, et interrogatio omnium in consummatione est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Sirach 16:23",
      "text": "Qui minoratur corde cogitat inania, et vir imprudens et errans cogitat stulta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Sirach 16:24",
      "text": "Audi me, fili, et disce disciplinam sensus, et in verbis meis attende in corde tuo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Sirach 16:25",
      "text": "et dicam in æquitate disciplinam, et scrutabor enarrare sapientiam: et in verbis meis attende in corde tuo, et dico in æquitate spiritus virtutes quas posuit Deus in opera sua ab initio, et in veritate enuntio scientiam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Sirach 16:26",
      "text": "In judicio Dei opera ejus ab initio, et ab institutione ipsorum distinxit partes illorum, et initia eorum in gentibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Sirach 16:27",
      "text": "Ornavit in æternum opera illorum: nec esurierunt, nec laboraverunt, et non destiterunt ab operibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Sirach 16:28",
      "text": "Unusquisque proximum sibi non angustiabit in æternum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Sirach 16:29",
      "text": "non sis incredibilis verbo illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Sirach 16:30",
      "text": "Post hæc Deus in terram respexit, et implevit illam bonis suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.16.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Sirach 16:31",
      "text": "anima omnis vitalis denuntiavit ante faciem ipsius, et in ipsam iterum reversio illorum.",
      "paragraphStart": false
    }
  ]
}
