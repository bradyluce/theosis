{
  "chapter": {
    "id": "vulgate:sirach.15",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 15,
    "referenceLabel": "Sirach 15",
    "summary": "Source text for Sirach 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.15.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Sirach 15:1",
      "text": "Qui timet Deum faciet bona, et qui continens est justitiæ apprehendet illam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.15.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Sirach 15:2",
      "text": "et obviabit illi quasi mater honorificata, et quasi mulier a virginitate suscipiet illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Sirach 15:3",
      "text": "Cibabit illum pane vitæ et intellectus, et aqua sapientiæ salutaris potabit illum: et firmabitur in illo, et non flectetur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Sirach 15:4",
      "text": "et continebit illum, et non confundetur: et exaltabit illum apud proximos suos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Sirach 15:5",
      "text": "et in medio ecclesiæ aperiet os ejus, et adimplebit illum spiritu sapientiæ et intellectus, et stola gloriæ vestiet illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Sirach 15:6",
      "text": "Jucunditatem et exsultationem thesaurizabit super illum, et nomine æterno hæreditabit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Sirach 15:7",
      "text": "Homines stulti non apprehendent illam, et homines sensati obviabunt illi. Homines stulti non videbunt eam: longe enim abest a superbia et dolo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Sirach 15:8",
      "text": "Viri mendaces non erunt illius memores: et viri veraces invenientur in illa, et successum habebunt usque ad inspectionem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Sirach 15:9",
      "text": "Non est speciosa laus in ore peccatoris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Sirach 15:10",
      "text": "quoniam a Deo profecta est sapientia. Sapientiæ enim Dei astabit laus, et in ore fideli abundabit, et Dominator dabit eam illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Sirach 15:11",
      "text": "Non dixeris: Per Deum abest: quæ enim odit ne feceris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Sirach 15:12",
      "text": "Non dicas: Ille me implanavit: non enim necessarii sunt ei homines impii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Sirach 15:13",
      "text": "Omne execramentum erroris odit Dominus, et non erit amabile timentibus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Sirach 15:14",
      "text": "Deus ab initio constituit hominem, et reliquit illum in manu consilii sui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Sirach 15:15",
      "text": "adjecit mandata et præcepta sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Sirach 15:16",
      "text": "Si volueris mandata servare, conservabunt te, et in perpetuum fidem placitam facere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Sirach 15:17",
      "text": "Apposuit tibi aquam et ignem, ad quod volueris porrige manum tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Sirach 15:18",
      "text": "Ante hominem vita et mors, bonum et malum: quod placuerit ei dabitur illi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Sirach 15:19",
      "text": "quoniam multa sapientia Dei, et fortis in potentia, videns omnes sine intermissione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Sirach 15:20",
      "text": "Oculi Domini ad timentes eum, et ipse agnoscit omnem operam hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Sirach 15:21",
      "text": "Nemini mandavit impie agere, et nemini dedit spatium peccandi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.15.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Sirach 15:22",
      "text": "non enim concupiscit multitudinem filiorum infidelium et inutilium.",
      "paragraphStart": false
    }
  ]
}
