{
  "chapter": {
    "id": "vulgate:sirach.20",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 20,
    "referenceLabel": "Sirach 20",
    "summary": "Source text for Sirach 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.20.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Sirach 20:1",
      "text": "Quam bonum est arguere, quam irasci, et confitentem in oratione non prohibere!",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.20.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Sirach 20:2",
      "text": "Concupiscentia spadonis devirginabit juvenculam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Sirach 20:3",
      "text": "sic qui facit per vim judicium iniquum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Sirach 20:4",
      "text": "Quam bonum est correptum manifestare pœnitentiam! sic enim effugies voluntarium peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Sirach 20:5",
      "text": "Est tacens qui invenitur sapiens: et est odibilis qui procax est ad loquendum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Sirach 20:6",
      "text": "Est tacens non habens sensum loquelæ: et est tacens sciens tempus aptum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Sirach 20:7",
      "text": "Homo sapiens tacebit usque ad tempus: lascivus autem et imprudens non servabunt tempus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Sirach 20:8",
      "text": "Qui multis utitur verbis lædet animam suam: et qui potestatem sibi sumit injuste, odietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Sirach 20:9",
      "text": "Est processio in malis viro indisciplinato, et est inventio in detrimentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Sirach 20:10",
      "text": "Est datum quod non est utile, et est datum cujus retributio duplex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Sirach 20:11",
      "text": "Est propter gloriam minoratio, et est qui ab humilitate levabit caput.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Sirach 20:12",
      "text": "Est qui multa redimat modico pretio, et restituens ea in septuplum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Sirach 20:13",
      "text": "Sapiens in verbis seipsum amabilem facit: gratiæ autem fatuorum effundentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Sirach 20:14",
      "text": "Datus insipientis non erit utilis tibi: oculi enim illius septemplices sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Sirach 20:15",
      "text": "Exigua dabit, et multa improperabit: et apertio oris illius inflammatio est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Sirach 20:16",
      "text": "Hodie fœneratur quis, et cras expetit: odibilis est homo hujusmodi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Sirach 20:17",
      "text": "Fatuo non erit amicus, et non erit gratia bonis illius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Sirach 20:18",
      "text": "qui enim edunt panem illius, falsæ linguæ sunt. Quoties et quanti irridebunt eum!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Sirach 20:19",
      "text": "neque enim quod habendum erat directo sensu distribuit; similiter et quod non erat habendum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Sirach 20:20",
      "text": "Lapsus falsæ linguæ quasi qui in pavimento cadens: sic casus malorum festinanter veniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Sirach 20:21",
      "text": "Homo acharis quasi fabula vana, in ore indisciplinatorum assidua erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Sirach 20:22",
      "text": "Ex ore fatui reprobabitur parabola: non enim dicit illam in tempore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Sirach 20:23",
      "text": "Est qui vetatur peccare præ inopia, et in requie sua stimulabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Sirach 20:24",
      "text": "Est qui perdet animam suam præ confusione, et ab imprudenti persona perdet eam: personæ autem acceptione perdet se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Sirach 20:25",
      "text": "Est qui præ confusione promittit amico, et lucratus est eum inimicum gratis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Sirach 20:26",
      "text": "Opprobrium nequam in homine mendacium: et in ore indisciplinatorum assidue erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Sirach 20:27",
      "text": "Potior fur quam assiduitas viri mendacis: perditionem autem ambo hæreditabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Sirach 20:28",
      "text": "Mores hominum mendacium sine honore, et confusio illorum cum ipsis sine intermissione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Sirach 20:29",
      "text": "Sapiens in verbis producet seipsum, et homo prudens placebit magnatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Sirach 20:30",
      "text": "Qui operatur terram suam inaltabit acervum frugum, et qui operatur justitiam, ipse exaltabitur: qui vero placet magnatis effugiet iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Sirach 20:31",
      "text": "Xenia et dona excæcant oculos judicum, et quasi mutus, in ore avertit correptiones eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Sirach 20:32",
      "text": "Sapientia absconsa, et thesaurus invisus, quæ utilitas in utrisque?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.20.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Sirach 20:33",
      "text": "Melior est qui celat insipientiam suam, quam homo qui abscondit sapientiam suam.",
      "paragraphStart": false
    }
  ]
}
