{
  "chapter": {
    "id": "vulgate:sirach.44",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 44,
    "referenceLabel": "Sirach 44",
    "summary": "Source text for Sirach 44 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.44.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 1,
      "referenceLabel": "Sirach 44:1",
      "text": "Laudemus viros gloriosos, et parentes nostros in generatione sua.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.44.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 2,
      "referenceLabel": "Sirach 44:2",
      "text": "Multam gloriam fecit Dominus: magnificentia sua a sæculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 3,
      "referenceLabel": "Sirach 44:3",
      "text": "Dominantes in potestatibus suis, homines magni virtute et prudentia sua præditi, nuntiantes in prophetis dignitatem prophetarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 4,
      "referenceLabel": "Sirach 44:4",
      "text": "et imperantes in præsenti populo, et virtute prudentiæ populis sanctissima verba:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 5,
      "referenceLabel": "Sirach 44:5",
      "text": "in peritia sua requirentes modos musicos, et narrantes carmina Scripturarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 6,
      "referenceLabel": "Sirach 44:6",
      "text": "homines divites in virtute, pulchritudinis studium habentes, pacificantes in domibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 7,
      "referenceLabel": "Sirach 44:7",
      "text": "Omnes isti in generationibus gentis suæ gloriam adepti sunt, et in diebus suis habentur in laudibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 8,
      "referenceLabel": "Sirach 44:8",
      "text": "Qui de illis nati sunt reliquerunt nomen narrandi laudes eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 9,
      "referenceLabel": "Sirach 44:9",
      "text": "Et sunt quorum non est memoria: perierunt quasi qui non fuerint: et nati sunt quasi non nati, et filii ipsorum cum ipsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 10,
      "referenceLabel": "Sirach 44:10",
      "text": "Sed illi viri misericordiæ sunt, quorum pietates non defuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 11,
      "referenceLabel": "Sirach 44:11",
      "text": "Cum semine eorum permanent bona:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 12,
      "referenceLabel": "Sirach 44:12",
      "text": "hæreditas sancta nepotes eorum, et in testamentis stetit semen eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 13,
      "referenceLabel": "Sirach 44:13",
      "text": "et filii eorum propter illos usque in æternum manent: semen eorum et gloria eorum non derelinquetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 14,
      "referenceLabel": "Sirach 44:14",
      "text": "Corpora ipsorum in pace sepulta sunt, et nomen eorum vivit in generationem et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 15,
      "referenceLabel": "Sirach 44:15",
      "text": "Sapientiam ipsorum narrent populi, et laudem eorum nuntiet ecclesia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 16,
      "referenceLabel": "Sirach 44:16",
      "text": "Enoch placuit Deo, et translatus est in paradisum, ut det gentibus pœnitentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 17,
      "referenceLabel": "Sirach 44:17",
      "text": "Noë inventus est perfectus, justus, et in tempore iracundiæ factus est reconciliatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 18,
      "referenceLabel": "Sirach 44:18",
      "text": "Ideo dimissum est reliquum terræ, cum factum est diluvium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 19,
      "referenceLabel": "Sirach 44:19",
      "text": "Testamenta sæculi posita sunt apud illum, ne deleri possit diluvio omnis caro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 20,
      "referenceLabel": "Sirach 44:20",
      "text": "Abraham magnus pater multitudinis gentium, et non est inventus similis illi in gloria: qui conservavit legem Excelsi, et fuit in testamento cum illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 21,
      "referenceLabel": "Sirach 44:21",
      "text": "In carne ejus stare fecit testamentum, et in tentatione inventus est fidelis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 22,
      "referenceLabel": "Sirach 44:22",
      "text": "Ideo jurejurando dedit illi gloriam in gente sua, crescere illum quasi terræ cumulum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 23,
      "referenceLabel": "Sirach 44:23",
      "text": "et ut stellas exaltare semen ejus, et hæreditare illos a mari usque ad mare, et a flumine usque ad terminos terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 24,
      "referenceLabel": "Sirach 44:24",
      "text": "Et in Isaac eodem modo fecit, propter Abraham patrem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 25,
      "referenceLabel": "Sirach 44:25",
      "text": "Benedictionem omnium gentium dedit illi Dominus, et testamentum confirmavit super caput Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 26,
      "referenceLabel": "Sirach 44:26",
      "text": "Agnovit eum in benedictionibus suis, et dedit illi hæreditatem, et divisit illi partem in tribubus duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.44.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 44,
      "verseNumber": 27,
      "referenceLabel": "Sirach 44:27",
      "text": "Et conservavit illi homines misericordiæ, invenientes gratiam in oculis omnis carnis.",
      "paragraphStart": false
    }
  ]
}
