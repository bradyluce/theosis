{
  "chapter": {
    "id": "vulgate:sirach.18",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 18,
    "referenceLabel": "Sirach 18",
    "summary": "Source text for Sirach 18 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.18.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Sirach 18:1",
      "text": "Qui vivet in æternum creavit omnia simul. Deus solus justificabitur, et manet invictus rex in æternum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.18.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Sirach 18:2",
      "text": "Quis sufficit enarrare opera illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Sirach 18:3",
      "text": "quis enim investigabit magnalia ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Sirach 18:4",
      "text": "virtutem autem magnitudinis ejus quis enuntiabit? aut quis adjiciet enarrare misericordiam ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Sirach 18:5",
      "text": "Non est minuere neque adjicere, nec est invenire magnalia Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Sirach 18:6",
      "text": "Cum consummaverit homo, tunc incipiet: et cum quieverit, aporiabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Sirach 18:7",
      "text": "Quid est homo? et quæ est gratia illius? et quid bonum aut quid nequam illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Sirach 18:8",
      "text": "Numerus dierum hominum, ut multum centum anni, quasi gutta aquæ maris deputati sunt: et sicut calculus arenæ, sic exigui anni in die ævi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Sirach 18:9",
      "text": "Propter hoc patiens est Deus in illis, et effundit super eos misericordiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Sirach 18:10",
      "text": "Vidit præsumptionem cordis eorum, quoniam mala est: et cognovit subversionem illorum, quoniam nequam est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Sirach 18:11",
      "text": "Ideo adimplevit propitiationem suam in illis, et ostendit eis viam æquitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Sirach 18:12",
      "text": "Miseratio hominis circa proximum suum: misericordia autem Dei super omnem carnem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Sirach 18:13",
      "text": "Qui misericordiam habet, docet et erudit quasi pastor gregem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Sirach 18:14",
      "text": "Miseretur excipientis doctrinam miserationis, et qui festinat in judiciis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Sirach 18:15",
      "text": "Fili, in bonis non des querelam, et in omni dato non des tristitiam verbi mali.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Sirach 18:16",
      "text": "Nonne ardorem refrigerabit ros? sic et verbum melius quam datum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Sirach 18:17",
      "text": "Nonne ecce verbum super datum bonum? sed utraque cum homine justificato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Sirach 18:18",
      "text": "Stultus acriter improperabit: et datus indisciplinati tabescere facit oculos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Sirach 18:19",
      "text": "Ante judicium para justitiam tibi, et antequam loquaris, disce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Sirach 18:20",
      "text": "Ante languorem adhibe medicinam: et ante judicium interroga teipsum, et in conspectu Dei invenies propitiationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Sirach 18:21",
      "text": "Ante languorem humilia te, et in tempore infirmitatis ostende conversationem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Sirach 18:22",
      "text": "Non impediaris orare semper, et ne verearis usque ad mortem justificari, quoniam merces Dei manet in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Sirach 18:23",
      "text": "Ante orationem præpara animam tuam, et noli esse quasi homo qui tentat Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Sirach 18:24",
      "text": "Memento iræ in die consummationis, et tempus retributionis in conversatione faciei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Sirach 18:25",
      "text": "Memento paupertatis in tempore abundantiæ, et necessitatum paupertatis in die divitiarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "Sirach 18:26",
      "text": "A mane usque ad vesperam immutabitur tempus, et hæc omnia citata in oculis Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "Sirach 18:27",
      "text": "Homo sapiens in omnibus metuet, et in diebus delictorum attendet ab inertia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "Sirach 18:28",
      "text": "Omnis astutus agnoscit sapientiam, et invenienti eam dabit confessionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 29,
      "referenceLabel": "Sirach 18:29",
      "text": "Sensati in verbis et ipsi sapienter egerunt, et intellexerunt veritatem et justitiam, et impluerunt proverbia et judicia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 30,
      "referenceLabel": "Sirach 18:30",
      "text": "Post concupiscentias tuas non eas, et a voluntate tua avertere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 31,
      "referenceLabel": "Sirach 18:31",
      "text": "Si præstes animæ tuæ concupiscentias ejus, faciat te in gaudium inimicis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 32,
      "referenceLabel": "Sirach 18:32",
      "text": "Ne oblecteris in turbis nec in modicis: assidua enim est commissio illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.18.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 18,
      "verseNumber": 33,
      "referenceLabel": "Sirach 18:33",
      "text": "Ne fueris mediocris in contentione ex fœnore, et est tibi nihil in sacculo: eris enim invidus vitæ tuæ.",
      "paragraphStart": false
    }
  ]
}
