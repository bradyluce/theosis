{
  "chapter": {
    "id": "vulgate:sirach.39",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 39,
    "referenceLabel": "Sirach 39",
    "summary": "Source text for Sirach 39 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.39.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 1,
      "referenceLabel": "Sirach 39:1",
      "text": "Sapientiam omnium antiquorum exquiret sapiens, et in prophetis vacabit.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.39.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 2,
      "referenceLabel": "Sirach 39:2",
      "text": "Narrationem virorum nominatorum conservabit, et in versutias parabolarum simul introibit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 3,
      "referenceLabel": "Sirach 39:3",
      "text": "Occulta proverbiorum exquiret, et in absconditis parabolarum conversabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 4,
      "referenceLabel": "Sirach 39:4",
      "text": "In medio magnatorum ministrabit, et in conspectu præsidis apparebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 5,
      "referenceLabel": "Sirach 39:5",
      "text": "In terram alienigenarum gentium pertransiet: bona enim et mala in hominibus tentabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 6,
      "referenceLabel": "Sirach 39:6",
      "text": "Cor suum tradet ad vigilandum diluculo ad Dominum, qui fecit illum, et in conspectu Altissimi deprecabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 7,
      "referenceLabel": "Sirach 39:7",
      "text": "Aperiet os suum in oratione, et pro delictis suis deprecabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 8,
      "referenceLabel": "Sirach 39:8",
      "text": "Si enim Dominus magnus voluerit, spiritu intelligentiæ replebit illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 9,
      "referenceLabel": "Sirach 39:9",
      "text": "et ipse tamquam imbres mittet eloquia sapientiæ suæ, et in oratione confitebitur Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 10,
      "referenceLabel": "Sirach 39:10",
      "text": "et ipse diriget consilium ejus, et disciplinam, et in absconditis suis consiliabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 11,
      "referenceLabel": "Sirach 39:11",
      "text": "Ipse palam faciet disciplinam doctrinæ suæ, et in lege testamenti Domini gloriabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 12,
      "referenceLabel": "Sirach 39:12",
      "text": "Collaudabunt multi sapientiam ejus, et usque in sæculum non delebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 13,
      "referenceLabel": "Sirach 39:13",
      "text": "Non recedet memoria ejus, et nomen ejus requiretur a generatione in generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 14,
      "referenceLabel": "Sirach 39:14",
      "text": "Sapientiam ejus enarrabunt gentes, et laudem ejus enuntiabit ecclesia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 15,
      "referenceLabel": "Sirach 39:15",
      "text": "Si permanserit, nomen derelinquet plus quam mille: et si requieverit, proderit illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 16,
      "referenceLabel": "Sirach 39:16",
      "text": "Adhuc consiliabor ut enarrem: ut furore enim repletus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 17,
      "referenceLabel": "Sirach 39:17",
      "text": "In voce dicit: Obaudite me, divini fructus, et quasi rosa plantata super rivos aquarum fructificate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 18,
      "referenceLabel": "Sirach 39:18",
      "text": "Quasi Libanus odorem suavitatis habete.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 19,
      "referenceLabel": "Sirach 39:19",
      "text": "Florete flores quasi lilium: et date odorem, et frondete in gratiam: et collaudate canticum, et benedicite Dominum in operibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 20,
      "referenceLabel": "Sirach 39:20",
      "text": "Date nomini ejus magnificentiam, et confitemini illi in voce labiorum vestrorum, et in canticis labiorum, et citharis: et sic dicetis in confessione:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 21,
      "referenceLabel": "Sirach 39:21",
      "text": "Opera Domini universa bona valde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 22,
      "referenceLabel": "Sirach 39:22",
      "text": "In verbo ejus stetit aqua sicut congeries: et in sermone oris illius sicut exceptoria aquarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 23,
      "referenceLabel": "Sirach 39:23",
      "text": "quoniam in præcepto ipsius placor fit, et non est minoratio in salute ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 24,
      "referenceLabel": "Sirach 39:24",
      "text": "Opera omnis carnis coram illo, et non est quidquam absconditum ab oculis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 25,
      "referenceLabel": "Sirach 39:25",
      "text": "A sæculo usque in sæculum respicit, et nihil est mirabile in conspectu ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 26,
      "referenceLabel": "Sirach 39:26",
      "text": "Non est dicere: Quid est hoc, aut quid est istud? omnia enim in tempore suo quærentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 27,
      "referenceLabel": "Sirach 39:27",
      "text": "Benedictio illius quasi fluvius inundavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 28,
      "referenceLabel": "Sirach 39:28",
      "text": "Quomodo cataclysmus aridam inebriavit, sic ira ipsius gentes quæ non exquisierunt eum hæreditabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 29,
      "referenceLabel": "Sirach 39:29",
      "text": "Quomodo convertit aquas in siccitatem, et siccata est terra, et viæ illius viis illorum directæ sunt, sic peccatoribus offensiones in ira ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 30,
      "referenceLabel": "Sirach 39:30",
      "text": "Bona bonis creata sunt ab initio: sic nequissimis bona et mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 31,
      "referenceLabel": "Sirach 39:31",
      "text": "Initium necessariæ rei vitæ hominum, aqua, ignis, et ferrum, sal, lac, et panis similagineus, et mel, et botrus uvæ, et oleum, et vestimentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 32,
      "referenceLabel": "Sirach 39:32",
      "text": "Hæc omnia sanctis in bona, sic et impiis et peccatoribus in mala convertentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 33,
      "referenceLabel": "Sirach 39:33",
      "text": "Sunt spiritus qui ad vindictam creati sunt, et in furore suo confirmaverunt tormenta sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 34,
      "referenceLabel": "Sirach 39:34",
      "text": "In tempore consummationis effundent virtutem, et furorem ejus qui fecit illos placabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 35,
      "referenceLabel": "Sirach 39:35",
      "text": "Ignis, grando, fames, et mors, omnia hæc ad vindictam creata sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 36,
      "referenceLabel": "Sirach 39:36",
      "text": "bestiarum dentes, et scorpii, et serpentes, et rhomphæa vindicans in exterminium impios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 37,
      "referenceLabel": "Sirach 39:37",
      "text": "In mandatis ejus epulabuntur: et super terram in necessitatem præparabuntur, et in temporibus suis non præterient verbum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 38,
      "referenceLabel": "Sirach 39:38",
      "text": "Propterea ab initio confirmatus sum, et consiliatus sum, et cogitavi, et scripta dimisi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.39",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 39,
      "referenceLabel": "Sirach 39:39",
      "text": "Omnia opera Domini bona, et omne opus hora sua subministrabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.40",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 40,
      "referenceLabel": "Sirach 39:40",
      "text": "Non est dicere: Hoc illo nequius est: omnia enim in tempore suo comprobabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.39.41",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 39,
      "verseNumber": 41,
      "referenceLabel": "Sirach 39:41",
      "text": "Et nunc in omni corde et ore collaudate, et benedicite nomen Domini.",
      "paragraphStart": false
    }
  ]
}
