{
  "chapter": {
    "id": "vulgate:sirach.35",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 35,
    "referenceLabel": "Sirach 35",
    "summary": "Source text for Sirach 35 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.35.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Sirach 35:1",
      "text": "Qui conservat legem multiplicat oblationem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.35.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Sirach 35:2",
      "text": "Sacrificium salutare est attendere mandatis, et discedere ab omni iniquitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Sirach 35:3",
      "text": "Et propitiationem litare sacrificii super injustitias: et deprecatio pro peccatis, recedere ab injustitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Sirach 35:4",
      "text": "Retribuet gratiam qui offert similaginem: et qui facit misericordiam offert sacrificium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Sirach 35:5",
      "text": "Beneplacitum est Domino recedere ab iniquitate: et deprecatio pro peccatis recedere ab injustitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Sirach 35:6",
      "text": "Non apparebis ante conspectum Domini vacuus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Sirach 35:7",
      "text": "hæc enim omnia propter mandatum Dei fiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Sirach 35:8",
      "text": "Oblatio justi impinguat altare, et odor suavitatis est in conspectu Altissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Sirach 35:9",
      "text": "Sacrificium justi acceptum est, et memoriam ejus non obliviscetur Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Sirach 35:10",
      "text": "Bono animo gloriam redde Deo, et non minuas primitias manuum tuarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Sirach 35:11",
      "text": "In omni dato hilarem fac vultum tuum, et in exsultatione sanctifica decimas tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Sirach 35:12",
      "text": "Da Altissimo secundum datum ejus, et in bono oculo adinventionem facito manuum tuarum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Sirach 35:13",
      "text": "quoniam Dominus retribuens est, et septies tantum reddet tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Sirach 35:14",
      "text": "Noli offerre munera prava, non enim suscipiet illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Sirach 35:15",
      "text": "Et noli inspicere sacrificum injustum, quoniam Dominus judex est, et non est apud illum gloria personæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Sirach 35:16",
      "text": "Non accipiet Dominus personam in pauperem, et deprecationem læsi exaudiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Sirach 35:17",
      "text": "Non despiciet preces pupilli, nec viduam, si effundat loquelam gemitus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Sirach 35:18",
      "text": "Nonne lacrimæ viduæ ad maxillam descendunt, et exclamatio ejus super deducentem eas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Sirach 35:19",
      "text": "A maxilla enim ascendunt usque ad cælum, et Dominus exauditor non delectabitur in illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Sirach 35:20",
      "text": "Qui adorat Deum in oblectatione suscipietur, et deprecatio illius usque ad nubes propinquabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Sirach 35:21",
      "text": "Oratio humiliantis se nubes penetrabit, et donec propinquet non consolabitur, et non discedet donec Altissimus aspiciat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Sirach 35:22",
      "text": "Et Dominus non elongabit: et judicabit justos, et faciet judicium: et Fortissimus non habebit in illis patientiam, ut contribulet dorsum ipsorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Sirach 35:23",
      "text": "et gentibus reddet vindictam, donec tollat plenitudinem superborum, et sceptra iniquorum contribulet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Sirach 35:24",
      "text": "donec reddat hominibus secundum actus suos, et secundum opera Adæ, et secundum præsumptionem illius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Sirach 35:25",
      "text": "donec judicet judicium plebis suæ, et oblectabit justos misericordia sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.35.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Sirach 35:26",
      "text": "Speciosa misericordia Dei in tempore tribulationis, quasi nubes pluviæ in tempore siccitatis.",
      "paragraphStart": false
    }
  ]
}
