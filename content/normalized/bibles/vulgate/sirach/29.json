{
  "chapter": {
    "id": "vulgate:sirach.29",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 29,
    "referenceLabel": "Sirach 29",
    "summary": "Source text for Sirach 29 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.29.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Sirach 29:1",
      "text": "Qui facit misericordiam fœneratur proximo suo: et qui prævalet manu mandata servat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.29.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Sirach 29:2",
      "text": "Fœnerare proximo tuo in tempore necessitatis illius: et iterum redde proximo in tempore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Sirach 29:3",
      "text": "Confirma verbum, et fideliter age cum illo: et in omni tempore invenies quod tibi necessarium est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Sirach 29:4",
      "text": "Multi quasi inventionem æstimaverunt fœnus, et præstiterunt molestiam his qui se adjuverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Sirach 29:5",
      "text": "Donec accipiant, osculantur manus dantis, et in promissionibus humiliant vocem suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Sirach 29:6",
      "text": "et in tempore redditionis postulabit tempus, et loquetur verba tædii et murmurationum, et tempus causabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Sirach 29:7",
      "text": "Si autem potuerit reddere, adversabitur: solidi vix reddet dimidium, et computabit illud quasi inventionem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Sirach 29:8",
      "text": "sin autem, fraudabit illum pecunia sua, et possidebit illum inimicum gratis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Sirach 29:9",
      "text": "et convitia et maledicta reddet illi, et pro honore et beneficio reddet illi contumeliam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Sirach 29:10",
      "text": "Multi non causa nequitiæ non fœnerati sunt, sed fraudari gratis timuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Sirach 29:11",
      "text": "Verumtamen super humilem animo fortior esto, et pro eleemosyna non trahas illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Sirach 29:12",
      "text": "Propter mandatum assume pauperem, et propter inopiam ejus ne dimittas eum vacuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Sirach 29:13",
      "text": "Perde pecuniam propter fratrem et amicum tuum, et non abscondas illam sub lapide in perditionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Sirach 29:14",
      "text": "Pone thesaurum tuum in præceptis Altissimi, et proderit tibi magis quam aurum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Sirach 29:15",
      "text": "Conclude eleemosynam in corde pauperis, et hæc pro te exorabit ab omni malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Sirach 29:16",
      "text": "Super scutum potentis",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Sirach 29:17",
      "text": "et super lanceam",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Sirach 29:18",
      "text": "adversus inimicum tuum pugnabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Sirach 29:19",
      "text": "Vir bonus fidem facit pro proximo suo: et qui perdiderit confusionem derelinquet sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Sirach 29:20",
      "text": "Gratiam fidejussoris ne obliviscaris: dedit enim pro te animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Sirach 29:21",
      "text": "Repromissorem fugit peccator et immundus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Sirach 29:22",
      "text": "Bona repromissoris sibi ascribit peccator: et ingratus sensu derelinquet liberantem se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Sirach 29:23",
      "text": "Vir repromittit de proximo suo: et cum perdiderit reverentiam, derelinquetur ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Sirach 29:24",
      "text": "Repromissio nequissima multos perdidit dirigentes, et commovit illos quasi fluctus maris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Sirach 29:25",
      "text": "Viros potentes gyrans migrare fecit, et vagati sunt in gentibus alienis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Sirach 29:26",
      "text": "Peccator transgrediens mandatum Domini incidet in promissionem nequam: et qui conatur multa agere incidet in judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Sirach 29:27",
      "text": "Recupera proximum secundum virtutem tuam, et attende tibi ne incidas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 28,
      "referenceLabel": "Sirach 29:28",
      "text": "Initium vitæ hominis, aqua et panis, et vestimentum, et domus protegens turpitudinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 29,
      "referenceLabel": "Sirach 29:29",
      "text": "Melior est victus pauperis sub tegmine asserum quam epulæ splendidæ in peregre sine domicilio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 30,
      "referenceLabel": "Sirach 29:30",
      "text": "Minimum pro magno placeat tibi, et improperium peregrinationis non audies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 31,
      "referenceLabel": "Sirach 29:31",
      "text": "Vita nequam hospitandi de domo in domum: et ubi hospitabitur non fiducialiter aget, nec aperiet os.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 32,
      "referenceLabel": "Sirach 29:32",
      "text": "Hospitabitur, et pascet, et potabit ingratos, et ad hæc amara audiet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 33,
      "referenceLabel": "Sirach 29:33",
      "text": "transi, hospes, et orna mensam, et quæ in manu habes ciba ceteros.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 34,
      "referenceLabel": "Sirach 29:34",
      "text": "Exi a facie honoris amicorum meorum: necessitudine domus meæ hospitio mihi factus est frater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.29.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 29,
      "verseNumber": 35,
      "referenceLabel": "Sirach 29:35",
      "text": "Gravia hæc homini habenti sensum: correptio domus, et improperium fœneratoris.",
      "paragraphStart": false
    }
  ]
}
