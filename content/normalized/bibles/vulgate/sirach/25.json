{
  "chapter": {
    "id": "vulgate:sirach.25",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 25,
    "referenceLabel": "Sirach 25",
    "summary": "Source text for Sirach 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.25.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Sirach 25:1",
      "text": "In tribus placitum est spiritui meo, quæ sunt probata coram Deo et hominibus:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.25.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Sirach 25:2",
      "text": "concordia fratrum, et amor proximorum, et vir et mulier bene sibi consentientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Sirach 25:3",
      "text": "Tres species odivit anima mea, et aggravor valde animæ illorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Sirach 25:4",
      "text": "pauperem superbum, divitem mendacem, senem fatuum et insensatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Sirach 25:5",
      "text": "Quæ in juventute tua non congregasti, quomodo in senectute tua invenies?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Sirach 25:6",
      "text": "Quam speciosum canitiei judicium, et presbyteris cognoscere consilium!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Sirach 25:7",
      "text": "Quam speciosa veteranis sapientia, et gloriosus intellectus et consilium!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Sirach 25:8",
      "text": "Corona senum multa peritia, et gloria illorum timor Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Sirach 25:9",
      "text": "Novem insuspicabilia cordis magnificavi: et decimum dicam in lingua hominibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Sirach 25:10",
      "text": "homo qui jucundatur in filiis, vivens et videns subversionem inimicorum suorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Sirach 25:11",
      "text": "Beatus qui habitat cum muliere sensata, et qui lingua sua non est lapsus, et qui non servivit indignis se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Sirach 25:12",
      "text": "Beatus qui invenit amicum verum, et qui enarrat justitiam auri audienti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Sirach 25:13",
      "text": "Quam magnus qui invenit sapientiam et scientiam! sed non est super timentem Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Sirach 25:14",
      "text": "Timor Dei super omnia se superposuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Sirach 25:15",
      "text": "Beatus homo cui donatum est habere timorem Dei: qui tenet illum, cui assimilabitur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Sirach 25:16",
      "text": "Timor Dei initium dilectionis ejus: fidei autem initium agglutinandum est ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Sirach 25:17",
      "text": "Omnis plaga tristitia cordis est, et omnis malitia nequitia mulieris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Sirach 25:18",
      "text": "Et omnem plagam, et non plagam videbit cordis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Sirach 25:19",
      "text": "et omnem nequitiam, et non nequitiam mulieris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Sirach 25:20",
      "text": "et omnem obductum, et non obductum odientium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Sirach 25:21",
      "text": "et omnem vindictam, et non vindictam inimicorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Sirach 25:22",
      "text": "Non est caput nequius super caput colubri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Sirach 25:23",
      "text": "et non est ira super iram mulieris. Commorari leoni et draconi placebit, quam habitare cum muliere nequam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Sirach 25:24",
      "text": "Nequitia mulieris immutat faciem ejus: et obcæcat vultum suum tamquam ursus, et quasi saccum ostendit. In medio proximorum ejus",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Sirach 25:25",
      "text": "ingemuit vir ejus, et audiens suspiravit modicum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Sirach 25:26",
      "text": "Brevis omnis malitia super malitiam mulieris: sors peccatorum cadat super illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Sirach 25:27",
      "text": "Sicut ascensus arenosus in pedibus veterani, sic mulier linguata homini quieto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Sirach 25:28",
      "text": "Ne respicias in mulieris speciem, et non concupiscas mulierem in specie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "Sirach 25:29",
      "text": "Mulieris ira, et irreverentia, et confusio magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 30,
      "referenceLabel": "Sirach 25:30",
      "text": "Mulier si primatum habeat, contraria est viro suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 31,
      "referenceLabel": "Sirach 25:31",
      "text": "Cor humile, et facies tristis, et plaga cordis, mulier nequam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 32,
      "referenceLabel": "Sirach 25:32",
      "text": "Manus debiles et genua dissoluta, mulier quæ non beatificat virum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 33,
      "referenceLabel": "Sirach 25:33",
      "text": "A muliere initium factum est peccati, et per illam omnes morimur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 34,
      "referenceLabel": "Sirach 25:34",
      "text": "Non des aquæ tuæ exitum, nec modicum: nec mulieri nequam veniam prodeundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 35,
      "referenceLabel": "Sirach 25:35",
      "text": "Si non ambulaverit ad manum tuam, confundet te in conspectu inimicorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.25.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 25,
      "verseNumber": 36,
      "referenceLabel": "Sirach 25:36",
      "text": "A carnibus tuis abscinde illam, ne semper te abutatur.",
      "paragraphStart": false
    }
  ]
}
