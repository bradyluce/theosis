{
  "chapter": {
    "id": "vulgate:sirach.22",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 22,
    "referenceLabel": "Sirach 22",
    "summary": "Source text for Sirach 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.22.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Sirach 22:1",
      "text": "In lapide luteo lapidatus est piger: et omnes loquentur super aspernationem illius.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.22.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Sirach 22:2",
      "text": "De stercore boum lapidatus est piger: et omnis qui tetigerit eum excutiet manus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Sirach 22:3",
      "text": "Confusio patris est de filio indisciplinato: filia autem in deminoratione fiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Sirach 22:4",
      "text": "Filia prudens hæreditas viro suo: nam quæ confundit, in contumeliam fit genitoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Sirach 22:5",
      "text": "Patrem et virum confundit audax, et ab impiis non minorabitur: ab utrisque autem inhonorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Sirach 22:6",
      "text": "Musica in luctu importuna narratio: flagella et doctrina in omni tempore sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Sirach 22:7",
      "text": "Qui docet fatuum, quasi qui conglutinat testam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Sirach 22:8",
      "text": "Qui narrat verbum non audienti, quasi qui excitat dormientem de gravi somno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Sirach 22:9",
      "text": "Cum dormiente loquitur qui enarrat stulto sapientiam: et in fine narrationis dicit: Quis est hic?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Sirach 22:10",
      "text": "Supra mortuum plora, defecit enim lux ejus: et supra fatuum plora, defecit enim sensus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Sirach 22:11",
      "text": "Modicum plora super mortuum, quoniam requievit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Sirach 22:12",
      "text": "nequissimi enim nequissima vita super mortem fatui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Sirach 22:13",
      "text": "Luctus mortui septem dies: fatui autem et impii omnes dies vitæ illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Sirach 22:14",
      "text": "Cum stulto ne multum loquaris, et cum insensato ne abieris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Sirach 22:15",
      "text": "Serva te ab illo, ut non molestiam habeas, et non coinquinaberis peccato illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Sirach 22:16",
      "text": "Deflecte ab illo, et invenies requiem, et non acediaberis in stultitia illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Sirach 22:17",
      "text": "Super plumbum quid gravabitur? et quod illi aliud nomen quam fatuus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Sirach 22:18",
      "text": "Arenam, et salem, et massam ferri facilius est ferre quam hominem imprudentem, et fatuum, et impium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Sirach 22:19",
      "text": "Loramentum ligneum colligatum in fundamento ædificii non dissolvetur, sic et cor confirmatum in cogitatione consilii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Sirach 22:20",
      "text": "Cogitatus sensati in omni tempore metu non depravabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Sirach 22:21",
      "text": "Sicut pali in excelsis, et cæmenta sine impensa posita, contra faciem venti non permanebunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Sirach 22:22",
      "text": "sic et cor timidum in cogitatione stulti contra impetum timoris non resistet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Sirach 22:23",
      "text": "Sicut cor trepidum in cogitatione fatui omni tempore non metuet, sic et qui in præceptis Dei permanet semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Sirach 22:24",
      "text": "Pungens oculum deducit lacrimas, et qui pungit cor profert sensum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Sirach 22:25",
      "text": "Mittens lapidem in volatilia, dejiciet illa: sic et qui conviciatur amico, dissolvit amicitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Sirach 22:26",
      "text": "Ad amicum etsi produxeris gladium, non desperes: est enim regressus. Ad amicum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Sirach 22:27",
      "text": "si aperueris os triste, non timeas: est enim concordatio: excepto convitio, et improperio, et superbia, et mysterii revelatione, et plaga dolosa: in his omnibus effugiet amicus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Sirach 22:28",
      "text": "Fidem posside cum amico in paupertate illius, ut et in bonis illius læteris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Sirach 22:29",
      "text": "In tempore tribulationis illius permane illi fidelis, ut et in hæreditate illius cohæres sis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Sirach 22:30",
      "text": "Ante ignem camini vapor et fumus ignis inaltatur: sic et ante sanguinem maledicta, et contumeliæ, et minæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Sirach 22:31",
      "text": "Amicum salutare non confundar, a facie illius non me abscondam: et si mala mihi evenerint per illum, sustinebo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Sirach 22:32",
      "text": "Omnis qui audiet cavebit se ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.22.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Sirach 22:33",
      "text": "Quis dabit ori meo custodiam, et super labia mea signaculum certum, ut non cadam ab ipsis, et lingua mea perdat me?",
      "paragraphStart": false
    }
  ]
}
