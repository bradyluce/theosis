{
  "chapter": {
    "id": "vulgate:sirach.17",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 17,
    "referenceLabel": "Sirach 17",
    "summary": "Source text for Sirach 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.17.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Sirach 17:1",
      "text": "Deus creavit de terra hominem, et secundum imaginem suam fecit illum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.17.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Sirach 17:2",
      "text": "et iterum convertit illum in ipsam, et secundum se vestivit illum virtute.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Sirach 17:3",
      "text": "Numerum dierum et tempus dedit illi, et dedit illi potestatem eorum quæ sunt super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Sirach 17:4",
      "text": "Posuit timorem illius super omnem carnem, et dominatus est bestiarum et volatilium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Sirach 17:5",
      "text": "Creavit ex ipso adjutorium simile sibi: consilium, et linguam, et oculos, et aures, et cor dedit illis excogitandi, et disciplina intellectus replevit illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Sirach 17:6",
      "text": "Creavit illis scientiam spiritus, sensu implevit cor illorum, et mala et bona ostendit illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Sirach 17:7",
      "text": "Posuit oculum suum super corda illorum, ostendere illis magnalia operum suorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Sirach 17:8",
      "text": "ut nomen sanctificationis collaudent, et gloriari in mirabilibus illius; ut magnalia enarrent operum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Sirach 17:9",
      "text": "Addidit illis disciplinam, et legem vitæ hæreditavit illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Sirach 17:10",
      "text": "Testamentum æternum constituit cum illis, et justitiam et judicia sua ostendit illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Sirach 17:11",
      "text": "Et magnalia honoris ejus vidit oculus illorum, et honorem vocis audierunt aures illorum. Et dixit illis: Attendite ab omni iniquo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Sirach 17:12",
      "text": "Et mandavit illis unicuique de proximo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Sirach 17:13",
      "text": "Viæ illorum coram ipso sunt semper: non sunt absconsæ ab oculis ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Sirach 17:14",
      "text": "In unamquamque gentem præposuit rectorem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Sirach 17:15",
      "text": "et pars Dei Israël facta est manifesta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Sirach 17:16",
      "text": "Et omnia opera illorum velut sol in conspectu Dei: et oculi ejus sine intermissione inspicientes in viis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Sirach 17:17",
      "text": "Non sunt absconsa testamenta per iniquitatem illorum, et omnes iniquitates eorum in conspectu Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Sirach 17:18",
      "text": "Eleemosyna viri quasi signaculum cum ipso, et gratiam hominis quasi pupillam conservabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Sirach 17:19",
      "text": "Et postea resurget, et retribuet illis retributionem, unicuique in caput ipsorum, et convertet in interiores partes terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Sirach 17:20",
      "text": "Pœnitentibus autem dedit viam justitiæ, et confirmavit deficientes sustinere, et destinavit illis sortem veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Sirach 17:21",
      "text": "Convertere ad Dominum, et relinque peccata tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Sirach 17:22",
      "text": "precare ante faciem Domini, et minue offendicula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Sirach 17:23",
      "text": "Revertere ad Dominum, et avertere ab injustitia tua, et nimis odito execrationem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Sirach 17:24",
      "text": "et cognosce justitias et judicia Dei, et sta in sorte propositionis, et orationis altissimi Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Sirach 17:25",
      "text": "In partes vade sæculi sancti, cum vivis et dantibus confessionem Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Sirach 17:26",
      "text": "Non demoreris in errore impiorum: ante mortem confitere: a mortuo, quasi nihil, perit confessio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Sirach 17:27",
      "text": "Confiteberis vivens, vivus et sanus confiteberis: et laudabis Deum, et gloriaberis in miserationibus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Sirach 17:28",
      "text": "Quam magna misericordia Domini, et propitiatio illius convertentibus ad se!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 29,
      "referenceLabel": "Sirach 17:29",
      "text": "Nec enim omnia possunt esse in hominibus, quoniam non est immortalis filius hominis, et in vanitate malitiæ placuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 30,
      "referenceLabel": "Sirach 17:30",
      "text": "Quid lucidius sole? et hic deficiet; aut quid nequius quam quod excogitavit caro et sanguis? et hoc arguetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.17.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 17,
      "verseNumber": 31,
      "referenceLabel": "Sirach 17:31",
      "text": "Virtutem altitudinis cæli ipse conspicit: et omnes homines terra et cinis.",
      "paragraphStart": false
    }
  ]
}
