{
  "chapter": {
    "id": "vulgate:sirach.32",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 32,
    "referenceLabel": "Sirach 32",
    "summary": "Source text for Sirach 32 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.32.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Sirach 32:1",
      "text": "Rectorem te posuerunt? noli extolli: esto in illis quasi unus ex ipsis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.32.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Sirach 32:2",
      "text": "Curam illorum habe, et sic conside, et omni cura tua explicita recumbe:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Sirach 32:3",
      "text": "ut læteris propter illos, et ornamentum gratiæ accipias coronam, et dignationem consequaris corrogationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Sirach 32:4",
      "text": "Loquere major natu: decet enim te",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Sirach 32:5",
      "text": "primum verbum diligenti scientia, et non impedias musicam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Sirach 32:6",
      "text": "Ubi auditus non est, non effundas sermonem, et importune noli extolli in sapientia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Sirach 32:7",
      "text": "Gemmula carbunculi in ornamento auri, et comparatio musicorum in convivio vini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Sirach 32:8",
      "text": "Sicut in fabricatione auri signum est smaragdi, sic numerus musicorum in jucundo et moderato vino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Sirach 32:9",
      "text": "Audi tacens, et pro reverentia accedet tibi bona gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Sirach 32:10",
      "text": "Adolescens, loquere in tua causa vix.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Sirach 32:11",
      "text": "Si bis interrogatus fueris, habeat caput responsum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Sirach 32:12",
      "text": "In multis esto quasi inscius, et audi tacens simul et quærens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Sirach 32:13",
      "text": "In medio magnatorum non præsumas: et ubi sunt senes non multum loquaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Sirach 32:14",
      "text": "Ante grandinem præibit coruscatio: et ante verecundiam præibit gratia, et pro reverentia accedet tibi bona gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Sirach 32:15",
      "text": "Et hora surgendi non te trices: præcurre autem prior in domum tuam, et illic avocare, et illic lude,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Sirach 32:16",
      "text": "et age conceptiones tuas, et non in delictis et verbo superbo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Sirach 32:17",
      "text": "et super his omnibus benedicito Dominum, qui fecit, et inebriantem te ab omnibus bonis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Sirach 32:18",
      "text": "Qui timet Dominum excipiet doctrinam ejus: et qui vigilaverint ad illum invenient benedictionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Sirach 32:19",
      "text": "Qui quærit legem replebitur ab ea, et qui insidiose agit scandalizabitur in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Sirach 32:20",
      "text": "Qui timent Dominum invenient judicium justum, et justitias quasi lumen accendent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Sirach 32:21",
      "text": "Peccator homo vitabit correptionem, et secundum voluntatem suam inveniet comparationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Sirach 32:22",
      "text": "Vir consilii non disperdet intelligentiam: alienus et superbus non pertimescet timorem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 23,
      "referenceLabel": "Sirach 32:23",
      "text": "etiam postquam fecit cum eo sine consilio, et suis insectationibus arguetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 24,
      "referenceLabel": "Sirach 32:24",
      "text": "Fili, sine consilio nihil facias, et post factum non pœnitebis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 25,
      "referenceLabel": "Sirach 32:25",
      "text": "In via ruinæ non eas, et non offendes in lapides: nec credas te viæ laboriosæ, ne ponas animæ tuæ scandalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 26,
      "referenceLabel": "Sirach 32:26",
      "text": "Et a filiis tuis cave, et a domesticis tuis attende.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 27,
      "referenceLabel": "Sirach 32:27",
      "text": "In omni opere tuo crede ex fide animæ tuæ, hoc est enim conservatio mandatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.32.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 32,
      "verseNumber": 28,
      "referenceLabel": "Sirach 32:28",
      "text": "Qui credit Deo attendit mandatis: et qui confidit in illo non minorabitur.",
      "paragraphStart": false
    }
  ]
}
