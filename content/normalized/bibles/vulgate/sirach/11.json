{
  "chapter": {
    "id": "vulgate:sirach.11",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 11,
    "referenceLabel": "Sirach 11",
    "summary": "Source text for Sirach 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.11.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Sirach 11:1",
      "text": "Sapientia humiliati exaltabit caput illius, et in medio magnatorum consedere illum faciet.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.11.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Sirach 11:2",
      "text": "Non laudes virum in specie sua, neque spernas hominem in visu suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Sirach 11:3",
      "text": "Brevis in volatilibus est apis, et initium dulcoris habet fructus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Sirach 11:4",
      "text": "In vestitu ne glorieris umquam, nec in die honoris tui extollaris: quoniam mirabilia opera Altissimi solius, et gloriosa, et absconsa, et invisa opera illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Sirach 11:5",
      "text": "Multi tyranni sederunt in throno: et insuspicabilis portavit diadema.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Sirach 11:6",
      "text": "Multi potentes oppressi sunt valide, et gloriosi traditi sunt in manus alterorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Sirach 11:7",
      "text": "Priusquam interroges, ne vituperes quemquam: et cum interrogaveris, corripe juste.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Sirach 11:8",
      "text": "Priusquam audias, ne respondeas verbum: et in medio sermonum ne adjicias loqui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Sirach 11:9",
      "text": "De ea re quæ te non molestat, ne certeris: et in judicio peccantium ne consistas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Sirach 11:10",
      "text": "Fili, ne in multis sint actus tui: et si dives fueris, non eris immunis a delicto. Si enim secutus fueris, non apprehendes: et non effugies, si præcucurreris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Sirach 11:11",
      "text": "Est homo laborans et festinans, et dolens: impius, et tanto magis non abundabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Sirach 11:12",
      "text": "Est homo marcidus egens recuperatione, plus deficiens virtute, et abundans paupertate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Sirach 11:13",
      "text": "et oculus Dei respexit illum in bono, et erexit eum ab humilitate ipsius, et exaltavit caput ejus: et mirati sunt in illo multi, et honoraverunt Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Sirach 11:14",
      "text": "Bona et mala, vita et mors, paupertas et honestas, a Deo sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Sirach 11:15",
      "text": "sapientia, et disciplina, et scientia legis, apud Deum: dilectio, et viæ bonorum, apud ipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Sirach 11:16",
      "text": "Error et tenebræ peccatoribus concreata sunt: qui autem exsultant in malis consenescunt in malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Sirach 11:17",
      "text": "Datio Dei permanet justis, et profectus illius successus habebit in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Sirach 11:18",
      "text": "Est qui locupletatur parce agendo, et hæc est pars mercedis illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Sirach 11:19",
      "text": "In eo quod dicit: Inveni requiem mihi, et nunc manducabo de bonis meis solus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Sirach 11:20",
      "text": "et nescit quod tempus præteriet, et mors appropinquet, et relinquat omnia aliis, et morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Sirach 11:21",
      "text": "Sta in testamento tuo, et in illo colloquere, et in opere mandatorum tuorum veterasce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Sirach 11:22",
      "text": "Ne manseris in operibus peccatorum: confide autem in Deo, et mane in loco tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Sirach 11:23",
      "text": "Facile est enim in oculis Dei subito honestare pauperem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Sirach 11:24",
      "text": "Benedictio Dei in mercedem justi festinat, et in hora veloci processus illius fructificat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Sirach 11:25",
      "text": "Ne dicas: Quid est mihi opus? et quæ erunt mihi ex hoc bona?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Sirach 11:26",
      "text": "Ne dicas: Sufficiens mihi sum: et quid ex hoc pessimabor?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Sirach 11:27",
      "text": "In die bonorum ne immemor sis malorum, et in die malorum ne immemor sis bonorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Sirach 11:28",
      "text": "quoniam facile est coram Deo in die obitus retribuere unicuique secundum vias suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Sirach 11:29",
      "text": "Malitia horæ oblivionem facit luxuriæ magnæ, et in fine hominis denudatio operum illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Sirach 11:30",
      "text": "Ante mortem ne laudes hominem quemquam: quoniam in filiis suis agnoscitur vir.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Sirach 11:31",
      "text": "Non omnem hominem inducas in domum tuam: multæ enim sunt insidiæ dolosi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Sirach 11:32",
      "text": "Sicut enim eructant præcordia fœtentium, et sicut perdix inducitur in caveam, et ut caprea in laqueum: sic et cor superborum, et sicut prospector videns casum proximi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Sirach 11:33",
      "text": "Bona enim in mala convertens insidiatur, et in electis imponet maculam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Sirach 11:34",
      "text": "A scintilla una augetur ignis, et ab uno doloso augetur sanguis: homo vero peccator sanguini insidiatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Sirach 11:35",
      "text": "Attende tibi a pestifero, fabricat enim mala, ne inducat super te subsannationem in perpetuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.11.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Sirach 11:36",
      "text": "Admitte ad te alienigenam: et subvertet te in turbine, et abalienabit te a tuis propriis.",
      "paragraphStart": false
    }
  ]
}
