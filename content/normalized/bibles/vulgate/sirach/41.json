{
  "chapter": {
    "id": "vulgate:sirach.41",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 41,
    "referenceLabel": "Sirach 41",
    "summary": "Source text for Sirach 41 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.41.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Sirach 41:1",
      "text": "O mors, quam amara est memoria tua homini pacem habenti in substantiis suis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.41.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Sirach 41:2",
      "text": "viro quieto, et cujus viæ directæ sunt in omnibus, et adhuc valenti accipere cibum!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Sirach 41:3",
      "text": "O mors, bonum est judicium tuum homini indigenti, et qui minoratur viribus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Sirach 41:4",
      "text": "defecto ætate, et cui de omnibus cura est, et incredibili, qui perdit patientiam!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Sirach 41:5",
      "text": "Noli metuere judicium mortis: memento quæ ante te fuerunt, et quæ superventura sunt tibi: hoc judicium a Domino omni carni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Sirach 41:6",
      "text": "Et quid superveniet tibi in beneplacito Altissimi? sive decem, sive centum, sive mille anni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Sirach 41:7",
      "text": "non est enim in inferno accusatio vitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Sirach 41:8",
      "text": "Filii abominationum fiunt filii peccatorum, et qui conversantur secus domos impiorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Sirach 41:9",
      "text": "Filiorum peccatorum periet hæreditas, et cum semine illorum assiduitas opprobrii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Sirach 41:10",
      "text": "De patre impio queruntur filii, quoniam propter illum sunt in opprobrio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Sirach 41:11",
      "text": "Væ vobis, viri impii, qui dereliquistis legem Domini Altissimi!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Sirach 41:12",
      "text": "Et si nati fueritis, in maledictione nascemini: et si mortui fueritis, in maledictione erit pars vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Sirach 41:13",
      "text": "Omnia quæ de terra sunt in terram convertentur: sic impii a maledicto in perditionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 14,
      "referenceLabel": "Sirach 41:14",
      "text": "Luctus hominum in corpore ipsorum: nomen autem impiorum delebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 15,
      "referenceLabel": "Sirach 41:15",
      "text": "Curam habe de bono nomine: hoc enim magis permanebit tibi quam mille thesauri pretiosi et magni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 16,
      "referenceLabel": "Sirach 41:16",
      "text": "Bonæ vitæ numerus dierum: bonum autem nomen permanebit in ævum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 17,
      "referenceLabel": "Sirach 41:17",
      "text": "Disciplinam in pace conservate, filii: sapientia enim abscondita, et thesaurus invisus, quæ utilitas in utrisque?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 18,
      "referenceLabel": "Sirach 41:18",
      "text": "Melior est homo qui abscondit stultitiam suam, quam homo qui abscondit sapientiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 19,
      "referenceLabel": "Sirach 41:19",
      "text": "Verumtamen reveremini in his quæ procedunt de ore meo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 20,
      "referenceLabel": "Sirach 41:20",
      "text": "non est enim bonum omnem reverentiam observare, et non omnia omnibus bene placent in fide.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 21,
      "referenceLabel": "Sirach 41:21",
      "text": "Erubescite a patre et a matre de fornicatione: et a præsidente et a potente de mendacio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 22,
      "referenceLabel": "Sirach 41:22",
      "text": "a principe et a judice de delicto: a synagoga et plebe de iniquitate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 23,
      "referenceLabel": "Sirach 41:23",
      "text": "a socio et amico de injustitia, et de loco in quo habitas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 24,
      "referenceLabel": "Sirach 41:24",
      "text": "de furto, de veritate Dei, et testamento: de discubitu in panibus, et ab obfuscatione dati et accepti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 25,
      "referenceLabel": "Sirach 41:25",
      "text": "a salutantibus de silentio, a respectu mulieris fornicariæ, et ab aversione vultus cognati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 26,
      "referenceLabel": "Sirach 41:26",
      "text": "Ne avertas faciem a proximo tuo, et ab auferendo partem et non restituendo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 27,
      "referenceLabel": "Sirach 41:27",
      "text": "Ne respicias mulierem alieni viri, et ne scruteris ancillam ejus, neque steteris ad lectum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.41.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 41,
      "verseNumber": 28,
      "referenceLabel": "Sirach 41:28",
      "text": "Ab amicis de sermonibus improperii: et cum dederis, ne improperes.",
      "paragraphStart": false
    }
  ]
}
