{
  "chapter": {
    "id": "vulgate:sirach.6",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 6,
    "referenceLabel": "Sirach 6",
    "summary": "Source text for Sirach 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.6.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Sirach 6:1",
      "text": "Noli fieri pro amico inimicus proximo: improperium enim et contumeliam malus hæreditabit: et omnis peccator invidus et bilinguis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.6.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Sirach 6:2",
      "text": "Non te extollas in cogitatione animæ tuæ velut taurus, ne forte elidatur virtus tua per stultitiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Sirach 6:3",
      "text": "et folia tua comedat, et fructus tuos perdat, et relinquaris velut lignum aridum in eremo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Sirach 6:4",
      "text": "Anima enim nequam disperdet qui se habet, et in gaudium inimicis dat illum, et deducet in sortem impiorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Sirach 6:5",
      "text": "Verbum dulce multiplicat amicos et mitigat inimicos, et lingua eucharis in bono homine abundat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Sirach 6:6",
      "text": "Multi pacifici sint tibi: et consiliarius sit tibi unus de mille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Sirach 6:7",
      "text": "Si possides amicum, in tentatione posside eum, et ne facile credas ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Sirach 6:8",
      "text": "Est enim amicus secundum tempus suum, et non permanebit in die tribulationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Sirach 6:9",
      "text": "Et est amicus qui convertitur ad inimicitiam, et est amicus qui odium et rixam et convitia denudabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Sirach 6:10",
      "text": "Est autem amicus socius mensæ, et non permanebit in die necessitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Sirach 6:11",
      "text": "Amicus si permanserit fixus, erit tibi quasi coæqualis, et in domesticis tuis fiducialiter aget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Sirach 6:12",
      "text": "Si humiliaverit se contra te, et a facie tua absconderit se, unanimem habebis amicitiam bonam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Sirach 6:13",
      "text": "Ab inimicis tuis separare, et ab amicis tuis attende.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Sirach 6:14",
      "text": "Amicus fidelis protectio fortis: qui autem invenit illum, invenit thesaurum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Sirach 6:15",
      "text": "Amico fideli nulla est comparatio, et non est digna ponderatio auri et argenti contra bonitatem fidei illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Sirach 6:16",
      "text": "Amicus fidelis medicamentum vitæ et immortalitatis: et qui metuunt Dominum, invenient illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Sirach 6:17",
      "text": "Qui timet Deum æque habebit amicitiam bonam, quoniam secundum illum erit amicus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Sirach 6:18",
      "text": "Fili, a juventute tua excipe doctrinam, et usque ad canos invenies sapientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Sirach 6:19",
      "text": "Quasi is qui arat et seminat accede ad eam, et sustine bonos fructus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Sirach 6:20",
      "text": "In opere enim ipsius exiguum laborabis, et cito edes de generationibus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Sirach 6:21",
      "text": "Quam aspera est nimium sapientia indoctis hominibus! et non permanebit in illa excors.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Sirach 6:22",
      "text": "Quasi lapidis virtus probatio erit in illis: et non demorabuntur projicere illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Sirach 6:23",
      "text": "Sapientia enim doctrinæ secundum nomen est ejus, et non est multis manifestata: quibus autem cognita est, permanet usque ad conspectum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Sirach 6:24",
      "text": "Audi, fili, et accipe consilium intellectus, et ne abjicias consilium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Sirach 6:25",
      "text": "Injice pedem tuum in compedes illius, et in torques illius collum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Sirach 6:26",
      "text": "Subjice humerum tuum, et porta illam, et ne acedieris vinculis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Sirach 6:27",
      "text": "In omni animo tuo accede ad illam, et in omni virtute tua conserva vias ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Sirach 6:28",
      "text": "Investiga illam, et manifestabitur tibi: et continens factus, ne derelinquas eam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Sirach 6:29",
      "text": "in novissimis enim invenies requiem in ea, et convertetur tibi in oblectationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Sirach 6:30",
      "text": "Et erunt tibi compedes ejus in protectionem fortitudinis et bases virtutis, et torques illius in stolam gloriæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Sirach 6:31",
      "text": "decor enim vitæ est in illa, et vincula illius alligatura salutaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Sirach 6:32",
      "text": "Stolam gloriæ indues eam, et coronam gratulationis superpones tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Sirach 6:33",
      "text": "Fili, si attenderis mihi, disces: et si accommodaveris animum tuum, sapiens eris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Sirach 6:34",
      "text": "Si inclinaveris aurem tuam, excipies doctrinam: et si dilexeris audire, sapiens eris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Sirach 6:35",
      "text": "In multitudine presbyterorum prudentium sta, et sapientiæ illorum ex corde conjungere, ut omnem narrationem Dei possis audire, et proverbia laudis non effugiant a te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "Sirach 6:36",
      "text": "Et si videris sensatum, evigila ad eum, et gradus ostiorum illius exterat pes tuus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.6.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "Sirach 6:37",
      "text": "Cogitatum tuum habe in præceptis Dei, et in mandatis illius maxime assiduus esto: et ipse dabit tibi cor, et concupiscentia sapientiæ dabitur tibi.",
      "paragraphStart": false
    }
  ]
}
