{
  "chapter": {
    "id": "vulgate:sirach.33",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 33,
    "referenceLabel": "Sirach 33",
    "summary": "Source text for Sirach 33 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.33.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Sirach 33:1",
      "text": "Timenti Dominum non occurrent mala: sed in tentatione Deus illum conservabit, et liberabit a malis. Sapiens non odit mandata et justitias,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.33.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Sirach 33:2",
      "text": "et non illidetur quasi in procella navis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Sirach 33:3",
      "text": "Homo sensatus credit legi Dei, et lex illi fidelis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Sirach 33:4",
      "text": "Qui interrogationem manifestat parabit verbum, et sic deprecatus exaudietur: et conservabit disciplinam, et tunc respondebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Sirach 33:5",
      "text": "Præcordia fatui quasi rota carri, et quasi axis versatilis cogitatus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Sirach 33:6",
      "text": "Equus emissarius, sic et amicus subsannator: sub omni supra sedente hinnit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Sirach 33:7",
      "text": "Quare dies diem superat, et iterum lux lucem, et annus annum a sole?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Sirach 33:8",
      "text": "A Domini scientia separati sunt, facto sole, et præceptum custodiente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Sirach 33:9",
      "text": "Et immutavit tempora, et dies festos ipsorum, et in illis dies festos celebraverunt ad horam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Sirach 33:10",
      "text": "Ex ipsis exaltavit et magnificavit Deus, et ex ipsis posuit in numerum dierum: et omnes homines de solo et ex terra unde creatus est Adam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Sirach 33:11",
      "text": "In multitudine disciplinæ Dominus separavit eos, et immutavit vias eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Sirach 33:12",
      "text": "Ex ipsis benedixit et exaltavit, et ex ipsis sanctificavit, et ad se applicavit, et ex ipsis maledixit, et humiliavit, et convertit illos a separatione ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Sirach 33:13",
      "text": "Quasi lutum figuli in manu ipsius, plasmare illud et disponere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Sirach 33:14",
      "text": "Omnes viæ ejus secundum dispositionem ejus: sic homo in manu illius qui se fecit, et reddet illi secundum judicium suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Sirach 33:15",
      "text": "Contra malum bonum est, et contra mortem vita: sic et contra virum justum peccator, et sic intuere in omnia opera Altissimi, duo et duo, et unum contra unum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Sirach 33:16",
      "text": "Et ego novissimus evigilavi, et quasi qui colligit acinos post vindemiatores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Sirach 33:17",
      "text": "In benedictione Dei et ipse speravi, et quasi qui vindemiat replevi torcular.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Sirach 33:18",
      "text": "Respicite quoniam non mihi soli laboravi, sed omnibus exquirentibus disciplinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Sirach 33:19",
      "text": "Audite me, magnates et omnes populi: et rectores ecclesiæ, auribus percipite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Sirach 33:20",
      "text": "Filio et mulieri, fratri et amico, non des potestatem super te in vita tua: et non dederis alii possessionem tuam, ne forte pœniteat te, et depreceris pro illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Sirach 33:21",
      "text": "Dum adhuc superes et aspiras, non immutabit te omnis caro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Sirach 33:22",
      "text": "Melius est enim ut filii tui te rogent, quam te respicere in manus filiorum tuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Sirach 33:23",
      "text": "In omnibus operibus tuis præcellens esto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 24,
      "referenceLabel": "Sirach 33:24",
      "text": "Ne dederis maculam in gloria tua. In die consummationis dierum vitæ tuæ, et in tempore exitus tui, distribue hæreditatem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 25,
      "referenceLabel": "Sirach 33:25",
      "text": "Cibaria, et virga, et onus asino: panis, et disciplina, et opus servo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 26,
      "referenceLabel": "Sirach 33:26",
      "text": "Operatur in disciplina, et quærit requiescere: laxa manus illi, et quærit libertatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 27,
      "referenceLabel": "Sirach 33:27",
      "text": "Jugum et lorum curvant collum durum, et servum inclinant operationes assiduæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 28,
      "referenceLabel": "Sirach 33:28",
      "text": "Servo malevolo tortura et compedes: mitte illum in operationem, ne vacet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 29,
      "referenceLabel": "Sirach 33:29",
      "text": "multam enim malitiam docuit otiositas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 30,
      "referenceLabel": "Sirach 33:30",
      "text": "In opera constitue eum: sic enim condecet illum. Quod si non obaudierit, curva illum compedibus, et non amplifices super omnem carnem: verum sine judicio nihil facias grave.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 31,
      "referenceLabel": "Sirach 33:31",
      "text": "Si est tibi servus fidelis, sit tibi quasi anima tua: quasi fratrem sic eum tracta, quoniam in sanguine animæ comparasti illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 32,
      "referenceLabel": "Sirach 33:32",
      "text": "Si læseris eum injuste, in fugam convertetur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.33.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 33,
      "referenceLabel": "Sirach 33:33",
      "text": "et si extollens discesserit, quem quæras et in qua via quæras illum nescis.",
      "paragraphStart": false
    }
  ]
}
