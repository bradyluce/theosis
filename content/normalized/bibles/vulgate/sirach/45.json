{
  "chapter": {
    "id": "vulgate:sirach.45",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 45,
    "referenceLabel": "Sirach 45",
    "summary": "Source text for Sirach 45 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.45.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 1,
      "referenceLabel": "Sirach 45:1",
      "text": "Dilectus Deo et hominibus Moyses, cujus memoria in benedictione est.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.45.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 2,
      "referenceLabel": "Sirach 45:2",
      "text": "Similem illum fecit in gloria sanctorum, et magnificavit eum in timore inimicorum, et in verbis suis monstra placavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 3,
      "referenceLabel": "Sirach 45:3",
      "text": "Glorificavit illum in conspectu regum, et jussit illi coram populo suo, et ostendit illi gloriam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 4,
      "referenceLabel": "Sirach 45:4",
      "text": "In fide et lenitate ipsius sanctum fecit illum, et elegit eum ex omni carne.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 5,
      "referenceLabel": "Sirach 45:5",
      "text": "Audivit enim eum, et vocem ipsius, et induxit illum in nubem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 6,
      "referenceLabel": "Sirach 45:6",
      "text": "Et dedit illi coram præcepta, et legem vitæ et disciplinæ, docere Jacob testamentum suum, et judicia sua Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 7,
      "referenceLabel": "Sirach 45:7",
      "text": "Excelsum fecit Aaron fratrem ejus, et similem sibi, de tribu Levi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 8,
      "referenceLabel": "Sirach 45:8",
      "text": "Statuit ei testamentum æternum, et dedit illi sacerdotium gentis, et beatificavit illum in gloria:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 9,
      "referenceLabel": "Sirach 45:9",
      "text": "et circumcinxit eum zona gloriæ, et induit eum stolam gloriæ, et coronavit eum in vasis virtutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 10,
      "referenceLabel": "Sirach 45:10",
      "text": "Circumpedes, et femoralia, et humerale posuit ei: et cinxit illum tintinnabulis aureis plurimis in gyro:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 11,
      "referenceLabel": "Sirach 45:11",
      "text": "dare sonitum in incessu suo, auditum facere sonitum in templo in memoriam filiis gentis suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 12,
      "referenceLabel": "Sirach 45:12",
      "text": "Stolam sanctam auro, et hyacintho, et purpura, opus textile viri sapientis, judicio et veritate præditi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 13,
      "referenceLabel": "Sirach 45:13",
      "text": "torto cocco opus artificis gemmis pretiosis figuratis in ligatura auri, et opere lapidarii sculptis, in memoriam secundum numerum tribuum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 14,
      "referenceLabel": "Sirach 45:14",
      "text": "Corona aurea super mitram ejus expressa signo sanctitatis, et gloria honoris: opus virtutis, et desideria oculorum ornata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 15,
      "referenceLabel": "Sirach 45:15",
      "text": "Sic pulchra ante ipsum non fuerunt talia usque ad originem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 16,
      "referenceLabel": "Sirach 45:16",
      "text": "Non est indutus illa alienigena aliquis, sed tantum filii ipsius soli, et nepotes ejus per omne tempus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 17,
      "referenceLabel": "Sirach 45:17",
      "text": "Sacrificia ipsius consumpta sunt igne quotidie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 18,
      "referenceLabel": "Sirach 45:18",
      "text": "Complevit Moyses manus ejus, et unxit illum oleo sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 19,
      "referenceLabel": "Sirach 45:19",
      "text": "Factum est illi in testamentum æternum, et semini ejus, sicut dies cæli, fungi sacerdotio, et habere laudem, et glorificare populum suum in nomine ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 20,
      "referenceLabel": "Sirach 45:20",
      "text": "Ipsum elegit ab omni vivente, offerre sacrificium Deo, incensum, et bonum odorem, in memoriam placare pro populo suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 21,
      "referenceLabel": "Sirach 45:21",
      "text": "et dedit illi in præceptis suis potestatem, in testamentis judiciorum: docere Jacob testimonia, et in lege sua lucem dare Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 22,
      "referenceLabel": "Sirach 45:22",
      "text": "Quia contra illum steterunt alieni, et propter invidiam circumdederunt illum homines in deserto, qui erant cum Dathan et Abiron, et congregatio Core in iracundia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 23,
      "referenceLabel": "Sirach 45:23",
      "text": "Vidit Dominus Deus, et non placuit illi, et consumpti sunt in impetu iracundiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 24,
      "referenceLabel": "Sirach 45:24",
      "text": "Fecit illis monstra, et consumpsit illos in flamma ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 25,
      "referenceLabel": "Sirach 45:25",
      "text": "Et addidit Aaron gloriam, et dedit illi hæreditatem, et primitias frugum terræ divisit illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 26,
      "referenceLabel": "Sirach 45:26",
      "text": "Panem ipsis in primis paravit in satietatem: nam et sacrificia Domini edent, quæ dedit illi et semini ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 27,
      "referenceLabel": "Sirach 45:27",
      "text": "Ceterum in terra gentes non hæreditabit, et pars non est illi in gente: ipse est enim pars ejus, et hæreditas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 28,
      "referenceLabel": "Sirach 45:28",
      "text": "Phinees, filius Eleazari, tertius in gloria est, imitando eum in timore Domini,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 29,
      "referenceLabel": "Sirach 45:29",
      "text": "et stare in reverentia gentis: in bonitate et alacritate animæ suæ placuit Deo pro Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 30,
      "referenceLabel": "Sirach 45:30",
      "text": "Ideo statuit illi testamentum pacis, principem sanctorum et gentis suæ, ut sit illi et semini ejus sacerdotii dignitas in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.45.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 45,
      "verseNumber": 31,
      "referenceLabel": "Sirach 45:31",
      "text": "Et testamentum David regi filio Jesse de tribu Juda, hæreditas ipsi et semini ejus: ut daret sapientiam in cor nostrum, judicare gentem suam in justitia, ne abolerentur bona ipsorum: et gloriam ipsorum in gentem eorum æternam fecit.",
      "paragraphStart": false
    }
  ]
}
