{
  "chapter": {
    "id": "vulgate:sirach.13",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 13,
    "referenceLabel": "Sirach 13",
    "summary": "Source text for Sirach 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.13.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Sirach 13:1",
      "text": "Qui tetigerit picem inquinabitur ab ea: et qui communicaverit superbo induet superbiam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.13.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Sirach 13:2",
      "text": "Pondus super se tollat qui honestiori se communicat, et ditiori te ne socius fueris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Sirach 13:3",
      "text": "Quid communicabit cacabus ad ollam? quando enim se colliserint, confringetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Sirach 13:4",
      "text": "Dives injuste egit, et fremet: pauper autem læsus tacebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Sirach 13:5",
      "text": "Si largitus fueris, assumet te: et si non habueris, derelinquet te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Sirach 13:6",
      "text": "Si habes, convivet tecum, et evacuabit te: et ipse non dolebit super te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Sirach 13:7",
      "text": "Si necessarius illi fueris, supplantabit te, et subridens spem dabit, narrans tibi bona, et dicet: Quid opus est tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Sirach 13:8",
      "text": "Et confundet te in cibis suis, donec te exinaniat bis et ter: et in novissimo deridebit te, et postea videns derelinquet te, et caput suum movebit ad te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Sirach 13:9",
      "text": "Humiliare Deo, et exspecta manus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Sirach 13:10",
      "text": "Attende ne seductus in stultitiam humilieris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Sirach 13:11",
      "text": "Noli esse humilis in sapientia tua, ne humiliatus in stultitiam seducaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Sirach 13:12",
      "text": "Advocatus a potentiore, discede: ex hoc enim magis te advocabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Sirach 13:13",
      "text": "Ne improbus sis, ne impingaris: et ne longe sis ab eo, ne eas in oblivionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Sirach 13:14",
      "text": "Ne retineas ex æquo loqui cum illo, nec credas multis verbis illius: ex multa enim loquela tentabit te, et subridens interrogabit te de absconditis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Sirach 13:15",
      "text": "Immitis animus illius conservabit verba tua: et non parcet de malitia, et de vinculis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Sirach 13:16",
      "text": "Cave tibi, et attende diligenter auditui tuo, quoniam cum subversione tua ambulas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Sirach 13:17",
      "text": "audiens vero illa, quasi in somnis vide, et vigilabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Sirach 13:18",
      "text": "Omni vita tua dilige Deum, et invoca illum in salute tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Sirach 13:19",
      "text": "Omne animal diligit simile sibi, sic et omnis homo proximum sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Sirach 13:20",
      "text": "Omnis caro ad similem sibi conjungetur, et omnis homo simili sui sociabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Sirach 13:21",
      "text": "Si communicabit lupus agno aliquando, sic peccator justo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Sirach 13:22",
      "text": "Quæ communicatio sancto homini ad canem? aut quæ pars diviti ad pauperem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Sirach 13:23",
      "text": "Venatio leonis onager in eremo: sic et pascua divitum sunt pauperes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Sirach 13:24",
      "text": "Et sicut abominatio est superbo humilitas, sic et execratio divitis pauper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Sirach 13:25",
      "text": "Dives commotus confirmatur ab amicis suis: humilis autem cum ceciderit, expelletur et a notis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Sirach 13:26",
      "text": "Diviti decepto multi recuperatores: locutus est superbia, et justificaverunt illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Sirach 13:27",
      "text": "Humilis deceptus est, insuper et arguitur: locutus est sensate, et non est datus ei locus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Sirach 13:28",
      "text": "Dives locutus est, et omnes tacuerunt, et verbum illius usque ad nubes perducent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Sirach 13:29",
      "text": "Pauper locutus est, et dicunt: Quis est hic? et si offenderit, subvertent illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Sirach 13:30",
      "text": "Bona est substantia cui non est peccatum in conscientia: et nequissima paupertas in ore impii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Sirach 13:31",
      "text": "Cor hominis immutat faciem illius, sive in bona, sive in mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.13.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Sirach 13:32",
      "text": "Vestigium cordis boni et faciem bonam difficile invenies, et cum labore.",
      "paragraphStart": false
    }
  ]
}
