{
  "chapter": {
    "id": "vulgate:sirach.2",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 2,
    "referenceLabel": "Sirach 2",
    "summary": "Source text for Sirach 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.2.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Sirach 2:1",
      "text": "Fili, accedens ad servitutem Dei sta in justitia et timore, et præpara animam tuam ad tentationem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.2.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Sirach 2:2",
      "text": "Deprime cor tuum, et sustine: inclina aurem tuam, et suscipe verba intellectus: et ne festines in tempore obductionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Sirach 2:3",
      "text": "Sustine sustentationes Dei: conjungere Deo, et sustine, ut crescat in novissimo vita tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Sirach 2:4",
      "text": "Omne quod tibi applicitum fuerit accipe: et in dolore sustine, et in humilitate tua patientiam habe:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Sirach 2:5",
      "text": "quoniam in igne probatur aurum et argentum, homines vero receptibiles in camino humiliationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Sirach 2:6",
      "text": "Crede Deo, et recuperabit te: et dirige viam tuam, et spera in illum: serva timorem illius, et in illo veterasce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Sirach 2:7",
      "text": "Metuentes Dominum, sustinete misericordiam ejus: et non deflectatis ab illo, ne cadatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Sirach 2:8",
      "text": "Qui timetis Dominum, credite illi, et non evacuabitur merces vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Sirach 2:9",
      "text": "Qui timetis Dominum, sperate in illum, et in oblectationem veniet vobis misericordia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Sirach 2:10",
      "text": "Qui timetis Dominum, diligite illum, et illuminabuntur corda vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Sirach 2:11",
      "text": "Respicite, filii, nationes hominum: et scitote quia nullus speravit in Domino et confusus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Sirach 2:12",
      "text": "Quis enim permansit in mandatis ejus, et derelictus est? aut quis invocavit eum, et despexit illum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Sirach 2:13",
      "text": "Quoniam pius et misericors est Deus, et remittet in die tribulationis peccata, et protector est omnibus exquirentibus se in veritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Sirach 2:14",
      "text": "Væ duplici corde, et labiis scelestis, et manibus malefacientibus, et peccatori terram ingredienti duabus viis!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Sirach 2:15",
      "text": "Væ dissolutis corde, qui non credunt Deo, et ideo non protegentur ab eo!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Sirach 2:16",
      "text": "Væ his qui perdiderunt sustinentiam, et qui dereliquerunt vias rectas, et diverterunt in vias pravas!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Sirach 2:17",
      "text": "Et quid facient cum inspicere cœperit Dominus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Sirach 2:18",
      "text": "Qui timent Dominum non erunt incredibiles verbo illius: et qui diligunt illum conservabunt viam illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Sirach 2:19",
      "text": "Qui timent Dominum inquirent quæ beneplacita sunt ei, et qui diligunt eum replebuntur lege ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Sirach 2:20",
      "text": "Qui timent Dominum præparabunt corda sua, et in conspectu illius sanctificabunt animas suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Sirach 2:21",
      "text": "Qui timent Dominum custodiunt mandata illius, et patientiam habebunt usque ad inspectionem illius,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Sirach 2:22",
      "text": "dicentes: Si pœnitentiam non egerimus, incidemus in manus Domini, et non in manus hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.2.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Sirach 2:23",
      "text": "Secundum enim magnitudinem ipsius, sic et misericordia illius cum ipso est.",
      "paragraphStart": false
    }
  ]
}
