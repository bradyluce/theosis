{
  "chapter": {
    "id": "vulgate:sirach.7",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 7,
    "referenceLabel": "Sirach 7",
    "summary": "Source text for Sirach 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.7.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Sirach 7:1",
      "text": "Noli facere mala, et non te apprehendent:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.7.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Sirach 7:2",
      "text": "discede ab iniquo, et deficient mala abs te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Sirach 7:3",
      "text": "Fili, non semines mala in sulcis injustitiæ, et non metes ea in septuplum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Sirach 7:4",
      "text": "Noli quærere a Domino ducatum, neque a rege cathedram honoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Sirach 7:5",
      "text": "Non te justifices ante Deum, quoniam agnitor cordis ipse est: et penes regem noli velle videri sapiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Sirach 7:6",
      "text": "Noli quærere fieri judex, nisi valeas virtute irrumpere iniquitates: ne forte extimescas faciem potentis, et ponas scandalum in æquitate tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Sirach 7:7",
      "text": "Non pecces in multitudinem civitatis, nec te immittas in populum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Sirach 7:8",
      "text": "neque alliges duplicia peccata, nec enim in uno eris immunis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Sirach 7:9",
      "text": "Noli esse pusillanimis in animo tuo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Sirach 7:10",
      "text": "exorare et facere eleemosynam ne despicias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Sirach 7:11",
      "text": "Ne dicas: In multitudine munerum meorum respiciet Deus, et offerente me Deo altissimo, munera mea suscipiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Sirach 7:12",
      "text": "Non irrideas hominem in amaritudine animæ: est enim qui humiliat et exaltat circumspector Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Sirach 7:13",
      "text": "Noli amare mendacium adversus fratrem tuum, neque in amicum similiter facias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Sirach 7:14",
      "text": "Noli velle mentiri omne mendacium: assiduitas enim illius non est bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Sirach 7:15",
      "text": "Noli verbosus esse in multitudine presbyterorum, et non iteres verbum in oratione tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Sirach 7:16",
      "text": "Non oderis laboriosa opera, et rusticationem creatam ab Altissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Sirach 7:17",
      "text": "Non te reputes in multitudine indisciplinatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Sirach 7:18",
      "text": "Memento iræ, quoniam non tardabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Sirach 7:19",
      "text": "Humilia valde spiritum tuum, quoniam vindicta carnis impii ignis et vermis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Sirach 7:20",
      "text": "Noli prævaricari in amicum pecuniam differentem, neque fratrem carissimum auro spreveris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Sirach 7:21",
      "text": "Noli discedere a muliere sensata et bona, quam sortitus es in timore Domini: gratia enim verecundiæ illius super aurum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Sirach 7:22",
      "text": "Non lædas servum in veritate operantem, neque mercenarium dantem animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Sirach 7:23",
      "text": "Servus sensatus sit tibi dilectus quasi anima tua: non defraudes illum libertate, neque inopem derelinquas illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Sirach 7:24",
      "text": "Pecora tibi sunt, attende illis: et si sunt utilia, perseverent apud te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Sirach 7:25",
      "text": "Filii tibi sunt? erudi illos, et curva illos a pueritia illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Sirach 7:26",
      "text": "Filiæ tibi sunt? serva corpus illarum, et non ostendas hilarem faciem tuam ad illas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Sirach 7:27",
      "text": "Trade filiam, et grande opus feceris: et homini sensato da illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Sirach 7:28",
      "text": "Mulier si est tibi secundum animam tuam, non projicias illam: et odibili non credas te. In toto corde tuo",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Sirach 7:29",
      "text": "honora patrem tuum, et gemitus matris tuæ ne obliviscaris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Sirach 7:30",
      "text": "memento quoniam nisi per illos natus non fuisses: et retribue illis, quomodo et illi tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Sirach 7:31",
      "text": "In tota anima tua time Dominum, et sacerdotes illius sanctifica.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Sirach 7:32",
      "text": "In omni virtute tua dilige eum qui te fecit, et ministros ejus ne derelinquas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Sirach 7:33",
      "text": "Honora Deum ex tota anima tua, et honorifica sacerdotes, et propurga te cum brachiis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Sirach 7:34",
      "text": "Da illis partem, sicut mandatum est tibi, primitiarum et purgationis, et de negligentia tua purga te cum paucis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Sirach 7:35",
      "text": "Datum brachiorum tuorum, et sacrificium sanctificationis offeres Domino, et initia sanctorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Sirach 7:36",
      "text": "Et pauperi porrige manum tuam, ut perficiatur propitiatio et benedictio tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Sirach 7:37",
      "text": "Gratia dati in conspectu omnis viventis, et mortuo non prohibeas gratiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "Sirach 7:38",
      "text": "Non desis plorantibus in consolatione, et cum lugentibus ambula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.39",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "Sirach 7:39",
      "text": "Non te pigeat visitare infirmum: ex his enim in dilectione firmaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.7.40",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "Sirach 7:40",
      "text": "In omnibus operibus tuis memorare novissima tua, et in æternum non peccabis.",
      "paragraphStart": false
    }
  ]
}
