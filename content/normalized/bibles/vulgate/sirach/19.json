{
  "chapter": {
    "id": "vulgate:sirach.19",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 19,
    "referenceLabel": "Sirach 19",
    "summary": "Source text for Sirach 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.19.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Sirach 19:1",
      "text": "Operarius ebriosus non locupletabitur: et qui spernit modica paulatim decidet.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.19.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Sirach 19:2",
      "text": "Vinum et mulieres apostatare faciunt sapientes, et arguent sensatos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Sirach 19:3",
      "text": "Et qui se jungit fornicariis erit nequam: putredo et vermes hæreditabunt illum: et extolletur in exemplum majus, et tolletur de numero anima ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Sirach 19:4",
      "text": "Qui credit cito levis corde est, et minorabitur: et qui delinquit in animam suam, insuper habebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Sirach 19:5",
      "text": "Qui gaudet iniquitate, denotabitur: et qui odit correptionem, minuetur vita: et qui odit loquacitatem, extinguit malitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Sirach 19:6",
      "text": "Qui peccat in animam suam, pœnitebit: et qui jucundatur in malitia, denotabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Sirach 19:7",
      "text": "Ne iteres verbum nequam et durum, et non minoraberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Sirach 19:8",
      "text": "Amico et inimico noli narrare sensum tuum: et si est tibi delictum, noli denudare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Sirach 19:9",
      "text": "audiet enim te, et custodiet te, et quasi defendens peccatum, odiet te, et sic aderit tibi semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Sirach 19:10",
      "text": "Audisti verbum adversus proximum tuum? commoriatur in te, fidens quoniam non te dirumpet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Sirach 19:11",
      "text": "A facie verbi parturit fatuus, tamquam gemitus partus infantis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Sirach 19:12",
      "text": "Sagitta infixa femori carnis, sic verbum in corde stulti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Sirach 19:13",
      "text": "Corripe amicum, ne forte non intellexerit, et dicat: Non feci: aut, si fecerit, ne iterum addat facere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Sirach 19:14",
      "text": "Corripe proximum, ne forte non dixerit: et si dixerit, ne forte iteret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Sirach 19:15",
      "text": "Corripe amicum, sæpe enim fit commissio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Sirach 19:16",
      "text": "et non omni verbo credas. Est qui labitur lingua, sed non ex animo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Sirach 19:17",
      "text": "quis est enim qui non deliquerit in lingua sua? Corripe proximum antequam commineris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Sirach 19:18",
      "text": "et da locum timori Altissimi: quia omnis sapientia timor Dei, et in illa timere Deum, et in omni sapientia dispositio legis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Sirach 19:19",
      "text": "Et non est sapientia nequitiæ disciplina, et non est cogitatus peccatorum prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Sirach 19:20",
      "text": "Est nequitia, et in ipsa execratio, et est insipiens qui minuitur sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Sirach 19:21",
      "text": "Melior est homo qui minuitur sapientia, et deficiens sensu, in timore, quam qui abundat sensu, et transgreditur legem Altissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Sirach 19:22",
      "text": "Est solertia certa, et ipsa iniqua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Sirach 19:23",
      "text": "et est qui emittit verbum certum enarrans veritatem. Est qui nequiter humiliat se, et interiora ejus plena sunt dolo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Sirach 19:24",
      "text": "et est qui se nimium submittit a multa humilitate: et est qui inclinat faciem suam, et fingit se non videre quod ignoratum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Sirach 19:25",
      "text": "et si ab imbecillitate virium vetetur peccare, si invenerit tempus malefaciendi, malefaciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Sirach 19:26",
      "text": "Ex visu cognoscitur vir, et ab occursu faciei cognoscitur sensatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Sirach 19:27",
      "text": "Amictus corporis, et risus dentium, et ingressus hominis, enuntiant de illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.19.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Sirach 19:28",
      "text": "Est correptio mendax in ira contumeliosi, et est judicium quod non probatur esse bonum: et est tacens, et ipse est prudens.",
      "paragraphStart": false
    }
  ]
}
