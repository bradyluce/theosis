{
  "chapter": {
    "id": "vulgate:sirach.4",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 4,
    "referenceLabel": "Sirach 4",
    "summary": "Source text for Sirach 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.4.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Sirach 4:1",
      "text": "Fili, eleemosynam pauperis ne defraudes, et oculos tuos ne transvertas a paupere.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.4.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Sirach 4:2",
      "text": "Animam esurientem ne despexeris, et non exasperes pauperem in inopia sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Sirach 4:3",
      "text": "Cor inopis ne afflixeris, et non protrahas datum angustianti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Sirach 4:4",
      "text": "Rogationem contribulati ne abjicias, et non avertas faciem tuam ab egeno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Sirach 4:5",
      "text": "Ab inope ne avertas oculos tuos propter iram: et non relinquas quærentibus tibi retro maledicere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Sirach 4:6",
      "text": "Maledicentis enim tibi in amaritudine animæ, exaudietur deprecatio illius: exaudiet autem eum qui fecit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Sirach 4:7",
      "text": "Congregationi pauperum affabilem te facito: et presbytero humilia animam tuam, et magnato humilia caput tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Sirach 4:8",
      "text": "Declina pauperi sine tristitia aurem tuam, et redde debitum tuum, et responde illi pacifica in mansuetudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Sirach 4:9",
      "text": "Libera eum qui injuriam patitur de manu superbi, et non acide feras in anima tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Sirach 4:10",
      "text": "In judicando esto pupillis misericors ut pater, et pro viro matri illorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Sirach 4:11",
      "text": "et eris tu velut filius Altissimi obediens, et miserebitur tui magis quam mater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Sirach 4:12",
      "text": "Sapientia filiis suis vitam inspirat: et suscipit inquirentes se, et præibit in via justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Sirach 4:13",
      "text": "Et qui illam diligit, diligit vitam, et qui vigilaverint ad illam complectentur placorem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Sirach 4:14",
      "text": "Qui tenuerint illam, vitam hæreditabunt: et quo introibit benedicet Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Sirach 4:15",
      "text": "Qui serviunt ei obsequentes erunt sancto: et eos qui diligunt illam, diligit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Sirach 4:16",
      "text": "Qui audit illam judicabit gentes: et qui intuetur illam permanebit confidens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Sirach 4:17",
      "text": "Si crediderit ei, hæreditabit illam, et erunt in confirmatione creaturæ illius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Sirach 4:18",
      "text": "quoniam in tentatione ambulat cum eo, et in primis eligit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Sirach 4:19",
      "text": "Timorem, et metum, et probationem inducet super illum: et cruciabit illum in tribulatione doctrinæ suæ, donec tentet eum in cogitationibus suis, et credat animæ illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Sirach 4:20",
      "text": "Et firmabit illum, et iter adducet directum ad illum, et lætificabit illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Sirach 4:21",
      "text": "et denudabit absconsa sua illi, et thesaurizabit super illum scientiam et intellectum justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Sirach 4:22",
      "text": "Si autem oberraverit, derelinquet eum, et tradet eum in manus inimici sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Sirach 4:23",
      "text": "Fili, conserva tempus, et devita a malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Sirach 4:24",
      "text": "Pro anima tua ne confundaris dicere verum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Sirach 4:25",
      "text": "est enim confusio adducens peccatum, et est confusio adducens gloriam et gratiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Sirach 4:26",
      "text": "Ne accipias faciem adversus faciem tuam, nec adversus animam tuam mendacium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Sirach 4:27",
      "text": "Ne reverearis proximum tuum in casu suo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Sirach 4:28",
      "text": "nec retineas verbum in tempore salutis. Non abscondas sapientiam tuam in decore suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Sirach 4:29",
      "text": "in lingua enim sapientia dignoscitur: et sensus, et scientia, et doctrina in verbo sensati, et firmamentum in operibus justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Sirach 4:30",
      "text": "Non contradicas verbo veritatis ullo modo, et de mendacio ineruditionis tuæ confundere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Sirach 4:31",
      "text": "Non confundaris confiteri peccata tua, et ne subjicias te omni homini pro peccato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Sirach 4:32",
      "text": "Noli resistere contra faciem potentis, nec coneris contra ictum fluvii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Sirach 4:33",
      "text": "Pro justitia agonizare pro anima tua, et usque ad mortem certa pro justitia: et Deus expugnabit pro te inimicos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "Sirach 4:34",
      "text": "Noli citatus esse in lingua tua, et inutilis, et remissus in operibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "Sirach 4:35",
      "text": "Noli esse sicut leo in domo tua, evertens domesticos tuos, et opprimens subjectos tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.4.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "Sirach 4:36",
      "text": "Non sit porrecta manus tua ad accipiendum, et ad dandum collecta.",
      "paragraphStart": false
    }
  ]
}
