{
  "chapter": {
    "id": "vulgate:sirach.49",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 49,
    "referenceLabel": "Sirach 49",
    "summary": "Source text for Sirach 49 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.49.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 1,
      "referenceLabel": "Sirach 49:1",
      "text": "Memoria Josiæ in compositionem odoris facta opus pigmentarii.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.49.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 2,
      "referenceLabel": "Sirach 49:2",
      "text": "In omni ore quasi mel indulcabitur ejus memoria, et ut musica in convivio vini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 3,
      "referenceLabel": "Sirach 49:3",
      "text": "Ipse est directus divinitus in pœnitentiam gentis, et tulit abominationes impietatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 4,
      "referenceLabel": "Sirach 49:4",
      "text": "Et gubernavit ad Dominum cor ipsius, et in diebus peccatorum corroboravit pietatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 5,
      "referenceLabel": "Sirach 49:5",
      "text": "Præter David et Ezechiam et Josiam, omnes peccatum commiserunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 6,
      "referenceLabel": "Sirach 49:6",
      "text": "nam reliquerunt legem Altissimi reges Juda, et contempserunt timorem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 7,
      "referenceLabel": "Sirach 49:7",
      "text": "Dederunt enim regnum suum aliis, et gloriam suam alienigenæ genti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 8,
      "referenceLabel": "Sirach 49:8",
      "text": "Incenderunt electam sanctitatis civitatem, et desertas fecerunt vias ipsius in manu Jeremiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 9,
      "referenceLabel": "Sirach 49:9",
      "text": "Nam male tractaverunt illum qui a ventre matris consecratus est propheta, evertere, et eruere, et perdere, et iterum ædificare, et renovare:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 10,
      "referenceLabel": "Sirach 49:10",
      "text": "Ezechiel, qui vidit conspectum gloriæ quam ostendit illi in curru cherubim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 11,
      "referenceLabel": "Sirach 49:11",
      "text": "Nam commemoratus est inimicorum in imbre, benefacere illis qui ostenderunt rectas vias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 12,
      "referenceLabel": "Sirach 49:12",
      "text": "Et duodecim prophetarum ossa pullulent de loco suo: nam corroboraverunt Jacob, et redemerunt se in fide virtutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 13,
      "referenceLabel": "Sirach 49:13",
      "text": "Quomodo amplificemus Zorobabel? nam et ipse quasi signum in dextera manu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 14,
      "referenceLabel": "Sirach 49:14",
      "text": "sic et Jesum filium Josedec, qui in diebus suis ædificaverunt domum, et exaltaverunt templum sanctum Domino, paratum in gloriam sempiternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 15,
      "referenceLabel": "Sirach 49:15",
      "text": "Et Nehemias in memoriam multi temporis, qui erexit nobis muros eversos, et stare fecit portas et seras, qui erexit domos nostras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 16,
      "referenceLabel": "Sirach 49:16",
      "text": "Nemo natus est in terra qualis Henoch, nam et ipse receptus est a terra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 17,
      "referenceLabel": "Sirach 49:17",
      "text": "neque ut Joseph, qui natus est homo princeps fratrum, firmamentum gentis, rector fratrum, stabilimentum populi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 18,
      "referenceLabel": "Sirach 49:18",
      "text": "et ossa ipsius visitata sunt, et post mortem prophetaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.49.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 49,
      "verseNumber": 19,
      "referenceLabel": "Sirach 49:19",
      "text": "Seth et Sem apud homines gloriam adepti sunt, et super omnem animam in origine Adam.",
      "paragraphStart": false
    }
  ]
}
