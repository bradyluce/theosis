{
  "chapter": {
    "id": "vulgate:sirach.50",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 50,
    "referenceLabel": "Sirach 50",
    "summary": "Source text for Sirach 50 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.50.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Sirach 50:1",
      "text": "Simon, Oniæ filius, sacerdos magnus, qui in vita sua suffulsit domum, et in diebus suis corroboravit templum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.50.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Sirach 50:2",
      "text": "Templi etiam altitudo ab ipso fundata est, duplex ædificatio, et excelsi parietes templi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Sirach 50:3",
      "text": "In diebus ipsius emanaverunt putei aquarum, et quasi mare adimpleti sunt supra modum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Sirach 50:4",
      "text": "Qui curavit gentem suam, et liberavit eam a perditione:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Sirach 50:5",
      "text": "qui prævaluit amplificare civitatem, qui adeptus est gloriam in conversatione gentis, et ingressum domus et atrii amplificavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Sirach 50:6",
      "text": "Quasi stella matutina in medio nebulæ, et quasi luna plena, in diebus suis lucet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Sirach 50:7",
      "text": "et quasi sol refulgens, sic ille effulsit in templo Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Sirach 50:8",
      "text": "Quasi arcus refulgens inter nebulas gloriæ, et quasi flos rosarum in diebus vernis, et quasi lilia quæ sunt in transitu aquæ, et quasi thus redolens in diebus æstatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Sirach 50:9",
      "text": "quasi ignis effulgens, et thus ardens in igne:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Sirach 50:10",
      "text": "quasi vas auri solidum, ornatum omni lapide pretioso:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Sirach 50:11",
      "text": "quasi oliva pullulans, et cypressus in altitudinem se extollens, in accipiendo ipsum stolam gloriæ, et vestiri eum in consummationem virtutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Sirach 50:12",
      "text": "In ascensu altaris sancti gloriam dedit sanctitatis amictum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Sirach 50:13",
      "text": "In accipiendo autem partes de manu sacerdotum, et ipse stans juxta aram: et circa illum corona fratrum: quasi plantatio cedri in monte Libano,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Sirach 50:14",
      "text": "sic circa illum steterunt quasi rami palmæ: et omnes filii Aaron in gloria sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Sirach 50:15",
      "text": "Oblatio autem Domini in manibus ipsorum coram omni synagoga Israël: et consummatione fungens in ara, amplificare oblationem excelsi Regis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Sirach 50:16",
      "text": "porrexit manum suam in libatione, et libavit de sanguine uvæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Sirach 50:17",
      "text": "Effudit in fundamento altaris odorem divinum excelso Principi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Sirach 50:18",
      "text": "Tunc exclamaverunt filii Aaron, in tubis productilibus sonuerunt: et auditam fecerunt vocem magnam in memoriam coram Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Sirach 50:19",
      "text": "Tunc omnis populus simul properaverunt, et ceciderunt in faciem super terram, adorare Dominum Deum suum, et dare preces omnipotenti Deo excelso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Sirach 50:20",
      "text": "Et amplificaverunt psallentes in vocibus suis, et in magna domo auctus est sonus suavitatis plenus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Sirach 50:21",
      "text": "Et rogavit populus Dominum excelsum in prece, usque dum perfectus est honor Domini, et munus suum perfecerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 22,
      "referenceLabel": "Sirach 50:22",
      "text": "Tunc descendens, manus suas extulit in omne congregationem filiorum Israël, dare gloriam Deo a labiis suis, et in nomine ipsius gloriari:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 23,
      "referenceLabel": "Sirach 50:23",
      "text": "et iteravit orationem suam, volens ostendere virtutem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 24,
      "referenceLabel": "Sirach 50:24",
      "text": "Et nunc orate Deum omnium, qui magna fecit in omni terra, qui auxit dies nostros a ventre matris nostræ, et fecit nobiscum secundum suam misericordiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 25,
      "referenceLabel": "Sirach 50:25",
      "text": "det nobis jucunditatem cordis, et fieri pacem in diebus nostris in Israël per dies sempiternos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 26,
      "referenceLabel": "Sirach 50:26",
      "text": "credere Israël nobiscum esse Dei misericordiam, ut liberet nos in diebus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 27,
      "referenceLabel": "Sirach 50:27",
      "text": "Duas gentes odit anima mea: tertia autem non est gens quam oderim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 28,
      "referenceLabel": "Sirach 50:28",
      "text": "qui sedent in monte Seir, et Philisthiim, et stultus populus qui habitat in Sichimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 29,
      "referenceLabel": "Sirach 50:29",
      "text": "Doctrinam sapientiæ et disciplinæ scripsit in codice isto Jesus, filius Sirach, Jerosolymita, qui renovavit sapientiam de corde suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 30,
      "referenceLabel": "Sirach 50:30",
      "text": "Beatus qui in istis versatur bonis: qui ponit illa in corde suo, sapiens erit semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.50.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 50,
      "verseNumber": 31,
      "referenceLabel": "Sirach 50:31",
      "text": "Si enim hæc fecerit, ad omnia valebit, quia lux Dei vestigium ejus est.",
      "paragraphStart": false
    }
  ]
}
