{
  "chapter": {
    "id": "vulgate:sirach.9",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 9,
    "referenceLabel": "Sirach 9",
    "summary": "Source text for Sirach 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.9.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Sirach 9:1",
      "text": "Non zeles mulierem sinus tui, ne ostendat super te malitiam doctrinæ nequam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.9.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Sirach 9:2",
      "text": "Non des mulieri potestatem animæ tuæ, ne ingrediatur in virtutem tuam, et confundaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Sirach 9:3",
      "text": "Ne respicias mulierem multivolam, ne forte incidas in laqueos illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Sirach 9:4",
      "text": "Cum saltatrice ne assiduus sis, nec audias illam, ne forte pereas in efficacia illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Sirach 9:5",
      "text": "Virginem ne conspicias, ne forte scandalizeris in decore illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Sirach 9:6",
      "text": "Ne des fornicariis animam tuam in ullo, ne perdas te et hæreditatem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Sirach 9:7",
      "text": "Noli circumspicere in vicis civitatis, nec oberraveris in plateis illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Sirach 9:8",
      "text": "Averte faciem tuam a muliere compta, et ne circumspicias speciem alienam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Sirach 9:9",
      "text": "Propter speciem mulieris multi perierunt: et ex hoc concupiscentia quasi ignis exardescit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Sirach 9:10",
      "text": "Omnis mulier quæ est fornicaria, quasi stercus in via conculcabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Sirach 9:11",
      "text": "Speciem mulieris alienæ multi admirati, reprobi facti sunt: colloquium enim illius quasi ignis exardescit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Sirach 9:12",
      "text": "Cum aliena muliere ne sedeas omnino, nec accumbas cum ea super cubitum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Sirach 9:13",
      "text": "et non alterceris cum illa in vino, ne forte declinet cor tuum in illam, et sanguine tuo labaris in perditionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Sirach 9:14",
      "text": "Ne derelinquas amicum antiquum: novus enim non erit similis illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Sirach 9:15",
      "text": "Vinum novum amicus novus: veterascet, et cum suavitate bibes illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Sirach 9:16",
      "text": "Non zeles gloriam et opes peccatoris: non enim scis quæ futura sit illius subversio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Sirach 9:17",
      "text": "Non placeat tibi injuria injustorum, sciens quoniam usque ad inferos non placebit impius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Sirach 9:18",
      "text": "Longe abesto ab homine potestatem habente occidendi, et non suspicaberis timorem mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Sirach 9:19",
      "text": "Et si accesseris ad illum, noli aliquid committere, ne forte auferat vitam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Sirach 9:20",
      "text": "Communionem mortis scito, quoniam in medio laqueorum ingredieris, et super dolentium arma ambulabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Sirach 9:21",
      "text": "Secundum virtutem tuam cave te a proximo tuo, et cum sapientibus et prudentibus tracta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Sirach 9:22",
      "text": "Viri justi sint tibi convivæ, et in timore Dei sit tibi gloriatio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Sirach 9:23",
      "text": "et in sensu sit tibi cogitatus Dei, et omnis enarratio tua in præceptis Altissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Sirach 9:24",
      "text": "In manu artificum opera laudabuntur, et princeps populi in sapientia sermonis sui, in sensu vero seniorum verbum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.9.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Sirach 9:25",
      "text": "Terribilis est in civitate sua homo linguosus: et temerarius in verbo suo odibilis erit.",
      "paragraphStart": false
    }
  ]
}
