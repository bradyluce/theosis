{
  "chapter": {
    "id": "vulgate:sirach.12",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 12,
    "referenceLabel": "Sirach 12",
    "summary": "Source text for Sirach 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.12.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Sirach 12:1",
      "text": "Si benefeceris, scito cui feceris, et erit gratia in bonis tuis multa.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.12.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Sirach 12:2",
      "text": "Benefac justo, et invenies retributionem magnam: et si non ab ipso, certe a Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Sirach 12:3",
      "text": "Non est enim ei bene qui assiduus est in malis, et eleemosynas non danti: quoniam et Altissimus odio habet peccatores, et misertus est pœnitentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Sirach 12:4",
      "text": "Da misericordi, et ne suscipias peccatorem: et impiis et peccatoribus reddet vindictam, custodiens eos in diem vindictæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Sirach 12:5",
      "text": "Da bono, et non receperis peccatorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Sirach 12:6",
      "text": "Benefac humili, et non dederis impio: prohibe panes illi dari, ne in ipsis potentior te sit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Sirach 12:7",
      "text": "nam duplicia mala invenies in omnibus bonis quæcumque feceris illi, quoniam et Altissimus odio habet peccatores, et impiis reddet vindictam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Sirach 12:8",
      "text": "Non agnoscetur in bonis amicus, et non abscondetur in malis inimicus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Sirach 12:9",
      "text": "In bonis viri, inimici illius in tristitia: et in malitia illius, amicus agnitus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Sirach 12:10",
      "text": "Non credas inimico tuo in æternum: sicut enim æramentum æruginat nequitia illius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Sirach 12:11",
      "text": "et si humiliatus vadat curvus, adjice animum tuum, et custodi te ab illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Sirach 12:12",
      "text": "Non statuas illum penes te, nec sedeat ad dexteram tuam, ne forte conversus in locum tuum, inquirat cathedram tuam, et in novissimo agnosces verba mea, et in sermonibus meis stimuleris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Sirach 12:13",
      "text": "Quis miserebitur incantatori a serpente percusso, et omnibus qui appropiant bestiis? et sic qui comitatur cum viro iniquo, et obvolutus est in peccatis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Sirach 12:14",
      "text": "Una hora tecum permanebit: si autem declinaveris, non supportabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Sirach 12:15",
      "text": "In labiis suis indulcat inimicus, et in corde suo insidiatur ut subvertat te in foveam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Sirach 12:16",
      "text": "In oculis suis lacrimatur inimicus, et si invenerit tempus, non satiabitur sanguine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Sirach 12:17",
      "text": "Et si incurrerint tibi mala, invenies eum illic priorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Sirach 12:18",
      "text": "In oculis suis lacrimatur inimicus, et quasi adjuvans suffodiet plantas tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.12.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Sirach 12:19",
      "text": "Caput suum movebit, et plaudet manu, et multa susurrans commutabit vultum suum.",
      "paragraphStart": false
    }
  ]
}
