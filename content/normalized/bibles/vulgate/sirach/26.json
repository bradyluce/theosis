{
  "chapter": {
    "id": "vulgate:sirach.26",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 26,
    "referenceLabel": "Sirach 26",
    "summary": "Source text for Sirach 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.26.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Sirach 26:1",
      "text": "Mulieris bonæ beatus vir: numerus enim annorum illius duplex.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.26.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Sirach 26:2",
      "text": "Mulier fortis oblectat virum suum, et annos vitæ illius in pace implebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Sirach 26:3",
      "text": "Pars bona mulier bona, in parte timentium Deum dabitur viro pro factis bonis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Sirach 26:4",
      "text": "divitis autem et pauperis cor bonum, in omni tempore vultus illorum hilaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Sirach 26:5",
      "text": "A tribus timuit cor meum, et in quarto facies mea metuit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Sirach 26:6",
      "text": "delaturam civitatis, et collectionem populi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Sirach 26:7",
      "text": "calumniam mendacem super mortem omnia gravia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Sirach 26:8",
      "text": "dolor cordis et luctus, mulier zelotypa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Sirach 26:9",
      "text": "In muliere zelotypa flagellum linguæ, omnibus communicans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Sirach 26:10",
      "text": "Sicut boum jugum quod movetur, ita et mulier nequam: qui tenet illam quasi qui apprehendit scorpionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Sirach 26:11",
      "text": "Mulier ebriosa ira magna, et contumelia: et turpitudo illius non tegetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Sirach 26:12",
      "text": "Fornicatio mulieris in extollentia oculorum, et in palpebris illius agnoscetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Sirach 26:13",
      "text": "In filia non avertente se, firma custodiam, ne inventa occasione utatur se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Sirach 26:14",
      "text": "Ab omni irreverentia oculorum ejus cave, et ne mireris si te neglexerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Sirach 26:15",
      "text": "Sicut viator sitiens ad fontem os aperiet, et ab omni aqua proxima bibet, et contra omnem palum sedebit, et contra omnem sagittam aperiet pharetram donec deficiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Sirach 26:16",
      "text": "Gratia mulieris sedulæ delectabit virum suum, et ossa illius impinguabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Sirach 26:17",
      "text": "Disciplina illius datum Dei est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Sirach 26:18",
      "text": "Mulier sensata et tacita, non est immutatio eruditæ animæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Sirach 26:19",
      "text": "Gratia super gratiam mulier sancta et pudorata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Sirach 26:20",
      "text": "Omnis autem ponderatio non est digna continentis animæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Sirach 26:21",
      "text": "Sicut sol oriens mundo in altissimis Dei, sic mulieris bonæ species in ornamentum domus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Sirach 26:22",
      "text": "Lucerna splendens super candelabrum sanctum, et species faciei super ætatem stabilem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Sirach 26:23",
      "text": "Columnæ aureæ super bases argenteas, et pedes firmi super plantas stabilis mulieris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Sirach 26:24",
      "text": "Fundamenta æterna supra petram solidam, et mandata Dei in corde mulieris sanctæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Sirach 26:25",
      "text": "In duobus contristatum est cor meum, et in tertio iracundia mihi advenit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Sirach 26:26",
      "text": "vir bellator deficiens per inopiam; et vir sensatus contemptus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Sirach 26:27",
      "text": "et qui transgreditur a justitia ad peccatum: Deus paravit eum ad rhomphæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.26.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Sirach 26:28",
      "text": "Duæ species difficiles et periculosæ mihi apparuerunt: difficile exuitur negotians a negligentia, et non justificabitur caupo a peccatis labiorum.",
      "paragraphStart": false
    }
  ]
}
