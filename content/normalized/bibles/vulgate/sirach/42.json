{
  "chapter": {
    "id": "vulgate:sirach.42",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 42,
    "referenceLabel": "Sirach 42",
    "summary": "Source text for Sirach 42 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.42.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 1,
      "referenceLabel": "Sirach 42:1",
      "text": "Non duplices sermonem auditus de revelatione sermonis absconditi: et eris vere sine confusione, et invenies gratiam in conspectu omnium hominum. Ne pro his omnibus confundaris, et ne accipias personam ut delinquas:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.42.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 2,
      "referenceLabel": "Sirach 42:2",
      "text": "de lege Altissimi, et testamento, et de judicio justificare impium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 3,
      "referenceLabel": "Sirach 42:3",
      "text": "de verbo sociorum et viatorum, et de datione hæreditatis amicorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 4,
      "referenceLabel": "Sirach 42:4",
      "text": "de æqualitate stateræ et ponderum, de acquisitione multorum et paucorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 5,
      "referenceLabel": "Sirach 42:5",
      "text": "de corruptione emptionis et negotiatorum, et de multa disciplina filiorum, et servo pessimo latus sanguinare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 6,
      "referenceLabel": "Sirach 42:6",
      "text": "Super mulierem nequam bonum est signum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 7,
      "referenceLabel": "Sirach 42:7",
      "text": "Ubi manus multæ sunt, claude: et quodcumque trades, numera et appende: datum vero et acceptum omne describe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 8,
      "referenceLabel": "Sirach 42:8",
      "text": "De disciplina insensati et fatui, et de senioribus qui judicantur ab adolescentibus: et eris eruditus in omnibus, et probabilis in conspectu omnium vivorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 9,
      "referenceLabel": "Sirach 42:9",
      "text": "Filia patris abscondita est vigilia, et sollicitudo ejus aufert somnum: ne forte in adolescentia sua adulta efficiatur, et cum viro commorata odibilis fiat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 10,
      "referenceLabel": "Sirach 42:10",
      "text": "nequando polluatur in virginitate sua, et in paternis suis gravida inveniatur: ne forte cum viro commorata transgrediatur, aut certe sterilis efficiatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 11,
      "referenceLabel": "Sirach 42:11",
      "text": "Super filiam luxuriosam confirma custodiam, nequando faciat te in opprobrium venire inimicis, a detractione in civitate, et objectione plebis, et confundat te in multitudine populi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 12,
      "referenceLabel": "Sirach 42:12",
      "text": "Omni homini noli intendere in specie, et in medio mulierum noli commorari:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 13,
      "referenceLabel": "Sirach 42:13",
      "text": "de vestimentis enim procedit tinea, et a muliere iniquitas viri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 14,
      "referenceLabel": "Sirach 42:14",
      "text": "Melior est enim iniquitas viri quam mulier benefaciens, et mulier confundens in opprobrium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 15,
      "referenceLabel": "Sirach 42:15",
      "text": "Memor ero igitur operum Domini, et quæ vidi annuntiabo. In sermonibus Domini opera ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 16,
      "referenceLabel": "Sirach 42:16",
      "text": "Sol illuminans per omnia respexit, et gloria Domini plenum est opus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 17,
      "referenceLabel": "Sirach 42:17",
      "text": "Nonne Dominus fecit sanctos enarrare omnia mirabilia sua, quæ confirmavit Dominus omnipotens stabiliri in gloria sua?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 18,
      "referenceLabel": "Sirach 42:18",
      "text": "Abyssum et cor hominum investigavit, et in astutia eorum excogitavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 19,
      "referenceLabel": "Sirach 42:19",
      "text": "Cognovit enim Dominus omnem scientiam, et inspexit in signum ævi, annuntians quæ præterierunt et quæ superventura sunt, revelans vestigia occultorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 20,
      "referenceLabel": "Sirach 42:20",
      "text": "Non præterit illum omnis cogitatus, et non abscondit se ab eo ullus sermo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 21,
      "referenceLabel": "Sirach 42:21",
      "text": "Magnalia sapientiæ suæ decoravit, qui est ante sæculum et usque in sæculum: neque adjectum est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 22,
      "referenceLabel": "Sirach 42:22",
      "text": "neque minuitur, et non eget alicujus consilio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 23,
      "referenceLabel": "Sirach 42:23",
      "text": "Quam desiderabilia omnia opera ejus! et tamquam scintilla quæ est considerare!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 24,
      "referenceLabel": "Sirach 42:24",
      "text": "Omnia hæc vivunt, et manent in sæculum, et in omni necessitate omnia obaudiunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 25,
      "referenceLabel": "Sirach 42:25",
      "text": "Omnia duplicia, unum contra unum, et non fecit quidquam deesse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.42.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 42,
      "verseNumber": 26,
      "referenceLabel": "Sirach 42:26",
      "text": "Uniuscujusque confirmavit bona: et quis satiabitur videns gloriam ejus?",
      "paragraphStart": false
    }
  ]
}
