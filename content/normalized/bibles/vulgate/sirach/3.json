{
  "chapter": {
    "id": "vulgate:sirach.3",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 3,
    "referenceLabel": "Sirach 3",
    "summary": "Source text for Sirach 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.3.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Sirach 3:1",
      "text": "Filii sapientiæ ecclesia justorum, et natio illorum obedientia et dilectio.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.3.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Sirach 3:2",
      "text": "Judicium patris audite, filii, et sic facite, ut salvi sitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Sirach 3:3",
      "text": "Deus enim honoravit patrem in filiis: et judicium matris exquirens, firmavit in filios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Sirach 3:4",
      "text": "Qui diligit Deum exorabit pro peccatis, et continebit se ab illis, et in oratione dierum exaudietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Sirach 3:5",
      "text": "Et sicut qui thesaurizat, ita et qui honorificat matrem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Sirach 3:6",
      "text": "Qui honorat patrem suum jucundabitur in filiis, et in die orationis suæ exaudietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Sirach 3:7",
      "text": "Qui honorat patrem suum vita vivet longiore, et qui obedit patri refrigerabit matrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Sirach 3:8",
      "text": "Qui timet Dominum honorat parentes, et quasi dominis serviet his qui se genuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Sirach 3:9",
      "text": "In opere, et sermone, et omni patientia, honora patrem tuum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Sirach 3:10",
      "text": "ut superveniat tibi benedictio ab eo, et benedictio illius in novissimo maneat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Sirach 3:11",
      "text": "Benedictio patris firmat domos filiorum: maledictio autem matris eradicat fundamenta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Sirach 3:12",
      "text": "Ne glorieris in contumelia patris tui: non enim est tibi gloria ejus confusio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Sirach 3:13",
      "text": "Gloria enim hominis ex honore patris sui, et dedecus filii pater sine honore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Sirach 3:14",
      "text": "Fili, suscipe senectam patris tui, et non contristes eum in vita illius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Sirach 3:15",
      "text": "et si defecerit sensu, veniam da, et ne spernas eum in virtute tua: eleemosyna enim patris non erit in oblivione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Sirach 3:16",
      "text": "Nam pro peccato matris restituetur tibi bonum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Sirach 3:17",
      "text": "et in justitia ædificabitur tibi, et in die tribulationis commemorabitur tui, et sicut in sereno glacies, solventur peccata tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Sirach 3:18",
      "text": "Quam malæ famæ est qui derelinquit patrem, et est maledictus a Deo qui exasperat matrem!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Sirach 3:19",
      "text": "Fili, in mansuetudine opera tua perfice, et super hominum gloriam diligeris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Sirach 3:20",
      "text": "Quanto magnus es, humilia te in omnibus, et coram Deo invenies gratiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Sirach 3:21",
      "text": "quoniam magna potentia Dei solius, et ab humilibus honoratur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Sirach 3:22",
      "text": "Altiora te ne quæsieris, et fortiora te ne scrutatus fueris: sed quæ præcepit tibi Deus, illa cogita semper, et in pluribus operibus ejus ne fueris curiosus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Sirach 3:23",
      "text": "Non est enim tibi necessarium ea, quæ abscondita sunt, videre oculis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Sirach 3:24",
      "text": "In supervacuis rebus noli scrutari multipliciter, et in pluribus operibus ejus non eris curiosus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Sirach 3:25",
      "text": "Plurima enim super sensum hominum ostensa sunt tibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Sirach 3:26",
      "text": "multos quoque supplantavit suspicio illorum, et in vanitate detinuit sensus illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Sirach 3:27",
      "text": "Cor durum habebit male in novissimo, et qui amat periculum in illo peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Sirach 3:28",
      "text": "Cor ingrediens duas vias non habebit successus, et pravus corde in illis scandalizabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Sirach 3:29",
      "text": "Cor nequam gravabitur in doloribus, et peccator adjiciet ad peccandum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Sirach 3:30",
      "text": "Synagogæ superborum non erit sanitas, frutex enim peccati radicabitur in illis, et non intelligetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Sirach 3:31",
      "text": "Cor sapientis intelligitur in sapientia, et auris bona audiet cum omni concupiscentia sapientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Sirach 3:32",
      "text": "Sapiens cor et intelligibile abstinebit se a peccatis, et in operibus justitiæ successus habebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Sirach 3:33",
      "text": "Ignem ardentem exstinguit aqua, et eleemosyna resistit peccatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.3.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Sirach 3:34",
      "text": "et Deus prospector est ejus qui reddit gratiam: meminit ejus in posterum, et in tempore casus sui inveniet firmamentum.",
      "paragraphStart": false
    }
  ]
}
