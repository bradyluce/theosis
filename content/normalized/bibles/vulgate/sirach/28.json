{
  "chapter": {
    "id": "vulgate:sirach.28",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 28,
    "referenceLabel": "Sirach 28",
    "summary": "Source text for Sirach 28 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.28.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Sirach 28:1",
      "text": "Qui vindicari vult, a Domino inveniet vindictam, et peccata illius servans servabit.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.28.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Sirach 28:2",
      "text": "Relinque proximo tuo nocenti te, et tunc deprecanti tibi peccata solventur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Sirach 28:3",
      "text": "Homo homini reservat iram, et a Deo quærit medelam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Sirach 28:4",
      "text": "in hominem similem sibi non habet misericordiam, et de peccatis suis deprecatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Sirach 28:5",
      "text": "Ipse cum caro sit reservat iram, et propitiationem petit a Deo: quis exorabit pro delictis illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Sirach 28:6",
      "text": "Memento novissimorum, et desine inimicari:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Sirach 28:7",
      "text": "tabitudo enim et mors imminent in mandatis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Sirach 28:8",
      "text": "Memorare timorem Dei, et non irascaris proximo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Sirach 28:9",
      "text": "Memorare testamentum Altissimi, et despice ignorantiam proximi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Sirach 28:10",
      "text": "Abstine te a lite, et minues peccata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Sirach 28:11",
      "text": "Homo enim iracundus incendit litem, et vir peccator turbabit amicos, et in medio pacem habentium immittet inimicitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Sirach 28:12",
      "text": "Secundum enim ligna silvæ sic ignis exardescit: et secundum virtutem hominis sic iracundia illius erit, et secundum substantiam suam exaltabit iram suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Sirach 28:13",
      "text": "Certamen festinatum incendit ignem, et lis festinans effundit sanguinem: et lingua testificans adducit mortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Sirach 28:14",
      "text": "Si sufflaveris in scintillam, quasi ignis exardebit: et si exspueris super illam, extinguetur: utraque ex ore proficiscuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Sirach 28:15",
      "text": "Susurro et bilinguis maledictus, multos enim turbabit pacem habentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Sirach 28:16",
      "text": "Lingua tertia multos commovit, et dispersit illos de gente in gentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Sirach 28:17",
      "text": "Civitates muratas divitum destruxit, et domus magnatorum effodit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Sirach 28:18",
      "text": "Virtutes populorum concidit, et gentes fortes dissolvit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Sirach 28:19",
      "text": "Lingua tertia mulieres viratas ejecit, et privavit illas laboribus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Sirach 28:20",
      "text": "Qui respicit illam non habebit requiem, nec habebit amicum in quo requiescat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Sirach 28:21",
      "text": "Flagelli plaga livorem facit: plaga autem linguæ comminuet ossa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Sirach 28:22",
      "text": "Multi ceciderunt in ore gladii: sed non sic quasi qui interierunt per linguam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Sirach 28:23",
      "text": "Beatus qui tectus est a lingua nequam, qui in iracundiam illius non transivit, et qui non attraxit jugum illius, et in vinculis ejus non est ligatus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Sirach 28:24",
      "text": "jugum enim illius jugum ferreum est, et vinculum illius vinculum æreum est;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Sirach 28:25",
      "text": "mors illius mors nequissima: et utilis potius infernus quam illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Sirach 28:26",
      "text": "Perseverantia illius non permanebit, sed obtinebit vias injustorum, et in flamma sua non comburet justos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Sirach 28:27",
      "text": "Qui relinquunt Deum incident in illam, et exardebit in illis, et non extinguetur, et immittetur in illos quasi leo, et quasi pardus lædet illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Sirach 28:28",
      "text": "Sepi aures tuas spinis: linguam nequam noli audire: et ori tuo facito ostia et seras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 29,
      "referenceLabel": "Sirach 28:29",
      "text": "Aurum tuum et argentum tuum confla, et verbis tuis facito stateram, et frenos ori tuo rectos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.28.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 28,
      "verseNumber": 30,
      "referenceLabel": "Sirach 28:30",
      "text": "et attende ne forte labaris in lingua, et cadas in conspectu inimicorum insidiantium tibi, et sit casus tuus insanabilis in mortem.",
      "paragraphStart": false
    }
  ]
}
