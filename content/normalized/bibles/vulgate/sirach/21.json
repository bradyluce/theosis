{
  "chapter": {
    "id": "vulgate:sirach.21",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 21,
    "referenceLabel": "Sirach 21",
    "summary": "Source text for Sirach 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.21.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Sirach 21:1",
      "text": "Fili, peccasti, non adjicias iterum: sed et de pristinis deprecare, ut tibi dimittantur.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.21.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Sirach 21:2",
      "text": "Quasi a facie colubri fuge peccata: et si accesseris ad illa, suscipient te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Sirach 21:3",
      "text": "Dentes leonis dentes ejus, interficientes animas hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Sirach 21:4",
      "text": "Quasi rhomphæa bis acuta omnis iniquitas: plagæ illius non est sanitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Sirach 21:5",
      "text": "Objurgatio et injuriæ annullabunt substantiam, et domus quæ nimis locuples est annullabitur superbia: sic substantia superbi eradicabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Sirach 21:6",
      "text": "Deprecatio pauperis ex ore usque ad aures ejus perveniet, et judicium festinato adveniet illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Sirach 21:7",
      "text": "Qui odit correptionem vestigium est peccatoris, et qui timet Deum convertetur ad cor suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Sirach 21:8",
      "text": "Notus a longe potens lingua audaci, et sensatus scit labi se ab ipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Sirach 21:9",
      "text": "Qui ædificat domum suam impendiis alienis, quasi qui colligat lapides suos in hieme.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Sirach 21:10",
      "text": "Stupa collecta synagoga peccantium, et consummatio illorum flamma ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Sirach 21:11",
      "text": "Via peccatorum complanata lapidibus: et in fine illorum inferi, et tenebræ, et pœnæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Sirach 21:12",
      "text": "Qui custodit justitiam, continebit sensum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Sirach 21:13",
      "text": "Consummatio timoris Dei, sapientia et sensus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Sirach 21:14",
      "text": "Non erudietur qui non est sapiens in bono.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Sirach 21:15",
      "text": "Est autem sapientia quæ abundat in malo, et non est sensus ubi est amaritudo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Sirach 21:16",
      "text": "Scientia sapientis tamquam inundatio abundabit, et consilium illius sicut fons vitæ permanet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Sirach 21:17",
      "text": "Cor fatui quasi vas confractum, et omnem sapientiam non tenebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Sirach 21:18",
      "text": "Verbum sapiens quodcumque audierit scius, laudabit, et ad se adjiciet: audivit luxuriosus, et displicebit illi, et projiciet illud post dorsum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Sirach 21:19",
      "text": "Narratio fatui quasi sarcina in via: nam in labiis sensati invenietur gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Sirach 21:20",
      "text": "Os prudentis quæritur in ecclesia, et verba illius cogitabunt in cordibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Sirach 21:21",
      "text": "Tamquam domus exterminata, sic fatuo sapientia: et scientia insensati inenarrabilia verba.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Sirach 21:22",
      "text": "Compedes in pedibus, stulto doctrina: et quasi vincula manuum super manum dextram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Sirach 21:23",
      "text": "Fatuus in risu exaltat vocem suam: vir autem sapiens vix tacite ridebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Sirach 21:24",
      "text": "Ornamentum aureum prudenti doctrina, et quasi brachiale in brachio dextro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Sirach 21:25",
      "text": "Pes fatui facilis in domum proximi: et homo peritus confundetur a persona potentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Sirach 21:26",
      "text": "Stultus a fenestra respiciet in domum: vir autem eruditus foris stabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Sirach 21:27",
      "text": "Stultitia hominis auscultare per ostium: et prudens gravabitur contumelia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Sirach 21:28",
      "text": "Labia imprudentium stulta narrabunt; verba autem prudentium statera ponderabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Sirach 21:29",
      "text": "In ore fatuorum cor illorum, et in corde sapientium os illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Sirach 21:30",
      "text": "Dum maledicit impius diabolum, maledicit ipse animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.21.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Sirach 21:31",
      "text": "Susurro coinquinabit animam suam, et in omnibus odietur, et qui cum eo manserit odiosus erit: tacitus et sensatus honorabitur.",
      "paragraphStart": false
    }
  ]
}
