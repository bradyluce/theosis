{
  "chapter": {
    "id": "vulgate:sirach.36",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 36,
    "referenceLabel": "Sirach 36",
    "summary": "Source text for Sirach 36 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.36.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Sirach 36:1",
      "text": "Miserere nostri, Deus omnium, et respice nos, et ostende nobis lucem miserationum tuarum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.36.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Sirach 36:2",
      "text": "et immitte timorem tuum super gentes quæ non exquisierunt te, ut cognoscant quia non est deus nisi tu, et enarrent magnalia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Sirach 36:3",
      "text": "Alleva manum tuam super gentes alienas, ut videant potentiam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Sirach 36:4",
      "text": "Sicut enim in conspectu eorum sanctificatus es in nobis, sic in conspectu nostro magnificaberis in eis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Sirach 36:5",
      "text": "ut cognoscant te, sicut et nos cognovimus quoniam non est deus præter te, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Sirach 36:6",
      "text": "Innova signa, et immuta mirabilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Sirach 36:7",
      "text": "Glorifica manum et brachium dextrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Sirach 36:8",
      "text": "Excita furorem, et effunde iram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Sirach 36:9",
      "text": "Tolle adversarium, et afflige inimicum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Sirach 36:10",
      "text": "Festina tempus, et memento finis, ut enarrent mirabilia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Sirach 36:11",
      "text": "In ira flammæ devoretur qui salvatur: et qui pessimant plebem tuam inveniant perditionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Sirach 36:12",
      "text": "Contere caput principum inimicorum, dicentium: Non est alius præter nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Sirach 36:13",
      "text": "Congrega omnes tribus Jacob, ut cognoscant quia non est deus nisi tu, et enarrent magnalia tua, et hæreditabis eos sicut ab initio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Sirach 36:14",
      "text": "Miserere plebi tuæ, super quam invocatum est nomen tuum, et Israël quem coæquasti primogenito tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Sirach 36:15",
      "text": "Miserere civitati sanctificationis tuæ, Jerusalem, civitati requiei tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Sirach 36:16",
      "text": "Reple Sion inenarrabilibus verbis tuis, et gloria tua populum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Sirach 36:17",
      "text": "Da testimonium his qui ab initio creaturæ tuæ sunt, et suscita prædicationes quas locuti sunt in nomine tuo prophetæ priores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Sirach 36:18",
      "text": "Da mercedem sustinentibus te, ut prophetæ tui fideles inveniantur: et exaudi orationes servorum tuorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Sirach 36:19",
      "text": "secundum benedictionem Aaron de populo tuo: et dirige nos in viam justitiæ, et sciant omnes qui habitant terram quia tu es Deus conspector sæculorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Sirach 36:20",
      "text": "Omnem escam manducabit venter: et est cibus cibo melior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Sirach 36:21",
      "text": "Fauces contingunt cibum feræ, et cor sensatum verba mendacia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Sirach 36:22",
      "text": "Cor pravum dabit tristitiam, et homo peritus resistet illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Sirach 36:23",
      "text": "Omnem masculum excipiet mulier: et est filia melior filia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Sirach 36:24",
      "text": "Species mulieris exhilarat faciem viri sui, et super omnem concupiscentiam hominis superducit desiderium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Sirach 36:25",
      "text": "Si est lingua curationis, est et mitigationis et misericordiæ: non est vir illius secundum filios hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Sirach 36:26",
      "text": "Qui possidet mulierem bonam inchoat possessionem: adjutorium secundum illum est, et columna ut requies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Sirach 36:27",
      "text": "Ubi non est sepes, diripietur possessio: et ubi non est mulier, ingemiscit egens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.36.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Sirach 36:28",
      "text": "Quis credit ei qui non habet nidum, et deflectens ubicumque obscuraverit, quasi succinctus latro exiliens de civitate in civitatem?",
      "paragraphStart": false
    }
  ]
}
