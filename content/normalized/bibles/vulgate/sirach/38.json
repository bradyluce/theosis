{
  "chapter": {
    "id": "vulgate:sirach.38",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 38,
    "referenceLabel": "Sirach 38",
    "summary": "Source text for Sirach 38 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.38.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Sirach 38:1",
      "text": "Honora medicum propter necessitatem: etenim illum creavit Altissimus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.38.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Sirach 38:2",
      "text": "A Deo est enim omnis medela, et a rege accipiet donationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Sirach 38:3",
      "text": "Disciplina medici exaltabit caput illius, et in conspectu magnatorum collaudabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Sirach 38:4",
      "text": "Altissimus creavit de terra medicamenta, et vir prudens non abhorrebit illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Sirach 38:5",
      "text": "Nonne a ligno indulcata est aqua amara?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Sirach 38:6",
      "text": "Ad agnitionem hominum virtus illorum: et dedit hominibus scientiam Altissimus, honorari in mirabilibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Sirach 38:7",
      "text": "In his curans mitigabit dolorem: et unguentarius faciet pigmenta suavitatis, et unctiones conficiet sanitatis: et non consummabuntur opera ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Sirach 38:8",
      "text": "Pax enim Dei super faciem terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Sirach 38:9",
      "text": "Fili, in tua infirmitate ne despicias teipsum: sed ora Dominum, et ipse curabit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Sirach 38:10",
      "text": "Averte a delicto, et dirige manus, et ab omni delicto munda cor tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Sirach 38:11",
      "text": "Da suavitatem et memoriam similaginis, et impingua oblationem, et da locum medico:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Sirach 38:12",
      "text": "etenim illum Dominus creavit, et non discedat a te, quia opera ejus sunt necessaria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Sirach 38:13",
      "text": "Est enim tempus quando in manus illorum incurras:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Sirach 38:14",
      "text": "ipsi vero Dominum deprecabuntur, ut dirigat requiem eorum, et sanitatem, propter conversationem illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Sirach 38:15",
      "text": "Qui delinquit in conspectu ejus qui fecit eum, incidet in manus medici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Sirach 38:16",
      "text": "Fili, in mortuum produc lacrimas, et quasi dira passus incipe plorare: et secundum judicium contege corpus illius, et non despicias sepulturam illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Sirach 38:17",
      "text": "Propter delaturam autem amare fer luctum illius uno die, et consolare propter tristitiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Sirach 38:18",
      "text": "et fac luctum secundum meritum ejus uno die, vel duobus, propter detractionem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Sirach 38:19",
      "text": "a tristitia enim festinat mors, et cooperit virtutem, et tristitia cordis flectit cervicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Sirach 38:20",
      "text": "In abductione permanet tristitia, et substantia inopis secundum cor ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Sirach 38:21",
      "text": "Ne dederis in tristitia cor tuum, sed repelle eam a te, et memento novissimorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Sirach 38:22",
      "text": "Noli oblivisci, neque enim est conversio: et huic nihil proderis, et teipsum pessimabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 23,
      "referenceLabel": "Sirach 38:23",
      "text": "Memor esto judicii mei: sic enim erit et tuum: mihi heri, et tibi hodie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 24,
      "referenceLabel": "Sirach 38:24",
      "text": "In requie mortui requiescere fac memoriam ejus, et consolare illum in exitu spiritus sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 25,
      "referenceLabel": "Sirach 38:25",
      "text": "Sapientia scribæ in tempore vacuitatis, et qui minoratur actu sapientiam percipiet, qua sapientia replebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 26,
      "referenceLabel": "Sirach 38:26",
      "text": "Qui tenet aratrum, et qui gloriatur in jaculo, stimulo boves agitat, et conversatur in operibus eorum, et enarratio ejus in filiis taurorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 27,
      "referenceLabel": "Sirach 38:27",
      "text": "Cor suum dabit ad versandos sulcos, et vigilia ejus in sagina vaccarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.28",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 28,
      "referenceLabel": "Sirach 38:28",
      "text": "Sic omnis faber et architectus, qui noctem tamquam diem transigit: qui sculpit signacula sculptilia, et assiduitas ejus variat picturam: cor suum dabit in similitudinem picturæ, et vigilia sua perficiet opus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.29",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 29,
      "referenceLabel": "Sirach 38:29",
      "text": "Sic faber ferrarius sedens juxta incudem, et considerans opus ferri: vapor ignis uret carnes ejus, et in calore fornacis concertatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.30",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 30,
      "referenceLabel": "Sirach 38:30",
      "text": "Vox mallei innovat aurem ejus, et contra similitudinem vasis oculus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.31",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 31,
      "referenceLabel": "Sirach 38:31",
      "text": "Cor suum dabit in consummationem operum, et vigilia sua ornabit in perfectionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.32",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 32,
      "referenceLabel": "Sirach 38:32",
      "text": "Sic figulus sedens ad opus suum, convertens pedibus suis rotam, qui in sollicitudine positus est semper propter opus suum, et in numero est omnis operatio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.33",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 33,
      "referenceLabel": "Sirach 38:33",
      "text": "In brachio suo formabit lutum, et ante pedes suos curvabit virtutem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.34",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 34,
      "referenceLabel": "Sirach 38:34",
      "text": "Cor suum dabit ut consummet linitionem, et vigilia sua mundabit fornacem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.35",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 35,
      "referenceLabel": "Sirach 38:35",
      "text": "Omnes hi in manibus suis speraverunt, et unusquisque in arte sua sapiens est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.36",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 36,
      "referenceLabel": "Sirach 38:36",
      "text": "Sine his omnibus non ædificatur civitas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.37",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 37,
      "referenceLabel": "Sirach 38:37",
      "text": "et non inhabitabunt, nec inambulabunt, et in ecclesiam non transilient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.38",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 38,
      "referenceLabel": "Sirach 38:38",
      "text": "Super sellam judicis non sedebunt, et testamentum judicii non intelligent, neque palam facient disciplinam et judicium, et in parabolis non invenientur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.38.39",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 38,
      "verseNumber": 39,
      "referenceLabel": "Sirach 38:39",
      "text": "sed creaturam ævi confirmabunt: et deprecatio illorum in operatione artis, accomodantes animam suam, et conquirentes in lege Altissimi.",
      "paragraphStart": false
    }
  ]
}
