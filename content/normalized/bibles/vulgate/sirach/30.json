{
  "chapter": {
    "id": "vulgate:sirach.30",
    "translationId": "vulgate",
    "bookSlug": "sirach",
    "chapterNumber": 30,
    "referenceLabel": "Sirach 30",
    "summary": "Source text for Sirach 30 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:sirach.30.1",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Sirach 30:1",
      "text": "Qui diligit filium suum assiduat illi flagella, ut lætetur in novissimo suo, et non palpet proximorum ostia.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:sirach.30.2",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Sirach 30:2",
      "text": "Qui docet filium suum laudabitur in illo, et in medio domesticorum in illo gloriabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.3",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Sirach 30:3",
      "text": "Qui docet filium suum in zelum mittit inimicum, et in medio amicorum gloriabitur in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.4",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Sirach 30:4",
      "text": "Mortuus est pater ejus, et quasi non est mortuus: similem enim reliquit sibi post se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.5",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Sirach 30:5",
      "text": "In vita sua vidit, et lætatus est in illo: in obitu suo non est contristatus, nec confusus est coram inimicis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.6",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Sirach 30:6",
      "text": "reliquit enim defensorem domus contra inimicos, et amicis reddentem gratiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.7",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Sirach 30:7",
      "text": "Pro animabus filiorum colligabit vulnera sua, et super omnem vocem turbabuntur viscera ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.8",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Sirach 30:8",
      "text": "Equus indomitus evadit durus, et filius remissus evadet præceps.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.9",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Sirach 30:9",
      "text": "Lacta filium, et paventem te faciet: lude cum eo, et contristabit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.10",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Sirach 30:10",
      "text": "Non corrideas illi, ne doleas, et in novissimo obstupescent dentes tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.11",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Sirach 30:11",
      "text": "Non des illi potestatem in juventute, et ne despicias cogitatus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.12",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Sirach 30:12",
      "text": "Curva cervicem ejus in juventute, et tunde latera ejus dum infans est, ne forte induret, et non credat tibi, et erit tibi dolor animæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.13",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Sirach 30:13",
      "text": "Doce filium tuum, et operare in illo, ne in turpitudinem illius offendas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.14",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Sirach 30:14",
      "text": "Melior est pauper sanus, et fortis viribus, quam dives imbecillis et flagellatus malitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.15",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Sirach 30:15",
      "text": "Salus animæ in sanctitate justitiæ melior est omni auro et argento: et corpus validum quam census immensus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.16",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Sirach 30:16",
      "text": "Non est census super censum salutis corporis, et non est oblectamentum super cordis gaudium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.17",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Sirach 30:17",
      "text": "Melior est mors quam vita amara, et requies æterna quam languor perseverans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.18",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Sirach 30:18",
      "text": "Bona abscondita in ore clauso, quasi appositiones epularum circumpositæ sepulchro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.19",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Sirach 30:19",
      "text": "Quid proderit libatio idolo? nec enim manducabit, nec odorabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.20",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Sirach 30:20",
      "text": "Sic qui effugatur a Domino, portans mercedes iniquitatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.21",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Sirach 30:21",
      "text": "videns oculis et ingemiscens, sicut spado complectens virginem, et suspirans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.22",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Sirach 30:22",
      "text": "Tristitiam non des animæ tuæ, et non affligas temetipsum in consilio tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.23",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Sirach 30:23",
      "text": "Jucunditas cordis, hæc est vita hominis, et thesaurus sine defectione sanctitatis: et exsultatio viri est longævitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.24",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Sirach 30:24",
      "text": "Miserere animæ tuæ placens Deo, et contine: congrega cor tuum in sanctitate ejus, et tristitiam longe repelle a te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.25",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Sirach 30:25",
      "text": "Multos enim occidit tristitia, et non est utilitas in illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.26",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Sirach 30:26",
      "text": "Zelus et iracundia minuunt dies, et ante tempus senectam adducet cogitatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:sirach.30.27",
      "translationId": "vulgate",
      "bookSlug": "sirach",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Sirach 30:27",
      "text": "Splendidum cor et bonum in epulis est: epulæ enim illius diligenter fiunt.",
      "paragraphStart": false
    }
  ]
}
