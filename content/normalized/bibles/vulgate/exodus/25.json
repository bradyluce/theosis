{
  "chapter": {
    "id": "vulgate:exodus.25",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 25,
    "referenceLabel": "Exodus 25",
    "summary": "Source text for Exodus 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.25.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Exodus 25:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.25.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Exodus 25:2",
      "text": "Loquere filiis Israël, ut tollant mihi primitias: ab omni homine qui offeret ultroneus, accipietis eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Exodus 25:3",
      "text": "Hæc sunt autem quæ accipere debeatis: aurum, et argentum, et æs,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Exodus 25:4",
      "text": "hyacinthum et purpuram, coccumque bis tinctum, et byssum, pilos caprarum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Exodus 25:5",
      "text": "et pelles arietum rubricatas, pellesque janthinas, et ligna setim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Exodus 25:6",
      "text": "oleum ad luminaria concinnanda: aromata in unguentum, et thymiamata boni odoris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Exodus 25:7",
      "text": "lapides onychinos, et gemmas ad ornandum ephod, ac rationale.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Exodus 25:8",
      "text": "Facientque mihi sanctuarium, et habitabo in medio eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Exodus 25:9",
      "text": "juxta omnem similitudinem tabernaculi quod ostendam tibi, et omnium vasorum in cultum ejus. Sicque facietis illud:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Exodus 25:10",
      "text": "arcam de lignis setim compingite, cujus longitudo habeat duos et semis cubitos: latitudo, cubitum et dimidium: altitudo, cubitum similiter ac semissem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Exodus 25:11",
      "text": "Et deaurabis eam auro mundissimo intus et foris: faciesque supra, coronam auream per circuitum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Exodus 25:12",
      "text": "et quatuor circulos aureos, quos pones per quatuor arcæ angulos: duo circuli sint in latere uno, et duo in altero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Exodus 25:13",
      "text": "Facies quoque vectes de lignis setim, et operies eos auro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Exodus 25:14",
      "text": "Inducesque per circulos qui sunt in arcæ lateribus, ut portetur in eis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Exodus 25:15",
      "text": "qui semper erunt in circulis, nec umquam extrahentur ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Exodus 25:16",
      "text": "Ponesque in arca testificationem quam dabo tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Exodus 25:17",
      "text": "Facies et propitiatorium de auro mundissimo: duos cubitos et dimidium tenebit longitudo ejus, et cubitum ac semissem latitudo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Exodus 25:18",
      "text": "Duos quoque cherubim aureos et productiles facies, ex utraque parte oraculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Exodus 25:19",
      "text": "Cherub unus sit in latere uno, et alter in altero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Exodus 25:20",
      "text": "Utrumque latus propitiatorii tegant expandentes alas, et operientes oraculum, respiciantque se mutuo versis vultibus in propitiatorium quo operienda est arca,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Exodus 25:21",
      "text": "in qua pones testimonium quod dabo tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Exodus 25:22",
      "text": "Inde præcipiam, et loquar ad te supra propitiatorium, ac de medio duorum cherubim, qui erunt super arcam testimonii, cuncta quæ mandabo per te filiis Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Exodus 25:23",
      "text": "Facies et mensam de lignis setim, habentem duos cubitos longitudinis, et in latitudine cubitum, et in altitudine cubitum et semissem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Exodus 25:24",
      "text": "Et inaurabis eam auro purissimo: faciesque illi labium aureum per circuitum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Exodus 25:25",
      "text": "et ipsi labio coronam interrasilem altam quatuor digitis: et super illam, alteram coronam aureolam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Exodus 25:26",
      "text": "Quatuor quoque circulos aureos præparabis, et pones eis in quatuor angulis ejusdem mensæ per singulos pedes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Exodus 25:27",
      "text": "Subter coronam erunt circuli aurei, ut mittantur vectes per eos, et possit mensa portari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Exodus 25:28",
      "text": "Ipsos quoque vectes facies de lignis setim, et circumdabis auro ad subvehendam mensam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "Exodus 25:29",
      "text": "Parabis et acetabula, ac phialas, thuribula, et cyathos, in quibus offerenda sunt libamina, ex auro purissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 30,
      "referenceLabel": "Exodus 25:30",
      "text": "Et pones super mensam panes propositionis in conspectu meo semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 31,
      "referenceLabel": "Exodus 25:31",
      "text": "Facies et candelabrum ductile de auro mundissimo, hastile ejus, et calamos, scyphos, et sphærulas, ac lilia ex ipso procedentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 32,
      "referenceLabel": "Exodus 25:32",
      "text": "Sex calami egredientur de lateribus, tres ex uno latere, et tres ex altero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 33,
      "referenceLabel": "Exodus 25:33",
      "text": "Tres scyphi quasi in nucis modum per calamos singulos, sphærulaque simul, et lilium: et tres similiter scyphi instar nucis in calamo altero, sphærulaque simul et lilium. Hoc erit opus sex calamorum, qui producendi sunt de hastili:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 34,
      "referenceLabel": "Exodus 25:34",
      "text": "in ipso autem candelabro erunt quatuor scyphi in nucis modum, sphærulæque per singulos, et lilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 35,
      "referenceLabel": "Exodus 25:35",
      "text": "Sphærulæ sub duobus calamis per tria loca, qui simul sex fiunt procedentes de hastili uno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 36,
      "referenceLabel": "Exodus 25:36",
      "text": "Et sphærulæ igitur et calami ex ipso erunt, universa ductilia de auro purissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.37",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 37,
      "referenceLabel": "Exodus 25:37",
      "text": "Facies et lucernas septem, et pones eas super candelabrum, ut luceant ex adverso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.38",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 38,
      "referenceLabel": "Exodus 25:38",
      "text": "Emunctoria quoque, et ubi quæ emuncta sunt extinguantur, fiant de auro purissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.39",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 39,
      "referenceLabel": "Exodus 25:39",
      "text": "Omne pondus candelabri cum universis vasis suis habebit talentum auri purissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.25.40",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 25,
      "verseNumber": 40,
      "referenceLabel": "Exodus 25:40",
      "text": "Inspice, et fac secundum exemplar quod tibi in monte monstratum est.",
      "paragraphStart": false
    }
  ]
}
