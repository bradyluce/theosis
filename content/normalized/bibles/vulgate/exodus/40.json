{
  "chapter": {
    "id": "vulgate:exodus.40",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 40,
    "referenceLabel": "Exodus 40",
    "summary": "Source text for Exodus 40 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.40.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Exodus 40:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.40.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Exodus 40:2",
      "text": "Mense primo, prima die mensis, eriges tabernaculum testimonii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Exodus 40:3",
      "text": "et pones in eo arcam, dimittesque ante illam velum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Exodus 40:4",
      "text": "et illata mensa, pones super eam quæ rite præcepta sunt. Candelabrum stabit cum lucernis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Exodus 40:5",
      "text": "et altare aureum, in quo adoletur incensum, coram arca testimonii. Tentorium in introitu tabernaculi pones,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Exodus 40:6",
      "text": "et ante illud altare holocausti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Exodus 40:7",
      "text": "labrum inter altare et tabernaculum, quod implebis aqua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Exodus 40:8",
      "text": "Circumdabisque atrium tentoriis, et ingressum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Exodus 40:9",
      "text": "Et assumpto unctionis oleo unges tabernaculum cum vasis suis, ut sanctificentur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Exodus 40:10",
      "text": "altare holocausti et omnia vasa ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Exodus 40:11",
      "text": "labrum cum basi sua: omnia unctionis oleo consecrabis, ut sint Sancta sanctorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Exodus 40:12",
      "text": "Applicabisque Aaron et filios ejus ad fores tabernaculi testimonii, et lotos aqua",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Exodus 40:13",
      "text": "indues sanctis vestibus, ut ministrent mihi, et unctio eorum in sacerdotium sempiternum proficiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Exodus 40:14",
      "text": "Fecitque Moyses omnia quæ præceperat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 15,
      "referenceLabel": "Exodus 40:15",
      "text": "Igitur mense primo anni secundi, prima die mensis, collocatum est tabernaculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 16,
      "referenceLabel": "Exodus 40:16",
      "text": "Erexitque Moyses illud, et posuit tabulas ac bases et vectes, statuitque columnas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 17,
      "referenceLabel": "Exodus 40:17",
      "text": "et expandit tectum super tabernaculum, imposito desuper operimento, sicut Dominus imperaverat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 18,
      "referenceLabel": "Exodus 40:18",
      "text": "Posuit et testimonium in arca, subditis infra vectibus, et oraculum desuper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 19,
      "referenceLabel": "Exodus 40:19",
      "text": "Cumque intulisset arcam in tabernaculum, appendit ante eam velum ut expleret Domini jussionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 20,
      "referenceLabel": "Exodus 40:20",
      "text": "Posuit et mensam in tabernaculo testimonii ad plagam septentrionalem extra velum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 21,
      "referenceLabel": "Exodus 40:21",
      "text": "ordinatis coram propositionis panibus, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 22,
      "referenceLabel": "Exodus 40:22",
      "text": "Posuit et candelabrum in tabernaculo testimonii e regione mensæ in parte australi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 23,
      "referenceLabel": "Exodus 40:23",
      "text": "locatis per ordinem lucernis, juxta præceptum Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 24,
      "referenceLabel": "Exodus 40:24",
      "text": "Posuit et altare aureum sub tecto testimonii contra velum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 25,
      "referenceLabel": "Exodus 40:25",
      "text": "et adolevit super eo incensum aromatum, sicut jusserat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 26,
      "referenceLabel": "Exodus 40:26",
      "text": "Posuit et tentorium in introitu tabernaculi testimonii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 27,
      "referenceLabel": "Exodus 40:27",
      "text": "et altare holocausti in vestibulo testimonii, offerens in eo holocaustum, et sacrificia, ut Dominus imperaverat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 28,
      "referenceLabel": "Exodus 40:28",
      "text": "Labrum quoque statuit inter tabernaculum testimonii et altare, implens illud aqua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 29,
      "referenceLabel": "Exodus 40:29",
      "text": "Laveruntque Moyses et Aaron ac filii ejus manus suas et pedes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 30,
      "referenceLabel": "Exodus 40:30",
      "text": "cum ingrederentur tectum fœderis, et accederent ad altare, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 31,
      "referenceLabel": "Exodus 40:31",
      "text": "Erexit et atrium per gyrum tabernaculi et altaris, ducto in introitu ejus tentorio. Postquam omnia perfecta sunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 32,
      "referenceLabel": "Exodus 40:32",
      "text": "operuit nubes tabernaculum testimonii, et gloria Domini implevit illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 33,
      "referenceLabel": "Exodus 40:33",
      "text": "Nec poterat Moyses ingredi tectum fœderis, nube operiente omnia, et majestate Domini coruscante, quia cuncta nubes operuerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 34,
      "referenceLabel": "Exodus 40:34",
      "text": "Siquando nubes tabernaculum deserebat, proficiscebantur filii Israël per turmas suas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 35,
      "referenceLabel": "Exodus 40:35",
      "text": "si pendebat desuper, manebant in eodem loco.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.40.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 40,
      "verseNumber": 36,
      "referenceLabel": "Exodus 40:36",
      "text": "Nubes quippe Domini incubabat per diem tabernaculo, et ignis in nocte, videntibus cunctis populis Israël per cunctas mansiones suas.",
      "paragraphStart": false
    }
  ]
}
