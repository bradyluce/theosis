{
  "chapter": {
    "id": "vulgate:exodus.39",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 39,
    "referenceLabel": "Exodus 39",
    "summary": "Source text for Exodus 39 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.39.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 1,
      "referenceLabel": "Exodus 39:1",
      "text": "De hyacintho vero et purpura, vermiculo ac bysso, fecit vestes, quibus indueretur Aaron quando ministrabat in sanctis, sicut præcepit Dominus Moysi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.39.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 2,
      "referenceLabel": "Exodus 39:2",
      "text": "Fecit igitur superhumerale de auro, hyacintho, et purpura, coccoque bis tincto, et bysso retorta,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 3,
      "referenceLabel": "Exodus 39:3",
      "text": "opere polymitario: inciditque bracteas aureas, et extenuavit in fila, ut possent torqueri cum priorum colorum subtegmine,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 4,
      "referenceLabel": "Exodus 39:4",
      "text": "duasque oras sibi invicem copulatas in utroque latere summitatum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 5,
      "referenceLabel": "Exodus 39:5",
      "text": "et balteum ex eisdem coloribus, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 6,
      "referenceLabel": "Exodus 39:6",
      "text": "Paravit et duos lapides onychinos, astrictos et inclusos auro, et sculptos arte gemmaria nominibus filiorum Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 7,
      "referenceLabel": "Exodus 39:7",
      "text": "posuitque eos in lateribus superhumeralis in monimentum filiorum Israël, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 8,
      "referenceLabel": "Exodus 39:8",
      "text": "Fecit et rationale opere polymito juxta opus superhumeralis, ex auro, hyacintho, purpura, coccoque bis tincto, et bysso retorta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 9,
      "referenceLabel": "Exodus 39:9",
      "text": "quadrangulum, duplex, mensuræ palmi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 10,
      "referenceLabel": "Exodus 39:10",
      "text": "Et posuit in eo gemmarum ordines quatuor. In primo versu erat sardius, topazius, smaragdus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 11,
      "referenceLabel": "Exodus 39:11",
      "text": "In secundo, carbunculus, sapphirus, et jaspis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 12,
      "referenceLabel": "Exodus 39:12",
      "text": "In tertio, ligurius, achates, et amethystus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 13,
      "referenceLabel": "Exodus 39:13",
      "text": "In quarto, chrysolithus, onychinus, et beryllus, circumdati et inclusi auro per ordines suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 14,
      "referenceLabel": "Exodus 39:14",
      "text": "Ipsique lapides duodecim sculpti erant nominibus duodecim tribuum Israël, singuli per nomina singulorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 15,
      "referenceLabel": "Exodus 39:15",
      "text": "Fecerunt in rationali et catenulas sibi invicem cohærentes, de auro purissimo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 16,
      "referenceLabel": "Exodus 39:16",
      "text": "et duos uncinos, totidemque annulos aureos. Porro annulos posuerunt in utroque latere rationalis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 17,
      "referenceLabel": "Exodus 39:17",
      "text": "e quibus penderent duæ catenæ aureæ, quas inseruerunt uncinis, qui in superhumeralis angulis eminebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 18,
      "referenceLabel": "Exodus 39:18",
      "text": "Hæc et ante et retro ita conveniebant sibi, ut superhumerale et rationale mutuo necterentur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 19,
      "referenceLabel": "Exodus 39:19",
      "text": "stricta ad balteum et annulis fortius copulata, quos jungebat vitta hyacinthina, ne laxa fluerent, et a se invicem moverentur, sicut præcepit Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 20,
      "referenceLabel": "Exodus 39:20",
      "text": "Feceruntque quoque tunicam superhumeralis totam hyacinthinam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 21,
      "referenceLabel": "Exodus 39:21",
      "text": "et capitium in superiori parte contra medium, oramque per gyrum capitii textilem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 22,
      "referenceLabel": "Exodus 39:22",
      "text": "deorsum autem ad pedes mala punica ex hyacintho, purpura, vermiculo, ac bysso retorta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 23,
      "referenceLabel": "Exodus 39:23",
      "text": "et tintinnabula de auro purissimo, quæ posuerunt inter malogranata, in extrema parte tunicæ per gyrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 24,
      "referenceLabel": "Exodus 39:24",
      "text": "tintinnabulum autem aureum, et malum punicum, quibus ornatus incedebat pontifex quando ministerio fungebatur, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 25,
      "referenceLabel": "Exodus 39:25",
      "text": "Fecerunt et tunicas byssinas opere textili Aaron et filiis ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 26,
      "referenceLabel": "Exodus 39:26",
      "text": "et mitras cum coronulis suis ex bysso:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 27,
      "referenceLabel": "Exodus 39:27",
      "text": "feminalia quoque linea, byssina:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 28,
      "referenceLabel": "Exodus 39:28",
      "text": "cingulum vero de bysso retorta, hyacintho, purpura, ac vermiculo bis tincto, arte plumaria, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 29,
      "referenceLabel": "Exodus 39:29",
      "text": "Fecerunt et laminam sacræ venerationis de auro purissimo, scripseruntque in ea opere gemmario, Sanctum Domini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 30,
      "referenceLabel": "Exodus 39:30",
      "text": "et strinxerunt eam cum mitra vitta hyacinthina, sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 31,
      "referenceLabel": "Exodus 39:31",
      "text": "Perfectum est igitur omne opus tabernaculi et tecti testimonii: feceruntque filii Israël cuncta quæ præceperat Dominus Moysi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 32,
      "referenceLabel": "Exodus 39:32",
      "text": "Et obtulerunt tabernaculum et tectum et universam supellectilem, annulos, tabulas, vectes, columnas ac bases,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 33,
      "referenceLabel": "Exodus 39:33",
      "text": "opertorium de pellibus arietum rubricatis, et aliud operimentum de janthinis pellibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 34,
      "referenceLabel": "Exodus 39:34",
      "text": "velum; arcam, vectes, propitiatorium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 35,
      "referenceLabel": "Exodus 39:35",
      "text": "mensam cum vasis suis et propositionis panibus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 36,
      "referenceLabel": "Exodus 39:36",
      "text": "candelabrum, lucernas, et utensilia earum cum oleo;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.37",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 37,
      "referenceLabel": "Exodus 39:37",
      "text": "altare aureum, et unguentum, et thymiama ex aromatibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.38",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 38,
      "referenceLabel": "Exodus 39:38",
      "text": "et tentorium in introitu tabernaculi;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.39",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 39,
      "referenceLabel": "Exodus 39:39",
      "text": "altare æneum, retiaculum, vectes, et vasa ejus omnia; labrum cum basi sua; tentoria atrii, et columnas cum basibus suis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.40",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 40,
      "referenceLabel": "Exodus 39:40",
      "text": "tentorium in introitu atrii, funiculosque illius et paxillos. Nihil ex vasis defuit, quæ in ministerium tabernaculi, et in tectum fœderis jussa sunt fieri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.41",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 41,
      "referenceLabel": "Exodus 39:41",
      "text": "Vestes quoque, quibus sacerdotes utuntur in sanctuario, Aaron scilicet et filii ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.42",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 42,
      "referenceLabel": "Exodus 39:42",
      "text": "obtulerunt filii Israël, sicut præceperat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.39.43",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 39,
      "verseNumber": 43,
      "referenceLabel": "Exodus 39:43",
      "text": "Quæ postquam Moyses cuncta vidit completa, benedixit eis.",
      "paragraphStart": false
    }
  ]
}
