{
  "chapter": {
    "id": "vulgate:exodus.21",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 21,
    "referenceLabel": "Exodus 21",
    "summary": "Source text for Exodus 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.21.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Exodus 21:1",
      "text": "Hæc sunt judicia quæ propones eis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.21.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Exodus 21:2",
      "text": "Si emeris servum hebræum, sex annis serviet tibi: in septimo egredietur liber gratis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Exodus 21:3",
      "text": "Cum quali veste intraverit, cum tali exeat: si habens uxorem, et uxor egredietur simul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Exodus 21:4",
      "text": "Sin autem dominus dederit illi uxorem, et pepererit filios et filias: mulier et liberi ejus erunt domini sui, ipse vero exibit cum vestitu suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Exodus 21:5",
      "text": "Quod si dixerit servus: Diligo dominum meum et uxorem ac liberos; non egrediar liber:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Exodus 21:6",
      "text": "offeret eum dominus diis, et applicabitur ad ostium et postes, perforabitque aurem ejus subula: et erit ei servus in sæculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Exodus 21:7",
      "text": "Si quis vendiderit filiam suam in famulam, non egredietur sicut ancillæ exire consueverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Exodus 21:8",
      "text": "Si displicuerit oculis domini sui cui tradita fuerat, dimittet eam: populo autem alieno vendendi non habebit potestatem, si spreverit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Exodus 21:9",
      "text": "Sin autem filio suo desponderit eam, juxta morem filiarum faciet illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Exodus 21:10",
      "text": "Quod si alteram ei acceperit, providebit puellæ nuptias, et vestimenta, et pretium pudicitiæ non negabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Exodus 21:11",
      "text": "Si tria ista non fecerit, egredietur gratis absque pecunia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Exodus 21:12",
      "text": "Qui percusserit hominem volens occidere, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Exodus 21:13",
      "text": "Qui autem non est insidiatus, sed Deus illum tradidit in manus ejus, constituam tibi locum in quem fugere debeat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Exodus 21:14",
      "text": "Si quis per industriam occiderit proximum suum, et per insidias: ab altari meo evelles eum, ut moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Exodus 21:15",
      "text": "Qui percusserit patrem suum aut matrem, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Exodus 21:16",
      "text": "Qui furatus fuerit hominem, et vendiderit eum, convictus noxæ, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Exodus 21:17",
      "text": "Qui maledixerit patri suo, vel matri, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Exodus 21:18",
      "text": "Si rixati fuerint viri, et percusserit alter proximum suum lapide vel pugno, et ille mortuus non fuerit, sed jacuerit in lectulo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Exodus 21:19",
      "text": "si surrexerit, et ambulaverit foris super baculum suum, innocens erit qui percusserit, ita tamen ut operas ejus et impensas in medicos restituat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Exodus 21:20",
      "text": "Qui percusserit servum suum, vel ancillam virga, et mortui fuerint in manibus ejus, criminis reus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Exodus 21:21",
      "text": "Sin autem uno die vel duobus supervixerit, non subjacebit pœnæ, quia pecunia illius est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Exodus 21:22",
      "text": "Si rixati fuerint viri, et percusserit quis mulierem prægnantem, et abortivum quidem fecerit, sed ipsa vixerit: subjacebit damno quantum maritus mulieris expetierit, et arbitri judicaverint.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Exodus 21:23",
      "text": "Sin autem mors ejus fuerit subsecuta, reddet animam pro anima,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Exodus 21:24",
      "text": "oculum pro oculo, dentem pro dente, manum pro manu, pedem pro pede,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Exodus 21:25",
      "text": "adustionem pro adustione, vulnus pro vulnere, livorem pro livore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Exodus 21:26",
      "text": "Si percusserit quispiam oculum servi sui aut ancillæ, et luscos eos fecerit, dimittet eos liberos pro oculo quem eruit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Exodus 21:27",
      "text": "Dentem quoque si excusserit servo vel ancillæ suæ, similiter dimittet eos liberos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Exodus 21:28",
      "text": "Si bos cornu percusserit virum aut mulierem, et mortui fuerint, lapidibus obruetur: et non comedentur carnes ejus, dominus quoque bovis innocens erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Exodus 21:29",
      "text": "Quod si bos cornupeta fuerit ab heri et nudiustertius, et contestati sunt dominum ejus, nec recluserit eum, occideritque virum aut mulierem: et bos lapidibus obruetur, et dominum ejus occident.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Exodus 21:30",
      "text": "Quod si pretium fuerit ei impositum, dabit pro anima sua quidquid fuerit postulatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Exodus 21:31",
      "text": "Filium quoque et filiam si cornu percusserit, simili sententiæ subjacebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Exodus 21:32",
      "text": "Si servum ancillamque invaserit, triginta siclos argenti domino dabit, bos vero lapidibus opprimetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Exodus 21:33",
      "text": "Si quis aperuerit cisternam, et foderit, et non operuerit eam, cecideritque bos aut asinus in eam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Exodus 21:34",
      "text": "reddet dominus cisternæ pretium jumentorum: quod autem mortuum est, ipsius erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 35,
      "referenceLabel": "Exodus 21:35",
      "text": "Si bos alienus bovem alterius vulneraverit, et ille mortuus fuerit: vendent bovem vivum, et divident pretium, cadaver autem mortui inter se dispertient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.21.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 21,
      "verseNumber": 36,
      "referenceLabel": "Exodus 21:36",
      "text": "Sin autem sciebat quod bos cornupeta esset ab heri et nudiustertius, et non custodivit eum dominus suus: reddet bovem pro bove, et cadaver integrum accipiet.",
      "paragraphStart": false
    }
  ]
}
