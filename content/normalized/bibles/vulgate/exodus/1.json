{
  "chapter": {
    "id": "vulgate:exodus.1",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 1,
    "referenceLabel": "Exodus 1",
    "summary": "Source text for Exodus 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.1.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Exodus 1:1",
      "text": "Hæc sunt nomina filiorum Israël qui ingressi sunt in Ægyptum cum Jacob: singuli cum domibus suis introierunt:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.1.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Exodus 1:2",
      "text": "Ruben, Simeon, Levi, Judas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Exodus 1:3",
      "text": "Issachar, Zabulon et Benjamin,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Exodus 1:4",
      "text": "Dan et Nephthali, Gad et Aser.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Exodus 1:5",
      "text": "Erant igitur omnes animæ eorum qui egressi sunt de femore Jacob, septuaginta: Joseph autem in Ægypto erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Exodus 1:6",
      "text": "Quo mortuo, et universis fratribus ejus, omnique cognatione illa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Exodus 1:7",
      "text": "filii Israël creverunt, et quasi germinantes multiplicati sunt: ac roborati nimis, impleverunt terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Exodus 1:8",
      "text": "Surrexit interea rex novus super Ægyptum, qui ignorabat Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Exodus 1:9",
      "text": "Et ait ad populum suum: Ecce, populus filiorum Israël multus, et fortior nobis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Exodus 1:10",
      "text": "Venite, sapienter opprimamus eum, ne forte multiplicetur: et si ingruerit contra nos bellum, addatur inimicis nostris, expugnatisque nobis egrediatur de terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Exodus 1:11",
      "text": "Præposuit itaque eis magistros operum, ut affligerent eos oneribus: ædificaveruntque urbes tabernaculorum Pharaoni, Phithom et Ramesses.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Exodus 1:12",
      "text": "Quantoque opprimebant eos, tanto magis multiplicabantur, et crescebant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Exodus 1:13",
      "text": "oderantque filios Israël Ægyptii, et affligebant illudentes eis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Exodus 1:14",
      "text": "atque ad amaritudinem perducebant vitam eorum operibus duris luti et lateris, omnique famulatu, quo in terræ operibus premebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Exodus 1:15",
      "text": "Dixit autem rex Ægypti obstetricibus Hebræorum, quarum una vocabatur Sephora, altera Phua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Exodus 1:16",
      "text": "præcipiens eis: Quando obstetricabitis Hebræas, et partus tempus advenerit: si masculus fuerit, interficite eum: si femina, reservate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Exodus 1:17",
      "text": "Timuerunt autem obstetrices Deum, et non fecerunt juxta præceptum regis Ægypti, sed conservabant mares.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Exodus 1:18",
      "text": "Quibus ad se accersitis, rex ait: Quidnam est hoc quod facere voluistis, ut pueros servaretis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Exodus 1:19",
      "text": "Quæ responderunt: Non sunt Hebreæ sicut ægyptiæ mulieres: ipsæ enim obstetricandi habent scientiam, et priusquam veniamus ad eas, pariunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Exodus 1:20",
      "text": "Bene ergo fecit Deus obstetricibus: et crevit populus, confortatusque est nimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Exodus 1:21",
      "text": "Et quia timuerunt obstetrices Deum, ædificavit eis domos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.1.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Exodus 1:22",
      "text": "Præcepit ergo Pharao omni populo suo, dicens: Quidquid masculini sexus natum fuerit, in flumen projicite: quidquid feminini, reservate.",
      "paragraphStart": false
    }
  ]
}
