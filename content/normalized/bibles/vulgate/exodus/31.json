{
  "chapter": {
    "id": "vulgate:exodus.31",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 31,
    "referenceLabel": "Exodus 31",
    "summary": "Source text for Exodus 31 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.31.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Exodus 31:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.31.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Exodus 31:2",
      "text": "Ecce, vocavi ex nomine Beseleel filium Uri filii Hur de tribu Juda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Exodus 31:3",
      "text": "et implevi spiritu Dei, sapientia, et intelligentia et scientia in omni opere,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Exodus 31:4",
      "text": "ad excogitandum quidquid fabrefieri potest ex auro, et argento, et ære,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Exodus 31:5",
      "text": "marmore, et gemmis, et diversitate lignorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Exodus 31:6",
      "text": "Dedique ei socium Ooliab filium Achisamech de tribu Dan. Et in corde omnis eruditi posui sapientiam: ut faciant cuncta quæ præcepi tibi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Exodus 31:7",
      "text": "tabernaculum fœderis, et arcam testimonii, et propitiatorium, quod super eam est, et cuncta vasa tabernaculi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Exodus 31:8",
      "text": "mensamque et vasa ejus, candelabrum purissimum cum vasis suis, et altaris thymiamatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Exodus 31:9",
      "text": "et holocausti, et omnia vasa eorum, labrum cum basi sua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Exodus 31:10",
      "text": "vestes sanctas in ministerio Aaron sacerdoti, et filiis ejus, ut fungantur officio suo in sacris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Exodus 31:11",
      "text": "oleum unctionis, et thymiama aromatum in sanctuario, omnia quæ præcepi tibi, facient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Exodus 31:12",
      "text": "Et locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Exodus 31:13",
      "text": "Loquere filiis Israël, et dices ad eos: Videte ut sabbatum meum custodiatis: quia signum est inter me et vos in generationibus vestris: ut sciatis quia ego Dominus, qui sanctifico vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Exodus 31:14",
      "text": "Custodite sabbatum meum, sanctum est enim vobis: qui polluerit illud, morte morietur; qui fecerit in eo opus, peribit anima illius de medio populi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Exodus 31:15",
      "text": "Sex diebus facietis opus: in die septimo sabbatum est, requies sancta Domino; omnis qui fecerit opus in hac die, morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Exodus 31:16",
      "text": "Custodiant filii Israël sabbatum, et celebrent illud in generationibus suis. Pactum est sempiternum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Exodus 31:17",
      "text": "inter me et filios Israël, signumque perpetuum; sex enim diebus fecit Dominus cælum et terram, et in septimo ab opere cessavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.31.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Exodus 31:18",
      "text": "Deditque Dominus Moysi, completis hujuscemodi sermonibus in monte Sinai, duas tabulas testimonii lapideas, scriptas digito Dei.",
      "paragraphStart": false
    }
  ]
}
