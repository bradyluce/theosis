{
  "chapter": {
    "id": "vulgate:exodus.23",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 23,
    "referenceLabel": "Exodus 23",
    "summary": "Source text for Exodus 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.23.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Exodus 23:1",
      "text": "Non suscipies vocem mendacii, nec junges manum tuam ut pro impio dicas falsum testimonium.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.23.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Exodus 23:2",
      "text": "Non sequeris turbam ad faciendum malum: nec in judicio, plurimorum acquiesces sententiæ, ut a vero devies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Exodus 23:3",
      "text": "Pauperis quoque non misereberis in judicio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Exodus 23:4",
      "text": "Si occurreris bovi inimici tui, aut asino erranti, reduc ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Exodus 23:5",
      "text": "Si videris asinum odientis te jacere sub onere, non pertransibis, sed sublevabis cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Exodus 23:6",
      "text": "Non declinabis in judicium pauperis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Exodus 23:7",
      "text": "Mendacium fugies. Insontem et justum non occides: quia aversor impium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Exodus 23:8",
      "text": "Nec accipies munera, quæ etiam excæcant prudentes, et subvertunt verba justorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Exodus 23:9",
      "text": "Peregrino molestus non eris. Scitis enim advenarum animas: quia et ipsi peregrini fuistis in terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Exodus 23:10",
      "text": "Sex annis seminabis terram tuam, et congregabis fruges ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Exodus 23:11",
      "text": "anno autem septimo dimittes eam, et requiescere facies, ut comedant pauperes populi tui: et quidquid reliquum fuerit, edant bestiæ agri: ita facies in vinea et in oliveto tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Exodus 23:12",
      "text": "Sex diebus operaberis: septimo die cessabis, ut requiescat bos et asinus tuus, et refrigeretur filius ancillæ tuæ, et advena.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Exodus 23:13",
      "text": "Omnia quæ dixi vobis, custodite. Et per nomen externorum deorum non jurabitis, neque audietur ex ore vestro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Exodus 23:14",
      "text": "Tribus vicibus per singulos annos mihi festa celebrabitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Exodus 23:15",
      "text": "Solemnitatem azymorum custodies. Septem diebus comedes azyma, sicut præcepi tibi, tempore mensis novorum, quando egressus es de Ægypto: non apparebis in conspectu meo vacuus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Exodus 23:16",
      "text": "Et solemnitatem messis primitivorum operis tui, quæcumque seminaveris in agro: solemnitatem quoque in exitu anni, quando congregaveris omnes fruges tuas de agro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Exodus 23:17",
      "text": "Ter in anno apparebit omne masculinum tuum coram Domino Deo tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Exodus 23:18",
      "text": "Non immolabis super fermento sanguinem victimæ meæ, nec remanebit adeps solemnitatis meæ usque mane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Exodus 23:19",
      "text": "Primitias frugum terræ tuæ deferes in domum Domini Dei tui. Non coques hædum in lacte matris suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Exodus 23:20",
      "text": "Ecce ego mittam angelum meum, qui præcedat te, et custodiat in via, et introducat in locum quem paravi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Exodus 23:21",
      "text": "Observa eum, et audi vocem ejus, nec contemnendum putes: quia non dimittet cum peccaveris, et est nomen meum in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Exodus 23:22",
      "text": "Quod si audieris vocem ejus, et feceris omnia quæ loquor, inimicus ero inimicis tuis, et affligam affligentes te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Exodus 23:23",
      "text": "Præcedetque te angelus meus, et introducet te ad Amorrhæum, et Hethæum, et Pherezæum, Chananæumque, et Hevæum, et Jebusæum, quos ego conteram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Exodus 23:24",
      "text": "Non adorabis deos eorum, nec coles eos: non facies opera eorum, sed destrues eos, et confringes statuas eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Exodus 23:25",
      "text": "Servietisque Domino Deo vestro, ut benedicam panibus tuis et aquis, et auferam infirmitatem de medio tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Exodus 23:26",
      "text": "Non erit infœcunda, nec sterilis in terra tua: numerum dierum tuorum implebo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Exodus 23:27",
      "text": "Terrorem meum mittam in præcursum tuum, et occidam omnem populum, ad quem ingredieris: cunctorumque inimicorum tuorum coram te terga vertam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Exodus 23:28",
      "text": "emittens crabrones prius, qui fugabunt Hevæum, et Chananæum, et Hethæum, antequam introëas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Exodus 23:29",
      "text": "Non ejiciam eos a facie tua anno uno: ne terra in solitudinem redigatur, et crescant contra te bestiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Exodus 23:30",
      "text": "Paulatim expellam eos de conspectu tuo, donec augearis, et possideas terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Exodus 23:31",
      "text": "Ponam autem terminos tuos a mari Rubro usque ad mare Palæstinorum, et a deserto usque ad fluvium: tradam in manibus vestris habitatores terræ, et ejiciam eos de conspectu vestro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Exodus 23:32",
      "text": "Non inibis cum eis fœdus, nec cum diis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.23.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Exodus 23:33",
      "text": "Non habitent in terra tua, ne forte peccare te faciant in me, si servieris diis eorum: quod tibi certe erit in scandalum.",
      "paragraphStart": false
    }
  ]
}
