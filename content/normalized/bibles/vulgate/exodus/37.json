{
  "chapter": {
    "id": "vulgate:exodus.37",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 37,
    "referenceLabel": "Exodus 37",
    "summary": "Source text for Exodus 37 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.37.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Exodus 37:1",
      "text": "Fecit autem Beseleel et arcam de lignis setim, habentem duos semis cubitos in longitudine, et cubitum ac semissem in latitudine, altitudo quoque unius cubiti fuit et dimidii: vestivitque eam auro purissimo intus ac foris.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.37.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Exodus 37:2",
      "text": "Et fecit illi coronam auream per gyrum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Exodus 37:3",
      "text": "conflans quatuor annulos aureos per quatuor angulos ejus: duos annulos in latere uno, et duos in altero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Exodus 37:4",
      "text": "Vectes quoque fecit de lignis setim, quos vestivit auro,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Exodus 37:5",
      "text": "et quos misit in annulos, qui erant in lateribus arcæ ad portandum eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Exodus 37:6",
      "text": "Fecit et propitiatorium, id est, oraculum, de auro mundissimo, duorum cubitorum et dimidii in longitudine, et cubiti ac semis in latitudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Exodus 37:7",
      "text": "Duos etiam cherubim ex auro ductili, quos posuit ex utraque parte propitiatorii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Exodus 37:8",
      "text": "cherub unum in summitate unius partis, et cherub alterum in summitate partis alterius: duos cherubim in singulis summitatibus propitiatorii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Exodus 37:9",
      "text": "extendentes alas, et tegentes propitiatorium, seque mutuo et illud respicientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Exodus 37:10",
      "text": "Fecit et mensam de lignis setim in longitudine duorum cubitorum, et in latitudine unius cubiti, quæ habebat in altitudine cubitum ac semissem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Exodus 37:11",
      "text": "Circumdeditque eam auro mundissimo, et fecit illi labium aureum per gyrum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Exodus 37:12",
      "text": "ipsique labio coronam auream interrasilem quatuor digitorum, et super eamdem, alteram coronam auream.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Exodus 37:13",
      "text": "Fudit et quatuor circulos aureos, quos posuit in quatuor angulis per singulos pedes mensæ",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Exodus 37:14",
      "text": "contra coronam: misitque in eos vectes, ut possit mensa portari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Exodus 37:15",
      "text": "Ipsos quoque vectes fecit de lignis setim, et circumdedit eos auro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Exodus 37:16",
      "text": "Et vasa ad diversos usus mensæ, acetabula, phialas, et cyathos, et thuribula, ex auro puro, in quibus offerenda sunt libamina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Exodus 37:17",
      "text": "Fecit et candelabrum ductile de auro mundissimo, de cujus vecte calami, scyphi, sphærulæque, ac lilia procedebant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Exodus 37:18",
      "text": "sex in utroque latere, tres calami ex parte una, et tres ex altera:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Exodus 37:19",
      "text": "tres scyphi in nucis modum per calamos singulos, sphærulæque simul et lilia: et tres scyphi instar nucis in calamo altero, sphærulæque simul et lilia. Æquum erat opus sex calamorum, qui procedebant de stipite candelabri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Exodus 37:20",
      "text": "In ipso autem vecte erant quatuor scyphi in nucis modum, sphærulæque per singulos simul et lilia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Exodus 37:21",
      "text": "et sphærulæ sub duobus calamis per loca tria, qui simul sex fiunt calami procedentes de vecte uno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Exodus 37:22",
      "text": "Et sphærulæ igitur, et calami ex ipso erant, universa ductilia ex auro purissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Exodus 37:23",
      "text": "Fecit et lucernas septem cum emunctoriis suis, et vasa ubi ea, quæ emuncta sunt, extinguantur, de auro mundissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Exodus 37:24",
      "text": "Talentum auri appendebat candelabrum cum omnibus vasis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 25,
      "referenceLabel": "Exodus 37:25",
      "text": "Fecit et altare thymiamatis de lignis setim, per quadrum singulos habens cubitos, et in altitudine duos: e cujus angulis procedebant cornua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 26,
      "referenceLabel": "Exodus 37:26",
      "text": "Vestivitque illud auro purissimo cum craticula ac parietibus et cornibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 27,
      "referenceLabel": "Exodus 37:27",
      "text": "Fecitque ei coronam aureolam per gyrum, et duos annulos aureos sub corona per singula latera, ut mittantur in eos vectes, et possit altare portari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 28,
      "referenceLabel": "Exodus 37:28",
      "text": "Ipsos autem vectes fecit de lignis setim, et operuit laminis aureis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.37.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 37,
      "verseNumber": 29,
      "referenceLabel": "Exodus 37:29",
      "text": "Composuit et oleum ad sanctificationis unguentum, et thymiama de aromatibus mundissimis opere pigmentarii.",
      "paragraphStart": false
    }
  ]
}
