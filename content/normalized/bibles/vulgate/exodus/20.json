{
  "chapter": {
    "id": "vulgate:exodus.20",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 20,
    "referenceLabel": "Exodus 20",
    "summary": "Source text for Exodus 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.20.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Exodus 20:1",
      "text": "Locutusque est Dominus cunctos sermones hos:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.20.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Exodus 20:2",
      "text": "Ego sum Dominus Deus tuus, qui eduxi te de terra Ægypti, de domo servitutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Exodus 20:3",
      "text": "Non habebis deos alienos coram me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Exodus 20:4",
      "text": "Non facies tibi sculptile, neque omnem similitudinem quæ est in cælo desuper, et quæ in terra deorsum, nec eorum quæ sunt in aquis sub terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Exodus 20:5",
      "text": "Non adorabis ea, neque coles: ego sum Dominus Deus tuus fortis, zelotes, visitans iniquitatem patrum in filios, in tertiam et quartam generationem eorum qui oderunt me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Exodus 20:6",
      "text": "et faciens misericordiam in millia his qui diligunt me, et custodiunt præcepta mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Exodus 20:7",
      "text": "Non assumes nomen Domini Dei tui in vanum: nec enim habebit insontem Dominus eum qui assumpserit nomen Domini Dei sui frustra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Exodus 20:8",
      "text": "Memento ut diem sabbati sanctifices.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Exodus 20:9",
      "text": "Sex diebus operaberis, et facies omnia opera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Exodus 20:10",
      "text": "Septimo autem die sabbatum Domini Dei tui est: non facies omne opus in eo, tu, et filius tuus et filia tua, servus tuus et ancilla tua, jumentum tuum, et advena qui est intra portas tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Exodus 20:11",
      "text": "Sex enim diebus fecit Dominus cælum et terram, et mare, et omnia quæ in eis sunt, et requievit in die septimo: idcirco benedixit Dominus diei sabbati, et sanctificavit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Exodus 20:12",
      "text": "Honora patrem tuum et matrem tuam, ut sis longævus super terram, quam Dominus Deus tuus dabit tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Exodus 20:13",
      "text": "Non occides.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Exodus 20:14",
      "text": "Non mœchaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Exodus 20:15",
      "text": "Non furtum facies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Exodus 20:16",
      "text": "Non loqueris contra proximum tuum falsum testimonium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Exodus 20:17",
      "text": "Non concupisces domum proximi tui, nec desiderabis uxorem ejus, non servum, non ancillam, non bovem, non asinum, nec omnia quæ illius sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Exodus 20:18",
      "text": "Cunctus autem populus videbat voces et lampades, et sonitum buccinæ, montemque fumantem: et perterriti ac pavore concussi, steterunt procul,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Exodus 20:19",
      "text": "dicentes Moysi: Loquere tu nobis, et audiemus: non loquatur nobis Dominus, ne forte moriamur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Exodus 20:20",
      "text": "Et ait Moyses ad populum: Nolite timere: ut enim probaret vos venit Deus, et ut terror illius esset in vobis, et non peccaretis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Exodus 20:21",
      "text": "Stetitque populus de longe. Moyses autem accessit ad caliginem in qua erat Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Exodus 20:22",
      "text": "Dixit præterea Dominus ad Moysen: Hæc dices filiis Israël: Vos vidistis quod de cælo locutus sim vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Exodus 20:23",
      "text": "Non facietis deos argenteos, nec deos aureos facietis vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Exodus 20:24",
      "text": "Altare de terra facietis mihi, et offeretis super eo holocausta et pacifica vestra, oves vestras et boves in omni loco in quo memoria fuerit nominis mei: veniam ad te, et benedicam tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Exodus 20:25",
      "text": "Quod si altare lapideum feceris mihi, non ædificabis illud de sectis lapidibus: si enim levaveris cultrum super eo, polluetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.20.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Exodus 20:26",
      "text": "Non ascendes per gradus ad altare meum, ne reveletur turpitudo tua.",
      "paragraphStart": false
    }
  ]
}
