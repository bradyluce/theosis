{
  "chapter": {
    "id": "vulgate:exodus.35",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 35,
    "referenceLabel": "Exodus 35",
    "summary": "Source text for Exodus 35 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.35.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Exodus 35:1",
      "text": "Igitur congregata omni turba filiorum Israël, dixit ad eos: Hæc sunt quæ jussit Dominus fieri.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.35.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Exodus 35:2",
      "text": "Sex diebus facietis opus: septimus dies erit vobis sanctus, sabbatum, et requies Domini: qui fecerit opus in eo, occidetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Exodus 35:3",
      "text": "Non succendetis ignem in omnibus habitaculis vestris per diem sabbati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Exodus 35:4",
      "text": "Et ait Moyses ad omnem catervam filiorum Israël: Iste est sermo quem præcepit Dominus, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Exodus 35:5",
      "text": "Separate apud vos primitias Domino. Omnis voluntarius et prono animo offerat eas Domino: aurum et argentum, et æs,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Exodus 35:6",
      "text": "hyacinthum et purpuram, coccumque bis tinctum, et byssum, pilos caprarum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Exodus 35:7",
      "text": "pellesque arietum rubricatas, et janthinas, ligna setim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Exodus 35:8",
      "text": "et oleum ad luminaria concinnanda, et ut conficiatur unguentum, et thymiama suavissimum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Exodus 35:9",
      "text": "lapides onychinos, et gemmas ad ornatum superhumeralis et rationalis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Exodus 35:10",
      "text": "Quisque vestrum sapiens est, veniat, et faciat quod Dominus imperavit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Exodus 35:11",
      "text": "tabernaculum scilicet, et tectum ejus, atque operimentum, annulos, et tabulata cum vectibus, paxillos, et bases:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Exodus 35:12",
      "text": "arcam et vectes, propitiatorium, et velum, quod ante illud oppanditur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Exodus 35:13",
      "text": "mensam cum vectibus et vasis, et propositionis panibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Exodus 35:14",
      "text": "candelabrum ad luminaria sustentanda, vasa illius et lucernas, et oleum ad nutrimenta ignium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Exodus 35:15",
      "text": "altare thymiamatis, et vectes, et oleum unctionis et thymiama ex aromatibus: tentorium ad ostium tabernaculi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Exodus 35:16",
      "text": "altare holocausti, et craticulam ejus æneam cum vectibus et vasis suis: labrum et basim ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Exodus 35:17",
      "text": "cortinas atrii cum columnis et basibus, tentorium in foribus vestibuli,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Exodus 35:18",
      "text": "paxillos tabernaculi et atrii cum funiculis suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Exodus 35:19",
      "text": "vestimenta, quorum usus est in ministerio sanctuarii, vestes Aaron pontificis ac filiorum ejus, ut sacerdotio fungantur mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Exodus 35:20",
      "text": "Egressaque omnis multitudo filiorum Israël de conspectu Moysi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Exodus 35:21",
      "text": "obtulerunt mente promptissima atque devota primitias Domino, ad faciendum opus tabernaculi testimonii. Quidquid ad cultum et ad vestes sanctas necessarium erat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Exodus 35:22",
      "text": "viri cum mulieribus præbuerunt, armillas et inaures, annulos et dextralia: omne vas aureum in donaria Domini separatum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Exodus 35:23",
      "text": "Si quis habebat hyacinthum, et purpuram, coccumque bis tinctum, byssum et pilos caprarum, pelles arietum rubricatas, et janthinas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Exodus 35:24",
      "text": "argenti, ærisque metalla, obtulerunt Domino, lignaque setim in varios usus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Exodus 35:25",
      "text": "Sed et mulieres doctæ, quæ neverant, dederunt hyacinthum, purpuram, et vermiculum, ac byssum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Exodus 35:26",
      "text": "et pilos caprarum, sponte propria cuncta tribuentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Exodus 35:27",
      "text": "Principes vero obtulerunt lapides onychinos, et gemmas ad superhumerale et rationale,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Exodus 35:28",
      "text": "aromataque et oleum ad luminaria concinnanda, et ad præparandum unguentum, ac thymiama odoris suavissimi componendum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 29,
      "referenceLabel": "Exodus 35:29",
      "text": "Omnes viri et mulieres mente devota obtulerunt donaria, ut fierent opera, quæ jusserat Dominus per manum Moysi. Cuncti filii Israël voluntaria Domino dedicaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 30,
      "referenceLabel": "Exodus 35:30",
      "text": "Dixitque Moyses ad filios Israël: Ecce, vocavit Dominus ex nomine Beseleel filium Uri, filii Hur de tribu Juda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 31,
      "referenceLabel": "Exodus 35:31",
      "text": "implevitque eum spiritu Dei, sapientia et intelligentia, et scientia et omni doctrina,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 32,
      "referenceLabel": "Exodus 35:32",
      "text": "ad excogitandum, et faciendum opus in auro, et argento, et ære,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 33,
      "referenceLabel": "Exodus 35:33",
      "text": "sculpendisque lapidibus, et opere carpentario, quidquid fabre adinveniri potest,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 34,
      "referenceLabel": "Exodus 35:34",
      "text": "dedit in corde ejus: Ooliab quoque filium Achisamech de tribu Dan:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.35.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 35,
      "verseNumber": 35,
      "referenceLabel": "Exodus 35:35",
      "text": "ambos erudivit sapientia, ut faciant opera abietarii, polymitarii, ac plumarii, de hyacintho ac purpura, coccoque bis tincto, et bysso, et texant omnia, ac nova quæque reperiant.",
      "paragraphStart": false
    }
  ]
}
