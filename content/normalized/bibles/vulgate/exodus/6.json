{
  "chapter": {
    "id": "vulgate:exodus.6",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 6,
    "referenceLabel": "Exodus 6",
    "summary": "Source text for Exodus 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.6.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Exodus 6:1",
      "text": "Dixitque Dominus ad Moysen: Nunc videbis quæ facturus sim Pharaoni: per manum enim fortem dimittet eos, et in manu robusta ejiciet illos de terra sua.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.6.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Exodus 6:2",
      "text": "Locutusque est Dominus ad Moysen dicens: Ego Dominus",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Exodus 6:3",
      "text": "qui apparui Abraham, Isaac et Jacob in Deo omnipotente: et nomen meum Adonai non indicavi eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Exodus 6:4",
      "text": "Pepigique fœdus cum eis, ut darem eis terram Chanaan, terram peregrinationis eorum, in qua fuerunt advenæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Exodus 6:5",
      "text": "Ego audivi gemitum filiorum Israël, quo Ægyptii oppresserunt eos: et recordatus sum pacti mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Exodus 6:6",
      "text": "Ideo dic filiis Israël: Ego Dominus qui educam vos de ergastulo Ægyptiorum, et eruam de servitute, ac redimam in brachio excelso et judiciis magnis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Exodus 6:7",
      "text": "Et assumam vos mihi in populum, et ero vester Deus: et scietis quod ego sum Dominus Deus vester qui eduxerim vos de ergastulo Ægyptiorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Exodus 6:8",
      "text": "et induxerim in terram, super quam levavi manum meam ut darem eam Abraham, Isaac et Jacob: daboque illam vobis possidendam. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Exodus 6:9",
      "text": "Narravit ergo Moyses omnia filiis Israël: qui non acquieverunt ei propter angustiam spiritus, et opus durissimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Exodus 6:10",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Exodus 6:11",
      "text": "Ingredere, et loquere ad Pharaonem regem Ægypti, ut dimittat filios Israël de terra sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Exodus 6:12",
      "text": "Respondit Moyses coram Domino: Ecce filii Israël non audiunt me: et quomodo audiet Pharao, præsertim cum incircumcisus sim labiis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Exodus 6:13",
      "text": "Locutusque est Dominus ad Moysen et Aaron, et dedit mandatum ad filios Israël, et ad Pharaonem regem Ægypti ut educerent filios Israël de terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Exodus 6:14",
      "text": "Isti sunt principes domorum per familias suas. Filii Ruben primogeniti Israëlis: Henoch et Phallu, Hesron et Charmi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Exodus 6:15",
      "text": "hæ cognationes Ruben. Filii Simeon: Jamuel, et Jamin, et Ahod, et Jachin, et Soar, et Saul filius Chananitidis: hæ progenies Simeon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Exodus 6:16",
      "text": "Et hæc nomina filiorum Levi per cognationes suas: Gerson, et Caath, et Merari. Anni autem vitæ Levi fuerunt centum triginta septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Exodus 6:17",
      "text": "Filii Gerson: Lobni et Semei, per cognationes suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Exodus 6:18",
      "text": "Filii Caath: Amram, et Isaar, et Hebron, et Oziel; anni quoque vitæ Caath, centum triginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Exodus 6:19",
      "text": "Filii Merari: Moholi et Musi: hæ cognationes Levi per familias suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Exodus 6:20",
      "text": "Accepit autem Amram uxorem Jochabed patruelem suam: quæ peperit ei Aaron et Moysen. Fueruntque anni vitæ Amram, centum triginta septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Exodus 6:21",
      "text": "Filii quoque Isaar: Core, et Nepheg, et Zechri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Exodus 6:22",
      "text": "Filii quoque Oziel: Misaël, et Elisaphan, et Sethri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Exodus 6:23",
      "text": "Accepit autem Aaron uxorem Elisabeth filiam Aminadab, sororem Nahason, quæ peperit ei Nadab, et Abiu, et Eleazar, et Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Exodus 6:24",
      "text": "Filii quoque Core: Aser, et Elcana, et Abiasaph: hæ sunt cognationes Coritarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Exodus 6:25",
      "text": "At vero Eleazar filius Aaron accepit uxorem de filiabus Phutiel: quæ peperit ei Phinees. Hi sunt principes familiarum Leviticarum per cognationes suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Exodus 6:26",
      "text": "Iste est Aaron et Moyses, quibus præcepit Dominus ut educerent filios Israël de terra Ægypti per turmas suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Exodus 6:27",
      "text": "Hi sunt, qui loquuntur ad Pharaonem regem Ægypti, ut educant filios Israël de Ægypto: iste est Moyses et Aaron,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Exodus 6:28",
      "text": "in die qua locutus est Dominus ad Moysen, in terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Exodus 6:29",
      "text": "Et locutus est Dominus ad Moysen, dicens: Ego Dominus: loquere ad Pharaonem regem Ægypti, omnia quæ ego loquor tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.6.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Exodus 6:30",
      "text": "Et ait Moyses coram Domino: En incircumcisus labiis sum, quomodo audiet me Pharao?",
      "paragraphStart": false
    }
  ]
}
