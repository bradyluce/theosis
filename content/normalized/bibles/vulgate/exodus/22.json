{
  "chapter": {
    "id": "vulgate:exodus.22",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 22,
    "referenceLabel": "Exodus 22",
    "summary": "Source text for Exodus 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.22.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Exodus 22:1",
      "text": "Si quis furatus fuerit bovem aut ovem, et occiderit vel vendiderit: quinque boves pro uno bove restituet, et quatuor oves pro una ove.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.22.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Exodus 22:2",
      "text": "Si effringens fur domum sive suffodiens fuerit inventus, et accepto vulnere mortuus fuerit, percussor non erit reus sanguinis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Exodus 22:3",
      "text": "Quod si orto sole hoc fecerit, homicidium perpetravit, et ipse morietur. Si non habuerit quod pro furto reddat, ipse venundabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Exodus 22:4",
      "text": "Si inventum fuerit apud eum quod furatus est, vivens: sive bos, sive asinus, sive ovis, duplum restituet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Exodus 22:5",
      "text": "Si læserit quispiam agrum vel vineam, et dimiserit jumentum suum ut depascatur aliena: quidquid optimum habuerit in agro suo, vel in vinea, pro damni æstimatione restituet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Exodus 22:6",
      "text": "Si egressus ignis invenerit spinas, et comprehenderit acervos frugum, sive stantes segetes in agris, reddet damnum qui ignem succenderit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Exodus 22:7",
      "text": "Si quis commendaverit amico pecuniam aut vas in custodiam, et ab eo, qui susceperat, furto ablata fuerint: si invenitur fur, duplum reddet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Exodus 22:8",
      "text": "si latet fur, dominus domus applicabitur ad deos, et jurabit quod non extenderit manum in rem proximi sui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Exodus 22:9",
      "text": "ad perpetrandam fraudem, tam in bove quam in asino, et ove ac vestimento, et quidquid damnum inferre potest: ad deos utriusque causa perveniet, et si illi judicaverint, duplum restituet proximo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Exodus 22:10",
      "text": "Si quis commendaverit proximo suo asinum, bovem, ovem, et omne jumentum ad custodiam, et mortuum fuerit, aut debilitatum, vel captum ab hostibus, nullusque hoc viderit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Exodus 22:11",
      "text": "jusjurandum erit in medio, quod non extenderit manum ad rem proximi sui: suscipietque dominus juramentum, et ille reddere non cogetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Exodus 22:12",
      "text": "Quod si furto ablatum fuerit, restituet damnum domino;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Exodus 22:13",
      "text": "si comestum a bestia, deferat ad eum quod occisum est, et non restituet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Exodus 22:14",
      "text": "Qui a proximo suo quidquam horum mutuo postulaverit, et debilitatum aut mortuum fuerit domino non præsente, reddere compelletur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Exodus 22:15",
      "text": "Quod si impræsentiarum dominus fuerit, non restituet, maxime si conductum venerat pro mercede operis sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Exodus 22:16",
      "text": "Si seduxerit quis virginem necdum desponsatam, dormieritque cum ea: dotabit eam, et habebit eam uxorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Exodus 22:17",
      "text": "Si pater virginis dare noluerit, reddet pecuniam juxta modum dotis, quam virgines accipere consueverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Exodus 22:18",
      "text": "Maleficos non patieris vivere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Exodus 22:19",
      "text": "Qui coierit cum jumento, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Exodus 22:20",
      "text": "Qui immolat diis, occidetur, præterquam Domino soli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Exodus 22:21",
      "text": "Advenam non contristabis, neque affliges eum: advenæ enim et ipsi fuistis in terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Exodus 22:22",
      "text": "Viduæ et pupillo non nocebitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Exodus 22:23",
      "text": "Si læseritis eos, vociferabuntur ad me, et ego audiam clamorem eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Exodus 22:24",
      "text": "et indignabitur furor meus, percutiamque vos gladio, et erunt uxores vestræ viduæ, et filii vestri pupilli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Exodus 22:25",
      "text": "Si pecuniam mutuam dederis populo meo pauperi qui habitat tecum, non urgebis eum quasi exactor, nec usuris opprimes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Exodus 22:26",
      "text": "Si pignus a proximo tuo acceperis vestimentum, ante solis occasum reddes ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Exodus 22:27",
      "text": "Ipsum enim est solum, quo operitur, indumentum carnis ejus, nec habet aliud in quo dormiat: si clamaverit ad me, exaudiam eum, quia misericors sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Exodus 22:28",
      "text": "Diis non detrahes, et principi populi tui non maledices.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Exodus 22:29",
      "text": "Decimas tuas et primitias tuas non tardabis reddere: primogenitum filiorum tuorum dabis mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Exodus 22:30",
      "text": "De bobus quoque, et ovibus similiter facies: septem diebus sit cum matre sua, die octava reddes illum mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.22.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Exodus 22:31",
      "text": "Viri sancti eritis mihi: carnem, quæ a bestiis fuerit prægustata, non comedetis, sed projicietis canibus.",
      "paragraphStart": false
    }
  ]
}
