{
  "chapter": {
    "id": "vulgate:exodus.26",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 26,
    "referenceLabel": "Exodus 26",
    "summary": "Source text for Exodus 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.26.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Exodus 26:1",
      "text": "Tabernaculum vero ita facies: decem cortinas de bysso retorta, et hyacintho, ac purpura, coccoque bis tincto, variatas opere plumario facies.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.26.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Exodus 26:2",
      "text": "Longitudo cortinæ unius habebit viginti octo cubitos: latitudo, quatuor cubitorum erit. Unius mensuræ fient universa tentoria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Exodus 26:3",
      "text": "Quinque cortinæ sibi jungentur mutuo, et aliæ quinque nexu simili cohærebunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Exodus 26:4",
      "text": "Ansulas hyacinthinas in lateribus ac summitatibus facies cortinarum, ut possint invicem copulari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Exodus 26:5",
      "text": "Quinquagenas ansulas cortina habebit in utraque parte, ita insertas ut ansa contra ansam veniat, et altera alteri possit aptari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Exodus 26:6",
      "text": "Facies et quinquaginta circulos aureos quibus cortinarum vela jungenda sunt, ut unum tabernaculum fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Exodus 26:7",
      "text": "Facies et saga cilicina undecim, ad operiendum tectum tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Exodus 26:8",
      "text": "Longitudo sagi unius habebit triginta cubitos, et latitudo, quatuor: æqua erit mensura sagorum omnium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Exodus 26:9",
      "text": "E quibus quinque junges seorsum, et sex sibi mutuo copulabis, ita ut sextum sagum in fronte tecti duplices.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Exodus 26:10",
      "text": "Facies et quinquaginta ansas in ora sagi unius, ut conjungi cum altero queat, et quinquaginta ansas in ora sagi alterius, ut cum altero copuletur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Exodus 26:11",
      "text": "Facies et quinquaginta fibulas æneas quibus jungantur ansæ, ut unum ex omnibus operimentum fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Exodus 26:12",
      "text": "Quod autem superfuerit in sagis quæ parantur tecto, id est unum sagum quod amplius est, ex medietate ejus operies posteriora tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Exodus 26:13",
      "text": "Et cubitus ex una parte pendebit, et alter ex altera qui plus est in sagorum longitudine, utrumque latus tabernaculi protegens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Exodus 26:14",
      "text": "Facies et operimentum aliud tecto de pellibus arietum rubricatis: et super hoc rursum aliud operimentum de janthinis pellibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Exodus 26:15",
      "text": "Facies et tabulas stantes tabernaculi de lignis setim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Exodus 26:16",
      "text": "quæ singulæ denos cubitos in longitudine habeant, et in latitudine singulos ac semissem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Exodus 26:17",
      "text": "In lateribus tabulæ, duæ incastraturæ fient, quibus tabula alteri tabulæ connectatur: atque in hunc modum cunctæ tabulæ parabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Exodus 26:18",
      "text": "Quarum viginti erunt in latere meridiano quod vergit ad austrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Exodus 26:19",
      "text": "Quibus quadraginta bases argenteas fundes, ut binæ bases singulis tabulis per duos angulos subjiciantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Exodus 26:20",
      "text": "In latere quoque secundo tabernaculi quod vergit ad aquilonem, viginti tabulæ erunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Exodus 26:21",
      "text": "quadraginta habentes bases argenteas, binæ bases singulis tabulis supponentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Exodus 26:22",
      "text": "Ad occidentalem vero plagam tabernaculi facies sex tabulas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Exodus 26:23",
      "text": "et rursum alias duas quæ in angulis erigantur post tergum tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Exodus 26:24",
      "text": "Eruntque conjunctæ a deorsum usque sursum, et una omnes compago retinebit. Duabus quoque tabulis quæ in angulis ponendæ sunt, similis junctura servabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Exodus 26:25",
      "text": "Et erunt simul tabulæ octo, bases earum argenteæ sedecim, duabus basibus per unam tabulam supputatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Exodus 26:26",
      "text": "Facies et vectes de lignis setim quinque ad continendas tabulas in uno latere tabernaculi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Exodus 26:27",
      "text": "et quinque alios in altero, et ejusdem numeri ad occidentalem plagam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Exodus 26:28",
      "text": "qui mittentur per medias tabulas a summo usque ad summum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 29,
      "referenceLabel": "Exodus 26:29",
      "text": "Ipsas quoque tabulas deaurabis, et fundes in eis annulos aureos per quos vectes tabulata contineant: quos operies laminis aureis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 30,
      "referenceLabel": "Exodus 26:30",
      "text": "Et eriges tabernaculum juxta exemplar quod tibi in monte monstratum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 31,
      "referenceLabel": "Exodus 26:31",
      "text": "Facies et velum de hyacintho, et purpura, coccoque bis tincto, et bysso retorta, opere plumario et pulchra varietate contextum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 32,
      "referenceLabel": "Exodus 26:32",
      "text": "quod appendes ante quatuor columnas de lignis setim, quæ ipsæ quidem deauratæ erunt, et habebunt capita aurea, sed bases argenteas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 33,
      "referenceLabel": "Exodus 26:33",
      "text": "Inseretur autem velum per circulos, intra quod pones arcam testimonii, quo et sanctuarium, et sanctuarii sanctuaria dividentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 34,
      "referenceLabel": "Exodus 26:34",
      "text": "Pones et propitiatorium super arcam testimonii in Sancto sanctorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 35,
      "referenceLabel": "Exodus 26:35",
      "text": "mensamque extra velum, et contra mensam candelabrum in latere tabernaculi meridiano: mensa enim stabit in parte aquilonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 36,
      "referenceLabel": "Exodus 26:36",
      "text": "Facies et tentorium in introitu tabernaculi de hyacintho, et purpura, coccoque bis tincto, et bysso retorta, opere plumarii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.26.37",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 26,
      "verseNumber": 37,
      "referenceLabel": "Exodus 26:37",
      "text": "Et quinque columnas deaurabis lignorum setim, ante quas ducetur tentorium: quarum erunt capita aurea, et bases æneæ.",
      "paragraphStart": false
    }
  ]
}
