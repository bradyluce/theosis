{
  "chapter": {
    "id": "vulgate:exodus.36",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 36,
    "referenceLabel": "Exodus 36",
    "summary": "Source text for Exodus 36 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.36.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Exodus 36:1",
      "text": "Fecit ergo Beseleel, et Ooliab, et omnis vir sapiens, quibus dedit Dominus sapientiam et intellectum, ut scirent fabre operari quæ in usus sanctuarii necessaria sunt, et quæ præcepit Dominus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.36.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Exodus 36:2",
      "text": "Cumque vocasset eos Moyses et omnem eruditum virum, cui dederat Dominus sapientiam, et qui sponte sua obtulerant se ad faciendum opus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Exodus 36:3",
      "text": "tradidit eis universa donaria filiorum Israël. Qui cum instarent operi, quotidie mane vota populus offerebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Exodus 36:4",
      "text": "Unde artifices venire compulsi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Exodus 36:5",
      "text": "dixerunt Moysi: Plus offert populus quam necessarium est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Exodus 36:6",
      "text": "Jussit ergo Moyses præconis voce cantari: Nec vir, nec mulier quidquam offerat ultra in opere sanctuarii. Sicque cessatum est a muneribus offerendis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Exodus 36:7",
      "text": "eo quod oblata sufficerent et superabundarent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Exodus 36:8",
      "text": "Feceruntque omnes corde sapientes ad explendum opus tabernaculi, cortinas decem de bysso retorta, et hyacintho, et purpura, coccoque bis tincto, opere vario, et arte polymita:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Exodus 36:9",
      "text": "quarum una habebat in longitudine viginti octo cubitos, et in latitudine quatuor; una mensura erat omnium cortinarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Exodus 36:10",
      "text": "Conjunxitque cortinas quinque, alteram alteri, et alias quinque sibi invicem copulavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Exodus 36:11",
      "text": "Fecit et ansas hyacinthinas in ora cortinæ unius ex utroque latere, et in ora cortinæ alterius similiter,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Exodus 36:12",
      "text": "ut contra se invicem venirent ansæ, et mutuo jungerentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Exodus 36:13",
      "text": "Unde et quinquaginta fudit circulos aureos, qui morderent cortinarum ansas, et fieret unum tabernaculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Exodus 36:14",
      "text": "Fecit et saga undecim de pilis caprarum ad operiendum tectum tabernaculi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Exodus 36:15",
      "text": "unum sagum in longitudine habebat cubitos triginta, et in latitudine cubitos quatuor: unius mensuræ erant omnia saga:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Exodus 36:16",
      "text": "quorum quinque junxit seorsum, et sex alia separatim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Exodus 36:17",
      "text": "Fecitque ansas quinquaginta in ora sagi unius, et quinquaginta in ora sagi alterius, ut sibi invicem jungerentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Exodus 36:18",
      "text": "Et fibulas æneas quinquaginta, quibus necteretur tectum, ut unum pallium ex omnibus sagis fieret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Exodus 36:19",
      "text": "Fecit et opertorium tabernaculi de pellibus arietum rubricatis: aliudque desuper velamentum de pellibus janthinis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Exodus 36:20",
      "text": "Fecit et tabulas tabernaculi de lignis setim stantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Exodus 36:21",
      "text": "Decem cubitorum erat longitudo tabulæ unius: et unum ac semis cubitum latitudo retinebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Exodus 36:22",
      "text": "Binæ incastraturæ erant per singulas tabulas, ut altera alteri jungeretur. Sic fecit in omnibus tabernaculi tabulis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Exodus 36:23",
      "text": "E quibus viginti ad plagam meridianam erant contra austrum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Exodus 36:24",
      "text": "cum quadraginta basibus argenteis. Duæ bases sub una tabula ponebantur ex utraque parte angulorum, ubi incastraturæ laterum in angulis terminantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Exodus 36:25",
      "text": "Ad plagam quoque tabernaculi, quæ respicit ad aquilonem, fecit viginti tabulas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Exodus 36:26",
      "text": "cum quadraginta basibus argenteis, duas bases per singulas tabulas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Exodus 36:27",
      "text": "Contra occidentem vero, id est, ad eam partem tabernaculi quæ mare respicit, fecit sex tabulas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Exodus 36:28",
      "text": "et duas alias per singulos angulos tabernaculi retro:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Exodus 36:29",
      "text": "quæ junctæ erant a deorsum usque sursum, et in unam compaginem pariter ferebantur. Ita fecit ex utraque parte per angulos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Exodus 36:30",
      "text": "ut octo essent simul tabulæ, et haberent bases argenteas sedecim, binas scilicet bases sub singulis tabulis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Exodus 36:31",
      "text": "Fecit et vectes de lignis setim, quinque ad continendas tabulas unius lateris tabernaculi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Exodus 36:32",
      "text": "et quinque alios ad alterius lateris coaptandas tabulas: et extra hos, quinque alios vectes ad occidentalem plagam tabernaculi contra mare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Exodus 36:33",
      "text": "Fecit quoque vectem alium, qui per medias tabulas ab angulo usque ad angulum perveniret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 34,
      "referenceLabel": "Exodus 36:34",
      "text": "Ipsa autem tabulata deauravit, fusis basibus earum argenteis. Et circulos eorum fecit aureos, per quos vectes induci possent: quos et ipsos laminis aureis operuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 35,
      "referenceLabel": "Exodus 36:35",
      "text": "Fecit et velum de hyacintho, et purpura, vermiculo, ac bysso retorta, opere polymitario, varium atque distinctum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 36,
      "referenceLabel": "Exodus 36:36",
      "text": "et quatuor columnas de lignis setim, quas cum capitibus deauravit, fusis basibus earum argenteis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.37",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 37,
      "referenceLabel": "Exodus 36:37",
      "text": "Fecit et tentorium in introitu tabernaculi ex hyacintho, purpura, vermiculo, byssoque retorta, opere plumarii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.36.38",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 36,
      "verseNumber": 38,
      "referenceLabel": "Exodus 36:38",
      "text": "et columnas quinque cum capitibus suis, quas operuit auro, basesque earum fudit æneas.",
      "paragraphStart": false
    }
  ]
}
