{
  "chapter": {
    "id": "vulgate:exodus.30",
    "translationId": "vulgate",
    "bookSlug": "exodus",
    "chapterNumber": 30,
    "referenceLabel": "Exodus 30",
    "summary": "Source text for Exodus 30 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:exodus.30.1",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Exodus 30:1",
      "text": "Facies quoque altare ad adolendum thymiama, de lignis setim,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:exodus.30.2",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Exodus 30:2",
      "text": "habens cubitum longitudinis, et alterum latitudinis, id est, quadrangulum, et duos cubitos in altitudine. Cornua ex ipso procedent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.3",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Exodus 30:3",
      "text": "Vestiesque illud auro purissimo, tam craticulam ejus, quam parietes per circuitum, et cornua. Faciesque ei coronam aureolam per gyrum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.4",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Exodus 30:4",
      "text": "et duos annulos aureos sub corona per singula latera, ut mittantur in eos vectes, et altare portetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.5",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Exodus 30:5",
      "text": "Ipsos quoque vectes facies de lignis setim, et inaurabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.6",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Exodus 30:6",
      "text": "Ponesque altare contra velum, quod ante arcum pendet testimonii coram propitiatorio quo tegitur testimonium, ubi loquar tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.7",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Exodus 30:7",
      "text": "Et adolebit incensum super eo Aaron, suave fragrans, mane. Quando componet lucernas, incendet illud:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.8",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Exodus 30:8",
      "text": "et quando collocabit eas ad vesperum, uret thymiama sempiternum coram Domino in generationes vestras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.9",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Exodus 30:9",
      "text": "Non offeretis super eo thymiama compositionis alterius, nec oblationem, et victimam, nec libabitis libamina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.10",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Exodus 30:10",
      "text": "Et deprecabitur Aaron super cornua ejus semel per annum, in sanguine quod oblatum est pro peccato, et placabit super eo in generationibus vestris. Sanctum sanctorum erit Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.11",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Exodus 30:11",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.12",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Exodus 30:12",
      "text": "Quando tuleris summam filiorum Israël juxta numerum, dabunt singuli pretium pro animabus suis Domino, et non erit plaga in eis, cum fuerint recensiti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.13",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Exodus 30:13",
      "text": "Hoc autem dabit omnis qui transit ad nomen, dimidium sicli juxta mensuram templi (siclus viginti obolos habet); media pars sicli offeretur Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.14",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Exodus 30:14",
      "text": "Qui habetur in numero, a viginti annis et supra, dabit pretium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.15",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Exodus 30:15",
      "text": "Dives non addet ad medium sicli, et pauper nihil minuet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.16",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Exodus 30:16",
      "text": "Susceptamque pecuniam, quæ collata est a filiis Israël, trades in usus tabernaculi testimonii, ut sit monimentum eorum coram Domino, et propitietur animabus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.17",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Exodus 30:17",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.18",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Exodus 30:18",
      "text": "Facies et labrum æneum cum basi sua ad lavandum: ponesque illud inter tabernaculum testimonii et altare. Et missa aqua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.19",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Exodus 30:19",
      "text": "lavabunt in ea Aaron et filii ejus manus suas ac pedes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.20",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Exodus 30:20",
      "text": "quando ingressuri sunt tabernaculum testimonii, et quando accessuri sunt ad altare, ut offerant in eo thymiama Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.21",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Exodus 30:21",
      "text": "ne forte moriantur; legitimum sempiternum erit ipsi, et semini ejus per successiones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.22",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Exodus 30:22",
      "text": "Locutusque est Dominus ad Moysen,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.23",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Exodus 30:23",
      "text": "dicens: Sume tibi aromata, primæ myrrhæ et electæ quingentos siclos, et cinnamomi medium, id est, ducentos quinquaginta siclos, calami similiter ducentos quinquaginta,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.24",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Exodus 30:24",
      "text": "casiæ autem quingentos siclos, in pondere sanctuarii, olei de olivetis mensuram hin:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.25",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Exodus 30:25",
      "text": "faciesque unctionis oleum sanctum, unguentum compositum opere unguentarii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.26",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Exodus 30:26",
      "text": "et unges ex eo tabernaculum testimonii, et arcam testamenti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.27",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Exodus 30:27",
      "text": "mensamque cum vasis suis, et candelabrum, et utensilia ejus, altaria thymiamatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.28",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Exodus 30:28",
      "text": "et holocausti, et universam supellectilem quæ ad cultum eorum pertinet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.29",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Exodus 30:29",
      "text": "Sanctificabisque omnia, et erunt Sancta sanctorum; qui tetigerit ea, sanctificabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.30",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Exodus 30:30",
      "text": "Aaron et filios ejus unges, sanctificabisque eos, ut sacerdotio fungantur mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.31",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Exodus 30:31",
      "text": "Filiis quoque Israël dices: Hoc oleum unctionis sanctum erit mihi in generationes vestras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.32",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 32,
      "referenceLabel": "Exodus 30:32",
      "text": "Caro hominis non ungetur ex eo, et juxta compositionem ejus non facietis aliud, quia sanctificatum est, et sanctum erit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.33",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 33,
      "referenceLabel": "Exodus 30:33",
      "text": "Homo quicumque tale composuerit, et dederit ex eo alieno, exterminabitur de populo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.34",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 34,
      "referenceLabel": "Exodus 30:34",
      "text": "Dixitque Dominus ad Moysen: Sume tibi aromata, stacten et onycha, galbanum boni odoris, et thus lucidissimum; æqualis ponderis erunt omnia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.35",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 35,
      "referenceLabel": "Exodus 30:35",
      "text": "faciesque thymiama compositum opere unguentarii, mistum diligenter, et purum, et sanctificatione dignissimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.36",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 36,
      "referenceLabel": "Exodus 30:36",
      "text": "Cumque in tenuissimum pulverem universa contuderis, pones ex eo coram tabernaculo testimonii, in quo loco apparebo tibi. Sanctum sanctorum erit vobis thymiama.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.37",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 37,
      "referenceLabel": "Exodus 30:37",
      "text": "Talem compositionem non facietis in usus vestros, quia sanctum est Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:exodus.30.38",
      "translationId": "vulgate",
      "bookSlug": "exodus",
      "chapterNumber": 30,
      "verseNumber": 38,
      "referenceLabel": "Exodus 30:38",
      "text": "Homo quicumque fecerit simile, ut odore illius perfruatur, peribit de populis suis.",
      "paragraphStart": false
    }
  ]
}
