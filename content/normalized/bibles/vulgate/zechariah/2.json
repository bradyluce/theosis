{
  "chapter": {
    "id": "vulgate:zechariah.2",
    "translationId": "vulgate",
    "bookSlug": "zechariah",
    "chapterNumber": 2,
    "referenceLabel": "Zechariah 2",
    "summary": "Source text for Zechariah 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:zechariah.2.1",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Zechariah 2:1",
      "text": "Et levavi oculos meos, et vidi, et ecce vir, et in manu ejus funiculus mensorum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:zechariah.2.2",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Zechariah 2:2",
      "text": "Et dixi: Quo tu vadis? Et dixit ad me: Ut metiar Jerusalem, et videam quanta sit latitudo ejus, et quanta longitudo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.3",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Zechariah 2:3",
      "text": "Et ecce angelus qui loquebatur in me egrediebatur, et angelus alius egrediebatur in occursum ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.4",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Zechariah 2:4",
      "text": "et dixit ad eum: Curre, loquere ad puerum istum, dicens: Absque muro habitabitur Jerusalem, præ multitudine hominum et jumentorum in medio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.5",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Zechariah 2:5",
      "text": "Et ego ero ei, ait Dominus, murus ignis in circuitu, et in gloria ero in medio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.6",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Zechariah 2:6",
      "text": "O, o, fugite de terra aquilonis, dicit Dominus, quoniam in quatuor ventos cæli dispersi vos, dicit Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.7",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Zechariah 2:7",
      "text": "O Sion! fuge, quæ habitas apud filiam Babylonis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.8",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Zechariah 2:8",
      "text": "quia hæc dicit Dominus exercituum: Post gloriam misit me ad gentes quæ spoliaverunt vos: qui enim tetigerit vos, tangit pupillam oculi mei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.9",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Zechariah 2:9",
      "text": "quia ecce ego levo manum meam super eos, et erunt prædæ his qui serviebant sibi: et cognoscetis quia Dominus exercituum misit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.10",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Zechariah 2:10",
      "text": "Lauda et lætare, filia Sion, quia ecce ego venio, et habitabo in medio tui, ait Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.11",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Zechariah 2:11",
      "text": "Et applicabuntur gentes multæ ad Dominum in die illa, et erunt mihi in populum, et habitabo in medio tui: et scies quia Dominus exercituum misit me ad te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.12",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Zechariah 2:12",
      "text": "Et possidebit Dominus Judam partem suam in terra sanctificata, et eliget adhuc Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:zechariah.2.13",
      "translationId": "vulgate",
      "bookSlug": "zechariah",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Zechariah 2:13",
      "text": "Sileat omnis caro a facie Domini, quia consurrexit de habitaculo sancto suo.",
      "paragraphStart": false
    }
  ]
}
