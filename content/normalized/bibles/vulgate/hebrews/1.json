{
  "chapter": {
    "id": "vulgate:hebrews.1",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 1,
    "referenceLabel": "Hebrews 1",
    "summary": "Source text for Hebrews 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.1.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 1:1",
      "text": "Multifariam, multisque modis olim Deus loquens patribus in prophetis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.1.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 1:2",
      "text": "novissime, diebus istis locutus est nobis in Filio, quem constituit hæredem universorum, per quem fecit et sæcula:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 1:3",
      "text": "qui cum sit splendor gloriæ, et figura substantiæ ejus, portansque omnia verbo virtutis suæ, purgationem peccatorum faciens, sedet ad dexteram majestatis in excelsis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 1:4",
      "text": "tanto melior angelis effectus, quanto differentius præ illis nomen hæreditavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 1:5",
      "text": "Cui enim dixit aliquando angelorum: Filius meus es tu, ego hodie genui te? Et rursum: Ego ero illi in patrem, et ipse erit mihi in filium?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 1:6",
      "text": "Et cum iterum introducit primogenitum in orbem terræ, dicit: Et adorent eum omnes angeli Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 1:7",
      "text": "Et ad angelos quidem dicit: Qui facit angelos suos spiritus, et ministros suos flammam ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 1:8",
      "text": "Ad Filium autem: Thronus tuus Deus in sæculum sæculi: virga æquitatis, virga regni tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 1:9",
      "text": "Dilexisti justitiam, et odisti iniquitatem: propterea unxit te Deus, Deus tuus, oleo exultationis præ participibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 1:10",
      "text": "Et: Tu in principio, Domine, terram fundasti: et opera manuum tuarum sunt cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 1:11",
      "text": "Ipsi peribunt, tu autem permanebis, et omnes ut vestimentum veterascent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 1:12",
      "text": "et velut amictum mutabis eos, et mutabuntur: tu autem idem ipse es, et anni tui non deficient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 1:13",
      "text": "Ad quem autem angelorum dixit aliquando: Sede a dextris meis, quoadusque ponam inimicos tuos scabellum pedum tuorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.1.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 1:14",
      "text": "Nonne omnes sunt administratorii spiritus, in ministerium missi propter eos, qui hæreditatem capient salutis?",
      "paragraphStart": false
    }
  ]
}
