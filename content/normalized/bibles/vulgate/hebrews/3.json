{
  "chapter": {
    "id": "vulgate:hebrews.3",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 3,
    "referenceLabel": "Hebrews 3",
    "summary": "Source text for Hebrews 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.3.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 3:1",
      "text": "Unde, fratres sancti, vocationis cælestis participes, considerate Apostolum, et pontificem confessionis nostræ Jesum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.3.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 3:2",
      "text": "qui fidelis est ei, qui fecit illum, sicut et Moyses in omni domo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 3:3",
      "text": "Amplioris enim gloriæ iste præ Moyse dignus est habitus, quanto ampliorem honorem habet domus, qui fabricavit illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 3:4",
      "text": "Omnis namque domus fabricatur ab aliquo: qui autem omnia creavit, Deus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 3:5",
      "text": "Et Moyses quidem fidelis erat in tota domo ejus tamquam famulus, in testimonium eorum, quæ dicenda erant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 3:6",
      "text": "Christus vero tamquam filius in domo sua: quæ domus sumus nos, si fiduciam, et gloriam spei usque ad finem, firmam retineamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 3:7",
      "text": "Quapropter sicut dicit Spiritus Sanctus: Hodie si vocem ejus audieritis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 3:8",
      "text": "nolite obdurare corda vestra, sicut in exacerbatione secundum diem tentationis in deserto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 3:9",
      "text": "ubi tentaverunt me patres vestri: probaverunt, et viderunt opera mea",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 3:10",
      "text": "quadraginta annis: propter quod infensus fui generationi huic, et dixi: Semper errant corde. Ipsi autem non cognoverunt vias meas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 3:11",
      "text": "sicut juravi in ira mea: Si introibunt in requiem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 3:12",
      "text": "Videte fratres, ne forte sit in aliquo vestrum cor malum incredulitatis, discedendi a Deo vivo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 3:13",
      "text": "sed adhortamini vosmetipsos per singulos dies, donec hodie cognominatur, ut non obduretur quis ex vobis fallacia peccati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 3:14",
      "text": "Participes enim Christi effecti sumus, si tamen initium substantiæ ejus usque ad finem firmum retineamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.15",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 3:15",
      "text": "Dum dicitur: Hodie si vocem ejus audieritis, nolite obdurare corda vestra, quemadmodum in illa exacerbatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.16",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 3:16",
      "text": "Quidam enim audientes exacerbaverunt: sed non universi qui profecti sunt ex Ægypto per Moysen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.17",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 3:17",
      "text": "Quibus autem infensus est quadraginta annis? nonne illis qui peccaverunt, quorum cadavera prostrata sunt in deserto?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.18",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 3:18",
      "text": "Quibus autem juravit non introire in requiem ipsius, nisi illis qui increduli fuerunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.3.19",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 3:19",
      "text": "Et videmus, quia non potuerunt introire propter incredulitatem.",
      "paragraphStart": false
    }
  ]
}
