{
  "chapter": {
    "id": "vulgate:hebrews.7",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 7,
    "referenceLabel": "Hebrews 7",
    "summary": "Source text for Hebrews 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.7.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 7:1",
      "text": "Hic enim Melchisedech, rex Salem, sacerdos Dei summi, qui obviavit Abrahæ regresso a cæde regum, et benedixit ei:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.7.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 7:2",
      "text": "cui et decimas omnium divisit Abraham: primum quidem qui interpretatur rex justitiæ: deinde autem et rex Salem, quod est, rex pacis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 7:3",
      "text": "sine patre, sine matre, sine genealogia, neque initium dierum, neque finem vitæ habens, assimilatus autem Filio Dei, manet sacerdos in perpetuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 7:4",
      "text": "Intuemini autem quantus sit hic, cui et decimas dedit de præcipuis Abraham patriarcha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 7:5",
      "text": "Et quidem de filiis Levi sacerdotium accipientes, mandatum habent decimas sumere a populo secundum legem, id est, a fratribus suis: quamquam et ipsi exierint de lumbis Abrahæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 7:6",
      "text": "Cujus autem generatio non annumeratur in eis, decimas sumpsit ab Abraham, et hunc, qui habebat repromissiones, benedixit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 7:7",
      "text": "Sine ulla autem contradictione, quod minus est, a meliore benedicitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 7:8",
      "text": "Et hic quidem, decimas morientes homines accipiunt: ibi autem contestatur, quia vivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 7:9",
      "text": "Et (ut ita dictum sit) per Abraham, et Levi, qui decimas accepit, decimatus est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 7:10",
      "text": "adhuc enim in lumbis patris erat, quando obviavit ei Melchisedech.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 7:11",
      "text": "Si ergo consummatio per sacerdotium Leviticum erat (populus enim sub ipso legem accepit) quid adhuc necessarium fuit secundum ordinem Melchisedech, alium surgere sacerdotem, et non secundum ordinem Aaron dici?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 7:12",
      "text": "Translato enim sacerdotio, necesse est ut et legis translatio fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 7:13",
      "text": "In quo enim hæc dicuntur, de alia tribu est, de qua nullus altari præsto fuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 7:14",
      "text": "Manifestum est enim quod ex Juda ortus sit Dominus noster: in qua tribu nihil de sacerdotibus Moyses locutus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.15",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 7:15",
      "text": "Et amplius adhuc manifestum est: si secundum similitudinem Melchisedech exsurgat alius sacerdos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.16",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 7:16",
      "text": "qui non secundum legem mandati carnalis factus est, sed secundum virtutem vitæ insolubilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.17",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 7:17",
      "text": "Contestatur enim: Quoniam tu es sacerdos in æternum, secundum ordinem Melchisedech.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.18",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 7:18",
      "text": "Reprobatio quidem fit præcedentis mandati, propter infirmitatem ejus, et inutilitatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.19",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 7:19",
      "text": "nihil enim ad perfectum adduxit lex: introductio vero melioris spei, per quam proximamus ad Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.20",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 7:20",
      "text": "Et quantum est non sine jurejurando (alii quidem sine jurejurando sacerdotes facti sunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.21",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 7:21",
      "text": "hic autem cum jurejurando per eum, qui dixit ad illum: Juravit Dominus, et non pœnitebit eum: tu es sacerdos in æternum):",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.22",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 7:22",
      "text": "in tantum melioris testamenti sponsor factus est Jesus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.23",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 7:23",
      "text": "Et alii quidem plures facti sunt sacerdotes, idcirco quod morte prohiberentur permanere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.24",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 7:24",
      "text": "hic autem eo quod maneat in æternum, sempiternum habet sacerdotium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.25",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 7:25",
      "text": "Unde et salvare in perpetuum potest accedentes per semetipsum ad Deum: semper vivens ad interpellandum pro nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.26",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 7:26",
      "text": "Talis enim decebat ut nobis esset pontifex, sanctus, innocens, impollutus, segregatus a peccatoribus, et excelsior cælis factus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.27",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 7:27",
      "text": "qui non habet necessitatem quotidie, quemadmodum sacerdotes, prius pro suis delictis hostias offerre, deinde pro populi: hoc enim fecit semel, seipsum offerendo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.7.28",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 7:28",
      "text": "Lex enim homines constituit sacerdotes infirmitatem habentes: sermo autem jurisjurandi, qui post legem est, Filium in æternum perfectum.",
      "paragraphStart": false
    }
  ]
}
