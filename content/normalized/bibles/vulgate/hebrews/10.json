{
  "chapter": {
    "id": "vulgate:hebrews.10",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 10,
    "referenceLabel": "Hebrews 10",
    "summary": "Source text for Hebrews 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.10.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 10:1",
      "text": "Umbram enim habens lex futurorum bonorum, non ipsam imaginem rerum: per singulos annos, eisdem ipsis hostiis quas offerunt indesinenter, numquam potest accedentes perfectos facere:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.10.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 10:2",
      "text": "alioquin cessassent offerri: ideo quod nullam haberent ultra conscientiam peccati, cultores semel mundati:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 10:3",
      "text": "sed in ipsis commemoratio peccatorum per singulos annos fit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 10:4",
      "text": "Impossibile enim est sanguine taurorum et hircorum auferri peccata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 10:5",
      "text": "Ideo ingrediens mundum dicit: Hostiam et oblationem noluisti: corpus autem aptasti mihi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 10:6",
      "text": "holocautomata pro peccato non tibi placuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 10:7",
      "text": "Tunc dixi: Ecce venio: in capite libri scriptum est de me: Ut faciam, Deus, voluntatem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 10:8",
      "text": "Superius dicens: Quia hostias, et oblationes, et holocautomata pro peccato noluisti, nec placita sunt tibi, quæ secundum legem offeruntur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 10:9",
      "text": "tunc dixi: Ecce venio, ut faciam, Deus, voluntatem tuam: aufert primum, ut sequens statuat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 10:10",
      "text": "In qua voluntate sanctificati sumus per oblationem corporis Jesu Christi semel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 10:11",
      "text": "Et omnis quidem sacerdos præsto est quotidie ministrans, et easdem sæpe offerens hostias, quæ numquam possunt auferre peccata:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 10:12",
      "text": "hic autem unam pro peccatis offerens hostiam, in sempiternum sedet in dextera Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 10:13",
      "text": "de cetero exspectans donec ponantur inimici ejus scabellum pedum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 10:14",
      "text": "Una enim oblatione, consummavit in sempiternum sanctificatos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.15",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 10:15",
      "text": "Contestatur autem nos et Spiritus Sanctus. Postquam enim dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.16",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 10:16",
      "text": "Hoc autem testamentum, quod testabor ad illos post dies illos, dicit Dominus, dando leges meas in cordibus eorum, et in mentibus eorum superscribam eas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.17",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 10:17",
      "text": "et peccatorum, et iniquitatum eorum jam non recordabor amplius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.18",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 10:18",
      "text": "Ubi autem horum remissio: jam non est oblatio pro peccato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.19",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 10:19",
      "text": "Habentes itaque, fratres, fiduciam in introitu sanctorum in sanguine Christi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.20",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 10:20",
      "text": "quam initiavit nobis viam novam, et viventem per velamen, id est, carnem suam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.21",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 10:21",
      "text": "et sacerdotem magnum super domum Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.22",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 10:22",
      "text": "accedamus cum vero corde in plenitudine fidei, aspersi corda a conscientia mala, et abluti corpus aqua munda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.23",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 10:23",
      "text": "teneamus spei nostræ confessionem indeclinabilem (fidelis enim est qui repromisit),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.24",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 10:24",
      "text": "et consideremus invicem in provocationem caritatis, et bonorum operum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.25",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 10:25",
      "text": "non deserentes collectionem nostram, sicut consuetudinis est quibusdam, sed consolantes, et tanto magis quanto videritis appropinquantem diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.26",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 10:26",
      "text": "Voluntarie enim peccantibus nobis post acceptam notitiam veritatis, jam non relinquitur pro peccatis hostia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.27",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 10:27",
      "text": "terribilis autem quædam exspectatio judicii, et ignis æmulatio, quæ consumptura est adversarios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.28",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 10:28",
      "text": "Irritam quis faciens legem Moysi, sine ulla miseratione duobus vel tribus testibus moritur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.29",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 10:29",
      "text": "quanto magis putatis deteriora mereri supplicia qui Filium Dei conculcaverit, et sanguinem testamenti pollutum duxerit, in quo sanctificatus est, et spiritui gratiæ contumeliam fecerit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.30",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Hebrews 10:30",
      "text": "Scimus enim qui dixit: Mihi vindicta, et ego retribuam. Et iterum: Quia judicabit Dominus populum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.31",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Hebrews 10:31",
      "text": "Horrendum est incidere in manus Dei viventis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.32",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Hebrews 10:32",
      "text": "Rememoramini autem pristinos dies, in quibus illuminati, magnum certamen sustinuistis passionum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.33",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Hebrews 10:33",
      "text": "et in altero quidem opprobriis et tribulationibus spectaculum facti: in altero autem socii taliter conversantium effecti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.34",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Hebrews 10:34",
      "text": "Nam et vinctis compassi estis, et rapinam bonorum vestrorum cum gaudio suscepistis, cognoscentes vos habere meliorem et manentem substantiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.35",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Hebrews 10:35",
      "text": "Nolite itaque amittere confidentiam vestram, quæ magnam habet remunerationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.36",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Hebrews 10:36",
      "text": "Patientia enim vobis necessaria est: ut voluntatem Dei facientes, reportetis promissionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.37",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Hebrews 10:37",
      "text": "Adhuc enim modicum aliquantulum, qui venturus est, veniet, et non tardabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.38",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Hebrews 10:38",
      "text": "Justus autem meus ex fide vivit: quod si subtraxerit se, non placebit animæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.10.39",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Hebrews 10:39",
      "text": "Nos autem non sumus subtractionis filii in perditionem, sed fidei in acquisitionem animæ.",
      "paragraphStart": false
    }
  ]
}
