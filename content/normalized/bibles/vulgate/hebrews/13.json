{
  "chapter": {
    "id": "vulgate:hebrews.13",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 13,
    "referenceLabel": "Hebrews 13",
    "summary": "Source text for Hebrews 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.13.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 13:1",
      "text": "Caritas fraternitatis maneat in vobis,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.13.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 13:2",
      "text": "et hospitalitatem nolite oblivisci: per hanc enim latuerunt quidam, angelis hospitio receptis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 13:3",
      "text": "Mementote vinctorum, tamquam simul vincti: et laborantium, tamquam et ipsi in corpore morantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 13:4",
      "text": "Honorabile connubium in omnibus, et thorus immaculatus. Fornicatores enim, et adulteros judicabit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 13:5",
      "text": "Sint mores sine avaritia, contenti præsentibus: ipse enim dixit: Non te deseram, neque derelinquam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 13:6",
      "text": "ita ut confidenter dicamus: Dominus mihi adjutor: non timebo quid faciat mihi homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 13:7",
      "text": "Mementote præpositorum vestrorum, qui vobis locuti sunt verbum Dei: quorum intuentes exitum conversationis, imitamini fidem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 13:8",
      "text": "Jesus Christus heri, et hodie: ipse et in sæcula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 13:9",
      "text": "Doctrinis variis et peregrinis nolite abduci. Optimum est enim gratia stabilire cor, non escis: quæ non profuerunt ambulantibus in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 13:10",
      "text": "Habemus altare, de quo edere non habent potestatem, qui tabernaculo deserviunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 13:11",
      "text": "Quorum enim animalium infertur sanguis pro peccato in Sancta per pontificem, horum corpora cremantur extra castra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 13:12",
      "text": "Propter quod et Jesus, ut sanctificaret per suum sanguinem populum, extra portam passus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 13:13",
      "text": "Exeamus igitur ad eum extra castra, improperium ejus portantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 13:14",
      "text": "Non enim habemus hic manentem civitatem, sed futuram inquirimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.15",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 13:15",
      "text": "Per ipsum ergo offeramus hostiam laudis semper Deo, id est, fructum labiorum confitentium nomini ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.16",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 13:16",
      "text": "Beneficentiæ autem et communionis nolite oblivisci: talibus enim hostiis promeretur Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.17",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 13:17",
      "text": "Obedite præpositis vestris, et subjacete eis. Ipsi enim pervigilant quasi rationem pro animabus vestris reddituri, ut cum gaudio hoc faciant, et non gementes: hoc enim non expedit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.18",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 13:18",
      "text": "Orate pro nobis: confidimus enim quia bonam conscientiam habemus in omnibus bene volentes conversari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.19",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 13:19",
      "text": "Amplius autem deprecor vos hoc facere, quo celerius restituar vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.20",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 13:20",
      "text": "Deus autem pacis, qui eduxit de mortuis pastorem magnum ovium, in sanguine testamenti æterni, Dominum nostrum Jesum Christum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.21",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 13:21",
      "text": "aptet vos in omni bono, ut faciatis ejus voluntatem: faciens in vobis quod placeat coram se per Jesum Christum: cui est gloria in sæcula sæculorum. Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.22",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 13:22",
      "text": "Rogo autem vos fratres, ut sufferatis verbum solatii. Etenim perpaucis scripsi vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.23",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 13:23",
      "text": "Cognoscite fratrem nostrum Timotheum dimissum: cum quo (si celerius venerit) videbo vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.24",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 13:24",
      "text": "Salutate omnes præpositos vestros, et omnes sanctos. Salutant vos de Italia fratres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.13.25",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 13:25",
      "text": "Gratia cum omnibus vobis. Amen.",
      "paragraphStart": false
    }
  ]
}
