{
  "chapter": {
    "id": "vulgate:hebrews.11",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 11,
    "referenceLabel": "Hebrews 11",
    "summary": "Source text for Hebrews 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.11.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 11:1",
      "text": "Est autem fides sperandarum substantia rerum, argumentum non apparentium.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.11.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 11:2",
      "text": "In hac enim testimonium consecuti sunt senes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 11:3",
      "text": "Fide intelligimus aptata esse sæcula verbo Dei: ut ex invisibilibus visibilia fierent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 11:4",
      "text": "Fide plurimam hostiam Abel, quam Cain, obtulit Deo, per quam testimonium consecutus est esse justus, testimonium perhibente muneribus ejus Deo, et per illam defunctus adhuc loquitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 11:5",
      "text": "Fide Henoch translatus est ne videret mortem, et non inveniebatur, quia transtulit illum Deus: ante translationem enim testimonium habuit placuisse Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 11:6",
      "text": "Sine fide autem impossibile est placere Deo. Credere enim oportet accedentem ad Deum quia est, et inquirentibus se remunerator sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 11:7",
      "text": "Fide Noë responso accepto de iis quæ adhuc non videbantur, metuens aptavit arcam in salutem domus suæ, per quam damnavit mundum: et justitiæ, quæ per fidem est, hæres est institutus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 11:8",
      "text": "Fide qui vocatur Abraham obedivit in locum exire, quem accepturus erat in hæreditatem: et exiit, nesciens quo iret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 11:9",
      "text": "Fide demoratus est in terra repromissionis, tamquam in aliena, in casulis habitando cum Isaac et Jacob cohæredibus repromissionis ejusdem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 11:10",
      "text": "Exspectabat enim fundamenta habentem civitatem: cujus artifex et conditor Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 11:11",
      "text": "Fide et ipsa Sara sterilis virtutem in conceptionem seminis accepit, etiam præter tempus ætatis: quoniam fidelem credidit esse eum qui repromiserat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 11:12",
      "text": "Propter quod et ab uno orti sunt (et hoc emortuo) tamquam sidera cæli in multitudinem, et sicut arena, quæ est ad oram maris, innumerabilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 11:13",
      "text": "Juxta fidem defuncti sunt omnes isti, non acceptis repromissionibus, sed a longe eas aspicientes, et salutantes, et confitentes quia peregrini et hospites sunt super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 11:14",
      "text": "Qui enim hæc dicunt, significant se patriam inquirere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.15",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 11:15",
      "text": "Et si quidem ipsius meminissent de qua exierunt, habebant utique tempus revertendi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.16",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 11:16",
      "text": "nunc autem meliorem appetunt, id est, cælestem. Ideo non confunditur Deus vocari Deus eorum: paravit enim illis civitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.17",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 11:17",
      "text": "Fide obtulit Abraham Isaac, cum tentaretur, et unigenitum offerebat, qui susceperat repromissiones:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.18",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 11:18",
      "text": "ad quem dictum est: Quia in Isaac vocabitur tibi semen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.19",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 11:19",
      "text": "arbitrans quia et a mortuis suscitare potens est Deus: unde eum et in parabolam accepit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.20",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 11:20",
      "text": "Fide et de futuris benedixit Isaac Jacob et Esau.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.21",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 11:21",
      "text": "Fide Jacob, moriens, singulos filiorum Joseph benedixit: et adoravit fastigium virgæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.22",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 11:22",
      "text": "Fide Joseph, moriens, de profectione filiorum Israël memoratus est, et de ossibus suis mandavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.23",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 11:23",
      "text": "Fide Moyses, natus, occultatus est mensibus tribus a parentibus suis, eo quod vidissent elegantem infantem, et non timuerunt regis edictum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.24",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 11:24",
      "text": "Fide Moyses grandis factus negavit se esse filium filiæ Pharaonis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.25",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 11:25",
      "text": "magis eligens affligi cum populo Dei, quam temporalis peccati habere jucunditatem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.26",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 11:26",
      "text": "majores divitias æstimans thesauro Ægyptiorum, improperium Christi: aspiciebat enim in remunerationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.27",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 11:27",
      "text": "Fide reliquit Ægyptum, non veritus animositatem regis: invisibilem enim tamquam videns sustinuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.28",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 11:28",
      "text": "Fide celebravit Pascha, et sanguinis effusionem: ne qui vastabat primitiva, tangeret eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.29",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 11:29",
      "text": "Fide transierunt mare Rubrum tamquam per aridam terram: quod experti Ægyptii, devorati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.30",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Hebrews 11:30",
      "text": "Fide muri Jericho corruerunt, circuitu dierum septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.31",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Hebrews 11:31",
      "text": "Fide Rahab meretrix non periit cum incredulis, excipiens exploratores cum pace.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.32",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Hebrews 11:32",
      "text": "Et quid adhuc dicam? deficiet enim me tempus enarrantem de Gedeon, Barac, Samson, Jephte, David, Samuel, et prophetis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.33",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Hebrews 11:33",
      "text": "qui per fidem vicerunt regna, operati sunt justitiam, adepti sunt repromissiones, obturaverunt ora leonum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.34",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Hebrews 11:34",
      "text": "extinxerunt impetum ignis, effugerunt aciem gladii, convaluerunt de infirmitate, fortes facti sunt in bello, castra verterunt exterorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.35",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Hebrews 11:35",
      "text": "acceperunt mulieres de resurrectione mortuos suos: alii autem distenti sunt non suscipientes redemptionem ut meliorem invenirent resurrectionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.36",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Hebrews 11:36",
      "text": "Alii vero ludibria, et verbera experti, insuper et vincula, et carceres:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.37",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 37,
      "referenceLabel": "Hebrews 11:37",
      "text": "lapidati sunt, secti sunt, tentati sunt, in occisione gladii mortui sunt, circuierunt in melotis, in pellibus caprinis, egentes, angustiati, afflicti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.38",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 38,
      "referenceLabel": "Hebrews 11:38",
      "text": "quibus dignus non erat mundus: in solitudinibus errantes, in montibus, in speluncis, et in cavernis terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.39",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 39,
      "referenceLabel": "Hebrews 11:39",
      "text": "Et hi omnes testimonio fidei probati, non acceperunt repromissionem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.11.40",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 11,
      "verseNumber": 40,
      "referenceLabel": "Hebrews 11:40",
      "text": "Deo pro nobis melius aliquid providente, ut non sine nobis consummarentur.",
      "paragraphStart": false
    }
  ]
}
