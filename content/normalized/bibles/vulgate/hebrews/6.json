{
  "chapter": {
    "id": "vulgate:hebrews.6",
    "translationId": "vulgate",
    "bookSlug": "hebrews",
    "chapterNumber": 6,
    "referenceLabel": "Hebrews 6",
    "summary": "Source text for Hebrews 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hebrews.6.1",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 6:1",
      "text": "Quapropter intermittentes inchoationis Christi sermonem, ad perfectiora feramur, non rursum jacientes fundamentum pœnitentiæ ab operibus mortuis, et fidei ad Deum,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hebrews.6.2",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 6:2",
      "text": "baptismatum doctrinæ, impositionis quoque manuum, ac resurrectionis mortuorum, et judicii æterni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.3",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 6:3",
      "text": "Et hoc faciemus, si quidem permiserit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.4",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 6:4",
      "text": "Impossibile est enim eos qui semel sunt illuminati, gustaverunt etiam donum cæleste, et participes facti sunt Spiritus Sancti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.5",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 6:5",
      "text": "gustaverunt nihilominus bonum Dei verbum, virtutesque sæculi venturi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.6",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 6:6",
      "text": "et prolapsi sunt; rursus renovari ad pœnitentiam, rursum crucifigentes sibimetipsis Filium Dei, et ostentui habentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.7",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 6:7",
      "text": "Terra enim sæpe venientem super se bibens imbrem, et generans herbam opportunam illis, a quibus colitur, accipit benedictionem a Deo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.8",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 6:8",
      "text": "proferens autem spinas ac tribulos, reproba est, et maledicto proxima: cujus consummatio in combustionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.9",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 6:9",
      "text": "Confidimus autem de vobis dilectissimi meliora, et viciniora saluti: tametsi ita loquimur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.10",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 6:10",
      "text": "Non enim injustus Deus, ut obliviscatur operis vestri, et dilectionis, quam ostendistis in nomine ipsius, qui ministrastis sanctis, et ministratis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.11",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 6:11",
      "text": "Cupimus autem unumquemque vestrum eamdem ostentare sollicitudinem ad expletionem spei usque in finem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.12",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 6:12",
      "text": "ut non segnes efficiamini, verum imitatores eorum, qui fide, et patientia hæreditabunt promissiones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.13",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 6:13",
      "text": "Abrahæ namque promittens Deus, quoniam neminem habuit, per quem juraret, majorem, juravit per semetipsum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.14",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 6:14",
      "text": "dicens: Nisi benedicens benedicam te, et multiplicans multiplicabo te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.15",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 6:15",
      "text": "Et sic longanimiter ferens, adeptus est repromissionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.16",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 6:16",
      "text": "Homines enim per majorem sui jurant: et omnis controversiæ eorum finis, ad confirmationem, est juramentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.17",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 6:17",
      "text": "In quo abundantius volens Deus ostendere pollicitationis hæredibus, immobilitatem consilii sui, interposuit jusjurandum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.18",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 6:18",
      "text": "ut per duas res immobiles, quibus impossibile est mentiri Deum, fortissimum solatium habeamus, qui confugimus ad tenendam propositam spem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.19",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 6:19",
      "text": "quam sicut anchoram habemus animæ tutam ac firmam, et incedentem usque ad interiora velaminis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hebrews.6.20",
      "translationId": "vulgate",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 6:20",
      "text": "ubi præcursor pro nobis introivit Jesus, secundum ordinem Melchisedech pontifex factus in æternum.",
      "paragraphStart": false
    }
  ]
}
