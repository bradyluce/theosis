{
  "chapter": {
    "id": "vulgate:esther.15",
    "translationId": "vulgate",
    "bookSlug": "esther",
    "chapterNumber": 15,
    "referenceLabel": "Esther 15",
    "summary": "Source text for Esther 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:esther.15.1",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Esther 15:1",
      "text": "Et mandavit ei (haud dubium quin esset Mardochæus) ut ingrederetur ad regem, et rogaret pro populo suo et pro patria sua.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:esther.15.2",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Esther 15:2",
      "text": "Memorare, inquit, dierum humilitatis tuæ, quomodo nutrita sis in manu mea, quia Aman secundus a rege locutus est contra nos in mortem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.3",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Esther 15:3",
      "text": "et tu invoca Dominum, et loquere regi pro nobis, et libera nos de morte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.4",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Esther 15:4",
      "text": "Die autem tertio deposuit vestimenta ornatus sui, et circumdata est gloria sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.5",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Esther 15:5",
      "text": "Cumque regio fulgeret habitu, et invocasset omnium rectorem et salvatorem Deum, assumpsit duas famulas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.6",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Esther 15:6",
      "text": "et super unam quidem innitebatur, quasi præ deliciis et nimia teneritudine corpus suum ferre non sustinens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.7",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Esther 15:7",
      "text": "altera autem famularum sequebatur dominam, defluentia in humum indumenta sustentans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.8",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Esther 15:8",
      "text": "Ipsa autem roseo colore vultum perfusa, et gratis ac nitentibus oculis, tristem celabat animum, et nimio timore contractum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.9",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Esther 15:9",
      "text": "Ingressa igitur cuncta per ordinem ostia, stetit contra regem, ubi ille residebat super solium regni sui, indutus vestibus regiis, auroque fulgens, et pretiosis lapidibus: eratque terribilis aspectu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.10",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Esther 15:10",
      "text": "Cumque elevasset faciem, et ardentibus oculis furorem pectoris indicasset, regina corruit, et in pallorem colore mutato, lassum super ancillulam reclinavit caput.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.11",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Esther 15:11",
      "text": "Convertitque Deus spiritum regis in mansuetudinem, et festinus ac metuens exilivit de solio, et sustentans eam ulnis suis donec rediret ad se, his verbis blandiebatur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.12",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Esther 15:12",
      "text": "Quid habes, Esther? ego sum frater tuus: noli metuere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.13",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Esther 15:13",
      "text": "Non morieris: non enim pro te, sed pro omnibus hæc lex constituta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.14",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Esther 15:14",
      "text": "Accede igitur, et tange sceptrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.15",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Esther 15:15",
      "text": "Cumque illa reticeret, tulit auream virgam, et posuit super collum ejus, et osculatus est eam, et ait: Cur mihi non loqueris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.16",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Esther 15:16",
      "text": "Quæ respondit: Vidi te, domine, quasi angelum Dei, et conturbatum est cor meum præ timore gloriæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.17",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Esther 15:17",
      "text": "Valde enim mirabilis es, domine, et facies tua plena est gratiarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.18",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Esther 15:18",
      "text": "Cumque loqueretur, rursus corruit, et pene exanimata est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:esther.15.19",
      "translationId": "vulgate",
      "bookSlug": "esther",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Esther 15:19",
      "text": "Rex autem turbabatur, et omnes ministri ejus consolabantur eam.",
      "paragraphStart": false
    }
  ]
}
