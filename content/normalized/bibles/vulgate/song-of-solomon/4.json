{
  "chapter": {
    "id": "vulgate:song-of-solomon.4",
    "translationId": "vulgate",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 4,
    "referenceLabel": "Song of Solomon 4",
    "summary": "Source text for Song of Solomon 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:song-of-solomon.4.1",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 4:1",
      "text": "Sponsus Quam pulchra es, amica mea! quam pulchra es! Oculi tui columbarum, absque eo quod intrinsecus latet. Capilli tui sicut greges caprarum quæ ascenderunt de monte Galaad.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:song-of-solomon.4.2",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 4:2",
      "text": "Dentes tui sicut greges tonsarum quæ ascenderunt de lavacro; omnes gemellis fœtibus, et sterilis non est inter eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.3",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 4:3",
      "text": "Sicut vitta coccinea labia tua, et eloquium tuum dulce. Sicut fragmen mali punici, ita genæ tuæ, absque eo quod intrinsecus latet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.4",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 4:4",
      "text": "Sicut turris David collum tuum, quæ ædificata est cum propugnaculis; mille clypei pendent ex ea, omnis armatura fortium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.5",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 4:5",
      "text": "Duo ubera tua sicut duo hinnuli, capreæ gemelli, qui pascuntur in liliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.6",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 4:6",
      "text": "Donec aspiret dies, et inclinentur umbræ, vadam ad montem myrrhæ, et ad collem thuris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.7",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 4:7",
      "text": "Tota pulchra es, amica mea, et macula non est in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.8",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 4:8",
      "text": "Veni de Libano, sponsa mea: veni de Libano, veni, coronaberis: de capite Amana, de vertice Sanir et Hermon, de cubilibus leonum, de montibus pardorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.9",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 4:9",
      "text": "Vulnerasti cor meum, soror mea, sponsa; vulnerasti cor meum in uno oculorum tuorum, et in uno crine colli tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.10",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 4:10",
      "text": "Quam pulchræ sunt mammæ tuæ, soror mea sponsa! pulchriora sunt ubera tua vino, et odor unguentorum tuorum super omnia aromata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.11",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 4:11",
      "text": "Favus distillans labia tua, sponsa; mel et lac sub lingua tua: et odor vestimentorum tuorum sicut odor thuris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.12",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 4:12",
      "text": "Hortus conclusus soror mea, sponsa, hortus conclusus, fons signatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.13",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 4:13",
      "text": "Emissiones tuæ paradisus malorum punicorum, cum pomorum fructibus, cypri cum nardo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.14",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 4:14",
      "text": "Nardus et crocus, fistula et cinnamomum, cum universis lignis Libani; myrrha et aloë, cum omnibus primis unguentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.15",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 4:15",
      "text": "Fons hortorum, puteus aquarum viventium, quæ fluunt impetu de Libano.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.4.16",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 4:16",
      "text": "Sponsa Surge, aquilo, et veni, auster: perfla hortum meum, et fluant aromata illius.",
      "paragraphStart": false
    }
  ]
}
