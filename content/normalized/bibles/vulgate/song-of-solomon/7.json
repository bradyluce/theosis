{
  "chapter": {
    "id": "vulgate:song-of-solomon.7",
    "translationId": "vulgate",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 7,
    "referenceLabel": "Song of Solomon 7",
    "summary": "Source text for Song of Solomon 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:song-of-solomon.7.1",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 7:1",
      "text": "Sponsa Quid videbis in Sulamite, nisi choros castrorum? Chorus Quam pulchri sunt gressus tui in calceamentis, filia principis! Juncturæ femorum tuorum sicut monilia quæ fabricata sunt manu artificis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:song-of-solomon.7.2",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 7:2",
      "text": "Umbilicus tuus crater tornatilis, numquam indigens poculis. Venter tuus sicut acervus tritici vallatus liliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.3",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 7:3",
      "text": "Duo ubera tua sicut duo hinnuli, gemelli capreæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.4",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 7:4",
      "text": "Collum tuum sicut turris eburnea; oculi tui sicut piscinæ in Hesebon quæ sunt in porta filiæ multitudinis. Nasus tuus sicut turris Libani, quæ respicit contra Damascum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.5",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 7:5",
      "text": "Caput tuum ut Carmelus; et comæ capitis tui sicut purpura regis vincta canalibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.6",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 7:6",
      "text": "Sponsus Quam pulchra es, et quam decora, carissima, in deliciis!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.7",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 7:7",
      "text": "Statura tua assimilata est palmæ, et ubera tua botris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.8",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 7:8",
      "text": "Dixi: Ascendam in palmam, et apprehendam fructus ejus; et erunt ubera tua sicut botri vineæ, et odor oris tui sicut malorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.9",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 7:9",
      "text": "Guttur tuum sicut vinum optimum, dignum dilecto meo ad potandum, labiisque et dentibus illius ad ruminandum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.10",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 7:10",
      "text": "Sponsa Ego dilecto meo, et ad me conversio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.11",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 7:11",
      "text": "Veni, dilecte mi, egrediamur in agrum, commoremur in villis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.12",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 7:12",
      "text": "Mane surgamus ad vineas: videamus si floruit vinea, si flores fructus parturiunt, si floruerunt mala punica; ibi dabo tibi ubera mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.7.13",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 7:13",
      "text": "Mandragoræ dederunt odorem in portis nostris omnia poma: nova et vetera, dilecte mi, servavi tibi.",
      "paragraphStart": false
    }
  ]
}
