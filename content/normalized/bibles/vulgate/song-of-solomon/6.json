{
  "chapter": {
    "id": "vulgate:song-of-solomon.6",
    "translationId": "vulgate",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 6,
    "referenceLabel": "Song of Solomon 6",
    "summary": "Source text for Song of Solomon 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:song-of-solomon.6.1",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 6:1",
      "text": "Sponsa Dilectus meus descendit in hortum suum ad areolam aromatum, ut pascatur in hortis, et lilia colligat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:song-of-solomon.6.2",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 6:2",
      "text": "Ego dilecto meo, et dilectus meus mihi, qui pascitur inter lilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.3",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 6:3",
      "text": "Sponsus Pulchra es, amica mea; suavis, et decora sicut Jerusalem; terribilis ut castrorum acies ordinata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.4",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 6:4",
      "text": "Averte oculos tuos a me, quia ipsi me avolare fecerunt. Capilli tui sicut grex caprarum quæ apparuerunt de Galaad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.5",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 6:5",
      "text": "Dentes tui sicut grex ovium quæ ascenderunt de lavacro: omnes gemellis fœtibus, et sterilis non est in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.6",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 6:6",
      "text": "Sicut cortex mali punici, sic genæ tuæ, absque occultis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.7",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 6:7",
      "text": "Sexaginta sunt reginæ, et octoginta concubinæ, et adolescentularum non est numerus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.8",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 6:8",
      "text": "Una est columba mea, perfecta mea, una est matris suæ, electa genetrici suæ. Viderunt eam filiæ, et beatissimam prædicaverunt; reginæ et concubinæ, et laudaverunt eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.9",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 6:9",
      "text": "Quæ est ista quæ progreditur quasi aurora consurgens, pulchra ut luna, electa ut sol, terribilis ut castrorum acies ordinata?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.10",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 6:10",
      "text": "Sponsa Descendi in hortum nucum, ut viderem poma convallium, et inspicerem si floruisset vinea, et germinassent mala punica.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.11",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 6:11",
      "text": "Nescivi: anima mea conturbavit me, propter quadrigas Aminadab.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.6.12",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 6:12",
      "text": "Chorus Revertere, revertere, Sulamitis! revertere, revertere ut intueamur te.",
      "paragraphStart": false
    }
  ]
}
