{
  "chapter": {
    "id": "vulgate:song-of-solomon.3",
    "translationId": "vulgate",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 3,
    "referenceLabel": "Song of Solomon 3",
    "summary": "Source text for Song of Solomon 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:song-of-solomon.3.1",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 3:1",
      "text": "In lectulo meo, per noctes, quæsivi quem diligit anima mea: quæsivi illum, et non inveni.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:song-of-solomon.3.2",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 3:2",
      "text": "Surgam, et circuibo civitatem: per vicos et plateas quæram quem diligit anima mea: quæsivi illum, et non inveni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.3",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 3:3",
      "text": "Invenerunt me vigiles qui custodiunt civitatem: Num quem diligit anima mea vidistis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.4",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 3:4",
      "text": "Paululum cum pertransissem eos, inveni quem diligit anima mea: tenui eum, nec dimittam, donec introducam illum in domum matris meæ, et in cubiculum genetricis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.5",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 3:5",
      "text": "Sponsus Adjuro vos, filiæ Jerusalem, per capreas cervosque camporum, ne suscitetis, neque evigilare faciatis dilectam, donec ipsa velit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.6",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 3:6",
      "text": "Chorus Quæ est ista quæ ascendit per desertum sicut virgula fumi ex aromatibus myrrhæ, et thuris, et universi pulveris pigmentarii?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.7",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 3:7",
      "text": "En lectulum Salomonis sexaginta fortes ambiunt ex fortissimis Israël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.8",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 3:8",
      "text": "omnes tenentes gladios, et ad bella doctissimi: uniuscujusque ensis super femur suum propter timores nocturnos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.9",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 3:9",
      "text": "Ferculum fecit sibi rex Salomon de lignis Libani;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.10",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 3:10",
      "text": "columnas ejus fecit argenteas, reclinatorium aureum, ascensum purpureum; media caritate constravit, propter filias Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.3.11",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 3:11",
      "text": "Egredimini et videte, filiæ Sion, regem Salomonem in diademate quo coronavit illum mater sua in die desponsationis illius, et in die lætitiæ cordis ejus.",
      "paragraphStart": false
    }
  ]
}
