{
  "chapter": {
    "id": "vulgate:song-of-solomon.2",
    "translationId": "vulgate",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:song-of-solomon.2.1",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "Ego flos campi, et lilium convallium.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:song-of-solomon.2.2",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "Sponsus Sicut lilium inter spinas, sic amica mea inter filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.3",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "Sponsa Sicut malus inter ligna silvarum, sic dilectus meus inter filios. Sub umbra illius quem desideraveram sedi, et fructus ejus dulcis gutturi meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.4",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "Introduxit me in cellam vinariam; ordinavit in me caritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.5",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Fulcite me floribus, stipate me malis, quia amore langueo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.6",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "Læva ejus sub capite meo, et dextera illius amplexabitur me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.7",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "Sponsus Adjuro vos, filiæ Jerusalem, per capreas cervosque camporum, ne suscitetis, neque evigilare faciatis dilectam, quoadusque ipsa velit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.8",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "Sponsa Vox dilecti mei; ecce iste venit, saliens in montibus, transiliens colles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.9",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "Similis est dilectus meus capreæ, hinnuloque cervorum. En ipse stat post parietem nostrum, respiciens per fenestras, prospiciens per cancellos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.10",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "En dilectus meus loquitur mihi. Sponsus Surge, propera, amica mea, columba mea, formosa mea, et veni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.11",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "jam enim hiems transiit; imber abiit, et recessit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.12",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "Flores apparuerunt in terra nostra; tempus putationis advenit: vox turturis audita est in terra nostra;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.13",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "ficus protulit grossos suos; vineæ florentes dederunt odorem suum. Surge, amica mea, speciosa mea, et veni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.14",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "columba mea, in foraminibus petræ, in caverna maceriæ, ostende mihi faciem tuam, sonet vox tua in auribus meis: vox enim tua dulcis, et facies tua decora.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.15",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Sponsa Capite nobis vulpes parvulas quæ demoliuntur vineas: nam vinea nostra floruit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.16",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "Dilectus meus mihi, et ego illi, qui pascitur inter lilia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.2.17",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "donec aspiret dies, et inclinentur umbræ. Revertere; similis esto, dilecte mi, capreæ, hinnuloque cervorum super montes Bether.",
      "paragraphStart": false
    }
  ]
}
