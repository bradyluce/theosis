{
  "chapter": {
    "id": "vulgate:song-of-solomon.1",
    "translationId": "vulgate",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 1,
    "referenceLabel": "Song of Solomon 1",
    "summary": "Source text for Song of Solomon 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:song-of-solomon.1.1",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 1:1",
      "text": "Sponsa Osculetur me osculo oris sui; quia meliora sunt ubera tua vino,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:song-of-solomon.1.2",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 1:2",
      "text": "fragrantia unguentis optimis. Oleum effusum nomen tuum; ideo adolescentulæ dilexerunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.3",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 1:3",
      "text": "Chorus Adolescentularum Trahe me, post te curremus in odorem unguentorum tuorum. Introduxit me rex in cellaria sua; exsultabimus et lætabimur in te, memores uberum tuorum super vinum. Recti diligunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.4",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 1:4",
      "text": "Sponsa Nigra sum, sed formosa, filiæ Jerusalem, sicut tabernacula Cedar, sicut pelles Salomonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.5",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 1:5",
      "text": "Nolite me considerare quod fusca sim, quia decoloravit me sol. Filii matris meæ pugnaverunt contra me; posuerunt me custodem in vineis: vineam meam non custodivi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.6",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 1:6",
      "text": "Indica mihi, quem diligit anima mea, ubi pascas, ubi cubes in meridie, ne vagari incipiam post greges sodalium tuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.7",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 1:7",
      "text": "Sponsus Si ignoras te, o pulcherrima inter mulieres, egredere, et abi post vestigia gregum, et pasce hædos tuos juxta tabernacula pastorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.8",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 1:8",
      "text": "Equitatui meo in curribus Pharaonis assimilavi te, amica mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.9",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 1:9",
      "text": "Pulchræ sunt genæ tuæ sicut turturis; collum tuum sicut monilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.10",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 1:10",
      "text": "Murenulas aureas faciemus tibi, vermiculatas argento.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.11",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 1:11",
      "text": "Sponsa Dum esset rex in accubitu suo, nardus mea dedit odorem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.12",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 1:12",
      "text": "Fasciculus myrrhæ dilectus meus mihi; inter ubera mea commorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.13",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 1:13",
      "text": "Botrus cypri dilectus meus mihi in vineis Engaddi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.14",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 1:14",
      "text": "Sponsus Ecce tu pulchra es, amica mea! ecce tu pulchra es! Oculi tui columbarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.15",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 1:15",
      "text": "Sponsa Ecce tu pulcher es, dilecte mi, et decorus! Lectulus noster floridus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:song-of-solomon.1.16",
      "translationId": "vulgate",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 1:16",
      "text": "Tigna domorum nostrarum cedrina, laquearia nostra cypressina.",
      "paragraphStart": false
    }
  ]
}
