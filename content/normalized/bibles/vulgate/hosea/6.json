{
  "chapter": {
    "id": "vulgate:hosea.6",
    "translationId": "vulgate",
    "bookSlug": "hosea",
    "chapterNumber": 6,
    "referenceLabel": "Hosea 6",
    "summary": "Source text for Hosea 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hosea.6.1",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Hosea 6:1",
      "text": "In tribulatione sua mane consurgent ad me: Venite, et revertamur ad Dominum,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hosea.6.2",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Hosea 6:2",
      "text": "quia ipse cepit, et sanabit nos; percutiet, et curabit nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.3",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Hosea 6:3",
      "text": "Vivificabit nos post duos dies; in die tertia suscitabit nos, et vivemus in conspectu ejus. Sciemus, sequemurque ut cognoscamus Dominum: quasi diluculum præparatus est egressus ejus, et veniet quasi imber nobis temporaneus et serotinus terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.4",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Hosea 6:4",
      "text": "Quid faciam tibi, Ephraim? quid faciam tibi, Juda? misericordia vestra quasi nubes matutina, et quasi ros mane pertransiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.5",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Hosea 6:5",
      "text": "Propter hoc dolavi in prophetis; occidi eos in verbis oris mei: et judicia tua quasi lux egredientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.6",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Hosea 6:6",
      "text": "Quia misericordiam volui, et non sacrificium; et scientiam Dei plus quam holocausta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.7",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Hosea 6:7",
      "text": "Ipsi autem sicut Adam transgressi sunt pactum: ibi prævaricati sunt in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.8",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Hosea 6:8",
      "text": "Galaad civitas operantium idolum, supplantata sanguine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.9",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Hosea 6:9",
      "text": "Et quasi fauces virorum latronum, particeps sacerdotum, in via interficientium pergentes de Sichem: quia scelus operati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.10",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Hosea 6:10",
      "text": "In domo Israël vidi horrendum: ibi fornicationes Ephraim, contaminatus est Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.6.11",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Hosea 6:11",
      "text": "Sed et Juda, pone messem tibi, cum convertero captivitatem populi mei.",
      "paragraphStart": false
    }
  ]
}
