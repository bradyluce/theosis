{
  "chapter": {
    "id": "vulgate:hosea.12",
    "translationId": "vulgate",
    "bookSlug": "hosea",
    "chapterNumber": 12,
    "referenceLabel": "Hosea 12",
    "summary": "Source text for Hosea 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:hosea.12.1",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Hosea 12:1",
      "text": "Ephraim pascit ventum, et sequitur æstum; tota die mendacium et vastitatem multiplicat: et fœdus cum Assyriis iniit, et oleum in Ægyptum ferebat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:hosea.12.2",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Hosea 12:2",
      "text": "Judicium ergo Domini cum Juda, et visitatio super Jacob: juxta vias ejus, et juxta adinventiones ejus reddet ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.3",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Hosea 12:3",
      "text": "In utero supplantavit fratrem suum, et in fortitudine sua directus est cum angelo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.4",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Hosea 12:4",
      "text": "Et invaluit ad angelum, et confortatus est; flevit, et rogavit eum. In Bethel invenit eum, et ibi locutus est nobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.5",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Hosea 12:5",
      "text": "Et Dominus Deus exercituum, Dominus memoriale ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.6",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Hosea 12:6",
      "text": "Et tu ad Deum tuum converteris; misericordiam et judicium custodi, et spera in Deo tuo semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.7",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Hosea 12:7",
      "text": "Chanaan, in manu ejus statera dolosa, calumniam dilexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.8",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Hosea 12:8",
      "text": "Et dixit Ephraim: Verumtamen dives effectus sum; inveni idolum mihi: omnes labores mei non invenient mihi iniquitatem quam peccavi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.9",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Hosea 12:9",
      "text": "Et ego Dominus Deus tuus ex terra Ægypti: adhuc sedere te faciam in tabernaculis, sicut in diebus festivitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.10",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Hosea 12:10",
      "text": "Et locutus sum super prophetas, et ego visionem multiplicavi, et in manu prophetarum assimilatus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.11",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Hosea 12:11",
      "text": "Si Galaad idolum, ergo frustra erant in Galgal bobus immolantes; nam et altaria eorum quasi acervi super sulcos agri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.12",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Hosea 12:12",
      "text": "Fugit Jacob in regionem Syriæ, et servivit Israël in uxorem, et in uxorem servavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.13",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Hosea 12:13",
      "text": "In propheta autem eduxit Dominus Israël de Ægypto, et in propheta servatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:hosea.12.14",
      "translationId": "vulgate",
      "bookSlug": "hosea",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Hosea 12:14",
      "text": "Ad iracundiam me provocavit Ephraim in amaritudinibus suis: et sanguis ejus super eum veniet, et opprobrium ejus restituet ei Dominus suus.",
      "paragraphStart": false
    }
  ]
}
