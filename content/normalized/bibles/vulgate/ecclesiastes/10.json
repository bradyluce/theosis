{
  "chapter": {
    "id": "vulgate:ecclesiastes.10",
    "translationId": "vulgate",
    "bookSlug": "ecclesiastes",
    "chapterNumber": 10,
    "referenceLabel": "Ecclesiastes 10",
    "summary": "Source text for Ecclesiastes 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ecclesiastes.10.1",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Ecclesiastes 10:1",
      "text": "Muscæ morientes perdunt suavitatem unguenti. Pretiosior est sapientia et gloria, parva et ad tempus stultitia.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ecclesiastes.10.2",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Ecclesiastes 10:2",
      "text": "Cor sapientis in dextera ejus, et cor stulti in sinistra illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.3",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Ecclesiastes 10:3",
      "text": "Sed et in via stultus ambulans, cum ipse insipiens sit, omnes stultos æstimat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.4",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Ecclesiastes 10:4",
      "text": "Si spiritus potestatem habentis ascenderit super te, locum tuum ne demiseris, quia curatio faciet cessare peccata maxima.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.5",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Ecclesiastes 10:5",
      "text": "Est malum quod vidi sub sole, quasi per errorem egrediens a facie principis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.6",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Ecclesiastes 10:6",
      "text": "positum stultum in dignitate sublimi, et divites sedere deorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.7",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Ecclesiastes 10:7",
      "text": "Vidi servos in equis, et principes ambulantes super terram quasi servos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.8",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Ecclesiastes 10:8",
      "text": "Qui fodit foveam incidet in eam, et qui dissipat sepem mordebit eum coluber.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.9",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Ecclesiastes 10:9",
      "text": "Qui transfert lapides affligetur in eis, et qui scindit ligna vulnerabitur ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.10",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Ecclesiastes 10:10",
      "text": "Si retusum fuerit ferrum, et hoc non ut prius, sed hebetatum fuerit, multo labore exacuetur, et post industriam sequetur sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.11",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Ecclesiastes 10:11",
      "text": "Si mordeat serpens in silentio, nihil eo minus habet qui occulte detrahit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.12",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Ecclesiastes 10:12",
      "text": "Verba oris sapientis gratia, et labia insipientis præcipitabunt eum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.13",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Ecclesiastes 10:13",
      "text": "initium verborum ejus stultitia, et novissimum oris illius error pessimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.14",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Ecclesiastes 10:14",
      "text": "Stultus verba multiplicat. Ignorat homo quid ante se fuerit; et quid post se futurum sit, quis ei poterit indicare?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.15",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Ecclesiastes 10:15",
      "text": "Labor stultorum affliget eos, qui nesciunt in urbem pergere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.16",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Ecclesiastes 10:16",
      "text": "Væ tibi, terra, cujus rex puer est, et cujus principes mane comedunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.17",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Ecclesiastes 10:17",
      "text": "Beata terra cujus rex nobilis est, et cujus principes vescuntur in tempore suo, ad reficiendum, et non ad luxuriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.18",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Ecclesiastes 10:18",
      "text": "In pigritiis humiliabitur contignatio, et in infirmitate manuum perstillabit domus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.19",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Ecclesiastes 10:19",
      "text": "In risum faciunt panem et vinum ut epulentur viventes; et pecuniæ obediunt omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.10.20",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Ecclesiastes 10:20",
      "text": "In cogitatione tua regi ne detrahas, et in secreto cubiculi tui ne maledixeris diviti: quia et aves cæli portabunt vocem tuam, et qui habet pennas annuntiabit sententiam.",
      "paragraphStart": false
    }
  ]
}
