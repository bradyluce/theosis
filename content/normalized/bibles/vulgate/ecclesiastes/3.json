{
  "chapter": {
    "id": "vulgate:ecclesiastes.3",
    "translationId": "vulgate",
    "bookSlug": "ecclesiastes",
    "chapterNumber": 3,
    "referenceLabel": "Ecclesiastes 3",
    "summary": "Source text for Ecclesiastes 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ecclesiastes.3.1",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Ecclesiastes 3:1",
      "text": "Omnia tempus habent, et suis spatiis transeunt universa sub cælo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ecclesiastes.3.2",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Ecclesiastes 3:2",
      "text": "Tempus nascendi, et tempus moriendi; tempus plantandi, et tempus evellendi quod plantatum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.3",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Ecclesiastes 3:3",
      "text": "Tempus occidendi, et tempus sanandi; tempus destruendi, et tempus ædificandi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.4",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Ecclesiastes 3:4",
      "text": "Tempus flendi, et tempus ridendi; tempus plangendi, et tempus saltandi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.5",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Ecclesiastes 3:5",
      "text": "Tempus spargendi lapides, et tempus colligendi, tempus amplexandi, et tempus longe fieri ab amplexibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.6",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Ecclesiastes 3:6",
      "text": "Tempus acquirendi, et tempus perdendi; tempus custodiendi, et tempus abjiciendi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.7",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Ecclesiastes 3:7",
      "text": "Tempus scindendi, et tempus consuendi; tempus tacendi, et tempus loquendi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.8",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Ecclesiastes 3:8",
      "text": "Tempus dilectionis, et tempus odii; tempus belli, et tempus pacis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.9",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Ecclesiastes 3:9",
      "text": "Quid habet amplius homo de labore suo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.10",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Ecclesiastes 3:10",
      "text": "Vidi afflictionem quam dedit Deus filiis hominum, ut distendantur in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.11",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Ecclesiastes 3:11",
      "text": "Cuncta fecit bona in tempore suo, et mundum tradidit disputationi eorum, ut non inveniat homo opus quod operatus est Deus ab initio usque ad finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.12",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Ecclesiastes 3:12",
      "text": "Et cognovi quod non esset melius nisi lætari, et facere bene in vita sua;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.13",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Ecclesiastes 3:13",
      "text": "omnis enim homo qui comedit et bibit, et videt bonum de labore suo, hoc donum Dei est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.14",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Ecclesiastes 3:14",
      "text": "Didici quod omnia opera quæ fecit Deus perseverent in perpetuum; non possumus eis quidquam addere, nec auferre, quæ fecit Deus ut timeatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.15",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Ecclesiastes 3:15",
      "text": "Quod factum est, ipsum permanet; quæ futura sunt jam fuerunt, et Deus instaurat quod abiit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.16",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Ecclesiastes 3:16",
      "text": "Vidi sub sole in loco judicii impietatem, et in loco justitiæ iniquitatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.17",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Ecclesiastes 3:17",
      "text": "et dixi in corde meo: Justum et impium judicabit Deus, et tempus omnis rei tunc erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.18",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Ecclesiastes 3:18",
      "text": "Dixi in corde meo de filiis hominum, ut probaret eos Deus, et ostenderet similes esse bestiis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.19",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Ecclesiastes 3:19",
      "text": "Idcirco unus interitus est hominis et jumentorum, et æqua utriusque conditio. Sicut moritur homo, sic et illa moriuntur. Similiter spirant omnia, et nihil habet homo jumento amplius: cuncta subjacent vanitati,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.20",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Ecclesiastes 3:20",
      "text": "et omnia pergunt ad unum locum. De terra facta sunt, et in terram pariter revertuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.21",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Ecclesiastes 3:21",
      "text": "Quis novit si spiritus filiorum Adam ascendat sursum, et si spiritus jumentorum descendat deorsum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ecclesiastes.3.22",
      "translationId": "vulgate",
      "bookSlug": "ecclesiastes",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Ecclesiastes 3:22",
      "text": "Et deprehendi nihil esse melius quam lætari hominem in opere suo, et hanc esse partem illius. Quis enim eum adducet ut post se futura cognoscat?",
      "paragraphStart": false
    }
  ]
}
