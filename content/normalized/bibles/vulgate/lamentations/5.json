{
  "chapter": {
    "id": "vulgate:lamentations.5",
    "translationId": "vulgate",
    "bookSlug": "lamentations",
    "chapterNumber": 5,
    "referenceLabel": "Lamentations 5",
    "summary": "Source text for Lamentations 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:lamentations.5.1",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 5:1",
      "text": "Recordare, Domine, quid acciderit nobis; intuere et respice opprobrium nostrum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:lamentations.5.2",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 5:2",
      "text": "Hæreditas nostra versa est ad alienos, domus nostræ ad extraneos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.3",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 5:3",
      "text": "Pupilli facti sumus absque patre, matres nostræ quasi viduæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.4",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 5:4",
      "text": "Aquam nostram pecunia bibimus; ligna nostra pretio comparavimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.5",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 5:5",
      "text": "Cervicibus nostris minabamur, lassis non dabatur requies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.6",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 5:6",
      "text": "Ægypto dedimus manum et Assyriis, ut saturaremur pane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.7",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 5:7",
      "text": "Patres nostri peccaverunt, et non sunt: et nos iniquitates eorum portavimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.8",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 5:8",
      "text": "Servi dominati sunt nostri: non fuit qui redimeret de manu eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.9",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 5:9",
      "text": "In animabus nostris afferebamus panem nobis, a facie gladii in deserto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.10",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 5:10",
      "text": "Pellis nostra quasi clibanus exusta est, a facie tempestatum famis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.11",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 5:11",
      "text": "Mulieres in Sion humiliaverunt, et virgines in civitatibus Juda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.12",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 5:12",
      "text": "Principes manu suspensi sunt; facies senum non erubuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.13",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 5:13",
      "text": "Adolescentibus impudice abusi sunt, et pueri in ligno corruerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.14",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 5:14",
      "text": "Senes defecerunt de portis, juvenes de choro psallentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.15",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 5:15",
      "text": "Defecit gaudium cordis nostri; versus est in luctum chorus noster.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.16",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 5:16",
      "text": "Cecidit corona capitis nostri: væ nobis, quia peccavimus!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.17",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 5:17",
      "text": "Propterea mœstum factum est cor nostrum; ideo contenebrati sunt oculi nostri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.18",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 5:18",
      "text": "propter montem Sion quia disperiit; vulpes ambulaverunt in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.19",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 5:19",
      "text": "Tu autem, Domine, in æternum permanebis, solium tuum in generationem et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.20",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 5:20",
      "text": "Quare in perpetuum oblivisceris nostri, derelinques nos in longitudine dierum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.21",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 5:21",
      "text": "Converte nos, Domine, ad te, et convertemur; innova dies nostros, sicut a principio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.5.22",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 5:22",
      "text": "Sed projiciens repulisti nos: iratus es contra nos vehementer.",
      "paragraphStart": false
    }
  ]
}
