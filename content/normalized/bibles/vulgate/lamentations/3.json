{
  "chapter": {
    "id": "vulgate:lamentations.3",
    "translationId": "vulgate",
    "bookSlug": "lamentations",
    "chapterNumber": 3,
    "referenceLabel": "Lamentations 3",
    "summary": "Source text for Lamentations 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:lamentations.3.1",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Lamentations 3:1",
      "text": "Aleph Ego vir videns paupertatem meam in virga indignationis ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:lamentations.3.2",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Lamentations 3:2",
      "text": "Aleph Me minavit, et adduxit in tenebras, et non in lucem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.3",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Lamentations 3:3",
      "text": "Aleph Tantum in me vertit et convertit manum suam tota die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.4",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Lamentations 3:4",
      "text": "Beth Vetustam fecit pellem meam et carnem meam; contrivit ossa mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.5",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Lamentations 3:5",
      "text": "Beth Ædificavit in gyro meo, et circumdedit me felle et labore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.6",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Lamentations 3:6",
      "text": "Beth In tenebrosis collocavit me, quasi mortuos sempiternos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.7",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Lamentations 3:7",
      "text": "Ghimel Circumædificavit adversum me, ut non egrediar; aggravavit compedem meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.8",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Lamentations 3:8",
      "text": "Ghimel Sed et cum clamavero, et rogavero, exclusit orationem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.9",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Lamentations 3:9",
      "text": "Ghimel Conclusit vias meas lapidibus quadris; semitas meas subvertit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.10",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Lamentations 3:10",
      "text": "Daleth Ursus insidians factus est mihi, leo in absconditis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.11",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Lamentations 3:11",
      "text": "Daleth Semitas meas subvertit, et confregit me; posuit me desolatam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.12",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Lamentations 3:12",
      "text": "Daleth Tetendit arcum suum, et posuit me quasi signum ad sagittam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.13",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Lamentations 3:13",
      "text": "He Misit in renibus meis filias pharetræ suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.14",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Lamentations 3:14",
      "text": "He Factus sum in derisum omni populo meo, canticum eorum tota die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.15",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Lamentations 3:15",
      "text": "He Replevit me amaritudinibus; inebriavit me absinthio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.16",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Lamentations 3:16",
      "text": "Vau Et fregit ad numerum dentes meos; cibavit me cinere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.17",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Lamentations 3:17",
      "text": "Vau Et repulsa est a pace anima mea; oblitus sum bonorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.18",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Lamentations 3:18",
      "text": "Vau Et dixi: Periit finis meus, et spes mea a Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.19",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Lamentations 3:19",
      "text": "Zain Recordare paupertatis, et transgressionis meæ, absinthii et fellis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.20",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Lamentations 3:20",
      "text": "Zain Memoria memor ero, et tabescet in me anima mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.21",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Lamentations 3:21",
      "text": "Zain Hæc recolens in corde meo, ideo sperabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.22",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Lamentations 3:22",
      "text": "Heth Misericordiæ Domini, quia non sumus consumpti; quia non defecerunt miserationes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.23",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Lamentations 3:23",
      "text": "Heth Novi diluculo, multa est fides tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.24",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Lamentations 3:24",
      "text": "Heth Pars mea Dominus, dixit anima mea; propterea exspectabo eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.25",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Lamentations 3:25",
      "text": "Teth Bonus est Dominus sperantibus in eum, animæ quærenti illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.26",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Lamentations 3:26",
      "text": "Teth Bonum est præstolari cum silentio salutare Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.27",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Lamentations 3:27",
      "text": "Teth Bonum est viro cum portaverit jugum ab adolescentia sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.28",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Lamentations 3:28",
      "text": "Jod Sedebit solitarius, et tacebit, quia levavit super se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.29",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Lamentations 3:29",
      "text": "Jod Ponet in pulvere os suum, si forte sit spes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.30",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Lamentations 3:30",
      "text": "Jod Dabit percutienti se maxillam: saturabitur opprobriis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.31",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Lamentations 3:31",
      "text": "Caph Quia non repellet in sempiternum Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.32",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Lamentations 3:32",
      "text": "Caph Quia si abjecit, et miserebitur, secundum multitudinem misericordiarum suarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.33",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Lamentations 3:33",
      "text": "Caph Non enim humiliavit ex corde suo et abjecit filios hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.34",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Lamentations 3:34",
      "text": "Lamed Ut conteret sub pedibus suis omnes vinctos terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.35",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Lamentations 3:35",
      "text": "Lamed Ut declinaret judicium viri in conspectu vultus Altissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.36",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Lamentations 3:36",
      "text": "Lamed Ut perverteret hominem in judicio suo; Dominus ignoravit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.37",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Lamentations 3:37",
      "text": "Mem Quis est iste qui dixit ut fieret, Domino non jubente?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.38",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Lamentations 3:38",
      "text": "Mem Ex ore Altissimi non egredientur nec mala nec bona?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.39",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 39,
      "referenceLabel": "Lamentations 3:39",
      "text": "Mem Quid murmuravit homo vivens, vir pro peccatis suis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.40",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 40,
      "referenceLabel": "Lamentations 3:40",
      "text": "Nun Scrutemur vias nostras, et quæramus, et revertamur ad Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.41",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 41,
      "referenceLabel": "Lamentations 3:41",
      "text": "Nun Levemus corda nostra cum manibus ad Dominum in cælos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.42",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 42,
      "referenceLabel": "Lamentations 3:42",
      "text": "Nun Nos inique egimus, et ad iracundiam provocavimus; idcirco tu inexorabilis es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.43",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 43,
      "referenceLabel": "Lamentations 3:43",
      "text": "Samech Operuisti in furore, et percussisti nos; occidisti, nec pepercisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.44",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 44,
      "referenceLabel": "Lamentations 3:44",
      "text": "Samech Opposuisti nubem tibi, ne transeat oratio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.45",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 45,
      "referenceLabel": "Lamentations 3:45",
      "text": "Samech Eradicationem et abjectionem posuisti me in medio populorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.46",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 46,
      "referenceLabel": "Lamentations 3:46",
      "text": "Phe Aperuerunt super nos os suum omnes inimici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.47",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 47,
      "referenceLabel": "Lamentations 3:47",
      "text": "Phe Formido et laqueus facta est nobis vaticinatio, et contritio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.48",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 48,
      "referenceLabel": "Lamentations 3:48",
      "text": "Phe Divisiones aquarum deduxit oculus meus, in contritione filiæ populi mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.49",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 49,
      "referenceLabel": "Lamentations 3:49",
      "text": "Ain Oculus meus afflictus est, nec tacuit, eo quod non esset requies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.50",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 50,
      "referenceLabel": "Lamentations 3:50",
      "text": "Ain Donec respiceret et videret Dominus de cælis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.51",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 51,
      "referenceLabel": "Lamentations 3:51",
      "text": "Ain Oculus meus deprædatus est animam meam in cunctis filiabus urbis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.52",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 52,
      "referenceLabel": "Lamentations 3:52",
      "text": "Sade Venatione ceperunt me quasi avem inimici mei gratis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.53",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 53,
      "referenceLabel": "Lamentations 3:53",
      "text": "Sade Lapsa est in lacum vita mea, et posuerunt lapidem super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.54",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 54,
      "referenceLabel": "Lamentations 3:54",
      "text": "Sade Inundaverunt aquæ super caput meum; dixi: Perii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.55",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 55,
      "referenceLabel": "Lamentations 3:55",
      "text": "Coph Invocavi nomen tuum, Domine, de lacu novissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.56",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 56,
      "referenceLabel": "Lamentations 3:56",
      "text": "Coph Vocem meam audisti; ne avertas aurem tuam a singultu meo et clamoribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.57",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 57,
      "referenceLabel": "Lamentations 3:57",
      "text": "Coph Appropinquasti in die quando invocavi te; dixisti: Ne timeas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.58",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 58,
      "referenceLabel": "Lamentations 3:58",
      "text": "Res Judicasti, Domine, causam animæ meæ, redemptor vitæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.59",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 59,
      "referenceLabel": "Lamentations 3:59",
      "text": "Res Vidisti, Domine, iniquitatem illorum adversum me: judica judicium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.60",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 60,
      "referenceLabel": "Lamentations 3:60",
      "text": "Res Vidisti omnem furorem, universas cogitationes eorum adversum me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.61",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 61,
      "referenceLabel": "Lamentations 3:61",
      "text": "Sin Audisti opprobrium eorum, Domine, omnes cogitationes eorum adversum me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.62",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 62,
      "referenceLabel": "Lamentations 3:62",
      "text": "Sin Labia insurgentium mihi, et meditationes eorum adversum me tota die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.63",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 63,
      "referenceLabel": "Lamentations 3:63",
      "text": "Sin Sessionem eorum et resurrectionem eorum vide; ego sum psalmus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.64",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 64,
      "referenceLabel": "Lamentations 3:64",
      "text": "Thau Redes eis vicem, Domine, juxta opera manuum suarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.65",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 65,
      "referenceLabel": "Lamentations 3:65",
      "text": "Thau Dabis eis scutum cordis, laborem tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:lamentations.3.66",
      "translationId": "vulgate",
      "bookSlug": "lamentations",
      "chapterNumber": 3,
      "verseNumber": 66,
      "referenceLabel": "Lamentations 3:66",
      "text": "Thau Persequeris in furore, et conteres eos sub cælis, Domine.",
      "paragraphStart": false
    }
  ]
}
