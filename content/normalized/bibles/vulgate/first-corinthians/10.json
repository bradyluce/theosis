{
  "chapter": {
    "id": "vulgate:first-corinthians.10",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 10,
    "referenceLabel": "1 Corinthians 10",
    "summary": "Source text for 1 Corinthians 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.10.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 10:1",
      "text": "Nolo enim vos ignorare fratres, quoniam patres nostri omnes sub nube fuerunt, et omnes mare transierunt,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.10.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 10:2",
      "text": "et omnes in Moyse baptizati sunt in nube, et in mari:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 10:3",
      "text": "et omnes eamdem escam spiritalem manducaverunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 10:4",
      "text": "et omnes eumdem potum spiritalem biberunt (bibebant autem de spiritali, consequente eos, petra: petra autem erat Christus):",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 10:5",
      "text": "sed non in pluribus eorum beneplacitum est Deo: nam prostrati sunt in deserto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 10:6",
      "text": "Hæc autem in figura facta sunt nostri, ut non simus concupiscentes malorum, sicut et illi concupierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 10:7",
      "text": "Neque idololatræ efficiamini, sicut quidam ex ipsis: quemadmodum scriptum est: Sedit populus manducare, et bibere, et surrexerunt ludere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 10:8",
      "text": "Neque fornicemur, sicut quidam ex ipsis fornicati sunt, et ceciderunt una die viginti tria millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 10:9",
      "text": "Neque tentemus Christum, sicut quidam eorum tentaverunt, et a serpentibus perierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 10:10",
      "text": "Neque murmuraveritis, sicut quidam eorum murmuraverunt, et perierunt ab exterminatore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 10:11",
      "text": "Hæc autem omnia in figura contingebant illis: scripta sunt autem ad correptionem nostram, in quos fines sæculorum devenerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 10:12",
      "text": "Itaque qui se existimat stare, videat ne cadat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 10:13",
      "text": "Tentatio vos non apprehendat nisi humana: fidelis autem Deus est, qui non patietur vos tentari supra id quod potestis, sed faciet etiam cum tentatione proventum ut possitis sustinere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 10:14",
      "text": "Propter quod, carissimi mihi, fugite ab idolorum cultura:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 10:15",
      "text": "ut prudentibus loquor, vos ipsi judicate quod dico.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 10:16",
      "text": "Calix benedictionis, cui benedicimus, nonne communicatio sanguinis Christi est? et panis quem frangimus, nonne participatio corporis Domini est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 10:17",
      "text": "Quoniam unus panis, unum corpus multi sumus, omnes qui de uno pane participamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 10:18",
      "text": "Videte Israël secundum carnem: nonne qui edunt hostias, participes sunt altaris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 10:19",
      "text": "Quid ergo? dico quod idolis immolatum sit aliquid? aut quod idolum, sit aliquid?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 10:20",
      "text": "Sed quæ immolant gentes, dæmoniis immolant, et non Deo. Nolo autem vos socios fieri dæmoniorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 10:21",
      "text": "non potestis calicem Domini bibere, et calicem dæmoniorum; non potestis mensæ Domini participes esse, et mensæ dæmoniorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 10:22",
      "text": "An æmulamur Dominum? numquid fortiores illo sumus? Omnia mihi licent, sed non omnia expediunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 10:23",
      "text": "Omnia mihi licent, sed non omnia ædificat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 10:24",
      "text": "Nemo quod suum est quærat, sed quod alterius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 10:25",
      "text": "Omne quod in macello venit, manducate, nihil interrogantes propter conscientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 10:26",
      "text": "Domini est terra, et plenitudo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 10:27",
      "text": "Si quis vocat vos infidelium, et vultis ire: omne quod vobis apponitur, manducate, nihil interrogantes propter conscientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 10:28",
      "text": "Si quis autem dixerit: Hoc immolatum est idolis: nolite manducare propter illum qui indicavit, et propter conscientiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 10:29",
      "text": "conscientiam autem dico non tuam, sed alterius. Ut quid enim libertas mea judicatur ab aliena conscientia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 10:30",
      "text": "Si ego cum gratia participo, quid blasphemor pro eo quod gratias ago?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 10:31",
      "text": "Sive ergo manducatis, sive bibitis, sive aliud quid facitis: omnia in gloriam Dei facite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.32",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 10:32",
      "text": "Sine offensione estote Judæis, et gentibus, et ecclesiæ Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.10.33",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 10:33",
      "text": "sicut et ego per omnia omnibus placeo, non quærens quod mihi utile est, sed quod multis: ut salvi fiant.",
      "paragraphStart": false
    }
  ]
}
