{
  "chapter": {
    "id": "vulgate:first-corinthians.9",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 9,
    "referenceLabel": "1 Corinthians 9",
    "summary": "Source text for 1 Corinthians 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.9.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 9:1",
      "text": "Non sum liber? non sum Apostolus? nonne Christum Jesum Dominum nostrum vidi? nonne opus meum vos estis in Domino?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.9.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 9:2",
      "text": "Et si aliis non sum Apostolus, sed tamen vobis sum: nam signaculum apostolatus mei vos estis in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 9:3",
      "text": "Mea defensio apud eos qui me interrogant, hæc est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 9:4",
      "text": "Numquid non habemus potestatem manducandi et bibendi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 9:5",
      "text": "numquid non habemus potestatem mulierem sororem circumducendi sicut et ceteri Apostoli, et fratres Domini, et Cephas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 9:6",
      "text": "aut ego solus, et Barnabas, non habemus potestatem hoc operandi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 9:7",
      "text": "Quis militat suis stipendiis umquam? quis plantat vineam, et de fructu ejus non edit? quis pascit gregem, et de lacte gregis non manducat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 9:8",
      "text": "Numquid secundum hominem hæc dico? an et lex hæc non dicit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 9:9",
      "text": "Scriptum est enim in lege Moysi: Non alligabis os bovi trituranti. Numquid de bobus cura est Deo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 9:10",
      "text": "an propter nos utique hoc dicit? Nam propter nos scripta sunt: quoniam debet in spe qui arat, arare: et qui triturat, in spe fructus percipiendi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 9:11",
      "text": "Si nos vobis spiritualia seminavimus, magnum est si nos carnalia vestra metamus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 9:12",
      "text": "Si alii potestatis vestræ participes sunt, quare non potius nos? Sed non usi sumus hac potestate: sed omnia sustinemus, ne quod offendiculum demus Evangelio Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 9:13",
      "text": "Nescitis quoniam qui in sacrario operantur quæ de sacrario sunt, edunt: et qui altari deserviunt, cum altari participant?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 9:14",
      "text": "Ita et Dominus ordinavit iis qui Evangelium annuntiant, de Evangelio vivere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 9:15",
      "text": "Ego autem nullo horum usus sum. Non autem scripsi hæc ut ita fiant in me: bonum est enim mihi magis mori, quam ut gloriam meam quis evacuet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 9:16",
      "text": "Nam si evangelizavero, non est mihi gloria: necessitas enim mihi incumbit: væ enim mihi est, si non evangelizavero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 9:17",
      "text": "Si enim volens hoc ago, mercedem habeo: si autem invitus, dispensatio mihi credita est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 9:18",
      "text": "Quæ est ergo merces mea? ut Evangelium prædicans, sine sumptu ponam Evangelium, ut non abutar potestate mea in Evangelio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 9:19",
      "text": "Nam cum liber essem ex omnibus, omnium me servum feci, ut plures lucrifacerem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 9:20",
      "text": "Et factus sum Judæis tamquam Judæus, ut Judæos lucrarer:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 9:21",
      "text": "iis qui sub lege sunt, quasi sub lege essem (cum ipse non essem sub lege) ut eos qui sub lege erant, lucrifacerem: iis qui sine lege erant, tamquam sine lege essem (cum sine lege Dei non essem: sed in lege essem Christi) ut lucrifacerem eos qui sine lege erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 9:22",
      "text": "Factus sum infirmis infirmus, ut infirmos lucrifacerem. Omnibus omnia factus sum, ut omnes facerem salvos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 9:23",
      "text": "Omnia autem facio propter Evangelium: ut particeps ejus efficiar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 9:24",
      "text": "Nescitis quod ii qui in stadio currunt, omnes quidem currunt, sed unus accipit bravium? Sic currite ut comprehendatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 9:25",
      "text": "Omnis autem qui in agone contendit, ab omnibus se abstinet, et illi quidem ut corruptibilem coronam accipiant: nos autem incorruptam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 9:26",
      "text": "Ego igitur sic curro, non quasi in incertum: sic pugno, non quasi aërem verberans:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.9.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 9:27",
      "text": "sed castigo corpus meum, et in servitutem redigo: ne forte cum aliis prædicaverim, ipse reprobus efficiar.",
      "paragraphStart": false
    }
  ]
}
