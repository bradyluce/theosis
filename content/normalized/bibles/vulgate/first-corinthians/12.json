{
  "chapter": {
    "id": "vulgate:first-corinthians.12",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 12,
    "referenceLabel": "1 Corinthians 12",
    "summary": "Source text for 1 Corinthians 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.12.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 12:1",
      "text": "De spiritualibus autem, nolo vos ignorare fratres.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.12.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 12:2",
      "text": "Scitis quoniam cum gentes essetis, ad simulacra muta prout ducebamini euntes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 12:3",
      "text": "Ideo notum vobis facio, quod nemo in Spiritu Dei loquens, dicit anathema Jesu. Et nemo potest dicere, Dominus Jesus, nisi in Spiritu Sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 12:4",
      "text": "Divisiones vero gratiarum sunt, idem autem Spiritus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 12:5",
      "text": "et divisiones ministrationum sunt, idem autem Dominus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 12:6",
      "text": "et divisiones operationum sunt, idem vero Deus qui operatur omnia in omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 12:7",
      "text": "Unicuique autem datur manifestatio Spiritus ad utilitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 12:8",
      "text": "Alii quidem per Spiritum datur sermo sapientiæ: alii autem sermo scientiæ secundum eumdem Spiritum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 12:9",
      "text": "alteri fides in eodem Spiritu: alii gratia sanitatum in uno Spiritu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 12:10",
      "text": "alii operatio virtutum, alii prophetia, alii discretio spirituum, alii genera linguarum, alii interpretatio sermonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 12:11",
      "text": "Hæc autem omnia operatur unus atque idem Spiritus, dividens singulis prout vult.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 12:12",
      "text": "Sicut enim corpus unum est, et membra habet multa, omnia autem membra corporis cum sint multa, unum tamen corpus sunt: ita et Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 12:13",
      "text": "Etenim in uno Spiritu omnes nos in unum corpus baptizati sumus, sive Judæi, sive gentiles, sive servi, sive liberi: et omnes in uno Spiritu potati sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 12:14",
      "text": "Nam et corpus non est unum membrum, sed multa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 12:15",
      "text": "Si dixerit pes: Quoniam non sum manus, non sum de corpore: num ideo non est de corpore?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 12:16",
      "text": "Et si dixerit auris: Quoniam non sum oculus, non sum de corpore: num ideo est de corpore?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 12:17",
      "text": "Si totum corpus oculus: ubi auditus? Si totum auditus: ubi odoratus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 12:18",
      "text": "Nunc autem posuit Deus membra, unumquodque eorum in corpore sicut voluit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 12:19",
      "text": "Quod si essent omnia unum membrum, ubi corpus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 12:20",
      "text": "Nunc autem multa quidem membra, unum autem corpus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 12:21",
      "text": "Non potest autem oculus dicere manui: Opera tua non indigeo: aut iterum caput pedibus: Non estis mihi necessarii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 12:22",
      "text": "Sed multo magis quæ videntur membra corporis infirmiora esse, necessariora sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 12:23",
      "text": "et quæ putamus ignobiliora membra esse corporis, his honorem abundantiorem circumdamus: et quæ inhonesta sunt nostra, abundantiorem honestatem habent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 12:24",
      "text": "Honesta autem nostra nullius egent: sed Deus temperavit corpus, ei cui deerat, abundantiorem tribuendo honorem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 12:25",
      "text": "ut non sit schisma in corpore, sed idipsum pro invicem sollicita sint membra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 12:26",
      "text": "Et si quid patitur unum membrum, compatiuntur omnia membra: sive gloriatur unum membrum, congaudent omnia membra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 12:27",
      "text": "Vos autem estis corpus Christi, et membra de membro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 12:28",
      "text": "Et quosdam quidem posuit Deus in ecclesia primum apostolos, secundo prophetas, exinde doctores, deinde virtutes, exinde gratias curationum, opitulationes, gubernationes, genera linguarum, interpretationes sermonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 12:29",
      "text": "Numquid omnes apostoli? numquid omnes prophetæ? numquid omnes doctores?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 12:30",
      "text": "numquid omnes virtutes? numquid omnes gratiam habent curationum? numquid omnes linguis loquuntur? numquid omnes interpretantur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.12.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 12:31",
      "text": "Æmulamini autem charismata meliora. Et adhuc excellentiorem viam vobis demonstro.",
      "paragraphStart": false
    }
  ]
}
