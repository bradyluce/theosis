{
  "chapter": {
    "id": "vulgate:first-corinthians.15",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 15,
    "referenceLabel": "1 Corinthians 15",
    "summary": "Source text for 1 Corinthians 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.15.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 15:1",
      "text": "Notum autem vobis facio, fratres, Evangelium, quod prædicavi vobis, quod et accepistis, in quo et statis,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.15.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 15:2",
      "text": "per quod et salvamini: qua ratione prædicaverim vobis, si tenetis, nisi frustra credidistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 15:3",
      "text": "Tradidi enim vobis in primis quod et accepi: quoniam Christus mortuus est pro peccatis nostris secundum Scripturas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 15:4",
      "text": "et quia sepultus est, et quia resurrexit tertia die secundum Scripturas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 15:5",
      "text": "et quia visus est Cephæ, et post hoc undecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 15:6",
      "text": "deinde visus est plus quam quingentis fratribus simul: ex quibus multi manent usque adhuc, quidam autem dormierunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 15:7",
      "text": "deinde visus est Jacobo, deinde Apostolis omnibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 15:8",
      "text": "novissime autem omnium tamquam abortivo, visus est et mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 15:9",
      "text": "Ego enim sum minimus Apostolorum, qui non sum dignus vocari Apostolus, quoniam persecutus sum ecclesiam Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 15:10",
      "text": "Gratia autem Dei sum id quod sum, et gratia ejus in me vacua non fuit, sed abundantius illis omnibus laboravi: non ego autem, sed gratia Dei mecum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 15:11",
      "text": "sive enim ego, sive illi: sic prædicamus, et sic credidistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 15:12",
      "text": "Si autem Christus prædicatur quod resurrexit a mortuis, quomodo quidam dicunt in vobis, quoniam resurrectio mortuorum non est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 15:13",
      "text": "Si autem resurrectio mortuorum non est: neque Christus resurrexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 15:14",
      "text": "Si autem Christus non resurrexit, inanis est ergo prædicatio nostra, inanis est et fides vestra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 15:15",
      "text": "invenimur autem et falsi testes Dei: quoniam testimonium diximus adversus Deum quod suscitaverit Christum, quem non suscitavit, si mortui non resurgunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 15:16",
      "text": "Nam si mortui non resurgunt, neque Christus resurrexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 15:17",
      "text": "Quod si Christus non resurrexit, vana est fides vestra: adhuc enim estis in peccatis vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 15:18",
      "text": "Ergo et qui dormierunt in Christo, perierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 15:19",
      "text": "Si in hac vita tantum in Christo sperantes sumus, miserabiliores sumus omnibus hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 15:20",
      "text": "Nunc autem Christus resurrexit a mortuis primitiæ dormientium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 15:21",
      "text": "quoniam quidem per hominem mors, et per hominem resurrectio mortuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 15:22",
      "text": "Et sicut in Adam omnes moriuntur, ita et in Christo omnes vivificabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 15:23",
      "text": "Unusquisque autem in suo ordine, primitiæ Christus: deinde ii qui sunt Christi, qui in adventu ejus crediderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 15:24",
      "text": "Deinde finis: cum tradiderit regnum Deo et Patri, cum evacuaverit omnem principatum, et potestatem, et virtutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 15:25",
      "text": "Oportet autem illum regnare donec ponat omnes inimicos sub pedibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 15:26",
      "text": "Novissima autem inimica destruetur mors: omnia enim subjecit pedibus ejus. Cum autem dicat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 15:27",
      "text": "Omnia subjecta sunt ei, sine dubio præter eum qui subjecit ei omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 15:28",
      "text": "Cum autem subjecta fuerint illi omnia: tunc et ipse Filius subjectus erit ei, qui subjecit sibi omnia, ut sit Deus omnia in omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 15:29",
      "text": "Alioquin quid facient qui baptizantur pro mortuis, si omnino mortui non resurgunt? ut quid et baptizantur pro illis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 15:30",
      "text": "ut quid et nos periclitamur omni hora?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 15:31",
      "text": "Quotidie morior per vestram gloriam, fratres, quam habeo in Christo Jesu Domino nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.32",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 15:32",
      "text": "Si secundum hominem ad bestias pugnavi Ephesi, quid mihi prodest, si mortui non resurgunt? Manducemus, et bibamus, cras enim moriemur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.33",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 15:33",
      "text": "Nolite seduci: corrumpunt mores bonos colloquia mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.34",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 15:34",
      "text": "Evigilate justi, et nolite peccare: ignorantiam enim Dei quidam habent, ad reverentiam vobis loquor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.35",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "1 Corinthians 15:35",
      "text": "Sed dicet aliquis: Quomodo resurgunt mortui? qualive corpore venient?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.36",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "1 Corinthians 15:36",
      "text": "Insipiens, tu quod seminas non vivificatur, nisi prius moriatur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.37",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "1 Corinthians 15:37",
      "text": "et quod seminas, non corpus, quod futurum est, seminas, sed nudum granum, ut puta tritici, aut alicujus ceterorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.38",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "1 Corinthians 15:38",
      "text": "Deus autem dat illi corpus sicut vult: ut unicuique seminum proprium corpus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.39",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "1 Corinthians 15:39",
      "text": "Non omnis caro, eadem caro: sed alia quidem hominum, alia vero pecorum, alia volucrum, alia autem piscium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.40",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "1 Corinthians 15:40",
      "text": "Et corpora cælestia, et corpora terrestria: sed alia quidem cælestium gloria, alia autem terrestrium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.41",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 41,
      "referenceLabel": "1 Corinthians 15:41",
      "text": "Alia claritas solis, alia claritas lunæ, et alia claritas stellarum. Stella enim a stella differt in claritate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.42",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 42,
      "referenceLabel": "1 Corinthians 15:42",
      "text": "sic et resurrectio mortuorum. Seminatur in corruptione, surget in incorruptione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.43",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 43,
      "referenceLabel": "1 Corinthians 15:43",
      "text": "Seminatur in ignobilitate, surget in gloria: seminatur in infirmitate, surget in virtute:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.44",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 44,
      "referenceLabel": "1 Corinthians 15:44",
      "text": "seminatur corpus animale, surget corpus spiritale. Si est corpus animale, est et spiritale, sicut scriptum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.45",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 45,
      "referenceLabel": "1 Corinthians 15:45",
      "text": "Factus est primus homo Adam in animam viventem, novissimus Adam in spiritum vivificantem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.46",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 46,
      "referenceLabel": "1 Corinthians 15:46",
      "text": "Sed non prius quod spiritale est, sed quod animale: deinde quod spiritale.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.47",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 47,
      "referenceLabel": "1 Corinthians 15:47",
      "text": "Primus homo de terra, terrenus: secundus homo de cælo, cælestis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.48",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 48,
      "referenceLabel": "1 Corinthians 15:48",
      "text": "Qualis terrenus, tales et terreni: et qualis cælestis, tales et cælestes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.49",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 49,
      "referenceLabel": "1 Corinthians 15:49",
      "text": "Igitur, sicut portavimus imaginem terreni, portemus et imaginem cælestis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.50",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 50,
      "referenceLabel": "1 Corinthians 15:50",
      "text": "Hoc autem dico, fratres: quia caro et sanguis regnum Dei possidere non possunt: neque corruptio incorruptelam possidebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.51",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 51,
      "referenceLabel": "1 Corinthians 15:51",
      "text": "Ecce mysterium vobis dico: omnes quidem resurgemus, sed non omnes immutabimur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.52",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 52,
      "referenceLabel": "1 Corinthians 15:52",
      "text": "In momento, in ictu oculi, in novissima tuba: canet enim tuba, et mortui resurgent incorrupti: et nos immutabimur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.53",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 53,
      "referenceLabel": "1 Corinthians 15:53",
      "text": "Oportet enim corruptibile hoc induere incorruptionem: et mortale hoc induere immortalitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.54",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 54,
      "referenceLabel": "1 Corinthians 15:54",
      "text": "Cum autem mortale hoc induerit immortalitatem, tunc fiet sermo, qui scriptus est: Absorpta est mors in victoria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.55",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 55,
      "referenceLabel": "1 Corinthians 15:55",
      "text": "Ubi est mors victoria tua? ubi est mors stimulus tuus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.56",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 56,
      "referenceLabel": "1 Corinthians 15:56",
      "text": "Stimulus autem mortis peccatum est: virtus vero peccati lex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.57",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 57,
      "referenceLabel": "1 Corinthians 15:57",
      "text": "Deo autem gratias, qui dedit nobis victoriam per Dominum nostrum Jesum Christum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.15.58",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 58,
      "referenceLabel": "1 Corinthians 15:58",
      "text": "Itaque fratres mei dilecti, stabiles estote, et immobiles: abundantes in opere Domini semper, scientes quod labor vester non est inanis in Domino.",
      "paragraphStart": false
    }
  ]
}
