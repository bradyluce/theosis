{
  "chapter": {
    "id": "vulgate:first-corinthians.16",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 16,
    "referenceLabel": "1 Corinthians 16",
    "summary": "Source text for 1 Corinthians 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.16.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 16:1",
      "text": "De collectis autem, quæ fiunt in sanctos, sicut ordinavi ecclesiis Galatiæ, ita et vos facite.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.16.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 16:2",
      "text": "Per unam sabbati unusquisque vestrum apud se seponat, recondens quod ei bene placuerit: ut non, cum venero, tunc collectæ fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 16:3",
      "text": "Cum autem præsens fuero, quos probaveritis per epistolas, hos mittam perferre gratiam vestram in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 16:4",
      "text": "Quod si dignum fuerit ut et ego eam, mecum ibunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 16:5",
      "text": "Veniam autem ad vos, cum Macedoniam pertransiero: nam Macedoniam pertransibo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 16:6",
      "text": "Apud vos autem forsitan manebo, vel etiam hiemabo: ut vos me deducatis quocumque iero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 16:7",
      "text": "Nolo enim vos modo in transitu videre, spero enim me aliquantulum temporis manere apud vos, si Dominus permiserit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 16:8",
      "text": "Permanebo autem Ephesi usque ad Pentecosten.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 16:9",
      "text": "Ostium enim mihi apertum est magnum, et evidens: et adversarii multi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 16:10",
      "text": "Si autem venerit Timotheus, videte ut sine timore sit apud vos: opus enim Domini operatur, sicut et ego.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 16:11",
      "text": "Ne quis ergo illum spernat: deducite autem illum in pace, ut veniat ad me: exspecto enim illum cum fratribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 16:12",
      "text": "De Apollo autem fratre vobis notum facio, quoniam multum rogavi eum ut veniret ad vos cum fratribus: et utique non fuit voluntas ut nunc veniret: veniet autem, cum ei vacuum fuerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 16:13",
      "text": "Vigilate, state in fide, viriliter agite, et confortamini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 16:14",
      "text": "Omnia vestra in caritate fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 16:15",
      "text": "Obsecro autem vos fratres, nostis domum Stephanæ, et Fortunati, et Achaici: quoniam sunt primitiæ Achaiæ, et in ministerium sanctorum ordinaverunt seipsos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 16:16",
      "text": "ut et vos subditi sitis ejusmodi, et omni cooperanti, et laboranti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 16:17",
      "text": "Gaudeo autem in præsentia Stephanæ, et Fortunati, et Achaici: quoniam id, quod vobis deerat, ipsi suppleverunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 16:18",
      "text": "refecerunt enim et meum spiritum, et vestrum. Cognoscite ergo qui hujusmodi sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 16:19",
      "text": "Salutant vos ecclesiæ Asiæ. Salutant vos in Domino multum, Aquila et Priscilla cum domestica sua ecclesia: apud quos et hospitor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 16:20",
      "text": "Salutant vos omnes fratres. Salutate invicem in osculo sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 16:21",
      "text": "Salutatio, mea manu Pauli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 16:22",
      "text": "Si quis non amat Dominum nostrum Jesum Christum, sit anathema, Maran Atha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 16:23",
      "text": "Gratia Domini nostri Jesu Christi vobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.16.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 16:24",
      "text": "Caritas mea cum omnibus vobis in Christo Jesu. Amen.",
      "paragraphStart": false
    }
  ]
}
