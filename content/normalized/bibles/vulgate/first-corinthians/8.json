{
  "chapter": {
    "id": "vulgate:first-corinthians.8",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 8,
    "referenceLabel": "1 Corinthians 8",
    "summary": "Source text for 1 Corinthians 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.8.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 8:1",
      "text": "De iis autem quæ idolis sacrificantur, scimus quia omnes scientiam habemus. Scientia inflat, caritas vero ædificat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.8.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 8:2",
      "text": "Si quis autem se existimat scire aliquid, nondum cognovit quemadmodum oporteat eum scire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 8:3",
      "text": "Si quis autem diligit Deum, hic cognitus est ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 8:4",
      "text": "De escis autem quæ idolis immolantur, scimus quia nihil est idolum in mundo, et quod nullus est Deus, nisi unus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 8:5",
      "text": "Nam etsi sunt qui dicantur dii sive in cælo, sive in terra (siquidem sunt dii multi, et domini multi):",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 8:6",
      "text": "nobis tamen unus est Deus, Pater, ex quo omnia, et nos in illum: et unus Dominus Jesus Christus, per quem omnia, et nos per ipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 8:7",
      "text": "Sed non in omnibus est scientia. Quidam autem cum conscientia usque nunc idoli, quasi idolothytum manducant: et conscientia ipsorum cum sit infirma, polluitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 8:8",
      "text": "Esca autem nos non commendat Deo. Neque enim si manducaverimus, abundabimus: neque si non manducaverimus, deficiemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 8:9",
      "text": "Videte autem ne forte hæc licentia vestra offendiculum fiat infirmis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 8:10",
      "text": "Si enim quis viderit eum, qui habet scientiam, in idolio recumbentem: nonne conscientia ejus, cum sit infirma, ædificabitur ad manducandum idolothyta?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 8:11",
      "text": "Et peribit infirmus in tua scientia, frater, propter quem Christus mortuus est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 8:12",
      "text": "Sic autem peccantes in fratres, et percutientes conscientiam eorum infirmam, in Christum peccatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.8.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 8:13",
      "text": "Quapropter si esca scandalizat fratrem meum, non manducabo carnem in æternum, ne fratrem meum scandalizem.",
      "paragraphStart": false
    }
  ]
}
