{
  "chapter": {
    "id": "vulgate:first-corinthians.13",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 13,
    "referenceLabel": "1 Corinthians 13",
    "summary": "Source text for 1 Corinthians 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.13.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 13:1",
      "text": "Si linguis hominum loquar, et angelorum, caritatem autem non habeam, factus sum velut æs sonans, aut cymbalum tinniens.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.13.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 13:2",
      "text": "Et si habuero prophetiam, et noverim mysteria omnia, et omnem scientiam: et si habuero omnem fidem ita ut montes transferam, caritatem autem non habuero, nihil sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 13:3",
      "text": "Et si distribuero in cibos pauperum omnes facultates meas, et si tradidero corpus meum ita ut ardeam, caritatem autem non habuero, nihil mihi prodest.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 13:4",
      "text": "Caritas patiens est, benigna est. Caritas non æmulatur, non agit perperam, non inflatur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 13:5",
      "text": "non est ambitiosa, non quærit quæ sua sunt, non irritatur, non cogitat malum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 13:6",
      "text": "non gaudet super iniquitate, congaudet autem veritati:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 13:7",
      "text": "omnia suffert, omnia credit, omnia sperat, omnia sustinet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 13:8",
      "text": "Caritas numquam excidit: sive prophetiæ evacuabuntur, sive linguæ cessabunt, sive scientia destruetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 13:9",
      "text": "Ex parte enim cognoscimus, et ex parte prophetamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 13:10",
      "text": "Cum autem venerit quod perfectum est, evacuabitur quod ex parte est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 13:11",
      "text": "Cum essem parvulus, loquebar ut parvulus, sapiebam ut parvulus, cogitabam ut parvulus. Quando autem factus sum vir, evacuavi quæ erant parvuli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 13:12",
      "text": "Videmus nunc per speculum in ænigmate: tunc autem facie ad faciem. Nunc cognosco ex parte: tunc autem cognoscam sicut et cognitus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.13.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 13:13",
      "text": "Nunc autem manent fides, spes, caritas, tria hæc: major autem horum est caritas.",
      "paragraphStart": false
    }
  ]
}
