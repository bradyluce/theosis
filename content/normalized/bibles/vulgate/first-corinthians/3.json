{
  "chapter": {
    "id": "vulgate:first-corinthians.3",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 3,
    "referenceLabel": "1 Corinthians 3",
    "summary": "Source text for 1 Corinthians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.3.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 3:1",
      "text": "Et ego, fratres, non potui vobis loqui quasi spiritualibus, sed quasi carnalibus. Tamquam parvulis in Christo,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.3.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 3:2",
      "text": "lac vobis potum dedi, non escam: nondum enim poteratis: sed nec nunc quidem potestis: adhuc enim carnales estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 3:3",
      "text": "Cum enim sit inter vos zelus, et contentio: nonne carnales estis, et secundum hominem ambulatis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 3:4",
      "text": "Cum enim quis dicat: Ego quidem sum Pauli; alius autem: Ego Apollo: nonne homines estis? Quid igitur est Apollo? quid vero Paulus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 3:5",
      "text": "ministri ejus, cui credidistis, et unicuique sicut Dominus dedit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 3:6",
      "text": "Ego plantavi, Apollo rigavit: sed Deus incrementum dedit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 3:7",
      "text": "Itaque neque qui plantat est aliquid, neque qui rigat: sed qui incrementum dat, Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 3:8",
      "text": "Qui autem plantat, et qui rigat, unum sunt. Unusquisque autem propriam mercedem accipiet, secundum suum laborem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 3:9",
      "text": "Dei enim sumus adjutores: Dei agricultura estis, Dei ædificatio estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 3:10",
      "text": "Secundum gratiam Dei, quæ data est mihi, ut sapiens architectus fundamentum posui: alius autem superædificat. Unusquisque autem videat quomodo superædificet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 3:11",
      "text": "Fundamentum enim aliud nemo potest ponere præter id quod positum est, quod est Christus Jesus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 3:12",
      "text": "Si quis autem superædificat super fundamentum hoc, aurum, argentum, lapides pretiosos, ligna, fœnum, stipulam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 3:13",
      "text": "uniuscujusque opus manifestum erit: dies enim Domini declarabit, quia in igne revelabitur: et uniuscujusque opus quale sit, ignis probabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 3:14",
      "text": "Si cujus opus manserit quod superædificavit, mercedem accipiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 3:15",
      "text": "Si cujus opus arserit, detrimentum patietur: ipse autem salvus erit, sic tamen quasi per ignem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 3:16",
      "text": "Nescitis quia templum Dei estis, et Spiritus Dei habitat in vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 3:17",
      "text": "Si quis autem templum Dei violaverit, disperdet illum Deus. Templum enim Dei sanctum est, quod estis vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 3:18",
      "text": "Nemo se seducat: si quis videtur inter vos sapiens esse in hoc sæculo, stultus fiat ut sit sapiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 3:19",
      "text": "Sapientia enim hujus mundi, stultitia est apud Deum. Scriptum est enim: Comprehendam sapientes in astutia eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 3:20",
      "text": "Et iterum: Dominus novit cogitationes sapientium quoniam vanæ sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 3:21",
      "text": "Nemo itaque glorietur in hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 3:22",
      "text": "Omnia enim vestra sunt, sive Paulus, sive Apollo, sive Cephas, sive mundus, sive vita, sive mors, sive præsentia, sive futura: omnia enim vestra sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.3.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 3:23",
      "text": "vos autem Christi: Christus autem Dei.",
      "paragraphStart": false
    }
  ]
}
