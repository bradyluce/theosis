{
  "chapter": {
    "id": "vulgate:first-corinthians.7",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 7,
    "referenceLabel": "1 Corinthians 7",
    "summary": "Source text for 1 Corinthians 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.7.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 7:1",
      "text": "De quibus autem scripsistis mihi: Bonum est homini mulierem non tangere:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.7.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 7:2",
      "text": "propter fornicationem autem unusquisque suam uxorem habeat, et unaquæque suum virum habeat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 7:3",
      "text": "Uxori vir debitum reddat: similiter autem et uxor viro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 7:4",
      "text": "Mulier sui corporis potestatem non habet, sed vir. Similiter autem et vir sui corporis potestatem non habet, sed mulier.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 7:5",
      "text": "Nolite fraudare invicem, nisi forte ex consensu ad tempus, ut vacetis orationi: et iterum revertimini in idipsum, ne tentet vos Satanas propter incontinentiam vestram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 7:6",
      "text": "Hoc autem dico secundum indulgentiam, non secundum imperium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 7:7",
      "text": "Volo enim omnes vos esse sicut meipsum: sed unusquisque proprium donum habet ex Deo: alius quidem sic, alius vero sic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 7:8",
      "text": "Dico autem non nuptis, et viduis: bonum est illis si sic permaneant, sicut et ego.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 7:9",
      "text": "Quod si non se continent, nubant. Melius est enim nubere, quam uri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 7:10",
      "text": "Iis autem qui matrimonio juncti sunt, præcipio non ego, sed Dominus, uxorem a viro non discedere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 7:11",
      "text": "quod si discesserit, manere innuptam, aut viro suo reconciliari. Et vir uxorem non dimittat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 7:12",
      "text": "Nam ceteris ego dico, non Dominus. Si quis frater uxorem habet infidelem, et hæc consentit habitare cum illo, non dimittat illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 7:13",
      "text": "Et si qua mulier fidelis habet virum infidelem, et hic consentit habitare cum illa, non dimittat virum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 7:14",
      "text": "sanctificatus est enim vir infidelis per mulierem fidelem, et sanctificata est mulier infidelis per virum fidelem: alioquin filii vestri immundi essent, nunc autem sancti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 7:15",
      "text": "Quod si infidelis discedit, discedat: non enim servituti subjectus est frater, aut soror in hujusmodi: in pace autem vocavit nos Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 7:16",
      "text": "Unde enim scis mulier, si virum salvum facies? aut unde scis vir, si mulierem salvam facies?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 7:17",
      "text": "Nisi unicuique sicut divisit Dominus, unumquemque sicut vocavit Deus, ita ambulet, et sicut in omnibus ecclesiis doceo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 7:18",
      "text": "Circumcisus aliquis vocatus est? non adducat præputium. In præputio aliquis vocatus est? non circumcidatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 7:19",
      "text": "Circumcisio nihil est, et præputium nihil est: sed observatio mandatorum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 7:20",
      "text": "Unusquisque in qua vocatione vocatus est, in ea permaneat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 7:21",
      "text": "Servus vocatus es? non sit tibi curæ: sed et si potes fieri liber, magis utere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 7:22",
      "text": "Qui enim in Domino vocatus est servus, libertus est Domini: similiter qui liber vocatus est, servus est Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 7:23",
      "text": "Pretio empti estis: nolite fieri servi hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 7:24",
      "text": "Unusquisque in quo vocatus est, fratres, in hoc permaneat apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 7:25",
      "text": "De virginibus autem præceptum Domini non habeo: consilium autem do, tamquam misericordiam consecutus a Domino, ut sim fidelis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 7:26",
      "text": "Existimo ergo hoc bonum esse propter instantem necessitatem, quoniam bonum est homini sic esse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 7:27",
      "text": "Alligatus es uxori? noli quærere solutionem. Solutus es ab uxore? noli quærere uxorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 7:28",
      "text": "Si autem acceperis uxorem, non peccasti. Et si nupserit virgo, non peccavit: tribulationem tamen carnis habebunt hujusmodi. Ego autem vobis parco.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 7:29",
      "text": "Hoc itaque dico, fratres: tempus breve est: reliquum est, ut et qui habent uxores, tamquam non habentes sint:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 7:30",
      "text": "et qui flent, tamquam non flentes: et qui gaudent, tamquam non gaudentes: et qui emunt, tamquam non possidentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 7:31",
      "text": "et qui utuntur hoc mundo, tamquam non utantur: præterit enim figura hujus mundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.32",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 7:32",
      "text": "Volo autem vos sine sollicitudine esse. Qui sine uxore est, sollicitus est quæ Domini sunt, quomodo placeat Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.33",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 7:33",
      "text": "Qui autem cum uxore est, sollicitus est quæ sunt mundi, quomodo placeat uxori, et divisus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.34",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 7:34",
      "text": "Et mulier innupta, et virgo, cogitat quæ Domini sunt, ut sit sancta corpore, et spiritu. Quæ autem nupta est, cogitat quæ sunt mundi, quomodo placeat viro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.35",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "1 Corinthians 7:35",
      "text": "Porro hoc ad utilitatem vestram dico: non ut laqueum vobis injiciam, sed ad id, quod honestum est, et quod facultatem præbeat sine impedimento Dominum obsecrandi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.36",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "1 Corinthians 7:36",
      "text": "Si quis autem turpem se videri existimat super virgine sua, quod sit superadulta, et ita oportet fieri: quod vult faciat: non peccat, si nubat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.37",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "1 Corinthians 7:37",
      "text": "Nam qui statuit in corde suo firmus, non habens necessitatem, potestatem autem habens suæ voluntatis, et hoc judicavit in corde suo, servare virginem suam, bene facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.38",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "1 Corinthians 7:38",
      "text": "Igitur et qui matrimonio jungit virginem suam, bene facit: et qui non jungit, melius facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.39",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "1 Corinthians 7:39",
      "text": "Mulier alligata est legi quanto tempore vir ejus vivit, quod si dormierit vir ejus, liberata est: cui vult nubat, tantum in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.7.40",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "1 Corinthians 7:40",
      "text": "Beatior autem erit si sic permanserit secundum meum consilium: puto autem quod et ego Spiritum Dei habeam.",
      "paragraphStart": false
    }
  ]
}
