{
  "chapter": {
    "id": "vulgate:first-corinthians.14",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 14,
    "referenceLabel": "1 Corinthians 14",
    "summary": "Source text for 1 Corinthians 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.14.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 14:1",
      "text": "Sectamini caritatem, æmulamini spiritualia: magis autem ut prophetetis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.14.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 14:2",
      "text": "Qui enim loquitur lingua, non hominibus loquitur, sed Deo: nemo enim audit. Spiritu autem loquitur mysteria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 14:3",
      "text": "Nam qui prophetat, hominibus loquitur ad ædificationem, et exhortationem, et consolationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 14:4",
      "text": "Qui loquitur lingua, semetipsum ædificat: qui autem prophetat, ecclesiam Dei ædificat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 14:5",
      "text": "Volo autem omnes vos loqui linguis: magis autem prophetare. Nam major est qui prophetat, quam qui loquitur linguis; nisi forte interpretetur ut ecclesia ædificationem accipiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 14:6",
      "text": "Nunc autem, fratres, si venero ad vos linguis loquens: quid vobis prodero, nisi vobis loquar aut in revelatione, aut in scientia, aut in prophetia, aut in doctrina?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 14:7",
      "text": "Tamen quæ sine anima sunt vocem dantia, sive tibia, sive cithara; nisi distinctionem sonituum dederint, quomodo scietur id quod canitur, aut quod citharizatur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 14:8",
      "text": "Etenim si incertam vocem det tuba, quis parabit se ad bellum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 14:9",
      "text": "Ita et vos per linguam nisi manifestum sermonem dederitis: quomodo scietur id quod dicitur? eritis enim in aëra loquentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 14:10",
      "text": "Tam multa, ut puta genera linguarum sunt in hoc mundo: et nihil sine voce est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 14:11",
      "text": "Si ergo nesciero virtutem vocis, ero ei, cui loquor, barbarus: et qui loquitur, mihi barbarus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 14:12",
      "text": "Sic et vos, quoniam æmulatores estis spirituum, ad ædificationem ecclesiæ quærite ut abundetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 14:13",
      "text": "Et ideo qui loquitur lingua, oret ut interpretetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 14:14",
      "text": "Nam si orem lingua, spiritus meus orat, mens autem mea sine fructu est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 14:15",
      "text": "Quid ergo est? Orabo spiritu, orabo et mente: psallam spiritu, psallam et mente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 14:16",
      "text": "Ceterum si benedixeris spiritu, qui supplet locum idiotæ, quomodo dicet: Amen, super tuam benedictionem? quoniam quid dicas, nescit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 14:17",
      "text": "Nam tu quidem bene gratias agis, sed alter non ædificatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 14:18",
      "text": "Gratias ago Deo meo, quod omnium vestrum lingua loquor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 14:19",
      "text": "Sed in ecclesia volo quinque verba sensu meo loqui, ut et alios instruam: quam decem millia verborum in lingua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 14:20",
      "text": "Fratres, nolite pueri effici sensibus, sed malitia parvuli estote: sensibus autem perfecti estote.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 14:21",
      "text": "In lege scriptum est: Quoniam in aliis linguis et labiis aliis loquar populo huic: et nec sic exaudient me, dicit Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 14:22",
      "text": "Itaque linguæ in signum sunt non fidelibus, sed infidelibus: prophetiæ autem non infidelibus, sed fidelibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 14:23",
      "text": "Si ergo conveniat universa ecclesia in unum, et omnes linguis loquantur, intrent autem idiotæ, aut infideles: nonne dicent quod insanitis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 14:24",
      "text": "Si autem omnes prophetent, intret autem quis infidelis, vel idiota, convincitur ab omnibus, dijudicatur ab omnibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 14:25",
      "text": "occulta cordis ejus manifesta fiunt: et ita cadens in faciem adorabit Deum, pronuntians quod vere Deus in vobis sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 14:26",
      "text": "Quid ergo est, fratres? Cum convenitis, unusquisque vestrum psalmum habet, doctrinam habet, apocalypsim habet, linguam habet, interpretationem habet: omnia ad ædificationem fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 14:27",
      "text": "Sive lingua quis loquitur, secundum duos, aut ut multum tres, et per partes, et unus interpretatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 14:28",
      "text": "Si autem non fuerit interpres, taceat in ecclesia: sibi autem loquatur, et Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 14:29",
      "text": "Prophetæ autem duo, aut tres dicant, et ceteri dijudicent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 14:30",
      "text": "Quod si alii revelatum fuerit sedenti, prior taceat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 14:31",
      "text": "Potestis enim omnes per singulos prophetare: ut omnes discant, et omnes exhortentur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.32",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 14:32",
      "text": "et spiritus prophetarum prophetis subjecti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.33",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 14:33",
      "text": "Non enim est dissensionis Deus, sed pacis: sicut et in omnibus ecclesiis sanctorum doceo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.34",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 14:34",
      "text": "Mulieres in ecclesiis taceant, non enim permittitur eis loqui, sed subditas esse, sicut et lex dicit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.35",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "1 Corinthians 14:35",
      "text": "Si quid autem volunt discere, domi viros suos interrogent. Turpe est enim mulieri loqui in ecclesia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.36",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "1 Corinthians 14:36",
      "text": "An a vobis verbum Dei processit? aut in vos solos pervenit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.37",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 37,
      "referenceLabel": "1 Corinthians 14:37",
      "text": "Si quis videtur propheta esse, aut spiritualis, cognoscat quæ scribo vobis, quia Domini sunt mandata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.38",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 38,
      "referenceLabel": "1 Corinthians 14:38",
      "text": "Si quis autem ignorat, ignorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.39",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 39,
      "referenceLabel": "1 Corinthians 14:39",
      "text": "Itaque fratres æmulamini prophetare: et loqui linguis nolite prohibere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.14.40",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 40,
      "referenceLabel": "1 Corinthians 14:40",
      "text": "Omnia autem honeste, et secundum ordinem fiant.",
      "paragraphStart": false
    }
  ]
}
