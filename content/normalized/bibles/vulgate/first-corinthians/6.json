{
  "chapter": {
    "id": "vulgate:first-corinthians.6",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 6,
    "referenceLabel": "1 Corinthians 6",
    "summary": "Source text for 1 Corinthians 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.6.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 6:1",
      "text": "Audet aliquis vestrum habens negotium adversus alterum, judicari apud iniquos, et non apud sanctos?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.6.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 6:2",
      "text": "an nescitis quoniam sancti de hoc mundo judicabunt? et si in vobis judicabitur mundus, indigni estis qui de minimis judicetis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 6:3",
      "text": "Nescitis quoniam angelos judicabimus? quanto magis sæcularia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 6:4",
      "text": "Sæcularia igitur judicia si habueritis: contemptibiles, qui sunt in ecclesia, illos constituite ad judicandum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 6:5",
      "text": "Ad verecundiam vestram dico. Sic non est inter vos sapiens quisquam, qui possit judicare inter fratrem suum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 6:6",
      "text": "Sed frater cum fratre judicio contendit: et hoc apud infideles?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 6:7",
      "text": "Jam quidem omnino delictum est in vobis, quod judicia habetis inter vos. Quare non magis injuriam accipitis? quare non magis fraudem patimini?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 6:8",
      "text": "Sed vos injuriam facitis, et fraudatis: et hoc fratribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 6:9",
      "text": "An nescitis quia iniqui regnum Dei non possidebunt? Nolite errare: neque fornicarii, neque idolis servientes, neque adulteri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 6:10",
      "text": "neque molles, neque masculorum concubitores, neque fures, neque avari, neque ebriosi, neque maledici, neque rapaces regnum Dei possidebunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 6:11",
      "text": "Et hæc quidam fuistis: sed abluti estis, sed sanctificati estis, sed justificati estis in nomine Domini nostri Jesu Christi, et in Spiritu Dei nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 6:12",
      "text": "Omnia mihi licent, sed non omnia expediunt: omnia mihi licent, sed ego sub nullis redigar potestate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 6:13",
      "text": "Esca ventri, et venter escis: Deus autem et hunc et has destruet: corpus autem non fornicationi, sed Domino: et Dominus corpori.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 6:14",
      "text": "Deus vero et Dominum suscitavit: et nos suscitabit per virtutem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 6:15",
      "text": "Nescitis quoniam corpora vestra membra sunt Christi? Tollens ergo membra Christi, faciam membra meretricis? Absit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 6:16",
      "text": "An nescitis quoniam qui adhæret meretrici, unum corpus efficitur? Erunt enim (inquit) duo in carne una.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 6:17",
      "text": "Qui autem adhæret Domino, unus spiritus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 6:18",
      "text": "Fugite fornicationem. Omne peccatum, quodcumque fecerit homo, extra corpus est: qui autem fornicatur, in corpus suum peccat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 6:19",
      "text": "An nescitis quoniam membra vestra, templum sunt Spiritus Sancti, qui in vobis est, quem habetis a Deo, et non estis vestri?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.6.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 6:20",
      "text": "Empti enim estis pretio magno. Glorificate, et portate Deum in corpore vestro.",
      "paragraphStart": false
    }
  ]
}
