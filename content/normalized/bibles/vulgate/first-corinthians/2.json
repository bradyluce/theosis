{
  "chapter": {
    "id": "vulgate:first-corinthians.2",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 2,
    "referenceLabel": "1 Corinthians 2",
    "summary": "Source text for 1 Corinthians 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.2.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 2:1",
      "text": "Et ego, cum venissem ad vos, fratres, veni non in sublimitate sermonis, aut sapientiæ, annuntians vobis testimonium Christi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.2.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 2:2",
      "text": "Non enim judicavi me scire aliquid inter vos, nisi Jesum Christum, et hunc crucifixum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 2:3",
      "text": "Et ego in infirmitate, et timore, et tremore multo fui apud vos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 2:4",
      "text": "et sermo meus, et prædicatio mea non in persuasibilibus humanæ sapientiæ verbis, sed in ostensione spiritus et virtutis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 2:5",
      "text": "ut fides vestra non sit in sapientia hominum, sed in virtute Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 2:6",
      "text": "Sapientiam autem loquimur inter perfectos: sapientiam vero non hujus sæculi, neque principum hujus sæculi, qui destruuntur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 2:7",
      "text": "sed loquimur Dei sapientiam in mysterio, quæ abscondita est, quam prædestinavit Deus ante sæcula in gloriam nostram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 2:8",
      "text": "quam nemo principum hujus sæculi cognovit: si enim cognovissent, numquam Dominum gloriæ crucifixissent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 2:9",
      "text": "Sed sicut scriptum est: Quod oculus non vidit, nec auris audivit, nec in cor hominis ascendit, quæ præparavit Deus iis qui diligunt illum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 2:10",
      "text": "nobis autem revelavit Deus per Spiritum suum: Spiritus enim omnia scrutatur, etiam profunda Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 2:11",
      "text": "Quis enim hominum scit quæ sunt hominis, nisi spiritus hominis, qui in ipso est? ita et quæ Dei sunt, nemo cognovit, nisi Spiritus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 2:12",
      "text": "Nos autem non spiritum hujus mundi accepimus, sed Spiritum qui ex Deo est, ut sciamus quæ a Deo donata sunt nobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 2:13",
      "text": "quæ et loquimur non in doctis humanæ sapientiæ verbis, sed in doctrina Spiritus, spiritualibus spiritualia comparantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 2:14",
      "text": "Animalis autem homo non percipit ea quæ sunt Spiritus Dei: stultitia enim est illi, et non potest intelligere: quia spiritualiter examinatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 2:15",
      "text": "Spiritualis autem judicat omnia: et ipse a nemine judicatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.2.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 2:16",
      "text": "Quis enim cognovit sensum Domini, qui instruat eum? nos autem sensum Christi habemus.",
      "paragraphStart": false
    }
  ]
}
