{
  "chapter": {
    "id": "vulgate:first-corinthians.11",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 11,
    "referenceLabel": "1 Corinthians 11",
    "summary": "Source text for 1 Corinthians 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.11.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 11:1",
      "text": "Imitatores mei estote, sicut et ego Christi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.11.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 11:2",
      "text": "Laudo autem vos fratres quod per omnia mei memores estis: et sicut tradidi vobis, præcepta mea tenetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 11:3",
      "text": "Volo autem vos scire quod omnis viri caput, Christus est: caput autem mulieris, vir: caput vero Christi, Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 11:4",
      "text": "Omnis vir orans, aut prophetans velato capite, deturpat caput suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 11:5",
      "text": "Omnis autem mulier orans, aut prophetans non velato capite, deturpat caput suum: unum enim est ac si decalvetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 11:6",
      "text": "Nam si non velatur mulier, tondeatur. Si vero turpe est mulieri tonderi, aut decalvari, velet caput suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 11:7",
      "text": "Vir quidem non debet velare caput suum: quoniam imago et gloria Dei est, mulier autem gloria viri est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 11:8",
      "text": "Non enim vir ex muliere est, sed mulier ex viro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 11:9",
      "text": "Etenim non est creatus vir propter mulierem, sed mulier propter virum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 11:10",
      "text": "Ideo debet mulier potestatem habere supra caput propter angelos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 11:11",
      "text": "Verumtamen neque vir sine muliere: neque mulier sine viro in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 11:12",
      "text": "Nam sicut mulier de viro, ita et vir per mulierem: omnia autem ex Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 11:13",
      "text": "Vos ipsi judicate: decet mulierem non velatam orare Deum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 11:14",
      "text": "Nec ipsa natura docet vos, quod vir quidem si comam nutriat, ignominia est illi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 11:15",
      "text": "mulier vero si comam nutriat, gloria est illi: quoniam capilli pro velamine ei dati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 11:16",
      "text": "Si quis autem videtur contentiosus esse: nos talem consuetudinem non habemus, neque ecclesia Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 11:17",
      "text": "Hoc autem præcipio: non laudans quod non in melius, sed in deterius convenitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 11:18",
      "text": "Primum quidem convenientibus vobis in ecclesiam, audio scissuras esse inter vos, et ex parte credo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 11:19",
      "text": "Nam oportet et hæreses esse, ut et qui probati sunt, manifesti fiant in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 11:20",
      "text": "Convenientibus ergo vobis in unum, jam non est Dominicam cœnam manducare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 11:21",
      "text": "Unusquisque enim suam cœnam præsumit ad manducandum, et alius quidem esurit, alius autem ebrius est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 11:22",
      "text": "Numquid domos non habetis ad manducandum, et bibendum? aut ecclesiam Dei contemnitis, et confunditis eos qui non habent? Quid dicam vobis? laudo vos? in hoc non laudo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 11:23",
      "text": "Ego enim accepi a Domino quod et tradidi vobis, quoniam Dominus Jesus in qua nocte tradebatur, accepit panem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 11:24",
      "text": "et gratias agens fregit, et dixit: Accipite, et manducate: hoc est corpus meum, quod pro vobis tradetur: hoc facite in meam commemorationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 11:25",
      "text": "Similiter et calicem, postquam cœnavit, dicens: Hic calix novum testamentum est in meo sanguine: hoc facite quotiescumque bibetis, in meam commemorationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 11:26",
      "text": "Quotiescumque enim manducabitis panem hunc, et calicem bibetis, mortem Domini annuntiabitis donec veniat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 11:27",
      "text": "Itaque quicumque manducaverit panem hunc, vel biberit calicem Domini indigne, reus erit corporis et sanguinis Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 11:28",
      "text": "Probet autem seipsum homo: et sic de pane illo edat, et de calice bibat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 11:29",
      "text": "Qui enim manducat et bibit indigne, judicium sibi manducat et bibit, non dijudicans corpus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 11:30",
      "text": "Ideo inter vos multi infirmi et imbecilles, et dormiunt multi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 11:31",
      "text": "Quod si nosmetipsos dijudicaremus, non utique judicaremur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.32",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 11:32",
      "text": "Dum judicamur autem, a Domino corripimur, ut non cum hoc mundo damnemur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.33",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 11:33",
      "text": "Itaque fratres mei, cum convenitis ad manducandum, invicem exspectate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.11.34",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 11:34",
      "text": "Si quis esurit, domi manducet, ut non in judicium conveniatis. Cetera autem, cum venero, disponam.",
      "paragraphStart": false
    }
  ]
}
