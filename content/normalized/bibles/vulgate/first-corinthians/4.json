{
  "chapter": {
    "id": "vulgate:first-corinthians.4",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 4,
    "referenceLabel": "1 Corinthians 4",
    "summary": "Source text for 1 Corinthians 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.4.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 4:1",
      "text": "Sic nos existimet homo ut ministros Christi, et dispensatores mysteriorum Dei.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.4.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 4:2",
      "text": "Hic jam quæritur inter dispensatores ut fidelis quis inveniatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 4:3",
      "text": "Mihi autem pro minimo est ut a vobis judicer, aut ab humano die: sed neque meipsum judico.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 4:4",
      "text": "Nihil enim mihi conscius sum, sed non in hoc justificatus sum: qui autem judicat me, Dominus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 4:5",
      "text": "Itaque nolite ante tempus judicare, quoadusque veniat Dominus: qui et illuminabit abscondita tenebrarum, et manifestabit consilia cordium: et tunc laus erit unicuique a Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 4:6",
      "text": "Hæc autem, fratres, transfiguravi in me et Apollo, propter vos: ut in nobis discatis, ne supra quam scriptum est, unus adversus alterum infletur pro alio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 4:7",
      "text": "Quis enim te discernit? quid autem habes quod non accepisti? si autem accepisti, quid gloriaris quasi non acceperis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 4:8",
      "text": "Jam saturati estis, jam divites facti estis: sine nobis regnatis: et utinam regnetis, ut et nos vobiscum regnemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 4:9",
      "text": "Puto enim quod Deus nos Apostolos novissimos ostendit, tamquam morti destinatos: quia spectaculum facti sumus mundo, et angelis, et hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 4:10",
      "text": "Nos stulti propter Christum, vos autem prudentes in Christo: nos infirmi, vos autem fortes: vos nobiles, nos autem ignobiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 4:11",
      "text": "Usque in hanc horam et esurimus, et sitimus, et nudi sumus, et colaphis cædimur, et instabiles sumus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 4:12",
      "text": "et laboramus operantes manibus nostris: maledicimur, et benedicimus: persecutionem patimur, et sustinemus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 4:13",
      "text": "blasphemamur, et obsecramus: tamquam purgamenta hujus mundi facti sumus, omnium peripsema usque adhuc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 4:14",
      "text": "Non ut confundam vos, hæc scribo, sed ut filios meos carissimos moneo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 4:15",
      "text": "Nam si decem millia pædagogorum habeatis in Christo, sed non multos patres. Nam in Christo Jesu per Evangelium ego vos genui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 4:16",
      "text": "Rogo ergo vos, imitatores mei estote, sicut et ego Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 4:17",
      "text": "Ideo misi ad vos Timotheum, qui est filius meus carissimus, et fidelis in Domino: qui vos commonefaciet vias meas, quæ sunt in Christo Jesu, sicut ubique in omni ecclesia doceo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 4:18",
      "text": "Tamquam non venturus sim ad vos, sic inflati sunt quidam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 4:19",
      "text": "Veniam autem ad vos cito, si Dominus voluerit: et cognoscam non sermonem eorum qui inflati sunt, sed virtutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 4:20",
      "text": "Non enim in sermone est regnum Dei, sed in virtute.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.4.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 4:21",
      "text": "Quid vultis? in virga veniam ad vos, an in caritate, et spiritu mansuetudinis?",
      "paragraphStart": false
    }
  ]
}
