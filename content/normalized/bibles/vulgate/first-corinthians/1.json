{
  "chapter": {
    "id": "vulgate:first-corinthians.1",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 1,
    "referenceLabel": "1 Corinthians 1",
    "summary": "Source text for 1 Corinthians 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.1.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 1:1",
      "text": "Paulus vocatus Apostolus Jesu Christi per voluntatem Dei, et Sosthenes frater,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.1.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 1:2",
      "text": "ecclesiæ Dei, quæ est Corinthi, sanctificatis in Christo Jesu, vocatis sanctis, cum omnibus qui invocant nomen Domini nostri Jesu Christi, in omni loco ipsorum et nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 1:3",
      "text": "Gratia vobis, et pax a Deo Patre nostro, et Domino Jesu Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 1:4",
      "text": "Gratias ago Deo meo semper pro vobis in gratia Dei, quæ data est vobis in Christo Jesu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 1:5",
      "text": "quod in omnibus divites facti estis in illo, in omni verbo, et in omni scientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 1:6",
      "text": "Sicut testimonium Christi confirmatum est in vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 1:7",
      "text": "ita ut nihil vobis desit in ulla gratia, exspectantibus revelationem Domini nostri Jesu Christi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 1:8",
      "text": "qui et confirmabit vos usque in finem sine crimine, in die adventus Domini nostri Jesu Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 1:9",
      "text": "Fidelis Deus: per quem vocati estis in societatem filii ejus Jesu Christi Domini nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 1:10",
      "text": "Obsecro autem vos fratres per nomen Domini nostri Jesu Christi: ut idipsum dicatis omnes, et non sint in vobis schismata: sitis autem perfecti in eodem sensu, et in eadem sententia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 1:11",
      "text": "Significatum est enim mihi de vobis fratres mei ab iis, qui sunt Chloës, quia contentiones sunt inter vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 1:12",
      "text": "Hoc autem dico, quod unusquisque vestrum dicit: Ego quidem sum Pauli: ego autem Apollo: ego vero Cephæ: ego autem Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 1:13",
      "text": "Divisus est Christus? numquid Paulus crucifixus est pro vobis? aut in nomine Pauli baptizati estis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.14",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 1:14",
      "text": "Gratias ago Deo, quod neminem vestrum baptizavi, nisi Crispum et Caium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.15",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 1:15",
      "text": "ne quis dicat quod in nomine meo baptizati estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.16",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 1:16",
      "text": "Baptizavi autem et Stephanæ domum: ceterum nescio si quem alium baptizaverim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.17",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 1:17",
      "text": "Non enim misit me Christus baptizare, sed evangelizare: non in sapientia verbi, ut non evacuetur crux Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.18",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 1:18",
      "text": "Verbum enim crucis pereuntibus quidem stultitia est: iis autem qui salvi fiunt, id est nobis, Dei virtus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.19",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 1:19",
      "text": "Scriptum est enim: Perdam sapientiam sapientium, et prudentiam prudentium reprobabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.20",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 1:20",
      "text": "Ubi sapiens? ubi scriba? ubi conquisitor hujus sæculi? Nonne stultam fecit Deus sapientiam hujus mundi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.21",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 1:21",
      "text": "Nam quia in Dei sapientia non cognovit mundus per sapientiam Deum: placuit Deo per stultitiam prædicationis salvos facere credentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.22",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 1:22",
      "text": "Quoniam et Judæi signa petunt, et Græci sapientiam quærunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.23",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 1:23",
      "text": "nos autem prædicamus Christum crucifixum: Judæis quidem scandalum, gentibus autem stultitiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.24",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 1:24",
      "text": "ipsis autem vocatis Judæis, atque Græcis Christum Dei virtutem, et Dei sapientiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.25",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 1:25",
      "text": "quia quod stultum est Dei, sapientius est hominibus: et quod infirmum est Dei, fortius est hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.26",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 1:26",
      "text": "Videte enim vocationem vestram, fratres, quia non multi sapientes secundum carnem, non multi potentes, non multi nobiles:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.27",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 1:27",
      "text": "sed quæ stulta sunt mundi elegit Deus, ut confundat sapientes: et infirma mundi elegit Deus, ut confundat fortia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.28",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 1:28",
      "text": "et ignobilia mundi, et contemptibilia elegit Deus, et ea quæ non sunt, ut ea quæ sunt destrueret:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.29",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 1:29",
      "text": "ut non glorietur omnis caro in conspectu ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.30",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 1:30",
      "text": "Ex ipso autem vos estis in Christo Jesu, qui factus est nobis sapientia a Deo, et justitia, et sanctificatio, et redemptio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.1.31",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 1:31",
      "text": "ut quemadmodum scriptum est: Qui gloriatur, in Domino glorietur.",
      "paragraphStart": false
    }
  ]
}
