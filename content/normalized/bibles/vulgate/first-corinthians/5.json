{
  "chapter": {
    "id": "vulgate:first-corinthians.5",
    "translationId": "vulgate",
    "bookSlug": "first-corinthians",
    "chapterNumber": 5,
    "referenceLabel": "1 Corinthians 5",
    "summary": "Source text for 1 Corinthians 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-corinthians.5.1",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 5:1",
      "text": "Omnino auditur inter vos fornicatio, et talis fornicatio, qualis nec inter gentes, ita ut uxorem patris sui aliquis habeat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-corinthians.5.2",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 5:2",
      "text": "Et vos inflati estis: et non magis luctum habuistis ut tollatur de medio vestrum qui hoc opus fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.3",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 5:3",
      "text": "Ego quidem absens corpore, præsens autem spiritu, jam judicavi ut præsens eum, qui sic operatus est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.4",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 5:4",
      "text": "in nomine Domini nostri Jesu Christi, congregatis vobis et meo spiritu, cum virtute Domini nostri Jesu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.5",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 5:5",
      "text": "tradere hujusmodi Satanæ in interitum carnis, ut spiritus salvus sit in die Domini nostri Jesu Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.6",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 5:6",
      "text": "Non est bona gloriatio vestra. Nescitis quia modicum fermentum totam massam corrumpit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.7",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 5:7",
      "text": "Expurgate vetus fermentum, ut sitis nova conspersio, sicut estis azymi. Etenim Pascha nostrum immolatus est Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.8",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 5:8",
      "text": "Itaque epulemur: non in fermento veteri, neque in fermento malitiæ et nequitiæ: sed in azymis sinceritatis et veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.9",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 5:9",
      "text": "Scripsi in epistola: Ne commisceamini fornicariis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.10",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 5:10",
      "text": "non utique fornicariis hujus mundi, aut avaris, aut rapacibus, aut idolis servientibus: alioquin debueratis de hoc mundo exiisse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.11",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 5:11",
      "text": "Nunc autem scripsi vobis non commisceri: si is qui frater nominatur, est fornicator, aut avarus, aut idolis serviens, aut maledicus, aut ebriosus, aut rapax, cum ejusmodi nec cibum sumere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.12",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 5:12",
      "text": "Quid enim mihi de iis qui foris sunt, judicare? nonne de iis qui intus sunt, vos judicatis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-corinthians.5.13",
      "translationId": "vulgate",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 5:13",
      "text": "nam eos qui foris sunt, Deus judicabit. Auferte malum ex vobis ipsis.",
      "paragraphStart": false
    }
  ]
}
