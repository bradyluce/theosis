{
  "chapter": {
    "id": "vulgate:matthew.24",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 24,
    "referenceLabel": "Matthew 24",
    "summary": "Source text for Matthew 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.24.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Matthew 24:1",
      "text": "Et egressus Jesus de templo, ibat. Et accesserunt discipuli ejus, ut ostenderent ei ædificationes templi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.24.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Matthew 24:2",
      "text": "Ipse autem respondens dixit illis: Videtis hæc omnia? amen dico vobis, non relinquetur hic lapis super lapidem, qui non destruatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Matthew 24:3",
      "text": "Sedente autem eo super montem Oliveti, accesserunt ad eum discipuli secreto, dicentes: Dic nobis, quando hæc erunt? et quod signum adventus tui, et consummationis sæculi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Matthew 24:4",
      "text": "Et respondens Jesus, dixit eis: Videte ne quis vos seducat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Matthew 24:5",
      "text": "multi enim venient in nomine meo, dicentes: Ego sum Christus: et multos seducent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Matthew 24:6",
      "text": "Audituri enim estis prælia, et opiniones præliorum. Videte ne turbemini: oportet enim hæc fieri, sed nondum est finis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Matthew 24:7",
      "text": "consurget enim gens in gentem, et regnum in regnum, et erunt pestilentiæ, et fames, et terræmotus per loca:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Matthew 24:8",
      "text": "hæc autem omnia initia sunt dolorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Matthew 24:9",
      "text": "Tunc tradent vos in tribulationem, et occident vos: et eritis odio omnibus gentibus propter nomen meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Matthew 24:10",
      "text": "Et tunc scandalizabuntur multi, et invicem tradent, et odio habebunt invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Matthew 24:11",
      "text": "Et multi pseudoprophetæ surgent, et seducent multos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Matthew 24:12",
      "text": "Et quoniam abundavit iniquitas, refrigescet caritas multorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Matthew 24:13",
      "text": "qui autem perseveraverit usque in finem, hic salvus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Matthew 24:14",
      "text": "Et prædicabitur hoc Evangelium regni in universo orbe, in testimonium omnibus gentibus: et tunc veniet consummatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Matthew 24:15",
      "text": "Cum ergo videritis abominationem desolationis, quæ dicta est a Daniele propheta, stantem in loco sancto, qui legit, intelligat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Matthew 24:16",
      "text": "tunc qui in Judæa sunt, fugiant ad montes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Matthew 24:17",
      "text": "et qui in tecto, non descendat tollere aliquid de domo sua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Matthew 24:18",
      "text": "et qui in agro, non revertatur tollere tunicam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Matthew 24:19",
      "text": "Væ autem prægnantibus et nutrientibus in illis diebus!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Matthew 24:20",
      "text": "Orate autem ut non fiat fuga vestra in hieme, vel sabbato:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Matthew 24:21",
      "text": "erit enim tunc tribulatio magna, qualis non fuit ab initio mundi usque modo, neque fiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Matthew 24:22",
      "text": "Et nisi breviati fuissent dies illi, non fieret salva omnis caro: sed propter electos breviabuntur dies illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Matthew 24:23",
      "text": "Tunc si quis vobis dixerit: Ecce hic est Christus, aut illic: nolite credere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Matthew 24:24",
      "text": "Surgent enim pseudochristi, et pseudoprophetæ: et dabunt signa magna, et prodigia, ita ut in errorem inducantur (si fieri potest) etiam electi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Matthew 24:25",
      "text": "Ecce prædixi vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Matthew 24:26",
      "text": "Si ergo dixerint vobis: Ecce in deserto est, nolite exire; Ecce in penetralibus, nolite credere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Matthew 24:27",
      "text": "Sicut enim fulgur exit ab oriente, et paret usque in occidentem: ita erit et adventus Filii hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Matthew 24:28",
      "text": "Ubicumque fuerit corpus, illic congregabuntur et aquilæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Matthew 24:29",
      "text": "Statim autem post tribulationem dierum illorum sol obscurabitur, et luna non dabit lumen suum, et stellæ cadent de cælo, et virtutes cælorum commovebuntur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Matthew 24:30",
      "text": "et tunc parebit signum Filii hominis in cælo: et tunc plangent omnes tribus terræ: et videbunt Filium hominis venientem in nubibus cæli cum virtute multa et majestate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Matthew 24:31",
      "text": "Et mittet angelos suos cum tuba, et voce magna: et congregabunt electos ejus a quatuor ventis, a summis cælorum usque ad terminos eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Matthew 24:32",
      "text": "Ab arbore autem fici discite parabolam: cum jam ramus ejus tener fuerit, et folia nata, scitis quia prope est æstas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Matthew 24:33",
      "text": "ita et vos cum videritis hæc omnia, scitote quia prope est, in januis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Matthew 24:34",
      "text": "Amen dico vobis, quia non præteribit generatio hæc, donec omnia hæc fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 35,
      "referenceLabel": "Matthew 24:35",
      "text": "Cælum et terra transibunt, verba autem mea non præteribunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 36,
      "referenceLabel": "Matthew 24:36",
      "text": "De die autem illa et hora nemo scit, neque angeli cælorum, nisi solus Pater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 37,
      "referenceLabel": "Matthew 24:37",
      "text": "Sicut autem in diebus Noë, ita erit et adventus Filii hominis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 38,
      "referenceLabel": "Matthew 24:38",
      "text": "sicut enim erant in diebus ante diluvium comedentes et bibentes, nubentes et nuptum tradentes, usque ad eum diem, quo intravit Noë in arcam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 39,
      "referenceLabel": "Matthew 24:39",
      "text": "et non cognoverunt donec venit diluvium, et tulit omnes: ita erit et adventus Filii hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 40,
      "referenceLabel": "Matthew 24:40",
      "text": "Tunc duo erunt in agro: unus assumetur, et unus relinquetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 41,
      "referenceLabel": "Matthew 24:41",
      "text": "Duæ molentes in mola: una assumetur, et una relinquetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 42,
      "referenceLabel": "Matthew 24:42",
      "text": "Vigilate ergo, quia nescitis qua hora Dominus vester venturus sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 43,
      "referenceLabel": "Matthew 24:43",
      "text": "Illud autem scitote, quoniam si sciret paterfamilias qua hora fur venturus esset, vigilaret utique, et non sineret perfodi domum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 44,
      "referenceLabel": "Matthew 24:44",
      "text": "Ideo et vos estote parati: quia qua nescitis hora Filius hominis venturus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 45,
      "referenceLabel": "Matthew 24:45",
      "text": "Quis, putas, est fidelis servus, et prudens, quem constituit dominus suus super familiam suam ut det illis cibum in tempore?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 46,
      "referenceLabel": "Matthew 24:46",
      "text": "Beatus ille servus, quem cum venerit dominus ejus, invenerit sic facientem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.47",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 47,
      "referenceLabel": "Matthew 24:47",
      "text": "Amen dico vobis, quoniam super omnia bona sua constituet eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.48",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 48,
      "referenceLabel": "Matthew 24:48",
      "text": "Si autem dixerit malus servus ille in corde suo: Moram fecit dominus meus venire:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.49",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 49,
      "referenceLabel": "Matthew 24:49",
      "text": "et cœperit percutere conservos suos, manducet autem et bibat cum ebriosis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.50",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 50,
      "referenceLabel": "Matthew 24:50",
      "text": "veniet dominus servi illius in die qua non sperat, et hora qua ignorat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.24.51",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 24,
      "verseNumber": 51,
      "referenceLabel": "Matthew 24:51",
      "text": "et dividet eum, partemque ejus ponet cum hypocritis: illic erit fletus et stridor dentium.",
      "paragraphStart": false
    }
  ]
}
