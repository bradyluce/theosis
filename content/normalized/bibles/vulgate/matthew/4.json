{
  "chapter": {
    "id": "vulgate:matthew.4",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 4,
    "referenceLabel": "Matthew 4",
    "summary": "Source text for Matthew 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.4.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Matthew 4:1",
      "text": "Tunc Jesus ductus est in desertum a Spiritu, ut tentaretur a diabolo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.4.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Matthew 4:2",
      "text": "Et cum jejunasset quadraginta diebus, et quadraginta noctibus, postea esuriit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Matthew 4:3",
      "text": "Et accedens tentator dixit ei: Si Filius Dei es, dic ut lapides isti panes fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Matthew 4:4",
      "text": "Qui respondens dixit: Scriptum est: Non in solo pane vivit homo, sed in omni verbo, quod procedit de ore Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Matthew 4:5",
      "text": "Tunc assumpsit eum diabolus in sanctam civitatem, et statuit eum super pinnaculum templi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Matthew 4:6",
      "text": "et dixit ei: Si Filius Dei es, mitte te deorsum. Scriptum est enim: Quia angelis suis mandavit de te, et in manibus tollent te, ne forte offendas ad lapidem pedem tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Matthew 4:7",
      "text": "Ait illi Jesus: Rursum scriptum est: Non tentabis Dominum Deum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Matthew 4:8",
      "text": "Iterum assumpsit eum diabolus in montem excelsum valde: et ostendit ei omnia regna mundi, et gloriam eorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Matthew 4:9",
      "text": "et dixit ei: Hæc omnia tibi dabo, si cadens adoraveris me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Matthew 4:10",
      "text": "Tunc dicit ei Jesus: Vade Satana: Scriptum est enim: Dominum Deum tuum adorabis, et illi soli servies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Matthew 4:11",
      "text": "Tunc reliquit eum diabolus: et ecce angeli accesserunt, et ministrabant ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Matthew 4:12",
      "text": "Cum autem audisset Jesus quod Joannes traditus esset, secessit in Galilæam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Matthew 4:13",
      "text": "et, relicta civitate Nazareth, venit, et habitavit in Capharnaum maritima, in finibus Zabulon et Nephthalim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Matthew 4:14",
      "text": "ut adimpleretur quod dictum est per Isaiam prophetam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Matthew 4:15",
      "text": "Terra Zabulon, et terra Nephthalim, via maris trans Jordanem, Galilæa gentium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Matthew 4:16",
      "text": "populus, qui sedebat in tenebris, vidit lucem magnam: et sedentibus in regione umbræ mortis, lux orta est eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Matthew 4:17",
      "text": "Exinde cœpit Jesus prædicare, et dicere: Pœnitentiam agite: appropinquavit enim regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Matthew 4:18",
      "text": "Ambulans autem Jesus juxta mare Galilææ, vidit duos fratres, Simonem, qui vocatur Petrus, et Andream fratrem ejus, mittentes rete in mare (erant enim piscatores),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Matthew 4:19",
      "text": "et ait illis: Venite post me, et faciam vos fieri piscatores hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Matthew 4:20",
      "text": "At illi continuo relictis retibus secuti sunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Matthew 4:21",
      "text": "Et procedens inde, vidit alios duos fratres, Jacobum Zebedæi, et Joannem fratrem ejus, in navi cum Zebedæo patre eorum, reficientes retia sua: et vocavit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Matthew 4:22",
      "text": "Illi autem statim relictis retibus et patre, secuti sunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Matthew 4:23",
      "text": "Et circuibat Jesus totam Galilæam, docens in synagogis eorum, et prædicans Evangelium regni: et sanans omnem languorem, et omnem infirmitatem in populo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Matthew 4:24",
      "text": "Et abiit opinio ejus in totam Syriam, et obtulerunt ei omnes male habentes, variis languoribus, et tormentis comprehensos, et qui dæmonia habebant, et lunaticos, et paralyticos, et curavit eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.4.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Matthew 4:25",
      "text": "et secutæ sunt eum turbæ multæ de Galilæa, et Decapoli, et de Jerosolymis, et de Judæa, et de trans Jordanem.",
      "paragraphStart": false
    }
  ]
}
