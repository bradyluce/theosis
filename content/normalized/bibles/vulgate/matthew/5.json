{
  "chapter": {
    "id": "vulgate:matthew.5",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 5,
    "referenceLabel": "Matthew 5",
    "summary": "Source text for Matthew 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.5.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Matthew 5:1",
      "text": "Videns autem Jesus turbas, ascendit in montem, et cum sedisset, accesserunt ad eum discipuli ejus,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.5.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Matthew 5:2",
      "text": "et aperiens os suum docebat eos dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Matthew 5:3",
      "text": "Beati pauperes spiritu: quoniam ipsorum est regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Matthew 5:4",
      "text": "Beati mites: quoniam ipsi possidebunt terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Matthew 5:5",
      "text": "Beati qui lugent: quoniam ipsi consolabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Matthew 5:6",
      "text": "Beati qui esuriunt et sitiunt justitiam: quoniam ipsi saturabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Matthew 5:7",
      "text": "Beati misericordes: quoniam ipsi misericordiam consequentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Matthew 5:8",
      "text": "Beati mundo corde: quoniam ipsi Deum videbunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Matthew 5:9",
      "text": "Beati pacifici: quoniam filii Dei vocabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Matthew 5:10",
      "text": "Beati qui persecutionem patiuntur propter justitiam: quoniam ipsorum est regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Matthew 5:11",
      "text": "Beati estis cum maledixerint vobis, et persecuti vos fuerint, et dixerint omne malum adversum vos mentientes, propter me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Matthew 5:12",
      "text": "gaudete, et exsultate, quoniam merces vestra copiosa est in cælis. Sic enim persecuti sunt prophetas, qui fuerunt ante vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Matthew 5:13",
      "text": "Vos estis sal terræ. Quod si sal evanuerit, in quo salietur? ad nihilum valet ultra, nisi ut mittatur foras, et conculcetur ab hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Matthew 5:14",
      "text": "Vos estis lux mundi. Non potest civitas abscondi supra montem posita,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Matthew 5:15",
      "text": "neque accendunt lucernam, et ponunt eam sub modio, sed super candelabrum, ut luceat omnibus qui in domo sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Matthew 5:16",
      "text": "Sic luceat lux vestra coram hominibus: ut videant opera vestra bona, et glorificent Patrem vestrum, qui in cælis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Matthew 5:17",
      "text": "Nolite putare quoniam veni solvere legem aut prophetas: non veni solvere, sed adimplere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Matthew 5:18",
      "text": "Amen quippe dico vobis, donec transeat cælum et terra, jota unum aut unus apex non præteribit a lege, donec omnia fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Matthew 5:19",
      "text": "Qui ergo solverit unum de mandatis istis minimis, et docuerit sic homines, minimus vocabitur in regno cælorum: qui autem fecerit et docuerit, hic magnus vocabitur in regno cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Matthew 5:20",
      "text": "Dico enim vobis, quia nisi abundaverit justitia vestra plus quam scribarum et pharisæorum, non intrabitis in regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Matthew 5:21",
      "text": "Audistis quia dictum est antiquis: Non occides: qui autem occiderit, reus erit judicio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Matthew 5:22",
      "text": "Ego autem dico vobis: quia omnis qui irascitur fratri suo, reus erit judicio. Qui autem dixerit fratri suo, raca: reus erit concilio. Qui autem dixerit, fatue: reus erit gehennæ ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Matthew 5:23",
      "text": "Si ergo offers munus tuum ad altare, et ibi recordatus fueris quia frater tuus habet aliquid adversum te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Matthew 5:24",
      "text": "relinque ibi munus tuum ante altare, et vade prius reconciliari fratri tuo: et tunc veniens offeres munus tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Matthew 5:25",
      "text": "Esto consentiens adversario tuo cito dum es in via cum eo: ne forte tradat te adversarius judici, et judex tradat te ministro: et in carcerem mittaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Matthew 5:26",
      "text": "Amen dico tibi, non exies inde, donec reddas novissimum quadrantem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Matthew 5:27",
      "text": "Audistis quia dictum est antiquis: Non mœchaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Matthew 5:28",
      "text": "Ego autem dico vobis: quia omnis qui viderit mulierem ad concupiscendum eam, jam mœchatus est eam in corde suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Matthew 5:29",
      "text": "Quod si oculus tuus dexter scandalizat te, erue eum, et projice abs te: expedit enim tibi ut pereat unum membrorum tuorum, quam totum corpus tuum mittatur in gehennam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Matthew 5:30",
      "text": "Et si dextra manus tua scandalizat te, abscide eam, et projice abs te: expedit enim tibi ut pereat unum membrorum tuorum, quam totum corpus tuum eat in gehennam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Matthew 5:31",
      "text": "Dictum est autem: Quicumque dimiserit uxorem suam, det ei libellum repudii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Matthew 5:32",
      "text": "Ego autem dico vobis: quia omnis qui dimiserit uxorem suam, excepta fornicationis causa, facit eam mœchari: et qui dimissam duxerit, adulterat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Matthew 5:33",
      "text": "Iterum audistis quia dictum est antiquis: Non perjurabis: reddes autem Domino juramenta tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Matthew 5:34",
      "text": "Ego autem dico vobis, non jurare omnino, neque per cælum, quia thronus Dei est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "Matthew 5:35",
      "text": "neque per terram, quia scabellum est pedum ejus: neque per Jerosolymam, quia civitas est magni regis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "Matthew 5:36",
      "text": "neque per caput tuum juraveris, quia non potes unum capillum album facere, aut nigrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "Matthew 5:37",
      "text": "Sit autem sermo vester, est, est: non, non: quod autem his abundantius est, a malo est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 38,
      "referenceLabel": "Matthew 5:38",
      "text": "Audistis quia dictum est: Oculum pro oculo, et dentem pro dente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 39,
      "referenceLabel": "Matthew 5:39",
      "text": "Ego autem dico vobis, non resistere malo: sed si quis te percusserit in dexteram maxillam tuam, præbe illi et alteram:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 40,
      "referenceLabel": "Matthew 5:40",
      "text": "et ei, qui vult tecum judicio contendere, et tunicam tuam tollere, dimitte ei et pallium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 41,
      "referenceLabel": "Matthew 5:41",
      "text": "et quicumque te angariaverit mille passus, vade cum illo et alia duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 42,
      "referenceLabel": "Matthew 5:42",
      "text": "Qui petit a te, da ei: et volenti mutuari a te, ne avertaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 43,
      "referenceLabel": "Matthew 5:43",
      "text": "Audistis quia dictum est: Diliges proximum tuum, et odio habebis inimicum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 44,
      "referenceLabel": "Matthew 5:44",
      "text": "Ego autem dico vobis: diligite inimicos vestros, benefacite his qui oderunt vos, et orate pro persequentibus et calumniantibus vos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 45,
      "referenceLabel": "Matthew 5:45",
      "text": "ut sitis filii Patris vestri, qui in cælis est: qui solem suum oriri facit super bonos et malos: et pluit super justos et injustos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 46,
      "referenceLabel": "Matthew 5:46",
      "text": "Si enim diligitis eos qui vos diligunt, quam mercedem habebitis? nonne et publicani hoc faciunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.47",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 47,
      "referenceLabel": "Matthew 5:47",
      "text": "Et si salutaveritis fratres vestros tantum, quid amplius facitis? nonne et ethnici hoc faciunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.5.48",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 5,
      "verseNumber": 48,
      "referenceLabel": "Matthew 5:48",
      "text": "Estote ergo vos perfecti, sicut et Pater vester cælestis perfectus est.",
      "paragraphStart": false
    }
  ]
}
