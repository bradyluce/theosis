{
  "chapter": {
    "id": "vulgate:matthew.14",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 14,
    "referenceLabel": "Matthew 14",
    "summary": "Source text for Matthew 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.14.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Matthew 14:1",
      "text": "In illo tempore audivit Herodes tetrarcha famam Jesu:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.14.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Matthew 14:2",
      "text": "et ait pueris suis: Hic est Joannes Baptista: ipse surrexit a mortuis, et ideo virtutes operantur in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Matthew 14:3",
      "text": "Herodes enim tenuit Joannem, et alligavit eum: et posuit in carcerem propter Herodiadem uxorem fratris sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Matthew 14:4",
      "text": "Dicebat enim illi Joannes: Non licet tibi habere eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Matthew 14:5",
      "text": "Et volens illum occidere, timuit populum: quia sicut prophetam eum habebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Matthew 14:6",
      "text": "Die autem natalis Herodis saltavit filia Herodiadis in medio, et placuit Herodi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Matthew 14:7",
      "text": "unde cum juramento pollicitus est ei dare quodcumque postulasset ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Matthew 14:8",
      "text": "At illa præmonita a matre sua: Da mihi, inquit, hic in disco caput Joannis Baptistæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Matthew 14:9",
      "text": "Et contristatus est rex: propter juramentum autem, et eos qui pariter recumbebant, jussit dari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Matthew 14:10",
      "text": "Misitque et decollavit Joannem in carcere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Matthew 14:11",
      "text": "Et allatum est caput ejus in disco, et datum est puellæ, et attulit matri suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Matthew 14:12",
      "text": "Et accedentes discipuli ejus, tulerunt corpus ejus, et sepelierunt illud: et venientes nuntiaverunt Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Matthew 14:13",
      "text": "Quod cum audisset Jesus, secessit inde in navicula, in locum desertum seorsum: et cum audissent turbæ, secutæ sunt eum pedestres de civitatibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Matthew 14:14",
      "text": "Et exiens vidit turbam multam, et misertus est eis, et curavit languidos eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Matthew 14:15",
      "text": "Vespere autem facto, accesserunt ad eum discipuli ejus, dicentes: Desertus est locus, et hora jam præteriit: dimitte turbas, ut euntes in castella, emant sibi escas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Matthew 14:16",
      "text": "Jesus autem dixit eis: Non habent necesse ire: date illis vos manducare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Matthew 14:17",
      "text": "Responderunt ei: Non habemus hic nisi quinque panes et duos pisces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Matthew 14:18",
      "text": "Qui ait eis: Afferte mihi illos huc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Matthew 14:19",
      "text": "Et cum jussisset turbam discumbere super fœnum, acceptis quinque panibus et duobus piscibus, aspiciens in cælum benedixit, et fregit, et dedit discipulis panes, discipuli autem turbis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Matthew 14:20",
      "text": "Et manducaverunt omnes, et saturati sunt. Et tulerunt reliquias, duodecim cophinos fragmentorum plenos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Matthew 14:21",
      "text": "Manducantium autem fuit numerus quinque millia virorum, exceptis mulieribus et parvulis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Matthew 14:22",
      "text": "Et statim compulit Jesus discipulos ascendere in naviculam, et præcedere eum trans fretum, donec dimitteret turbas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Matthew 14:23",
      "text": "Et dimissa turba, ascendit in montem solus orare. Vespere autem facto solus erat ibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Matthew 14:24",
      "text": "navicula autem in medio mari jactabatur fluctibus: erat enim contrarius ventus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Matthew 14:25",
      "text": "Quarta enim vigilia noctis, venit ad eos ambulans super mare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Matthew 14:26",
      "text": "Et videntes eum super mare ambulantem, turbati sunt, dicentes: Quia phantasma est. Et præ timore clamaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Matthew 14:27",
      "text": "Statimque Jesus locutus est eis, dicens: Habete fiduciam: ego sum, nolite timere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Matthew 14:28",
      "text": "Respondens autem Petrus, dixit: Domine, si tu es, jube me ad te venire super aquas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Matthew 14:29",
      "text": "At ipse ait: Veni. Et descendens Petrus de navicula, ambulabat super aquam ut veniret ad Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Matthew 14:30",
      "text": "Videns vero ventum validum, timuit: et cum cœpisset mergi, clamavit dicens: Domine, salvum me fac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Matthew 14:31",
      "text": "Et continuo Jesus extendens manum, apprehendit eum: et ait illi: Modicæ fidei, quare dubitasti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Matthew 14:32",
      "text": "Et cum ascendissent in naviculam, cessavit ventus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Matthew 14:33",
      "text": "Qui autem in navicula erant, venerunt, et adoraverunt eum, dicentes: Vere Filius Dei es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Matthew 14:34",
      "text": "Et cum transfretassent, venerunt in terram Genesar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Matthew 14:35",
      "text": "Et cum cognovissent eum viri loci illius, miserunt in universam regionem illam, et obtulerunt ei omnes male habentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.14.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Matthew 14:36",
      "text": "et rogabant eum ut vel fimbriam vestimenti ejus tangerent. Et quicumque tetigerunt, salvi facti sunt.",
      "paragraphStart": false
    }
  ]
}
