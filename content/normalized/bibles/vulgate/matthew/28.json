{
  "chapter": {
    "id": "vulgate:matthew.28",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 28,
    "referenceLabel": "Matthew 28",
    "summary": "Source text for Matthew 28 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.28.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Matthew 28:1",
      "text": "Vespere autem sabbati, quæ lucescit in prima sabbati, venit Maria Magdalene, et altera Maria, videre sepulchrum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.28.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Matthew 28:2",
      "text": "Et ecce terræmotus factus est magnus. Angelus enim Domini descendit de cælo: et accedens revolvit lapidem, et sedebat super eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Matthew 28:3",
      "text": "erat autem aspectus ejus sicut fulgur: et vestimentum ejus sicut nix.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Matthew 28:4",
      "text": "Præ timore autem ejus exterriti sunt custodes, et facti sunt velut mortui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Matthew 28:5",
      "text": "Respondens autem angelus dixit mulieribus: Nolite timere vos: scio enim, quod Jesum, qui crucifixus est, quæritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Matthew 28:6",
      "text": "Non est hic: surrexit enim, sicut dixit: venite, et videte locum ubi positus erat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Matthew 28:7",
      "text": "Et cito euntes, dicite discipulis ejus quia surrexit: et ecce præcedit vos in Galilæam: ibi eum videbitis: ecce prædixi vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Matthew 28:8",
      "text": "Et exierunt cito de monumento cum timore et gaudio magno, currentes nuntiare discipulis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Matthew 28:9",
      "text": "Et ecce Jesus occurrit illis, dicens: Avete. Illæ autem accesserunt, et tenuerunt pedes ejus, et adoraverunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Matthew 28:10",
      "text": "Tunc ait illis Jesus: Nolite timere: ite, nuntiate fratribus meis ut eant in Galilæam; ibi me videbunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Matthew 28:11",
      "text": "Quæ cum abiissent, ecce quidam de custodibus venerunt in civitatem, et nuntiaverunt principibus sacerdotum omnia quæ facta fuerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Matthew 28:12",
      "text": "Et congregati cum senioribus consilio accepto, pecuniam copiosam dederunt militibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Matthew 28:13",
      "text": "dicentes: Dicite quia discipuli ejus nocte venerunt, et furati sunt eum, nobis dormientibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Matthew 28:14",
      "text": "Et si hoc auditum fuerit a præside, nos suadebimus ei, et securos vos faciemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Matthew 28:15",
      "text": "At illi, accepta pecunia, fecerunt sicut erant edocti. Et divulgatum est verbum istud apud Judæos, usque in hodiernum diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Matthew 28:16",
      "text": "Undecim autem discipuli abierunt in Galilæam in montem ubi constituerat illis Jesus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Matthew 28:17",
      "text": "Et videntes eum adoraverunt: quidam autem dubitaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Matthew 28:18",
      "text": "Et accedens Jesus locutus est eis, dicens: Data est mihi omnis potestas in cælo et in terra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Matthew 28:19",
      "text": "euntes ergo docete omnes gentes: baptizantes eos in nomine Patris, et Filii, et Spiritus Sancti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.28.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Matthew 28:20",
      "text": "docentes eos servare omnia quæcumque mandavi vobis: et ecce ego vobiscum sum omnibus diebus, usque ad consummationem sæculi.",
      "paragraphStart": false
    }
  ]
}
