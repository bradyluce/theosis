{
  "chapter": {
    "id": "vulgate:matthew.10",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 10,
    "referenceLabel": "Matthew 10",
    "summary": "Source text for Matthew 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.10.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Matthew 10:1",
      "text": "Et convocatis duodecim discipulis suis, dedit illis potestatem spirituum immundorum, ut ejicerent eos, et curarent omnem languorem, et omnem infirmitatem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.10.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Matthew 10:2",
      "text": "Duodecim autem Apostolorum nomina sunt hæc. Primus, Simon, qui dicitur Petrus: et Andreas frater ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Matthew 10:3",
      "text": "Jacobus Zebedæi, et Joannes frater ejus, Philippus, et Bartholomæus, Thomas, et Matthæus publicanus, Jacobus Alphæi, et Thaddæus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Matthew 10:4",
      "text": "Simon Chananæus, et Judas Iscariotes, qui et tradidit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Matthew 10:5",
      "text": "Hos duodecim misit Jesus, præcipiens eis, dicens: In viam gentium ne abieritis, et in civitates Samaritanorum ne intraveritis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Matthew 10:6",
      "text": "sed potius ite ad oves quæ perierunt domus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Matthew 10:7",
      "text": "Euntes autem prædicate, dicentes: Quia appropinquavit regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Matthew 10:8",
      "text": "Infirmos curate, mortuos suscitate, leprosos mundate, dæmones ejicite: gratis accepistis, gratis date.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Matthew 10:9",
      "text": "Nolite possidere aurum, neque argentum, neque pecuniam in zonis vestris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Matthew 10:10",
      "text": "non peram in via, neque duas tunicas, neque calceamenta, neque virgam: dignus enim est operarius cibo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Matthew 10:11",
      "text": "In quamcumque autem civitatem aut castellum intraveritis, interrogate, quis in ea dignus sit: et ibi manete donec exeatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Matthew 10:12",
      "text": "Intrantes autem in domum, salutate eam, dicentes: Pax huic domui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Matthew 10:13",
      "text": "Et siquidem fuerit domus illa digna, veniet pax vestra super eam: si autem non fuerit digna, pax vestra revertetur ad vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Matthew 10:14",
      "text": "Et quicumque non receperit vos, neque audierit sermones vestros: exeuntes foras de domo, vel civitate, excutite pulverem de pedibus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Matthew 10:15",
      "text": "Amen dico vobis: Tolerabilius erit terræ Sodomorum et Gomorrhæorum in die judicii, quam illi civitati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Matthew 10:16",
      "text": "Ecce ego mitto vos sicut oves in medio luporum. Estote ergo prudentes sicut serpentes, et simplices sicut columbæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Matthew 10:17",
      "text": "Cavete autem ab hominibus. Tradent enim vos in conciliis, et in synagogis suis flagellabunt vos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Matthew 10:18",
      "text": "et ad præsides, et ad reges ducemini propter me in testimonium illis, et gentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Matthew 10:19",
      "text": "Cum autem tradent vos, nolite cogitare quomodo, aut quid loquamini: dabitur enim vobis in illa hora, quid loquamini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Matthew 10:20",
      "text": "non enim vos estis qui loquimini, sed Spiritus Patris vestri, qui loquitur in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Matthew 10:21",
      "text": "Tradet autem frater fratrem in mortem, et pater filium: et insurgent filii in parentes, et morte eos afficient:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Matthew 10:22",
      "text": "et eritis odio omnibus propter nomen meum: qui autem perseveraverit usque in finem, hic salvus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Matthew 10:23",
      "text": "Cum autem persequentur vos in civitate ista, fugite in aliam. Amen dico vobis, non consummabitis civitates Israël, donec veniat Filius hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Matthew 10:24",
      "text": "Non est discipulus super magistrum, nec servus super dominum suum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Matthew 10:25",
      "text": "sufficit discipulo ut sit sicut magister ejus, et servo, sicut dominus ejus. Si patremfamilias Beelzebub vocaverunt, quanto magis domesticos ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Matthew 10:26",
      "text": "Ne ergo timueritis eos. Nihil enim est opertum, quod non revelabitur: et occultum, quod non scietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Matthew 10:27",
      "text": "Quod dico vobis in tenebris, dicite in lumine: et quod in aure auditis, prædicate super tecta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Matthew 10:28",
      "text": "Et nolite timere eos qui occidunt corpus, animam autem non possunt occidere: sed potius timete eum, qui potest et animam et corpus perdere in gehennam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Matthew 10:29",
      "text": "Nonne duo passeres asse veneunt? et unus ex illis non cadet super terram sine Patre vestro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Matthew 10:30",
      "text": "Vestri autem capilli capitis omnes numerati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Matthew 10:31",
      "text": "Nolite ergo timere: multis passeribus meliores estis vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Matthew 10:32",
      "text": "Omnis ergo qui confitebitur me coram hominibus, confitebor et ego eum coram Patre meo, qui in cælis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Matthew 10:33",
      "text": "Qui autem negaverit me coram hominibus, negabo et ego eum coram Patre meo, qui in cælis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Matthew 10:34",
      "text": "Nolite arbitrari quia pacem venerim mittere in terram: non veni pacem mittere, sed gladium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Matthew 10:35",
      "text": "veni enim separare hominem adversus patrem suum, et filiam adversus matrem suam, et nurum adversus socrum suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Matthew 10:36",
      "text": "et inimici hominis, domestici ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Matthew 10:37",
      "text": "Qui amat patrem aut matrem plus quam me, non est me dignus: et qui amat filium aut filiam super me, non est me dignus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Matthew 10:38",
      "text": "Et qui non accipit crucem suam, et sequitur me, non est me dignus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Matthew 10:39",
      "text": "Qui invenit animam suam, perdet illam: et qui perdiderit animam suam propter me, inveniet eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 40,
      "referenceLabel": "Matthew 10:40",
      "text": "Qui recipit vos, me recipit: et qui me recipit, recipit eum qui me misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 41,
      "referenceLabel": "Matthew 10:41",
      "text": "Qui recipit prophetam in nomine prophetæ, mercedem prophetæ accipiet: et qui recipit justum in nomine justi, mercedem justi accipiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.10.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 10,
      "verseNumber": 42,
      "referenceLabel": "Matthew 10:42",
      "text": "Et quicumque potum dederit uni ex minimis istis calicem aquæ frigidæ tantum in nomine discipuli: amen dico vobis, non perdet mercedem suam.",
      "paragraphStart": false
    }
  ]
}
