{
  "chapter": {
    "id": "vulgate:matthew.15",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 15,
    "referenceLabel": "Matthew 15",
    "summary": "Source text for Matthew 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.15.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Matthew 15:1",
      "text": "Tunc accesserunt ad eum ab Jerosolymis scribæ et pharisæi, dicentes:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.15.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Matthew 15:2",
      "text": "Quare discipuli tui transgrediuntur traditionem seniorum? non enim lavant manus suas cum panem manducant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Matthew 15:3",
      "text": "Ipse autem respondens ait illis: Quare et vos transgredimini mandatum Dei propter traditionem vestram? Nam Deus dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Matthew 15:4",
      "text": "Honora patrem, et matrem: et, Qui maledixerit patri, vel matri, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Matthew 15:5",
      "text": "Vos autem dicitis: Quicumque dixerit patri, vel matri: Munus, quodcumque est ex me, tibi proderit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Matthew 15:6",
      "text": "et non honorificabit patrem suum, aut matrem suam: et irritum fecistis mandatum Dei propter traditionem vestram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Matthew 15:7",
      "text": "Hypocritæ, bene prophetavit de vobis Isaias, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Matthew 15:8",
      "text": "Populus hic labiis me honorat: cor autem eorum longe est a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Matthew 15:9",
      "text": "Sine causa autem colunt me, docentes doctrinas et mandata hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Matthew 15:10",
      "text": "Et convocatis ad se turbis, dixit eis: Audite, et intelligite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Matthew 15:11",
      "text": "Non quod intrat in os, coinquinat hominem: sed quod procedit ex ore, hoc coinquinat hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Matthew 15:12",
      "text": "Tunc accedentes discipuli ejus, dixerunt ei: Scis quia pharisæi audito verbo hoc, scandalizati sunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Matthew 15:13",
      "text": "At ille respondens ait: Omnis plantatio, quam non plantavit Pater meus cælestis, eradicabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Matthew 15:14",
      "text": "Sinite illos: cæci sunt, et duces cæcorum; cæcus autem si cæco ducatum præstet, ambo in foveam cadunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Matthew 15:15",
      "text": "Respondens autem Petrus dixit ei: Edissere nobis parabolam istam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Matthew 15:16",
      "text": "At ille dixit: Adhuc et vos sine intellectu estis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Matthew 15:17",
      "text": "Non intelligitis quia omne quod in os intrat, in ventrem vadit, et in secessum emittitur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Matthew 15:18",
      "text": "Quæ autem procedunt de ore, de corde exeunt, et ea coinquinant hominem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Matthew 15:19",
      "text": "de corde enim exeunt cogitationes malæ, homicidia, adulteria, fornicationes, furta, falsa testimonia, blasphemiæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Matthew 15:20",
      "text": "hæc sunt, quæ coinquinant hominem. Non lotis autem manibus manducare, non coinquinat hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Matthew 15:21",
      "text": "Et egressus inde Jesus secessit in partes Tyri et Sidonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Matthew 15:22",
      "text": "Et ecce mulier chananæa a finibus illis egressa clamavit, dicens ei: Miserere mei, Domine fili David: filia mea male a dæmonio vexatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Matthew 15:23",
      "text": "Qui non respondit ei verbum. Et accedentes discipuli ejus rogabant eum dicentes: Dimitte eam: quia clamat post nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Matthew 15:24",
      "text": "Ipse autem respondens ait: Non sum missus nisi ad oves, quæ perierunt domus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Matthew 15:25",
      "text": "At illa venit, et adoravit eum, dicens: Domine, adjuva me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Matthew 15:26",
      "text": "Qui respondens ait: Non est bonum sumere panem filiorum, et mittere canibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Matthew 15:27",
      "text": "At illa dixit: Etiam Domine: nam et catelli edunt de micis quæ cadunt de mensa dominorum suorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Matthew 15:28",
      "text": "Tunc respondens Jesus, ait illi: O mulier, magna est fides tua: fiat tibi sicut vis. Et sanata est filia ejus ex illa hora.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Matthew 15:29",
      "text": "Et cum transisset inde Jesus, venit secus mare Galilææ: et ascendens in montem, sedebat ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Matthew 15:30",
      "text": "Et accesserunt ad eum turbæ multæ, habentes secum mutos, cæcos, claudos, debiles, et alios multos: et projecerunt eos ad pedes ejus, et curavit eos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Matthew 15:31",
      "text": "ita ut turbæ mirarentur, videntes mutos loquentes, claudos ambulantes, cæcos videntes: et magnificabant Deum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Matthew 15:32",
      "text": "Jesus autem, convocatis discipulis suis, dixit: Misereor turbæ, quia triduo jam perseverant mecum, et non habent quod manducent: et dimittere eos jejunos nolo, ne deficiant in via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Matthew 15:33",
      "text": "Et dicunt ei discipuli: Unde ergo nobis in deserto panes tantos, ut saturemus turbam tantam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Matthew 15:34",
      "text": "Et ait illis Jesus: Quot habetis panes? At illi dixerunt: Septem, et paucos pisciculos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Matthew 15:35",
      "text": "Et præcepit turbæ ut discumberent super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Matthew 15:36",
      "text": "Et accipiens septem panes, et pisces, et gratias agens, fregit, et dedit discipulis suis, et discipuli dederunt populo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Matthew 15:37",
      "text": "Et comederunt omnes, et saturati sunt. Et quod superfuit de fragmentis, tulerunt septem sportas plenas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Matthew 15:38",
      "text": "Erant autem qui manducaverunt quatuor millia hominum, extra parvulos et mulieres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.15.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Matthew 15:39",
      "text": "Et, dimissa turba, ascendit in naviculam: et venit in fines Magedan.",
      "paragraphStart": false
    }
  ]
}
