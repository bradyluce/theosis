{
  "chapter": {
    "id": "vulgate:matthew.23",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 23,
    "referenceLabel": "Matthew 23",
    "summary": "Source text for Matthew 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.23.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Matthew 23:1",
      "text": "Tunc Jesus locutus est ad turbas, et ad discipulos suos,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.23.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Matthew 23:2",
      "text": "dicens: Super cathedram Moysi sederunt scribæ et pharisæi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Matthew 23:3",
      "text": "Omnia ergo quæcumque dixerint vobis, servate, et facite: secundum opera vero eorum nolite facere: dicunt enim, et non faciunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Matthew 23:4",
      "text": "Alligant enim onera gravia, et importabilia, et imponunt in humeros hominum: digito autem suo nolunt ea movere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Matthew 23:5",
      "text": "Omnia vero opera sua faciunt ut videantur ab hominibus: dilatant enim phylacteria sua, et magnificant fimbrias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Matthew 23:6",
      "text": "Amant autem primos recubitus in cœnis, et primas cathedras in synagogis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Matthew 23:7",
      "text": "et salutationes in foro, et vocari ab hominibus Rabbi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Matthew 23:8",
      "text": "Vos autem nolite vocari Rabbi: unus est enim magister vester, omnes autem vos fratres estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Matthew 23:9",
      "text": "Et patrem nolite vocare vobis super terram: unus est enim pater vester qui in cælis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Matthew 23:10",
      "text": "Nec vocemini magistri: quia magister vester unus est, Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Matthew 23:11",
      "text": "Qui major est vestrum, erit minister vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Matthew 23:12",
      "text": "Qui autem se exaltaverit, humiliabitur: et qui se humiliaverit, exaltabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Matthew 23:13",
      "text": "Væ autem vobis scribæ et pharisæi hypocritæ, quia clauditis regnum cælorum ante homines! vos enim non intratis, nec introëuntes sinitis intrare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Matthew 23:14",
      "text": "Væ vobis scribæ et pharisæi hypocritæ, quia comeditis domos viduarum, orationes longas orantes! propter hoc amplius accipietis judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Matthew 23:15",
      "text": "Væ vobis scribæ et pharisæi hypocritæ, quia circuitis mare, et aridam, ut faciatis unum proselytum, et cum fuerit factus, facitis eum filium gehennæ duplo quam vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Matthew 23:16",
      "text": "Væ vobis duces cæci, qui dicitis: Quicumque juraverit per templum, nihil est: qui autem juraverit in auro templi, debet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Matthew 23:17",
      "text": "Stulti et cæci: quid enim majus est? aurum, an templum, quod sanctificat aurum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Matthew 23:18",
      "text": "Et quicumque juraverit in altari, nihil est: quicumque autem juraverit in dono, quod est super illud, debet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Matthew 23:19",
      "text": "Cæci: quid enim majus est, donum, an altare, quod sanctificat donum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Matthew 23:20",
      "text": "Qui ergo jurat in altari, jurat in eo, et in omnibus quæ super illud sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Matthew 23:21",
      "text": "Et quicumque juraverit in templo, jurat in illo, et in eo qui habitat in ipso:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Matthew 23:22",
      "text": "et qui jurat in cælo, jurat in throno Dei, et in eo qui sedet super eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Matthew 23:23",
      "text": "Væ vobis scribæ et pharisæi hypocritæ, qui decimatis mentham, et anethum, et cyminum, et reliquistis quæ graviora sunt legis, judicium, et misericordiam, et fidem! hæc oportuit facere, et illa non omittere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Matthew 23:24",
      "text": "Duces cæci, excolantes culicem, camelum autem glutientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Matthew 23:25",
      "text": "Væ vobis scribæ et pharisæi hypocritæ, quia mundatis quod deforis est calicis et paropsidis; intus autem pleni estis rapina et immunditia!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Matthew 23:26",
      "text": "Pharisæe cæce, munda prius quod intus est calicis, et paropsidis, ut fiat id, quod deforis est, mundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Matthew 23:27",
      "text": "Væ vobis scribæ et pharisæi hypocritæ, quia similes estis sepulchris dealbatis, quæ a foris parent hominibus speciosa, intus vero pleni sunt ossibus mortuorum, et omni spurcitia!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Matthew 23:28",
      "text": "Sic et vos a foris quidem paretis hominibus justi: intus autem pleni estis hypocrisi et iniquitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Matthew 23:29",
      "text": "Væ vobis scribæ et pharisæi hypocritæ, qui ædificatis sepulchra prophetarum, et ornatis monumenta justorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Matthew 23:30",
      "text": "et dicitis: Si fuissemus in diebus patrum nostrorum, non essemus socii eorum in sanguine prophetarum!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Matthew 23:31",
      "text": "itaque testimonio estis vobismetipsis, quia filii estis eorum, qui prophetas occiderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Matthew 23:32",
      "text": "Et vos implete mensuram patrum vestrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Matthew 23:33",
      "text": "Serpentes, genimina viperarum, quomodo fugietis a judicio gehennæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Matthew 23:34",
      "text": "Ideo ecce ego mitto ad vos prophetas, et sapientes, et scribas, et ex illis occidetis, et crucifigetis, et ex eis flagellabitis in synagogis vestris, et persequemini de civitate in civitatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Matthew 23:35",
      "text": "ut veniat super vos omnis sanguis justus, qui effusus est super terram, a sanguine Abel justi usque ad sanguinem Zachariæ, filii Barachiæ, quem occidistis inter templum et altare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 36,
      "referenceLabel": "Matthew 23:36",
      "text": "Amen dico vobis, venient hæc omnia super generationem istam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 37,
      "referenceLabel": "Matthew 23:37",
      "text": "Jerusalem, Jerusalem, quæ occidis prophetas, et lapidas eos, qui ad te missi sunt, quoties volui congregare filios tuos, quemadmodum gallina congregat pullos suos sub alas, et noluisti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 38,
      "referenceLabel": "Matthew 23:38",
      "text": "Ecce relinquetur vobis domus vestra deserta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.23.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 39,
      "referenceLabel": "Matthew 23:39",
      "text": "Dico enim vobis, non me videbitis amodo, donec dicatis: Benedictus, qui venit in nomine Domini.",
      "paragraphStart": false
    }
  ]
}
