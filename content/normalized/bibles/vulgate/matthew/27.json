{
  "chapter": {
    "id": "vulgate:matthew.27",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 27,
    "referenceLabel": "Matthew 27",
    "summary": "Source text for Matthew 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.27.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Matthew 27:1",
      "text": "Mane autem facto, consilium inierunt omnes principes sacerdotum et seniores populi adversus Jesum, ut eum morti traderent.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.27.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Matthew 27:2",
      "text": "Et vinctum adduxerunt eum, et tradiderunt Pontio Pilato præsidi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Matthew 27:3",
      "text": "Tunc videns Judas, qui eum tradidit, quod damnatus esset, pœnitentia ductus, retulit triginta argenteos principibus sacerdotum, et senioribus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Matthew 27:4",
      "text": "dicens: Peccavi, tradens sanguinem justum. At illi dixerunt: Quid ad nos? tu videris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Matthew 27:5",
      "text": "Et projectis argenteis in templo, recessit: et abiens laqueo se suspendit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Matthew 27:6",
      "text": "Principes autem sacerdotum, acceptis argenteis, dixerunt: Non licet eos mittere in corbonam: quia pretium sanguinis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Matthew 27:7",
      "text": "Consilio autem inito, emerunt ex illis agrum figuli, in sepulturam peregrinorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Matthew 27:8",
      "text": "Propter hoc vocatus est ager ille, Haceldama, hoc est, Ager sanguinis, usque in hodiernum diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Matthew 27:9",
      "text": "Tunc impletum est quod dictum est per Jeremiam prophetam, dicentem: Et acceperunt triginta argenteos pretium appretiati, quem appretiaverunt a filiis Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Matthew 27:10",
      "text": "et dederunt eos in agrum figuli, sicut constituit mihi Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Matthew 27:11",
      "text": "Jesus autem stetit ante præsidem, et interrogavit eum præses, dicens: Tu es rex Judæorum? Dicit illi Jesus: Tu dicis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Matthew 27:12",
      "text": "Et cum accusaretur a principibus sacerdotum et senioribus, nihil respondit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Matthew 27:13",
      "text": "Tunc dicit illi Pilatus: Non audis quanta adversum te dicunt testimonia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Matthew 27:14",
      "text": "Et non respondit ei ad ullum verbum, ita ut miraretur præses vehementer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Matthew 27:15",
      "text": "Per diem autem solemnem consueverat præses populo dimittere unum vinctum, quem voluissent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Matthew 27:16",
      "text": "habebat autem tunc vinctum insignem, qui dicebatur Barabbas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Matthew 27:17",
      "text": "Congregatis ergo illis, dixit Pilatus: Quem vultis dimittam vobis: Barabbam, an Jesum, qui dicitur Christus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Matthew 27:18",
      "text": "Sciebat enim quod per invidiam tradidissent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Matthew 27:19",
      "text": "Sedente autem illo pro tribunali, misit ad eum uxor ejus, dicens: Nihil tibi, et justo illi: multa enim passa sum hodie per visum propter eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Matthew 27:20",
      "text": "Principes autem sacerdotum et seniores persuaserunt populis ut peterent Barabbam, Jesum vero perderent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Matthew 27:21",
      "text": "Respondens autem præses, ait illis: Quem vultis vobis de duobus dimitti? At illi dixerunt: Barabbam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Matthew 27:22",
      "text": "Dicit illis Pilatus: Quid igitur faciam de Jesu, qui dicitur Christus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Matthew 27:23",
      "text": "Dicunt omnes: Crucifigatur. Ait illis præses: Quid enim mali fecit? At illi magis clamabant dicentes: Crucifigatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Matthew 27:24",
      "text": "Videns autem Pilatus quia nihil proficeret, sed magis tumultus fieret: accepta aqua, lavit manus coram populo, dicens: Innocens ego sum a sanguine justi hujus: vos videritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Matthew 27:25",
      "text": "Et respondens universus populus, dixit: Sanguis ejus super nos, et super filios nostros.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Matthew 27:26",
      "text": "Tunc dimisit illis Barabbam: Jesum autem flagellatum tradidit eis ut crucifigeretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Matthew 27:27",
      "text": "Tunc milites præsidis suscipientes Jesum in prætorium, congregaverunt ad eum universam cohortem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 28,
      "referenceLabel": "Matthew 27:28",
      "text": "et exuentes eum, chlamydem coccineam circumdederunt ei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 29,
      "referenceLabel": "Matthew 27:29",
      "text": "et plectentes coronam de spinis, posuerunt super caput ejus, et arundinem in dextera ejus. Et genu flexo ante eum, illudebant ei, dicentes: Ave rex Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 30,
      "referenceLabel": "Matthew 27:30",
      "text": "Et exspuentes in eum, acceperunt arundinem, et percutiebant caput ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 31,
      "referenceLabel": "Matthew 27:31",
      "text": "Et postquam illuserunt ei, exuerunt eum chlamyde, et induerunt eum vestimentis ejus, et duxerunt eum ut crucifigerent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 32,
      "referenceLabel": "Matthew 27:32",
      "text": "Exeuntes autem invenerunt hominem Cyrenæum, nomine Simonem: hunc angariaverunt ut tolleret crucem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 33,
      "referenceLabel": "Matthew 27:33",
      "text": "Et venerunt in locum qui dicitur Golgotha, quod est Calvariæ locus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 34,
      "referenceLabel": "Matthew 27:34",
      "text": "Et dederunt ei vinum bibere cum felle mistum. Et cum gustasset, noluit bibere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 35,
      "referenceLabel": "Matthew 27:35",
      "text": "Postquam autem crucifixerunt eum, diviserunt vestimenta ejus, sortem mittentes: ut impleretur quod dictum est per prophetam dicentem: Diviserunt sibi vestimenta mea, et super vestem meam miserunt sortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 36,
      "referenceLabel": "Matthew 27:36",
      "text": "Et sedentes servabant eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 37,
      "referenceLabel": "Matthew 27:37",
      "text": "Et imposuerunt super caput ejus causam ipsius scriptam: Hic est Jesus rex Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 38,
      "referenceLabel": "Matthew 27:38",
      "text": "Tunc crucifixi sunt cum eo duo latrones: unus a dextris, et unus a sinistris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 39,
      "referenceLabel": "Matthew 27:39",
      "text": "Prætereuntes autem blasphemabant eum moventes capita sua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 40,
      "referenceLabel": "Matthew 27:40",
      "text": "et dicentes: Vah! qui destruis templum Dei, et in triduo illud reædificas: salva temetipsum: si Filius Dei es, descende de cruce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 41,
      "referenceLabel": "Matthew 27:41",
      "text": "Similiter et principes sacerdotum illudentes cum scribis et senioribus dicebant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 42,
      "referenceLabel": "Matthew 27:42",
      "text": "Alios salvos fecit, seipsum non potest salvum facere: si rex Israël est, descendat nunc de cruce, et credimus ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 43,
      "referenceLabel": "Matthew 27:43",
      "text": "confidit in Deo: liberet nunc, si vult eum: dixit enim: Quia Filius Dei sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 44,
      "referenceLabel": "Matthew 27:44",
      "text": "Idipsum autem et latrones, qui crucifixi erant cum eo, improperabant ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 45,
      "referenceLabel": "Matthew 27:45",
      "text": "A sexta autem hora tenebræ factæ sunt super universam terram usque ad horam nonam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 46,
      "referenceLabel": "Matthew 27:46",
      "text": "Et circa horam nonam clamavit Jesus voce magna, dicens: Eli, Eli, lamma sabacthani? hoc est: Deus meus, Deus meus, ut quid dereliquisti me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.47",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 47,
      "referenceLabel": "Matthew 27:47",
      "text": "Quidam autem illic stantes, et audientes, dicebant: Eliam vocat iste.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.48",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 48,
      "referenceLabel": "Matthew 27:48",
      "text": "Et continuo currens unus ex eis, acceptam spongiam implevit aceto, et imposuit arundini, et dabat ei bibere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.49",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 49,
      "referenceLabel": "Matthew 27:49",
      "text": "Ceteri vero dicebant: Sine, videamus an veniat Elias liberans eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.50",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 50,
      "referenceLabel": "Matthew 27:50",
      "text": "Jesus autem iterum clamans voce magna, emisit spiritum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.51",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 51,
      "referenceLabel": "Matthew 27:51",
      "text": "Et ecce velum templi scissum est in duas partes a summo usque deorsum: et terra mota est, et petræ scissæ sunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.52",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 52,
      "referenceLabel": "Matthew 27:52",
      "text": "et monumenta aperta sunt: et multa corpora sanctorum, qui dormierant, surrexerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.53",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 53,
      "referenceLabel": "Matthew 27:53",
      "text": "Et exeuntes de monumentis post resurrectionem ejus, venerunt in sanctam civitatem, et apparuerunt multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.54",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 54,
      "referenceLabel": "Matthew 27:54",
      "text": "Centurio autem, et qui cum eo erant, custodientes Jesum, viso terræmotu, et his quæ fiebant, timuerunt valde, dicentes: Vere Filius Dei erat iste.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.55",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 55,
      "referenceLabel": "Matthew 27:55",
      "text": "Erant autem ibi mulieres multæ a longe, quæ secutæ erant Jesum a Galilæa, ministrantes ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.56",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 56,
      "referenceLabel": "Matthew 27:56",
      "text": "inter quas erat Maria Magdalene, et Maria Jacobi, et Joseph mater, et mater filiorum Zebedæi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.57",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 57,
      "referenceLabel": "Matthew 27:57",
      "text": "Cum autem sero factum esset, venit quidam homo dives ab Arimathæa, nomine Joseph, qui et ipse discipulus erat Jesu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.58",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 58,
      "referenceLabel": "Matthew 27:58",
      "text": "hic accessit ad Pilatum, et petiit corpus Jesu. Tunc Pilatus jussit reddi corpus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.59",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 59,
      "referenceLabel": "Matthew 27:59",
      "text": "Et accepto corpore, Joseph involvit illud in sindone munda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.60",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 60,
      "referenceLabel": "Matthew 27:60",
      "text": "et posuit illud in monumento suo novo, quod exciderat in petra. Et advolvit saxum magnum ad ostium monumenti, et abiit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.61",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 61,
      "referenceLabel": "Matthew 27:61",
      "text": "Erant autem ibi Maria Magdalene, et altera Maria, sedentes contra sepulchrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.27.62",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 27,
      "verseNumber": 62,
