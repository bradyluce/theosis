{
  "chapter": {
    "id": "vulgate:matthew.7",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 7,
    "referenceLabel": "Matthew 7",
    "summary": "Source text for Matthew 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.7.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Matthew 7:1",
      "text": "Nolite judicare, ut non judicemini.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.7.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Matthew 7:2",
      "text": "In quo enim judicio judicaveritis, judicabimini: et in qua mensura mensi fueritis, remetietur vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Matthew 7:3",
      "text": "Quid autem vides festucam in oculo fratris tui, et trabem in oculo tuo non vides?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Matthew 7:4",
      "text": "aut quomodo dicis fratri tuo: Sine ejiciam festucam de oculo tuo, et ecce trabs est in oculo tuo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Matthew 7:5",
      "text": "Hypocrita, ejice primum trabem de oculo tuo, et tunc videbis ejicere festucam de oculo fratris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Matthew 7:6",
      "text": "Nolite dare sanctum canibus: neque mittatis margaritas vestras ante porcos, ne forte conculcent eas pedibus suis, et conversi dirumpant vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Matthew 7:7",
      "text": "Petite, et dabitur vobis: quærite, et invenietis: pulsate, et aperietur vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Matthew 7:8",
      "text": "Omnis enim qui petit, accipit: et qui quærit, invenit: et pulsanti aperietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Matthew 7:9",
      "text": "Aut quis est ex vobis homo, quem si petierit filius suus panem, numquid lapidem porriget ei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Matthew 7:10",
      "text": "aut si piscem petierit, numquid serpentem porriget ei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Matthew 7:11",
      "text": "Si ergo vos, cum sitis mali, nostis bona data dare filiis vestris: quanto magis Pater vester, qui in cælis est, dabit bona petentibus se?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Matthew 7:12",
      "text": "Omnia ergo quæcumque vultis ut faciant vobis homines, et vos facite illis. Hæc est enim lex, et prophetæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Matthew 7:13",
      "text": "Intrate per angustam portam: quia lata porta, et spatiosa via est, quæ ducit ad perditionem, et multi sunt qui intrant per eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Matthew 7:14",
      "text": "Quam angusta porta, et arcta via est, quæ ducit ad vitam: et pauci sunt qui inveniunt eam!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Matthew 7:15",
      "text": "Attendite a falsis prophetis, qui veniunt ad vos in vestimentis ovium, intrinsecus autem sunt lupi rapaces:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Matthew 7:16",
      "text": "a fructibus eorum cognoscetis eos. Numquid colligunt de spinis uvas, aut de tribulis ficus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Matthew 7:17",
      "text": "Sic omnis arbor bona fructus bonos facit: mala autem arbor malos fructus facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Matthew 7:18",
      "text": "Non potest arbor bona malos fructus facere: neque arbor mala bonos fructus facere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Matthew 7:19",
      "text": "Omnis arbor, quæ non facit fructum bonum, excidetur, et in ignem mittetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Matthew 7:20",
      "text": "Igitur ex fructibus eorum cognoscetis eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Matthew 7:21",
      "text": "Non omnis qui dicit mihi, Domine, Domine, intrabit in regnum cælorum: sed qui facit voluntatem Patris mei, qui in cælis est, ipse intrabit in regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Matthew 7:22",
      "text": "Multi dicent mihi in illa die: Domine, Domine, nonne in nomine tuo prophetavimus, et in nomine tuo dæmonia ejecimus, et in nomine tuo virtutes multas fecimus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Matthew 7:23",
      "text": "Et tunc confitebor illis: Quia numquam novi vos: discedite a me, qui operamini iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Matthew 7:24",
      "text": "Omnis ergo qui audit verba mea hæc, et facit ea, assimilabitur viro sapienti, qui ædificavit domum suam supra petram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Matthew 7:25",
      "text": "et descendit pluvia, et venerunt flumina, et flaverunt venti, et irruerunt in domum illam, et non cecidit: fundata enim erat super petram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Matthew 7:26",
      "text": "Et omnis qui audit verba mea hæc, et non facit ea, similis erit viro stulto, qui ædificavit domum suam super arenam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Matthew 7:27",
      "text": "et descendit pluvia, et venerunt flumina, et flaverunt venti, et irruerunt in domum illam, et cecidit, et fuit ruina illius magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Matthew 7:28",
      "text": "Et factum est: cum consummasset Jesus verba hæc, admirabantur turbæ super doctrina ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.7.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Matthew 7:29",
      "text": "Erat enim docens eos sicut potestatem habens, et non sicut scribæ eorum, et pharisæi.",
      "paragraphStart": false
    }
  ]
}
