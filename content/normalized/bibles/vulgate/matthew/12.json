{
  "chapter": {
    "id": "vulgate:matthew.12",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 12,
    "referenceLabel": "Matthew 12",
    "summary": "Source text for Matthew 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.12.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Matthew 12:1",
      "text": "In illo tempore abiit Jesus per sata sabbato: discipuli autem ejus esurientes cœperunt vellere spicas, et manducare.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.12.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Matthew 12:2",
      "text": "Pharisæi autem videntes, dixerunt ei: Ecce discipuli tui faciunt quod non licet facere sabbatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Matthew 12:3",
      "text": "At ille dixit eis: Non legistis quid fecerit David, quando esuriit, et qui cum eo erant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Matthew 12:4",
      "text": "quomodo intravit in domum Dei, et panes propositionis comedit, quos non licebat ei edere, neque his qui cum eo erant, nisi solis sacerdotibus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Matthew 12:5",
      "text": "aut non legistis in lege quia sabbatis sacerdotes in templo sabbatum violant, et sine crimine sunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Matthew 12:6",
      "text": "Dico autem vobis, quia templo major est hic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Matthew 12:7",
      "text": "Si autem sciretis, quid est: Misericordiam volo, et non sacrificium: numquam condemnassetis innocentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Matthew 12:8",
      "text": "dominus enim est Filius hominis etiam sabbati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Matthew 12:9",
      "text": "Et cum inde transisset, venit in synagogam eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Matthew 12:10",
      "text": "Et ecce homo manum habens aridam, et interrogabant eum, dicentes: Si licet sabbatis curare? ut accusarent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Matthew 12:11",
      "text": "Ipse autem dixit illis: Quis erit ex vobis homo, qui habeat ovem unam, et si ceciderit hæc sabbatis in foveam, nonne tenebit et levabit eam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Matthew 12:12",
      "text": "Quanto magis melior est homo ove? itaque licet sabbatis benefacere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Matthew 12:13",
      "text": "Tunc ait homini: Extende manum tuam. Et extendit, et restituta est sanitati sicut altera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Matthew 12:14",
      "text": "Exeuntes autem pharisæi, consilium faciebant adversus eum, quomodo perderent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Matthew 12:15",
      "text": "Jesus autem sciens recessit inde: et secuti sunt eum multi, et curavit eos omnes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Matthew 12:16",
      "text": "et præcepit eis ne manifestum eum facerent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Matthew 12:17",
      "text": "Ut adimpleretur quod dictum est per Isaiam prophetam, dicentem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Matthew 12:18",
      "text": "Ecce puer meus, quem elegi, dilectus meus, in quo bene complacuit animæ meæ. Ponam spiritum meum super eum, et judicium gentibus nuntiabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Matthew 12:19",
      "text": "Non contendet, neque clamabit, neque audiet aliquis in plateis vocem ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Matthew 12:20",
      "text": "arundinem quassatam non confringet, et linum fumigans non extinguet, donec ejiciat ad victoriam judicium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Matthew 12:21",
      "text": "et in nomine ejus gentes sperabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Matthew 12:22",
      "text": "Tunc oblatus est ei dæmonium habens, cæcus, et mutus, et curavit eum ita ut loqueretur, et videret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Matthew 12:23",
      "text": "Et stupebant omnes turbæ, et dicebant: Numquid hic est filius David?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Matthew 12:24",
      "text": "Pharisæi autem audientes, dixerunt: Hic non ejicit dæmones nisi in Beelzebub principe dæmoniorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Matthew 12:25",
      "text": "Jesus autem sciens cogitationes eorum, dixit eis: Omne regnum divisum contra se desolabitur: et omnis civitas vel domus divisa contra se, non stabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Matthew 12:26",
      "text": "Et si Satanas Satanam ejicit, adversus se divisus est: quomodo ergo stabit regnum ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Matthew 12:27",
      "text": "Et si ego in Beelzebub ejicio dæmones, filii vestri in quo ejiciunt? ideo ipsi judices vestri erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Matthew 12:28",
      "text": "Si autem ego in Spiritu Dei ejicio dæmones, igitur pervenit in vos regnum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Matthew 12:29",
      "text": "Aut quomodo potest quisquam intrare in domum fortis, et vasa ejus diripere, nisi prius alligaverit fortem? et tunc domum illius diripiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "Matthew 12:30",
      "text": "Qui non est mecum, contra me est; et qui non congregat mecum, spargit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "Matthew 12:31",
      "text": "Ideo dico vobis: Omne peccatum et blasphemia remittetur hominibus, Spiritus autem blasphemia non remittetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "Matthew 12:32",
      "text": "Et quicumque dixerit verbum contra Filium hominis, remittetur ei: qui autem dixerit contra Spiritum Sanctum, non remittetur ei, neque in hoc sæculo, neque in futuro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "Matthew 12:33",
      "text": "Aut facite arborem bonam, et fructum ejus bonum: aut facite arborem malam, et fructum ejus malum: siquidem ex fructu arbor agnoscitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "Matthew 12:34",
      "text": "Progenies viperarum, quomodo potestis bona loqui, cum sitis mali? ex abundantia enim cordis os loquitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "Matthew 12:35",
      "text": "Bonus homo de bono thesauro profert bona: et malus homo de malo thesauro profert mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "Matthew 12:36",
      "text": "Dico autem vobis quoniam omne verbum otiosum, quod locuti fuerint homines, reddent rationem de eo in die judicii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "Matthew 12:37",
      "text": "Ex verbis enim tuis justificaberis et ex verbis tuis condemnaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "Matthew 12:38",
      "text": "Tunc responderunt ei quidam de scribis et pharisæis, dicentes: Magister, volumus a te signum videre.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "Matthew 12:39",
      "text": "Qui respondens ait illis: Generatio mala et adultera signum quærit: et signum non dabitur ei, nisi signum Jonæ prophetæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "Matthew 12:40",
      "text": "Sicut enim fuit Jonas in ventre ceti tribus diebus, et tribus noctibus, sic erit Filius hominis in corde terræ tribus diebus et tribus noctibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "Matthew 12:41",
      "text": "Viri Ninivitæ surgent in judicio cum generatione ista, et condemnabunt eam: quia pœnitentiam egerunt in prædicatione Jonæ, et ecce plus quam Jonas hic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "Matthew 12:42",
      "text": "Regina austri surget in judicio cum generatione ista, et condemnabit eam: quia venit a finibus terræ audire sapientiam Salomonis, et ecce plus quam Salomon hic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "Matthew 12:43",
      "text": "Cum autem immundus spiritus exierit ab homine, ambulat per loca arida, quærens requiem, et non invenit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "Matthew 12:44",
      "text": "Tunc dicit: Revertar in domum meam, unde exivi. Et veniens invenit eam vacantem, scopis mundatam, et ornatam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "Matthew 12:45",
      "text": "Tunc vadit, et assumit septem alios spiritus secum nequiores se, et intrantes habitant ibi: et fiunt novissima hominis illius pejora prioribus. Sic erit et generationi huic pessimæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "Matthew 12:46",
      "text": "Adhuc eo loquente ad turbas, ecce mater ejus et fratres stabant foris, quærentes loqui ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.47",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "Matthew 12:47",
      "text": "Dixit autem ei quidam: Ecce mater tua, et fratres tui foris stant quærentes te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.48",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 48,
      "referenceLabel": "Matthew 12:48",
      "text": "At ipse respondens dicenti sibi, ait: Quæ est mater mea, et qui sunt fratres mei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.49",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 49,
      "referenceLabel": "Matthew 12:49",
      "text": "Et extendens manum in discipulos suos, dixit: Ecce mater mea, et fratres mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.12.50",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 12,
      "verseNumber": 50,
      "referenceLabel": "Matthew 12:50",
      "text": "Quicumque enim fecerit voluntatem Patris mei, qui in cælis est, ipse meus frater, et soror, et mater est.",
      "paragraphStart": false
    }
  ]
}
