{
  "chapter": {
    "id": "vulgate:matthew.1",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 1,
    "referenceLabel": "Matthew 1",
    "summary": "Source text for Matthew 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.1.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Matthew 1:1",
      "text": "Liber generationis Jesu Christi filii David, filii Abraham.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.1.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Matthew 1:2",
      "text": "Abraham genuit Isaac. Isaac autem genuit Jacob. Jacob autem genuit Judam, et fratres ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Matthew 1:3",
      "text": "Judas autem genuit Phares, et Zaram de Thamar. Phares autem genuit Esron. Esron autem genuit Aram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Matthew 1:4",
      "text": "Aram autem genuit Aminadab. Aminadab autem genuit Naasson. Naasson autem genuit Salmon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Matthew 1:5",
      "text": "Salmon autem genuit Booz de Rahab. Booz autem genuit Obed ex Ruth. Obed autem genuit Jesse. Jesse autem genuit David regem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Matthew 1:6",
      "text": "David autem rex genuit Salomonem ex ea quæ fuit Uriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Matthew 1:7",
      "text": "Salomon autem genuit Roboam. Roboam autem genuit Abiam. Abias autem genuit Asa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Matthew 1:8",
      "text": "Asa autem genuit Josophat. Josophat autem genuit Joram. Joram autem genuit Oziam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Matthew 1:9",
      "text": "Ozias autem genuit Joatham. Joatham autem genuit Achaz. Achaz autem genuit Ezechiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Matthew 1:10",
      "text": "Ezechias autem genuit Manassen. Manasses autem genuit Amon. Amon autem genuit Josiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Matthew 1:11",
      "text": "Josias autem genuit Jechoniam, et fratres ejus in transmigratione Babylonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Matthew 1:12",
      "text": "Et post transmigrationem Babylonis: Jechonias genuit Salathiel. Salathiel autem genuit Zorobabel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Matthew 1:13",
      "text": "Zorobabel autem genuit Abiud. Abiud autem genuit Eliacim. Eliacim autem genuit Azor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Matthew 1:14",
      "text": "Azor autem genuit Sadoc. Sadoc autem genuit Achim. Achim autem genuit Eliud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Matthew 1:15",
      "text": "Eliud autem genuit Eleazar. Eleazar autem genuit Mathan. Mathan autem genuit Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Matthew 1:16",
      "text": "Jacob autem genuit Joseph virum Mariæ, de qua natus est Jesus, qui vocatur Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Matthew 1:17",
      "text": "Omnes itaque generationes ab Abraham usque ad David, generationes quatuordecim: et a David usque ad transmigrationem Babylonis, generationes quatuordecim: et a transmigratione Babylonis usque ad Christum, generationes quatuordecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Matthew 1:18",
      "text": "Christi autem generatio sic erat: cum esset desponsata mater ejus Maria Joseph, antequam convenirent inventa est in utero habens de Spiritu Sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Matthew 1:19",
      "text": "Joseph autem vir ejus cum esset justus, et nollet eam traducere, voluit occulte dimittere eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Matthew 1:20",
      "text": "Hæc autem eo cogitante, ecce angelus Domini apparuit in somnis ei, dicens: Joseph, fili David, noli timere accipere Mariam conjugem tuam: quod enim in ea natum est, de Spiritu Sancto est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Matthew 1:21",
      "text": "Pariet autem filium: et vocabis nomen ejus Jesum: ipse enim salvum faciet populum suum a peccatis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Matthew 1:22",
      "text": "Hoc autem totum factum est, ut adimpleretur quod dictum est a Domino per prophetam dicentem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Matthew 1:23",
      "text": "Ecce virgo in utero habebit, et pariet filium: et vocabunt nomen ejus Emmanuel, quod est interpretatum Nobiscum Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Matthew 1:24",
      "text": "Exsurgens autem Joseph a somno, fecit sicut præcepit ei angelus Domini, et accepit conjugem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.1.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Matthew 1:25",
      "text": "Et non cognoscebat eam donec peperit filium suum primogenitum: et vocavit nomen ejus Jesum.",
      "paragraphStart": false
    }
  ]
}
