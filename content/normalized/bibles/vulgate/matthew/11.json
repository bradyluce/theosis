{
  "chapter": {
    "id": "vulgate:matthew.11",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 11,
    "referenceLabel": "Matthew 11",
    "summary": "Source text for Matthew 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.11.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Matthew 11:1",
      "text": "Et factum est, cum consummasset Jesus, præcipiens duodecim discipulis suis, transiit inde ut doceret, et prædicaret in civitatibus eorum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.11.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Matthew 11:2",
      "text": "Joannes autem cum audisset in vinculis opera Christi, mittens duos de discipulis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Matthew 11:3",
      "text": "ait illi: Tu es, qui venturus es, an alium exspectamus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Matthew 11:4",
      "text": "Et respondens Jesus ait illis: Euntes renuntiate Joanni quæ audistis, et vidistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Matthew 11:5",
      "text": "Cæci vident, claudi ambulant, leprosi mundantur, surdi audiunt, mortui resurgunt, pauperes evangelizantur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Matthew 11:6",
      "text": "et beatus est, qui non fuerit scandalizatus in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Matthew 11:7",
      "text": "Illis autem abeuntibus, cœpit Jesus dicere ad turbas de Joanne: Quid existis in desertum videre? arundinem vento agitatam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Matthew 11:8",
      "text": "Sed quid existis videre? hominem mollibus vestitum? Ecce qui mollibus vestiuntur, in domibus regum sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Matthew 11:9",
      "text": "Sed quid existis videre? prophetam? Etiam dico vobis, et plus quam prophetam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Matthew 11:10",
      "text": "Hic est enim de quo scriptum est: Ecce ego mitto angelum meum ante faciem tuam, qui præparabit viam tuam ante te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Matthew 11:11",
      "text": "Amen dico vobis, non surrexit inter natos mulierum major Joanne Baptista: qui autem minor est in regno cælorum, major est illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Matthew 11:12",
      "text": "A diebus autem Joannis Baptistæ usque nunc, regnum cælorum vim patitur, et violenti rapiunt illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Matthew 11:13",
      "text": "Omnes enim prophetæ et lex usque ad Joannem prophetaverunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Matthew 11:14",
      "text": "et si vultis recipere, ipse est Elias, qui venturus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Matthew 11:15",
      "text": "Qui habet aures audiendi, audiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Matthew 11:16",
      "text": "Cui autem similem æstimabo generationem istam? Similis est pueris sedentibus in foro: qui clamantes coæqualibus",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Matthew 11:17",
      "text": "dicunt: Cecinimus vobis, et non saltastis: lamentavimus, et non planxistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Matthew 11:18",
      "text": "Venit enim Joannes neque manducans, neque bibens, et dicunt: Dæmonium habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Matthew 11:19",
      "text": "Venit Filius hominis manducans, et bibens, et dicunt: Ecce homo vorax, et potator vini, publicanorum et peccatorum amicus. Et justificata est sapientia a filiis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Matthew 11:20",
      "text": "Tunc cœpit exprobrare civitatibus, in quibus factæ sunt plurimæ virtutes ejus, quia non egissent pœnitentiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Matthew 11:21",
      "text": "Væ tibi Corozain, væ tibi Bethsaida: quia, si in Tyro et Sidone factæ essent virtutes quæ factæ sunt in vobis, olim in cilicio et cinere pœnitentiam egissent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Matthew 11:22",
      "text": "Verumtamen dico vobis: Tyro et Sidoni remissius erit in die judicii, quam vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Matthew 11:23",
      "text": "Et tu Capharnaum, numquid usque in cælum exaltaberis? usque in infernum descendes, quia si in Sodomis factæ fuissent virtutes quæ factæ sunt in te, forte mansissent usque in hanc diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Matthew 11:24",
      "text": "Verumtamen dico vobis, quia terræ Sodomorum remissius erit in die judicii, quam tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Matthew 11:25",
      "text": "In illo tempore respondens Jesus dixit: Confiteor tibi, Pater, Domine cæli et terræ, quia abscondisti hæc a sapientibus, et prudentibus, et revelasti ea parvulis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Matthew 11:26",
      "text": "Ita Pater: quoniam sic fuit placitum ante te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Matthew 11:27",
      "text": "Omnia mihi tradita sunt a Patre meo. Et nemo novit Filium, nisi Pater: neque Patrem quis novit, nisi Filius, et cui voluerit Filius revelare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Matthew 11:28",
      "text": "Venite ad me omnes qui laboratis, et onerati estis, et ego reficiam vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Matthew 11:29",
      "text": "Tollite jugum meum super vos, et discite a me, quia mitis sum, et humilis corde: et invenietis requiem animabus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.11.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Matthew 11:30",
      "text": "Jugum enim meum suave est, et onus meum leve.",
      "paragraphStart": false
    }
  ]
}
