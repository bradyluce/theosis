{
  "chapter": {
    "id": "vulgate:matthew.8",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 8,
    "referenceLabel": "Matthew 8",
    "summary": "Source text for Matthew 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.8.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Matthew 8:1",
      "text": "Cum autem descendisset de monte, secutæ sunt eum turbæ multæ:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.8.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Matthew 8:2",
      "text": "et ecce leprosus veniens, adorabat eum, dicens: Domine, si vis, potes me mundare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Matthew 8:3",
      "text": "Et extendens Jesus manum, tetigit eum, dicens: Volo: mundare. Et confestim mundata est lepra ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Matthew 8:4",
      "text": "Et ait illi Jesus: Vide, nemini dixeris: sed vade, ostende te sacerdoti, et offer munus, quod præcepit Moyses, in testimonium illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Matthew 8:5",
      "text": "Cum autem introisset Capharnaum, accessit ad eum centurio, rogans eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Matthew 8:6",
      "text": "et dicens: Domine, puer meus jacet in domo paralyticus, et male torquetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Matthew 8:7",
      "text": "Et ait illi Jesus: Ego veniam, et curabo eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Matthew 8:8",
      "text": "Et respondens centurio, ait: Domine, non sum dignus ut intres sub tectum meum: sed tantum dic verbo, et sanabitur puer meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Matthew 8:9",
      "text": "Nam et ego homo sum sub potestate constitutus, habens sub me milites, et dico huic: Vade, et vadit: et alii: Veni, et venit: et servo meo: Fac hoc, et facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Matthew 8:10",
      "text": "Audiens autem Jesus miratus est, et sequentibus se dixit: Amen dico vobis, non inveni tantam fidem in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Matthew 8:11",
      "text": "Dico autem vobis, quod multi ab oriente et occidente venient, et recumbent cum Abraham, et Isaac, et Jacob in regno cælorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Matthew 8:12",
      "text": "filii autem regni ejicientur in tenebras exteriores: ibi erit fletus et stridor dentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Matthew 8:13",
      "text": "Et dixit Jesus centurioni: Vade, et sicut credidisti, fiat tibi. Et sanatus est puer in illa hora.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Matthew 8:14",
      "text": "Et cum venisset Jesus in domum Petri, vidit socrum ejus jacentem, et febricitantem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Matthew 8:15",
      "text": "et tetigit manum ejus, et dimisit eam febris, et surrexit, et ministrabat eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Matthew 8:16",
      "text": "Vespere autem facto, obtulerunt ei multos dæmonia habentes: et ejiciebat spiritus verbo, et omnes male habentes curavit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Matthew 8:17",
      "text": "ut adimpleretur quod dictum est per Isaiam prophetam, dicentem: Ipse infirmitates nostras accepit: et ægrotationes nostras portavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Matthew 8:18",
      "text": "Videns autem Jesus turbas multas circum se, jussit ire trans fretum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Matthew 8:19",
      "text": "Et accedens unus scriba, ait illi: Magister, sequar te, quocumque ieris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Matthew 8:20",
      "text": "Et dicit ei Jesus: Vulpes foveas habent, et volucres cæli nidos; Filius autem hominis non habet ubi caput reclinet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Matthew 8:21",
      "text": "Alius autem de discipulis ejus ait illi: Domine, permitte me primum ire, et sepelire patrem meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Matthew 8:22",
      "text": "Jesus autem ait illi: Sequere me, et dimitte mortuos sepelire mortuos suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Matthew 8:23",
      "text": "Et ascendente eo in naviculam, secuti sunt eum discipuli ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Matthew 8:24",
      "text": "et ecce motus magnus factus est in mari, ita ut navicula operiretur fluctibus: ipse vero dormiebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Matthew 8:25",
      "text": "Et accesserunt ad eum discipuli ejus, et suscitaverunt eum, dicentes: Domine, salva nos: perimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Matthew 8:26",
      "text": "Et dicit eis Jesus: Quid timidi estis, modicæ fidei? Tunc surgens imperavit ventis, et mari, et facta est tranquillitas magna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Matthew 8:27",
      "text": "Porro homines mirati sunt, dicentes: Qualis est hic, quia venti et mare obediunt ei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Matthew 8:28",
      "text": "Et cum venisset trans fretum in regionem Gerasenorum, occurrerunt ei duo habentes dæmonia, de monumentis exeuntes, sævi nimis, ita ut nemo posset transire per viam illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Matthew 8:29",
      "text": "Et ecce clamaverunt, dicentes: Quid nobis et tibi, Jesu fili Dei? Venisti huc ante tempus torquere nos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Matthew 8:30",
      "text": "Erat autem non longe ab illis grex multorum porcorum pascens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Matthew 8:31",
      "text": "Dæmones autem rogabant eum, dicentes: Si ejicis nos hinc, mitte nos in gregem porcorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Matthew 8:32",
      "text": "Et ait illis: Ite. At illi exeuntes abierunt in porcos, et ecce impetu abiit totus grex per præceps in mare: et mortui sunt in aquis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Matthew 8:33",
      "text": "Pastores autem fugerunt: et venientes in civitatem, nuntiaverunt omnia, et de eis qui dæmonia habuerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.8.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Matthew 8:34",
      "text": "Et ecce tota civitas exiit obviam Jesu: et viso eo, rogabant ut transiret a finibus eorum.",
      "paragraphStart": false
    }
  ]
}
