{
  "chapter": {
    "id": "vulgate:matthew.13",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 13,
    "referenceLabel": "Matthew 13",
    "summary": "Source text for Matthew 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.13.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Matthew 13:1",
      "text": "In illo die exiens Jesus de domo, sedebat secus mare.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.13.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Matthew 13:2",
      "text": "Et congregatæ sunt ad eum turbæ multæ, ita ut naviculam ascendens sederet: et omnis turba stabat in littore,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Matthew 13:3",
      "text": "et locutus est eis multa in parabolis, dicens: Ecce exiit qui seminat, seminare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Matthew 13:4",
      "text": "Et dum seminat, quædam ceciderunt secus viam, et venerunt volucres cæli, et comederunt ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Matthew 13:5",
      "text": "Alia autem ceciderunt in petrosa, ubi non habebant terram multam: et continuo exorta sunt, quia non habebant altitudinem terræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Matthew 13:6",
      "text": "sole autem orto æstuaverunt; et quia non habebant radicem, aruerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Matthew 13:7",
      "text": "Alia autem ceciderunt in spinas: et creverunt spinæ, et suffocaverunt ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Matthew 13:8",
      "text": "Alia autem ceciderunt in terram bonam: et dabant fructum, aliud centesimum, aliud sexagesimum, aliud trigesimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Matthew 13:9",
      "text": "Qui habet aures audiendi, audiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Matthew 13:10",
      "text": "Et accedentes discipuli dixerunt ei: Quare in parabolis loqueris eis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Matthew 13:11",
      "text": "Qui respondens, ait illis: Quia vobis datum est nosse mysteria regni cælorum: illis autem non est datum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Matthew 13:12",
      "text": "Qui enim habet, dabitur ei, et abundabit: qui autem non habet, et quod habet auferetur ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Matthew 13:13",
      "text": "Ideo in parabolis loquor eis: quia videntes non vident, et audientes non audiunt, neque intelligunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Matthew 13:14",
      "text": "Et adimpletur in eis prophetia Isaiæ, dicentis: Auditu audietis, et non intelligetis: et videntes videbitis, et non videbitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Matthew 13:15",
      "text": "Incrassatum est enim cor populi hujus, et auribus graviter audierunt, et oculos suos clauserunt: nequando videant oculis, et auribus audiant, et corde intelligant, et convertantur, et sanem eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Matthew 13:16",
      "text": "Vestri autem beati oculi quia vident, et aures vestræ quia audiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Matthew 13:17",
      "text": "Amen quippe dico vobis, quia multi prophetæ et justi cupierunt videre quæ videtis, et non viderunt: et audire quæ auditis, et non audierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Matthew 13:18",
      "text": "Vos ergo audite parabolam seminantis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Matthew 13:19",
      "text": "Omnis qui audit verbum regni, et non intelligit, venit malus, et rapit quod seminatum est in corde ejus: hic est qui secus viam seminatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Matthew 13:20",
      "text": "Qui autem super petrosa seminatus est, hic est qui verbum audit, et continuo cum gaudio accipit illud:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Matthew 13:21",
      "text": "non habet autem in se radicem, sed est temporalis: facta autem tribulatione et persecutione propter verbum, continuo scandalizatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Matthew 13:22",
      "text": "Qui autem seminatus est in spinis, hic est qui verbum audit, et sollicitudo sæculi istius, et fallacia divitiarum suffocat verbum, et sine fructu efficitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Matthew 13:23",
      "text": "Qui vero in terram bonam seminatus est, hic est qui audit verbum, et intelligit, et fructum affert, et facit aliud quidem centesimum, aliud autem sexagesimum, aliud vero trigesimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Matthew 13:24",
      "text": "Aliam parabolam proposuit illis, dicens: Simile factum est regnum cælorum homini, qui seminavit bonum semen in agro suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Matthew 13:25",
      "text": "cum autem dormirent homines, venit inimicus ejus, et superseminavit zizania in medio tritici, et abiit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Matthew 13:26",
      "text": "Cum autem crevisset herba, et fructum fecisset, tunc apparuerunt et zizania.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Matthew 13:27",
      "text": "Accedentes autem servi patrisfamilias, dixerunt ei: Domine, nonne bonum semen seminasti in agro tuo? unde ergo habet zizania?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Matthew 13:28",
      "text": "Et ait illis: Inimicus homo hoc fecit. Servi autem dixerunt ei: Vis, imus, et colligimus ea?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Matthew 13:29",
      "text": "Et ait: Non: ne forte colligentes zizania, eradicetis simul cum eis et triticum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Matthew 13:30",
      "text": "Sinite utraque crescere usque ad messem, et in tempore messis dicam messoribus: Colligite primum zizania, et alligate ea in fasciculos ad comburendum: triticum autem congregate in horreum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Matthew 13:31",
      "text": "Aliam parabolam proposuit eis dicens: Simile est regnum cælorum grano sinapis, quod accipiens homo seminavit in agro suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Matthew 13:32",
      "text": "quod minimum quidem est omnibus seminibus: cum autem creverit, majus est omnibus oleribus, et fit arbor, ita ut volucres cæli veniant, et habitent in ramis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Matthew 13:33",
      "text": "Aliam parabolam locutus est eis: Simile est regnum cælorum fermento, quod acceptum mulier abscondit in farinæ satis tribus, donec fermentatum est totum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Matthew 13:34",
      "text": "Hæc omnia locutus est Jesus in parabolis ad turbas: et sine parabolis non loquebatur eis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "Matthew 13:35",
      "text": "ut impleretur quod dictum erat per prophetam dicentem: Aperiam in parabolis os meum; eructabo abscondita a constitutione mundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "Matthew 13:36",
      "text": "Tunc, dimissis turbis, venit in domum: et accesserunt ad eum discipuli ejus, dicentes: Edissere nobis parabolam zizaniorum agri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "Matthew 13:37",
      "text": "Qui respondens ait illis: Qui seminat bonum semen, est Filius hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 38,
      "referenceLabel": "Matthew 13:38",
      "text": "Ager autem est mundus. Bonum vero semen, hi sunt filii regni. Zizania autem, filii sunt nequam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 39,
      "referenceLabel": "Matthew 13:39",
      "text": "Inimicus autem, qui seminavit ea, est diabolus. Messis vero, consummatio sæculi est. Messores autem, angeli sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 40,
      "referenceLabel": "Matthew 13:40",
      "text": "Sicut ergo colliguntur zizania, et igni comburuntur: sic erit in consummatione sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 41,
      "referenceLabel": "Matthew 13:41",
      "text": "Mittet Filius hominis angelos suos, et colligent de regno ejus omnia scandala, et eos qui faciunt iniquitatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 42,
      "referenceLabel": "Matthew 13:42",
      "text": "et mittent eos in caminum ignis. Ibi erit fletus et stridor dentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 43,
      "referenceLabel": "Matthew 13:43",
      "text": "Tunc justi fulgebunt sicut sol in regno Patris eorum. Qui habet aures audiendi, audiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 44,
      "referenceLabel": "Matthew 13:44",
      "text": "Simile est regnum cælorum thesauro abscondito in agro: quem qui invenit homo, abscondit, et præ gaudio illius vadit, et vendit universa quæ habet, et emit agrum illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 45,
      "referenceLabel": "Matthew 13:45",
      "text": "Iterum simile est regnum cælorum homini negotiatori, quærenti bonas margaritas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 46,
      "referenceLabel": "Matthew 13:46",
      "text": "Inventa autem una pretiosa margarita, abiit, et vendidit omnia quæ habuit, et emit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.47",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 47,
      "referenceLabel": "Matthew 13:47",
      "text": "Iterum simile est regnum cælorum sagenæ missæ in mare, et ex omni genere piscium congreganti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.48",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 48,
      "referenceLabel": "Matthew 13:48",
      "text": "Quam, cum impleta esset, educentes, et secus littus sedentes, elegerunt bonis in vasa, malos autem foras miserunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.49",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 49,
      "referenceLabel": "Matthew 13:49",
      "text": "Sic erit in consummatione sæculi: exibunt angeli, et separabunt malos de medio justorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.50",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 50,
      "referenceLabel": "Matthew 13:50",
      "text": "et mittent eos in caminum ignis: ibi erit fletus, et stridor dentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.51",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 51,
      "referenceLabel": "Matthew 13:51",
      "text": "Intellexistis hæc omnia? Dicunt ei: Etiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.52",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 52,
      "referenceLabel": "Matthew 13:52",
      "text": "Ait illis: Ideo omnis scriba doctus in regno cælorum, similis est homini patrifamilias, qui profert de thesauro suo nova et vetera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.53",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 53,
      "referenceLabel": "Matthew 13:53",
      "text": "Et factum est, cum consummasset Jesus parabolas istas, transiit inde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.54",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 54,
      "referenceLabel": "Matthew 13:54",
      "text": "Et veniens in patriam suam, docebat eos in synagogis eorum, ita ut mirarentur, et dicerent: Unde huic sapientia hæc, et virtutes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.55",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 55,
      "referenceLabel": "Matthew 13:55",
      "text": "Nonne hic est fabri filius? nonne mater ejus dicitur Maria, et fratres ejus, Jacobus, et Joseph, et Simon, et Judas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.56",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 56,
      "referenceLabel": "Matthew 13:56",
      "text": "et sorores ejus, nonne omnes apud nos sunt? unde ergo huic omnia ista?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.57",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 57,
      "referenceLabel": "Matthew 13:57",
      "text": "Et scandalizabantur in eo. Jesus autem dixit eis: Non est propheta sine honore, nisi in patria sua, et in domo sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.13.58",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 13,
      "verseNumber": 58,
      "referenceLabel": "Matthew 13:58",
      "text": "Et non fecit ibi virtutes multas propter incredulitatem illorum.",
      "paragraphStart": false
    }
  ]
}
