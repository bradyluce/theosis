{
  "chapter": {
    "id": "vulgate:matthew.26",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 26,
    "referenceLabel": "Matthew 26",
    "summary": "Source text for Matthew 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.26.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Matthew 26:1",
      "text": "Et factum est: cum consummasset Jesus sermones hos omnes, dixit discipulis suis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.26.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Matthew 26:2",
      "text": "Scitis quia post biduum Pascha fiet, et Filius hominis tradetur ut crucifigatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Matthew 26:3",
      "text": "Tunc congregati sunt principes sacerdotum, et seniores populi, in atrium principis sacerdotum, qui dicebatur Caiphas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Matthew 26:4",
      "text": "et consilium fecerunt ut Jesum dolo tenerent, et occiderent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Matthew 26:5",
      "text": "Dicebant autem: Non in die festo, ne forte tumultus fieret in populo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Matthew 26:6",
      "text": "Cum autem Jesus esset in Bethania in domo Simonis leprosi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Matthew 26:7",
      "text": "accessit ad eum mulier habens alabastrum unguenti pretiosi, et effudit super caput ipsius recumbentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Matthew 26:8",
      "text": "Videntes autem discipuli, indignati sunt, dicentes: Ut quid perditio hæc?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Matthew 26:9",
      "text": "potuit enim istud venundari multo, et dari pauperibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Matthew 26:10",
      "text": "Sciens autem Jesus, ait illis: Quid molesti estis huic mulieri? opus enim bonum operata est in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Matthew 26:11",
      "text": "Nam semper pauperes habetis vobiscum: me autem non semper habetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Matthew 26:12",
      "text": "Mittens enim hæc unguentum hoc in corpus meum, ad sepeliendum me fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Matthew 26:13",
      "text": "Amen dico vobis, ubicumque prædicatum fuerit hoc Evangelium in toto mundo, dicetur et quod hæc fecit in memoriam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Matthew 26:14",
      "text": "Tunc abiit unus de duodecim, qui dicebatur Judas Iscariotes, ad principes sacerdotum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Matthew 26:15",
      "text": "et ait illis: Quid vultis mihi dare, et ego vobis eum tradam? At illi constituerunt ei triginta argenteos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Matthew 26:16",
      "text": "Et exinde quærebat opportunitatem ut eum traderet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Matthew 26:17",
      "text": "Prima autem die azymorum accesserunt discipuli ad Jesum, dicentes: Ubi vis paremus tibi comedere Pascha?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Matthew 26:18",
      "text": "At Jesus dixit: Ite in civitatem ad quemdam, et dicite ei: Magister dicit: Tempus meum prope est, apud te facio Pascha cum discipulis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Matthew 26:19",
      "text": "Et fecerunt discipuli sicut constituit illis Jesus, et paraverunt Pascha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Matthew 26:20",
      "text": "Vespere autem facto, discumbebat cum duodecim discipulis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Matthew 26:21",
      "text": "Et edentibus illis, dixit: Amen dico vobis, quia unus vestrum me traditurus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Matthew 26:22",
      "text": "Et contristati valde, cœperunt singuli dicere: Numquid ego sum Domine?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Matthew 26:23",
      "text": "At ipse respondens, ait: Qui intingit mecum manum in paropside, hic me tradet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Matthew 26:24",
      "text": "Filius quidem hominis vadit, sicut scriptum est de illo: væ autem homini illi, per quem Filius hominis tradetur! bonum erat ei, si natus non fuisset homo ille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Matthew 26:25",
      "text": "Respondens autem Judas, qui tradidit eum, dixit: Numquid ego sum Rabbi? Ait illi: Tu dixisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Matthew 26:26",
      "text": "Cœnantibus autem eis, accepit Jesus panem, et benedixit, ac fregit, deditque discipulis suis, et ait: Accipite, et comedite: hoc est corpus meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Matthew 26:27",
      "text": "Et accipiens calicem, gratias egit: et dedit illis, dicens: Bibite ex hoc omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Matthew 26:28",
      "text": "Hic est enim sanguis meus novi testamenti, qui pro multis effundetur in remissionem peccatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 29,
      "referenceLabel": "Matthew 26:29",
      "text": "Dico autem vobis: non bibam amodo de hoc genimine vitis usque in diem illum, cum illud bibam vobiscum novum in regno Patris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 30,
      "referenceLabel": "Matthew 26:30",
      "text": "Et hymno dicto, exierunt in montem Oliveti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 31,
      "referenceLabel": "Matthew 26:31",
      "text": "Tunc dicit illis Jesus: Omnes vos scandalum patiemini in me in ista nocte. Scriptum est enim: Percutiam pastorem, et dispergentur oves gregis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 32,
      "referenceLabel": "Matthew 26:32",
      "text": "Postquam autem resurrexero, præcedam vos in Galilæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 33,
      "referenceLabel": "Matthew 26:33",
      "text": "Respondens autem Petrus, ait illi: Et si omnes scandalizati fuerint in te, ego numquam scandalizabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 34,
      "referenceLabel": "Matthew 26:34",
      "text": "Ait illi Jesus: Amen dico tibi, quia in hac nocte, antequam gallus cantet, ter me negabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 35,
      "referenceLabel": "Matthew 26:35",
      "text": "Ait illi Petrus: Etiamsi oportuerit me mori tecum, non te negabo. Similiter et omnes discipuli dixerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 36,
      "referenceLabel": "Matthew 26:36",
      "text": "Tunc venit Jesus cum illis in villam, quæ dicitur Gethsemani, et dixit discipulis suis: Sedete hic donec vadam illuc, et orem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 37,
      "referenceLabel": "Matthew 26:37",
      "text": "Et assumpto Petro, et duobus filiis Zebedæi, cœpit contristari et mœstus esse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 38,
      "referenceLabel": "Matthew 26:38",
      "text": "Tunc ait illis: Tristis est anima mea usque ad mortem: sustinete hic, et vigilate mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 39,
      "referenceLabel": "Matthew 26:39",
      "text": "Et progressus pusillum, procidit in faciem suam, orans, et dicens: Pater mi, si possibile est, transeat a me calix iste: verumtamen non sicut ego volo, sed sicut tu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 40,
      "referenceLabel": "Matthew 26:40",
      "text": "Et venit ad discipulos suos, et invenit eos dormientes, et dicit Petro: Sic non potuistis una hora vigilare mecum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 41,
      "referenceLabel": "Matthew 26:41",
      "text": "Vigilate, et orate ut non intretis in tentationem. Spiritus quidem promptus est, caro autem infirma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 42,
      "referenceLabel": "Matthew 26:42",
      "text": "Iterum secundo abiit, et oravit, dicens: Pater mi, si non potest hic calix transire nisi bibam illum, fiat voluntas tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 43,
      "referenceLabel": "Matthew 26:43",
      "text": "Et venit iterum, et invenit eos dormientes: erant enim oculi eorum gravati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 44,
      "referenceLabel": "Matthew 26:44",
      "text": "Et relictis illis, iterum abiit, et oravit tertio, eumdem sermonem dicens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 45,
      "referenceLabel": "Matthew 26:45",
      "text": "Tunc venit ad discipulos suos, et dicit illis: Dormite jam, et requiescite: ecce appropinquavit hora, et Filius hominis tradetur in manus peccatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 46,
      "referenceLabel": "Matthew 26:46",
      "text": "Surgite, eamus: ecce appropinquavit qui me tradet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.47",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 47,
      "referenceLabel": "Matthew 26:47",
      "text": "Adhuc eo loquente, ecce Judas unus de duodecim venit, et cum eo turba multa cum gladiis et fustibus, missi a principibus sacerdotum, et senioribus populi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.48",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 48,
      "referenceLabel": "Matthew 26:48",
      "text": "Qui autem tradidit eum, dedit illis signum, dicens: Quemcumque osculatus fuero, ipse est, tenete eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.49",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 49,
      "referenceLabel": "Matthew 26:49",
      "text": "Et confestim accedens ad Jesum, dixit: Ave Rabbi. Et osculatus est eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.50",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 50,
      "referenceLabel": "Matthew 26:50",
      "text": "Dixitque illi Jesus: Amice, ad quid venisti? Tunc accesserunt, et manus injecerunt in Jesum, et tenuerunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.51",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 51,
      "referenceLabel": "Matthew 26:51",
      "text": "Et ecce unus ex his qui erant cum Jesu, extendens manum, exemit gladium suum, et percutiens servum principis sacerdotum amputavit auriculam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.52",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 52,
      "referenceLabel": "Matthew 26:52",
      "text": "Tunc ait illi Jesus: Converte gladium tuum in locum suum: omnes enim, qui acceperint gladium, gladio peribunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.53",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 53,
      "referenceLabel": "Matthew 26:53",
      "text": "An putas, quia non possum rogare patrem meum, et exhibebit mihi modo plusquam duodecim legiones angelorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.54",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 54,
      "referenceLabel": "Matthew 26:54",
      "text": "Quomodo ergo implebuntur Scripturæ, quia sic oportet fieri?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.55",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 55,
      "referenceLabel": "Matthew 26:55",
      "text": "In illa hora dixit Jesus turbis: Tamquam ad latronem existis cum gladiis et fustibus comprehendere me: quotidie apud vos sedebam docens in templo, et non me tenuistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.56",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 56,
      "referenceLabel": "Matthew 26:56",
      "text": "Hoc autem totum factum est, ut adimplerentur Scripturæ prophetarum. Tunc discipuli omnes, relicto eo, fugerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.57",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 57,
      "referenceLabel": "Matthew 26:57",
      "text": "At illi tenentes Jesum, duxerunt ad Caipham principem sacerdotum, ubi scribæ et seniores convenerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.58",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 58,
      "referenceLabel": "Matthew 26:58",
      "text": "Petrus autem sequebatur eum a longe, usque in atrium principis sacerdotum. Et ingressus intro, sedebat cum ministris, ut videret finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.59",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 59,
      "referenceLabel": "Matthew 26:59",
      "text": "Principes autem sacerdotum, et omne concilium, quærebant falsum testimonium contra Jesum, ut eum morti traderent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.60",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 60,
      "referenceLabel": "Matthew 26:60",
      "text": "et non invenerunt, cum multi falsi testes accessissent. Novissime autem venerunt duo falsi testes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.61",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 61,
      "referenceLabel": "Matthew 26:61",
      "text": "et dixerunt: Hic dixit: Possum destruere templum Dei, et post triduum reædificare illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.62",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 62,
      "referenceLabel": "Matthew 26:62",
      "text": "Et surgens princeps sacerdotum, ait illi: Nihil respondes ad ea, quæ isti adversum te testificantur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.63",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 63,
      "referenceLabel": "Matthew 26:63",
      "text": "Jesus autem tacebat. Et princeps sacerdotum ait illi: Adjuro te per Deum vivum, ut dicas nobis si tu es Christus Filius Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.64",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 64,
      "referenceLabel": "Matthew 26:64",
      "text": "Dicit illi Jesus: Tu dixisti. Verumtamen dico vobis, amodo videbitis Filium hominis sedentem a dextris virtutis Dei, et venientem in nubibus cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.65",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 65,
      "referenceLabel": "Matthew 26:65",
      "text": "Tunc princeps sacerdotum scidit vestimenta sua, dicens: Blasphemavit: quid adhuc egemus testibus? ecce nunc audistis blasphemiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.66",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 66,
      "referenceLabel": "Matthew 26:66",
      "text": "quid vobis videtur? At illi respondentes dixerunt: Reus est mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.67",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 67,
      "referenceLabel": "Matthew 26:67",
      "text": "Tunc exspuerunt in faciem ejus, et colaphis eum ceciderunt, alii autem palmas in faciem ejus dederunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.68",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 68,
      "referenceLabel": "Matthew 26:68",
      "text": "dicentes: Prophetiza nobis Christe, quis est qui te percussit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.69",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 69,
      "referenceLabel": "Matthew 26:69",
      "text": "Petrus vero sedebat foris in atrio: et accessit ad eum una ancilla, dicens: Et tu cum Jesu Galilæo eras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.70",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 70,
      "referenceLabel": "Matthew 26:70",
      "text": "At ille negavit coram omnibus, dicens: Nescio quid dicis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.71",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 71,
      "referenceLabel": "Matthew 26:71",
      "text": "Exeunte autem illo januam, vidit eum alia ancilla, et ait his qui erant ibi: Et hic erat cum Jesu Nazareno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.72",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 72,
      "referenceLabel": "Matthew 26:72",
      "text": "Et iterum negavit cum juramento: Quia non novi hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.73",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 73,
      "referenceLabel": "Matthew 26:73",
      "text": "Et post pusillum accesserunt qui stabant, et dixerunt Petro: Vere et tu ex illis es: nam et loquela tua manifestum te facit.",
