    },
    {
      "id": "vulgate:matthew.26.74",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 74,
      "referenceLabel": "Matthew 26:74",
      "text": "Tunc cœpit detestari et jurare quia non novisset hominem. Et continuo gallus cantavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.26.75",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 75,
      "referenceLabel": "Matthew 26:75",
      "text": "Et recordatus est Petrus verbi Jesu, quod dixerat: Priusquam gallus cantet, ter me negabis. Et egressus foras, flevit amare.",
