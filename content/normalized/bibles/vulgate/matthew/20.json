{
  "chapter": {
    "id": "vulgate:matthew.20",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 20,
    "referenceLabel": "Matthew 20",
    "summary": "Source text for Matthew 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.20.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Matthew 20:1",
      "text": "Simile est regnum cælorum homini patrifamilias, qui exiit primo mane conducere operarios in vineam suam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.20.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Matthew 20:2",
      "text": "Conventione autem facta cum operariis ex denario diurno, misit eos in vineam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Matthew 20:3",
      "text": "Et egressus circa horam tertiam, vidit alios stantes in foro otiosos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Matthew 20:4",
      "text": "et dixit illis: Ite et vos in vineam meam, et quod justum fuerit dabo vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Matthew 20:5",
      "text": "Illi autem abierunt. Iterum autem exiit circa sextam et nonam horam: et fecit similiter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Matthew 20:6",
      "text": "Circa undecimam vero exiit, et invenit alios stantes, et dicit illis: Quid hic statis tota die otiosi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Matthew 20:7",
      "text": "Dicunt ei: Quia nemo nos conduxit. Dicit illis: Ite et vos in vineam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Matthew 20:8",
      "text": "Cum sero autem factum esset, dicit dominus vineæ procuratori suo: Voca operarios, et redde illis mercedem incipiens a novissimis usque ad primos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Matthew 20:9",
      "text": "Cum venissent ergo qui circa undecimam horam venerant, acceperunt singulos denarios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Matthew 20:10",
      "text": "Venientes autem et primi, arbitrati sunt quod plus essent accepturi: acceperunt autem et ipsi singulos denarios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Matthew 20:11",
      "text": "Et accipientes murmurabant adversus patremfamilias,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Matthew 20:12",
      "text": "dicentes: Hi novissimi una hora fecerunt, et pares illos nobis fecisti, qui portavimus pondus diei, et æstus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Matthew 20:13",
      "text": "At ille respondens uni eorum, dixit: Amice, non facio tibi injuriam: nonne ex denario convenisti mecum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Matthew 20:14",
      "text": "Tolle quod tuum est, et vade: volo autem et huic novissimo dare sicut et tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Matthew 20:15",
      "text": "Aut non licet mihi quod volo, facere? an oculus tuus nequam est, quia ego bonus sum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Matthew 20:16",
      "text": "Sic erunt novissimi primi, et primi novissimi. Multi enim sunt vocati, pauci vero electi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Matthew 20:17",
      "text": "Et ascendens Jesus Jerosolymam, assumpsit duodecim discipulos secreto, et ait illis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Matthew 20:18",
      "text": "Ecce ascendimus Jerosolymam, et Filius hominis tradetur principibus sacerdotum, et scribis, et condemnabunt eum morte,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Matthew 20:19",
      "text": "et tradent eum gentibus ad illudendum, et flagellandum, et crucifigendum, et tertia die resurget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Matthew 20:20",
      "text": "Tunc accessit ad eum mater filiorum Zebedæi cum filiis suis, adorans et petens aliquid ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Matthew 20:21",
      "text": "Qui dixit ei: Quid vis? Ait illi: Dic ut sedeant hi duo filii mei, unus ad dexteram tuam, et unus ad sinistram in regno tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Matthew 20:22",
      "text": "Respondens autem Jesus, dixit: Nescitis quid petatis. Potestis bibere calicem, quem ego bibiturus sum? Dicunt ei: Possumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Matthew 20:23",
      "text": "Ait illis: Calicem quidem meum bibetis: sedere autem ad dexteram meam vel sinistram non est meum dare vobis, sed quibus paratum est a Patre meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Matthew 20:24",
      "text": "Et audientes decem, indignati sunt de duobus fratribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Matthew 20:25",
      "text": "Jesus autem vocavit eos ad se, et ait: Scitis quia principes gentium dominantur eorum: et qui majores sunt, potestatem exercent in eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Matthew 20:26",
      "text": "Non ita erit inter vos: sed quicumque voluerit inter vos major fieri, sit vester minister:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Matthew 20:27",
      "text": "et qui voluerit inter vos primus esse, erit vester servus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Matthew 20:28",
      "text": "Sicut Filius hominis non venit ministrari, sed ministrare, et dare animam suam redemptionem pro multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Matthew 20:29",
      "text": "Et egredientibus illis ab Jericho, secuta est eum turba multa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Matthew 20:30",
      "text": "et ecce duo cæci sedentes secus viam audierunt quia Jesus transiret: et clamaverunt, dicentes: Domine, miserere nostri, fili David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Matthew 20:31",
      "text": "Turba autem increpabat eos ut tacerent. At illi magis clamabant, dicentes: Domine, miserere nostri, fili David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Matthew 20:32",
      "text": "Et stetit Jesus, et vocavit eos, et ait: Quid vultis ut faciam vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Matthew 20:33",
      "text": "Dicunt illi: Domine, ut aperiantur oculi nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.20.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 34,
      "referenceLabel": "Matthew 20:34",
      "text": "Misertus autem eorum Jesus, tetigit oculos eorum. Et confestim viderunt, et secuti sunt eum.",
      "paragraphStart": false
    }
  ]
}
