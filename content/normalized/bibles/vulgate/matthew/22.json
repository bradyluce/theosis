{
  "chapter": {
    "id": "vulgate:matthew.22",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 22,
    "referenceLabel": "Matthew 22",
    "summary": "Source text for Matthew 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.22.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Matthew 22:1",
      "text": "Et respondens Jesus, dixit iterum in parabolis eis, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.22.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Matthew 22:2",
      "text": "Simile factum est regnum cælorum homini regi, qui fecit nuptias filio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Matthew 22:3",
      "text": "Et misit servos suos vocare invitatos ad nuptias, et nolebant venire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Matthew 22:4",
      "text": "Iterum misit alios servos, dicens: Dicite invitatis: Ecce prandium meum paravi, tauri mei et altilia occisa sunt, et omnia parata: venite ad nuptias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Matthew 22:5",
      "text": "Illi autem neglexerunt: et abierunt, alius in villam suam, alius vero ad negotiationem suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Matthew 22:6",
      "text": "reliqui vero tenuerunt servos ejus, et contumeliis affectos occiderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Matthew 22:7",
      "text": "Rex autem cum audisset, iratus est: et missis exercitibus suis, perdidit homicidas illos, et civitatem illorum succendit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Matthew 22:8",
      "text": "Tunc ait servis suis: Nuptiæ quidem paratæ sunt, sed qui invitati erant, non fuerunt digni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Matthew 22:9",
      "text": "ite ergo ad exitus viarum, et quoscumque inveneritis, vocate ad nuptias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Matthew 22:10",
      "text": "Et egressi servi ejus in vias, congregaverunt omnes quos invenerunt, malos et bonos: et impletæ sunt nuptiæ discumbentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Matthew 22:11",
      "text": "Intravit autem rex ut videret discumbentes, et vidit ibi hominem non vestitum veste nuptiali.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Matthew 22:12",
      "text": "Et ait illi: Amice, quomodo huc intrasti non habens vestem nuptialem? At ille obmutuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Matthew 22:13",
      "text": "Tunc dicit rex ministris: Ligatis manibus et pedibus ejus, mittite eum in tenebras exteriores: ibi erit fletus et stridor dentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Matthew 22:14",
      "text": "Multi enim sunt vocati, pauci vero electi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Matthew 22:15",
      "text": "Tunc abeuntes pharisæi, consilium inierunt ut caperent eum in sermone.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Matthew 22:16",
      "text": "Et mittunt ei discipulos suos cum Herodianis, dicentes: Magister, scimus quia verax es, et viam Dei in veritate doces, et non est tibi cura de aliquo: non enim respicis personam hominum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Matthew 22:17",
      "text": "dic ergo nobis quid tibi videtur, licet censum dare Cæsari, an non?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Matthew 22:18",
      "text": "Cognita autem Jesus nequitia eorum, ait: Quid me tentatis, hypocritæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Matthew 22:19",
      "text": "ostendite mihi numisma census. At illi obtulerunt ei denarium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Matthew 22:20",
      "text": "Et ait illis Jesus: Cujus est imago hæc, et superscriptio?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Matthew 22:21",
      "text": "Dicunt ei: Cæsaris. Tunc ait illis: Reddite ergo quæ sunt Cæsaris, Cæsari: et quæ sunt Dei, Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Matthew 22:22",
      "text": "Et audientes mirati sunt, et relicto eo abierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Matthew 22:23",
      "text": "In illo die accesserunt ad eum sadducæi, qui dicunt non esse resurrectionem: et interrogaverunt eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Matthew 22:24",
      "text": "dicentes: Magister, Moyses dixit: Si quis mortuus fuerit non habens filium, ut ducat frater ejus uxorem illius, et suscitet semen fratri suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Matthew 22:25",
      "text": "Erant autem apud nos septem fratres: et primus, uxore ducta, defunctus est: et non habens semen, reliquit uxorem suam fratri suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Matthew 22:26",
      "text": "Similiter secundus, et tertius usque ad septimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Matthew 22:27",
      "text": "Novissime autem omnium et mulier defuncta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Matthew 22:28",
      "text": "In resurrectione ergo cujus erit de septem uxor? omnes enim habuerunt eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Matthew 22:29",
      "text": "Respondens autem Jesus, ait illis: Erratis nescientes Scripturas, neque virtutem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Matthew 22:30",
      "text": "In resurrectione enim neque nubent, neque nubentur: sed erunt sicut angeli Dei in cælo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Matthew 22:31",
      "text": "De resurrectione autem mortuorum non legistis quod dictum est a Deo dicente vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "Matthew 22:32",
      "text": "Ego sum Deus Abraham, et Deus Isaac, et Deus Jacob? Non est Deus mortuorum, sed viventium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "Matthew 22:33",
      "text": "Et audientes turbæ, mirabantur in doctrina ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "Matthew 22:34",
      "text": "Pharisæi autem audientes quod silentium imposuisset sadducæis, convenerunt in unum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "Matthew 22:35",
      "text": "et interrogavit eum unus ex eis legis doctor, tentans eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "Matthew 22:36",
      "text": "Magister, quod est mandatum magnum in lege?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "Matthew 22:37",
      "text": "Ait illi Jesus: Diliges Dominum Deum tuum ex toto corde tuo, et in tota anima tua, et in tota mente tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "Matthew 22:38",
      "text": "Hoc est maximum, et primum mandatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "Matthew 22:39",
      "text": "Secundum autem simile est huic: Diliges proximum tuum, sicut teipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "Matthew 22:40",
      "text": "In his duobus mandatis universa lex pendet, et prophetæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 41,
      "referenceLabel": "Matthew 22:41",
      "text": "Congregatis autem pharisæis, interrogavit eos Jesus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 42,
      "referenceLabel": "Matthew 22:42",
      "text": "dicens: Quid vobis videtur de Christo? cujus filius est? Dicunt ei: David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 43,
      "referenceLabel": "Matthew 22:43",
      "text": "Ait illis: Quomodo ergo David in spiritu vocat eum Dominum, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 44,
      "referenceLabel": "Matthew 22:44",
      "text": "Dixit Dominus Domino meo: Sede a dextris meis, donec ponam inimicos tuos scabellum pedum tuorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 45,
      "referenceLabel": "Matthew 22:45",
      "text": "Si ergo David vocat eum Dominum, quomodo filius ejus est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.22.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 46,
      "referenceLabel": "Matthew 22:46",
      "text": "Et nemo poterat ei respondere verbum: neque ausus fuit quisquam ex illa die eum amplius interrogare.",
      "paragraphStart": false
    }
  ]
}
