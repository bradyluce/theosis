{
  "chapter": {
    "id": "vulgate:matthew.9",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 9,
    "referenceLabel": "Matthew 9",
    "summary": "Source text for Matthew 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.9.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Matthew 9:1",
      "text": "Et ascendens in naviculam, transfretavit, et venit in civitatem suam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.9.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Matthew 9:2",
      "text": "Et ecce offerebant ei paralyticum jacentem in lecto. Et videns Jesus fidem illorum, dixit paralytico: Confide fili, remittuntur tibi peccata tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Matthew 9:3",
      "text": "Et ecce quidam de scribis dixerunt intra se: Hic blasphemat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Matthew 9:4",
      "text": "Et cum vidisset Jesus cogitationes eorum, dixit: Ut quid cogitatis mala in cordibus vestris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Matthew 9:5",
      "text": "Quid est facilius dicere: Dimittuntur tibi peccata tua: an dicere: Surge, et ambula?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Matthew 9:6",
      "text": "Ut autem sciatis, quia Filius hominis habet potestatem in terra dimittendi peccata, tunc ait paralytico: Surge, tolle lectum tuum, et vade in domum tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Matthew 9:7",
      "text": "Et surrexit, et abiit in domum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Matthew 9:8",
      "text": "Videntes autem turbæ timuerunt, et glorificaverunt Deum, qui dedit potestatem talem hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Matthew 9:9",
      "text": "Et, cum transiret inde Jesus, vidit hominem sedentem in telonio, Matthæum nomine. Et ait illi: Sequere me. Et surgens, secutus est eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Matthew 9:10",
      "text": "Et factum est, discumbente eo in domo, ecce multi publicani et peccatores venientes, discumbebant cum Jesu, et discipulis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Matthew 9:11",
      "text": "Et videntes pharisæi, dicebant discipulis ejus: Quare cum publicanis et peccatoribus manducat magister vester?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Matthew 9:12",
      "text": "At Jesus audiens, ait: Non est opus valentibus medicus, sed male habentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Matthew 9:13",
      "text": "Euntes autem discite quid est: Misericordiam volo, et non sacrificium. Non enim veni vocare justos, sed peccatores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Matthew 9:14",
      "text": "Tunc accesserunt ad eum discipuli Joannis, dicentes: Quare nos, et pharisæi, jejunamus frequenter: discipuli autem tui non jejunant?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Matthew 9:15",
      "text": "Et ait illis Jesus: Numquid possunt filii sponsi lugere, quamdiu cum illis est sponsus? Venient autem dies cum auferetur ab eis sponsus: et tunc jejunabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Matthew 9:16",
      "text": "Nemo autem immittit commissuram panni rudis in vestimentum vetus: tollit enim plenitudinem ejus a vestimento, et pejor scissura fit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Matthew 9:17",
      "text": "Neque mittunt vinum novum in utres veteres: alioquin rumpuntur utres, et vinum effunditur, et utres pereunt. Sed vinum novum in utres novos mittunt: et ambo conservantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Matthew 9:18",
      "text": "Hæc illo loquente ad eos, ecce princeps unus accessit, et adorabat eum, dicens: Domine, filia mea modo defuncta est: sed veni, impone manum tuam super eam, et vivet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Matthew 9:19",
      "text": "Et surgens Jesus, sequebatur eum, et discipuli ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Matthew 9:20",
      "text": "Et ecce mulier, quæ sanguinis fluxum patiebatur duodecim annis, accessit retro, et tetigit fimbriam vestimenti ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Matthew 9:21",
      "text": "Dicebat enim intra se: Si tetigero tantum vestimentum ejus, salva ero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Matthew 9:22",
      "text": "At Jesus conversus, et videns eam, dixit: Confide, filia, fides tua te salvam fecit. Et salva facta est mulier ex illa hora.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Matthew 9:23",
      "text": "Et cum venisset Jesus in domum principis, et vidisset tibicines et turbam tumultuantem, dicebat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Matthew 9:24",
      "text": "Recedite: non est enim mortua puella, sed dormit. Et deridebant eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Matthew 9:25",
      "text": "Et cum ejecta esset turba, intravit: et tenuit manum ejus, et surrexit puella.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Matthew 9:26",
      "text": "Et exiit fama hæc in universam terram illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Matthew 9:27",
      "text": "Et transeunte inde Jesu, secuti sunt eum duo cæci, clamantes, et dicentes: Miserere nostri, fili David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Matthew 9:28",
      "text": "Cum autem venisset domum, accesserunt ad eum cæci. Et dicit eis Jesus: Creditis quia hoc possum facere vobis? Dicunt ei: Utique, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Matthew 9:29",
      "text": "Tunc tetigit oculos eorum, dicens: Secundum fidem vestram, fiat vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Matthew 9:30",
      "text": "Et aperti sunt oculi eorum: et comminatus est illis Jesus, dicens: Videte ne quis sciat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Matthew 9:31",
      "text": "Illi autem exeuntes, diffamaverunt eum in tota terra illa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Matthew 9:32",
      "text": "Egressis autem illis, ecce obtulerunt ei hominem mutum, dæmonium habentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Matthew 9:33",
      "text": "Et ejecto dæmonio, locutus est mutus, et miratæ sunt turbæ, dicentes: Numquam apparuit sic in Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Matthew 9:34",
      "text": "Pharisæi autem dicebant: In principe dæmoniorum ejicit dæmones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Matthew 9:35",
      "text": "Et circuibat Jesus omnes civitates, et castella, docens in synagogis eorum, et prædicans Evangelium regni, et curans omnem languorem, et omnem infirmitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "Matthew 9:36",
      "text": "Videns autem turbas, misertus est eis: quia erant vexati, et jacentes sicut oves non habentes pastorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "Matthew 9:37",
      "text": "Tunc dicit discipulis suis: Messis quidem multa, operarii autem pauci.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.9.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "Matthew 9:38",
      "text": "Rogate ergo Dominum messis, ut mittat operarios in messem suam.",
      "paragraphStart": false
    }
  ]
}
