{
  "chapter": {
    "id": "vulgate:matthew.19",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 19,
    "referenceLabel": "Matthew 19",
    "summary": "Source text for Matthew 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.19.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Matthew 19:1",
      "text": "Et factum est, cum consummasset Jesus sermones istos, migravit a Galilæa, et venit in fines Judææ trans Jordanem,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.19.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Matthew 19:2",
      "text": "et secutæ sunt eum turbæ multæ, et curavit eos ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Matthew 19:3",
      "text": "Et accesserunt ad eum pharisæi tentantes eum, et dicentes: Si licet homini dimittere uxorem suam, quacumque ex causa?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Matthew 19:4",
      "text": "Qui respondens, ait eis: Non legistis, quia qui fecit hominem ab initio, masculum et feminam fecit eos? Et dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Matthew 19:5",
      "text": "Propter hoc dimittet homo patrem, et matrem, et adhærebit uxori suæ, et erunt duo in carne una.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Matthew 19:6",
      "text": "Itaque jam non sunt duo, sed una caro. Quod ergo Deus conjunxit, homo non separet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Matthew 19:7",
      "text": "Dicunt illi: Quid ergo Moyses mandavit dare libellum repudii, et dimittere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Matthew 19:8",
      "text": "Ait illis: Quoniam Moyses ad duritiam cordis vestri permisit vobis dimittere uxores vestras: ab initio autem non fuit sic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Matthew 19:9",
      "text": "Dico autem vobis, quia quicumque dimiserit uxorem suam, nisi ob fornicationem, et aliam duxerit, mœchatur: et qui dimissam duxerit, mœchatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Matthew 19:10",
      "text": "Dicunt ei discipuli ejus: Si ita est causa hominis cum uxore, non expedit nubere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Matthew 19:11",
      "text": "Qui dixit illis: Non omnes capiunt verbum istud, sed quibus datum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Matthew 19:12",
      "text": "Sunt enim eunuchi, qui de matris utero sic nati sunt: et sunt eunuchi, qui facti sunt ab hominibus: et sunt eunuchi, qui seipsos castraverunt propter regnum cælorum. Qui potest capere capiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Matthew 19:13",
      "text": "Tunc oblati sunt ei parvuli, ut manus eis imponeret, et oraret. Discipuli autem increpabant eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Matthew 19:14",
      "text": "Jesus vero ait eis: Sinite parvulos, et nolite eos prohibere ad me venire: talium est enim regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Matthew 19:15",
      "text": "Et cum imposuisset eis manus, abiit inde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Matthew 19:16",
      "text": "Et ecce unus accedens, ait illi: Magister bone, quid boni faciam ut habeam vitam æternam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Matthew 19:17",
      "text": "Qui dixit ei: Quid me interrogas de bono? Unus est bonus, Deus. Si autem vis ad vitam ingredi, serva mandata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Matthew 19:18",
      "text": "Dicit illi: Quæ? Jesus autem dixit: Non homicidium facies; non adulterabis; non facies furtum; non falsum testimonium dices;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Matthew 19:19",
      "text": "honora patrem tuum, et matrem tuam, et diliges proximum tuum sicut teipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Matthew 19:20",
      "text": "Dicit illi adolescens: Omnia hæc custodivi a juventute mea: quid adhuc mihi deest?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Matthew 19:21",
      "text": "Ait illi Jesus: Si vis perfectus esse, vade, vende quæ habes, et da pauperibus, et habebis thesaurum in cælo: et veni, sequere me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Matthew 19:22",
      "text": "Cum audisset autem adolescens verbum, abiit tristis: erat enim habens multas possessiones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Matthew 19:23",
      "text": "Jesus autem dixit discipulis suis: Amen dico vobis, quia dives difficile intrabit in regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Matthew 19:24",
      "text": "Et iterum dico vobis: Facilius est camelum per foramen acus transire, quam divitem intrare in regnum cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Matthew 19:25",
      "text": "Auditis autem his, discipuli mirabantur valde, dicentes: Quis ergo poterit salvus esse?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Matthew 19:26",
      "text": "Aspiciens autem Jesus, dixit illis: Apud homines hoc impossibile est: apud Deum autem omnia possibilia sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Matthew 19:27",
      "text": "Tunc respondens Petrus, dixit ei: Ecce nos reliquimus omnia, et secuti sumus te: quid ergo erit nobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Matthew 19:28",
      "text": "Jesus autem dixit illis: Amen dico vobis, quod vos, qui secuti estis me, in regeneratione cum sederit Filius hominis in sede majestatis suæ, sedebitis et vos super sedes duodecim, judicantes duodecim tribus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Matthew 19:29",
      "text": "Et omnis qui reliquerit domum, vel fratres, aut sorores, aut patrem, aut matrem, aut uxorem, aut filios, aut agros propter nomen meum, centuplum accipiet, et vitam æternam possidebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.19.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Matthew 19:30",
      "text": "Multi autem erunt primi novissimi, et novissimi primi.",
      "paragraphStart": false
    }
  ]
}
