{
  "chapter": {
    "id": "vulgate:matthew.25",
    "translationId": "vulgate",
    "bookSlug": "matthew",
    "chapterNumber": 25,
    "referenceLabel": "Matthew 25",
    "summary": "Source text for Matthew 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:matthew.25.1",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Matthew 25:1",
      "text": "Tunc simile erit regnum cælorum decem virginibus: quæ accipientes lampades suas exierunt obviam sponso et sponsæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:matthew.25.2",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Matthew 25:2",
      "text": "Quinque autem ex eis erant fatuæ, et quinque prudentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.3",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Matthew 25:3",
      "text": "sed quinque fatuæ, acceptis lampadibus, non sumpserunt oleum secum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.4",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Matthew 25:4",
      "text": "prudentes vero acceperunt oleum in vasis suis cum lampadibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.5",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Matthew 25:5",
      "text": "Moram autem faciente sponso, dormitaverunt omnes et dormierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.6",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Matthew 25:6",
      "text": "Media autem nocte clamor factus est: Ecce sponsus venit, exite obviam ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.7",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Matthew 25:7",
      "text": "Tunc surrexerunt omnes virgines illæ, et ornaverunt lampades suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.8",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Matthew 25:8",
      "text": "Fatuæ autem sapientibus dixerunt: Date nobis de oleo vestro, quia lampades nostræ extinguuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.9",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Matthew 25:9",
      "text": "Responderunt prudentes, dicentes: Ne forte non sufficiat nobis, et vobis, ite potius ad vendentes, et emite vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.10",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Matthew 25:10",
      "text": "Dum autem irent emere, venit sponsus: et quæ paratæ erant, intraverunt cum eo ad nuptias, et clausa est janua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.11",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Matthew 25:11",
      "text": "Novissime vero veniunt et reliquæ virgines, dicentes: Domine, domine, aperi nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.12",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Matthew 25:12",
      "text": "At ille respondens, ait: Amen dico vobis, nescio vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.13",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Matthew 25:13",
      "text": "Vigilate itaque, quia nescitis diem, neque horam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.14",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Matthew 25:14",
      "text": "Sicut enim homo peregre proficiscens, vocavit servos suos, et tradidit illis bona sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.15",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Matthew 25:15",
      "text": "Et uni dedit quinque talenta, alii autem duo, alii vero unum, unicuique secundum propriam virtutem: et profectus est statim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.16",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Matthew 25:16",
      "text": "Abiit autem qui quinque talenta acceperat, et operatus est in eis, et lucratus est alia quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.17",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Matthew 25:17",
      "text": "Similiter et qui duo acceperat, lucratus est alia duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.18",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Matthew 25:18",
      "text": "Qui autem unum acceperat, abiens fodit in terram, et abscondit pecuniam domini sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.19",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Matthew 25:19",
      "text": "Post multum vero temporis venit dominus servorum illorum, et posuit rationem cum eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.20",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Matthew 25:20",
      "text": "Et accedens qui quinque talenta acceperat, obtulit alia quinque talenta, dicens: Domine, quinque talenta tradidisti mihi, ecce alia quinque superlucratus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.21",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Matthew 25:21",
      "text": "Ait illi dominus ejus: Euge serve bone, et fidelis: quia super pauca fuisti fidelis, super multa te constituam; intra in gaudium domini tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.22",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Matthew 25:22",
      "text": "Accessit autem et qui duo talenta acceperat, et ait: Domine, duo talenta tradidisti mihi, ecce alia duo lucratus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.23",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Matthew 25:23",
      "text": "Ait illi dominus ejus: Euge serve bone, et fidelis: quia super pauca fuisti fidelis, super multa te constituam; intra in gaudium domini tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.24",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Matthew 25:24",
      "text": "Accedens autem et qui unum talentum acceperat, ait: Domine, scio quia homo durus es; metis ubi non seminasti, et congregas ubi non sparsisti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.25",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Matthew 25:25",
      "text": "et timens abii, et abscondi talentum tuum in terra: ecce habes quod tuum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.26",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Matthew 25:26",
      "text": "Respondens autem dominus ejus, dixit ei: Serve male, et piger, sciebas quia meto ubi non semino, et congrego ubi non sparsi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.27",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Matthew 25:27",
      "text": "oportuit ergo te committere pecuniam meam numulariis, et veniens ego recepissem utique quod meum est cum usura.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.28",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Matthew 25:28",
      "text": "Tollite itaque ab eo talentum, et date ei qui habet decem talenta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.29",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "Matthew 25:29",
      "text": "omni enim habenti dabitur, et abundabit: ei autem qui non habet, et quod videtur habere, auferetur ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.30",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 30,
      "referenceLabel": "Matthew 25:30",
      "text": "Et inutilem servum ejicite in tenebras exteriores: illic erit fletus, et stridor dentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.31",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 31,
      "referenceLabel": "Matthew 25:31",
      "text": "Cum autem venerit Filius hominis in majestate sua, et omnes angeli cum eo, tunc sedebit super sedem majestatis suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.32",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 32,
      "referenceLabel": "Matthew 25:32",
      "text": "et congregabuntur ante eum omnes gentes, et separabit eos ab invicem, sicut pastor segregat oves ab hædis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.33",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 33,
      "referenceLabel": "Matthew 25:33",
      "text": "et statuet oves quidem a dextris suis, hædos autem a sinistris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.34",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 34,
      "referenceLabel": "Matthew 25:34",
      "text": "Tunc dicet rex his qui a dextris ejus erunt: Venite benedicti Patris mei, possidete paratum vobis regnum a constitutione mundi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.35",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 35,
      "referenceLabel": "Matthew 25:35",
      "text": "esurivi enim, et dedistis mihi manducare: sitivi, et dedistis mihi bibere: hospes eram, et collegistis me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.36",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 36,
      "referenceLabel": "Matthew 25:36",
      "text": "nudus, et cooperuistis me: infirmus, et visitastis me: in carcere eram, et venistis ad me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.37",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 37,
      "referenceLabel": "Matthew 25:37",
      "text": "Tunc respondebunt ei justi, dicentes: Domine, quando te vidimus esurientem, et pavimus te: sitientem, et dedimus tibi potum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.38",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 38,
      "referenceLabel": "Matthew 25:38",
      "text": "quando autem te vidimus hospitem, et collegimus te: aut nudum, et cooperuimus te?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.39",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 39,
      "referenceLabel": "Matthew 25:39",
      "text": "aut quando te vidimus infirmum, aut in carcere, et venimus ad te?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.40",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 40,
      "referenceLabel": "Matthew 25:40",
      "text": "Et respondens rex, dicet illis: Amen dico vobis, quamdiu fecistis uni ex his fratribus meis minimis, mihi fecistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.41",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 41,
      "referenceLabel": "Matthew 25:41",
      "text": "Tunc dicet et his qui a sinistris erunt: Discedite a me maledicti in ignem æternum, qui paratus est diabolo, et angelis ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.42",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 42,
      "referenceLabel": "Matthew 25:42",
      "text": "esurivi enim, et non dedistis mihi manducare: sitivi, et non desistis mihi potum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.43",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 43,
      "referenceLabel": "Matthew 25:43",
      "text": "hospes eram, et non collegistis me: nudus, et non cooperuistis me: infirmus, et in carcere, et non visitastis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.44",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 44,
      "referenceLabel": "Matthew 25:44",
      "text": "Tunc respondebunt ei et ipsi, dicentes: Domine, quando te vidimus esurientem, aut sitientem, aut hospitem, aut nudum, aut infirmum, aut in carcere, et non ministravimus tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.45",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 45,
      "referenceLabel": "Matthew 25:45",
      "text": "Tunc respondebit illis, dicens: Amen dico vobis: Quamdiu non fecistis uni de minoribus his, nec mihi fecistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:matthew.25.46",
      "translationId": "vulgate",
      "bookSlug": "matthew",
      "chapterNumber": 25,
      "verseNumber": 46,
      "referenceLabel": "Matthew 25:46",
      "text": "Et ibunt hi in supplicium æternum: justi autem in vitam æternam.",
      "paragraphStart": false
    }
  ]
}
