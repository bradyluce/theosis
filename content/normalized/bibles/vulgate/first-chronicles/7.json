{
  "chapter": {
    "id": "vulgate:first-chronicles.7",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 7,
    "referenceLabel": "1 Chronicles 7",
    "summary": "Source text for 1 Chronicles 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.7.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 7:1",
      "text": "Porro filii Issachar: Thola, et Phua, Jasub, et Simeron, quatuor.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.7.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 7:2",
      "text": "Filii Thola: Ozi, et Raphaia, et Jeriel, et Jemai, et Jebsem, et Samuel, principes per domos cognationum suarum. De stirpe Thola viri fortissimi numerati sunt in diebus David, viginti duo millia sexcenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 7:3",
      "text": "Filii Ozi: Izrahia, de quo nati sunt Michaël, et Obadia, et Joël, et Jesia, quinque omnes principes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 7:4",
      "text": "Cumque eis per familias et populos suos, accincti ad prælium, viri fortissimi, triginta sex millia: multas enim habuerunt uxores, et filios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 7:5",
      "text": "Fratres quoque eorum per omnem cognationem Issachar robustissimi ad pugnandum, octoginta septem millia numerati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 7:6",
      "text": "Filii Benjamin: Bela, et Bechor, et Jadihel, tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 7:7",
      "text": "Filii Bela: Esbon, et Ozi, et Oziel, et Jerimoth, et Urai, quinque principes familiarum, et ad pugnandum robustissimi: numerus autem eorum, viginti duo millia et triginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 7:8",
      "text": "Porro filii Bechor: Zamira, et Joas, et Eliezer, et Elioënai, et Amri, et Jerimoth, et Abia, et Anathoth, et Almath: omnes hi filii Bechor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 7:9",
      "text": "Numerati sunt autem per familias suas principes cognationum suarum ad bella fortissimi, viginti millia et ducenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 7:10",
      "text": "Porro filii Jadihel: Balan. Filii autem Balan: Jehus, et Benjamin, et Aod, et Chanana, et Zethan, et Tharsis, et Ahisahar:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 7:11",
      "text": "omnes hi filii Jadihel, principes cognationum suarum viri fortissimi, decem et septem millia et ducenti ad prælium procedentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 7:12",
      "text": "Sepham quoque et Hapham filii Hir: et Hasim filii Aher.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 7:13",
      "text": "Filii autem Nephthali: Jaziel, et Guni, et Jeser, et Sellum, filii Bala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 7:14",
      "text": "Porro filius Manasse, Esriel: concubinaque ejus Syra peperit Machir patrem Galaad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 7:15",
      "text": "Machir autem accepit uxores filiis suis Happhim, et Saphan: et habuit sororem nomine Maacha: nomen autem secundi, Salphaad, natæque sunt Salphaad filiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 7:16",
      "text": "Et peperit Maacha uxor Machir filium, vocavitque nomen ejus Phares: porro nomen fratris ejus, Sares: et filii ejus, Ulam, et Recen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 7:17",
      "text": "Filius autem Ulam, Badan: hi sunt filii Galaad, filii Machir, filii Manasse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 7:18",
      "text": "Soror autem ejus Regina peperit Virum decorum, et Abiezer, et Mohola.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 7:19",
      "text": "Erant autem filii Semida, Ahin, et Sechem, et Leci, et Aniam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 7:20",
      "text": "Filii autem Ephraim: Suthala, Bared filius ejus, Thahath filius ejus, Elada filius ejus, Thahath filius ejus, hujus filius Zabad,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 7:21",
      "text": "et hujus filius Suthula, et hujus filius Ezer et Elad: occiderunt autem eos viri Geth indigenæ, quia descenderant ut invaderent possessiones eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 7:22",
      "text": "Luxit igitur Ephraim pater eorum multis diebus, et venerunt fratres ejus ut consolarentur eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 7:23",
      "text": "Ingressusque est ad uxorem suam: quæ concepit, et peperit filium, et vocavit nomen ejus Beria, eo quod in malis domus ejus ortus esset:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 7:24",
      "text": "filia autem ejus fuit Sara, quæ ædificavit Bethoron inferiorem et superiorem, et Ozensara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 7:25",
      "text": "Porro filius ejus Rapha, et Reseph, et Thale, de quo natus est Thaan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 7:26",
      "text": "qui genuit Laadan: hujus quoque filius Ammiud, qui genuit Elisama,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 7:27",
      "text": "de quo ortus est Nun, qui habuit filium Josue.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 7:28",
      "text": "Possessio autem eorum et habitatio, Bethel cum filiabus suis, et contra orientem Noran, ad occidentalem plagam Gazer et filiæ ejus, Sichem quoque cum filiabus suis, usque ad Aza cum filiabus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 7:29",
      "text": "Juxta filios quoque Manasse, Bethsan et filias ejus, Thanach et filias ejus, Mageddo et filias ejus, Dor et filias ejus: in his habitaverunt filii Joseph, filii Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 7:30",
      "text": "Filii Aser: Jemna, et Jesua, et Jessui, et Baria, et Sara soror eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 7:31",
      "text": "Filii autem Baria: Heber, et Melchiel: ipse est pater Barsaith.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 7:32",
      "text": "Heber autem genuit Jephlat, et Somer, et Hotham, et Suaa sororem eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 7:33",
      "text": "Filii Jephlat: Phosech, et Chamaal, et Asoth: hi filii Jephlat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 7:34",
      "text": "Porro filii Somer: Ahi, et Roaga, et Haba, et Aram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 7:35",
      "text": "Filii autem Helem fratris ejus: Supha, et Jemna, et Selles, et Amal.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 7:36",
      "text": "Filii Supha: Sue, Harnapher, et Sual, et Beri, et Jamra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 7:37",
      "text": "Bosor, et Hod, et Samma, et Salusa, et Jethran, et Bera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 7:38",
      "text": "Filii Jether: Jephone, et Phaspha, et Ara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 7:39",
      "text": "Filii autem Olla: Aree, et Haniel, et Resia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.7.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 7:40",
      "text": "Omnes hi filii Aser, principes cognationum, electi atque fortissimi duces ducum: numerus autem eorum ætatis quæ apta esset ad bellum, viginti sex millia.",
      "paragraphStart": false
    }
  ]
}
