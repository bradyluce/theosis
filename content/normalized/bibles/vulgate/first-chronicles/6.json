{
  "chapter": {
    "id": "vulgate:first-chronicles.6",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 6,
    "referenceLabel": "1 Chronicles 6",
    "summary": "Source text for 1 Chronicles 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.6.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 6:1",
      "text": "Filii Levi: Gerson, Caath, et Merari.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.6.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 6:2",
      "text": "Filii Caath: Amram, Isaar, Hebron, et Oziel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 6:3",
      "text": "Filii Amram: Aaron, Moyses, et Maria. Filii Aaron: Nadab et Abiu, Eleazar, et Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 6:4",
      "text": "Eleazar genuit Phinees, et Phinees genuit Abisue.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 6:5",
      "text": "Abisue vero genuit Bocci, et Bocci genuit Ozi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 6:6",
      "text": "Ozi genuit Zaraiam, et Zaraias genuit Meraioth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 6:7",
      "text": "Porro Meraioth genuit Amariam, et Amarias genuit Achitob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 6:8",
      "text": "Achitob genuit Sadoc, et Sadoc genuit Achimaas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 6:9",
      "text": "Achimaas genuit Azariam, Azarias genuit Johanan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 6:10",
      "text": "Johanan genuit Azariam: ipse est qui sacerdotio functus est in domo quam ædificavit Salomon in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 6:11",
      "text": "Genuit autem Azarias Amariam, et Amarias genuit Achitob,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 6:12",
      "text": "Achitob genuit Sadoc, et Sadoc genuit Sellum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 6:13",
      "text": "Sellum genuit Helciam, et Helcias genuit Azariam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 6:14",
      "text": "Azarias genuit Saraiam, et Saraias genuit Josedec.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 6:15",
      "text": "Porro Josedec egressus est, quando transtulit Dominus Judam et Jerusalem per manus Nabuchodonosor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 6:16",
      "text": "Filii ergo Levi: Gersom, Caath, et Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 6:17",
      "text": "Et hæc nomina filiorum Gersom: Lobni, et Semei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 6:18",
      "text": "Filii Caath: Amram, et Isaar, et Hebron, et Oziel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 6:19",
      "text": "Filii Merari: Moholi et Musi. Hæ autem cognationes Levi secundum familias eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 6:20",
      "text": "Gersom: Lobni filius ejus, Jahath filius ejus, Zamma filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 6:21",
      "text": "Joah filius ejus, Addo filius ejus, Zara filius ejus, Jethrai filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 6:22",
      "text": "Filii Caath: Aminadab filius ejus, Core filius ejus, Asir filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 6:23",
      "text": "Elcana filius ejus, Abiasaph filius ejus, Asir filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 6:24",
      "text": "Thahath filius ejus, Uriel filius ejus, Ozias filius ejus, Saul filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 6:25",
      "text": "Filii Elcana, Amasai et Achimoth",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 6:26",
      "text": "et Elcana. Filii Elcana: Sophai filius ejus, Nahath filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 6:27",
      "text": "Eliab filius ejus, Jeroham filius ejus, Elcana filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 6:28",
      "text": "Filii Samuel: primogenitus Vasseni, et Abia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 6:29",
      "text": "Filii autem Merari, Moholi: Lobni filius ejus, Semei filius ejus, Oza filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 6:30",
      "text": "Sammaa filius ejus, Haggia filius ejus, Asaia filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 6:31",
      "text": "Isti sunt quos constituit David super cantores domus Domini, ex quo collocata est arca:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 6:32",
      "text": "et ministrabant coram tabernaculo testimonii, canentes donec ædificaret Salomon domum Domini in Jerusalem: stabant autem juxta ordinem suum in ministerio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 6:33",
      "text": "Hi vero sunt qui assistebant cum filiis suis, de filiis Caath, Hemam cantor filius Johel, filii Samuel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 6:34",
      "text": "filii Elcana, filii Jeroham, filii Eliel, filii Thohu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 6:35",
      "text": "filii Suph, filii Elcana, filii Mahath, filii Amasai,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 6:36",
      "text": "filii Elcana, filii Johel, filii Azariæ, filii Sophoniæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 6:37",
      "text": "filii Thahath, filii Asir, filii Abiasaph, filii Core,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 6:38",
      "text": "filii Isaar, filii Caath, filii Levi, filii Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 6:39",
      "text": "Et frater ejus Asaph, qui stabat a dextris ejus, Asaph filius Barachiæ, filii Samaa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 6:40",
      "text": "filii Michaël, filii Basaiæ, filii Melchiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 6:41",
      "text": "filii Athanai, filii Zara, filii Adaia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 6:42",
      "text": "filii Ethan, filii Zamma, filii Semei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 6:43",
      "text": "filii Jeth, filii Gersom, filii Levi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.44",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 6:44",
      "text": "Filii autem Merari fratres eorum, ad sinistram, Ethan filius Cusi, filii Abdi, filii Maloch,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.45",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 6:45",
      "text": "filii Hasabiæ, filii Amasiæ, filii Helciæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.46",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 6:46",
      "text": "filii Amasai, filii Boni, filii Somer,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.47",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 6:47",
      "text": "filii Moholi, filii Musi, filii Merari, filii Levi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.48",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 6:48",
      "text": "Fratres quoque eorum Levitæ, qui ordinati sunt in cunctum ministerium tabernaculi domus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.49",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 6:49",
      "text": "Aaron vero et filii ejus adolebant incensum super altare holocausti, et super altare thymiamatis, in omne opus Sancti sanctorum: et ut precarentur pro Israël juxta omnia quæ præceperat Moyses servus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.50",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 6:50",
      "text": "Hi sunt autem filii Aaron: Eleazar filius ejus, Phinees filius ejus, Abisue filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.51",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 6:51",
      "text": "Bocci filius ejus, Ozi filius ejus, Zarahia filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.52",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 6:52",
      "text": "Meraioth filius ejus, Amarias filius ejus, Achitob filius ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.53",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 6:53",
      "text": "Sadoc filius ejus, Achimaas filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.54",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 6:54",
      "text": "Et hæc habitacula eorum per vicos atque confinia, filiorum scilicet Aaron, juxta cognationes Caathitarum: ipsis enim sorte contigerant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.55",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 55,
      "referenceLabel": "1 Chronicles 6:55",
      "text": "Dederunt igitur eis Hebron in terra Juda, et suburbana ejus per circuitum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.56",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 56,
      "referenceLabel": "1 Chronicles 6:56",
      "text": "agros autem civitatis, et villas, Caleb filio Jephone.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.57",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 57,
      "referenceLabel": "1 Chronicles 6:57",
      "text": "Porro filiis Aaron dederunt civitates ad confugiendum Hebron, et Lobna, et suburbana ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.58",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 58,
      "referenceLabel": "1 Chronicles 6:58",
      "text": "Jether quoque, et Esthemo cum suburbanis suis, sed et Helon, et Dabir cum suburbanis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.59",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 59,
      "referenceLabel": "1 Chronicles 6:59",
      "text": "Asan quoque, et Bethsemes, et suburbana earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.60",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 60,
      "referenceLabel": "1 Chronicles 6:60",
      "text": "De tribu autem Benjamin, Gabee et suburbana ejus, et Almath cum suburbanis suis, Anathoth quoque cum suburbanis suis: omnes civitates, tredecim, per cognationes suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.61",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 61,
      "referenceLabel": "1 Chronicles 6:61",
      "text": "Filiis autem Caath residuis de cognatione sua dederunt ex dimidia tribu Manasse in possessionem urbes decem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.62",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 62,
      "referenceLabel": "1 Chronicles 6:62",
      "text": "Porro filiis Gersom per cognationes suas de tribu Issachar, et de tribu Aser, et de tribu Nephthali, et de tribu Manasse in Basan, urbes tredecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.63",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 63,
      "referenceLabel": "1 Chronicles 6:63",
      "text": "Filiis autem Merari per cognationes suas de tribu Ruben, et de tribu Gad, et de tribu Zabulon, dederunt sorte civitates duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.64",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 64,
      "referenceLabel": "1 Chronicles 6:64",
      "text": "Dederunt quoque filii Israël Levitis civitates, et suburbana earum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.65",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 65,
      "referenceLabel": "1 Chronicles 6:65",
      "text": "dederuntque per sortem, ex tribu filiorum Juda, et ex tribu filiorum Simeon, et ex tribu filiorum Benjamin urbes has, quas vocaverunt nominibus suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.66",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 66,
      "referenceLabel": "1 Chronicles 6:66",
      "text": "et his, qui erant de cognatione filiorum Caath, fueruntque civitates in terminis eorum de tribu Ephraim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.67",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 67,
      "referenceLabel": "1 Chronicles 6:67",
      "text": "Dederunt ergo eis urbes ad confugiendum, Sichem cum suburbanis suis in monte Ephraim, et Gazer cum suburbanis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.68",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 68,
      "referenceLabel": "1 Chronicles 6:68",
      "text": "Jecmaam quoque cum suburbanis suis, et Bethoron similiter,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.69",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 69,
      "referenceLabel": "1 Chronicles 6:69",
      "text": "necnon et Helon cum suburbanis suis, et Gethremmon in eumdem modum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.70",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 70,
      "referenceLabel": "1 Chronicles 6:70",
      "text": "Porro ex dimidia tribu Manasse, Aner et suburbana ejus, Balaam et suburbana ejus: his videlicet, qui de cognatione filiorum Caath reliqui erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.71",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 71,
      "referenceLabel": "1 Chronicles 6:71",
      "text": "Filiis autem Gersom de cognatione dimidiæ tribus Manasse, Gaulon in Basan, et suburbana ejus, et Astaroth cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.72",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 72,
      "referenceLabel": "1 Chronicles 6:72",
      "text": "De tribu Issachar, Cedes et suburbanis suis, et Dabereth cum suburbanis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.73",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 73,
      "referenceLabel": "1 Chronicles 6:73",
      "text": "Ramoth quoque et suburbana ejus, et Anem cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.74",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 74,
      "referenceLabel": "1 Chronicles 6:74",
      "text": "De tribu vero Aser: Masal cum suburbanis suis, et Abdon similiter,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.75",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 75,
      "referenceLabel": "1 Chronicles 6:75",
      "text": "Hucac quoque et suburbana ejus, et Rohob cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.76",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 76,
      "referenceLabel": "1 Chronicles 6:76",
      "text": "Porro de tribu Nephthali, Cedes in Galilæa et suburbana ejus, Hamon cum suburbanis suis, et Cariathaim et suburbana ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.77",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 77,
      "referenceLabel": "1 Chronicles 6:77",
      "text": "Filiis autem Merari residuis: de tribu Zabulon, Remmono et suburbana ejus, et Thabor cum suburbanis sus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.78",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 78,
      "referenceLabel": "1 Chronicles 6:78",
      "text": "trans Jordanem quoque ex adverso Jericho contra orientem Jordanis, de tribu Ruben, Bosor in solitudine cum suburbanis suis, et Jassa cum suburbanis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.79",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 79,
      "referenceLabel": "1 Chronicles 6:79",
      "text": "Cademoth quoque et suburbana ejus, et Mephaat cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.80",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 80,
      "referenceLabel": "1 Chronicles 6:80",
      "text": "Necnon et de tribu Gad, Ramoth in Galaad et suburbana ejus, et Manaim cum suburbanis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.6.81",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 6,
      "verseNumber": 81,
      "referenceLabel": "1 Chronicles 6:81",
      "text": "sed et Hesebon cum suburbanis suis, et Jezer cum suburbanis suis.",
      "paragraphStart": false
    }
  ]
}
