{
  "chapter": {
    "id": "vulgate:first-chronicles.4",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 4,
    "referenceLabel": "1 Chronicles 4",
    "summary": "Source text for 1 Chronicles 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.4.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 4:1",
      "text": "Filii Juda: Phares, Hesron, et Charmi, et Hur, et Sobal.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.4.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 4:2",
      "text": "Raia vero filius Sobal genuit Jahath, de quo nati sunt Ahumai, et Laad: hæ cognationes Sarathi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 4:3",
      "text": "Ista quoque stirps Etam: Jezrahel, et Jesema, et Jedebos. Nomen quoque sororis eorum, Asalelphuni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 4:4",
      "text": "Phanuel autem pater Gedor, et Ezer pater Hosa: isti sunt filii Hur primogeniti Ephratha patris Bethlehem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 4:5",
      "text": "Assur vero patri Thecuæ erant duæ uxores, Halaa et Naara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 4:6",
      "text": "Peperit autem ei Naara, Oozam, et Hepher, et Themani, et Ahasthari: isti sunt filii Naara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 4:7",
      "text": "Porro filii Halaa, Sereth, Isaar et Ethnan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 4:8",
      "text": "Cos autem genuit Anob, et Soboba, et cognationem Aharehel filii Arum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 4:9",
      "text": "Fuit autem Jabes inclytus præ fratribus suis, et mater ejus vocavit nomen illius Jabes, dicens: Quia peperi eum in dolore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 4:10",
      "text": "Invocavit vero Jabes Deum Israël, dicens: Si benedicens benedixeris mihi, et dilataveris terminos meos, et fuerit manus tua mecum, et feceris me a malitia non opprimi. Et præstitit Deus quæ precatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 4:11",
      "text": "Caleb autem frater Sua genuit Mahir, qui fuit pater Esthon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 4:12",
      "text": "Porro Esthon genuit Bethrapha, et Phesse, et Tehinna patrem urbis Naas: hi sunt viri Recha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 4:13",
      "text": "Filii autem Cenez, Othoniel, et Saraia. Porro filii Othoniel, Hathath, et Maonathi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 4:14",
      "text": "Maonathi genuit Ophra, Saraia autem genuit Joab patrem Vallis artificum: ibi quippe artifices erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 4:15",
      "text": "Filii vero Caleb filii Jephone, Hir, et Ela, et Naham. Filii quoque Ela: Cenez.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 4:16",
      "text": "Filii quoque Jaleleel: Ziph, et Zipha, Thiria, et Asraël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 4:17",
      "text": "Et filii Ezra, Jether, et Mered, et Epher, et Jalon, genuitque Mariam, et Sammai, et Jesba patrem Esthamo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 4:18",
      "text": "Uxor quoque ejus Judaia, peperit Jared patrem Gedor, et Heber patrem Socho, et Icuthiel patrem Zanoë: hi autem filii Bethiæ filiæ Pharaonis, quam accepit Mered.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 4:19",
      "text": "Et filii uxoris Odaiæ sororis Naham patris Ceila, Garmi, et Esthamo, qui fuit de Machathi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 4:20",
      "text": "Filii quoque Simon, Amnon, et Rinna filius Hanan, et Thilon. Et filii Jesi, Zoheth, et Benzoheth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 4:21",
      "text": "Filii Sela, filii Juda: Her pater Lecha, et Laada pater Maresa, et cognationes domus operantium byssum in domo juramenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 4:22",
      "text": "Et qui stare fecit solem, virique Mendacii, et Securus, et Incendens, qui principes fuerunt in Moab, et qui reversi sunt in Lahem: hæc autem verba vetera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 4:23",
      "text": "Hi sunt figuli habitantes in plantationibus et in sepibus, apud regem in operibus ejus: commoratique sunt ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 4:24",
      "text": "Filii Simeon: Namuel et Jamin, Jarib, Zara, Saul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 4:25",
      "text": "Sellum filius ejus, Mapsam filius ejus, Masma filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 4:26",
      "text": "Filii Masma: Hamuel filius ejus, Zachur filius ejus, Semei filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 4:27",
      "text": "Filii Semei sedecim, et filiæ sex: fratres autem ejus non habuerunt filios multos, et universa cognatio non potuit adæquare summam filiorum Juda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 4:28",
      "text": "Habitaverunt autem in Bersabee, et Molada, et Hasarsuhal,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 4:29",
      "text": "et in Bala, et in Asom, et in Tholad,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 4:30",
      "text": "et in Bathuel, et in Horma, et in Siceleg,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 4:31",
      "text": "et in Bethmarchaboth, et in Hasarsusim, et in Bethberai, et in Saarim: hæ civitates eorum usque ad regem David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 4:32",
      "text": "Villæ quoque eorum: Etam, et Aën, Remmon, et Thochen, et Asan, civitates quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 4:33",
      "text": "Et universi viculi eorum per circuitum civitatum istarum usque ad Baal: hæc est habitatio eorum, et sedium distributio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 4:34",
      "text": "Mosobab quoque et Jemlech, et Josa filius Amasiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 4:35",
      "text": "et Joël, et Jehu filius Josabiæ filii Saraiæ filii Asiel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 4:36",
      "text": "et Elioënai, et Jacoba, et Isuhaia, et Asaia, et Adiel, et Ismiel, et Banaia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 4:37",
      "text": "Ziza quoque filius Sephei filii Allon filii Idaia filii Semri filii Samaia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 4:38",
      "text": "Isti sunt nominati principes in cognationibus suis, et in domo affinitatum suarum multiplicati sunt vehementer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 4:39",
      "text": "Et profecti sunt ut ingrederentur in Gador usque ad orientem vallis, et ut quærerent pascua gregibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 4:40",
      "text": "Inveneruntque pascuas uberes, et valde bonas, et terram latissimam et quietam et fertilem, in qua ante habitaverant de stirpe Cham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 4:41",
      "text": "Hi ergo venerunt, quos supra descripsimus nominatim, in diebus Ezechiæ regis Juda: et percusserunt tabernacula eorum, et habitatores qui inventi fuerant ibi, et deleverunt eos usque in præsentem diem: habitaveruntque pro eis, quoniam uberrimas pascuas ibidem repererunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 4:42",
      "text": "De filiis quoque Simeon abierunt in montem Seir viri quingenti, habentes principes Phalthiam et Naariam et Raphaiam et Oziel filios Jesi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.4.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 4,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 4:43",
      "text": "et percusserunt reliquias, quæ evadere potuerant, Amalecitarum, et habitaverunt ibi pro eis usque ad diem hanc.",
      "paragraphStart": false
    }
  ]
}
