{
  "chapter": {
    "id": "vulgate:first-chronicles.8",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 8,
    "referenceLabel": "1 Chronicles 8",
    "summary": "Source text for 1 Chronicles 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.8.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 8:1",
      "text": "Benjamin autem genuit Bale primogenitum suum, Asbel secundum, Ahara tertium,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.8.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 8:2",
      "text": "Nohaa quartum, et Rapha quintum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 8:3",
      "text": "Fueruntque filii Bale: Addar, et Gera, et Abiud,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 8:4",
      "text": "Abisue quoque et Naaman, et Ahoë,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 8:5",
      "text": "sed et Gera, et Sephuphan, et Huram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 8:6",
      "text": "Hi sunt filii Ahod, principes cognationum habitantium in Gabaa, qui translati sunt in Manahath.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 8:7",
      "text": "Naaman autem, et Achia, et Gera, ipse transtulit eos, et genuit Osa, et Ahiud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 8:8",
      "text": "Porro Saharaim genuit in regione Moab, postquam dimisit Husim et Bara uxores suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 8:9",
      "text": "Genuit autem de Hodes uxore sua Jobab, et Sebia, et Mosa, et Molchom,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 8:10",
      "text": "Jehus quoque, et Sechia, et Marma: hi sunt filii ejus principes in familiis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 8:11",
      "text": "Mehusim vero genuit Abitob et Elphaal.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 8:12",
      "text": "Porro filii Elphaal: Heber, et Misaam, et Samad: hic ædificavit Ono, et Lod, et filias ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 8:13",
      "text": "Baria autem et Sama principes cognationum habitantium in Ajalon: hi fugaverunt habitatores Geth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 8:14",
      "text": "Et Ahio, et Sesac, et Jerimoth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 8:15",
      "text": "et Zabadia, et Arod, et Heder,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 8:16",
      "text": "Michaël quoque, et Jespha, et Joha filii Baria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 8:17",
      "text": "Et Zabadia, et Mosollam, et Hezeci, et Heber,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 8:18",
      "text": "et Jesamari, et Jezlia, et Jobab filii Elphaal,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 8:19",
      "text": "et Jacim, et Zechri, et Zabdi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 8:20",
      "text": "et Elioënai, et Selethai, et Eliel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 8:21",
      "text": "et Adaia, et Baraia, et Samarath, filii Semei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 8:22",
      "text": "Et Jespham, et Heber, et Eliel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 8:23",
      "text": "et Abdon, et Zechri, et Hanan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 8:24",
      "text": "et Hanania, et Ælam, et Anathothia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 8:25",
      "text": "et Jephdaia, et Phanuel, filii Sesac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 8:26",
      "text": "Et Samsari, et Sohoria, et Otholia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 8:27",
      "text": "et Jersia, et Elia, et Zechri, filii Jeroham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 8:28",
      "text": "Hi patriarchæ, et cognationum principes, qui habitaverunt in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 8:29",
      "text": "In Gabaon autem habitaverunt Abigabaon, et nomen uxoris ejus Maacha:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 8:30",
      "text": "filiusque ejus primogenitus Abdon, et Sur, et Cis, et Baal, et Nadab,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 8:31",
      "text": "Gedor quoque, et Ahio, et Zacher, et Macelloth:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 8:32",
      "text": "et Macelloth genuit Samaa: habitaveruntque ex adverso fratrum suorum in Jerusalem cum fratribus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 8:33",
      "text": "Ner autem genuit Cis, et Cis genuit Saul. Porro Saul genuit Jonathan, et Melchisua, et Abinadab, et Esbaal.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 8:34",
      "text": "Filius autem Jonathan, Meribbaal: et Meribbaal genuit Micha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 8:35",
      "text": "Filii Micha, Phithon, et Melech, et Tharaa, et Ahaz.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 8:36",
      "text": "Et Ahaz genuit Joada, et Joada genuit Alamath, et Azmoth, et Zamri: porro Zamri genuit Mosa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 8:37",
      "text": "et Mosa genuit Banaa, cujus filius fuit Rapha, de quo ortus est Elasa, qui genuit Asel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 8:38",
      "text": "Porro Asel sex filii fuerunt his nominibus: Ezricam, Bocru, Ismahel, Saria, Obdia, et Hanan: omnes hi filii Asel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 8:39",
      "text": "Filii autem Esec fratris ejus, Ulam primogenitus, et Jehus secundus, et Eliphalet tertius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.8.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 8,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 8:40",
      "text": "Fueruntque filii Ulam viri robustissimi, et magno robore tendentes arcum: et multos habentes filios ac nepotes, usque ad centum quinquaginta. Omnes hi filii Benjamin.",
      "paragraphStart": false
    }
  ]
}
