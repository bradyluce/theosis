{
  "chapter": {
    "id": "vulgate:first-chronicles.25",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 25,
    "referenceLabel": "1 Chronicles 25",
    "summary": "Source text for 1 Chronicles 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.25.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 25:1",
      "text": "Igitur David et magistratus exercitus segregaverunt in ministerium filios Asaph, et Heman, et Idithun, qui prophetarent in citharis, et psalteriis, et cymbalis secundum numerum suum, dedicato sibi officio servientes.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.25.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 25:2",
      "text": "De filiis Asaph: Zachur, et Joseph, et Nathania, et Asarela, filii Asaph: sub manu Asaph prophetantis juxta regem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 25:3",
      "text": "Porro Idithun: filii Idithun, Godolias, Sori, Jeseias, et Hasabias, et Mathathias, sex, sub manu patris sui Idithun, qui in cithara prophetabat super confitentes et laudantes Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 25:4",
      "text": "Heman quoque: filii Heman, Bocciau, Mathaniau, Oziel, Subuel, et Jerimoth, Hananias, Hanani, Eliatha, Geddelthi, et Romemthiezer, et Jesbacassa, Mellothi, Othir, Mahazioth:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 25:5",
      "text": "omnes isti filii Heman videntis regis in sermonibus Dei, ut exaltaret cornu: deditque Deus Heman filios quatuordecim, et filias tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 25:6",
      "text": "Universi sub manu patris sui ad cantandum in templo Domini distributi erant, in cymbalis, et psalteriis, et citharis, in ministeria domus Domini juxta regem: Asaph videlicet, et Idithun, et Heman.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 25:7",
      "text": "Fuit autem numerus eorum cum fratribus suis, qui erudiebant canticum Domini, cuncti doctores, ducenti octoginta octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 25:8",
      "text": "Miseruntque sortes per vices suas, ex æquo tam major quam minor, doctus pariter et indoctus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 25:9",
      "text": "Egressaque est sors prima Joseph, qui erat de Asaph. Secunda Godoliæ, ipsi et filiis ejus, et fratribus ejus duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 25:10",
      "text": "Tertia Zachur, filiis et fratribus ejus duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 25:11",
      "text": "Quarta Isari, filiis et fratribus ejus duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 25:12",
      "text": "Quinta Nathaniæ, filiis et fratribus ejus duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.25.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 25:13",
      "text": "Sexta Bocciau, filiis et fratribus ejus duodecim.",
