      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 25:14",
      "text": "Septima Isreela, filiis et fratribus ejus duodecim.",
