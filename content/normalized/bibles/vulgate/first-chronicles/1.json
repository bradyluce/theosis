{
  "chapter": {
    "id": "vulgate:first-chronicles.1",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.1.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Adam, Seth, Enos,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.1.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Cainan, Malaleel, Jared,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Henoch, Mathusale, Lamech,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Noë, Sem, Cham, et Japtheth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "Filii Japheth: Gomer, et Magog, et Madai, et Javan, Thubal, Mosoch, Thiras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "Porro filii Gomer: Ascenez, et Riphath, et Thogorma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "Filii autem Javan: Elisa et Tharsis, Cethim et Dodanim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "Filii Cham: Chus, et Mesraim, et Phut, et Chanaan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "Filii autem Chus: Saba, et Hevila, Sabatha, et Regma, et Sabathacha. Porro filii Regma: Saba, et Dadan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "Chus autem genuit Nemrod: iste cœpit esse potens in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "Mesraim vero genuit Ludim, et Anamim, et Laabim, et Nephtuim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "Phetrusim quoque, et Casluim: de quibus egressi sunt Philisthiim, et Caphtorim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "Chanaan vero genuit Sidonem primogenitum suum, Hethæum quoque,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "et Jebusæum, et Amorrhæum, et Gergesæum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "Hevæumque et Aracæum, et Sinæum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "Aradium quoque, et Samaræum, et Hamathæum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "Filii Sem: Ælam, et Assur, et Arphaxad, et Lud, et Aram, et Hus, et Hul, et Gether, et Mosoch.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "Arphaxad autem genuit Sale, qui et ipse genuit Heber.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "Porro Heber nati sunt duo filii: nomen uni Phaleg, quia in diebus ejus divisa est terra; et nomen fratris ejus Jectan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "Jectan autem genuit Elmodad, et Saleph, et Asarmoth, et Jare,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "Adoram quoque, et Huzal, et Decla,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "Hebal etiam, et Abimaël, et Saba, necnon",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "et Ophir, et Hevila, et Jobab: omnes isti filii Jectan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "Sem, Arphaxad, Sale,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Heber, Phaleg, Ragau,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Serug, Nachor, Thare,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Abram: iste est Abraham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "Filii autem Abraham, Isaac et Ismahel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "Et hæ generationes eorum. Primogenitus Ismahelis, Nabaioth, et Cedar, et Adbeel, et Mabsam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "et Masma, et Duma, Massa, Hadad, et Thema,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Jetur, Naphis, Cedma: hi sunt filii Ismahelis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "Filii autem Ceturæ concubinæ Abraham, quos genuit: Zamran, Jecsan, Madan, Madian, Jesboc, et Sue. Porro filii Jecsan: Saba, et Dadan. Filii autem Dadan: Assurim, et Latussim, et Laomim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "Filii autem Madian: Epha, et Epher, et Henoch, et Abida, et Eldaa: omnes hi filii Ceturæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "Genuit autem Abraham Isaac: cujus fuerunt filii Esau, et Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "Filii Esau: Eliphaz, Rahuel, Jehus, Ihelom, et Core.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "Filii Eliphaz: Theman, Omar, Sephi, Gathan, Cenez, Thamna, Amalec.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "Filii Rahuel: Nahath, Zara, Samma, Meza.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "Filii Seir: Lotan, Sobal, Sebeon, Ana, Dison, Eser, Disan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "Filii Lotan: Hori, Homam. Soror autem Lotan fuit Thamna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "Filii Sobal: Alian, et Manahath, et Ebal, Sephi et Onam. Filii Sebeon: Aja et Ana. Filii Ana: Dison.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "Filii Dison: Hamram, et Heseban, et Jethran, et Charan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "Filii Eser: Balaan, et Zavan, et Jacan. Filii Disan: Hus et Aran.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "Isti sunt reges qui imperaverunt in terra Edom, antequam esset rex super filios Israël. Bale filius Beor: et nomen civitatis ejus, Denaba.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.44",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "Mortuus est autem Bale, et regnavit pro eo Jobab filius Zare de Bosra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.45",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "Cumque et Jobab fuisset mortuus, regnavit pro eo Husam de terra Themanorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.46",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "Obiit quoque et Husam, et regnavit pro eo Adad filius Badad, qui percussit Madian in terra Moab: et nomen civitatis ejus Avith.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.47",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "Cumque et Adad fuisset mortuus, regnavit pro eo Semla de Masreca.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.48",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "Sed et Semla mortuus est, et regnavit pro eo Saul de Rohoboth, quæ juxta amnem sita est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.49",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "Mortuo quoque Saul, regnavit pro eo Balanan filius Achobor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.50",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "Sed et hic mortuus est, et regnavit pro eo Adad: cujus urbis nomen fuit Phau, et appellata est uxor ejus Meetabel filia Matred filiæ Mezaab.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.51",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "Adad autem mortuo, duces pro regibus in Edom esse cœperunt: dux Thamna, dux Alva, dux Jetheth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.52",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "dux Oolibama, dux Ela, dux Phinon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.53",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "dux Cenez, dux Theman, dux Mabsar,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.1.54",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "dux Magdiel, dux Hiram: hi duces Edom.",
      "paragraphStart": false
    }
  ]
}
