{
  "chapter": {
    "id": "vulgate:first-chronicles.16",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 16,
    "referenceLabel": "1 Chronicles 16",
    "summary": "Source text for 1 Chronicles 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.16.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 16:1",
      "text": "Attulerunt igitur arcam Dei, et constituerunt eam in medio tabernaculi quod tetenderat ei David: et obtulerunt holocausta et pacifica coram Deo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.16.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 16:2",
      "text": "Cumque complesset David offerens holocausta et pacifica, benedixit populo in nomine Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 16:3",
      "text": "Et divisit universis per singulos, a viro usque ad mulierem, tortam panis, et partem assæ carnis bubalæ, et frixam oleo similam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 16:4",
      "text": "Constituitque coram arca Domini de Levitis, qui ministrarent, et recordarentur operum ejus, et glorificarent atque laudarent Dominum Deum Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 16:5",
      "text": "Asaph principem, et secundum ejus Zachariam: porro Jahiel, et Semiramoth, et Jehiel, et Mathathiam, et Eliab, et Banaiam, et Obededom: Jehiel super organa psalterii et lyras: Asaph autem ut cymbalis personaret:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 16:6",
      "text": "Banaiam vero et Jaziel sacerdotes canere tuba jugiter coram arca fœderis Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 16:7",
      "text": "In illo die fecit David principem ad confitendum Domino Asaph et fratres ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 16:8",
      "text": "Confitemini Domino, et invocate nomen ejus: notas facite in populis adinventiones ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 16:9",
      "text": "Cantate ei, et psallite ei, et narrate omnia mirabilia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 16:10",
      "text": "Laudate nomen sanctum ejus: lætetur cor quærentium Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 16:11",
      "text": "Quærite Dominum, et virtutem ejus: quærite faciem ejus semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 16:12",
      "text": "Recordamini mirabilium ejus quæ fecit; signorum illius, et judiciorum oris ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 16:13",
      "text": "semen Israël servi ejus, filii Jacob electi ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 16:14",
      "text": "Ipse Dominus Deus noster: in universa terra judicia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 16:15",
      "text": "Recordamini in sempiternum pacti ejus: sermonis quem præcepit in mille generationes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 16:16",
      "text": "quem pepigit cum Abraham, et juramenti illius cum Isaac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 16:17",
      "text": "Et constituit illud Jacob in præceptum, et Israël in pactum sempiternum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 16:18",
      "text": "dicens: Tibi dabo terram Chanaan, funiculum hæreditatis vestræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 16:19",
      "text": "cum essent pauci numero, parvi et coloni ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 16:20",
      "text": "Et transierunt de gente in gentem, et de regno ad populum alterum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 16:21",
      "text": "Non dimisit quemquam calumniari eos, sed increpavit pro eis reges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 16:22",
      "text": "Nolite tangere christos meos, et in prophetis meis nolite malignari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 16:23",
      "text": "Cantate Domino omnis terra; annuntiate ex die in diem salutare ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 16:24",
      "text": "narrate in gentibus gloriam ejus; in cunctis populis mirabilia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 16:25",
      "text": "Quia magnus Dominus, et laudabilis nimis, et horribilis super omnes deos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 16:26",
      "text": "Omnes enim dii populorum idola: Dominus autem cælos fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 16:27",
      "text": "Confessio et magnificentia coram eo: fortitudo et gaudium in loco ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 16:28",
      "text": "Afferte Domino, familiæ populorum: afferte Domino gloriam et imperium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 16:29",
      "text": "Date Domino gloriam; nomini ejus levate sacrificium, et venite in conspectu ejus: et adorate Dominum in decore sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 16:30",
      "text": "Commoveatur a facie ejus omnis terra: ipse enim fundavit orbem immobilem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 16:31",
      "text": "Lætentur cæli, et exultet terra, et dicant in nationibus: Dominus regnavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 16:32",
      "text": "Tonet mare et plenitudo ejus; exultent agri, et omnia quæ in eis sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 16:33",
      "text": "Tunc laudabunt ligna saltus coram Domino: quia venit judicare terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 16:34",
      "text": "Confitemini Domino, quoniam bonus: quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 16:35",
      "text": "Et dicite: Salva nos, Deus salvator noster, et congrega nos, et erue de gentibus: ut confiteamur nomini sancto tuo, et exultemus in carminibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 16:36",
      "text": "Benedictus Dominus Deus Israël, ab æterno usque in æternum. Et dicat omnis populo: Amen, et hymnum Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 16:37",
      "text": "Reliquit itaque ibi coram arca fœderis Domini Asaph et fratres ejus, ut ministrarent in conspectu arcæ jugiter per singulos dies, et vices suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 16:38",
      "text": "Porro Obededom, et fratres ejus sexaginta octo: et Obededom filium Idithun, et Hosa, constituit janitores;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 16:39",
      "text": "Sadoc autem sacerdotem, et fratres ejus sacerdotes, coram tabernaculo Domini in excelso quod erat in Gabaon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 16:40",
      "text": "ut offerrent holocausta Domino super altare holocautomatis jugiter, mane et vespere, juxta omnia quæ scripta sunt in lege Domini, quam præcepit Israëli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 16:41",
      "text": "Et post eum Heman, et Idithun, et reliquos electos, unumquemque vocabulo suo ad confitendum Domino, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 16:42",
      "text": "Heman quoque et Idithun canentes tuba, et quatientes cymbala et omnia musicorum organa ad canendum Deo: filios autem Idithun fecit esse portarios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.16.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 16,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 16:43",
      "text": "Reversusque est omnis populus in domum suam: et David, ut benediceret etiam domui suæ.",
      "paragraphStart": false
    }
  ]
}
