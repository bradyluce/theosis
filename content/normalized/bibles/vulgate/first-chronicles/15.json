{
  "chapter": {
    "id": "vulgate:first-chronicles.15",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 15,
    "referenceLabel": "1 Chronicles 15",
    "summary": "Source text for 1 Chronicles 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.15.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 15:1",
      "text": "Fecit quoque sibi domos in civitate David: et ædificavit locum arcæ Dei, tetenditque ei tabernaculum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.15.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 15:2",
      "text": "Tunc dixit David: Illicitum est ut a quocumque portetur arca Dei nisi a Levitis, quos elegit Dominus ad portandum eam, et ad ministrandum sibi usque in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 15:3",
      "text": "Congregavitque universum Israël in Jerusalem, ut afferretur arca Dei in locum suum, quem præparaverat ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 15:4",
      "text": "necnon et filios Aaron, et Levitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 15:5",
      "text": "De filiis Caath, Uriel princeps fuit, et fratres ejus centum viginti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 15:6",
      "text": "De filiis Merari, Asaia princeps: et fratres ejus ducenti viginti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 15:7",
      "text": "De filiis Gersom, Joël princeps: et fratres ejus centum triginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 15:8",
      "text": "De filiis Elisaphan, Semeias princeps: et fratres ejus ducenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 15:9",
      "text": "De filiis Hebron, Eliel princeps: et fratres ejus octoginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 15:10",
      "text": "De filiis Oziel, Aminadab princeps: et fratres ejus centum duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 15:11",
      "text": "Vocavitque David Sadoc et Abiathar sacerdotes, et Levitas, Uriel, Asaiam, Joël, Semeiam, Eliel, et Aminadab:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 15:12",
      "text": "et dixit ad eos: Vos, qui estis principes familiarum Leviticarum, sanctificamini cum fratribus vestris, et afferte arcam Domini Dei Israël ad locum qui ei præparatus est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 15:13",
      "text": "ne ut a principio, quia non eratis præsentes, percussit nos Dominus; sic et nunc fiat, illicitum quid nobis agentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 15:14",
      "text": "Sanctificati sunt ergo sacerdotes et Levitæ ut portarent arcam Domini Dei Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 15:15",
      "text": "Et tulerunt filii Levi arcam Dei, sicut præceperat Moyses juxta verbum Domini, humeris suis in vectibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 15:16",
      "text": "Dixitque David principibus Levitarum, ut constituerent de fratribus suis cantores in organis musicorum, nablis videlicet, et lyris, et cymbalis, ut resonaret in excelsis sonitus lætitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 15:17",
      "text": "Constitueruntque Levitas: Heman filium Joël, et de fratribus ejus Asaph filium Barachiæ: de filiis vero Merari, fratribus eorum: Ethan filium Casaiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 15:18",
      "text": "Et cum eis fratres eorum: in secundo ordine, Zachariam, et Ben, et Jaziel, et Semiramoth, et Jahiel, et Ani, Eliab, et Banaiam, et Maasiam, et Mathathiam, et Eliphalu, et Maceniam, et Obededom, et Jehiel, janitores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 15:19",
      "text": "Porro cantores, Heman, Asaph, et Ethan, in cymbalis æneis concrepantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 15:20",
      "text": "Zacharias autem, et Oziel, et Semiramoth, et Jahiel, et Ani, et Eliab, et Maasias, et Banaias in nablis arcana cantabant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 15:21",
      "text": "Porro Mathathias, et Eliphalu, et Macenias, et Obededom, et Jehiel, et Ozaziu, in citharis pro octava canebant epinicion.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 15:22",
      "text": "Chonenias autem princeps Levitarum, prophetiæ præerat, ad præcinendam melodiam: erat quippe valde sapiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 15:23",
      "text": "Et Barachias, et Elcana, janitores arcæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 15:24",
      "text": "Porro Sebenias, et Josaphat, et Nathanaël, et Amasai, et Zacharias, et Banaias, et Eliezer sacerdotes, clangebant tubis coram arca Dei: et Obededom et Jehias erant janitores arcæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 15:25",
      "text": "Igitur David, et omnes majores natu Israël, et tribuni, ierunt ad deportandam arcam fœderis Domini de domo Obededom cum lætitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 15:26",
      "text": "Cumque adjuvisset Deus Levitas qui portabant arcam fœderis Domini, immolabantur septem tauri, et septem arietes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 15:27",
      "text": "Porro David erat indutus stola byssina, et universi Levitæ qui portabant arcam, cantoresque, et Chonenias princeps prophetiæ inter cantores: David autem etiam indutus erat ephod lineo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 15:28",
      "text": "Universusque Israël deducebant arcam fœderis Domini in jubilo, et sonitu buccinæ, et tubis, et cymbalis, et nablis, et citharis concrepantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.15.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 15:29",
      "text": "Cumque pervenisset arca fœderis Domini usque ad civitatem David, Michol filia Saul prospiciens per fenestram vidit regem David saltantem atque ludentem, et despexit eum in corde suo.",
      "paragraphStart": false
    }
  ]
}
