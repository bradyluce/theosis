{
  "chapter": {
    "id": "vulgate:first-chronicles.26",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 26,
    "referenceLabel": "1 Chronicles 26",
    "summary": "Source text for 1 Chronicles 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.26.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 26:1",
      "text": "Divisiones autem janitorum: de Coritis Meselemia, filius Core, de filiis Asaph.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.26.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 26:2",
      "text": "Filii Meselemiæ: Zacharias primogenitus, Jadihel secundus, Zabadias tertius, Jathanaël quartus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 26:3",
      "text": "Ælam quintus, Johanan sextus, Elioënai septimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 26:4",
      "text": "Filii autem Obededom: Semeias primogenitus, Jozabad secundus, Joaha tertius, Sachar quartus, Nathanaël quintus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 26:5",
      "text": "Ammiel sextus, Issachar septimus, Phollathi octavus: quia benedixit illi Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 26:6",
      "text": "Semei autem filio ejus nati sunt filii, præfecti familiarum suarum: erant enim viri fortissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 26:7",
      "text": "Filii ergo Semeiæ: Othni, et Raphaël, et Obed, Elzabad, fratres ejus viri fortissimi: Eliu quoque et Samachias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 26:8",
      "text": "Omnes hi, de filiis Obededom: ipsi, et filii et fratres eorum, fortissimi ad ministrandum, sexaginta duo de Obededom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 26:9",
      "text": "Porro Meselemiæ filii, et fratres eorum robustissimi, decem et octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 26:10",
      "text": "De Hosa autem, id est, de filiis Merari: Semri princeps (non enim habuerat primogenitum, et idcirco posuerat eum pater ejus in principem),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 26:11",
      "text": "Helcias secundus, Tabelias tertius, Zacharias quartus: omnes hi filii et fratres Hosa, tredecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 26:12",
      "text": "Hi divisi sunt in janitores, ut semper principes custodiarum, sicut et fratres eorum ministrarent in domo Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 26:13",
      "text": "Missæ sunt ergo sortes ex æquo, et parvis et magnis, per familias suas in unamquamque portarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 26:14",
      "text": "Cecidit ergo sors orientalis, Selemiæ. Porro Zachariæ filio ejus, viro prudentissimo et erudito, sortito obtigit plaga septentrionalis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 26:15",
      "text": "Obededom vero et filiis ejus ad austrum: in qua parte domus erat seniorum concilium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 26:16",
      "text": "Sephim et Hosa ad occidentem, juxta portam, quæ ducit ad viam ascensionis: custodia contra custodiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 26:17",
      "text": "Ad orientem vero Levitæ sex: et ad aquilonem, quatuor per diem: atque ad meridiem similiter in die quatuor: et ubi erat concilium bini et bini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 26:18",
      "text": "In cellulis quoque janitorum ad occidentem quatuor in via, binique per cellulas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 26:19",
      "text": "Hæ sunt divisiones janitorum filiorum Core et Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 26:20",
      "text": "Porro Achias erat super thesauros domus Dei, et vasa sanctorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 26:21",
      "text": "Filii Ledan, filii Gersonni: de Ledan principes familiarum Ledan, et Gersonni, Jehieli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 26:22",
      "text": "Filii Jehieli: Zathan, et Joël fratres ejus super thesauros domus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 26:23",
      "text": "Amramitis, et Isaaritis, et Hebronitis, et Ozihelitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 26:24",
      "text": "Subaël autem filius Gersom filii Moysi, præpositus thesauris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 26:25",
      "text": "Fratres quoque ejus Eliezer, cujus filius Rahabia, et hujus filius Isaias, et hujus filius Joram, hujus quoque filius Zechri, et hujus filius Selemith.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 26:26",
      "text": "Ipse Selemith, et fratres ejus, super thesauros sanctorum quæ sanctificavit David rex, et principes familiarum, et tribuni, et centuriones, et duces exercitus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 26:27",
      "text": "de bellis et manubiis præliorum, quæ consecraverant ad instaurationem et supellectilem templi Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 26:28",
      "text": "Hæc autem universa sanctificavit Samuel videns, et Saul filius Cis, et Abner filius Ner, et Joab filius Sarviæ: omnes qui sanctificaverant ea per manum Selemith et fratrum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 26:29",
      "text": "Isaaritis vero præerat Chonenias, et filii ejus ad opera forinsecus super Israël ad docendum et judicandum eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 26:30",
      "text": "Porro de Hebronitis Hasabias, et fratres ejus viri fortissimi, mille septingenti præerant Israëli trans Jordanem contra occidentem, in cunctis operibus Domini, et in ministerium regis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 26:31",
      "text": "Hebronitarum autem princeps fuit Jeria secundum familias et cognationes eorum. Quadragesimo anno regni David recensiti sunt, et inventi sunt viri fortissimi in Jazer Galaad,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.26.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 26,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 26:32",
      "text": "fratresque ejus robustioris ætatis, duo millia septingenti principes familiarum. Præposuit autem eos David rex Rubenitis, et Gadditis, et dimidiæ tribui Manasse, in omne ministerium Dei et regis.",
      "paragraphStart": false
    }
  ]
}
