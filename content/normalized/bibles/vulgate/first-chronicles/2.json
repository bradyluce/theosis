{
  "chapter": {
    "id": "vulgate:first-chronicles.2",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 2,
    "referenceLabel": "1 Chronicles 2",
    "summary": "Source text for 1 Chronicles 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.2.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 2:1",
      "text": "Filii autem Israël: Ruben, Simeon, Levi, Juda, Issachar, et Zabulon,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.2.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 2:2",
      "text": "Dan, Joseph, Benjamin, Nephthali, Gad, et Aser.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 2:3",
      "text": "Filii Juda: Her, Onan, et Sela: hi tres nati sunt ei de filia Sue Chananitide. Fuit autem Her primogenitus Juda malus coram Domino, et occidit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 2:4",
      "text": "Thamar autem nurus ejus peperit ei Phares et Zara: omnes ergo filii Juda, quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 2:5",
      "text": "Filii autem Phares: Hesron et Hamul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 2:6",
      "text": "Filii quoque Zaræ: Zamri, et Ethan, et Eman, Chalchal quoque, et Dara, simul quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 2:7",
      "text": "Filii Charmi: Achar, qui turbavit Israël, et peccavit in furto anathematis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 2:8",
      "text": "Filii Ethan: Azarias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 2:9",
      "text": "Filii autem Hesron qui nati sunt ei: Jerameel, et Ram, et Calubi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 2:10",
      "text": "Porro Ram genuit Aminadab. Aminadab autem genuit Nahasson, principem filiorum Juda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 2:11",
      "text": "Nahasson quoque genuit Salma, de quo ortus est Booz.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 2:12",
      "text": "Booz vero genuit Obed, qui et ipse genuit Isai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 2:13",
      "text": "Isai autem genuit primogenitum Eliab, secundum Abinadab, tertium Simmaa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 2:14",
      "text": "quartum Nathanaël, quintum Raddai,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 2:15",
      "text": "sextum Asom, septimum David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 2:16",
      "text": "Quorum sorores fuerunt Sarvia et Abigail. Filii Sarviæ: Abisai, Joab, et Asaël, tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 2:17",
      "text": "Abigail autem genuit Amasa, cujus pater fuit Jether Ismahelites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 2:18",
      "text": "Caleb vero filius Hesron accepit uxorem nomine Azuba, de qua genuit Jerioth: fueruntque filii ejus Jaser, et Sobab, et Ardon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 2:19",
      "text": "Cumque mortua fuisset Azuba, accepit uxorem Caleb Ephratha, quæ peperit ei Hur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 2:20",
      "text": "Porro Hur genuit Uri, et Uri genuit Bezeleel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 2:21",
      "text": "Post hæc ingressus est Hesron ad filiam Machir patris Galaad, et accepit eam cum esset annorum sexaginta: quæ peperit ei Segub.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 2:22",
      "text": "Sed et Segub genuit Jair, et possedit viginti tres civitates in terra Galaad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 2:23",
      "text": "Cepitque Gessur et Aram oppida Jair, et Canath, et viculos ejus sexaginta civitatum: omnes isti filii Machir patris Galaad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 2:24",
      "text": "Cum autem mortuus esset Hesron, ingressus est Caleb ad Ephratha. Habuit quoque Hesron uxorem Abia, quæ peperit ei Assur patrem Thecuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 2:25",
      "text": "Nati sunt autem filii Jerameel primogeniti Hesron, Ram primogenitus ejus, et Buna, et Aram, et Asom, et Achia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 2:26",
      "text": "Duxit quoque uxorem alteram Jerameel, nomine Atara, quæ fuit mater Onam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 2:27",
      "text": "Sed et filii Ram primogeniti Jerameel fuerunt Moos, Jamin, et Achar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 2:28",
      "text": "Onam autem habuit filios Semei et Jada. Filii autem Semei: Nadab et Abisur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 2:29",
      "text": "Nomen vero uxoris Abisur, Abihail, quæ peperit ei Ahobban et Molid.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 2:30",
      "text": "Filii autem Nadab fuerunt Saled et Apphaim. Mortuus est autem Saled absque liberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 2:31",
      "text": "Filius vero Apphaim, Jesi: qui Jesi genuit Sesan. Porro Sesan genuit Oholai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 2:32",
      "text": "Filii autem Jada fratris Semei: Jether, et Jonathan. Sed et Jether mortuus est absque liberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 2:33",
      "text": "Porro Jonathan genuit Phaleth, et Ziza. Isti fuerunt filii Jerameel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 2:34",
      "text": "Sesan autem non habuit filios, sed filias: et servum ægyptium nomine Jeraa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 2:35",
      "text": "Deditque ei filiam suam uxorem: quæ peperit ei Ethei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 2:36",
      "text": "Ethei autem genuit Nathan, et Nathan genuit Zabad.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 2:37",
      "text": "Zabad quoque genuit Ophlal, et Ophlal genuit Obed.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 2:38",
      "text": "Obed genuit Jehu, Jehu genuit Azariam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 2:39",
      "text": "Azarias genuit Helles, et Helles genuit Elasa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 2:40",
      "text": "Elasa genuit Sisamoi, Sisamoi genuit Sellum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 2:41",
      "text": "Sellum genuit Icamiam, Icamia autem genuit Elisama.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 2:42",
      "text": "Filii autem Caleb fratris Jerameel: Mesa primogenitus ejus; ipse est pater Ziph: et filii Maresa patris Hebron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 2:43",
      "text": "Porro filii Hebron, Core, et Taphua, et Recem, et Samma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.44",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 2:44",
      "text": "Samma autem genuit Raham, patrem Jercaam, et Recem genuit Sammai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.45",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 2:45",
      "text": "Filius Sammai, Maon: et Maon pater Bethsur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.46",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 2:46",
      "text": "Epha autem concubina Caleb peperit Haran, et Mosa, et Gezez. Porro Haran genuit Gezez.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.47",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 2:47",
      "text": "Filii autem Jahaddai, Regom, et Joathan, et Gesan, et Phalet, et Epha, et Saaph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.48",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 2:48",
      "text": "Concubina Caleb Maacha, peperit Saber, et Tharana.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.49",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 2:49",
      "text": "Genuit autem Saaph pater Madmena Sue, patrem Machbena et patrem Gabaa. Filia vero Caleb fuit Achsa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.50",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 2:50",
      "text": "Hi erant filii Caleb, filii Hur primogeniti Ephratha, Sobal pater Cariathiarim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.51",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 2:51",
      "text": "Salma pater Bethlehem, Hariph pater Bethgader.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.52",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 2:52",
      "text": "Fuerunt autem filii Sobal patris Cariathiarim, qui videbat dimidium requietionum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.53",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 2:53",
      "text": "Et de cognatione Cariathiarim, Jethrei, et Aphuthei, et Semathei, et Maserei. Ex his egressi sunt Saraitæ, et Esthaolitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.54",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 2:54",
      "text": "Filii Salma, Bethlehem, et Netophathi, coronæ domus Joab, et dimidium requietionis Sarai:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.2.55",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "1 Chronicles 2:55",
      "text": "cognationes quoque scribarum habitantium in Jabes, canentes atque resonantes, et in tabernaculis commorantes. Hi sunt Cinæi, qui venerunt de Calore patris domus Rechab.",
      "paragraphStart": false
    }
  ]
}
