{
  "chapter": {
    "id": "vulgate:first-chronicles.3",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 3,
    "referenceLabel": "1 Chronicles 3",
    "summary": "Source text for 1 Chronicles 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.3.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 3:1",
      "text": "David vero hos habuit filios, qui ei nati sunt in Hebron: primogenitum Amnon ex Achinoam Jezrahelitide, secundum Daniel de Abigail Carmelitide,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.3.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 3:2",
      "text": "tertium Absalom filium Maacha filiæ Tholmai regis Gessur, quartum Adoniam filium Aggith,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 3:3",
      "text": "quintum Saphathiam ex Abital, sextum Jethraham de Egla uxore sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 3:4",
      "text": "Sex ergo nati sunt ei in Hebron, ubi regnavit septem annis et sex mensibus. Triginta autem et tribus annis regnavit in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 3:5",
      "text": "Porro in Jerusalem nati sunt ei filii, Simmaa, et Sobab, et Nathan, et Salomon, quatuor de Bethsabee filia Ammiel:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 3:6",
      "text": "Jebaar quoque et Elisama,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 3:7",
      "text": "et Eliphaleth, et Noge, et Nepheg, et Japhia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 3:8",
      "text": "necnon Elisama, et Eliada, et Elipheleth, novem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 3:9",
      "text": "omnes hi, filii David absque filiis concubinarum: habueruntque sororem Thamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 3:10",
      "text": "Filius autem Salomonis, Roboam: cujus Abia filius genuit Asa. De hoc quoque natus est Josaphat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 3:11",
      "text": "pater Joram: qui Joram genuit Ochoziam, ex quo ortus est Joas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 3:12",
      "text": "et hujus Amasias filius genuit Azariam. Porro Azariæ filius Joatham",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 3:13",
      "text": "procreavit Achaz patrem Ezechiæ, de quo natus est Manasses.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 3:14",
      "text": "Sed et Manasses genuit Amon patrem Josiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 3:15",
      "text": "Filii autem Josiæ fuerunt: primogenitus Johanan, secundus Joakim, tertius Sedecias, quartus Sellum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 3:16",
      "text": "De Joakim natus est Jechonias, et Sedecias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 3:17",
      "text": "Filii Jechoniæ fuerunt: Asir, Salathiel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 3:18",
      "text": "Melchiram, Phadaia, Senneser, et Jecemia, Sama, et Nadabia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 3:19",
      "text": "De Phadaia orti sunt Zorobabel et Semei. Zorobabel genuit Mosollam, Hananiam, et Salomith sororem eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 3:20",
      "text": "Hasaban quoque, et Ohol, et Barachian, et Hasadian, Josabhesed, quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 3:21",
      "text": "Filius autem Hananiæ, Phaltias pater Jeseiæ, cujus filius Raphaia: hujus quoque filius, Arnan, de quo natus est Obdia, cujus filius fuit Sechenias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 3:22",
      "text": "Filius Secheniæ, Semeia: cujus filii Hattus, et Jegaal, et Baria, et Naaria, et Saphat, sex numero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 3:23",
      "text": "Filius Naariæ, Elioënai, et Ezechias, et Ezricam, tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.3.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 3:24",
      "text": "Filii Elioënai, Oduia, et Eliasub, et Pheleia, et Accub, et Johanan, et Dalaia, et Anani, septem.",
      "paragraphStart": false
    }
  ]
}
