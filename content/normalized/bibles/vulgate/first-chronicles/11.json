{
  "chapter": {
    "id": "vulgate:first-chronicles.11",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 11,
    "referenceLabel": "1 Chronicles 11",
    "summary": "Source text for 1 Chronicles 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.11.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 11:1",
      "text": "Congregatus est igitur omnis Israël ad David in Hebron, dicens: Os tuum sumus, et caro tua.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.11.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 11:2",
      "text": "Heri quoque et nudiustertius cum adhuc regnaret Saul, tu eras qui educebas et introducebas Israël: tibi enim dixit Dominus Deus tuus: Tu pasces populum meum Israël, et tu eris princeps super eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 11:3",
      "text": "Venerunt ergo omnes majores natu Israël ad regem in Hebron, et iniit David cum eis fœdus coram Domino: unxeruntque eum regem super Israël, juxta sermonem Domini quem locutus est in manu Samuel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 11:4",
      "text": "Abiit quoque David et omnis Israël in Jerusalem: hæc est Jebus, ubi erant Jebusæi habitatores terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 11:5",
      "text": "Dixeruntque qui habitabant in Jebus ad David: Non ingredieris huc. Porro David cepit arcem Sion, quæ est civitas David,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 11:6",
      "text": "dixitque: Omnis qui percusserit Jebusæum in primis, erit princeps et dux. Ascendit igitur primus Joab filius Sarviæ, et factus est princeps.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 11:7",
      "text": "Habitavit autem David in arce, et idcirco appellata est civitas David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 11:8",
      "text": "Ædificavitque urbem in circuitu a Mello usque ad gyrum; Joab autem reliqua urbis exstruxit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 11:9",
      "text": "Proficiebatque David vadens et crescens, et Dominus exercituum erat cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 11:10",
      "text": "Hi principes virorum fortium David, qui adjuverunt eum ut rex fieret super omnem Israël, juxta verbum Domini quod locutus est ad Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 11:11",
      "text": "Et iste numerus robustorum David: Jesbaam filius Hachamoni princeps inter triginta: iste levavit hastam suam super trecentos vulneratos una vice.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 11:12",
      "text": "Et post eum Eleazar filius patrui ejus Ahohites, qui erat inter tres potentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 11:13",
      "text": "Iste fuit cum David in Phesdomim, quando Philisthiim congregati sunt ad locum illum in prælium: et erat ager regionis illius plenus hordeo, fugeratque populus a facie Philisthinorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 11:14",
      "text": "Hi steterunt in medio agri, et defenderunt eum: cumque percussissent Philisthæos, dedit Dominus salutem magnam populo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 11:15",
      "text": "Descenderunt autem tres de triginta principibus ad petram, in qua erat David, ad speluncam Odollam, quando Philisthiim fuerant castrametati in valle Raphaim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 11:16",
      "text": "Porro David erat in præsidio, et statio Philisthinorum in Bethlehem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 11:17",
      "text": "Desideravit igitur David, et dixit: O si quis daret mihi aquam de cisterna Bethlehem, quæ est in porta!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 11:18",
      "text": "Tres ergo isti per media castra Philisthinorum perrexerunt, et hauserunt aquam de cisterna Bethlehem quæ erat in porta, et attulerunt ad David ut biberet. Qui noluit, sed magis libavit illam Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 11:19",
      "text": "dicens: Absit ut in conspectu Dei mei hoc faciam, et sanguinem istorum virorum bibam: quia in periculo animarum suarum attulerunt mihi aquam. Et ob hanc causam noluit bibere: hæc fecerunt tres robustissimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 11:20",
      "text": "Abisai quoque frater Joab ipse erat princeps trium, et ipse levavit hastam suam contra trecentos vulneratos, et ipse erat inter tres nominatissimus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 11:21",
      "text": "et inter tres secundos inclytus, et princeps eorum: verumtamen usque ad tres primos non pervenerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 11:22",
      "text": "Banaias filius Jojadæ viri robustissimi, qui multa opera perpetrarat, de Cabseel: ipse percussit duos ariel Moab, et ipse descendit et interfecit leonem in media cisterna tempore nivis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 11:23",
      "text": "Et ipse percussit virum ægyptium, cujus statura erat quinque cubitorum, et habebat lanceam ut liciatorium texentium: descendit igitur ad eum cum virga, et rapuit hastam quam tenebat manu, et interfecit eum hasta sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 11:24",
      "text": "Hæc fecit Banaias filius Jojadæ, qui erat inter tres robustos nominatissimus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 11:25",
      "text": "inter triginta primus, verumtamen ad tres usque non pervenerat: posuit autem eum David ad auriculam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 11:26",
      "text": "Porro fortissimi viri in exercitu, Asahel frater Joab, et Elchanan filius patrui ejus de Bethlehem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 11:27",
      "text": "Sammoth Arorites, Helles Pharonites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 11:28",
      "text": "Ira filius Acces Thecuites, Abiezer Anathothites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 11:29",
      "text": "Sobbochai Husathites, Ilai Ahohites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 11:30",
      "text": "Maharai Netophathites, Heled filius Baana Netophathites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 11:31",
      "text": "Ethai filius Ribai de Gabaath filiorum Benjamin, Banaia Pharatonites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 11:32",
      "text": "Hurai de torrente Gaas, Abiel Arbathites, Azmoth Bauramites, Eliaba Salabonites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 11:33",
      "text": "Filii Assem Gezonites, Jonathan filius Sage Ararites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 11:34",
      "text": "Ahiam filius Sachar Ararites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 11:35",
      "text": "Eliphal filius Ur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 11:36",
      "text": "Hepher Mecherathites, Ahia Phelonites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 11:37",
      "text": "Hesro Carmelites, Naarai filius Asbai,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 11:38",
      "text": "Joël frater Nathan, Mibahar filius Agarai,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 11:39",
      "text": "Selec Ammonites, Naharai Berothites armiger Joab filii Sarviæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 11:40",
      "text": "Ira Jethræus, Gareb Jethræus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 11:41",
      "text": "Urias Hethæus, Zabad filius Oholi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 11:42",
      "text": "Adina filius Siza Rubenites princeps Rubenitarum, et cum eo triginta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 11:43",
      "text": "Hanan filius Maacha, et Josaphat Mathanites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.44",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 11:44",
      "text": "Ozia Astarothites, Samma, et Jehiel filii Hotham Arorites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.45",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 11:45",
      "text": "Jedihel filius Samri, et Joha frater ejus Thosaites,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.11.46",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 11,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 11:46",
      "text": "Eliel Mahumites, et Jeribai, et Josaia filii Elnaëm, et Jethma Moabites, Eliel, et Obed, et Jasiel de Masobia.",
      "paragraphStart": false
    }
  ]
}
