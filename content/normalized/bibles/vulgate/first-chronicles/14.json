{
  "chapter": {
    "id": "vulgate:first-chronicles.14",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 14,
    "referenceLabel": "1 Chronicles 14",
    "summary": "Source text for 1 Chronicles 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.14.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 14:1",
      "text": "Misit quoque Hiram rex Tyri nuntios ad David, et ligna cedrina, et artifices parietum, lignorumque, ut ædificarent ei domum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.14.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 14:2",
      "text": "Cognovitque David quod confirmasset eum Dominus in regem super Israël, et sublevatum esset regnum suum super populum ejus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 14:3",
      "text": "Accepit quoque David alias uxores in Jerusalem, genuitque filios et filias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 14:4",
      "text": "Et hæc nomina eorum, qui nati sunt ei in Jerusalem: Samua, et Sobab, Nathan, et Salomon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 14:5",
      "text": "Jebahar, et Elisua, et Eliphalet,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 14:6",
      "text": "Noga quoque, et Napheg, et Japhia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 14:7",
      "text": "Elisama, et Baaliada, et Eliphalet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 14:8",
      "text": "Audientes autem Philisthiim eo quod unctus esset David regem super universum Israël, ascenderunt omnes ut quærerent eum: quod cum audisset David, egressus est obviam eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 14:9",
      "text": "Porro Philisthiim venientes, diffusi sunt in valle Raphaim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 14:10",
      "text": "Consuluitque David Dominum, dicens: Si ascendam ad Philisthæos, et si trades eos in manu mea? Et dixit ei Dominus: Ascende, et tradam eos in manu tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 14:11",
      "text": "Cumque illi ascendissent in Baalpharasim, percussit eos ibi David, et dixit: Divisit Deus inimicos meos per manum meam, sicut dividuntur aquæ: et idcirco vocatum est nomen illius loci Baalpharasim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 14:12",
      "text": "Dereliqueruntque ibi deos suos, quos David jussit exuri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 14:13",
      "text": "Alia etiam vice Philisthiim irruerunt, et diffusi sunt in valle.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 14:14",
      "text": "Consuluitque rursum David Deum, et dixit ei Deus: Non ascendas post eos: recede ab eis, et venies contra illos ex adverso pyrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 14:15",
      "text": "Cumque audieris sonitum gradientis in cacumine pyrorum, tunc egredieris ad bellum: egressus est enim Deus ante te, ut percutiat castra Philisthiim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 14:16",
      "text": "Fecit ergo David sicut præceperat ei Deus, et percussit castra Philisthinorum, de Gabaon usque Gazera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.14.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 14:17",
      "text": "Divulgatumque est nomen David in universis regionibus, et Dominus dedit pavorem ejus super omnes gentes.",
      "paragraphStart": false
    }
  ]
}
