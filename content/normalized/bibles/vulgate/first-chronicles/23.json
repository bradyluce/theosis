{
  "chapter": {
    "id": "vulgate:first-chronicles.23",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 23,
    "referenceLabel": "1 Chronicles 23",
    "summary": "Source text for 1 Chronicles 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.23.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 23:1",
      "text": "Igitur David, senex et plenus dierum, regem constituit Salomonem filium suum super Israël.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.23.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 23:2",
      "text": "Et congregavit omnes principes Israël, et sacerdotes atque Levitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 23:3",
      "text": "Numeratique sunt Levitæ a triginta annis et supra: et inventa sunt triginta octo millia virorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 23:4",
      "text": "Ex his electi sunt, et distributi in ministerium domus Domini, viginti quatuor millia: præpositorum autem et judicum, sex millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 23:5",
      "text": "Porro quatuor millia janitores, et totidem psaltæ, canentes Domino in organis quæ fecerat ad canendum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 23:6",
      "text": "Et distribuit eos David per vices filiorum Levi, Gerson videlicet, et Caath, et Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 23:7",
      "text": "Filii Gerson: Leedan, et Semei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 23:8",
      "text": "Filii Leedan: princeps Jahiel, et Zethan, et Joël, tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 23:9",
      "text": "Filii Semei: Salomith, et Hosiel, et Aran, tres: isti principes familiarum Leedan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 23:10",
      "text": "Porro filii Semei: Leheth, et Ziza, et Jaus, et Baria: isti filii Semei, quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 23:11",
      "text": "Erat autem Leheth prior, Ziza secundus: porro Jaus et Baria non habuerunt plurimos filios, et idcirco in una familia, unaque domo computati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 23:12",
      "text": "Filii Caath: Amram, et Isaar, Hebron, et Oziel, quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 23:13",
      "text": "Filii Amram: Aaron et Moyses. Separatusque est Aaron ut ministraret in Sancto sanctorum, ipse et filii ejus in sempiternum, et adoleret incensum Domino secundum ritum suum, ac benediceret nomini ejus in perpetuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 23:14",
      "text": "Moysi quoque hominis Dei filii annumerati sunt in tribu Levi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 23:15",
      "text": "Filii Moysi: Gersom et Eliezer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 23:16",
      "text": "Filii Gersom: Subuel primus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 23:17",
      "text": "Fuerunt autem filii Eliezer: Rohobia primus: et non erant Eliezer filii alii. Porro filii Rohobia multiplicati sunt nimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 23:18",
      "text": "Filii Isaar: Salomith primus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 23:19",
      "text": "Filii Hebron: Jeriau primus, Amarias secundus, Jahaziel tertius, Jecmaam quartus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 23:20",
      "text": "Filii Oziel: Micha primus, Jesia secundus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 23:21",
      "text": "Filii Merari: Moholi, et Musi. Filii Moholi: Eleazar et Cis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 23:22",
      "text": "Mortuus est autem Eleazar, et non habuit filios, sed filias: acceperuntque eas filii Cis fratres earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 23:23",
      "text": "Filii Musi: Moholi, et Eder, et Jerimoth, tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 23:24",
      "text": "Hi filii Levi in cognationibus et familiis suis, principes per vices, et numerum capitum singulorum qui faciebant opera ministerii domus Domini, a viginti annis et supra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 23:25",
      "text": "Dixit enim David: Requiem dedit Dominus Deus Israël populo suo, et habitationem Jerusalem usque in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 23:26",
      "text": "Nec erit officii Levitarum ut ultra portent tabernaculum et omnia vasa ejus ad ministrandum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 23:27",
      "text": "Juxta præcepta quoque David novissima, supputabitur numerus filiorum Levi a viginti annis et supra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 23:28",
      "text": "Et erunt sub manu filiorum Aaron in cultum domus Domini, in vestibulis, et in exedris, et in loco purificationis, et in sanctuario, et in universis operibus ministerii templi Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 23:29",
      "text": "Sacerdotes autem, super panes propositionis, et ad similæ sacrificium, et ad lagana azyma, et sartaginem, et ad torrendum, et super omne pondus atque mensuram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 23:30",
      "text": "Levitæ vero ut stent mane ad confitendum et canendum Domino: similiterque ad vesperam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 23:31",
      "text": "tam in oblatione holocaustorum Domini, quam in sabbatis et calendis et solemnitatibus reliquis juxta numerum et cæremonias uniuscujusque rei, jugiter coram Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.23.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 23:32",
      "text": "Et custodiant observationes tabernaculi fœderis, et ritum sanctuarii, et observationem filiorum Aaron fratrum suorum, ut ministrent in domo Domini.",
      "paragraphStart": false
    }
  ]
}
