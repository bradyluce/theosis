{
  "chapter": {
    "id": "vulgate:first-chronicles.9",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 9,
    "referenceLabel": "1 Chronicles 9",
    "summary": "Source text for 1 Chronicles 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.9.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 9:1",
      "text": "Universus ergo Israël dinumeratus est, et summa eorum scripta est in libro regum Israël et Juda: translatique sunt in Babylonem propter delictum suum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.9.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 9:2",
      "text": "Qui autem habitaverunt primi in possessionibus et in urbibus suis: Israël, et sacerdotes, et Levitæ, et Nathinæi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 9:3",
      "text": "Commorati sunt in Jerusalem de filiis Juda, et de filiis Benjamin, de filiis quoque Ephraim, et Manasse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 9:4",
      "text": "Othei filius Ammiud, filii Amri, filii Omrai, filii Bonni, de filiis Phares filii Juda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 9:5",
      "text": "Et de Siloni: Asaia primogenitus, et filii ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 9:6",
      "text": "De filiis autem Zara, Jehuel, et fratres eorum, sexcenti nonaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 9:7",
      "text": "Porro de filiis Benjamin: Salo filius Mosollam, filii Oduia, filii Asana,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 9:8",
      "text": "et Jobania filius Jeroham, et Ela filius Ozi, filii Mochori, et Mosollam filius Saphatiæ, filii Rahuel, filii Jebaniæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 9:9",
      "text": "et fratres eorum per familias suas, nongenti quinquaginta sex. Omnes hi principes cognationum per domos patrum suorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 9:10",
      "text": "De sacerdotibus autem: Jedaia, Jojarib, et Jachin:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 9:11",
      "text": "Azarias quoque filius Helciæ, filii Mosollam, filii Sadoc, filii Maraioth, filii Achitob, pontifex domus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 9:12",
      "text": "Porro Adaias filius Jeroham, filii Phassur, filii Melchiæ, et Maasai filius Adiel filii Jezra, filii Mosollam, filii Mosollamith, filii Emmer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 9:13",
      "text": "Fratres quoque eorum principes per familias suas, mille septingenti sexaginta, fortissimi robore ad faciendum opus ministerii in domo Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 9:14",
      "text": "De Levitis autem: Semeia filius Hassub filii Ezricam, filii Hasebia de filiis Merari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 9:15",
      "text": "Bacbacar quoque carpentarius, et Galal, et Mathania filius Micha, filii Zechri, filii Asaph:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 9:16",
      "text": "et Obdia filius Semeiæ, filii Galal, filii Idithun: et Barachia filius Asa, filii Elcana, qui habitavit in atriis Netophati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 9:17",
      "text": "Janitores autem: Sellum, et Accub, et Telmon, et Ahimam: et frater eorum Sellum princeps,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 9:18",
      "text": "usque ad illud tempus, in porta regis ad orientem, observabant per vices suas de filiis Levi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 9:19",
      "text": "Sellum vero filius Core filii Abiasaph, filii Core, cum fratribus suis, et domo patris sui, hi sunt Coritæ super opera ministerii, custodes vestibulorum tabernaculi: et familiæ eorum per vices castrorum Domini custodientes introitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 9:20",
      "text": "Phinees autem filius Eleazari erat dux eorum coram Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 9:21",
      "text": "Porro Zacharias filius Mosollamia, janitor portæ tabernaculi testimonii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 9:22",
      "text": "Omnes hi electi in ostiarios per portas, ducenti duodecim: et descripti in villis propriis, quos constituerunt David, et Samuel videns, in fide sua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 9:23",
      "text": "tam ipsos quam filios eorum, in ostiis domus Domini et in tabernaculo vicibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 9:24",
      "text": "Per quatuor ventos erant ostiarii: id est, ad orientem, et ad occidentem, et ad aquilonem, et ad austrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 9:25",
      "text": "Fratres autem eorum in viculis morabantur, et veniebant in sabbatis suis de tempore usque ad tempus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 9:26",
      "text": "His quatuor Levitis creditus erat omnis numerus janitorum, et erant super exedras et thesauros domus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 9:27",
      "text": "Per gyrum quoque templi Domini morabantur in custodiis suis: ut cum tempus fuisset, ipsi mane aperirent fores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 9:28",
      "text": "De horum genere erant et super vasa ministerii: ad numerum enim et inferebantur vasa, et efferebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 9:29",
      "text": "De ipsis et qui credita habebant utensilia sanctuarii, præerant similæ, et vino, et oleo, et thuri, et aromatibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 9:30",
      "text": "Filii autem sacerdotum unguenta ex aromatibus conficiebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 9:31",
      "text": "Et Mathathias Levites primogenitus Sellum Coritæ, præfectus erat eorum quæ in sartagine frigebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 9:32",
      "text": "Porro de filiis Caath fratribus eorum, super panes erant propositionis, ut semper novos per singula sabbata præpararent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 9:33",
      "text": "Hi sunt principes cantorum per familias Levitarum, qui in exedris morabantur, ut die ac nocte jugiter suo ministerio deservirent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 9:34",
      "text": "Capita Levitarum, per familias suas principes, manserunt in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 9:35",
      "text": "In Gabaon autem commorati sunt pater Gabaon Jehiel, et nomen uxoris ejus Maacha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 9:36",
      "text": "Filius primogenitus ejus Abdon, et Sur, et Cis, et Baal, et Ner, et Nadab,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 9:37",
      "text": "Gedor quoque, et Ahio, et Zacharias, et Macelloth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 9:38",
      "text": "Porro Macelloth genuit Samaan: isti habitaverunt e regione fratrum suorum in Jerusalem cum fratribus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 9:39",
      "text": "Ner autem genuit Cis, et Cis genuit Saul, et Saul genuit Jonathan, et Melchisua, et Abinadab, et Esbaal.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 9:40",
      "text": "Filius autem Jonathan, Meribbaal: et Meribbaal genuit Micha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.41",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 9:41",
      "text": "Porro filii Micha, Phithon, et Melech, et Tharaa, et Ahaz.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.42",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 9:42",
      "text": "Ahaz autem genuit Jara, et Jara genuit Alamath, et Azmoth, et Zamri. Zamri autem genuit Mosa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.43",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 9:43",
      "text": "Mosa vero genuit Banaa, cujus filius Raphaia, genuit Elasa, de quo ortus est Asel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.9.44",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 9,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 9:44",
      "text": "Porro Asel sex filios habuit, his nominibus: Ezricam, Bocru, Ismahel, Saria, Obdia, Hanan: hi sunt filii Asel.",
      "paragraphStart": false
    }
  ]
}
