{
  "chapter": {
    "id": "vulgate:first-chronicles.24",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 24,
    "referenceLabel": "1 Chronicles 24",
    "summary": "Source text for 1 Chronicles 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.24.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 24:1",
      "text": "Porro filiis Aaron hæ partitiones erant. Filii Aaron: Nadab, et Abiu, et Eleazar, et Ithamar.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.24.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 24:2",
      "text": "Mortui sunt autem Nadab et Abiu ante patrem suum absque liberis: sacerdotioque functus est Eleazar, et Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 24:3",
      "text": "Et divisit eos David, id est, Sadoc de filiis Eleazari, et Ahimelech de filiis Ithamar, secundum vices suas et ministerium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 24:4",
      "text": "Inventique sunt multo plures filii Eleazar in principibus viris, quam filii Ithamar. Divisit autem eis, hoc est, filiis Eleazar, principes per familias sedecim: et filiis Ithamar per familias et domos suas octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 24:5",
      "text": "Porro divisit utrasque inter se familias sortibus: erant enim principes sanctuarii, et principes Dei, tam de filiis Eleazar quam de filiis Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 24:6",
      "text": "Descripsitque eos Semeias filius Nathanaël scriba Levites, coram rege et principibus, et Sadoc sacerdote, et Ahimelech filio Abiathar, principibus quoque familiarum sacerdotalium, et Leviticarum: unam domum, quæ ceteris præerat, Eleazar: et alteram domum, quæ sub se habebat ceteros, Ithamar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 24:7",
      "text": "Exivit autem sors prima Jojarib, secunda Jedei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 24:8",
      "text": "tertia Harim, quarta Seorim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 24:9",
      "text": "quinta Melchia, sexta Maiman,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 24:10",
      "text": "septima Accos, octava Abia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 24:11",
      "text": "nona Jesua, decima Sechenia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 24:12",
      "text": "undecima Eliasib, duodecima Jacim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 24:13",
      "text": "tertiadecima Hoppha, decimaquarta Isbaab,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 24:14",
      "text": "decimaquinta Belga, decimasexta Emmer,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 24:15",
      "text": "decimaseptima Hezir, decimaoctava Aphses,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 24:16",
      "text": "decimanona Pheteia, vigesima Hezechiel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 24:17",
      "text": "vigesima prima Jachin, vigesima secunda Gamul,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 24:18",
      "text": "vigesima tertia Dalaiau, vigesima quarta Maaziau.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 24:19",
      "text": "Hæ vices eorum secundum ministeria sua, ut ingrediantur domum Domini, et juxta ritum suum sub manu Aaron patris eorum, sicut præceperat Dominus Deus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 24:20",
      "text": "Porro filiorum Levi qui reliqui fuerant, de filiis Amram erat Subaël, et de filiis Subaël, Jehedeia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 24:21",
      "text": "De filiis quoque Rohobiæ, princeps Jesias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 24:22",
      "text": "Isaari vero filius Salemoth, filiusque Salemoth Jahath:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 24:23",
      "text": "filiusque ejus Jeriau primus, Amarias secundus, Jahaziel tertius, Jecmaan quartus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 24:24",
      "text": "Filius Oziel, Micha: filius Micha, Samir.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 24:25",
      "text": "Frater Micha, Jesia: filiusque Jesiæ, Zacharias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 24:26",
      "text": "Filii Merari: Moholi, et Musi. Filius Oziau: Benno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 24:27",
      "text": "Filius quoque Merari: Oziau, et Soam, et Zachur, et Hebri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 24:28",
      "text": "Porro Moholi filius, Eleazar, qui non habebat liberos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 24:29",
      "text": "Filius vero Cis, Jerameel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 24:30",
      "text": "Filii Musi: Moholi, Eder et Jerimoth: isti filii Levi secundum domos familiarum suarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.24.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 24:31",
      "text": "Miseruntque et ipsi sortes contra fratres suos filios Aaron coram David rege, et Sadoc, et Ahimelech, et principibus familiarum sacerdotalium et Leviticarum, tam majores quam minores: omnes sors æqualiter dividebat.",
      "paragraphStart": false
    }
  ]
}
