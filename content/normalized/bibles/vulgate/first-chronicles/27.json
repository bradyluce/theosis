{
  "chapter": {
    "id": "vulgate:first-chronicles.27",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 27,
    "referenceLabel": "1 Chronicles 27",
    "summary": "Source text for 1 Chronicles 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.27.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 27:1",
      "text": "Filii autem Israël secundum numerum suum, principes familiarum, tribuni, et centuriones, et præfecti, qui ministrabant regi juxta turmas suas, ingredientes et egredientes per singulos menses in anno, viginti quatuor millibus singuli præerant.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.27.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 27:2",
      "text": "Primæ turmæ in primo mense Jesboam præerat filius Zabdiel, et sub eo viginti quatuor millia;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 27:3",
      "text": "de filiis Phares, princeps cunctorum principum in exercitu mense primo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 27:4",
      "text": "Secundi mensis habebat turmam Dudia Ahohites, et post se alter nomine Macelloth, qui regebat partem exercitus viginti quatuor millium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 27:5",
      "text": "Dux quoque turmæ tertiæ in mense tertio erat Banaias filius Jojadæ sacerdos: et in divisione sua viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 27:6",
      "text": "Ipse est Banaias fortissimus inter triginta, et super triginta: præerat autem turmæ ipsius Amizabad filius ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 27:7",
      "text": "Quartus, mense quarto, Asahel frater Joab, et Zabadias filius ejus post eum: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 27:8",
      "text": "Quintus, mense quinto, princeps Samaoth Jezerites: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 27:9",
      "text": "Sextus, mense sexto, Hira filius Acces Thecuites: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 27:10",
      "text": "Septimus, mense septimo, Helles Phallonites de filiis Ephraim: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 27:11",
      "text": "Octavus, mense octavo, Sobochai Husathites de stirpe Zarahi: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 27:12",
      "text": "Nonus, mense nono, Abiezer Anathothites de filiis Jemini: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 27:13",
      "text": "Decimus, mense decimo, Marai, et ipse Netophathites de stirpe Zarai: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 27:14",
      "text": "Undecimus, mense undecimo, Banaias Pharathonites de filiis Ephraim: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 27:15",
      "text": "Duodecimus, mense duodecimo, Holdai Netophathites, de stirpe Gothoniel: et in turma ejus viginti quatuor millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 27:16",
      "text": "Porro tribubus præerant Israël, Rubenitis, dux Eliezer filius Zechri: Simeonitis, dux Saphatias filius Maacha:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 27:17",
      "text": "Levitis, Hasabias filius Camuel: Aaronitis, Sadoc:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 27:18",
      "text": "Juda, Eliu frater David: Issachar, Amri filius Michaël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 27:19",
      "text": "Zabulonitis, Jesmaias filius Abdiæ: Nephthalitibus, Jerimoth filius Ozriel:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 27:20",
      "text": "filiis Ephraim, Osee filius Ozaziu: dimidiæ tribui Manasse, Joël filius Phadaiæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 27:21",
      "text": "et dimidiæ tribui Manasse in Galaad, Jaddo filius Zachariæ: Benjamin autem, Jasiel filius Abner:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 27:22",
      "text": "Dan vero, Ezrihel filius Jeroham: hi principes filiorum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 27:23",
      "text": "Noluit autem David numerare eos a viginti annis inferius: quia dixerat Dominus ut multiplicaret Israël quasi stellas cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 27:24",
      "text": "Joab filius Sarviæ cœperat numerare, nec complevit: quia super hoc ira irruerat in Israël, et idcirco numerus eorum qui fuerant recensiti, non est relatus in fastos regis David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 27:25",
      "text": "Super thesauros autem regis fuit Azmoth filius Adiel: his autem thesauris, qui erant in urbibus, et in vicis, et in turribus, præsidebat Jonathan filius Oziæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 27:26",
      "text": "Operi autem rustico, et agricolis qui exercebant terram, præerat Ezri filius Chelub:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 27:27",
      "text": "vinearumque cultoribus, Semeias Romathites: cellis autem vinariis, Zabdias Aphonites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 27:28",
      "text": "Nam super oliveta et ficeta quæ erant in campestribus, Balanam Gederites: super apothecas autem olei, Joas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 27:29",
      "text": "Porro armentis quæ pascebantur in Saron, præpositus fuit Setrai Saronites: et super boves in vallibus, Saphat filius Adli:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 27:30",
      "text": "super camelos vero, Ubil Ismahelites: et super asinos, Jadias Meronathites:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 27:31",
      "text": "super oves quoque, Jaziz Agareus: omnes hi, principes substantiæ regis David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 27:32",
      "text": "Jonathan autem patruus David, consiliarius, vir prudens et litteratus: ipse et Jahiel filius Hachamoni erant cum filiis regis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 27:33",
      "text": "Achitophel etiam consiliarius regis, et Chusai Arachites amicus regis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.27.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 27,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 27:34",
      "text": "Post Achitophel fuit Jojada filius Banaiæ, et Abiathar. Princeps autem exercitus regis erat Joab.",
      "paragraphStart": false
    }
  ]
}
