{
  "chapter": {
    "id": "vulgate:first-chronicles.12",
    "translationId": "vulgate",
    "bookSlug": "first-chronicles",
    "chapterNumber": 12,
    "referenceLabel": "1 Chronicles 12",
    "summary": "Source text for 1 Chronicles 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-chronicles.12.1",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 12:1",
      "text": "Hi quoque venerunt ad David in Siceleg, cum adhuc fugeret Saul filium Cis, qui erant fortissimi et egregii pugnatores,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-chronicles.12.2",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 12:2",
      "text": "tendentes arcum, et utraque manu fundis saxa jacientes, et dirigentes sagittas, de fratribus Saul ex Benjamin.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.3",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 12:3",
      "text": "Princeps Ahiecer, et Joas filii Samaa Gabaathites, et Jaziel, et Phallet filii Azmoth, et Baracha, et Jehu Anathotites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.4",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 12:4",
      "text": "Samaias quoque Gabaonites fortissimus inter triginta et super triginta. Jeremias, et Jeheziel, et Johanan, et Jezabad Gaderothites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.5",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 12:5",
      "text": "Et Eluzai, et Jerimuth, et Baalia, et Samaria, et Saphatia Haruphites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.6",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 12:6",
      "text": "Elcana, et Jesia, et Azareel, et Joëzer, et Jesbaam de Carehim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.7",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 12:7",
      "text": "Joëla quoque, et Zabadia filii Jeroham de Gedor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.8",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 12:8",
      "text": "Sed et de Gaddi transfugerunt ad David cum lateret in deserto, viri robustissimi, et pugnatores optimi, tenentes clypeum et hastam: facies eorum quasi facies leonis, et veloces quasi capreæ in montibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.9",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 12:9",
      "text": "Ezer princeps, Obdias secundus, Eliab tertius,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.10",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 12:10",
      "text": "Masmana quartus, Jeremias quintus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.11",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 12:11",
      "text": "Ethi sextus, Eliel septimus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.12",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 12:12",
      "text": "Johanan octavus, Elzebad nonus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.13",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 12:13",
      "text": "Jeremias decimus, Machbanai undecimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.14",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 12:14",
      "text": "Hi de filiis Gad principes exercitus: novissimus centum militibus præerat, et maximus mille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.15",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 12:15",
      "text": "Isti sunt qui transierunt Jordanem mense primo, quando inundare consuevit super ripas suas: et omnes fugaverunt qui morabantur in vallibus ad orientalem plagam et occidentalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.16",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 12:16",
      "text": "Venerunt autem et de Benjamin et de Juda ad præsidium in quo morabatur David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.17",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 12:17",
      "text": "Egressusque est David obviam eis, et ait: Si pacifice venistis ad me ut auxiliemini mihi, cor meum jungatur vobis: si autem insidiamini mihi pro adversariis meis, cum ego iniquitatem in manibus non habeam, videat Deus patrum nostrorum, et judicet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.18",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 12:18",
      "text": "Spiritus vero induit Amasai principem inter triginta, et ait: Tui sumus, o David, et tecum, fili Isai. Pax, pax tibi, et pax adjutoribus tuis: te enim adjuvat Deus tuus. Suscepit ergo eos David, et constituit principes turmæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.19",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 12:19",
      "text": "Porro de Manasse transfugerunt ad David, quando veniebat cum Philisthiim adversus Saul ut pugnaret: et non dimicavit cum eis, quia inito consilio remiserunt eum principes Philisthinorum, dicentes: Periculo capitis nostri revertetur ad dominum suum Saul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.20",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 12:20",
      "text": "Quando igitur reversus est in Siceleg, transfugerunt ad eum de Manasse, Ednas, et Jozabad, et Jedihel, et Michaël, et Ednas, et Jozabad, et Eliu, et Salathi, principes millium in Manasse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.21",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 12:21",
      "text": "Hi præbuerunt auxilium David adversus latrunculos: omnes enim erant viri fortissimi, et facti sunt principes in exercitu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.22",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 12:22",
      "text": "Sed et per singulos dies veniebant ad David ad auxiliandum ei, usque dum fieret grandis numerus, quasi exercitus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.23",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 12:23",
      "text": "Iste quoque est numerus principum exercitus qui venerunt ad David cum esset in Hebron, ut transferrent regnum Saul ad eum, juxta verbum Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.24",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 12:24",
      "text": "Filii Juda portantes clypeum et hastam, sex millia octingenti expediti ad prælium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.25",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 12:25",
      "text": "De filiis Simeon virorum fortissimorum ad pugnandum, septem millia centum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.26",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 12:26",
      "text": "De filiis Levi, quatuor millia sexcenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.27",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 12:27",
      "text": "Jojoda quoque princeps de stirpe Aaron, et cum eo tria millia septingenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.28",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 12:28",
      "text": "Sadoc etiam puer egregiæ indolis, et domus patris ejus, principes viginti duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.29",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 12:29",
      "text": "De filiis autem Benjamin fratribus Saul, tria millia: magna enim pars eorum adhuc sequebatur domum Saul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.30",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 12:30",
      "text": "Porro de filiis Ephraim viginti millia octingenti, fortissimi robore, viri nominati in cognationibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.31",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 12:31",
      "text": "Et ex dimidia tribu Manasse, decem et octo millia, singuli per nomina sua, venerunt ut constituerent regem David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.32",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 12:32",
      "text": "De filiis quoque Issachar viri eruditi, qui noverant singula tempora ad præcipiendum quid facere deberet Israël, principes ducenti: omnis autem reliqua tribus eorum consilium sequebatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.33",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 12:33",
      "text": "Porro de Zabulon qui egrediebantur ad prælium, et stabant in acie instructi armis bellicis, quinquaginta millia venerunt in auxilium, non in corde duplici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.34",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 12:34",
      "text": "Et de Nephthali, principes mille, et cum eis instructi clypeo et hasta, triginta et septem millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.35",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 12:35",
      "text": "De Dan etiam præparati ad prælium, viginti octo millia sexcenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.36",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 12:36",
      "text": "Et de Aser egredientes ad pugnam, et in acie provocantes, quadraginta millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.37",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 12:37",
      "text": "Trans Jordanem autem de filiis Ruben, et de Gad, et dimidia parte tribus Manasse, instructi armis bellicis, centum viginti millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.38",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 12:38",
      "text": "Omnes isti viri bellatores expediti ad pugnandum, corde perfecto venerunt in Hebron, ut constituerent regem David super universum Israël: sed et omnes reliqui ex Israël uno corde erant, ut rex fieret David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.39",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 12:39",
      "text": "Fueruntque ibi apud David tribus diebus comedentes et bibentes: præparaverant enim eis fratres sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-chronicles.12.40",
      "translationId": "vulgate",
      "bookSlug": "first-chronicles",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 12:40",
      "text": "Sed et qui juxta eos erant, usque ad Issachar, et Zabulon, et Nephthali, afferebant panes in asinis, et camelis, et mulis, et bobus ad vescendum: farinam, palathas, uvam passam, vinum, oleum, boves, arietes ad omnem copiam: gaudium quippe erat in Israël.",
      "paragraphStart": false
    }
  ]
}
