{
  "chapter": {
    "id": "vulgate:nehemiah.12",
    "translationId": "vulgate",
    "bookSlug": "nehemiah",
    "chapterNumber": 12,
    "referenceLabel": "Nehemiah 12",
    "summary": "Source text for Nehemiah 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:nehemiah.12.1",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 12:1",
      "text": "Hi sunt autem sacerdotes et Levitæ, qui ascenderunt cum Zorobabel filio Salathiel, et Josue: Saraia, Jeremias, Esdras,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:nehemiah.12.2",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 12:2",
      "text": "Amaria, Melluch, Hattus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.3",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 12:3",
      "text": "Sebenias, Rheum, Merimuth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.4",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 12:4",
      "text": "Addo, Genthon, Abia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.5",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 12:5",
      "text": "Miamin, Madia, Belga,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.6",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 12:6",
      "text": "Semeia, et Jojarib, Idaia, Sellum, Amoc, Helcias,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.7",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 12:7",
      "text": "Idaia. Isti principes sacerdotum, et fratres eorum in diebus Josue.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.8",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 12:8",
      "text": "Porro Levitæ, Jesua, Bennui, Cedmihel, Sarebia, Juda, Mathanias, super hymnos ipsi et fratres eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.9",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 12:9",
      "text": "et Becbecia atque Hanni, et fratres eorum, unusquisque in officio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.10",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 12:10",
      "text": "Josue autem genuit Joacim, et Joacim genuit Eliasib, et Eliasib genuit Jojada,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.11",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 12:11",
      "text": "et Jojada genuit Jonathan, et Jonathan genuit Jeddoa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.12",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 12:12",
      "text": "In diebus autem Joacim erant sacerdotes et principes familiarum: Saraiæ, Maraia: Jeremiæ, Hanania:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.13",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 12:13",
      "text": "Esdræ, Mosollam: Amariæ, Johanan:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.14",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 12:14",
      "text": "Milicho, Jonathan: Sebeniæ, Joseph:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.15",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 12:15",
      "text": "Haram, Edna: Maraioth, Helci:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.16",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 12:16",
      "text": "Adaiæ, Zacharia: Genthon, Mosollam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.17",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 12:17",
      "text": "Abiæ, Zechri: Miamin et Moadiæ, Phelti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.18",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 12:18",
      "text": "Belgæ, Sammua: Semaiæ, Jonathan:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.19",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 12:19",
      "text": "Jojarib, Mathanai: Jodaiæ, Azzi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.20",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 12:20",
      "text": "Sellai, Celai: Amoc, Heber:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.21",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 12:21",
      "text": "Helciæ, Hasebia: Idaiæ, Nathanaël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.22",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 12:22",
      "text": "Levitæ in diebus Eliasib, et Jojada, et Johanan, et Jeddoa, scripti principes familiarum, et sacerdotes in regno Darii Persæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.23",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 12:23",
      "text": "Filii Levi principes familiarum, scripti in libro verborum dierum, et usque ad dies Jonathan, filii Eliasib.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.24",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 12:24",
      "text": "Et principes Levitarum, Hasebia, Serebia, et Josue filius Cedmihel: et fratres eorum per vices suas, ut laudarent et confiterentur juxta præceptum David viri Dei, et observarent æque per ordinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.25",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 12:25",
      "text": "Mathania, et Becbecia, Obedia, Mosollam, Telmon, Accub, custodes portarum et vestibulorum ante portas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.26",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 12:26",
      "text": "Hi in diebus Joacim filii Josue, filii Josedec, et in diebus Nehemiæ ducis, et Esdræ sacerdotis scribæque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.27",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 12:27",
      "text": "In dedicatione autem muri Jerusalem, requisierunt Levitas de omnibus locis suis ut adducerent eos in Jerusalem, et facerent dedicationem et lætitiam in actione gratiarum, et cantico, et in cymbalis, psalteriis, et citharis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.28",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 12:28",
      "text": "Congregati sunt autem filii cantorum de campestribus circa Jerusalem, et de villis Nethuphathi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.29",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 12:29",
      "text": "et de domo Galgal, et de regionibus Geba et Azmaveth: quoniam villas ædificaverunt sibi cantores in circuitu Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.30",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 12:30",
      "text": "Et mundati sunt sacerdotes et Levitæ, et mundaverunt populum, et portas, et murum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.31",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 12:31",
      "text": "Ascendere autem feci principes Juda super murum, et statui duos magnos choros laudantium. Et ierunt ad dexteram super murum ad portam sterquilinii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.32",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 12:32",
      "text": "Et ivit post eos Osaias, et media pars principum Juda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.33",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 12:33",
      "text": "et Azarias, Esdras, et Mosollam, Judas, et Benjamin, et Semeia, et Jeremias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.34",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 12:34",
      "text": "Et de filiis sacerdotum in tubis, Zacharias filius Jonathan, filius Semeiæ, filius Mathaniæ, filius Michaiæ, filius Zechur, filius Asaph,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.35",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 12:35",
      "text": "et fratres ejus Semeia, et Azareel, Malalai, Galalai, Maai, Nathanaël, et Judas, et Hanani, in vasis cantici David viri Dei: et Esdras scriba ante eos in porta fontis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.36",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 12:36",
      "text": "Et contra eos ascenderunt in gradibus civitatis David in ascensu muri super domum David, et usque ad portam aquarum ad orientem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.37",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 12:37",
      "text": "Et chorus secundus gratias referentium ibat ex adverso, et ego post eum, et media pars populi super murum, et super turrim furnorum, et usque ad murum latissimum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.38",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "Nehemiah 12:38",
      "text": "et super portam Ephraim, et super portam antiquam, et super portam piscium et turrim Hananeel, et turrim Emath, et usque ad portam gregis: et steterunt in porta custodiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.39",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "Nehemiah 12:39",
      "text": "steteruntque duo chori laudantium in domo Dei, et ego, et dimidia pars magistratuum mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.40",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "Nehemiah 12:40",
      "text": "Et sacerdotes, Eliachim, Maasia, Miamin, Michea, Elioënai, Zacharia, Hanania in tubis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.41",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "Nehemiah 12:41",
      "text": "et Maasia, et Semeia, et Eleazar, et Azzi, et Johanan, et Melchia, et Ælam, et Ezer. Et clare cecinerunt cantores, et Jezraia præpositus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.42",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "Nehemiah 12:42",
      "text": "et immolaverunt in die illa victimas magnas, et lætati sunt: Deus enim lætificaverat eos lætitia magna: sed et uxores eorum et liberi gavisi sunt, et audita est lætitia Jerusalem procul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.43",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "Nehemiah 12:43",
      "text": "Recensuerunt quoque in die illa viros super gazophylacia thesauri ad libamina, et ad primitias, et ad decimas, ut introferrent per eos principes civitatis in decore gratiarum actionis, sacerdotes et Levitas: quia lætificatus est Juda in sacerdotibus et Levitis adstantibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.44",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "Nehemiah 12:44",
      "text": "Et custodierunt observationem Dei sui, et observationem expiationis, et cantores, et janitores juxta præceptum David, et Salomonis filii ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.45",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "Nehemiah 12:45",
      "text": "quia in diebus David et Asaph ab exordio erant principes constituti cantorum in carmine laudantium et confitentium Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.12.46",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "Nehemiah 12:46",
      "text": "Et omnis Israël in diebus Zorobabel et in diebus Nehemiæ, dabant partes cantoribus et janitoribus per dies singulos, et sanctificabant Levitas, et Levitæ sanctificabant filios Aaron.",
      "paragraphStart": false
    }
  ]
}
