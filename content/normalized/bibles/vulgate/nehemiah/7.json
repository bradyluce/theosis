    },
    {
      "id": "vulgate:nehemiah.7.54",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 54,
      "referenceLabel": "Nehemiah 7:54",
      "text": "filii Besloth, filii Mahida, filii Harsa,",
