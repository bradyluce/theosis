{
  "chapter": {
    "id": "vulgate:nehemiah.7",
    "translationId": "vulgate",
    "bookSlug": "nehemiah",
    "chapterNumber": 7,
    "referenceLabel": "Nehemiah 7",
    "summary": "Source text for Nehemiah 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:nehemiah.7.1",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 7:1",
      "text": "Postquam autem ædificatus est murus, et posui valvas, et recensui janitores, et cantores, et Levitas,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:nehemiah.7.2",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 7:2",
      "text": "præcepi Hanani fratri meo, et Hananiæ principi domus de Jerusalem (ipse enim quasi vir verax et timens Deum plus ceteris videbatur),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.3",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 7:3",
      "text": "et dixi eis: Non aperiantur portæ Jerusalem usque ad calorem solis. Cumque adhuc assisterent, clausæ portæ sunt, et oppilatæ: et posui custodes de habitatoribus Jerusalem, singulos per vices suas, et unumquemque contra domum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.4",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 7:4",
      "text": "Civitas autem erat lata nimis et grandis, et populus parvus in medio ejus, et non erant domus ædificatæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.5",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 7:5",
      "text": "Deus autem dedit in corde meo, et congregavi optimates, et magistratus, et vulgus, ut recenserem eos: et inveni librum census eorum qui ascenderant primum, et inventum est scriptum in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.6",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 7:6",
      "text": "Isti filii provinciæ, qui ascenderunt de captivitate migrantium, quos transtulerat Nabuchodonosor rex Babylonis, et reversi sunt in Jerusalem et in Judæam, unusquisque in civitatem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.7",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 7:7",
      "text": "Qui venerunt cum Zorobabel, Josue, Nehemias, Azarias, Raamias, Nahamani, Mardochæus, Belsam, Mespharath, Begoai, Nahum, Baana. Numerus virorum populi Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.8",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 7:8",
      "text": "filii Pharos, duo millia centum septuaginta duo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.9",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 7:9",
      "text": "filii Saphatia, trecenti septuaginta duo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.10",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 7:10",
      "text": "filii Area, sexcenti quinquaginta duo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.11",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 7:11",
      "text": "filii Phahathmoab filiorum Josue et Joab, duo millia octingenti decem et octo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.12",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 7:12",
      "text": "filii Ælam, mille ducenti quinquaginta quatuor:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.13",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 7:13",
      "text": "filii Zethua, octingenti quadraginta quinque:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.14",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 7:14",
      "text": "filii Zachai, septingenti sexaginta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.15",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 7:15",
      "text": "filii Bannui, sexcenti quadraginta octo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.16",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 7:16",
      "text": "filii Bebai, sexcenti viginti octo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.17",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 7:17",
      "text": "filii Azgad, duo millia trecenti viginti duo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.18",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 7:18",
      "text": "filii Adonicam, sexcenti sexaginta septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.19",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 7:19",
      "text": "filii Beguai, duo millia sexaginta septem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.20",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 7:20",
      "text": "filii Adin, sexcenti quinquaginta quinque:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.21",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 7:21",
      "text": "filii Ater, filii Hezeciæ, nonaginta octo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.22",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 7:22",
      "text": "filii Hasem, trecenti viginti octo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.23",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 7:23",
      "text": "filii Besai, trecenti viginti quatuor:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.24",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 7:24",
      "text": "filii Hareph, centum duodecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.25",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 7:25",
      "text": "filii Gabaon, nonaginta quinque:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.26",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 7:26",
      "text": "filii Bethlehem et Netupha, centum octoginta octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.27",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 7:27",
      "text": "Viri Anathoth, centum viginti octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.28",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 7:28",
      "text": "Viri Bethazmoth, quadraginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.29",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 7:29",
      "text": "Viri Cariathiarim, Cephira, et Beroth, septingenti quadraginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.30",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 7:30",
      "text": "Viri Rama et Geba, sexcenti viginti unus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.31",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 7:31",
      "text": "Viri Machmas, centum viginti duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.32",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 7:32",
      "text": "Viri Bethel et Hai, centum viginti tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.33",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 7:33",
      "text": "Viri Nebo alterius, quinquaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.34",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 7:34",
      "text": "Viri Ælam alterius, mille ducenti quinquaginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.35",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 7:35",
      "text": "Filii Harem, trecenti viginti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.36",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 7:36",
      "text": "Filii Jericho, trecenti quadraginta quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.37",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Nehemiah 7:37",
      "text": "Filii Lod Hadid et Ono, septingenti viginti unus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.38",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "Nehemiah 7:38",
      "text": "Filii Senaa, tria millia nongenti triginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.39",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "Nehemiah 7:39",
      "text": "Sacerdotes: filii Idaia in domo Josue, nongenti septuaginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.40",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "Nehemiah 7:40",
      "text": "Filii Emmer, mille quinquaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.41",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 41,
      "referenceLabel": "Nehemiah 7:41",
      "text": "Filii Phashur, mille ducenti quadraginta septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.42",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 42,
      "referenceLabel": "Nehemiah 7:42",
      "text": "Filii Arem, mille decem et septem. Levitæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.43",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 43,
      "referenceLabel": "Nehemiah 7:43",
      "text": "filii Josue et Cedmihel filiorum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.44",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 44,
      "referenceLabel": "Nehemiah 7:44",
      "text": "Oduiæ, septuaginta quatuor. Cantores:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.45",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 45,
      "referenceLabel": "Nehemiah 7:45",
      "text": "filii Asaph, centum quadraginta octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.46",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 46,
      "referenceLabel": "Nehemiah 7:46",
      "text": "Janitores: filii Sellum, filii Ater, filii Telmon, filii Accub, filii Hatita, filii Sobai: centum triginta octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.47",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 47,
      "referenceLabel": "Nehemiah 7:47",
      "text": "Nathinæi: filii Soha, filii Hasupha, filii Tebbaoth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.48",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 48,
      "referenceLabel": "Nehemiah 7:48",
      "text": "filii Ceros, filii Siaa, filii Phadon, filii Lebana, filii Hagaba, filii Selmai,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.49",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 49,
      "referenceLabel": "Nehemiah 7:49",
      "text": "filii Hanan, filii Geddel, filii Gaher,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.50",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 50,
      "referenceLabel": "Nehemiah 7:50",
      "text": "filii Raaia, filii Rasin, filii Necoda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.51",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 51,
      "referenceLabel": "Nehemiah 7:51",
      "text": "filii Gezem, filii Aza, filii Phasea,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.52",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 52,
      "referenceLabel": "Nehemiah 7:52",
      "text": "filii Besai, filii Munim, filii Nephussim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.53",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 53,
      "referenceLabel": "Nehemiah 7:53",
      "text": "filii Bacbuc, filii Hacupha, filii Harhur,",
