    },
    {
      "id": "vulgate:nehemiah.7.55",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 55,
      "referenceLabel": "Nehemiah 7:55",
      "text": "filii Bercos, filii Sisara, filii Thema,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.56",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 56,
      "referenceLabel": "Nehemiah 7:56",
      "text": "filii Nasia, filii Hatipha,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.57",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 57,
      "referenceLabel": "Nehemiah 7:57",
      "text": "filii servorum Salomonis, filii Sothai, filii Sophereth, filii Pharida,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.58",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 58,
      "referenceLabel": "Nehemiah 7:58",
      "text": "filii Jahala, filii Darcon, filii Jeddel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.59",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 59,
      "referenceLabel": "Nehemiah 7:59",
      "text": "filii Saphatia, filii Hatil, filii Phochereth, qui erat ortus ex Sabaim filio Amon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.60",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 60,
      "referenceLabel": "Nehemiah 7:60",
      "text": "Omnes Nathinæi, et filii servorum Salomonis, trecenti nonaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.61",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 61,
      "referenceLabel": "Nehemiah 7:61",
      "text": "Hi sunt autem qui ascenderunt de Thelmela, Thelharsa, Cherub, Addon, et Emmer: et non potuerunt indicare domum patrum suorum, et semen suum, utrum ex Israël essent,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.62",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 62,
      "referenceLabel": "Nehemiah 7:62",
      "text": "filii Dalaia, filii Tobia, filii Necoda, sexcenti quadraginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.63",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 63,
      "referenceLabel": "Nehemiah 7:63",
      "text": "Et de sacerdotibus, filii Habia, filii Accos, filii Berzellai, qui accepit de filiabus Berzellai Galaaditis uxorem, et vocatus est nomine eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.64",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 64,
      "referenceLabel": "Nehemiah 7:64",
      "text": "Hi quæsierunt scripturam suam in censu, et non invenerunt: et ejecti sunt de sacerdotio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.65",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 7,
      "verseNumber": 65,
      "referenceLabel": "Nehemiah 7:65",
      "text": "Dixitque Athersatha eis ut non manducarent de Sanctis sanctorum, donec staret sacerdos doctus et eruditus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.7.66",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
