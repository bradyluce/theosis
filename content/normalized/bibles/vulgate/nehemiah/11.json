{
  "chapter": {
    "id": "vulgate:nehemiah.11",
    "translationId": "vulgate",
    "bookSlug": "nehemiah",
    "chapterNumber": 11,
    "referenceLabel": "Nehemiah 11",
    "summary": "Source text for Nehemiah 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:nehemiah.11.1",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Nehemiah 11:1",
      "text": "Habitaverunt autem principes populi in Jerusalem: reliqua vero plebs misit sortem, ut tollerent unam partem de decem qui habitaturi essent in Jerusalem civitate sancta, novem vero partes in civitatibus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:nehemiah.11.2",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Nehemiah 11:2",
      "text": "Benedixit autem populus omnibus viris qui se sponte obtulerant ut habitarent in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.3",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Nehemiah 11:3",
      "text": "Hi sunt itaque principes provinciæ qui habitaverunt in Jerusalem, et in civitatibus Juda. Habitavit autem unusquisque in possessione sua, in urbibus suis, Israël, sacerdotes, Levitæ, Nathinæi, et filii servorum Salomonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.4",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Nehemiah 11:4",
      "text": "Et in Jerusalem habitaverunt de filiis Juda, et de filiis Benjamin: de filiis Juda, Athaias filius Aziam, filii Zachariæ, filii Amariæ, filii Saphatiæ, filii Melaleel: de filiis Phares,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.5",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Nehemiah 11:5",
      "text": "Maasia filius Baruch, filius Cholhoza, filius Hazia, filius Adaia, filius Jojarib, filius Zachariæ, filius Silonitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.6",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Nehemiah 11:6",
      "text": "omnes hi filii Phares, qui habitaverunt in Jerusalem, quadringenti sexaginta octo viri fortes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.7",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Nehemiah 11:7",
      "text": "Hi sunt autem filii Benjamin: Sellum filius Mosollam, filius Joëd, filius Phadaia, filius Colaia, filius Masia, filius Etheel, filius Isaia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.8",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Nehemiah 11:8",
      "text": "et post eum Gebbai, Sellai, nongenti viginti octo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.9",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 11:9",
      "text": "et Joël filius Zechri præpositus eorum, et Judas filius Senua super civitatem secundus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.10",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Nehemiah 11:10",
      "text": "Et de sacerdotibus, Idaia filius Joarib, Jachin,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.11",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Nehemiah 11:11",
      "text": "Saraia filius Helciæ, filius Mosollam, filius Sadoc, filius Meraioth, filius Achitob princeps domus Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.12",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Nehemiah 11:12",
      "text": "et fratres eorum facientes opera templi: octingenti viginti duo. Et Adaia filius Jeroham, filius Phelelia, filius Amsi, filius Zachariæ, filius Pheshur, filius Melchiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.13",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Nehemiah 11:13",
      "text": "et fratres ejus principes patrum: ducenti quadraginta duo. Et Amassai filius Azreel, filius Ahazi, filius Mosollamoth, filius Emmer,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.14",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Nehemiah 11:14",
      "text": "et fratres eorum potentes nimis: centum viginti octo, et præpositus eorum Zabdiel filius potentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.15",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Nehemiah 11:15",
      "text": "Et de Levitis, Semeia filius Hasub, filius Azaricam, filius Hasabia, filius Boni,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.16",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Nehemiah 11:16",
      "text": "et Sabathai et Jozabed, super omnia opera quæ erant forinsecus in domo Dei, a principibus Levitarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.17",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Nehemiah 11:17",
      "text": "Et Mathania filius Micha, filius Zebedei, filius Asaph, princeps ad laudandum et ad confitendum in oratione, et Becbecia secundus de fratribus ejus, et Abda filius Samua, filius Galal, filius Idithun:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.18",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Nehemiah 11:18",
      "text": "omnes Levitæ in civitate sancta ducenti octoginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.19",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Nehemiah 11:19",
      "text": "Et janitores, Accub, Telmon, et fratres eorum, qui custodiebant ostia: centum septuaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.20",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Nehemiah 11:20",
      "text": "Et reliqui ex Israël sacerdotes et Levitæ in universis civitatibus Juda, unusquisque in possessione sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.21",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Nehemiah 11:21",
      "text": "Et Nathinæi, qui habitabant in Ophel, et Siaha, et Gaspha de Nathinæis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.22",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Nehemiah 11:22",
      "text": "Et episcopus Levitarum in Jerusalem, Azzi filius Bani, filius Hasabiæ, filius Mathaniæ, filius Michæ. De filiis Asaph, cantores in ministerio domus Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.23",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Nehemiah 11:23",
      "text": "Præceptum quippe regis super eos erat, et ordo in cantoribus per dies singulos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.24",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Nehemiah 11:24",
      "text": "et Phathahia filius Mesezebel, de filiis Zara filii Juda in manu regis, juxta omne verbum populi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.25",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Nehemiah 11:25",
      "text": "et in domibus per omnes regiones eorum. De filiis Juda habitaverunt in Cariatharbe et in filiabus ejus: et in Dibon, et in filiabus ejus: et in Cabseel, et in viculis ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.26",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Nehemiah 11:26",
      "text": "et in Jesue, et in Molada, et in Bethphaleth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.27",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Nehemiah 11:27",
      "text": "et in Hasersual, et in Bersabee, et in filiabus ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.28",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Nehemiah 11:28",
      "text": "et in Siceleg, et in Mochona, et in filiabus ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.29",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Nehemiah 11:29",
      "text": "et in Remmon, et in Saraa, et in Jerimuth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.30",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Nehemiah 11:30",
      "text": "Zanoa, Odollam, et in villis earum, Lachis et regionibus ejus, et Azeca, et filiabus ejus. Et manserunt in Bersabee usque ad vallem Ennom.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.31",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Nehemiah 11:31",
      "text": "Filii autem Benjamin, a Geba, Mechmas, et Hai, et Bethel, et filiabus ejus",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.32",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Nehemiah 11:32",
      "text": "Anathoth, Nob, Anania,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.33",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Nehemiah 11:33",
      "text": "Asor, Rama, Gethaim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.34",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Nehemiah 11:34",
      "text": "Hadid, Seboim, et Neballat, Lod,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.35",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Nehemiah 11:35",
      "text": "et Ono valle artificum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:nehemiah.11.36",
      "translationId": "vulgate",
      "bookSlug": "nehemiah",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Nehemiah 11:36",
      "text": "Et de Levitis portiones Judæ et Benjamin.",
      "paragraphStart": false
    }
  ]
}
