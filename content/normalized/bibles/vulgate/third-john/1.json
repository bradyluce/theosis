{
  "chapter": {
    "id": "vulgate:third-john.1",
    "translationId": "vulgate",
    "bookSlug": "third-john",
    "chapterNumber": 1,
    "referenceLabel": "3 John 1",
    "summary": "Source text for 3 John 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:third-john.1.1",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "3 John 1:1",
      "text": "Senior Gajo carissimo, quem ego diligo in veritate.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:third-john.1.2",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "3 John 1:2",
      "text": "Carissime, de omnibus orationem facio prospere te ingredi, et valere sicut prospere agit anima tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.3",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "3 John 1:3",
      "text": "Gavisus sum valde venientibus fratribus, et testimonium perhibentibus veritati tuæ, sicut tu in veritate ambulas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.4",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "3 John 1:4",
      "text": "Majorem horum non habeo gratiam, quam ut audiam filios meos in veritate ambulare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.5",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "3 John 1:5",
      "text": "Carissime, fideliter facis quidquid operaris in fratres, et hoc in peregrinos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.6",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "3 John 1:6",
      "text": "qui testimonium reddiderunt caritati tuæ in conspectu ecclesiæ: quos, benefaciens, deduces digne Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.7",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "3 John 1:7",
      "text": "Pro nomine enim ejus profecti sunt, nihil accipientes a gentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.8",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "3 John 1:8",
      "text": "Nos ergo debemus suscipere hujusmodi, ut cooperatores simus veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.9",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "3 John 1:9",
      "text": "Scripsissem forsitan ecclesiæ: sed is qui amat primatum gerere in eis, Diotrephes, non recipit nos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.10",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "3 John 1:10",
      "text": "propter hoc si venero, commonebo ejus opera, quæ facit, verbis malignis garriens in nos: et quasi non ei ista sufficiant, neque ipse suscipit fratres: et eos qui suscipiunt, prohibet, et de ecclesia ejicit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.11",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "3 John 1:11",
      "text": "Carissime, noli imitari malum, sed quod bonum est. Qui benefacit, ex Deo est: qui malefacit, non vidit Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.12",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "3 John 1:12",
      "text": "Demetrio testimonium redditur ab omnibus, et ab ipsa veritate, sed et nos testimonium perhibemus: et nosti quoniam testimonium nostrum verum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.13",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "3 John 1:13",
      "text": "Multa habui tibi scribere: sed nolui per atramentum et calamum scribere tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:third-john.1.14",
      "translationId": "vulgate",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "3 John 1:14",
      "text": "Spero autem protinus te videre, et os ad os loquemur. Pax tibi. Salutant te amici. Saluta amicos nominatim.",
      "paragraphStart": false
    }
  ]
}
