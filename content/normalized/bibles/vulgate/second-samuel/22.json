{
  "chapter": {
    "id": "vulgate:second-samuel.22",
    "translationId": "vulgate",
    "bookSlug": "second-samuel",
    "chapterNumber": 22,
    "referenceLabel": "2 Samuel 22",
    "summary": "Source text for 2 Samuel 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-samuel.22.1",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "2 Samuel 22:1",
      "text": "Locutus est autem David Domino verba carminis hujus in die qua liberavit eum Dominus de manu omnium inimicorum suorum, et de manu Saul.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-samuel.22.2",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "2 Samuel 22:2",
      "text": "Et ait: Dominus petra mea, et robur meum, et salvator meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.3",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "2 Samuel 22:3",
      "text": "Deus fortis meus: sperabo in eum; scutum meum, et cornu salutis meæ: elevator meus, et refugium meum; salvator meus: de iniquitate liberabis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.4",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "2 Samuel 22:4",
      "text": "Laudabilem invocabo Dominum, et ab inimicis meis salvus ero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.5",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "2 Samuel 22:5",
      "text": "Quia circumdederunt me contritiones mortis: torrentes Belial terruerunt me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.6",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "2 Samuel 22:6",
      "text": "Funes inferni circumdederunt me: prævenerunt me laquei mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.7",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "2 Samuel 22:7",
      "text": "In tribulatione mea invocabo Dominum, et ad Deum meum clamabo: et exaudiet de templo suo vocem meam, et clamor meus veniet ad aures ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.8",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "2 Samuel 22:8",
      "text": "Commota est et contremuit terra; fundamenta montium concussa sunt, et conquassata: quoniam iratus est eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.9",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "2 Samuel 22:9",
      "text": "Ascendit fumus de naribus ejus, et ignis de ore ejus vorabit: carbones succensi sunt ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.10",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "2 Samuel 22:10",
      "text": "Inclinavit cælos, et descendit: et caligo sub pedibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.11",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "2 Samuel 22:11",
      "text": "Et ascendit super cherubim, et volavit: et lapsus est super pennas venti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.12",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "2 Samuel 22:12",
      "text": "Posuit tenebras in circuitu suo latibulum, cribrans aquas de nubibus cælorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.13",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "2 Samuel 22:13",
      "text": "Præ fulgore in conspectu ejus, succensi sunt carbones ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.14",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "2 Samuel 22:14",
      "text": "Tonabit de cælo Dominus, et excelsus dabit vocem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.15",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "2 Samuel 22:15",
      "text": "Misit sagittas et dissipavit eos; fulgur, et consumpsit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.16",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "2 Samuel 22:16",
      "text": "Et apparuerunt effusiones maris, et revelata sunt fundamenta orbis ab increpatione Domini, ab inspiratione spiritus furoris ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.17",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "2 Samuel 22:17",
      "text": "Misit de excelso, et assumpsit me, et extraxit me de aquis multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.18",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "2 Samuel 22:18",
      "text": "Liberavit me ab inimico meo potentissimo, et ab his qui oderant me: quoniam robustiores me erant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.19",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "2 Samuel 22:19",
      "text": "Prævenit me in die afflictionis meæ, et factus est Dominus firmamentum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.20",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "2 Samuel 22:20",
      "text": "Et eduxit me in latitudinem: liberavit me, quia complacui ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.21",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "2 Samuel 22:21",
      "text": "Retribuet mihi Dominus secundum justitiam meam: et secundum munditiam manuum mearum reddet mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.22",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "2 Samuel 22:22",
      "text": "Quia custodivi vias Domini, et non egi impie a Deo meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.23",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "2 Samuel 22:23",
      "text": "Omnia enim judicia ejus in conspectu meo, et præcepta ejus non amovi a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.24",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "2 Samuel 22:24",
      "text": "Et ero perfectus cum eo, et custodiam me ab iniquitate mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.25",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "2 Samuel 22:25",
      "text": "Et restituet mihi Dominus secundum justitiam meam, et secundum munditiam manuum mearum in conspectu oculorum suorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.26",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "2 Samuel 22:26",
      "text": "Cum sancto sanctus eris, et cum robusto perfectus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.27",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "2 Samuel 22:27",
      "text": "Cum electo electus eris, et cum perverso perverteris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.28",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "2 Samuel 22:28",
      "text": "Et populum pauperem salvum facies: oculisque tuis excelsos humiliabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.29",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "2 Samuel 22:29",
      "text": "Quia tu lucerna mea, Domine, et tu, Domine, illuminabis tenebras meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.30",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "2 Samuel 22:30",
      "text": "In te enim curram accinctus: in Deo meo transiliam murum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.31",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "2 Samuel 22:31",
      "text": "Deus, immaculata via ejus; eloquium Domini igne examinatum: scutum est omnium sperantium in se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.32",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 32,
      "referenceLabel": "2 Samuel 22:32",
      "text": "Quis est Deus præter Dominum, et quis fortis præter Deum nostrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.33",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 33,
      "referenceLabel": "2 Samuel 22:33",
      "text": "Deus qui accinxit me fortitudine, et complanavit perfectam viam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.34",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 34,
      "referenceLabel": "2 Samuel 22:34",
      "text": "Coæquans pedes meos cervis, et super excelsa mea statuens me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.35",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 35,
      "referenceLabel": "2 Samuel 22:35",
      "text": "docens manus meas ad prælium, et componens quasi arcum æreum brachia mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.36",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 36,
      "referenceLabel": "2 Samuel 22:36",
      "text": "Dedisti mihi clypeum salutis tuæ, et mansuetudo tua multiplicavit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.37",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 37,
      "referenceLabel": "2 Samuel 22:37",
      "text": "Dilatabis gressus meos subtus me, et non deficient tali mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.38",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 38,
      "referenceLabel": "2 Samuel 22:38",
      "text": "Persequar inimicos meos, et conteram, et non convertar donec consumam eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.39",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 39,
      "referenceLabel": "2 Samuel 22:39",
      "text": "Consumam eos et confringam, ut non consurgant: cadent sub pedibus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.40",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 40,
      "referenceLabel": "2 Samuel 22:40",
      "text": "Accinxisti me fortitudine ad prælium: incurvasti resistentes mihi subtus me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.41",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 41,
      "referenceLabel": "2 Samuel 22:41",
      "text": "Inimicos meos dedisti mihi dorsum; odientes me, et disperdam eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.42",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 42,
      "referenceLabel": "2 Samuel 22:42",
      "text": "Clamabunt, et non erit qui salvet; ad Dominum, et non exaudiet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.43",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 43,
      "referenceLabel": "2 Samuel 22:43",
      "text": "Delebo eos ut pulverem terræ; quasi lutum platearum comminuam eos atque confringam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.44",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 44,
      "referenceLabel": "2 Samuel 22:44",
      "text": "Salvabis me a contradictionibus populi mei; custodies me in caput gentium: populus quem ignoro serviet mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.45",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 45,
      "referenceLabel": "2 Samuel 22:45",
      "text": "Filii alieni resistent mihi; auditu auris obedient mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.46",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 46,
      "referenceLabel": "2 Samuel 22:46",
      "text": "Filii alieni defluxerunt, et contrahentur in angustiis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.47",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 47,
      "referenceLabel": "2 Samuel 22:47",
      "text": "Vivit Dominus, et benedictus Deus meus, et exaltabitur Deus fortis salutis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.48",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 48,
      "referenceLabel": "2 Samuel 22:48",
      "text": "Deus qui das vindictas mihi, et dejicis populos sub me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.49",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 49,
      "referenceLabel": "2 Samuel 22:49",
      "text": "Qui educis me ab inimicis meis, et a resistentibus mihi elevas me: a viro iniquo liberabis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.50",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 50,
      "referenceLabel": "2 Samuel 22:50",
      "text": "Propterea confitebor tibi, Domine, in gentibus, et nomini tuo cantabo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-samuel.22.51",
      "translationId": "vulgate",
      "bookSlug": "second-samuel",
      "chapterNumber": 22,
      "verseNumber": 51,
      "referenceLabel": "2 Samuel 22:51",
      "text": "magnificans salutes regis sui, et faciens misericordiam christo suo David, et semini ejus in sempiternum.",
      "paragraphStart": false
    }
  ]
}
