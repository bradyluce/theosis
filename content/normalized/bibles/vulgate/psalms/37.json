{
  "chapter": {
    "id": "vulgate:psalms.37",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.37.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "Psalmus David, in rememorationem de sabbato.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.37.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "Domine, ne in furore tuo arguas me, neque in ira tua corripias me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "quoniam sagittæ tuæ infixæ sunt mihi, et confirmasti super me manum tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "Non est sanitas in carne mea, a facie iræ tuæ; non est pax ossibus meis, a facie peccatorum meorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "quoniam iniquitates meæ supergressæ sunt caput meum, et sicut onus grave gravatæ sunt super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "Putruerunt et corruptæ sunt cicatrices meæ, a facie insipientiæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "Miser factus sum et curvatus sum usque in finem; tota die contristatus ingrediebar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "Quoniam lumbi mei impleti sunt illusionibus, et non est sanitas in carne mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "Afflictus sum, et humiliatus sum nimis; rugiebam a gemitu cordis mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "Domine, ante te omne desiderium meum, et gemitus meus a te non est absconditus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "Cor meum conturbatum est; dereliquit me virtus mea, et lumen oculorum meorum, et ipsum non est mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "Amici mei et proximi mei adversum me appropinquaverunt, et steterunt; et qui juxta me erant, de longe steterunt: et vim faciebant qui quærebant animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "Et qui inquirebant mala mihi, locuti sunt vanitates, et dolos tota die meditabantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "Ego autem, tamquam surdus, non audiebam; et sicut mutus non aperiens os suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "Et factus sum sicut homo non audiens, et non habens in ore suo redargutiones.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "Quoniam in te, Domine, speravi; tu exaudies me, Domine Deus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "Quia dixi: Nequando supergaudeant mihi inimici mei; et dum commoventur pedes mei, super me magna locuti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "Quoniam ego in flagella paratus sum, et dolor meus in conspectu meo semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "Quoniam iniquitatem meam annuntiabo, et cogitabo pro peccato meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "Inimici autem mei vivunt, et confirmati sunt super me: et multiplicati sunt qui oderunt me inique.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "Qui retribuunt mala pro bonis detrahebant mihi, quoniam sequebar bonitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "Ne derelinquas me, Domine Deus meus; ne discesseris a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.37.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Psalms 37:23",
      "text": "Intende in adjutorium meum, Domine Deus salutis meæ.",
      "paragraphStart": false
    }
  ]
}
