{
  "chapter": {
    "id": "vulgate:psalms.6",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.6.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "In finem, in carminibus. Psalmus David. Pro octava.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.6.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "Domine, ne in furore tuo arguas me, neque in ira tua corripias me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "Miserere mei, Domine, quoniam infirmus sum; sana me, Domine, quoniam conturbata sunt ossa mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "Et anima mea turbata est valde; sed tu, Domine, usquequo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "Convertere, Domine, et eripe animam meam; salvum me fac propter misericordiam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "Quoniam non est in morte qui memor sit tui; in inferno autem quis confitebitur tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "Laboravi in gemitu meo; lavabo per singulas noctes lectum meum: lacrimis meis stratum meum rigabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "Turbatus est a furore oculus meus; inveteravi inter omnes inimicos meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "Discedite a me omnes qui operamini iniquitatem, quoniam exaudivit Dominus vocem fletus mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "Exaudivit Dominus deprecationem meam; Dominus orationem meam suscepit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.6.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Psalms 6:11",
      "text": "Erubescant, et conturbentur vehementer, omnes inimici mei; convertantur, et erubescant valde velociter.",
      "paragraphStart": false
    }
  ]
}
