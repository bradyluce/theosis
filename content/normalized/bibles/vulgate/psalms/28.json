{
  "chapter": {
    "id": "vulgate:psalms.28",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 28,
    "referenceLabel": "Psalms 28",
    "summary": "Source text for Psalms 28 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.28.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Psalms 28:1",
      "text": "Psalmus David, in consummatione tabernaculi. Afferte Domino, filii Dei, afferte Domino filios arietum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.28.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Psalms 28:2",
      "text": "Afferte Domino gloriam et honorem; afferte Domino gloriam nomini ejus; adorate Dominum in atrio sancto ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Psalms 28:3",
      "text": "Vox Domini super aquas; Deus majestatis intonuit: Dominus super aquas multas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Psalms 28:4",
      "text": "Vox Domini in virtute; vox Domini in magnificentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Psalms 28:5",
      "text": "Vox Domini confringentis cedros, et confringet Dominus cedros Libani:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Psalms 28:6",
      "text": "et comminuet eas, tamquam vitulum Libani, et dilectus quemadmodum filius unicornium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Psalms 28:7",
      "text": "Vox Domini intercidentis flammam ignis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Psalms 28:8",
      "text": "vox Domini concutientis desertum: et commovebit Dominus desertum Cades.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Psalms 28:9",
      "text": "Vox Domini præparantis cervos: et revelabit condensa, et in templo ejus omnes dicent gloriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Psalms 28:10",
      "text": "Dominus diluvium inhabitare facit, et sedebit Dominus rex in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.28.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Psalms 28:11",
      "text": "Dominus virtutem populo suo dabit; Dominus benedicet populo suo in pace.",
      "paragraphStart": false
    }
  ]
}
