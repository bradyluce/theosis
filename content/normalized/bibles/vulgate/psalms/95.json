{
  "chapter": {
    "id": "vulgate:psalms.95",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.95.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "Canticum ipsi David, quando domus ædificabatur post captivitatem. Cantate Domino canticum novum; cantate Domino omnis terra.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.95.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Cantate Domino, et benedicite nomini ejus; annuntiate de die in diem salutare ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "Annuntiate inter gentes gloriam ejus; in omnibus populis mirabilia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "Quoniam magnus Dominus, et laudabilis nimis: terribilis est super omnes deos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "Quoniam omnes dii gentium dæmonia; Dominus autem cælos fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "Confessio et pulchritudo in conspectu ejus; sanctimonia et magnificentia in sanctificatione ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "Afferte Domino, patriæ gentium, afferte Domino gloriam et honorem;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "afferte Domino gloriam nomini ejus. Tollite hostias, et introite in atria ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "adorate Dominum in atrio sancto ejus. Commoveatur a facie ejus universa terra;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "dicite in gentibus, quia Dominus regnavit. Etenim correxit orbem terræ, qui non commovebitur; judicabit populos in æquitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Lætentur cæli, et exsultet terra; commoveatur mare et plenitudo ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 12,
      "referenceLabel": "Psalms 95:12",
      "text": "gaudebunt campi, et omnia quæ in eis sunt. Tunc exsultabunt omnia ligna silvarum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.95.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 13,
      "referenceLabel": "Psalms 95:13",
      "text": "a facie Domini, quia venit, quoniam venit judicare terram. Judicabit orbem terræ in æquitate, et populos in veritate sua.",
      "paragraphStart": false
    }
  ]
}
