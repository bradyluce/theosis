{
  "chapter": {
    "id": "vulgate:psalms.23",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.23.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "Prima sabbati. Psalmus David. Domini est terra, et plenitudo ejus; orbis terrarum, et universi qui habitant in eo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.23.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "Quia ipse super maria fundavit eum, et super flumina præparavit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "Quis ascendet in montem Domini? aut quis stabit in loco sancto ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "Innocens manibus et mundo corde, qui non accepit in vano animam suam, nec juravit in dolo proximo suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "hic accipiet benedictionem a Domino, et misericordiam a Deo salutari suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "Hæc est generatio quærentium eum, quærentium faciem Dei Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Psalms 23:7",
      "text": "Attollite portas, principes, vestras, et elevamini, portæ æternales, et introibit rex gloriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Psalms 23:8",
      "text": "Quis est iste rex gloriæ? Dominus fortis et potens, Dominus potens in prælio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Psalms 23:9",
      "text": "Attollite portas, principes, vestras, et elevamini, portæ æternales, et introibit rex gloriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.23.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Psalms 23:10",
      "text": "Quis est iste rex gloriæ? Dominus virtutum ipse est rex gloriæ.",
      "paragraphStart": false
    }
  ]
}
