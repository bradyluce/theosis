{
  "chapter": {
    "id": "vulgate:psalms.45",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 45,
    "referenceLabel": "Psalms 45",
    "summary": "Source text for Psalms 45 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.45.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 1,
      "referenceLabel": "Psalms 45:1",
      "text": "In finem, filiis Core, pro arcanis. Psalmus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.45.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 2,
      "referenceLabel": "Psalms 45:2",
      "text": "Deus noster refugium et virtus; adjutor in tribulationibus quæ invenerunt nos nimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 3,
      "referenceLabel": "Psalms 45:3",
      "text": "Propterea non timebimus dum turbabitur terra, et transferentur montes in cor maris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 4,
      "referenceLabel": "Psalms 45:4",
      "text": "Sonuerunt, et turbatæ sunt aquæ eorum; conturbati sunt montes in fortitudine ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 5,
      "referenceLabel": "Psalms 45:5",
      "text": "Fluminis impetus lætificat civitatem Dei: sanctificavit tabernaculum suum Altissimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 6,
      "referenceLabel": "Psalms 45:6",
      "text": "Deus in medio ejus, non commovebitur; adjuvabit eam Deus mane diluculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 7,
      "referenceLabel": "Psalms 45:7",
      "text": "Conturbatæ sunt gentes, et inclinata sunt regna: dedit vocem suam, mota est terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 8,
      "referenceLabel": "Psalms 45:8",
      "text": "Dominus virtutum nobiscum; susceptor noster Deus Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 9,
      "referenceLabel": "Psalms 45:9",
      "text": "Venite, et videte opera Domini, quæ posuit prodigia super terram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 10,
      "referenceLabel": "Psalms 45:10",
      "text": "auferens bella usque ad finem terræ. Arcum conteret, et confringet arma, et scuta comburet igni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 11,
      "referenceLabel": "Psalms 45:11",
      "text": "Vacate, et videte quoniam ego sum Deus; exaltabor in gentibus, et exaltabor in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.45.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 12,
      "referenceLabel": "Psalms 45:12",
      "text": "Dominus virtutum nobiscum; susceptor noster Deus Jacob.",
      "paragraphStart": false
    }
  ]
}
