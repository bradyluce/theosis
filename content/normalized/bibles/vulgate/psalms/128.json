{
  "chapter": {
    "id": "vulgate:psalms.128",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.128.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "Canticum graduum. Sæpe expugnaverunt me a juventute mea, dicat nunc Israël;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.128.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "sæpe expugnaverunt me a juventute mea: etenim non potuerunt mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.128.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Supra dorsum meum fabricaverunt peccatores; prolongaverunt iniquitatem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.128.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Dominus justus concidit cervices peccatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.128.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "Confundantur, et convertantur retrorsum omnes qui oderunt Sion.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.128.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "Fiant sicut fœnum tectorum, quod priusquam evellatur exaruit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.128.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 7,
      "referenceLabel": "Psalms 128:7",
      "text": "de quo non implevit manum suam qui metit, et sinum suum qui manipulos colligit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.128.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 8,
      "referenceLabel": "Psalms 128:8",
      "text": "Et non dixerunt qui præteribant: Benedictio Domini super vos. Benediximus vobis in nomine Domini.",
      "paragraphStart": false
    }
  ]
}
