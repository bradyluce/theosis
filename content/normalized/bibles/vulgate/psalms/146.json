{
  "chapter": {
    "id": "vulgate:psalms.146",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.146.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Alleluja. Laudate Dominum, quoniam bonus est psalmus; Deo nostro sit jucunda, decoraque laudatio.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.146.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "Ædificans Jerusalem Dominus, dispersiones Israëlis congregabit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "qui sanat contritos corde, et alligat contritiones eorum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "qui numerat multitudinem stellarum, et omnibus eis nomina vocat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Magnus Dominus noster, et magna virtus ejus, et sapientiæ ejus non est numerus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "Suscipiens mansuetos Dominus; humilians autem peccatores usque ad terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "Præcinite Domino in confessione; psallite Deo nostro in cithara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "Qui operit cælum nubibus, et parat terræ pluviam; qui producit in montibus fœnum, et herbam servituti hominum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "qui dat jumentis escam ipsorum, et pullis corvorum invocantibus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "Non in fortitudine equi voluntatem habebit, nec in tibiis viri beneplacitum erit ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.146.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 11,
      "referenceLabel": "Psalms 146:11",
      "text": "Beneplacitum est Domino super timentes eum, et in eis qui sperant super misericordia ejus.",
      "paragraphStart": false
    }
  ]
}
