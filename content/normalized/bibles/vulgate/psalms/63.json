{
  "chapter": {
    "id": "vulgate:psalms.63",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.63.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.63.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "Exaudi, Deus, orationem meam cum deprecor; a timore inimici eripe animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Protexisti me a conventu malignantium, a multitudine operantium iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "Quia exacuerunt ut gladium linguas suas; intenderunt arcum rem amaram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "ut sagittent in occultis immaculatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "Subito sagittabunt eum, et non timebunt; firmaverunt sibi sermonem nequam. Narraverunt ut absconderent laqueos; dixerunt: Quis videbit eos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "Scrutati sunt iniquitates; defecerunt scrutantes scrutinio. Accedet homo ad cor altum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "et exaltabitur Deus. Sagittæ parvulorum factæ sunt plagæ eorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "et infirmatæ sunt contra eos linguæ eorum. Conturbati sunt omnes qui videbant eos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "et timuit omnis homo. Et annuntiaverunt opera Dei, et facta ejus intellexerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.63.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "Lætabitur justus in Domino, et sperabit in eo, et laudabuntur omnes recti corde.",
      "paragraphStart": false
    }
  ]
}
