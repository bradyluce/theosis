{
  "chapter": {
    "id": "vulgate:psalms.44",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 44,
    "referenceLabel": "Psalms 44",
    "summary": "Source text for Psalms 44 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.44.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 1,
      "referenceLabel": "Psalms 44:1",
      "text": "In finem, pro iis qui commutabuntur. Filiis Core, ad intellectum. Canticum pro dilecto.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.44.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 2,
      "referenceLabel": "Psalms 44:2",
      "text": "Eructavit cor meum verbum bonum: dico ego opera mea regi. Lingua mea calamus scribæ velociter scribentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 3,
      "referenceLabel": "Psalms 44:3",
      "text": "Speciosus forma præ filiis hominum, diffusa est gratia in labiis tuis: propterea benedixit te Deus in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 4,
      "referenceLabel": "Psalms 44:4",
      "text": "Accingere gladio tuo super femur tuum, potentissime.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 5,
      "referenceLabel": "Psalms 44:5",
      "text": "Specie tua et pulchritudine tua intende, prospere procede, et regna, propter veritatem, et mansuetudinem, et justitiam; et deducet te mirabiliter dextera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 6,
      "referenceLabel": "Psalms 44:6",
      "text": "Sagittæ tuæ acutæ: populi sub te cadent, in corda inimicorum regis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 7,
      "referenceLabel": "Psalms 44:7",
      "text": "Sedes tua, Deus, in sæculum sæculi; virga directionis virga regni tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 8,
      "referenceLabel": "Psalms 44:8",
      "text": "Dilexisti justitiam, et odisti iniquitatem; propterea unxit te Deus, Deus tuus, oleo lætitiæ, præ consortibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 9,
      "referenceLabel": "Psalms 44:9",
      "text": "Myrrha, et gutta, et casia a vestimentis tuis, a domibus eburneis; ex quibus delectaverunt te",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 10,
      "referenceLabel": "Psalms 44:10",
      "text": "filiæ regum in honore tuo. Astitit regina a dextris tuis in vestitu deaurato, circumdata varietate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 11,
      "referenceLabel": "Psalms 44:11",
      "text": "Audi, filia, et vide, et inclina aurem tuam; et obliviscere populum tuum, et domum patris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 12,
      "referenceLabel": "Psalms 44:12",
      "text": "Et concupiscet rex decorem tuum, quoniam ipse est Dominus Deus tuus, et adorabunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 13,
      "referenceLabel": "Psalms 44:13",
      "text": "Et filiæ Tyri in muneribus vultum tuum deprecabuntur; omnes divites plebis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 14,
      "referenceLabel": "Psalms 44:14",
      "text": "Omnis gloria ejus filiæ regis ab intus, in fimbriis aureis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 15,
      "referenceLabel": "Psalms 44:15",
      "text": "circumamicta varietatibus. Adducentur regi virgines post eam; proximæ ejus afferentur tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 16,
      "referenceLabel": "Psalms 44:16",
      "text": "Afferentur in lætitia et exsultatione; adducentur in templum regis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 17,
      "referenceLabel": "Psalms 44:17",
      "text": "Pro patribus tuis nati sunt tibi filii; constitues eos principes super omnem terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.44.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 18,
      "referenceLabel": "Psalms 44:18",
      "text": "Memores erunt nominis tui in omni generatione et generationem: propterea populi confitebuntur tibi in æternum, et in sæculum sæculi.",
      "paragraphStart": false
    }
  ]
}
