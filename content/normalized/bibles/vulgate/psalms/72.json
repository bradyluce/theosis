{
  "chapter": {
    "id": "vulgate:psalms.72",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.72.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "Psalmus Asaph. Quam bonus Israël Deus, his qui recto sunt corde!",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.72.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "Mei autem pene moti sunt pedes, pene effusi sunt gressus mei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "quia zelavi super iniquos, pacem peccatorum videns.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "Quia non est respectus morti eorum, et firmamentum in plaga eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "In labore hominum non sunt, et cum hominibus non flagellabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "Ideo tenuit eos superbia; operti sunt iniquitate et impietate sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "Prodiit quasi ex adipe iniquitas eorum; transierunt in affectum cordis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "Cogitaverunt et locuti sunt nequitiam; iniquitatem in excelso locuti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "Posuerunt in cælum os suum, et lingua eorum transivit in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "Ideo convertetur populus meus hic, et dies pleni invenientur in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "Et dixerunt: Quomodo scit Deus, et si est scientia in excelso?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "Ecce ipsi peccatores, et abundantes in sæculo obtinuerunt divitias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "Et dixi: Ergo sine causa justificavi cor meum, et lavi inter innocentes manus meas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "et fui flagellatus tota die, et castigatio mea in matutinis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "Si dicebam: Narrabo sic; ecce nationem filiorum tuorum reprobavi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "Existimabam ut cognoscerem hoc; labor est ante me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "donec intrem in sanctuarium Dei, et intelligam in novissimis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Verumtamen propter dolos posuisti eis; dejecisti eos dum allevarentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "Quomodo facti sunt in desolationem? subito defecerunt: perierunt propter iniquitatem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "Velut somnium surgentium, Domine, in civitate tua imaginem ipsorum ad nihilum rediges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 21,
      "referenceLabel": "Psalms 72:21",
      "text": "Quia inflammatum est cor meum, et renes mei commutati sunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 22,
      "referenceLabel": "Psalms 72:22",
      "text": "et ego ad nihilum redactus sum, et nescivi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 23,
      "referenceLabel": "Psalms 72:23",
      "text": "ut jumentum factus sum apud te, et ego semper tecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 24,
      "referenceLabel": "Psalms 72:24",
      "text": "Tenuisti manum dexteram meam, et in voluntate tua deduxisti me, et cum gloria suscepisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 25,
      "referenceLabel": "Psalms 72:25",
      "text": "Quid enim mihi est in cælo? et a te quid volui super terram?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 26,
      "referenceLabel": "Psalms 72:26",
      "text": "Defecit caro mea et cor meum; Deus cordis mei, et pars mea, Deus in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 27,
      "referenceLabel": "Psalms 72:27",
      "text": "Quia ecce qui elongant se a te peribunt; perdidisti omnes qui fornicantur abs te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.72.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 28,
      "referenceLabel": "Psalms 72:28",
      "text": "Mihi autem adhærere Deo bonum est; ponere in Domino Deo spem meam: ut annuntiem omnes prædicationes tuas in portis filiæ Sion.",
      "paragraphStart": false
    }
  ]
}
