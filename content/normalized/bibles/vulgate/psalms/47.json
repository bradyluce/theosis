{
  "chapter": {
    "id": "vulgate:psalms.47",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.47.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "Psalmus cantici. Filiis Core, secunda sabbati.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.47.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "Magnus Dominus et laudabilis nimis, in civitate Dei nostri, in monte sancto ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "Fundatur exsultatione universæ terræ mons Sion; latera aquilonis, civitas regis magni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "Deus in domibus ejus cognoscetur cum suscipiet eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "Quoniam ecce reges terræ congregati sunt; convenerunt in unum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "Ipsi videntes, sic admirati sunt, conturbati sunt, commoti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "Tremor apprehendit eos; ibi dolores ut parturientis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "in spiritu vehementi conteres naves Tharsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "Sicut audivimus, sic vidimus, in civitate Domini virtutum, in civitate Dei nostri: Deus fundavit eam in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 10,
      "referenceLabel": "Psalms 47:10",
      "text": "Suscepimus, Deus, misericordiam tuam in medio templi tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 11,
      "referenceLabel": "Psalms 47:11",
      "text": "Secundum nomen tuum, Deus, sic et laus tua in fines terræ; justitia plena est dextera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 12,
      "referenceLabel": "Psalms 47:12",
      "text": "Lætetur mons Sion, et exsultent filiæ Judæ, propter judicia tua, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 13,
      "referenceLabel": "Psalms 47:13",
      "text": "Circumdate Sion, et complectimini eam; narrate in turribus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 14,
      "referenceLabel": "Psalms 47:14",
      "text": "Ponite corda vestra in virtute ejus, et distribuite domos ejus, ut enarretis in progenie altera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.47.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 15,
      "referenceLabel": "Psalms 47:15",
      "text": "Quoniam hic est Deus, Deus noster in æternum, et in sæculum sæculi: ipse reget nos in sæcula.",
      "paragraphStart": false
    }
  ]
}
