{
  "chapter": {
    "id": "vulgate:psalms.94",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.94.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "Laus cantici ipsi David. Venite, exsultemus Domino; jubilemus Deo salutari nostro;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.94.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "præoccupemus faciem ejus in confessione, et in psalmis jubilemus ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "quoniam Deus magnus Dominus, et rex magnus super omnes deos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "Quia in manu ejus sunt omnes fines terræ, et altitudines montium ipsius sunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "quoniam ipsius est mare, et ipse fecit illud, et siccam manus ejus formaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "Venite, adoremus, et procidamus, et ploremus ante Dominum qui fecit nos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "quia ipse est Dominus Deus noster, et nos populus pascuæ ejus, et oves manus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "Hodie si vocem ejus audieritis, nolite obdurare corda vestra",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "sicut in irritatione, secundum diem tentationis in deserto, ubi tentaverunt me patres vestri: probaverunt me, et viderunt opera mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "Quadraginta annis offensus fui generationi illi, et dixi: Semper hi errant corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.94.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "Et isti non cognoverunt vias meas: ut juravi in ira mea: Si introibunt in requiem meam.",
      "paragraphStart": false
    }
  ]
}
