{
  "chapter": {
    "id": "vulgate:psalms.76",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.76.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "In finem, pro Idithun. Psalmus Asaph.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.76.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "Voce mea ad Dominum clamavi; voce mea ad Deum, et intendit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "In die tribulationis meæ Deum exquisivi; manibus meis nocte contra eum, et non sum deceptus. Renuit consolari anima mea;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "memor fui Dei, et delectatus sum, et exercitatus sum, et defecit spiritus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "Anticipaverunt vigilias oculi mei; turbatus sum, et non sum locutus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "Cogitavi dies antiquos, et annos æternos in mente habui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "Et meditatus sum nocte cum corde meo, et exercitabar, et scopebam spiritum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "Numquid in æternum projiciet Deus? aut non apponet ut complacitior sit adhuc?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "aut in finem misericordiam suam abscindet, a generatione in generationem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "aut obliviscetur misereri Deus? aut continebit in ira sua misericordias suas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "Et dixi: Nunc cœpi; hæc mutatio dexteræ Excelsi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "Memor fui operum Domini, quia memor ero ab initio mirabilium tuorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 13,
      "referenceLabel": "Psalms 76:13",
      "text": "et meditabor in omnibus operibus tuis, et in adinventionibus tuis exercebor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 14,
      "referenceLabel": "Psalms 76:14",
      "text": "Deus, in sancto via tua: quis deus magnus sicut Deus noster?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 15,
      "referenceLabel": "Psalms 76:15",
      "text": "Tu es Deus qui facis mirabilia: notam fecisti in populis virtutem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 16,
      "referenceLabel": "Psalms 76:16",
      "text": "Redemisti in brachio tuo populum tuum, filios Jacob et Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 17,
      "referenceLabel": "Psalms 76:17",
      "text": "Viderunt te aquæ, Deus; viderunt te aquæ, et timuerunt: et turbatæ sunt abyssi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 18,
      "referenceLabel": "Psalms 76:18",
      "text": "Multitudo sonitus aquarum; vocem dederunt nubes. Etenim sagittæ tuæ transeunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 19,
      "referenceLabel": "Psalms 76:19",
      "text": "vox tonitrui tui in rota. Illuxerunt coruscationes tuæ orbi terræ; commota est, et contremuit terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 20,
      "referenceLabel": "Psalms 76:20",
      "text": "In mari via tua, et semitæ tuæ in aquis multis, et vestigia tua non cognoscentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.76.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 21,
      "referenceLabel": "Psalms 76:21",
      "text": "Deduxisti sicut oves populum tuum, in manu Moysi et Aaron.",
      "paragraphStart": false
    }
  ]
}
