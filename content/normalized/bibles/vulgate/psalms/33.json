{
  "chapter": {
    "id": "vulgate:psalms.33",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.33.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "Davidi, cum immutavit vultum suum coram Achimelech, et dimisit eum, et abiit.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.33.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Benedicam Dominum in omni tempore; semper laus ejus in ore meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "In Domino laudabitur anima mea: audiant mansueti, et lætentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "Magnificate Dominum mecum, et exaltemus nomen ejus in idipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "Exquisivi Dominum, et exaudivit me; et ex omnibus tribulationibus meis eripuit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "Accedite ad eum, et illuminamini; et facies vestræ non confundentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "Iste pauper clamavit, et Dominus exaudivit eum, et de omnibus tribulationibus ejus salvavit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Immittet angelus Domini in circuitu timentium eum, et eripiet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "Gustate et videte quoniam suavis est Dominus; beatus vir qui sperat in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "Timete Dominum, omnes sancti ejus, quoniam non est inopia timentibus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "Divites eguerunt, et esurierunt; inquirentes autem Dominum non minuentur omni bono.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Venite, filii; audite me: timorem Domini docebo vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "Quis est homo qui vult vitam; diligit dies videre bonos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "Prohibe linguam tuam a malo, et labia tua ne loquantur dolum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "Diverte a malo, et fac bonum; inquire pacem, et persequere eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "Oculi Domini super justos, et aures ejus in preces eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "Vultus autem Domini super facientes mala, ut perdat de terra memoriam eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Clamaverunt justi, et Dominus exaudivit eos; et ex omnibus tribulationibus eorum liberavit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "Juxta est Dominus iis qui tribulato sunt corde, et humiles spiritu salvabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Multæ tribulationes justorum; et de omnibus his liberabit eos Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "Custodit Dominus omnia ossa eorum: unum ex his non conteretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Mors peccatorum pessima; et qui oderunt justum delinquent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.33.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Psalms 33:23",
      "text": "Redimet Dominus animas servorum suorum, et non delinquent omnes qui sperant in eo.",
      "paragraphStart": false
    }
  ]
}
