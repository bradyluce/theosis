{
  "chapter": {
    "id": "vulgate:psalms.88",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.88.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "Intellectus Ethan Ezrahitæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.88.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "Misericordias Domini in æternum cantabo; in generationem et generationem annuntiabo veritatem tuam in ore meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "Quoniam dixisti: In æternum misericordia ædificabitur in cælis; præparabitur veritas tua in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "Disposui testamentum electis meis; juravi David servo meo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "Usque in æternum præparabo semen tuum, et ædificabo in generationem et generationem sedem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "Confitebuntur cæli mirabilia tua, Domine; etenim veritatem tuam in ecclesia sanctorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "Quoniam quis in nubibus æquabitur Domino; similis erit Deo in filiis Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "Deus, qui glorificatur in consilio sanctorum, magnus et terribilis super omnes qui in circuitu ejus sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "Domine Deus virtutum, quis similis tibi? potens es, Domine, et veritas tua in circuitu tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "Tu dominaris potestati maris; motum autem fluctuum ejus tu mitigas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "Tu humiliasti, sicut vulneratum, superbum; in brachio virtutis tuæ dispersisti inimicos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "Tui sunt cæli, et tua est terra: orbem terræ, et plenitudinem ejus tu fundasti;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "aquilonem et mare tu creasti. Thabor et Hermon in nomine tuo exsultabunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "tuum brachium cum potentia. Firmetur manus tua, et exaltetur dextera tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "justitia et judicium præparatio sedis tuæ: misericordia et veritas præcedent faciem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "Beatus populus qui scit jubilationem: Domine, in lumine vultus tui ambulabunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "et in nomine tuo exsultabunt tota die, et in justitia tua exaltabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "Quoniam gloria virtutis eorum tu es, et in beneplacito tuo exaltabitur cornu nostrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 19,
      "referenceLabel": "Psalms 88:19",
      "text": "Quia Domini est assumptio nostra, et sancti Israël regis nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 20,
      "referenceLabel": "Psalms 88:20",
      "text": "Tunc locutus es in visione sanctis tuis, et dixisti: Posui adjutorium in potente, et exaltavi electum de plebe mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 21,
      "referenceLabel": "Psalms 88:21",
      "text": "Inveni David, servum meum; oleo sancto meo unxi eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 22,
      "referenceLabel": "Psalms 88:22",
      "text": "Manus enim mea auxiliabitur ei, et brachium meum confortabit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 23,
      "referenceLabel": "Psalms 88:23",
      "text": "Nihil proficiet inimicus in eo, et filius iniquitatis non apponet nocere ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 24,
      "referenceLabel": "Psalms 88:24",
      "text": "Et concidam a facie ipsius inimicos ejus, et odientes eum in fugam convertam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 25,
      "referenceLabel": "Psalms 88:25",
      "text": "Et veritas mea et misericordia mea cum ipso, et in nomine meo exaltabitur cornu ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 26,
      "referenceLabel": "Psalms 88:26",
      "text": "Et ponam in mari manum ejus, et in fluminibus dexteram ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 27,
      "referenceLabel": "Psalms 88:27",
      "text": "Ipse invocabit me: Pater meus es tu, Deus meus, et susceptor salutis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 28,
      "referenceLabel": "Psalms 88:28",
      "text": "Et ego primogenitum ponam illum, excelsum præ regibus terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 29,
      "referenceLabel": "Psalms 88:29",
      "text": "In æternum servabo illi misericordiam meam, et testamentum meum fidele ipsi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 30,
      "referenceLabel": "Psalms 88:30",
      "text": "Et ponam in sæculum sæculi semen ejus, et thronum ejus sicut dies cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 31,
      "referenceLabel": "Psalms 88:31",
      "text": "Si autem dereliquerint filii ejus legem meam, et in judiciis meis non ambulaverint;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 32,
      "referenceLabel": "Psalms 88:32",
      "text": "si justitias meas profanaverint, et mandata mea non custodierint:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 33,
      "referenceLabel": "Psalms 88:33",
      "text": "visitabo in virga iniquitates eorum, et in verberibus peccata eorum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 34,
      "referenceLabel": "Psalms 88:34",
      "text": "misericordiam autem meam non dispergam ab eo, neque nocebo in veritate mea,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 35,
      "referenceLabel": "Psalms 88:35",
      "text": "neque profanabo testamentum meum: et quæ procedunt de labiis meis non faciam irrita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 36,
      "referenceLabel": "Psalms 88:36",
      "text": "Semel juravi in sancto meo, si David mentiar:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 37,
      "referenceLabel": "Psalms 88:37",
      "text": "semen ejus in æternum manebit. Et thronus ejus sicut sol in conspectu meo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 38,
      "referenceLabel": "Psalms 88:38",
      "text": "et sicut luna perfecta in æternum, et testis in cælo fidelis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 39,
      "referenceLabel": "Psalms 88:39",
      "text": "Tu vero repulisti et despexisti; distulisti christum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 40,
      "referenceLabel": "Psalms 88:40",
      "text": "Evertisti testamentum servi tui; profanasti in terra sanctuarium ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.41",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 41,
      "referenceLabel": "Psalms 88:41",
      "text": "Destruxisti omnes sepes ejus; posuisti firmamentum ejus formidinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.42",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 42,
      "referenceLabel": "Psalms 88:42",
      "text": "Diripuerunt eum omnes transeuntes viam; factus est opprobrium vicinis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.43",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 43,
      "referenceLabel": "Psalms 88:43",
      "text": "Exaltasti dexteram deprimentium eum; lætificasti omnes inimicos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.44",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 44,
      "referenceLabel": "Psalms 88:44",
      "text": "Avertisti adjutorium gladii ejus, et non es auxiliatus ei in bello.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.45",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 45,
      "referenceLabel": "Psalms 88:45",
      "text": "Destruxisti eum ab emundatione, et sedem ejus in terram collisisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.46",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 46,
      "referenceLabel": "Psalms 88:46",
      "text": "Minorasti dies temporis ejus; perfudisti eum confusione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.47",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 47,
      "referenceLabel": "Psalms 88:47",
      "text": "Usquequo, Domine, avertis in finem? exardescet sicut ignis ira tua?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.48",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 48,
      "referenceLabel": "Psalms 88:48",
      "text": "Memorare quæ mea substantia: numquid enim vane constituisti omnes filios hominum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.49",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 49,
      "referenceLabel": "Psalms 88:49",
      "text": "Quis est homo qui vivet et non videbit mortem? eruet animam suam de manu inferi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.50",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 50,
      "referenceLabel": "Psalms 88:50",
      "text": "Ubi sunt misericordiæ tuæ antiquæ, Domine, sicut jurasti David in veritate tua?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.51",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 51,
      "referenceLabel": "Psalms 88:51",
      "text": "Memor esto, Domine, opprobrii servorum tuorum, quod continui in sinu meo, multarum gentium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.52",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 52,
      "referenceLabel": "Psalms 88:52",
      "text": "quod exprobraverunt inimici tui, Domine; quod exprobraverunt commutationem christi tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.88.53",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 53,
      "referenceLabel": "Psalms 88:53",
      "text": "Benedictus Dominus in æternum. Fiat, fiat.",
      "paragraphStart": false
    }
  ]
}
