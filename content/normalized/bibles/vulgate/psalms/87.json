{
  "chapter": {
    "id": "vulgate:psalms.87",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.87.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "Canticum Psalmi, filiis Core, in finem, pro Maheleth ad respondendum. Intellectus Eman Ezrahitæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.87.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "Domine, Deus salutis meæ, in die clamavi et nocte coram te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Intret in conspectu tuo oratio mea, inclina aurem tuam ad precem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "Quia repleta est malis anima mea, et vita mea inferno appropinquavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "Æstimatus sum cum descendentibus in lacum, factus sum sicut homo sine adjutorio,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "inter mortuos liber; sicut vulnerati dormientes in sepulchris, quorum non es memor amplius, et ipsi de manu tua repulsi sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "Posuerunt me in lacu inferiori, in tenebrosis, et in umbra mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 8,
      "referenceLabel": "Psalms 87:8",
      "text": "Super me confirmatus est furor tuus, et omnes fluctus tuos induxisti super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 9,
      "referenceLabel": "Psalms 87:9",
      "text": "Longe fecisti notos meos a me; posuerunt me abominationem sibi. Traditus sum, et non egrediebar;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 10,
      "referenceLabel": "Psalms 87:10",
      "text": "oculi mei languerunt præ inopia. Clamavi ad te, Domine, tota die; expandi ad te manus meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 11,
      "referenceLabel": "Psalms 87:11",
      "text": "Numquid mortuis facies mirabilia? aut medici suscitabunt, et confitebuntur tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 12,
      "referenceLabel": "Psalms 87:12",
      "text": "Numquid narrabit aliquis in sepulchro misericordiam tuam, et veritatem tuam in perditione?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 13,
      "referenceLabel": "Psalms 87:13",
      "text": "Numquid cognoscentur in tenebris mirabilia tua? et justitia tua in terra oblivionis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 14,
      "referenceLabel": "Psalms 87:14",
      "text": "Et ego ad te, Domine, clamavi, et mane oratio mea præveniet te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 15,
      "referenceLabel": "Psalms 87:15",
      "text": "Ut quid, Domine, repellis orationem meam; avertis faciem tuam a me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 16,
      "referenceLabel": "Psalms 87:16",
      "text": "Pauper sum ego, et in laboribus a juventute mea; exaltatus autem, humiliatus sum et conturbatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 17,
      "referenceLabel": "Psalms 87:17",
      "text": "In me transierunt iræ tuæ, et terrores tui conturbaverunt me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 18,
      "referenceLabel": "Psalms 87:18",
      "text": "circumdederunt me sicut aqua tota die; circumdederunt me simul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.87.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 19,
      "referenceLabel": "Psalms 87:19",
      "text": "Elongasti a me amicum et proximum, et notos meos a miseria.",
      "paragraphStart": false
    }
  ]
}
