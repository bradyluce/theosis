{
  "chapter": {
    "id": "vulgate:psalms.140",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 140,
    "referenceLabel": "Psalms 140",
    "summary": "Source text for Psalms 140 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.140.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 1,
      "referenceLabel": "Psalms 140:1",
      "text": "Psalmus David. Domine, clamavi ad te: exaudi me; intende voci meæ, cum clamavero ad te.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.140.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 2,
      "referenceLabel": "Psalms 140:2",
      "text": "Dirigatur oratio mea sicut incensum in conspectu tuo; elevatio manuum mearum sacrificium vespertinum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 3,
      "referenceLabel": "Psalms 140:3",
      "text": "Pone, Domine, custodiam ori meo, et ostium circumstantiæ labiis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 4,
      "referenceLabel": "Psalms 140:4",
      "text": "Non declines cor meum in verba malitiæ, ad excusandas excusationes in peccatis; cum hominibus operantibus iniquitatem, et non communicabo cum electis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 5,
      "referenceLabel": "Psalms 140:5",
      "text": "Corripiet me justus in misericordia, et increpabit me: oleum autem peccatoris non impinguet caput meum. Quoniam adhuc et oratio mea in beneplacitis eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 6,
      "referenceLabel": "Psalms 140:6",
      "text": "absorpti sunt juncti petræ judices eorum. Audient verba mea, quoniam potuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 7,
      "referenceLabel": "Psalms 140:7",
      "text": "Sicut crassitudo terræ erupta est super terram, dissipata sunt ossa nostra secus infernum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 8,
      "referenceLabel": "Psalms 140:8",
      "text": "Quia ad te, Domine, Domine, oculi mei; in te speravi, non auferas animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 9,
      "referenceLabel": "Psalms 140:9",
      "text": "Custodi me a laqueo quem statuerunt mihi, et a scandalis operantium iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.140.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 10,
      "referenceLabel": "Psalms 140:10",
      "text": "Cadent in retiaculo ejus peccatores: singulariter sum ego, donec transeam.",
      "paragraphStart": false
    }
  ]
}
