{
  "chapter": {
    "id": "vulgate:psalms.67",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 67,
    "referenceLabel": "Psalms 67",
    "summary": "Source text for Psalms 67 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.67.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 1,
      "referenceLabel": "Psalms 67:1",
      "text": "In finem. Psalmus cantici ipsi David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.67.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 2,
      "referenceLabel": "Psalms 67:2",
      "text": "Exsurgat Deus, et dissipentur inimici ejus; et fugiant qui oderunt eum a facie ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 3,
      "referenceLabel": "Psalms 67:3",
      "text": "Sicut deficit fumus, deficiant; sicut fluit cera a facie ignis, sic pereant peccatores a facie Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 4,
      "referenceLabel": "Psalms 67:4",
      "text": "Et justi epulentur, et exsultent in conspectu Dei, et delectentur in lætitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 5,
      "referenceLabel": "Psalms 67:5",
      "text": "Cantate Deo; psalmum dicite nomini ejus: iter facite ei qui ascendit super occasum. Dominus nomen illi; exsultate in conspectu ejus. Turbabuntur a facie ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 6,
      "referenceLabel": "Psalms 67:6",
      "text": "patris orphanorum, et judicis viduarum; Deus in loco sancto suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 7,
      "referenceLabel": "Psalms 67:7",
      "text": "Deus qui inhabitare facit unius moris in domo; qui educit vinctos in fortitudine, similiter eos qui exasperant, qui habitant in sepulchris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 8,
      "referenceLabel": "Psalms 67:8",
      "text": "Deus, cum egredereris in conspectu populi tui, cum pertransires in deserto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 9,
      "referenceLabel": "Psalms 67:9",
      "text": "terra mota est, etenim cæli distillaverunt, a facie Dei Sinai, a facie Dei Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 10,
      "referenceLabel": "Psalms 67:10",
      "text": "Pluviam voluntariam segregabis, Deus, hæreditati tuæ; et infirmata est, tu vero perfecisti eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 11,
      "referenceLabel": "Psalms 67:11",
      "text": "Animalia tua habitabunt in ea; parasti in dulcedine tua pauperi, Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 12,
      "referenceLabel": "Psalms 67:12",
      "text": "Dominus dabit verbum evangelizantibus, virtute multa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 13,
      "referenceLabel": "Psalms 67:13",
      "text": "Rex virtutum dilecti, dilecti; et speciei domus dividere spolia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 14,
      "referenceLabel": "Psalms 67:14",
      "text": "Si dormiatis inter medios cleros, pennæ columbæ deargentatæ, et posteriora dorsi ejus in pallore auri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 15,
      "referenceLabel": "Psalms 67:15",
      "text": "Dum discernit cælestis reges super eam, nive dealbabuntur in Selmon.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 16,
      "referenceLabel": "Psalms 67:16",
      "text": "Mons Dei, mons pinguis: mons coagulatus, mons pinguis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 17,
      "referenceLabel": "Psalms 67:17",
      "text": "Ut quid suspicamini, montes coagulatos? mons in quo beneplacitum est Deo habitare in eo; etenim Dominus habitabit in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 18,
      "referenceLabel": "Psalms 67:18",
      "text": "Currus Dei decem millibus multiplex, millia lætantium; Dominus in eis in Sina, in sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 19,
      "referenceLabel": "Psalms 67:19",
      "text": "Ascendisti in altum, cepisti captivitatem, accepisti dona in hominibus; etenim non credentes inhabitare Dominum Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 20,
      "referenceLabel": "Psalms 67:20",
      "text": "Benedictus Dominus die quotidie: prosperum iter faciet nobis Deus salutarium nostrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 21,
      "referenceLabel": "Psalms 67:21",
      "text": "Deus noster, Deus salvos faciendi; et Domini, Domini exitus mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 22,
      "referenceLabel": "Psalms 67:22",
      "text": "Verumtamen Deus confringet capita inimicorum suorum, verticem capilli perambulantium in delictis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 23,
      "referenceLabel": "Psalms 67:23",
      "text": "Dixit Dominus: Ex Basan convertam, convertam in profundum maris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 24,
      "referenceLabel": "Psalms 67:24",
      "text": "ut intingatur pes tuus in sanguine; lingua canum tuorum ex inimicis, ab ipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 25,
      "referenceLabel": "Psalms 67:25",
      "text": "Viderunt ingressus tuos, Deus, ingressus Dei mei, regis mei, qui est in sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 26,
      "referenceLabel": "Psalms 67:26",
      "text": "Prævenerunt principes conjuncti psallentibus, in medio juvencularum tympanistriarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 27,
      "referenceLabel": "Psalms 67:27",
      "text": "In ecclesiis benedicite Deo Domino de fontibus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 28,
      "referenceLabel": "Psalms 67:28",
      "text": "Ibi Benjamin adolescentulus, in mentis excessu; principes Juda, duces eorum; principes Zabulon, principes Nephthali.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 29,
      "referenceLabel": "Psalms 67:29",
      "text": "Manda, Deus, virtuti tuæ; confirma hoc, Deus, quod operatus es in nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 30,
      "referenceLabel": "Psalms 67:30",
      "text": "A templo tuo in Jerusalem, tibi offerent reges munera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 31,
      "referenceLabel": "Psalms 67:31",
      "text": "Increpa feras arundinis; congregatio taurorum in vaccis populorum: ut excludant eos qui probati sunt argento. Dissipa gentes quæ bella volunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 32,
      "referenceLabel": "Psalms 67:32",
      "text": "Venient legati ex Ægypto; Æthiopia præveniet manus ejus Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 33,
      "referenceLabel": "Psalms 67:33",
      "text": "Regna terræ, cantate Deo; psallite Domino; psallite Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 34,
      "referenceLabel": "Psalms 67:34",
      "text": "Qui ascendit super cælum cæli, ad orientem: ecce dabit voci suæ vocem virtutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 35,
      "referenceLabel": "Psalms 67:35",
      "text": "Date gloriam Deo super Israël; magnificentia ejus et virtus ejus in nubibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.67.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 36,
      "referenceLabel": "Psalms 67:36",
      "text": "Mirabilis Deus in sanctis suis; Deus Israël ipse dabit virtutem et fortitudinem plebi suæ. Benedictus Deus!",
      "paragraphStart": false
    }
  ]
}
