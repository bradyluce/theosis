{
  "chapter": {
    "id": "vulgate:psalms.59",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 59,
    "referenceLabel": "Psalms 59",
    "summary": "Source text for Psalms 59 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.59.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 1,
      "referenceLabel": "Psalms 59:1",
      "text": "In finem, pro his qui immutabuntur, in tituli inscriptionem ipsi David, in doctrinam,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.59.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 2,
      "referenceLabel": "Psalms 59:2",
      "text": "cum succendit Mesopotamiam Syriæ et Sobal, et convertit Joab, et percussit Idumæam in valle Salinarum duodecim millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 3,
      "referenceLabel": "Psalms 59:3",
      "text": "Deus, repulisti nos, et destruxisti nos; iratus es, et misertus es nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 4,
      "referenceLabel": "Psalms 59:4",
      "text": "Commovisti terram, et conturbasti eam; sana contritiones ejus, quia commota est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 5,
      "referenceLabel": "Psalms 59:5",
      "text": "Ostendisti populo tuo dura; potasti nos vino compunctionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 6,
      "referenceLabel": "Psalms 59:6",
      "text": "Dedisti metuentibus te significationem, ut fugiant a facie arcus; ut liberentur dilecti tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 7,
      "referenceLabel": "Psalms 59:7",
      "text": "Salvum fac dextera tua, et exaudi me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 8,
      "referenceLabel": "Psalms 59:8",
      "text": "Deus locutus est in sancto suo: lætabor, et partibor Sichimam; et convallem tabernaculorum metibor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 9,
      "referenceLabel": "Psalms 59:9",
      "text": "Meus est Galaad, et meus est Manasses; et Ephraim fortitudo capitis mei. Juda rex meus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 10,
      "referenceLabel": "Psalms 59:10",
      "text": "Moab olla spei meæ. In Idumæam extendam calceamentum meum: mihi alienigenæ subditi sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 11,
      "referenceLabel": "Psalms 59:11",
      "text": "Quis deducet me in civitatem munitam? quis deducet me usque in Idumæam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 12,
      "referenceLabel": "Psalms 59:12",
      "text": "nonne tu, Deus, qui repulisti nos? et non egredieris, Deus, in virtutibus nostris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 13,
      "referenceLabel": "Psalms 59:13",
      "text": "Da nobis auxilium de tribulatione, quia vana salus hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.59.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 14,
      "referenceLabel": "Psalms 59:14",
      "text": "In Deo faciemus virtutem; et ipse ad nihilum deducet tribulantes nos.",
      "paragraphStart": false
    }
  ]
}
