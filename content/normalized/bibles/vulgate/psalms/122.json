  "verses": [
    {
      "id": "vulgate:psalms.122.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "Canticum graduum. Ad te levavi oculos meos, qui habitas in cælis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.122.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Ecce sicut oculi servorum in manibus dominorum suorum; sicut oculi ancillæ in manibus dominæ suæ: ita oculi nostri ad Dominum Deum nostrum, donec misereatur nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.122.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Miserere nostri, Domine, miserere nostri, quia multum repleti sumus despectione;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.122.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "quia multum repleta est anima nostra opprobrium abundantibus, et despectio superbis.",
      "paragraphStart": false
    }
  ]
}
