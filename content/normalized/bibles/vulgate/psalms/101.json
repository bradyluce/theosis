{
  "chapter": {
    "id": "vulgate:psalms.101",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 101,
    "referenceLabel": "Psalms 101",
    "summary": "Source text for Psalms 101 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.101.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 1,
      "referenceLabel": "Psalms 101:1",
      "text": "Oratio pauperis, cum anxius fuerit, et in conspectu Domini effuderit precem suam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.101.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 2,
      "referenceLabel": "Psalms 101:2",
      "text": "Domine, exaudi orationem meam, et clamor meus ad te veniat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 3,
      "referenceLabel": "Psalms 101:3",
      "text": "Non avertas faciem tuam a me: in quacumque die tribulor, inclina ad me aurem tuam; in quacumque die invocavero te, velociter exaudi me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 4,
      "referenceLabel": "Psalms 101:4",
      "text": "Quia defecerunt sicut fumus dies mei, et ossa mea sicut cremium aruerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 5,
      "referenceLabel": "Psalms 101:5",
      "text": "Percussus sum ut fœnum, et aruit cor meum, quia oblitus sum comedere panem meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 6,
      "referenceLabel": "Psalms 101:6",
      "text": "A voce gemitus mei adhæsit os meum carni meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 7,
      "referenceLabel": "Psalms 101:7",
      "text": "Similis factus sum pellicano solitudinis; factus sum sicut nycticorax in domicilio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 8,
      "referenceLabel": "Psalms 101:8",
      "text": "Vigilavi, et factus sum sicut passer solitarius in tecto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 9,
      "referenceLabel": "Psalms 101:9",
      "text": "Tota die exprobrabant mihi inimici mei, et qui laudabant me adversum me jurabant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 10,
      "referenceLabel": "Psalms 101:10",
      "text": "quia cinerem tamquam panem manducabam, et potum meum cum fletu miscebam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 11,
      "referenceLabel": "Psalms 101:11",
      "text": "a facie iræ et indignationis tuæ: quia elevans allisisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 12,
      "referenceLabel": "Psalms 101:12",
      "text": "Dies mei sicut umbra declinaverunt, et ego sicut fœnum arui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 13,
      "referenceLabel": "Psalms 101:13",
      "text": "Tu autem, Domine, in æternum permanes, et memoriale tuum in generationem et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 14,
      "referenceLabel": "Psalms 101:14",
      "text": "Tu exsurgens misereberis Sion, quia tempus miserendi ejus, quia venit tempus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 15,
      "referenceLabel": "Psalms 101:15",
      "text": "quoniam placuerunt servis tuis lapides ejus, et terræ ejus miserebuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 16,
      "referenceLabel": "Psalms 101:16",
      "text": "Et timebunt gentes nomen tuum, Domine, et omnes reges terræ gloriam tuam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 17,
      "referenceLabel": "Psalms 101:17",
      "text": "quia ædificavit Dominus Sion, et videbitur in gloria sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 18,
      "referenceLabel": "Psalms 101:18",
      "text": "Respexit in orationem humilium et non sprevit precem eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 19,
      "referenceLabel": "Psalms 101:19",
      "text": "Scribantur hæc in generatione altera, et populus qui creabitur laudabit Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 20,
      "referenceLabel": "Psalms 101:20",
      "text": "Quia prospexit de excelso sancto suo; Dominus de cælo in terram aspexit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 21,
      "referenceLabel": "Psalms 101:21",
      "text": "ut audiret gemitus compeditorum; ut solveret filios interemptorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 22,
      "referenceLabel": "Psalms 101:22",
      "text": "ut annuntient in Sion nomen Domini, et laudem ejus in Jerusalem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 23,
      "referenceLabel": "Psalms 101:23",
      "text": "in conveniendo populos in unum, et reges, ut serviant Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 24,
      "referenceLabel": "Psalms 101:24",
      "text": "Respondit ei in via virtutis suæ: Paucitatem dierum meorum nuntia mihi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 25,
      "referenceLabel": "Psalms 101:25",
      "text": "ne revoces me in dimidio dierum meorum, in generationem et generationem anni tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 26,
      "referenceLabel": "Psalms 101:26",
      "text": "Initio tu, Domine, terram fundasti, et opera manuum tuarum sunt cæli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 27,
      "referenceLabel": "Psalms 101:27",
      "text": "Ipsi peribunt, tu autem permanes; et omnes sicut vestimentum veterascent. Et sicut opertorium mutabis eos, et mutabuntur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 28,
      "referenceLabel": "Psalms 101:28",
      "text": "tu autem idem ipse es, et anni tui non deficient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.101.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 29,
      "referenceLabel": "Psalms 101:29",
      "text": "Filii servorum tuorum habitabunt, et semen eorum in sæculum dirigetur.",
      "paragraphStart": false
    }
  ]
}
