{
  "chapter": {
    "id": "vulgate:psalms.24",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.24.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "In finem. Psalmus David. Ad te, Domine, levavi animam meam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.24.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "Deus meus, in te confido; non erubescam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Neque irrideant me inimici mei: etenim universi qui sustinent te, non confundentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "Confundantur omnes iniqua agentes supervacue. Vias tuas, Domine, demonstra mihi, et semitas tuas edoce me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "Dirige me in veritate tua, et doce me, quia tu es Deus salvator meus, et te sustinui tota die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "Reminiscere miserationum tuarum, Domine, et misericordiarum tuarum quæ a sæculo sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Delicta juventutis meæ, et ignorantias meas, ne memineris. Secundum misericordiam tuam memento mei tu, propter bonitatem tuam, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Dulcis et rectus Dominus; propter hoc legem dabit delinquentibus in via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "Diriget mansuetos in judicio; docebit mites vias suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "Universæ viæ Domini, misericordia et veritas, requirentibus testamentum ejus et testimonia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Psalms 24:11",
      "text": "Propter nomen tuum, Domine, propitiaberis peccato meo; multum est enim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Psalms 24:12",
      "text": "Quis est homo qui timet Dominum? legem statuit ei in via quam elegit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Psalms 24:13",
      "text": "Anima ejus in bonis demorabitur, et semen ejus hæreditabit terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Psalms 24:14",
      "text": "Firmamentum est Dominus timentibus eum; et testamentum ipsius ut manifestetur illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Psalms 24:15",
      "text": "Oculi mei semper ad Dominum, quoniam ipse evellet de laqueo pedes meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Psalms 24:16",
      "text": "Respice in me, et miserere mei, quia unicus et pauper sum ego.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Psalms 24:17",
      "text": "Tribulationes cordis mei multiplicatæ sunt: de necessitatibus meis erue me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Psalms 24:18",
      "text": "Vide humilitatem meam et laborem meum, et dimitte universa delicta mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Psalms 24:19",
      "text": "Respice inimicos meos, quoniam multiplicati sunt, et odio iniquo oderunt me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Psalms 24:20",
      "text": "Custodi animam meam, et erue me: non erubescam, quoniam speravi in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Psalms 24:21",
      "text": "Innocentes et recti adhæserunt mihi, quia sustinui te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.24.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Psalms 24:22",
      "text": "Libera, Deus, Israël ex omnibus tribulationibus suis.",
      "paragraphStart": false
    }
  ]
}
