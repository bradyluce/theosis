{
  "chapter": {
    "id": "vulgate:psalms.64",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 64,
    "referenceLabel": "Psalms 64",
    "summary": "Source text for Psalms 64 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.64.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 1,
      "referenceLabel": "Psalms 64:1",
      "text": "In finem. Psalmus David, canticum Jeremiæ et Ezechielis populo transmigrationis, cum inciperent exire.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.64.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 2,
      "referenceLabel": "Psalms 64:2",
      "text": "Te decet hymnus, Deus, in Sion, et tibi reddetur votum in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 3,
      "referenceLabel": "Psalms 64:3",
      "text": "Exaudi orationem meam; ad te omnis caro veniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 4,
      "referenceLabel": "Psalms 64:4",
      "text": "Verba iniquorum prævaluerunt super nos, et impietatibus nostris tu propitiaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 5,
      "referenceLabel": "Psalms 64:5",
      "text": "Beatus quem elegisti et assumpsisti: inhabitabit in atriis tuis. Replebimur in bonis domus tuæ; sanctum est templum tuum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 6,
      "referenceLabel": "Psalms 64:6",
      "text": "mirabile in æquitate. Exaudi nos, Deus, salutaris noster, spes omnium finium terræ, et in mari longe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 7,
      "referenceLabel": "Psalms 64:7",
      "text": "Præparans montes in virtute tua, accinctus potentia;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 8,
      "referenceLabel": "Psalms 64:8",
      "text": "qui conturbas profundum maris, sonum fluctuum ejus. Turbabuntur gentes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 9,
      "referenceLabel": "Psalms 64:9",
      "text": "et timebunt qui habitant terminos a signis tuis; exitus matutini et vespere delectabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 10,
      "referenceLabel": "Psalms 64:10",
      "text": "Visitasti terram, et inebriasti eam; multiplicasti locupletare eam. Flumen Dei repletum est aquis; parasti cibum illorum: quoniam ita est præparatio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 11,
      "referenceLabel": "Psalms 64:11",
      "text": "Rivos ejus inebria; multiplica genimina ejus: in stillicidiis ejus lætabitur germinans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 12,
      "referenceLabel": "Psalms 64:12",
      "text": "Benedices coronæ anni benignitatis tuæ, et campi tui replebuntur ubertate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 13,
      "referenceLabel": "Psalms 64:13",
      "text": "Pinguescent speciosa deserti, et exsultatione colles accingentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.64.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 14,
      "referenceLabel": "Psalms 64:14",
      "text": "Induti sunt arietes ovium, et valles abundabunt frumento; clamabunt, etenim hymnum dicent.",
      "paragraphStart": false
    }
  ]
}
