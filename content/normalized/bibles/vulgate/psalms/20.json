{
  "chapter": {
    "id": "vulgate:psalms.20",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.20.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.20.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "Domine, in virtute tua lætabitur rex, et super salutare tuum exsultabit vehementer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "Desiderium cordis ejus tribuisti ei, et voluntate labiorum ejus non fraudasti eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "Quoniam prævenisti eum in benedictionibus dulcedinis; posuisti in capite ejus coronam de lapide pretioso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "Vitam petiit a te, et tribuisti ei longitudinem dierum, in sæculum, et in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "Magna est gloria ejus in salutari tuo; gloriam et magnum decorem impones super eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "Quoniam dabis eum in benedictionem in sæculum sæculi; lætificabis eum in gaudio cum vultu tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "Quoniam rex sperat in Domino, et in misericordia Altissimi non commovebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Inveniatur manus tua omnibus inimicis tuis; dextera tua inveniat omnes qui te oderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Psalms 20:10",
      "text": "Pones eos ut clibanum ignis in tempore vultus tui: Dominus in ira sua conturbabit eos, et devorabit eos ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Psalms 20:11",
      "text": "Fructum eorum de terra perdes, et semen eorum a filiis hominum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Psalms 20:12",
      "text": "quoniam declinaverunt in te mala; cogitaverunt consilia quæ non potuerunt stabilire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Psalms 20:13",
      "text": "Quoniam pones eos dorsum; in reliquiis tuis præparabis vultum eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.20.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Psalms 20:14",
      "text": "Exaltare, Domine, in virtute tua; cantabimus et psallemus virtutes tuas.",
      "paragraphStart": false
    }
  ]
}
