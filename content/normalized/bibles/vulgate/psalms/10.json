{
  "chapter": {
    "id": "vulgate:psalms.10",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 10,
    "referenceLabel": "Psalms 10",
    "summary": "Source text for Psalms 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.10.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Psalms 10:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.10.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Psalms 10:2",
      "text": "In Domino confido; quomodo dicitis animæ meæ: Transmigra in montem sicut passer?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.10.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Psalms 10:3",
      "text": "Quoniam ecce peccatores intenderunt arcum; paraverunt sagittas suas in pharetra, ut sagittent in obscuro rectos corde:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.10.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Psalms 10:4",
      "text": "quoniam quæ perfecisti destruxerunt; justus autem, quid fecit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.10.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Psalms 10:5",
      "text": "Dominus in templo sancto suo; Dominus in cælo sedes ejus. Oculi ejus in pauperem respiciunt; palpebræ ejus interrogant filios hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.10.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Psalms 10:6",
      "text": "Dominus interrogat justum et impium; qui autem diligit iniquitatem, odit animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.10.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Psalms 10:7",
      "text": "Pluet super peccatores laqueos; ignis et sulphur, et spiritus procellarum, pars calicis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.10.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Psalms 10:8",
      "text": "Quoniam justus Dominus, et justitias dilexit: æquitatem vidit vultus ejus.",
      "paragraphStart": false
    }
  ]
}
