{
  "chapter": {
    "id": "vulgate:psalms.69",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.69.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "In finem. Psalmus David in rememorationem, quod salvum fecerit eum Dominus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.69.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "Deus, in adjutorium meum intende; Domine, ad adjuvandum me festina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.69.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "Confundantur, et revereantur, qui quærunt animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.69.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "Avertantur retrorsum, et erubescant, qui volunt mihi mala; avertantur statim erubescentes qui dicunt mihi: Euge, euge!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.69.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "Exsultent et lætentur in te omnes qui quærunt te; et dicant semper: Magnificetur Dominus, qui diligunt salutare tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.69.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "Ego vero egenus et pauper sum; Deus, adjuva me. Adjutor meus et liberator meus es tu; Domine, ne moreris.",
      "paragraphStart": false
    }
  ]
}
