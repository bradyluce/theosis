{
  "chapter": {
    "id": "vulgate:psalms.86",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.86.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "Filiis Core. Psalmus cantici. Fundamenta ejus in montibus sanctis;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.86.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "diligit Dominus portas Sion super omnia tabernacula Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.86.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Gloriosa dicta sunt de te, civitas Dei!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.86.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "Memor ero Rahab et Babylonis, scientium me; ecce alienigenæ, et Tyrus, et populus Æthiopum, hi fuerunt illic.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.86.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "Numquid Sion dicet: Homo et homo natus est in ea, et ipse fundavit eam Altissimus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.86.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "Dominus narrabit in scripturis populorum et principum, horum qui fuerunt in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.86.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "Sicut lætantium omnium habitatio est in te.",
      "paragraphStart": false
    }
  ]
}
