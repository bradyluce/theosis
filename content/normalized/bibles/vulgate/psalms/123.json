{
  "chapter": {
    "id": "vulgate:psalms.123",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 123,
    "referenceLabel": "Psalms 123",
    "summary": "Source text for Psalms 123 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.123.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 1,
      "referenceLabel": "Psalms 123:1",
      "text": "Canticum graduum. Nisi quia Dominus erat in nobis, dicat nunc Israël,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.123.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 2,
      "referenceLabel": "Psalms 123:2",
      "text": "nisi quia Dominus erat in nobis: cum exsurgerent homines in nos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.123.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 3,
      "referenceLabel": "Psalms 123:3",
      "text": "forte vivos deglutissent nos; cum irasceretur furor eorum in nos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.123.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 4,
      "referenceLabel": "Psalms 123:4",
      "text": "forsitan aqua absorbuisset nos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.123.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 5,
      "referenceLabel": "Psalms 123:5",
      "text": "torrentem pertransivit anima nostra; forsitan pertransisset anima nostra aquam intolerabilem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.123.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 6,
      "referenceLabel": "Psalms 123:6",
      "text": "Benedictus Dominus, qui non dedit nos in captionem dentibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.123.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 7,
      "referenceLabel": "Psalms 123:7",
      "text": "Anima nostra sicut passer erepta est de laqueo venantium; laqueus contritus est, et nos liberati sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.123.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 8,
      "referenceLabel": "Psalms 123:8",
      "text": "Adjutorium nostrum in nomine Domini, qui fecit cælum et terram.",
      "paragraphStart": false
    }
  ]
}
