{
  "chapter": {
    "id": "vulgate:psalms.3",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.3.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "Psalmus David, cum fugeret a facie Absalom filii sui.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.3.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "Domine, quid multiplicati sunt qui tribulant me? Multi insurgunt adversum me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "multi dicunt animæ meæ: Non est salus ipsi in Deo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "Tu autem Domine, susceptor meus es, gloria mea, et exaltans caput meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "Voce mea ad Dominum clamavi; et exaudivit me de monte sancto suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "Ego dormivi, et soporatus sum; et exsurrexi, quia Dominus suscepit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "Non timebo millia populi circumdantis me. Exsurge, Domine; salvum me fac, Deus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Quoniam tu percussisti omnes adversantes mihi sine causa; dentes peccatorum contrivisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.3.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Psalms 3:9",
      "text": "Domini est salus; et super populum tuum benedictio tua.",
      "paragraphStart": false
    }
  ]
}
