{
  "chapter": {
    "id": "vulgate:psalms.91",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.91.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 1,
      "referenceLabel": "Psalms 91:1",
      "text": "Psalmus cantici, in die sabbati.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.91.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "Bonum est confiteri Domino, et psallere nomini tuo, Altissime:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "ad annuntiandum mane misericordiam tuam, et veritatem tuam per noctem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "in decachordo, psalterio; cum cantico, in cithara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "Quia delectasti me, Domine, in factura tua; et in operibus manuum tuarum exsultabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "Quam magnificata sunt opera tua, Domine! nimis profundæ factæ sunt cogitationes tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "Vir insipiens non cognoscet, et stultus non intelliget hæc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "Cum exorti fuerint peccatores sicut fœnum, et apparuerint omnes qui operantur iniquitatem, ut intereant in sæculum sæculi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "tu autem Altissimus in æternum, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "Quoniam ecce inimici tui, Domine, quoniam ecce inimici tui peribunt; et dispergentur omnes qui operantur iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "Et exaltabitur sicut unicornis cornu meum, et senectus mea in misericordia uberi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "Et despexit oculus meus inimicos meos, et in insurgentibus in me malignantibus audiet auris mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "Justus ut palma florebit; sicut cedrus Libani multiplicabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "Plantati in domo Domini, in atriis domus Dei nostri florebunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "Adhuc multiplicabuntur in senecta uberi, et bene patientes erunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.91.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "ut annuntient quoniam rectus Dominus Deus noster, et non est iniquitas in eo.",
      "paragraphStart": false
    }
  ]
}
