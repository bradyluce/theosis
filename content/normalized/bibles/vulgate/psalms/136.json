{
  "chapter": {
    "id": "vulgate:psalms.136",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.136.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "Psalmus David, Jeremiæ. Super flumina Babylonis illic sedimus et flevimus, cum recordaremur Sion.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.136.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "In salicibus in medio ejus suspendimus organa nostra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "quia illic interrogaverunt nos, qui captivos duxerunt nos, verba cantionum; et qui abduxerunt nos: Hymnum cantate nobis de canticis Sion.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "Quomodo cantabimus canticum Domini in terra aliena?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "Si oblitus fuero tui, Jerusalem, oblivioni detur dextera mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "Adhæreat lingua mea faucibus meis, si non meminero tui; si non proposuero Jerusalem in principio lætitiæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "Memor esto, Domine, filiorum Edom, in die Jerusalem: qui dicunt: Exinanite, exinanite usque ad fundamentum in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "Filia Babylonis misera! beatus qui retribuet tibi retributionem tuam quam retribuisti nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.136.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "Beatus qui tenebit, et allidet parvulos tuos ad petram.",
      "paragraphStart": false
    }
  ]
}
