{
  "chapter": {
    "id": "vulgate:psalms.111",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.111.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Alleluja, reversionis Aggæi et Zachariæ. Beatus vir qui timet Dominum: in mandatis ejus volet nimis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.111.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "Potens in terra erit semen ejus; generatio rectorum benedicetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "Gloria et divitiæ in domo ejus, et justitia ejus manet in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "Exortum est in tenebris lumen rectis: misericors, et miserator, et justus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "Jucundus homo qui miseretur et commodat; disponet sermones suos in judicio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "quia in æternum non commovebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "In memoria æterna erit justus; ab auditione mala non timebit. Paratum cor ejus sperare in Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "confirmatum est cor ejus; non commovebitur donec despiciat inimicos suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "Dispersit, dedit pauperibus; justitia ejus manet in sæculum sæculi: cornu ejus exaltabitur in gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.111.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "Peccator videbit, et irascetur; dentibus suis fremet et tabescet: desiderium peccatorum peribit.",
      "paragraphStart": false
    }
  ]
}
