{
  "chapter": {
    "id": "vulgate:psalms.66",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.66.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "In finem, in hymnis. Psalmus cantici David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.66.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "Deus misereatur nostri, et benedicat nobis; illuminet vultum suum super nos, et misereatur nostri:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.66.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "ut cognoscamus in terra viam tuam, in omnibus gentibus salutare tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.66.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "Confiteantur tibi populi, Deus: confiteantur tibi populi omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.66.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Lætentur et exsultent gentes, quoniam judicas populos in æquitate, et gentes in terra dirigis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.66.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "Confiteantur tibi populi, Deus: confiteantur tibi populi omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.66.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "Terra dedit fructum suum: benedicat nos Deus, Deus noster!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.66.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "Benedicat nos Deus, et metuant eum omnes fines terræ.",
      "paragraphStart": false
    }
  ]
}
