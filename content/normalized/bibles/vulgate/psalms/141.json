{
  "chapter": {
    "id": "vulgate:psalms.141",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 141,
    "referenceLabel": "Psalms 141",
    "summary": "Source text for Psalms 141 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.141.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 1,
      "referenceLabel": "Psalms 141:1",
      "text": "Intellectus David, cum esset in spelunca, oratio.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.141.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 2,
      "referenceLabel": "Psalms 141:2",
      "text": "Voce mea ad Dominum clamavi, voce mea ad Dominum deprecatus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.141.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 3,
      "referenceLabel": "Psalms 141:3",
      "text": "Effundo in conspectu ejus orationem meam, et tribulationem meam ante ipsum pronuntio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.141.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 4,
      "referenceLabel": "Psalms 141:4",
      "text": "in deficiendo ex me spiritum meum, et tu cognovisti semitas meas. In via hac qua ambulabam absconderunt laqueum mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.141.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 5,
      "referenceLabel": "Psalms 141:5",
      "text": "Considerabam ad dexteram, et videbam, et non erat qui cognosceret me: periit fuga a me, et non est qui requirat animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.141.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 6,
      "referenceLabel": "Psalms 141:6",
      "text": "Clamavi ad te, Domine; dixi: Tu es spes mea, portio mea in terra viventium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.141.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 7,
      "referenceLabel": "Psalms 141:7",
      "text": "Intende ad deprecationem meam, quia humiliatus sum nimis. Libera me a persequentibus me, quia confortati sunt super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.141.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 141,
      "verseNumber": 8,
      "referenceLabel": "Psalms 141:8",
      "text": "Educ de custodia animam meam ad confitendum nomini tuo; me exspectant justi donec retribuas mihi.",
      "paragraphStart": false
    }
  ]
}
