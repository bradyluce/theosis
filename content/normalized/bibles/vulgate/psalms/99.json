  "verses": [
    {
      "id": "vulgate:psalms.99.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "Psalmus in confessione.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.99.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "Jubilate Deo, omnis terra; servite Domino in lætitia. Introite in conspectu ejus in exsultatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.99.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Scitote quoniam Dominus ipse est Deus; ipse fecit nos, et non ipsi nos: populus ejus, et oves pascuæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.99.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "Introite portas ejus in confessione; atria ejus in hymnis: confitemini illi. Laudate nomen ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.99.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "quoniam suavis est Dominus, in æternum misericordia ejus, et usque in generationem et generationem veritas ejus.",
      "paragraphStart": false
    }
  ]
}
