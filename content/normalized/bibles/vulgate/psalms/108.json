{
  "chapter": {
    "id": "vulgate:psalms.108",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.108.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.108.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "Deus, laudem meam ne tacueris, quia os peccatoris et os dolosi super me apertum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "Locuti sunt adversum me lingua dolosa, et sermonibus odii circumdederunt me: et expugnaverunt me gratis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "Pro eo ut me diligerent, detrahebant mihi; ego autem orabam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "Et posuerunt adversum me mala pro bonis, et odium pro dilectione mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "Constitue super eum peccatorem, et diabolus stet a dextris ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "Cum judicatur, exeat condemnatus; et oratio ejus fiat in peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "Fiant dies ejus pauci, et episcopatum ejus accipiat alter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "Fiant filii ejus orphani, et uxor ejus vidua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Nutantes transferantur filii ejus et mendicent, et ejiciantur de habitationibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "Scrutetur fœnerator omnem substantiam ejus, et diripiant alieni labores ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "Non sit illi adjutor, nec sit qui misereatur pupillis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "Fiant nati ejus in interitum; in generatione una deleatur nomen ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 14,
      "referenceLabel": "Psalms 108:14",
      "text": "In memoriam redeat iniquitas patrum ejus in conspectu Domini, et peccatum matris ejus non deleatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 15,
      "referenceLabel": "Psalms 108:15",
      "text": "Fiant contra Dominum semper, et dispereat de terra memoria eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 16,
      "referenceLabel": "Psalms 108:16",
      "text": "pro eo quod non est recordatus facere misericordiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 17,
      "referenceLabel": "Psalms 108:17",
      "text": "et persecutus est hominem inopem et mendicum, et compunctum corde, mortificare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 18,
      "referenceLabel": "Psalms 108:18",
      "text": "Et dilexit maledictionem, et veniet ei; et noluit benedictionem, et elongabitur ab eo. Et induit maledictionem sicut vestimentum; et intravit sicut aqua in interiora ejus, et sicut oleum in ossibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 19,
      "referenceLabel": "Psalms 108:19",
      "text": "Fiat ei sicut vestimentum quo operitur, et sicut zona qua semper præcingitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 20,
      "referenceLabel": "Psalms 108:20",
      "text": "Hoc opus eorum qui detrahunt mihi apud Dominum, et qui loquuntur mala adversus animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 21,
      "referenceLabel": "Psalms 108:21",
      "text": "Et tu, Domine, Domine, fac mecum propter nomen tuum, quia suavis est misericordia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 22,
      "referenceLabel": "Psalms 108:22",
      "text": "Libera me, quia egenus et pauper ego sum, et cor meum conturbatum est intra me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 23,
      "referenceLabel": "Psalms 108:23",
      "text": "Sicut umbra cum declinat ablatus sum, et excussus sum sicut locustæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 24,
      "referenceLabel": "Psalms 108:24",
      "text": "Genua mea infirmata sunt a jejunio, et caro mea immutata est propter oleum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 25,
      "referenceLabel": "Psalms 108:25",
      "text": "Et ego factus sum opprobrium illis; viderunt me, et moverunt capita sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 26,
      "referenceLabel": "Psalms 108:26",
      "text": "Adjuva me, Domine Deus meus; salvum me fac secundum misericordiam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 27,
      "referenceLabel": "Psalms 108:27",
      "text": "Et sciant quia manus tua hæc, et tu, Domine, fecisti eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 28,
      "referenceLabel": "Psalms 108:28",
      "text": "Maledicent illi, et tu benedices: qui insurgunt in me confundantur; servus autem tuus lætabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 29,
      "referenceLabel": "Psalms 108:29",
      "text": "Induantur qui detrahunt mihi pudore, et operiantur sicut diploide confusione sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 30,
      "referenceLabel": "Psalms 108:30",
      "text": "Confitebor Domino nimis in ore meo, et in medio multorum laudabo eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.108.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 31,
      "referenceLabel": "Psalms 108:31",
      "text": "quia astitit a dextris pauperis, ut salvam faceret a persequentibus animam meam.",
      "paragraphStart": false
    }
  ]
}
