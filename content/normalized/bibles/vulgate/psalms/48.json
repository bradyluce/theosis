{
  "chapter": {
    "id": "vulgate:psalms.48",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 48,
    "referenceLabel": "Psalms 48",
    "summary": "Source text for Psalms 48 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.48.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Psalms 48:1",
      "text": "In finem, filiis Core. Psalmus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.48.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Psalms 48:2",
      "text": "Audite hæc, omnes gentes; auribus percipite, omnes qui habitatis orbem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Psalms 48:3",
      "text": "quique terrigenæ et filii hominum, simul in unum dives et pauper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Psalms 48:4",
      "text": "Os meum loquetur sapientiam, et meditatio cordis mei prudentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Psalms 48:5",
      "text": "Inclinabo in parabolam aurem meam; aperiam in psalterio propositionem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Psalms 48:6",
      "text": "Cur timebo in die mala? iniquitas calcanei mei circumdabit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Psalms 48:7",
      "text": "Qui confidunt in virtute sua, et in multitudine divitiarum suarum, gloriantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Psalms 48:8",
      "text": "Frater non redimit, redimet homo: non dabit Deo placationem suam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Psalms 48:9",
      "text": "et pretium redemptionis animæ suæ. Et laborabit in æternum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Psalms 48:10",
      "text": "et vivet adhuc in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Psalms 48:11",
      "text": "Non videbit interitum, cum viderit sapientes morientes: simul insipiens et stultus peribunt. Et relinquent alienis divitias suas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Psalms 48:12",
      "text": "et sepulchra eorum domus illorum in æternum; tabernacula eorum in progenie et progenie: vocaverunt nomina sua in terris suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Psalms 48:13",
      "text": "Et homo, cum in honore esset, non intellexit. Comparatus est jumentis insipientibus, et similis factus est illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Psalms 48:14",
      "text": "Hæc via illorum scandalum ipsis; et postea in ore suo complacebunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 15,
      "referenceLabel": "Psalms 48:15",
      "text": "Sicut oves in inferno positi sunt: mors depascet eos. Et dominabuntur eorum justi in matutino; et auxilium eorum veterascet in inferno a gloria eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 16,
      "referenceLabel": "Psalms 48:16",
      "text": "Verumtamen Deus redimet animam meam de manu inferi, cum acceperit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 17,
      "referenceLabel": "Psalms 48:17",
      "text": "Ne timueris cum dives factus fuerit homo, et cum multiplicata fuerit gloria domus ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 18,
      "referenceLabel": "Psalms 48:18",
      "text": "quoniam, cum interierit, non sumet omnia, neque descendet cum eo gloria ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 19,
      "referenceLabel": "Psalms 48:19",
      "text": "Quia anima ejus in vita ipsius benedicetur; confitebitur tibi cum benefeceris ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 20,
      "referenceLabel": "Psalms 48:20",
      "text": "Introibit usque in progenies patrum suorum; et usque in æternum non videbit lumen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.48.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 21,
      "referenceLabel": "Psalms 48:21",
      "text": "Homo, cum in honore esset, non intellexit. Comparatus est jumentis insipientibus, et similis factus est illis.",
      "paragraphStart": false
    }
  ]
}
