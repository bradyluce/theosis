{
  "chapter": {
    "id": "vulgate:psalms.16",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 16,
    "referenceLabel": "Psalms 16",
    "summary": "Source text for Psalms 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.16.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Psalms 16:1",
      "text": "Oratio David. Exaudi, Domine, justitiam meam; intende deprecationem meam. Auribus percipe orationem meam, non in labiis dolosis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.16.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Psalms 16:2",
      "text": "De vultu tuo judicium meum prodeat; oculi tui videant æquitates.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Psalms 16:3",
      "text": "Probasti cor meum, et visitasti nocte; igne me examinasti, et non est inventa in me iniquitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Psalms 16:4",
      "text": "Ut non loquatur os meum opera hominum: propter verba labiorum tuorum, ego custodivi vias duras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Psalms 16:5",
      "text": "Perfice gressus meos in semitis tuis, ut non moveantur vestigia mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Psalms 16:6",
      "text": "Ego clamavi, quoniam exaudisti me, Deus; inclina aurem tuam mihi, et exaudi verba mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Psalms 16:7",
      "text": "Mirifica misericordias tuas, qui salvos facis sperantes in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Psalms 16:8",
      "text": "A resistentibus dexteræ tuæ custodi me ut pupillam oculi. Sub umbra alarum tuarum protege me",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Psalms 16:9",
      "text": "a facie impiorum qui me afflixerunt. Inimici mei animam meam circumdederunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Psalms 16:10",
      "text": "adipem suum concluserunt: os eorum locutum est superbiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Psalms 16:11",
      "text": "Projicientes me nunc circumdederunt me; oculos suos statuerunt declinare in terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Psalms 16:12",
      "text": "Susceperunt me sicut leo paratus ad prædam, et sicut catulus leonis habitans in abditis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Psalms 16:13",
      "text": "Exsurge, Domine: præveni eum, et supplanta eum: eripe animam meam ab impio; frameam tuam",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Psalms 16:14",
      "text": "ab inimicis manus tuæ. Domine, a paucis de terra divide eos in vita eorum; de absconditis tuis adimpletus est venter eorum. Saturati sunt filiis, et dimiserunt reliquias suas parvulis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.16.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Psalms 16:15",
      "text": "Ego autem in justitia apparebo conspectui tuo; satiabor cum apparuerit gloria tua.",
      "paragraphStart": false
    }
  ]
}
