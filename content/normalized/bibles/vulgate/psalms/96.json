{
  "chapter": {
    "id": "vulgate:psalms.96",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.96.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "Huic David, quando terra ejus restituta est. Dominus regnavit: exsultet terra; lætentur insulæ multæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.96.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Nubes et caligo in circuitu ejus; justitia et judicium correctio sedis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "Ignis ante ipsum præcedet, et inflammabit in circuitu inimicos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "Illuxerunt fulgura ejus orbi terræ; vidit, et commota est terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "Montes sicut cera fluxerunt a facie Domini; a facie Domini omnis terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "Annuntiaverunt cæli justitiam ejus, et viderunt omnes populi gloriam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Confundantur omnes qui adorant sculptilia, et qui gloriantur in simulacris suis. Adorate eum omnes angeli ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Audivit, et lætata est Sion, et exsultaverunt filiæ Judæ propter judicia tua, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "Quoniam tu Dominus altissimus super omnem terram; nimis exaltatus es super omnes deos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "Qui diligitis Dominum, odite malum: custodit Dominus animas sanctorum suorum; de manu peccatoris liberabit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Lux orta est justo, et rectis corde lætitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.96.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "Lætamini, justi, in Domino, et confitemini memoriæ sanctificationis ejus.",
      "paragraphStart": false
    }
  ]
}
