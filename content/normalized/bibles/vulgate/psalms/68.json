{
  "chapter": {
    "id": "vulgate:psalms.68",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 68,
    "referenceLabel": "Psalms 68",
    "summary": "Source text for Psalms 68 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.68.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 1,
      "referenceLabel": "Psalms 68:1",
      "text": "In finem, pro iis qui commutabuntur. David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.68.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 2,
      "referenceLabel": "Psalms 68:2",
      "text": "Salvum me fac, Deus, quoniam intraverunt aquæ usque ad animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 3,
      "referenceLabel": "Psalms 68:3",
      "text": "Infixus sum in limo profundi et non est substantia. Veni in altitudinem maris, et tempestas demersit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 4,
      "referenceLabel": "Psalms 68:4",
      "text": "Laboravi clamans, raucæ factæ sunt fauces meæ; defecerunt oculi mei, dum spero in Deum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 5,
      "referenceLabel": "Psalms 68:5",
      "text": "Multiplicati sunt super capillos capitis mei qui oderunt me gratis. Confortati sunt qui persecuti sunt me inimici mei injuste; quæ non rapui, tunc exsolvebam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 6,
      "referenceLabel": "Psalms 68:6",
      "text": "Deus, tu scis insipientiam meam; et delicta mea a te non sunt abscondita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 7,
      "referenceLabel": "Psalms 68:7",
      "text": "Non erubescant in me qui exspectant te, Domine, Domine virtutum; non confundantur super me qui quærunt te, Deus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 8,
      "referenceLabel": "Psalms 68:8",
      "text": "Quoniam propter te sustinui opprobrium; operuit confusio faciem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 9,
      "referenceLabel": "Psalms 68:9",
      "text": "Extraneus factus sum fratribus meis, et peregrinus filiis matris meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 10,
      "referenceLabel": "Psalms 68:10",
      "text": "Quoniam zelus domus tuæ comedit me, et opprobria exprobrantium tibi ceciderunt super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 11,
      "referenceLabel": "Psalms 68:11",
      "text": "Et operui in jejunio animam meam, et factum est in opprobrium mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 12,
      "referenceLabel": "Psalms 68:12",
      "text": "Et posui vestimentum meum cilicium; et factus sum illis in parabolam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 13,
      "referenceLabel": "Psalms 68:13",
      "text": "Adversum me loquebantur qui sedebant in porta, et in me psallebant qui bibebant vinum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 14,
      "referenceLabel": "Psalms 68:14",
      "text": "Ego vero orationem meam ad te, Domine; tempus beneplaciti, Deus. In multitudine misericordiæ tuæ, exaudi me in veritate salutis tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 15,
      "referenceLabel": "Psalms 68:15",
      "text": "Eripe me de luto, ut non infigar; libera me ab iis qui oderunt me, et de profundis aquarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 16,
      "referenceLabel": "Psalms 68:16",
      "text": "Non me demergat tempestas aquæ, neque absorbeat me profundum, neque urgeat super me puteus os suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 17,
      "referenceLabel": "Psalms 68:17",
      "text": "Exaudi me, Domine, quoniam benigna est misericordia tua; secundum multitudinem miserationum tuarum respice in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 18,
      "referenceLabel": "Psalms 68:18",
      "text": "Et ne avertas faciem tuam a puero tuo; quoniam tribulor, velociter exaudi me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 19,
      "referenceLabel": "Psalms 68:19",
      "text": "Intende animæ meæ, et libera eam; propter inimicos meos, eripe me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 20,
      "referenceLabel": "Psalms 68:20",
      "text": "Tu scis improperium meum, et confusionem meam, et reverentiam meam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 21,
      "referenceLabel": "Psalms 68:21",
      "text": "in conspectu tuo sunt omnes qui tribulant me. Improperium exspectavit cor meum et miseriam: et sustinui qui simul contristaretur, et non fuit; et qui consolaretur, et non inveni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 22,
      "referenceLabel": "Psalms 68:22",
      "text": "Et dederunt in escam meam fel, et in siti mea potaverunt me aceto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 23,
      "referenceLabel": "Psalms 68:23",
      "text": "Fiat mensa eorum coram ipsis in laqueum, et in retributiones, et in scandalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 24,
      "referenceLabel": "Psalms 68:24",
      "text": "Obscurentur oculi eorum, ne videant, et dorsum eorum semper incurva.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 25,
      "referenceLabel": "Psalms 68:25",
      "text": "Effunde super eos iram tuam, et furor iræ tuæ comprehendat eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 26,
      "referenceLabel": "Psalms 68:26",
      "text": "Fiat habitatio eorum deserta, et in tabernaculis eorum non sit qui inhabitet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 27,
      "referenceLabel": "Psalms 68:27",
      "text": "Quoniam quem tu percussisti persecuti sunt, et super dolorem vulnerum meorum addiderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 28,
      "referenceLabel": "Psalms 68:28",
      "text": "Appone iniquitatem super iniquitatem eorum, et non intrent in justitiam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 29,
      "referenceLabel": "Psalms 68:29",
      "text": "Deleantur de libro viventium, et cum justis non scribantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 30,
      "referenceLabel": "Psalms 68:30",
      "text": "Ego sum pauper et dolens; salus tua, Deus, suscepit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 31,
      "referenceLabel": "Psalms 68:31",
      "text": "Laudabo nomen Dei cum cantico, et magnificabo eum in laude:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 32,
      "referenceLabel": "Psalms 68:32",
      "text": "et placebit Deo super vitulum novellum, cornua producentem et ungulas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 33,
      "referenceLabel": "Psalms 68:33",
      "text": "Videant pauperes, et lætentur; quærite Deum, et vivet anima vestra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 34,
      "referenceLabel": "Psalms 68:34",
      "text": "quoniam exaudivit pauperes Dominus, et vinctos suos non despexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 35,
      "referenceLabel": "Psalms 68:35",
      "text": "Laudent illum cæli et terra; mare, et omnia reptilia in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 36,
      "referenceLabel": "Psalms 68:36",
      "text": "Quoniam Deus salvam faciet Sion, et ædificabuntur civitates Juda, et inhabitabunt ibi, et hæreditate acquirent eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.68.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 37,
      "referenceLabel": "Psalms 68:37",
      "text": "Et semen servorum ejus possidebit eam; et qui diligunt nomen ejus habitabunt in ea.",
      "paragraphStart": false
    }
  ]
}
