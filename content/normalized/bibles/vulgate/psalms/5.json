{
  "chapter": {
    "id": "vulgate:psalms.5",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 5,
    "referenceLabel": "Psalms 5",
    "summary": "Source text for Psalms 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.5.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Psalms 5:1",
      "text": "In finem, pro ea quæ hæreditatem consequitur. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.5.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Psalms 5:2",
      "text": "Verba mea auribus percipe, Domine; intellige clamorem meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Psalms 5:3",
      "text": "Intende voci orationis meæ, rex meus et Deus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Psalms 5:4",
      "text": "Quoniam ad te orabo, Domine: mane exaudies vocem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Psalms 5:5",
      "text": "Mane astabo tibi, et videbo quoniam non Deus volens iniquitatem tu es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Psalms 5:6",
      "text": "Neque habitabit juxta te malignus, neque permanebunt injusti ante oculos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Psalms 5:7",
      "text": "Odisti omnes qui operantur iniquitatem; perdes omnes qui loquuntur mendacium. Virum sanguinum et dolosum abominabitur Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Psalms 5:8",
      "text": "Ego autem in multitudine misericordiæ tuæ introibo in domum tuam; adorabo ad templum sanctum tuum in timore tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Psalms 5:9",
      "text": "Domine, deduc me in justitia tua: propter inimicos meos dirige in conspectu tuo viam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Psalms 5:10",
      "text": "Quoniam non est in ore eorum veritas; cor eorum vanum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Psalms 5:11",
      "text": "Sepulchrum patens est guttur eorum; linguis suis dolose agebant: judica illos, Deus. Decidant a cogitationibus suis; secundum multitudinem impietatum eorum expelle eos, quoniam irritaverunt te, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Psalms 5:12",
      "text": "Et lætentur omnes qui sperant in te; in æternum exsultabunt, et habitabis in eis. Et gloriabuntur in te omnes qui diligunt nomen tuum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.5.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Psalms 5:13",
      "text": "quoniam tu benedices justo. Domine, ut scuto bonæ voluntatis tuæ coronasti nos.",
      "paragraphStart": false
    }
  ]
}
