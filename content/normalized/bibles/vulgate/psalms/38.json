{
  "chapter": {
    "id": "vulgate:psalms.38",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 38,
    "referenceLabel": "Psalms 38",
    "summary": "Source text for Psalms 38 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.38.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Psalms 38:1",
      "text": "In finem, ipsi Idithun. Canticum David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.38.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Psalms 38:2",
      "text": "Dixi: Custodiam vias meas: ut non delinquam in lingua mea. Posui ori meo custodiam, cum consisteret peccator adversum me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Psalms 38:3",
      "text": "Obmutui, et humiliatus sum, et silui a bonis; et dolor meus renovatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Psalms 38:4",
      "text": "Concaluit cor meum intra me; et in meditatione mea exardescet ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Psalms 38:5",
      "text": "Locutus sum in lingua mea: Notum fac mihi, Domine, finem meum, et numerum dierum meorum quis est, ut sciam quid desit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Psalms 38:6",
      "text": "Ecce mensurabiles posuisti dies meos, et substantia mea tamquam nihilum ante te. Verumtamen universa vanitas, omnis homo vivens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Psalms 38:7",
      "text": "Verumtamen in imagine pertransit homo; sed et frustra conturbatur: thesaurizat, et ignorat cui congregabit ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Psalms 38:8",
      "text": "Et nunc quæ est exspectatio mea: nonne Dominus? et substantia mea apud te est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Psalms 38:9",
      "text": "Ab omnibus iniquitatibus meis erue me: opprobrium insipienti dedisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Psalms 38:10",
      "text": "Obmutui, et non aperui os meum, quoniam tu fecisti;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Psalms 38:11",
      "text": "amove a me plagas tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Psalms 38:12",
      "text": "A fortitudine manus tuæ ego defeci in increpationibus: propter iniquitatem corripuisti hominem. Et tabescere fecisti sicut araneam animam ejus: verumtamen vane conturbatur omnis homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Psalms 38:13",
      "text": "Exaudi orationem meam, Domine, et deprecationem meam; auribus percipe lacrimas meas. Ne sileas, quoniam advena ego sum apud te, et peregrinus sicut omnes patres mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.38.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Psalms 38:14",
      "text": "Remitte mihi, ut refrigerer priusquam abeam et amplius non ero.",
      "paragraphStart": false
    }
  ]
}
