{
  "chapter": {
    "id": "vulgate:psalms.82",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.82.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "Canticum Psalmi Asaph.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.82.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "Deus, quis similis erit tibi? ne taceas, neque compescaris, Deus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "quoniam ecce inimici tui sonuerunt, et qui oderunt te extulerunt caput.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Super populum tuum malignaverunt consilium, et cogitaverunt adversus sanctos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "Dixerunt: Venite, et disperdamus eos de gente, et non memoretur nomen Israël ultra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "Quoniam cogitaverunt unanimiter; simul adversum te testamentum disposuerunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "tabernacula Idumæorum et Ismahelitæ, Moab et Agareni,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Gebal, et Ammon, et Amalec; alienigenæ cum habitantibus Tyrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 9,
      "referenceLabel": "Psalms 82:9",
      "text": "Etenim Assur venit cum illis: facti sunt in adjutorium filiis Lot.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 10,
      "referenceLabel": "Psalms 82:10",
      "text": "Fac illis sicut Madian et Sisaræ, sicut Jabin in torrente Cisson.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 11,
      "referenceLabel": "Psalms 82:11",
      "text": "Disperierunt in Endor; facti sunt ut stercus terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 12,
      "referenceLabel": "Psalms 82:12",
      "text": "Pone principes eorum sicut Oreb, et Zeb, et Zebee, et Salmana: omnes principes eorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 13,
      "referenceLabel": "Psalms 82:13",
      "text": "qui dixerunt: Hæreditate possideamus sanctuarium Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 14,
      "referenceLabel": "Psalms 82:14",
      "text": "Deus meus, pone illos ut rotam, et sicut stipulam ante faciem venti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 15,
      "referenceLabel": "Psalms 82:15",
      "text": "Sicut ignis qui comburit silvam, et sicut flamma comburens montes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 16,
      "referenceLabel": "Psalms 82:16",
      "text": "ita persequeris illos in tempestate tua, et in ira tua turbabis eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 17,
      "referenceLabel": "Psalms 82:17",
      "text": "Imple facies eorum ignominia, et quærent nomen tuum, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 18,
      "referenceLabel": "Psalms 82:18",
      "text": "Erubescant, et conturbentur in sæculum sæculi, et confundantur, et pereant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.82.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 19,
      "referenceLabel": "Psalms 82:19",
      "text": "Et cognoscant quia nomen tibi Dominus: tu solus Altissimus in omni terra.",
      "paragraphStart": false
    }
  ]
}
