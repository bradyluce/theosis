{
  "chapter": {
    "id": "vulgate:psalms.40",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 40,
    "referenceLabel": "Psalms 40",
    "summary": "Source text for Psalms 40 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.40.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Psalms 40:1",
      "text": "In finem. Psalmus ipsi David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.40.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Psalms 40:2",
      "text": "Beatus qui intelligit super egenum et pauperem: in die mala liberabit eum Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Psalms 40:3",
      "text": "Dominus conservet eum, et vivificet eum, et beatum faciat eum in terra, et non tradat eum in animam inimicorum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Psalms 40:4",
      "text": "Dominus opem ferat illi super lectum doloris ejus; universum stratum ejus versasti in infirmitate ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Psalms 40:5",
      "text": "Ego dixi: Domine, miserere mei; sana animam meam, quia peccavi tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Psalms 40:6",
      "text": "Inimici mei dixerunt mala mihi: Quando morietur, et peribit nomen ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Psalms 40:7",
      "text": "Et si ingrediebatur ut videret, vana loquebatur; cor ejus congregavit iniquitatem sibi. Egrediebatur foras et loquebatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Psalms 40:8",
      "text": "In idipsum adversum me susurrabant omnes inimici mei; adversum me cogitabant mala mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Psalms 40:9",
      "text": "Verbum iniquum constituerunt adversum me: Numquid qui dormit non adjiciet ut resurgat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Psalms 40:10",
      "text": "Etenim homo pacis meæ in quo speravi, qui edebat panes meos, magnificavit super me supplantationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Psalms 40:11",
      "text": "Tu autem, Domine, miserere mei, et resuscita me; et retribuam eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Psalms 40:12",
      "text": "In hoc cognovi quoniam voluisti me, quoniam non gaudebit inimicus meus super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Psalms 40:13",
      "text": "Me autem propter innocentiam suscepisti; et confirmasti me in conspectu tuo in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.40.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Psalms 40:14",
      "text": "Benedictus Dominus Deus Israël a sæculo et usque in sæculum. Fiat, fiat.",
      "paragraphStart": false
    }
  ]
}
