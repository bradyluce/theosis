{
  "chapter": {
    "id": "vulgate:psalms.12",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 12,
    "referenceLabel": "Psalms 12",
    "summary": "Source text for Psalms 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.12.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Psalms 12:1",
      "text": "In finem. Psalmus David. Usquequo, Domine, oblivisceris me in finem? usquequo avertis faciem tuam a me?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.12.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Psalms 12:2",
      "text": "quamdiu ponam consilia in anima mea; dolorem in corde meo per diem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.12.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Psalms 12:3",
      "text": "usquequo exaltabitur inimicus meus super me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.12.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Psalms 12:4",
      "text": "Respice, et exaudi me, Domine Deus meus. Illumina oculos meos, ne umquam obdormiam in morte;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.12.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Psalms 12:5",
      "text": "nequando dicat inimicus meus: Prævalui adversus eum. Qui tribulant me exsultabunt si motus fuero;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.12.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Psalms 12:6",
      "text": "ego autem in misericordia tua speravi. Exsultabit cor meum in salutari tuo. Cantabo Domino qui bona tribuit mihi; et psallam nomini Domini altissimi.",
      "paragraphStart": false
    }
  ]
}
