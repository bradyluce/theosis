{
  "chapter": {
    "id": "vulgate:psalms.74",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.74.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "In finem, ne corrumpas. Psalmus cantici Asaph.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.74.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "Confitebimur tibi, Deus, confitebimur, et invocabimus nomen tuum; narrabimus mirabilia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "Cum accepero tempus, ego justitias judicabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "Liquefacta est terra et omnes qui habitant in ea: ego confirmavi columnas ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "Dixi iniquis: Nolite inique agere: et delinquentibus: Nolite exaltare cornu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "nolite extollere in altum cornu vestrum; nolite loqui adversus Deum iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "Quia neque ab oriente, neque ab occidente, neque a desertis montibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "quoniam Deus judex est. Hunc humiliat, et hunc exaltat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "quia calix in manu Domini vini meri, plenus misto. Et inclinavit ex hoc in hoc; verumtamen fæx ejus non est exinanita: bibent omnes peccatores terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "Ego autem annuntiabo in sæculum; cantabo Deo Jacob:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.74.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 11,
      "referenceLabel": "Psalms 74:11",
      "text": "et omnia cornua peccatorum confringam, et exaltabuntur cornua justi.",
      "paragraphStart": false
    }
  ]
}
