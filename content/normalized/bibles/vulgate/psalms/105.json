{
  "chapter": {
    "id": "vulgate:psalms.105",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 105,
    "referenceLabel": "Psalms 105",
    "summary": "Source text for Psalms 105 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.105.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 1,
      "referenceLabel": "Psalms 105:1",
      "text": "Alleluja. Confitemini Domino, quoniam bonus, quoniam in sæculum misericordia ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.105.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 2,
      "referenceLabel": "Psalms 105:2",
      "text": "Quis loquetur potentias Domini; auditas faciet omnes laudes ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 3,
      "referenceLabel": "Psalms 105:3",
      "text": "Beati qui custodiunt judicium, et faciunt justitiam in omni tempore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 4,
      "referenceLabel": "Psalms 105:4",
      "text": "Memento nostri, Domine, in beneplacito populi tui; visita nos in salutari tuo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 5,
      "referenceLabel": "Psalms 105:5",
      "text": "ad videndum in bonitate electorum tuorum; ad lætandum in lætitia gentis tuæ: ut lauderis cum hæreditate tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 6,
      "referenceLabel": "Psalms 105:6",
      "text": "Peccavimus cum patribus nostris: injuste egimus; iniquitatem fecimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 7,
      "referenceLabel": "Psalms 105:7",
      "text": "Patres nostri in Ægypto non intellexerunt mirabilia tua; non fuerunt memores multitudinis misericordiæ tuæ. Et irritaverunt ascendentes in mare, mare Rubrum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 8,
      "referenceLabel": "Psalms 105:8",
      "text": "et salvavit eos propter nomen suum, ut notam faceret potentiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 9,
      "referenceLabel": "Psalms 105:9",
      "text": "Et increpuit mare Rubrum et exsiccatum est, et deduxit eos in abyssis sicut in deserto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 10,
      "referenceLabel": "Psalms 105:10",
      "text": "Et salvavit eos de manu odientium, et redemit eos de manu inimici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 11,
      "referenceLabel": "Psalms 105:11",
      "text": "Et operuit aqua tribulantes eos; unus ex eis non remansit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 12,
      "referenceLabel": "Psalms 105:12",
      "text": "Et crediderunt verbis ejus, et laudaverunt laudem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 13,
      "referenceLabel": "Psalms 105:13",
      "text": "Cito fecerunt; obliti sunt operum ejus: et non sustinuerunt consilium ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 14,
      "referenceLabel": "Psalms 105:14",
      "text": "Et concupierunt concupiscentiam in deserto, et tentaverunt Deum in inaquoso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 15,
      "referenceLabel": "Psalms 105:15",
      "text": "Et dedit eis petitionem ipsorum, et misit saturitatem in animas eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 16,
      "referenceLabel": "Psalms 105:16",
      "text": "Et irritaverunt Moysen in castris; Aaron, sanctum Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 17,
      "referenceLabel": "Psalms 105:17",
      "text": "Aperta est terra, et deglutivit Dathan, et operuit super congregationem Abiron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 18,
      "referenceLabel": "Psalms 105:18",
      "text": "Et exarsit ignis in synagoga eorum: flamma combussit peccatores.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 19,
      "referenceLabel": "Psalms 105:19",
      "text": "Et fecerunt vitulum in Horeb, et adoraverunt sculptile.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 20,
      "referenceLabel": "Psalms 105:20",
      "text": "Et mutaverunt gloriam suam in similitudinem vituli comedentis fœnum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 21,
      "referenceLabel": "Psalms 105:21",
      "text": "Obliti sunt Deum qui salvavit eos; qui fecit magnalia in Ægypto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 22,
      "referenceLabel": "Psalms 105:22",
      "text": "mirabilia in terra Cham, terribilia in mari Rubro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 23,
      "referenceLabel": "Psalms 105:23",
      "text": "Et dixit ut disperderet eos, si non Moyses, electus ejus, stetisset in confractione in conspectu ejus, ut averteret iram ejus, ne disperderet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 24,
      "referenceLabel": "Psalms 105:24",
      "text": "Et pro nihilo habuerunt terram desiderabilem; non crediderunt verbo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 25,
      "referenceLabel": "Psalms 105:25",
      "text": "Et murmuraverunt in tabernaculis suis; non exaudierunt vocem Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 26,
      "referenceLabel": "Psalms 105:26",
      "text": "Et elevavit manum suam super eos ut prosterneret eos in deserto:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 27,
      "referenceLabel": "Psalms 105:27",
      "text": "et ut dejiceret semen eorum in nationibus, et dispergeret eos in regionibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 28,
      "referenceLabel": "Psalms 105:28",
      "text": "Et initiati sunt Beelphegor, et comederunt sacrificia mortuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 29,
      "referenceLabel": "Psalms 105:29",
      "text": "Et irritaverunt eum in adinventionibus suis, et multiplicata est in eis ruina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 30,
      "referenceLabel": "Psalms 105:30",
      "text": "Et stetit Phinees, et placavit, et cessavit quassatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 31,
      "referenceLabel": "Psalms 105:31",
      "text": "Et reputatum est ei in justitiam, in generationem et generationem usque in sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 32,
      "referenceLabel": "Psalms 105:32",
      "text": "Et irritaverunt eum ad aquas contradictionis, et vexatus est Moyses propter eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 33,
      "referenceLabel": "Psalms 105:33",
      "text": "quia exacerbaverunt spiritum ejus, et distinxit in labiis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 34,
      "referenceLabel": "Psalms 105:34",
      "text": "Non disperdiderunt gentes quas dixit Dominus illis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 35,
      "referenceLabel": "Psalms 105:35",
      "text": "et commisti sunt inter gentes, et didicerunt opera eorum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 36,
      "referenceLabel": "Psalms 105:36",
      "text": "et servierunt sculptilibus eorum, et factum est illis in scandalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 37,
      "referenceLabel": "Psalms 105:37",
      "text": "Et immolaverunt filios suos et filias suas dæmoniis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 38,
      "referenceLabel": "Psalms 105:38",
      "text": "Et effuderunt sanguinem innocentem, sanguinem filiorum suorum et filiarum suarum, quas sacrificaverunt sculptilibus Chanaan. Et infecta est terra in sanguinibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 39,
      "referenceLabel": "Psalms 105:39",
      "text": "et contaminata est in operibus eorum: et fornicati sunt in adinventionibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 40,
      "referenceLabel": "Psalms 105:40",
      "text": "Et iratus est furore Dominus in populum suum, et abominatus est hæreditatem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.41",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 41,
      "referenceLabel": "Psalms 105:41",
      "text": "Et tradidit eos in manus gentium; et dominati sunt eorum qui oderunt eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.42",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 42,
      "referenceLabel": "Psalms 105:42",
      "text": "Et tribulaverunt eos inimici eorum, et humiliati sunt sub manibus eorum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.43",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 43,
      "referenceLabel": "Psalms 105:43",
      "text": "sæpe liberavit eos. Ipsi autem exacerbaverunt eum in consilio suo, et humiliati sunt in iniquitatibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.44",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 44,
      "referenceLabel": "Psalms 105:44",
      "text": "Et vidit cum tribularentur, et audivit orationem eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.45",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 45,
      "referenceLabel": "Psalms 105:45",
      "text": "Et memor fuit testamenti sui, et pœnituit eum secundum multitudinem misericordiæ suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.46",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 46,
      "referenceLabel": "Psalms 105:46",
      "text": "et dedit eos in misericordias, in conspectu omnium qui ceperant eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.47",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 47,
      "referenceLabel": "Psalms 105:47",
      "text": "Salvos nos fac, Domine Deus noster, et congrega nos de nationibus: ut confiteamur nomini sancto tuo, et gloriemur in laude tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.105.48",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 105,
      "verseNumber": 48,
      "referenceLabel": "Psalms 105:48",
      "text": "Benedictus Dominus Deus Israël, a sæculo et usque in sæculum; et dicet omnis populus: Fiat, fiat.",
      "paragraphStart": false
    }
  ]
}
