{
  "chapter": {
    "id": "vulgate:psalms.89",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.89.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "Oratio Moysi, hominis Dei. Domine, refugium factus es nobis a generatione in generationem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.89.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "Priusquam montes fierent, aut formaretur terra et orbis, a sæculo et usque in sæculum tu es, Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "Ne avertas hominem in humilitatem: et dixisti: Convertimini, filii hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "Quoniam mille anni ante oculos tuos tamquam dies hesterna quæ præteriit: et custodia in nocte",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "quæ pro nihilo habentur, eorum anni erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "Mane sicut herba transeat; mane floreat, et transeat; vespere decidat, induret, et arescat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "Quia defecimus in ira tua, et in furore tuo turbati sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "Posuisti iniquitates nostras in conspectu tuo; sæculum nostrum in illuminatione vultus tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "Quoniam omnes dies nostri defecerunt, et in ira tua defecimus. Anni nostri sicut aranea meditabuntur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "dies annorum nostrorum in ipsis septuaginta anni. Si autem in potentatibus octoginta anni, et amplius eorum labor et dolor; quoniam supervenit mansuetudo, et corripiemur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "Quis novit potestatem iræ tuæ, et præ timore tuo iram tuam",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "dinumerare? Dexteram tuam sic notam fac, et eruditos corde in sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "Convertere, Domine; usquequo? et deprecabilis esto super servos tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "Repleti sumus mane misericordia tua; et exsultavimus, et delectati sumus omnibus diebus nostris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "Lætati sumus pro diebus quibus nos humiliasti; annis quibus vidimus mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "Respice in servos tuos et in opera tua, et dirige filios eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.89.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "Et sit splendor Domini Dei nostri super nos, et opera manuum nostrarum dirige super nos, et opus manuum nostrarum dirige.",
      "paragraphStart": false
    }
  ]
}
