{
  "chapter": {
    "id": "vulgate:psalms.110",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 110,
    "referenceLabel": "Psalms 110",
    "summary": "Source text for Psalms 110 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.110.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 1,
      "referenceLabel": "Psalms 110:1",
      "text": "Alleluja. Confitebor tibi, Domine, in toto corde meo, in consilio justorum, et congregatione.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.110.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 2,
      "referenceLabel": "Psalms 110:2",
      "text": "Magna opera Domini: exquisita in omnes voluntates ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 3,
      "referenceLabel": "Psalms 110:3",
      "text": "Confessio et magnificentia opus ejus, et justitia ejus manet in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 4,
      "referenceLabel": "Psalms 110:4",
      "text": "Memoriam fecit mirabilium suorum, misericors et miserator Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 5,
      "referenceLabel": "Psalms 110:5",
      "text": "Escam dedit timentibus se; memor erit in sæculum testamenti sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 6,
      "referenceLabel": "Psalms 110:6",
      "text": "Virtutem operum suorum annuntiabit populo suo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 7,
      "referenceLabel": "Psalms 110:7",
      "text": "ut det illis hæreditatem gentium. Opera manuum ejus veritas et judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 8,
      "referenceLabel": "Psalms 110:8",
      "text": "Fidelia omnia mandata ejus, confirmata in sæculum sæculi, facta in veritate et æquitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 9,
      "referenceLabel": "Psalms 110:9",
      "text": "Redemptionem misit populo suo; mandavit in æternum testamentum suum. Sanctum et terribile nomen ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.110.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 10,
      "referenceLabel": "Psalms 110:10",
      "text": "Initium sapientiæ timor Domini; intellectus bonus omnibus facientibus eum: laudatio ejus manet in sæculum sæculi.",
      "paragraphStart": false
    }
  ]
}
