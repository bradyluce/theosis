{
  "chapter": {
    "id": "vulgate:psalms.18",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 18,
    "referenceLabel": "Psalms 18",
    "summary": "Source text for Psalms 18 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.18.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Psalms 18:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.18.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Psalms 18:2",
      "text": "Cæli enarrant gloriam Dei, et opera manuum ejus annuntiat firmamentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Psalms 18:3",
      "text": "Dies diei eructat verbum, et nox nocti indicat scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Psalms 18:4",
      "text": "Non sunt loquelæ, neque sermones, quorum non audiantur voces eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Psalms 18:5",
      "text": "In omnem terram exivit sonus eorum, et in fines orbis terræ verba eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Psalms 18:6",
      "text": "In sole posuit tabernaculum suum; et ipse tamquam sponsus procedens de thalamo suo. Exsultavit ut gigas ad currendam viam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Psalms 18:7",
      "text": "a summo cælo egressio ejus. Et occursus ejus usque ad summum ejus; nec est qui se abscondat a calore ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Psalms 18:8",
      "text": "Lex Domini immaculata, convertens animas; testimonium Domini fidele, sapientiam præstans parvulis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Psalms 18:9",
      "text": "Justitiæ Domini rectæ, lætificantes corda; præceptum Domini lucidum, illuminans oculos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Psalms 18:10",
      "text": "Timor Domini sanctus, permanens in sæculum sæculi; judicia Domini vera, justificata in semetipsa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Psalms 18:11",
      "text": "desiderabilia super aurum et lapidem pretiosum multum, et dulciora super mel et favum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Psalms 18:12",
      "text": "Etenim servus tuus custodit ea; in custodiendis illis retributio multa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Psalms 18:13",
      "text": "Delicta quis intelligit? ab occultis meis munda me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Psalms 18:14",
      "text": "et ab alienis parce servo tuo. Si mei non fuerint dominati, tunc immaculatus ero, et emundabor a delicto maximo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.18.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Psalms 18:15",
      "text": "Et erunt ut complaceant eloquia oris mei, et meditatio cordis mei in conspectu tuo semper. Domine, adjutor meus, et redemptor meus.",
      "paragraphStart": false
    }
  ]
}
