{
  "chapter": {
    "id": "vulgate:psalms.4",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 4,
    "referenceLabel": "Psalms 4",
    "summary": "Source text for Psalms 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.4.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Psalms 4:1",
      "text": "In finem, in carminibus. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.4.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Psalms 4:2",
      "text": "Cum invocarem exaudivit me Deus justitiæ meæ, in tribulatione dilatasti mihi. Miserere mei, et exaudi orationem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Psalms 4:3",
      "text": "Filii hominum, usquequo gravi corde? ut quid diligitis vanitatem, et quæritis mendacium?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Psalms 4:4",
      "text": "Et scitote quoniam mirificavit Dominus sanctum suum; Dominus exaudiet me cum clamavero ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Psalms 4:5",
      "text": "Irascimini, et nolite peccare; quæ dicitis in cordibus vestris, in cubilibus vestris compungimini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Psalms 4:6",
      "text": "Sacrificate sacrificium justitiæ, et sperate in Domino. Multi dicunt: Quis ostendit nobis bona?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Psalms 4:7",
      "text": "Signatum est super nos lumen vultus tui, Domine: dedisti lætitiam in corde meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Psalms 4:8",
      "text": "A fructu frumenti, vini, et olei sui, multiplicati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Psalms 4:9",
      "text": "In pace in idipsum dormiam, et requiescam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.4.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Psalms 4:10",
      "text": "quoniam tu, Domine, singulariter in spe constituisti me.",
      "paragraphStart": false
    }
  ]
}
