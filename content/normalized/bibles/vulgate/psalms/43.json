{
  "chapter": {
    "id": "vulgate:psalms.43",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 43,
    "referenceLabel": "Psalms 43",
    "summary": "Source text for Psalms 43 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.43.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 1,
      "referenceLabel": "Psalms 43:1",
      "text": "In finem. Filiis Core ad intellectum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.43.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 2,
      "referenceLabel": "Psalms 43:2",
      "text": "Deus, auribus nostris audivimus, patres nostri annuntiaverunt nobis, opus quod operatus es in diebus eorum, et in diebus antiquis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 3,
      "referenceLabel": "Psalms 43:3",
      "text": "Manus tua gentes disperdidit, et plantasti eos; afflixisti populos, et expulisti eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 4,
      "referenceLabel": "Psalms 43:4",
      "text": "Nec enim in gladio suo possederunt terram, et brachium eorum non salvavit eos: sed dextera tua et brachium tuum, et illuminatio vultus tui, quoniam complacuisti in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 5,
      "referenceLabel": "Psalms 43:5",
      "text": "Tu es ipse rex meus et Deus meus, qui mandas salutes Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 6,
      "referenceLabel": "Psalms 43:6",
      "text": "In te inimicos nostros ventilabimus cornu, et in nomine tuo spernemus insurgentes in nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 7,
      "referenceLabel": "Psalms 43:7",
      "text": "Non enim in arcu meo sperabo, et gladius meus non salvabit me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 8,
      "referenceLabel": "Psalms 43:8",
      "text": "salvasti enim nos de affligentibus nos, et odientes nos confudisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 9,
      "referenceLabel": "Psalms 43:9",
      "text": "In Deo laudabimur tota die, et in nomine tuo confitebimur in sæculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 10,
      "referenceLabel": "Psalms 43:10",
      "text": "Nunc autem repulisti et confudisti nos, et non egredieris, Deus, in virtutibus nostris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 11,
      "referenceLabel": "Psalms 43:11",
      "text": "Avertisti nos retrorsum post inimicos nostros, et qui oderunt nos diripiebant sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 12,
      "referenceLabel": "Psalms 43:12",
      "text": "Dedisti nos tamquam oves escarum, et in gentibus dispersisti nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 13,
      "referenceLabel": "Psalms 43:13",
      "text": "Vendidisti populum tuum sine pretio, et non fuit multitudo in commutationibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 14,
      "referenceLabel": "Psalms 43:14",
      "text": "Posuisti nos opprobrium vicinis nostris; subsannationem et derisum his qui sunt in circuitu nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 15,
      "referenceLabel": "Psalms 43:15",
      "text": "Posuisti nos in similitudinem gentibus; commotionem capitis in populis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 16,
      "referenceLabel": "Psalms 43:16",
      "text": "Tota die verecundia mea contra me est, et confusio faciei meæ cooperuit me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 17,
      "referenceLabel": "Psalms 43:17",
      "text": "a voce exprobrantis et obloquentis, a facie inimici et persequentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 18,
      "referenceLabel": "Psalms 43:18",
      "text": "Hæc omnia venerunt super nos; nec obliti sumus te, et inique non egimus in testamento tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 19,
      "referenceLabel": "Psalms 43:19",
      "text": "Et non recessit retro cor nostrum; et declinasti semitas nostras a via tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 20,
      "referenceLabel": "Psalms 43:20",
      "text": "quoniam humiliasti nos in loco afflictionis, et cooperuit nos umbra mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 21,
      "referenceLabel": "Psalms 43:21",
      "text": "Si obliti sumus nomen Dei nostri, et si expandimus manus nostras ad deum alienum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 22,
      "referenceLabel": "Psalms 43:22",
      "text": "nonne Deus requiret ista? ipse enim novit abscondita cordis. Quoniam propter te mortificamur tota die; æstimati sumus sicut oves occisionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 23,
      "referenceLabel": "Psalms 43:23",
      "text": "Exsurge; quare obdormis, Domine? exsurge, et ne repellas in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 24,
      "referenceLabel": "Psalms 43:24",
      "text": "Quare faciem tuam avertis? oblivisceris inopiæ nostræ et tribulationis nostræ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 25,
      "referenceLabel": "Psalms 43:25",
      "text": "Quoniam humiliata est in pulvere anima nostra; conglutinatus est in terra venter noster.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.43.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 26,
      "referenceLabel": "Psalms 43:26",
      "text": "Exsurge, Domine, adjuva nos, et redime nos propter nomen tuum.",
      "paragraphStart": false
    }
  ]
}
