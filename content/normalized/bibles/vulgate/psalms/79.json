{
  "chapter": {
    "id": "vulgate:psalms.79",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 79,
    "referenceLabel": "Psalms 79",
    "summary": "Source text for Psalms 79 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.79.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 1,
      "referenceLabel": "Psalms 79:1",
      "text": "In finem, pro iis qui commutabuntur. Testimonium Asaph, psalmus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.79.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 2,
      "referenceLabel": "Psalms 79:2",
      "text": "Qui regis Israël, intende; qui deducis velut ovem Joseph. Qui sedes super cherubim, manifestare",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 3,
      "referenceLabel": "Psalms 79:3",
      "text": "coram Ephraim, Benjamin, et Manasse. Excita potentiam tuam, et veni, ut salvos facias nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 4,
      "referenceLabel": "Psalms 79:4",
      "text": "Deus, converte nos, et ostende faciem tuam, et salvi erimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 5,
      "referenceLabel": "Psalms 79:5",
      "text": "Domine Deus virtutum, quousque irasceris super orationem servi tui?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 6,
      "referenceLabel": "Psalms 79:6",
      "text": "cibabis nos pane lacrimarum, et potum dabis nobis in lacrimis in mensura?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 7,
      "referenceLabel": "Psalms 79:7",
      "text": "Posuisti nos in contradictionem vicinis nostris, et inimici nostri subsannaverunt nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 8,
      "referenceLabel": "Psalms 79:8",
      "text": "Deus virtutum, converte nos, et ostende faciem tuam, et salvi erimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 9,
      "referenceLabel": "Psalms 79:9",
      "text": "Vineam de Ægypto transtulisti: ejecisti gentes, et plantasti eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 10,
      "referenceLabel": "Psalms 79:10",
      "text": "Dux itineris fuisti in conspectu ejus; plantasti radices ejus, et implevit terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 11,
      "referenceLabel": "Psalms 79:11",
      "text": "Operuit montes umbra ejus, et arbusta ejus cedros Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 12,
      "referenceLabel": "Psalms 79:12",
      "text": "Extendit palmites suos usque ad mare, et usque ad flumen propagines ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 13,
      "referenceLabel": "Psalms 79:13",
      "text": "Ut quid destruxisti maceriam ejus, et vindemiant eam omnes qui prætergrediuntur viam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 14,
      "referenceLabel": "Psalms 79:14",
      "text": "Exterminavit eam aper de silva, et singularis ferus depastus est eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 15,
      "referenceLabel": "Psalms 79:15",
      "text": "Deus virtutum, convertere, respice de cælo, et vide, et visita vineam istam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 16,
      "referenceLabel": "Psalms 79:16",
      "text": "et perfice eam quam plantavit dextera tua, et super filium hominis quem confirmasti tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 17,
      "referenceLabel": "Psalms 79:17",
      "text": "Incensa igni et suffossa, ab increpatione vultus tui peribunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 18,
      "referenceLabel": "Psalms 79:18",
      "text": "Fiat manus tua super virum dexteræ tuæ, et super filium hominis quem confirmasti tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 19,
      "referenceLabel": "Psalms 79:19",
      "text": "Et non discedimus a te: vivificabis nos, et nomen tuum invocabimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.79.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 20,
      "referenceLabel": "Psalms 79:20",
      "text": "Domine Deus virtutum, converte nos, et ostende faciem tuam, et salvi erimus.",
      "paragraphStart": false
    }
  ]
}
