{
  "chapter": {
    "id": "vulgate:psalms.85",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.85.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "Oratio ipsi David. Inclina, Domine, aurem tuam et exaudi me, quoniam inops et pauper sum ego.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.85.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "Custodi animam meam, quoniam sanctus sum; salvum fac servum tuum, Deus meus, sperantem in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "Miserere mei, Domine, quoniam ad te clamavi tota die;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "lætifica animam servi tui, quoniam ad te, Domine, animam meam levavi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "Quoniam tu, Domine, suavis et mitis, et multæ misericordiæ omnibus invocantibus te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "Auribus percipe, Domine, orationem meam, et intende voci deprecationis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "In die tribulationis meæ clamavi ad te, quia exaudisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "Non est similis tui in diis, Domine, et non est secundum opera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "Omnes gentes quascumque fecisti venient, et adorabunt coram te, Domine, et glorificabunt nomen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "Quoniam magnus es tu, et faciens mirabilia; tu es Deus solus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Deduc me, Domine, in via tua, et ingrediar in veritate tua; lætetur cor meum, ut timeat nomen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "Confitebor tibi, Domine Deus meus, in toto corde meo, et glorificabo nomen tuum in æternum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "quia misericordia tua magna est super me, et eruisti animam meam ex inferno inferiori.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 14,
      "referenceLabel": "Psalms 85:14",
      "text": "Deus, iniqui insurrexerunt super me, et synagoga potentium quæsierunt animam meam: et non proposuerunt te in conspectu suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 15,
      "referenceLabel": "Psalms 85:15",
      "text": "Et tu, Domine Deus, miserator et misericors; patiens, et multæ misericordiæ, et verax.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 16,
      "referenceLabel": "Psalms 85:16",
      "text": "Respice in me, et miserere mei; da imperium tuum puero tuo, et salvum fac filium ancillæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.85.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 17,
      "referenceLabel": "Psalms 85:17",
      "text": "Fac mecum signum in bonum, ut videant qui oderunt me, et confundantur: quoniam tu, Domine, adjuvisti me, et consolatus es me.",
      "paragraphStart": false
    }
  ]
}
