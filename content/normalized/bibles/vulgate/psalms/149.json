{
  "chapter": {
    "id": "vulgate:psalms.149",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.149.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Alleluja. Cantate Domino canticum novum; laus ejus in ecclesia sanctorum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.149.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Lætetur Israël in eo qui fecit eum, et filii Sion exsultent in rege suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Laudent nomen ejus in choro; in tympano et psalterio psallant ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "Quia beneplacitum est Domino in populo suo, et exaltabit mansuetos in salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "Exsultabunt sancti in gloria; lætabuntur in cubilibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "Exaltationes Dei in gutture eorum, et gladii ancipites in manibus eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "ad faciendam vindictam in nationibus, increpationes in populis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "ad alligandos reges eorum in compedibus, et nobiles eorum in manicis ferreis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.149.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "ut faciant in eis judicium conscriptum: gloria hæc est omnibus sanctis ejus. Alleluja.",
      "paragraphStart": false
    }
  ]
}
