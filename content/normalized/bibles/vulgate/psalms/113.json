{
  "chapter": {
    "id": "vulgate:psalms.113",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.113.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Alleluja. In exitu Israël de Ægypto, domus Jacob de populo barbaro,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.113.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "facta est Judæa sanctificatio ejus; Israël potestas ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "Mare vidit, et fugit; Jordanis conversus est retrorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "Montes exsultaverunt ut arietes, et colles sicut agni ovium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "Quid est tibi, mare, quod fugisti? et tu, Jordanis, quia conversus es retrorsum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "montes, exsultastis sicut arietes? et colles, sicut agni ovium?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "A facie Domini mota est terra, a facie Dei Jacob:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "qui convertit petram in stagna aquarum, et rupem in fontes aquarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "Non nobis, Domine, non nobis, sed nomini tuo da gloriam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 10,
      "referenceLabel": "Psalms 113:10",
      "text": "super misericordia tua et veritate tua; nequando dicant gentes: Ubi est Deus eorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 11,
      "referenceLabel": "Psalms 113:11",
      "text": "Deus autem noster in cælo; omnia quæcumque voluit fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 12,
      "referenceLabel": "Psalms 113:12",
      "text": "Simulacra gentium argentum et aurum, opera manuum hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 13,
      "referenceLabel": "Psalms 113:13",
      "text": "Os habent, et non loquentur; oculos habent, et non videbunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 14,
      "referenceLabel": "Psalms 113:14",
      "text": "Aures habent, et non audient; nares habent, et non odorabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 15,
      "referenceLabel": "Psalms 113:15",
      "text": "Manus habent, et non palpabunt; pedes habent, et non ambulabunt; non clamabunt in gutture suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 16,
      "referenceLabel": "Psalms 113:16",
      "text": "Similes illis fiant qui faciunt ea, et omnes qui confidunt in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 17,
      "referenceLabel": "Psalms 113:17",
      "text": "Domus Israël speravit in Domino; adjutor eorum et protector eorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 18,
      "referenceLabel": "Psalms 113:18",
      "text": "Domus Aaron speravit in Domino; adjutor eorum et protector eorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 19,
      "referenceLabel": "Psalms 113:19",
      "text": "Qui timent Dominum speraverunt in Domino; adjutor eorum et protector eorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 20,
      "referenceLabel": "Psalms 113:20",
      "text": "Dominus memor fuit nostri, et benedixit nobis. Benedixit domui Israël; benedixit domui Aaron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 21,
      "referenceLabel": "Psalms 113:21",
      "text": "Benedixit omnibus qui timent Dominum, pusillis cum majoribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 22,
      "referenceLabel": "Psalms 113:22",
      "text": "Adjiciat Dominus super vos, super vos et super filios vestros.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 23,
      "referenceLabel": "Psalms 113:23",
      "text": "Benedicti vos a Domino, qui fecit cælum et terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 24,
      "referenceLabel": "Psalms 113:24",
      "text": "Cælum cæli Domino; terram autem dedit filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 25,
      "referenceLabel": "Psalms 113:25",
      "text": "Non mortui laudabunt te, Domine, neque omnes qui descendunt in infernum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.113.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 26,
      "referenceLabel": "Psalms 113:26",
      "text": "sed nos qui vivimus, benedicimus Domino, ex hoc nunc et usque in sæculum.",
      "paragraphStart": false
    }
  ]
}
