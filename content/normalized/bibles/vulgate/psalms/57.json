{
  "chapter": {
    "id": "vulgate:psalms.57",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 57,
    "referenceLabel": "Psalms 57",
    "summary": "Source text for Psalms 57 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.57.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 1,
      "referenceLabel": "Psalms 57:1",
      "text": "In finem, ne disperdas. David in tituli inscriptionem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.57.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 2,
      "referenceLabel": "Psalms 57:2",
      "text": "Si vere utique justitiam loquimini, recta judicate, filii hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 3,
      "referenceLabel": "Psalms 57:3",
      "text": "Etenim in corde iniquitates operamini; in terra injustitias manus vestræ concinnant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 4,
      "referenceLabel": "Psalms 57:4",
      "text": "Alienati sunt peccatores a vulva; erraverunt ab utero: locuti sunt falsa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 5,
      "referenceLabel": "Psalms 57:5",
      "text": "Furor illis secundum similitudinem serpentis, sicut aspidis surdæ et obturantis aures suas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 6,
      "referenceLabel": "Psalms 57:6",
      "text": "quæ non exaudiet vocem incantantium, et venefici incantantis sapienter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 7,
      "referenceLabel": "Psalms 57:7",
      "text": "Deus conteret dentes eorum in ore ipsorum; molas leonum confringet Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 8,
      "referenceLabel": "Psalms 57:8",
      "text": "Ad nihilum devenient tamquam aqua decurrens; intendit arcum suum donec infirmentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 9,
      "referenceLabel": "Psalms 57:9",
      "text": "Sicut cera quæ fluit auferentur; supercecidit ignis, et non viderunt solem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 10,
      "referenceLabel": "Psalms 57:10",
      "text": "Priusquam intelligerent spinæ vestræ rhamnum, sicut viventes sic in ira absorbet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 11,
      "referenceLabel": "Psalms 57:11",
      "text": "Lætabitur justus cum viderit vindictam; manus suas lavabit in sanguine peccatoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.57.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 12,
      "referenceLabel": "Psalms 57:12",
      "text": "Et dicet homo: Si utique est fructus justo, utique est Deus judicans eos in terra.",
      "paragraphStart": false
    }
  ]
}
