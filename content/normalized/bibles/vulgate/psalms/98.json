{
  "chapter": {
    "id": "vulgate:psalms.98",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 98,
    "referenceLabel": "Psalms 98",
    "summary": "Source text for Psalms 98 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.98.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 1,
      "referenceLabel": "Psalms 98:1",
      "text": "Psalmus ipsi David. Dominus regnavit: irascantur populi; qui sedet super cherubim: moveatur terra.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.98.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 2,
      "referenceLabel": "Psalms 98:2",
      "text": "Dominus in Sion magnus, et excelsus super omnes populos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 3,
      "referenceLabel": "Psalms 98:3",
      "text": "Confiteantur nomini tuo magno, quoniam terribile et sanctum est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 4,
      "referenceLabel": "Psalms 98:4",
      "text": "et honor regis judicium diligit. Tu parasti directiones; judicium et justitiam in Jacob tu fecisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 5,
      "referenceLabel": "Psalms 98:5",
      "text": "Exaltate Dominum Deum nostrum, et adorate scabellum pedum ejus, quoniam sanctum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 6,
      "referenceLabel": "Psalms 98:6",
      "text": "Moyses et Aaron in sacerdotibus ejus, et Samuel inter eos qui invocant nomen ejus: invocabant Dominum, et ipse exaudiebat eos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 7,
      "referenceLabel": "Psalms 98:7",
      "text": "in columna nubis loquebatur ad eos. Custodiebant testimonia ejus, et præceptum quod dedit illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 8,
      "referenceLabel": "Psalms 98:8",
      "text": "Domine Deus noster, tu exaudiebas eos; Deus, tu propitius fuisti eis, et ulciscens in omnes adinventiones eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.98.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 9,
      "referenceLabel": "Psalms 98:9",
      "text": "Exaltate Dominum Deum nostrum, et adorate in monte sancto ejus, quoniam sanctus Dominus Deus noster.",
      "paragraphStart": false
    }
  ]
}
