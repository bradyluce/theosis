{
  "chapter": {
    "id": "vulgate:psalms.7",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 7,
    "referenceLabel": "Psalms 7",
    "summary": "Source text for Psalms 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.7.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Psalms 7:1",
      "text": "Psalmus David, quem cantavit Domino pro verbis Chusi, filii Jemini.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.7.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Psalms 7:2",
      "text": "Domine Deus meus, in te speravi; salvum me fac ex omnibus persequentibus me, et libera me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Psalms 7:3",
      "text": "nequando rapiat ut leo animam meam, dum non est qui redimat, neque qui salvum faciat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Psalms 7:4",
      "text": "Domine Deus meus, si feci istud, si est iniquitas in manibus meis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Psalms 7:5",
      "text": "si reddidi retribuentibus mihi mala, decidam merito ab inimicis meis inanis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Psalms 7:6",
      "text": "Persequatur inimicus animam meam, et comprehendat; et conculcet in terra vitam meam, et gloriam meam in pulverem deducat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Psalms 7:7",
      "text": "Exsurge, Domine, in ira tua, et exaltare in finibus inimicorum meorum: et exsurge, Domine Deus meus, in præcepto quod mandasti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Psalms 7:8",
      "text": "et synagoga populorum circumdabit te: et propter hanc in altum regredere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Psalms 7:9",
      "text": "Dominus judicat populos. Judica me, Domine, secundum justitiam meam, et secundum innocentiam meam super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Psalms 7:10",
      "text": "Consumetur nequitia peccatorum, et diriges justum, scrutans corda et renes, Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Psalms 7:11",
      "text": "Justum adjutorium meum a Domino, qui salvos facit rectos corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Psalms 7:12",
      "text": "Deus judex justus, fortis, et patiens; numquid irascitur per singulos dies?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Psalms 7:13",
      "text": "Nisi conversi fueritis, gladium suum vibrabit; arcum suum tetendit, et paravit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Psalms 7:14",
      "text": "Et in eo paravit vasa mortis, sagittas suas ardentibus effecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Psalms 7:15",
      "text": "Ecce parturiit injustitiam; concepit dolorem, et peperit iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Psalms 7:16",
      "text": "Lacum aperuit, et effodit eum; et incidit in foveam quam fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Psalms 7:17",
      "text": "Convertetur dolor ejus in caput ejus, et in verticem ipsius iniquitas ejus descendet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.7.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Psalms 7:18",
      "text": "Confitebor Domino secundum justitiam ejus, et psallam nomini Domini altissimi.",
      "paragraphStart": false
    }
  ]
}
