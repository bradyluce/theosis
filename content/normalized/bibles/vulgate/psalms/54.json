{
  "chapter": {
    "id": "vulgate:psalms.54",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.54.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "In finem, in carminibus. Intellectus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.54.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "Exaudi, Deus, orationem meam, et ne despexeris deprecationem meam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "intende mihi, et exaudi me. Contristatus sum in exercitatione mea, et conturbatus sum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "a voce inimici, et a tribulatione peccatoris. Quoniam declinaverunt in me iniquitates, et in ira molesti erant mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "Cor meum conturbatum est in me, et formido mortis cecidit super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "Timor et tremor venerunt super me, et contexerunt me tenebræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "Et dixi: Quis dabit mihi pennas sicut columbæ, et volabo, et requiescam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 8,
      "referenceLabel": "Psalms 54:8",
      "text": "Ecce elongavi fugiens, et mansi in solitudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 9,
      "referenceLabel": "Psalms 54:9",
      "text": "Exspectabam eum qui salvum me fecit a pusillanimitate spiritus, et tempestate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 10,
      "referenceLabel": "Psalms 54:10",
      "text": "Præcipita, Domine; divide linguas eorum: quoniam vidi iniquitatem et contradictionem in civitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 11,
      "referenceLabel": "Psalms 54:11",
      "text": "Die ac nocte circumdabit eam super muros ejus iniquitas; et labor in medio ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 12,
      "referenceLabel": "Psalms 54:12",
      "text": "et injustitia: et non defecit de plateis ejus usura et dolus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 13,
      "referenceLabel": "Psalms 54:13",
      "text": "Quoniam si inimicus meus maledixisset mihi, sustinuissem utique. Et si is qui oderat me super me magna locutus fuisset, abscondissem me forsitan ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 14,
      "referenceLabel": "Psalms 54:14",
      "text": "Tu vero homo unanimis, dux meus, et notus meus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 15,
      "referenceLabel": "Psalms 54:15",
      "text": "qui simul mecum dulces capiebas cibos; in domo Dei ambulavimus cum consensu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 16,
      "referenceLabel": "Psalms 54:16",
      "text": "Veniat mors super illos, et descendant in infernum viventes: quoniam nequitiæ in habitaculis eorum, in medio eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 17,
      "referenceLabel": "Psalms 54:17",
      "text": "Ego autem ad Deum clamavi, et Dominus salvabit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 18,
      "referenceLabel": "Psalms 54:18",
      "text": "Vespere, et mane, et meridie, narrabo, et annuntiabo; et exaudiet vocem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 19,
      "referenceLabel": "Psalms 54:19",
      "text": "Redimet in pace animam meam ab his qui appropinquant mihi: quoniam inter multos erant mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 20,
      "referenceLabel": "Psalms 54:20",
      "text": "Exaudiet Deus, et humiliabit illos, qui est ante sæcula. Non enim est illis commutatio, et non timuerunt Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 21,
      "referenceLabel": "Psalms 54:21",
      "text": "Extendit manum suam in retribuendo; contaminaverunt testamentum ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 22,
      "referenceLabel": "Psalms 54:22",
      "text": "divisi sunt ab ira vultus ejus, et appropinquavit cor illius. Molliti sunt sermones ejus super oleum; et ipsi sunt jacula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 23,
      "referenceLabel": "Psalms 54:23",
      "text": "Jacta super Dominum curam tuam, et ipse te enutriet; non dabit in æternum fluctuationem justo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.54.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 24,
      "referenceLabel": "Psalms 54:24",
      "text": "Tu vero, Deus, deduces eos in puteum interitus. Viri sanguinum et dolosi non dimidiabunt dies suos; ego autem sperabo in te, Domine.",
      "paragraphStart": false
    }
  ]
}
