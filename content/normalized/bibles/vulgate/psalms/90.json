{
  "chapter": {
    "id": "vulgate:psalms.90",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.90.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "Laus cantici David. Qui habitat in adjutorio Altissimi, in protectione Dei cæli commorabitur.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.90.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Dicet Domino: Susceptor meus es tu, et refugium meum; Deus meus, sperabo in eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "Quoniam ipse liberavit me de laqueo venantium, et a verbo aspero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "Scapulis suis obumbrabit tibi, et sub pennis ejus sperabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Scuto circumdabit te veritas ejus: non timebis a timore nocturno;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "a sagitta volante in die, a negotio perambulante in tenebris, ab incursu, et dæmonio meridiano.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "Cadent a latere tuo mille, et decem millia a dextris tuis; ad te autem non appropinquabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Verumtamen oculis tuis considerabis, et retributionem peccatorum videbis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "Quoniam tu es, Domine, spes mea; Altissimum posuisti refugium tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "Non accedet ad te malum, et flagellum non appropinquabit tabernaculo tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Quoniam angelis suis mandavit de te, ut custodiant te in omnibus viis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "In manibus portabunt te, ne forte offendas ad lapidem pedem tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Super aspidem et basiliscum ambulabis, et conculcabis leonem et draconem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "Quoniam in me speravit, liberabo eum; protegam eum, quoniam cognovit nomen meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "Clamabit ad me, et ego exaudiam eum; cum ipso sum in tribulatione: eripiam eum, et glorificabo eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.90.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "Longitudine dierum replebo eum, et ostendam illi salutare meum.",
      "paragraphStart": false
    }
  ]
}
