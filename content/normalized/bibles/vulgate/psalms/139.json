{
  "chapter": {
    "id": "vulgate:psalms.139",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.139.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.139.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Eripe me, Domine, ab homine malo; a viro iniquo eripe me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Qui cogitaverunt iniquitates in corde, tota die constituebant prælia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "Acuerunt linguas suas sicut serpentis; venenum aspidum sub labiis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "Custodi me, Domine, de manu peccatoris, et ab hominibus iniquis eripe me. Qui cogitaverunt supplantare gressus meos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "absconderunt superbi laqueum mihi. Et funes extenderunt in laqueum; juxta iter, scandalum posuerunt mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "Dixi Domino: Deus meus es tu; exaudi, Domine, vocem deprecationis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "Domine, Domine, virtus salutis meæ, obumbrasti super caput meum in die belli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "Ne tradas me, Domine, a desiderio meo peccatori: cogitaverunt contra me; ne derelinquas me, ne forte exaltentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "Caput circuitus eorum: labor labiorum ipsorum operiet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "Cadent super eos carbones; in ignem dejicies eos: in miseriis non subsistent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "Vir linguosus non dirigetur in terra; virum injustum mala capient in interitu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "Cognovi quia faciet Dominus judicium inopis, et vindictam pauperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.139.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "Verumtamen justi confitebuntur nomini tuo, et habitabunt recti cum vultu tuo.",
      "paragraphStart": false
    }
  ]
}
