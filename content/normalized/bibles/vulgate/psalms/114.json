{
  "chapter": {
    "id": "vulgate:psalms.114",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.114.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "Alleluja. Dilexi, quoniam exaudiet Dominus vocem orationis meæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.114.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Quia inclinavit aurem suam mihi, et in diebus meis invocabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "Circumdederunt me dolores mortis; et pericula inferni invenerunt me. Tribulationem et dolorem inveni,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "et nomen Domini invocavi: o Domine, libera animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "Misericors Dominus et justus, et Deus noster miseretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "Custodiens parvulos Dominus; humiliatus sum, et liberavit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Convertere, anima mea, in requiem tuam, quia Dominus benefecit tibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "quia eripuit animam meam de morte, oculos meos a lacrimis, pedes meos a lapsu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.114.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 9,
      "referenceLabel": "Psalms 114:9",
      "text": "Placebo Domino in regione vivorum.",
      "paragraphStart": false
    }
  ]
}
