{
  "chapter": {
    "id": "vulgate:psalms.84",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.84.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "In finem, filiis Core. Psalmus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.84.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "Benedixisti, Domine, terram tuam; avertisti captivitatem Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Remisisti iniquitatem plebis tuæ; operuisti omnia peccata eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Mitigasti omnem iram tuam; avertisti ab ira indignationis tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Converte nos, Deus salutaris noster, et averte iram tuam a nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "Numquid in æternum irasceris nobis? aut extendes iram tuam a generatione in generationem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "Deus, tu conversus vivificabis nos, et plebs tua lætabitur in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "Ostende nobis, Domine, misericordiam tuam, et salutare tuum da nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Audiam quid loquatur in me Dominus Deus, quoniam loquetur pacem in plebem suam, et super sanctos suos, et in eos qui convertuntur ad cor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "Verumtamen prope timentes eum salutare ipsius, ut inhabitet gloria in terra nostra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "Misericordia et veritas obviaverunt sibi; justitia et pax osculatæ sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "Veritas de terra orta est, et justitia de cælo prospexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "Etenim Dominus dabit benignitatem, et terra nostra dabit fructum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.84.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 14,
      "referenceLabel": "Psalms 84:14",
      "text": "Justitia ante eum ambulabit, et ponet in via gressus suos.",
      "paragraphStart": false
    }
  ]
}
