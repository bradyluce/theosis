{
  "chapter": {
    "id": "vulgate:psalms.2",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.2.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "Quare fremuerunt gentes, et populi meditati sunt inania?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.2.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "Astiterunt reges terræ, et principes convenerunt in unum adversus Dominum, et adversus christum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "Dirumpamus vincula eorum, et projiciamus a nobis jugum ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "Qui habitat in cælis irridebit eos, et Dominus subsannabit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "Tunc loquetur ad eos in ira sua, et in furore suo conturbabit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "Ego autem constitutus sum rex ab eo super Sion, montem sanctum ejus, prædicans præceptum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "Dominus dixit ad me: Filius meus es tu; ego hodie genui te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "Postula a me, et dabo tibi gentes hæreditatem tuam, et possessionem tuam terminos terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "Reges eos in virga ferrea, et tamquam vas figuli confringes eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "Et nunc, reges, intelligite; erudimini, qui judicatis terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "Servite Domino in timore, et exsultate ei cum tremore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "Apprehendite disciplinam, nequando irascatur Dominus, et pereatis de via justa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.2.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Psalms 2:13",
      "text": "Cum exarserit in brevi ira ejus, beati omnes qui confidunt in eo.",
      "paragraphStart": false
    }
  ]
}
