{
  "chapter": {
    "id": "vulgate:psalms.103",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.103.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "Ipsi David. Benedic, anima mea, Domino: Domine Deus meus, magnificatus es vehementer. Confessionem et decorem induisti,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.103.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "amictus lumine sicut vestimento. Extendens cælum sicut pellem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "qui tegis aquis superiora ejus: qui ponis nubem ascensum tuum; qui ambulas super pennas ventorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "qui facis angelos tuos spiritus, et ministros tuos ignem urentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "Qui fundasti terram super stabilitatem suam: non inclinabitur in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "Abyssus sicut vestimentum amictus ejus; super montes stabunt aquæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "Ab increpatione tua fugient; a voce tonitrui tui formidabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "Ascendunt montes, et descendunt campi, in locum quem fundasti eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "Terminum posuisti quem non transgredientur, neque convertentur operire terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "Qui emittis fontes in convallibus; inter medium montium pertransibunt aquæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "Potabunt omnes bestiæ agri; expectabunt onagri in siti sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "Super ea volucres cæli habitabunt; de medio petrarum dabunt voces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "Rigans montes de superioribus suis; de fructu operum tuorum satiabitur terra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "producens fœnum jumentis, et herbam servituti hominum, ut educas panem de terra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "et vinum lætificet cor hominis: ut exhilaret faciem in oleo, et panis cor hominis confirmet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "Saturabuntur ligna campi, et cedri Libani quas plantavit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "illic passeres nidificabunt: herodii domus dux est eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "Montes excelsi cervis; petra refugium herinaciis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "Fecit lunam in tempora; sol cognovit occasum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Posuisti tenebras, et facta est nox; in ipsa pertransibunt omnes bestiæ silvæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "catuli leonum rugientes ut rapiant, et quærant a Deo escam sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "Ortus est sol, et congregati sunt, et in cubilibus suis collocabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 23,
      "referenceLabel": "Psalms 103:23",
      "text": "Exibit homo ad opus suum, et ad operationem suam usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 24,
      "referenceLabel": "Psalms 103:24",
      "text": "Quam magnificata sunt opera tua, Domine! omnia in sapientia fecisti; impleta est terra possessione tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 25,
      "referenceLabel": "Psalms 103:25",
      "text": "Hoc mare magnum et spatiosum manibus; illic reptilia quorum non est numerus: animalia pusilla cum magnis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 26,
      "referenceLabel": "Psalms 103:26",
      "text": "Illic naves pertransibunt; draco iste quem formasti ad illudendum ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 27,
      "referenceLabel": "Psalms 103:27",
      "text": "Omnia a te expectant ut des illis escam in tempore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 28,
      "referenceLabel": "Psalms 103:28",
      "text": "Dante te illis, colligent; aperiente te manum tuam, omnia implebuntur bonitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 29,
      "referenceLabel": "Psalms 103:29",
      "text": "Avertente autem te faciem, turbabuntur; auferes spiritum eorum, et deficient, et in pulverem suum revertentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 30,
      "referenceLabel": "Psalms 103:30",
      "text": "Emittes spiritum tuum, et creabuntur, et renovabis faciem terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 31,
      "referenceLabel": "Psalms 103:31",
      "text": "Sit gloria Domini in sæculum; lætabitur Dominus in operibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 32,
      "referenceLabel": "Psalms 103:32",
      "text": "Qui respicit terram, et facit eam tremere; qui tangit montes, et fumigant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 33,
      "referenceLabel": "Psalms 103:33",
      "text": "Cantabo Domino in vita mea; psallam Deo meo quamdiu sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 34,
      "referenceLabel": "Psalms 103:34",
      "text": "Jucundum sit ei eloquium meum; ego vero delectabor in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.103.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 35,
      "referenceLabel": "Psalms 103:35",
      "text": "Deficiant peccatores a terra, et iniqui, ita ut non sint. Benedic, anima mea, Domino.",
      "paragraphStart": false
    }
  ]
}
