{
  "chapter": {
    "id": "vulgate:psalms.51",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.51.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "In finem. Intellectus David,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.51.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "cum venit Doëg Idumæus, et nuntiavit Sauli: Venit David in domum Achimelech.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "Quid gloriaris in malitia, qui potens es in iniquitate?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "Tota die injustitiam cogitavit lingua tua; sicut novacula acuta fecisti dolum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "Dilexisti malitiam super benignitatem; iniquitatem magis quam loqui æquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "Dilexisti omnia verba præcipitationis; lingua dolosa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "Propterea Deus destruet te in finem; evellet te, et emigrabit te de tabernaculo tuo, et radicem tuam de terra viventium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "Videbunt justi, et timebunt; et super eum ridebunt, et dicent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "Ecce homo qui non posuit Deum adjutorem suum; sed speravit in multitudine divitiarum suarum, et prævaluit in vanitate sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "Ego autem, sicut oliva fructifera in domo Dei; speravi in misericordia Dei, in æternum et in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.51.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "Confitebor tibi in sæculum, quia fecisti; et exspectabo nomen tuum, quoniam bonum est in conspectu sanctorum tuorum.",
      "paragraphStart": false
    }
  ]
}
