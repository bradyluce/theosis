{
  "chapter": {
    "id": "vulgate:psalms.73",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 73,
    "referenceLabel": "Psalms 73",
    "summary": "Source text for Psalms 73 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.73.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 1,
      "referenceLabel": "Psalms 73:1",
      "text": "Intellectus Asaph. Ut quid, Deus, repulisti in finem, iratus est furor tuus super oves pascuæ tuæ?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.73.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 2,
      "referenceLabel": "Psalms 73:2",
      "text": "Memor esto congregationis tuæ, quam possedisti ab initio. Redemisti virgam hæreditatis tuæ, mons Sion, in quo habitasti in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 3,
      "referenceLabel": "Psalms 73:3",
      "text": "Leva manus tuas in superbias eorum in finem: quanta malignatus est inimicus in sancto!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 4,
      "referenceLabel": "Psalms 73:4",
      "text": "Et gloriati sunt qui oderunt te in medio solemnitatis tuæ; posuerunt signa sua, signa:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 5,
      "referenceLabel": "Psalms 73:5",
      "text": "et non cognoverunt sicut in exitu super summum. Quasi in silva lignorum securibus",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 6,
      "referenceLabel": "Psalms 73:6",
      "text": "exciderunt januas ejus in idipsum; in securi et ascia dejecerunt eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 7,
      "referenceLabel": "Psalms 73:7",
      "text": "Incenderunt igni sanctuarium tuum; in terra polluerunt tabernaculum nominis tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 8,
      "referenceLabel": "Psalms 73:8",
      "text": "Dixerunt in corde suo cognatio eorum simul: Quiescere faciamus omnes dies festos Dei a terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 9,
      "referenceLabel": "Psalms 73:9",
      "text": "Signa nostra non vidimus; jam non est propheta; et nos non cognoscet amplius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 10,
      "referenceLabel": "Psalms 73:10",
      "text": "Usquequo, Deus, improperabit inimicus? irritat adversarius nomen tuum in finem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 11,
      "referenceLabel": "Psalms 73:11",
      "text": "Ut quid avertis manum tuam, et dexteram tuam de medio sinu tuo in finem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 12,
      "referenceLabel": "Psalms 73:12",
      "text": "Deus autem rex noster ante sæcula: operatus est salutem in medio terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 13,
      "referenceLabel": "Psalms 73:13",
      "text": "Tu confirmasti in virtute tua mare; contribulasti capita draconum in aquis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 14,
      "referenceLabel": "Psalms 73:14",
      "text": "Tu confregisti capita draconis; dedisti eum escam populis Æthiopum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 15,
      "referenceLabel": "Psalms 73:15",
      "text": "Tu dirupisti fontes et torrentes; tu siccasti fluvios Ethan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 16,
      "referenceLabel": "Psalms 73:16",
      "text": "Tuus est dies, et tua est nox; tu fabricatus es auroram et solem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 17,
      "referenceLabel": "Psalms 73:17",
      "text": "Tu fecisti omnes terminos terræ; æstatem et ver tu plasmasti ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 18,
      "referenceLabel": "Psalms 73:18",
      "text": "Memor esto hujus: inimicus improperavit Domino, et populus insipiens incitavit nomen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 19,
      "referenceLabel": "Psalms 73:19",
      "text": "Ne tradas bestiis animas confitentes tibi, et animas pauperum tuorum ne obliviscaris in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 20,
      "referenceLabel": "Psalms 73:20",
      "text": "Respice in testamentum tuum, quia repleti sunt qui obscurati sunt terræ domibus iniquitatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 21,
      "referenceLabel": "Psalms 73:21",
      "text": "Ne avertatur humilis factus confusus; pauper et inops laudabunt nomen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 22,
      "referenceLabel": "Psalms 73:22",
      "text": "Exsurge, Deus, judica causam tuam; memor esto improperiorum tuorum, eorum quæ ab insipiente sunt tota die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.73.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 23,
      "referenceLabel": "Psalms 73:23",
      "text": "Ne obliviscaris voces inimicorum tuorum: superbia eorum qui te oderunt ascendit semper.",
      "paragraphStart": false
    }
  ]
}
