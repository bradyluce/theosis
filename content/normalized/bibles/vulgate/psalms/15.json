{
  "chapter": {
    "id": "vulgate:psalms.15",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 15,
    "referenceLabel": "Psalms 15",
    "summary": "Source text for Psalms 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.15.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Psalms 15:1",
      "text": "Tituli inscriptio, ipsi David. Conserva me, Domine, quoniam speravi in te.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.15.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Psalms 15:2",
      "text": "Dixi Domino: Deus meus es tu, quoniam bonorum meorum non eges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Psalms 15:3",
      "text": "Sanctis qui sunt in terra ejus, mirificavit omnes voluntates meas in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Psalms 15:4",
      "text": "Multiplicatæ sunt infirmitates eorum: postea acceleraverunt. Non congregabo conventicula eorum de sanguinibus, nec memor ero nominum eorum per labia mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Psalms 15:5",
      "text": "Dominus pars hæreditatis meæ, et calicis mei: tu es qui restitues hæreditatem meam mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Psalms 15:6",
      "text": "Funes ceciderunt mihi in præclaris; etenim hæreditas mea præclara est mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Psalms 15:7",
      "text": "Benedicam Dominum qui tribuit mihi intellectum; insuper et usque ad noctem increpuerunt me renes mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Psalms 15:8",
      "text": "Providebam Dominum in conspectu meo semper: quoniam a dextris est mihi, ne commovear.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Psalms 15:9",
      "text": "Propter hoc lætatum est cor meum, et exsultavit lingua mea; insuper et caro mea requiescet in spe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.15.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Psalms 15:10",
      "text": "Quoniam non derelinques animam meam in inferno, nec dabis sanctum tuum videre corruptionem. Notas mihi fecisti vias vitæ; adimplebis me lætitia cum vultu tuo: delectationes in dextera tua usque in finem.",
      "paragraphStart": false
    }
  ]
}
