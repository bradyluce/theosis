{
  "chapter": {
    "id": "vulgate:psalms.102",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.102.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "Ipsi David. Benedic, anima mea, Domino, et omnia quæ intra me sunt nomini sancto ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.102.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "Benedic, anima mea, Domino, et noli oblivisci omnes retributiones ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "Qui propitiatur omnibus iniquitatibus tuis; qui sanat omnes infirmitates tuas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "qui redimit de interitu vitam tuam; qui coronat te in misericordia et miserationibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "qui replet in bonis desiderium tuum; renovabitur ut aquilæ juventus tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "faciens misericordias Dominus, et judicium omnibus injuriam patientibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "Notas fecit vias suas Moysi; filiis Israël voluntates suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "Miserator et misericors Dominus: longanimis, et multum misericors.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "Non in perpetuum irascetur, neque in æternum comminabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "Non secundum peccata nostra fecit nobis, neque secundum iniquitates nostras retribuit nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "Quoniam secundum altitudinem cæli a terra, corroboravit misericordiam suam super timentes se;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "quantum distat ortus ab occidente, longe fecit a nobis iniquitates nostras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "Quomodo miseretur pater filiorum, misertus est Dominus timentibus se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "Quoniam ipse cognovit figmentum nostrum; recordatus est quoniam pulvis sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "Homo, sicut fœnum dies ejus; tamquam flos agri, sic efflorebit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "quoniam spiritus pertransibit in illo, et non subsistet, et non cognoscet amplius locum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "Misericordia autem Domini ab æterno, et usque in æternum super timentes eum. Et justitia illius in filios filiorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "his qui servant testamentum ejus, et memores sunt mandatorum ipsius ad faciendum ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "Dominus in cælo paravit sedem suam, et regnum ipsius omnibus dominabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "Benedicite Domino, omnes angeli ejus: potentes virtute, facientes verbum illius, ad audiendam vocem sermonum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "Benedicite Domino, omnes virtutes ejus; ministri ejus, qui facitis voluntatem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.102.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "Benedicite Domino, omnia opera ejus: in omni loco dominationis ejus, benedic, anima mea, Domino.",
      "paragraphStart": false
    }
  ]
}
