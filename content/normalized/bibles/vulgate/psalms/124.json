  },
  "verses": [
    {
      "id": "vulgate:psalms.124.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "Canticum graduum. Qui confidunt in Domino, sicut mons Sion: non commovebitur in æternum, qui habitat",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.124.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "in Jerusalem. Montes in circuitu ejus; et Dominus in circuitu populi sui, ex hoc nunc et usque in sæculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.124.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "Quia non relinquet Dominus virgam peccatorum super sortem justorum: ut non extendant justi ad iniquitatem manus suas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.124.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "benefac, Domine, bonis, et rectis corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.124.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "Declinantes autem in obligationes, adducet Dominus cum operantibus iniquitatem. Pax super Israël!",
      "paragraphStart": false
    }
  ]
}
