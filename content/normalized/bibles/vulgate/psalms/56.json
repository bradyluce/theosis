{
  "chapter": {
    "id": "vulgate:psalms.56",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 56,
    "referenceLabel": "Psalms 56",
    "summary": "Source text for Psalms 56 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.56.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 1,
      "referenceLabel": "Psalms 56:1",
      "text": "In finem, ne disperdas. David in tituli inscriptionem, cum fugeret a facie Saul in speluncam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.56.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 2,
      "referenceLabel": "Psalms 56:2",
      "text": "Miserere mei, Deus, miserere mei, quoniam in te confidit anima mea. Et in umbra alarum tuarum sperabo, donec transeat iniquitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 3,
      "referenceLabel": "Psalms 56:3",
      "text": "Clamabo ad Deum altissimum, Deum qui benefecit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 4,
      "referenceLabel": "Psalms 56:4",
      "text": "Misit de cælo, et liberavit me; dedit in opprobrium conculcantes me. Misit Deus misericordiam suam et veritatem suam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 5,
      "referenceLabel": "Psalms 56:5",
      "text": "et eripuit animam meam de medio catulorum leonum. Dormivi conturbatus. Filii hominum dentes eorum arma et sagittæ, et lingua eorum gladius acutus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 6,
      "referenceLabel": "Psalms 56:6",
      "text": "Exaltare super cælos, Deus, et in omnem terram gloria tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 7,
      "referenceLabel": "Psalms 56:7",
      "text": "Laqueum paraverunt pedibus meis, et incurvaverunt animam meam. Foderunt ante faciem meam foveam, et inciderunt in eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 8,
      "referenceLabel": "Psalms 56:8",
      "text": "Paratum cor meum, Deus, paratum cor meum; cantabo, et psalmum dicam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 9,
      "referenceLabel": "Psalms 56:9",
      "text": "Exsurge, gloria mea; exsurge, psalterium et cithara: exsurgam diluculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 10,
      "referenceLabel": "Psalms 56:10",
      "text": "Confitebor tibi in populis, Domine, et psalmum dicam tibi in gentibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 11,
      "referenceLabel": "Psalms 56:11",
      "text": "quoniam magnificata est usque ad cælos misericordia tua, et usque ad nubes veritas tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.56.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 12,
      "referenceLabel": "Psalms 56:12",
      "text": "Exaltare super cælos, Deus, et super omnem terram gloria tua.",
      "paragraphStart": false
    }
  ]
}
