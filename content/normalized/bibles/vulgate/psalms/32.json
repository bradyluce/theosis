{
  "chapter": {
    "id": "vulgate:psalms.32",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 32,
    "referenceLabel": "Psalms 32",
    "summary": "Source text for Psalms 32 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.32.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Psalms 32:1",
      "text": "Psalmus David. Exsultate, justi, in Domino; rectos decet collaudatio.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.32.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Psalms 32:2",
      "text": "Confitemini Domino in cithara; in psalterio decem chordarum psallite illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Psalms 32:3",
      "text": "Cantate ei canticum novum; bene psallite ei in vociferatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Psalms 32:4",
      "text": "Quia rectum est verbum Domini, et omnia opera ejus in fide.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Psalms 32:5",
      "text": "Diligit misericordiam et judicium; misericordia Domini plena est terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Psalms 32:6",
      "text": "Verbo Domini cæli firmati sunt, et spiritu oris ejus omnis virtus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Psalms 32:7",
      "text": "Congregans sicut in utre aquas maris; ponens in thesauris abyssos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Psalms 32:8",
      "text": "Timeat Dominum omnis terra; ab eo autem commoveantur omnes inhabitantes orbem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Psalms 32:9",
      "text": "Quoniam ipse dixit, et facta sunt; ipse mandavit et creata sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Psalms 32:10",
      "text": "Dominus dissipat consilia gentium; reprobat autem cogitationes populorum, et reprobat consilia principum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Psalms 32:11",
      "text": "Consilium autem Domini in æternum manet; cogitationes cordis ejus in generatione et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Psalms 32:12",
      "text": "Beata gens cujus est Dominus Deus ejus; populus quem elegit in hæreditatem sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Psalms 32:13",
      "text": "De cælo respexit Dominus; vidit omnes filios hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Psalms 32:14",
      "text": "De præparato habitaculo suo respexit super omnes qui habitant terram:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Psalms 32:15",
      "text": "qui finxit sigillatim corda eorum; qui intelligit omnia opera eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Psalms 32:16",
      "text": "Non salvatur rex per multam virtutem, et gigas non salvabitur in multitudine virtutis suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Psalms 32:17",
      "text": "Fallax equus ad salutem; in abundantia autem virtutis suæ non salvabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Psalms 32:18",
      "text": "Ecce oculi Domini super metuentes eum, et in eis qui sperant super misericordia ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Psalms 32:19",
      "text": "ut eruat a morte animas eorum, et alat eos in fame.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Psalms 32:20",
      "text": "Anima nostra sustinet Dominum, quoniam adjutor et protector noster est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Psalms 32:21",
      "text": "Quia in eo lætabitur cor nostrum, et in nomine sancto ejus speravimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.32.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Psalms 32:22",
      "text": "Fiat misericordia tua, Domine, super nos, quemadmodum speravimus in te.",
      "paragraphStart": false
    }
  ]
}
