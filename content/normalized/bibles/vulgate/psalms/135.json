{
  "chapter": {
    "id": "vulgate:psalms.135",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.135.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Alleluja. Confitemini Domino, quoniam bonus, quoniam in æternum misericordia ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.135.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "Confitemini Deo deorum, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Confitemini Domino dominorum, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "Qui facit mirabilia magna solus, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "Qui fecit cælos in intellectu, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Qui firmavit terram super aquas, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "Qui fecit luminaria magna, quoniam in æternum misericordia ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "solem in potestatem diei, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "lunam et stellas in potestatem noctis, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "Qui percussit Ægyptum cum primogenitis eorum, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "Qui eduxit Israël de medio eorum, quoniam in æternum misericordia ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "in manu potenti et brachio excelso, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Qui divisit mare Rubrum in divisiones, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "et eduxit Israël per medium ejus, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "et excussit Pharaonem et virtutem ejus in mari Rubro, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "Qui traduxit populum suum per desertum, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "Qui percussit reges magnos, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "et occidit reges fortes, quoniam in æternum misericordia ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "Sehon, regem Amorrhæorum, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "et Og, regem Basan, quoniam in æternum misericordia ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "et dedit terram eorum hæreditatem, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 22,
      "referenceLabel": "Psalms 135:22",
      "text": "hæreditatem Israël, servo suo, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 23,
      "referenceLabel": "Psalms 135:23",
      "text": "Quia in humilitate nostra memor fuit nostri, quoniam in æternum misericordia ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 24,
      "referenceLabel": "Psalms 135:24",
      "text": "et redemit nos ab inimicis nostris, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 25,
      "referenceLabel": "Psalms 135:25",
      "text": "Qui dat escam omni carni, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.135.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 26,
      "referenceLabel": "Psalms 135:26",
      "text": "Confitemini Deo cæli, quoniam in æternum misericordia ejus. Confitemini Domino dominorum, quoniam in æternum misericordia ejus.",
      "paragraphStart": false
    }
  ]
}
