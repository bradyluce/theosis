{
  "chapter": {
    "id": "vulgate:psalms.112",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.112.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Alleluja. Laudate, pueri, Dominum; laudate nomen Domini.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.112.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "Sit nomen Domini benedictum ex hoc nunc et usque in sæculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "A solis ortu usque ad occasum laudabile nomen Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "Excelsus super omnes gentes Dominus, et super cælos gloria ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "Quis sicut Dominus Deus noster, qui in altis habitat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "et humilia respicit in cælo et in terra?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "Suscitans a terra inopem, et de stercore erigens pauperem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "ut collocet eum cum principibus, cum principibus populi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.112.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "Qui habitare facit sterilem in domo, matrem filiorum lætantem.",
      "paragraphStart": false
    }
  ]
}
