      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 1,
      "referenceLabel": "Psalms 132:1",
      "text": "Canticum graduum David. Ecce quam bonum et quam jucundum, habitare fratres in unum!",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.132.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 2,
      "referenceLabel": "Psalms 132:2",
      "text": "Sicut unguentum in capite, quod descendit in barbam, barbam Aaron, quod descendit in oram vestimenti ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.132.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 3,
      "referenceLabel": "Psalms 132:3",
      "text": "sicut ros Hermon, qui descendit in montem Sion. Quoniam illic mandavit Dominus benedictionem, et vitam usque in sæculum.",
      "paragraphStart": false
    }
  ]
}
