{
  "chapter": {
    "id": "vulgate:psalms.49",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 49,
    "referenceLabel": "Psalms 49",
    "summary": "Source text for Psalms 49 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.49.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 1,
      "referenceLabel": "Psalms 49:1",
      "text": "Psalmus Asaph. Deus deorum Dominus locutus est, et vocavit terram a solis ortu usque ad occasum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.49.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 2,
      "referenceLabel": "Psalms 49:2",
      "text": "Ex Sion species decoris ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 3,
      "referenceLabel": "Psalms 49:3",
      "text": "Deus manifeste veniet; Deus noster, et non silebit. Ignis in conspectu ejus exardescet; et in circuitu ejus tempestas valida.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 4,
      "referenceLabel": "Psalms 49:4",
      "text": "Advocabit cælum desursum, et terram, discernere populum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 5,
      "referenceLabel": "Psalms 49:5",
      "text": "Congregate illi sanctos ejus, qui ordinant testamentum ejus super sacrificia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 6,
      "referenceLabel": "Psalms 49:6",
      "text": "Et annuntiabunt cæli justitiam ejus, quoniam Deus judex est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 7,
      "referenceLabel": "Psalms 49:7",
      "text": "Audi, populus meus, et loquar; Israël, et testificabor tibi: Deus, Deus tuus ego sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 8,
      "referenceLabel": "Psalms 49:8",
      "text": "Non in sacrificiis tuis arguam te; holocausta autem tua in conspectu meo sunt semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 9,
      "referenceLabel": "Psalms 49:9",
      "text": "Non accipiam de domo tua vitulos, neque de gregibus tuis hircos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 10,
      "referenceLabel": "Psalms 49:10",
      "text": "quoniam meæ sunt omnes feræ silvarum, jumenta in montibus, et boves.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 11,
      "referenceLabel": "Psalms 49:11",
      "text": "Cognovi omnia volatilia cæli, et pulchritudo agri mecum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 12,
      "referenceLabel": "Psalms 49:12",
      "text": "Si esuriero, non dicam tibi: meus est enim orbis terræ et plenitudo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 13,
      "referenceLabel": "Psalms 49:13",
      "text": "Numquid manducabo carnes taurorum? aut sanguinem hircorum potabo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 14,
      "referenceLabel": "Psalms 49:14",
      "text": "Immola Deo sacrificium laudis, et redde Altissimo vota tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 15,
      "referenceLabel": "Psalms 49:15",
      "text": "Et invoca me in die tribulationis: eruam te, et honorificabis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 16,
      "referenceLabel": "Psalms 49:16",
      "text": "Peccatori autem dixit Deus: Quare tu enarras justitias meas? et assumis testamentum meum per os tuum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 17,
      "referenceLabel": "Psalms 49:17",
      "text": "Tu vero odisti disciplinam, et projecisti sermones meos retrorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 18,
      "referenceLabel": "Psalms 49:18",
      "text": "Si videbas furem, currebas cum eo; et cum adulteris portionem tuam ponebas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 19,
      "referenceLabel": "Psalms 49:19",
      "text": "Os tuum abundavit malitia, et lingua tua concinnabat dolos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 20,
      "referenceLabel": "Psalms 49:20",
      "text": "Sedens adversus fratrem tuum loquebaris, et adversus filium matris tuæ ponebas scandalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 21,
      "referenceLabel": "Psalms 49:21",
      "text": "Hæc fecisti, et tacui. Existimasti inique quod ero tui similis: arguam te, et statuam contra faciem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 22,
      "referenceLabel": "Psalms 49:22",
      "text": "Intelligite hæc, qui obliviscimini Deum, nequando rapiat, et non sit qui eripiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.49.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 49,
      "verseNumber": 23,
      "referenceLabel": "Psalms 49:23",
      "text": "Sacrificium laudis honorificabit me, et illic iter quo ostendam illi salutare Dei.",
      "paragraphStart": false
    }
  ]
}
