{
  "chapter": {
    "id": "vulgate:psalms.121",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.121.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "Canticum graduum. Lætatus sum in his quæ dicta sunt mihi: In domum Domini ibimus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.121.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "Stantes erant pedes nostri in atriis tuis, Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "Jerusalem, quæ ædificatur ut civitas, cujus participatio ejus in idipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "Illuc enim ascenderunt tribus, tribus Domini: testimonium Israël, ad confitendum nomini Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "Quia illic sederunt sedes in judicio, sedes super domum David.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "Rogate quæ ad pacem sunt Jerusalem, et abundantia diligentibus te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "Fiat pax in virtute tua, et abundantia in turribus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "Propter fratres meos et proximos meos, loquebar pacem de te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.121.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 9,
      "referenceLabel": "Psalms 121:9",
      "text": "Propter domum Domini Dei nostri, quæsivi bona tibi.",
      "paragraphStart": false
    }
  ]
}
