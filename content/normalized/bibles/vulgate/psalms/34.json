{
  "chapter": {
    "id": "vulgate:psalms.34",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.34.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "Ipsi David. Judica, Domine, nocentes me; expugna impugnantes me.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.34.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "Apprehende arma et scutum, et exsurge in adjutorium mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "Effunde frameam, et conclude adversus eos qui persequuntur me; dic animæ meæ: Salus tua ego sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "Confundantur et revereantur quærentes animam meam; avertantur retrorsum et confundantur cogitantes mihi mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "Fiant tamquam pulvis ante faciem venti, et angelus Domini coarctans eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "Fiat via illorum tenebræ et lubricum, et angelus Domini persequens eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "Quoniam gratis absconderunt mihi interitum laquei sui; supervacue exprobraverunt animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "Veniat illi laqueus quem ignorat, et captio quam abscondit apprehendat eum, et in laqueum cadat in ipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "Anima autem mea exsultabit in Domino, et delectabitur super salutari suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "Omnia ossa mea dicent: Domine, quis similis tibi? eripiens inopem de manu fortiorum ejus; egenum et pauperem a diripientibus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "Surgentes testes iniqui, quæ ignorabam interrogabant me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "Retribuebant mihi mala pro bonis, sterilitatem animæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "Ego autem, cum mihi molesti essent, induebar cilicio; humiliabam in jejunio animam meam, et oratio mea in sinu meo convertetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "Quasi proximum et quasi fratrem nostrum sic complacebam; quasi lugens et contristatus sic humiliabar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "Et adversum me lætati sunt, et convenerunt; congregata sunt super me flagella, et ignoravi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "Dissipati sunt, nec compuncti; tentaverunt me, subsannaverunt me subsannatione; frenduerunt super me dentibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "Domine, quando respicies? Restitue animam meam a malignitate eorum; a leonibus unicam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "Confitebor tibi in ecclesia magna; in populo gravi laudabo te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "Non supergaudeant mihi qui adversantur mihi inique, qui oderunt me gratis, et annuunt oculis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "Quoniam mihi quidem pacifice loquebantur; et in iracundia terræ loquentes, dolos cogitabant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "Et dilataverunt super me os suum; dixerunt: Euge, euge! viderunt oculi nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "Vidisti, Domine: ne sileas; Domine, ne discedas a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Psalms 34:23",
      "text": "Exsurge et intende judicio meo, Deus meus; et Dominus meus, in causam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Psalms 34:24",
      "text": "Judica me secundum justitiam tuam, Domine Deus meus, et non supergaudeant mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Psalms 34:25",
      "text": "Non dicant in cordibus suis: Euge, euge, animæ nostræ; nec dicant: Devoravimus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Psalms 34:26",
      "text": "Erubescant et revereantur simul qui gratulantur malis meis; induantur confusione et reverentia qui magna loquuntur super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Psalms 34:27",
      "text": "Exsultent et lætentur qui volunt justitiam meam; et dicant semper: Magnificetur Dominus, qui volunt pacem servi ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.34.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Psalms 34:28",
      "text": "Et lingua mea meditabitur justitiam tuam; tota die laudem tuam.",
      "paragraphStart": false
    }
  ]
}
