{
  "chapter": {
    "id": "vulgate:psalms.50",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.50.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "In finem. Psalmus David,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.50.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "cum venit ad eum Nathan propheta, quando intravit ad Bethsabee.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Miserere mei, Deus, secundum magnam misericordiam tuam; et secundum multitudinem miserationum tuarum, dele iniquitatem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "Amplius lava me ab iniquitate mea, et a peccato meo munda me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "Quoniam iniquitatem meam ego cognosco, et peccatum meum contra me est semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "Tibi soli peccavi, et malum coram te feci; ut justificeris in sermonibus tuis, et vincas cum judicaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "Ecce enim in iniquitatibus conceptus sum, et in peccatis concepit me mater mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "Ecce enim veritatem dilexisti; incerta et occulta sapientiæ tuæ manifestasti mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "Asperges me hyssopo, et mundabor; lavabis me, et super nivem dealbabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "Auditui meo dabis gaudium et lætitiam, et exsultabunt ossa humiliata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "Averte faciem tuam a peccatis meis, et omnes iniquitates meas dele.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "Cor mundum crea in me, Deus, et spiritum rectum innova in visceribus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Ne projicias me a facie tua, et spiritum sanctum tuum ne auferas a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Redde mihi lætitiam salutaris tui, et spiritu principali confirma me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "Docebo iniquos vias tuas, et impii ad te convertentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "Libera me de sanguinibus, Deus, Deus salutis meæ, et exsultabit lingua mea justitiam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "Domine, labia mea aperies, et os meum annuntiabit laudem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "Quoniam si voluisses sacrificium, dedissem utique; holocaustis non delectaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "Sacrificium Deo spiritus contribulatus; cor contritum et humiliatum, Deus, non despicies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "Benigne fac, Domine, in bona voluntate tua Sion, ut ædificentur muri Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.50.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "Tunc acceptabis sacrificium justitiæ, oblationes et holocausta; tunc imponent super altare tuum vitulos.",
      "paragraphStart": false
    }
  ]
}
