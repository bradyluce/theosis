{
  "chapter": {
    "id": "vulgate:psalms.109",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.109.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "Psalmus David. Dixit Dominus Domino meo: Sede a dextris meis, donec ponam inimicos tuos scabellum pedum tuorum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.109.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "Virgam virtutis tuæ emittet Dominus ex Sion: dominare in medio inimicorum tuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.109.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "Tecum principium in die virtutis tuæ in splendoribus sanctorum: ex utero, ante luciferum, genui te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.109.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "Juravit Dominus, et non pœnitebit eum: Tu es sacerdos in æternum secundum ordinem Melchisedech.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.109.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "Dominus a dextris tuis; confregit in die iræ suæ reges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.109.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "Judicabit in nationibus, implebit ruinas; conquassabit capita in terra multorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.109.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "De torrente in via bibet; propterea exaltabit caput.",
      "paragraphStart": false
    }
  ]
}
