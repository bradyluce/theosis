{
  "chapter": {
    "id": "vulgate:psalms.119",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 119,
    "referenceLabel": "Psalms 119",
    "summary": "Source text for Psalms 119 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.119.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 1,
      "referenceLabel": "Psalms 119:1",
      "text": "Canticum graduum. Ad Dominum cum tribularer clamavi, et exaudivit me.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.119.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 2,
      "referenceLabel": "Psalms 119:2",
      "text": "Domine, libera animam meam a labiis iniquis et a lingua dolosa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.119.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 3,
      "referenceLabel": "Psalms 119:3",
      "text": "Quid detur tibi, aut quid apponatur tibi ad linguam dolosam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.119.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 4,
      "referenceLabel": "Psalms 119:4",
      "text": "Sagittæ potentis acutæ, cum carbonibus desolatoriis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.119.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 5,
      "referenceLabel": "Psalms 119:5",
      "text": "Heu mihi, quia incolatus meus prolongatus est! habitavi cum habitantibus Cedar;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.119.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 6,
      "referenceLabel": "Psalms 119:6",
      "text": "multum incola fuit anima mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.119.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 7,
      "referenceLabel": "Psalms 119:7",
      "text": "Cum his qui oderunt pacem eram pacificus; cum loquebar illis, impugnabant me gratis.",
      "paragraphStart": false
    }
  ]
}
