{
  "chapter": {
    "id": "vulgate:psalms.25",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.25.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "In finem. Psalmus David. Judica me, Domine, quoniam ego in innocentia mea ingressus sum, et in Domino sperans non infirmabor.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.25.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "Proba me, Domine, et tenta me; ure renes meos et cor meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "Quoniam misericordia tua ante oculos meos est, et complacui in veritate tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "Non sedi cum concilio vanitatis, et cum iniqua gerentibus non introibo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "Odivi ecclesiam malignantium, et cum impiis non sedebo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "Lavabo inter innocentes manus meas, et circumdabo altare tuum, Domine:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "ut audiam vocem laudis, et enarrem universa mirabilia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "Domine, dilexi decorem domus tuæ, et locum habitationis gloriæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "Ne perdas cum impiis, Deus, animam meam, et cum viris sanguinum vitam meam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "in quorum manibus iniquitates sunt; dextera eorum repleta est muneribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "Ego autem in innocentia mea ingressus sum; redime me, et miserere mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.25.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "Pes meus stetit in directo; in ecclesiis benedicam te, Domine.",
      "paragraphStart": false
    }
  ]
}
