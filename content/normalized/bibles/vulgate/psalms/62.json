{
  "chapter": {
    "id": "vulgate:psalms.62",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 62,
    "referenceLabel": "Psalms 62",
    "summary": "Source text for Psalms 62 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.62.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 1,
      "referenceLabel": "Psalms 62:1",
      "text": "Psalmus David, cum esset in deserto Idumææ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.62.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 2,
      "referenceLabel": "Psalms 62:2",
      "text": "Deus, Deus meus, ad te de luce vigilo. Sitivit in te anima mea; quam multipliciter tibi caro mea!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 3,
      "referenceLabel": "Psalms 62:3",
      "text": "In terra deserta, et invia, et inaquosa, sic in sancto apparui tibi, ut viderem virtutem tuam et gloriam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 4,
      "referenceLabel": "Psalms 62:4",
      "text": "Quoniam melior est misericordia tua super vitas, labia mea laudabunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 5,
      "referenceLabel": "Psalms 62:5",
      "text": "Sic benedicam te in vita mea, et in nomine tuo levabo manus meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 6,
      "referenceLabel": "Psalms 62:6",
      "text": "Sicut adipe et pinguedine repleatur anima mea, et labiis exsultationis laudabit os meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 7,
      "referenceLabel": "Psalms 62:7",
      "text": "Si memor fui tui super stratum meum, in matutinis meditabor in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 8,
      "referenceLabel": "Psalms 62:8",
      "text": "Quia fuisti adjutor meus, et in velamento alarum tuarum exsultabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 9,
      "referenceLabel": "Psalms 62:9",
      "text": "Adhæsit anima mea post te; me suscepit dextera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 10,
      "referenceLabel": "Psalms 62:10",
      "text": "Ipsi vero in vanum quæsierunt animam meam: introibunt in inferiora terræ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 11,
      "referenceLabel": "Psalms 62:11",
      "text": "tradentur in manus gladii: partes vulpium erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.62.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 12,
      "referenceLabel": "Psalms 62:12",
      "text": "Rex vero lætabitur in Deo; laudabuntur omnes qui jurant in eo: quia obstructum est os loquentium iniqua.",
      "paragraphStart": false
    }
  ]
}
