{
  "chapter": {
    "id": "vulgate:psalms.115",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.115.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Alleluja. Credidi, propter quod locutus sum; ego autem humiliatus sum nimis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.115.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "Ego dixi in excessu meo: Omnis homo mendax.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "Quid retribuam Domino pro omnibus quæ retribuit mihi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "Calicem salutaris accipiam, et nomen Domini invocabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "Vota mea Domino reddam coram omni populo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "Pretiosa in conspectu Domini mors sanctorum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "O Domine, quia ego servus tuus; ego servus tuus, et filius ancillæ tuæ. Dirupisti vincula mea:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "tibi sacrificabo hostiam laudis, et nomen Domini invocabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "Vota mea Domino reddam in conspectu omnis populi ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.115.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "in atriis domus Domini, in medio tui, Jerusalem.",
      "paragraphStart": false
    }
  ]
}
