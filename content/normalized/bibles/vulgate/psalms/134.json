{
  "chapter": {
    "id": "vulgate:psalms.134",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 134,
    "referenceLabel": "Psalms 134",
    "summary": "Source text for Psalms 134 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.134.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 1,
      "referenceLabel": "Psalms 134:1",
      "text": "Alleluja. Laudate nomen Domini; laudate, servi, Dominum:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.134.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 2,
      "referenceLabel": "Psalms 134:2",
      "text": "qui statis in domo Domini, in atriis domus Dei nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 3,
      "referenceLabel": "Psalms 134:3",
      "text": "Laudate Dominum, quia bonus Dominus; psallite nomini ejus, quoniam suave.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 4,
      "referenceLabel": "Psalms 134:4",
      "text": "Quoniam Jacob elegit sibi Dominus; Israël in possessionem sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 5,
      "referenceLabel": "Psalms 134:5",
      "text": "Quia ego cognovi quod magnus est Dominus, et Deus noster præ omnibus diis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 6,
      "referenceLabel": "Psalms 134:6",
      "text": "Omnia quæcumque voluit Dominus fecit, in cælo, in terra, in mari et in omnibus abyssis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 7,
      "referenceLabel": "Psalms 134:7",
      "text": "Educens nubes ab extremo terræ, fulgura in pluviam fecit; qui producit ventos de thesauris suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 8,
      "referenceLabel": "Psalms 134:8",
      "text": "Qui percussit primogenita Ægypti, ab homine usque ad pecus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 9,
      "referenceLabel": "Psalms 134:9",
      "text": "Et misit signa et prodigia in medio tui, Ægypte: in Pharaonem, et in omnes servos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 10,
      "referenceLabel": "Psalms 134:10",
      "text": "Qui percussit gentes multas, et occidit reges fortes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 11,
      "referenceLabel": "Psalms 134:11",
      "text": "Sehon, regem Amorrhæorum, et Og, regem Basan, et omnia regna Chanaan:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 12,
      "referenceLabel": "Psalms 134:12",
      "text": "et dedit terram eorum hæreditatem, hæreditatem Israël populo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 13,
      "referenceLabel": "Psalms 134:13",
      "text": "Domine, nomen tuum in æternum; Domine, memoriale tuum in generationem et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 14,
      "referenceLabel": "Psalms 134:14",
      "text": "Quia judicabit Dominus populum suum, et in servis suis deprecabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 15,
      "referenceLabel": "Psalms 134:15",
      "text": "Simulacra gentium argentum et aurum, opera manuum hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 16,
      "referenceLabel": "Psalms 134:16",
      "text": "Os habent, et non loquentur; oculos habent, et non videbunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 17,
      "referenceLabel": "Psalms 134:17",
      "text": "Aures habent, et non audient; neque enim est spiritus in ore ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 18,
      "referenceLabel": "Psalms 134:18",
      "text": "Similes illis fiant qui faciunt ea, et omnes qui confidunt in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 19,
      "referenceLabel": "Psalms 134:19",
      "text": "Domus Israël, benedicite Domino; domus Aaron, benedicite Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 20,
      "referenceLabel": "Psalms 134:20",
      "text": "Domus Levi, benedicite Domino; qui timetis Dominum, benedicite Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.134.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 21,
      "referenceLabel": "Psalms 134:21",
      "text": "Benedictus Dominus ex Sion, qui habitat in Jerusalem.",
      "paragraphStart": false
    }
  ]
}
