{
  "chapter": {
    "id": "vulgate:psalms.11",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 11,
    "referenceLabel": "Psalms 11",
    "summary": "Source text for Psalms 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.11.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "In finem, pro octava. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.11.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "Salvum me fac, Domine, quoniam defecit sanctus, quoniam diminutæ sunt veritates a filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "Vana locuti sunt unusquisque ad proximum suum; labia dolosa, in corde et corde locuti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "Disperdat Dominus universa labia dolosa, et linguam magniloquam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "Qui dixerunt: Linguam nostram magnificabimus; labia nostra a nobis sunt. Quis noster dominus est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "Propter miseriam inopum, et gemitum pauperum, nunc exsurgam, dicit Dominus. Ponam in salutari; fiducialiter agam in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "Eloquia Domini, eloquia casta; argentum igne examinatum, probatum terræ, purgatum septuplum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Psalms 11:8",
      "text": "Tu, Domine, servabis nos, et custodies nos a generatione hac in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.11.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Psalms 11:9",
      "text": "In circuitu impii ambulant: secundum altitudinem tuam multiplicasti filios hominum.",
      "paragraphStart": false
    }
  ]
}
