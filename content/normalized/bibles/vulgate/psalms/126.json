  "verses": [
    {
      "id": "vulgate:psalms.126.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 1,
      "referenceLabel": "Psalms 126:1",
      "text": "Canticum graduum Salomonis. Nisi Dominus ædificaverit domum, in vanum laboraverunt qui ædificant eam. Nisi Dominus custodierit civitatem, frustra vigilat qui custodit eam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.126.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 2,
      "referenceLabel": "Psalms 126:2",
      "text": "Vanum est vobis ante lucem surgere: surgite postquam sederitis, qui manducatis panem doloris. Cum dederit dilectis suis somnum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.126.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 3,
      "referenceLabel": "Psalms 126:3",
      "text": "ecce hæreditas Domini, filii; merces, fructus ventris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.126.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 4,
      "referenceLabel": "Psalms 126:4",
      "text": "Sicut sagittæ in manu potentis, ita filii excussorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.126.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 5,
      "referenceLabel": "Psalms 126:5",
      "text": "Beatus vir qui implevit desiderium suum ex ipsis: non confundetur cum loquetur inimicis suis in porta.",
      "paragraphStart": false
    }
  ]
}
