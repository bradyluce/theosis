{
  "chapter": {
    "id": "vulgate:psalms.17",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 17,
    "referenceLabel": "Psalms 17",
    "summary": "Source text for Psalms 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.17.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Psalms 17:1",
      "text": "In finem. Puero Domini David, qui locutus est Domino verba cantici hujus, in die qua eripuit eum Dominus de manu omnium inimicorum ejus, et de manu Saul, et dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.17.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Psalms 17:2",
      "text": "Diligam te, Domine, fortitudo mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Psalms 17:3",
      "text": "Dominus firmamentum meum, et refugium meum, et liberator meus. Deus meus adjutor meus, et sperabo in eum; protector meus, et cornu salutis meæ, et susceptor meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Psalms 17:4",
      "text": "Laudans invocabo Dominum, et ab inimicis meis salvus ero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Psalms 17:5",
      "text": "Circumdederunt me dolores mortis, et torrentes iniquitatis conturbaverunt me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Psalms 17:6",
      "text": "Dolores inferni circumdederunt me; præoccupaverunt me laquei mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Psalms 17:7",
      "text": "In tribulatione mea invocavi Dominum, et ad Deum meum clamavi: et exaudivit de templo sancto suo vocem meam; et clamor meus in conspectu ejus introivit in aures ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Psalms 17:8",
      "text": "Commota est, et contremuit terra; fundamenta montium conturbata sunt, et commota sunt: quoniam iratus est eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Psalms 17:9",
      "text": "Ascendit fumus in ira ejus, et ignis a facie ejus exarsit; carbones succensi sunt ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Psalms 17:10",
      "text": "Inclinavit cælos, et descendit, et caligo sub pedibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Psalms 17:11",
      "text": "Et ascendit super cherubim, et volavit; volavit super pennas ventorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Psalms 17:12",
      "text": "Et posuit tenebras latibulum suum; in circuitu ejus tabernaculum ejus, tenebrosa aqua in nubibus aëris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Psalms 17:13",
      "text": "Præ fulgore in conspectu ejus nubes transierunt; grando et carbones ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Psalms 17:14",
      "text": "Et intonuit de cælo Dominus, et Altissimus dedit vocem suam: grando et carbones ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Psalms 17:15",
      "text": "Et misit sagittas suas, et dissipavit eos; fulgura multiplicavit, et conturbavit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Psalms 17:16",
      "text": "Et apparuerunt fontes aquarum, et revelata sunt fundamenta orbis terrarum, ab increpatione tua, Domine, ab inspiratione spiritus iræ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Psalms 17:17",
      "text": "Misit de summo, et accepit me; et assumpsit me de aquis multis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Psalms 17:18",
      "text": "Eripuit me de inimicis meis fortissimis, et ab his qui oderunt me. Quoniam confortati sunt super me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Psalms 17:19",
      "text": "prævenerunt me in die afflictionis meæ: et factus est Dominus protector meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Psalms 17:20",
      "text": "Et eduxit me in latitudinem; salvum me fecit, quoniam voluit me,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Psalms 17:21",
      "text": "et retribuet mihi Dominus secundum justitiam meam, et secundum puritatem manuum mearum retribuet mihi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Psalms 17:22",
      "text": "quia custodivi vias Domini, nec impie gessi a Deo meo;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Psalms 17:23",
      "text": "quoniam omnia judicia ejus in conspectu meo, et justitias ejus non repuli a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Psalms 17:24",
      "text": "Et ero immaculatus cum eo; et observabo me ab iniquitate mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Psalms 17:25",
      "text": "Et retribuet mihi Dominus secundum justitiam meam, et secundum puritatem manuum mearum in conspectu oculorum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Psalms 17:26",
      "text": "Cum sancto sanctus eris, et cum viro innocente innocens eris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Psalms 17:27",
      "text": "et cum electo electus eris, et cum perverso perverteris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Psalms 17:28",
      "text": "Quoniam tu populum humilem salvum facies, et oculos superborum humiliabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 29,
      "referenceLabel": "Psalms 17:29",
      "text": "Quoniam tu illuminas lucernam meam, Domine; Deus meus, illumina tenebras meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 30,
      "referenceLabel": "Psalms 17:30",
      "text": "Quoniam in te eripiar a tentatione; et in Deo meo transgrediar murum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 31,
      "referenceLabel": "Psalms 17:31",
      "text": "Deus meus, impolluta via ejus; eloquia Domini igne examinata: protector est omnium sperantium in se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 32,
      "referenceLabel": "Psalms 17:32",
      "text": "Quoniam quis deus præter Dominum? aut quis deus præter Deum nostrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 33,
      "referenceLabel": "Psalms 17:33",
      "text": "Deus qui præcinxit me virtute, et posuit immaculatam viam meam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 34,
      "referenceLabel": "Psalms 17:34",
      "text": "qui perfecit pedes meos tamquam cervorum, et super excelsa statuens me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 35,
      "referenceLabel": "Psalms 17:35",
      "text": "qui docet manus meas ad prælium. Et posuisti, ut arcum æreum, brachia mea,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 36,
      "referenceLabel": "Psalms 17:36",
      "text": "et dedisti mihi protectionem salutis tuæ: et dextera tua suscepit me, et disciplina tua correxit me in finem, et disciplina tua ipsa me docebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 37,
      "referenceLabel": "Psalms 17:37",
      "text": "Dilatasti gressus meos subtus me, et non sunt infirmata vestigia mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 38,
      "referenceLabel": "Psalms 17:38",
      "text": "Persequar inimicos meos, et comprehendam illos; et non convertar donec deficiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 39,
      "referenceLabel": "Psalms 17:39",
      "text": "Confringam illos, nec poterunt stare; cadent subtus pedes meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 40,
      "referenceLabel": "Psalms 17:40",
      "text": "Et præcinxisti me virtute ad bellum, et supplantasti insurgentes in me subtus me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.41",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 41,
      "referenceLabel": "Psalms 17:41",
      "text": "Et inimicos meos dedisti mihi dorsum, et odientes me disperdidisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.42",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 42,
      "referenceLabel": "Psalms 17:42",
      "text": "Clamaverunt, nec erat qui salvos faceret; ad Dominum, nec exaudivit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.43",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 43,
      "referenceLabel": "Psalms 17:43",
      "text": "Et comminuam eos ut pulverem ante faciem venti; ut lutum platearum delebo eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.44",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 44,
      "referenceLabel": "Psalms 17:44",
      "text": "Eripies me de contradictionibus populi; constitues me in caput gentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.45",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 45,
      "referenceLabel": "Psalms 17:45",
      "text": "Populus quem non cognovi servivit mihi; in auditu auris obedivit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.46",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 46,
      "referenceLabel": "Psalms 17:46",
      "text": "Filii alieni mentiti sunt mihi, filii alieni inveterati sunt, et claudicaverunt a semitis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.47",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 47,
      "referenceLabel": "Psalms 17:47",
      "text": "Vivit Dominus, et benedictus Deus meus, et exaltetur Deus salutis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.48",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 48,
      "referenceLabel": "Psalms 17:48",
      "text": "Deus qui das vindictas mihi, et subdis populos sub me; liberator meus de inimicis meis iracundis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.49",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 49,
      "referenceLabel": "Psalms 17:49",
      "text": "Et ab insurgentibus in me exaltabis me; a viro iniquo eripies me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.50",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 50,
      "referenceLabel": "Psalms 17:50",
      "text": "Propterea confitebor tibi in nationibus, Domine, et nomini tuo psalmum dicam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.17.51",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 51,
      "referenceLabel": "Psalms 17:51",
      "text": "magnificans salutes regis ejus, et faciens misericordiam christo suo David, et semini ejus usque in sæculum.",
      "paragraphStart": false
    }
  ]
}
