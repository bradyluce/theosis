{
  "chapter": {
    "id": "vulgate:psalms.61",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.61.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "In finem, pro Idithun. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.61.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "Nonne Deo subjecta erit anima mea? ab ipso enim salutare meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "Nam et ipse Deus meus et salutaris meus; susceptor meus, non movebor amplius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "Quousque irruitis in hominem? interficitis universi vos, tamquam parieti inclinato et maceriæ depulsæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "Verumtamen pretium meum cogitaverunt repellere; cucurri in siti: ore suo benedicebant, et corde suo maledicebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "Verumtamen Deo subjecta esto, anima mea, quoniam ab ipso patientia mea:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "quia ipse Deus meus et salvator meus, adjutor meus, non emigrabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "In Deo salutare meum et gloria mea; Deus auxilii mei, et spes mea in Deo est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 9,
      "referenceLabel": "Psalms 61:9",
      "text": "Sperate in eo, omnis congregatio populi; effundite coram illo corda vestra: Deus adjutor noster in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 10,
      "referenceLabel": "Psalms 61:10",
      "text": "Verumtamen vani filii hominum, mendaces filii hominum in stateris, ut decipiant ipsi de vanitate in idipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 11,
      "referenceLabel": "Psalms 61:11",
      "text": "Nolite sperare in iniquitate, et rapinas nolite concupiscere; divitiæ si affluant, nolite cor apponere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 12,
      "referenceLabel": "Psalms 61:12",
      "text": "Semel locutus est Deus; duo hæc audivi: quia potestas Dei est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.61.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 13,
      "referenceLabel": "Psalms 61:13",
      "text": "et tibi, Domine, misericordia: quia tu reddes unicuique juxta opera sua.",
      "paragraphStart": false
    }
  ]
}
