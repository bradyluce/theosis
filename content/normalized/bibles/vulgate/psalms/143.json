{
  "chapter": {
    "id": "vulgate:psalms.143",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 143,
    "referenceLabel": "Psalms 143",
    "summary": "Source text for Psalms 143 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.143.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 1,
      "referenceLabel": "Psalms 143:1",
      "text": "Psalmus David. Adversus Goliath. Benedictus Dominus Deus meus, qui docet manus meas ad prælium, et digitos meos ad bellum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.143.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 2,
      "referenceLabel": "Psalms 143:2",
      "text": "Misericordia mea et refugium meum; susceptor meus et liberator meus; protector meus, et in ipso speravi, qui subdit populum meum sub me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 3,
      "referenceLabel": "Psalms 143:3",
      "text": "Domine, quid est homo, quia innotuisti ei? aut filius hominis, quia reputas eum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 4,
      "referenceLabel": "Psalms 143:4",
      "text": "Homo vanitati similis factus est; dies ejus sicut umbra prætereunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 5,
      "referenceLabel": "Psalms 143:5",
      "text": "Domine, inclina cælos tuos, et descende; tange montes, et fumigabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 6,
      "referenceLabel": "Psalms 143:6",
      "text": "Fulgura coruscationem, et dissipabis eos; emitte sagittas tuas, et conturbabis eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 7,
      "referenceLabel": "Psalms 143:7",
      "text": "Emitte manum tuam de alto: eripe me, et libera me de aquis multis, de manu filiorum alienorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 8,
      "referenceLabel": "Psalms 143:8",
      "text": "quorum os locutum est vanitatem, et dextera eorum dextera iniquitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 9,
      "referenceLabel": "Psalms 143:9",
      "text": "Deus, canticum novum cantabo tibi; in psalterio decachordo psallam tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 10,
      "referenceLabel": "Psalms 143:10",
      "text": "Qui das salutem regibus, qui redemisti David servum tuum de gladio maligno,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 11,
      "referenceLabel": "Psalms 143:11",
      "text": "eripe me, et erue me de manu filiorum alienorum, quorum os locutum est vanitatem, et dextera eorum dextera iniquitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 12,
      "referenceLabel": "Psalms 143:12",
      "text": "Quorum filii sicut novellæ plantationes in juventute sua; filiæ eorum compositæ, circumornatæ ut similitudo templi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 13,
      "referenceLabel": "Psalms 143:13",
      "text": "Promptuaria eorum plena, eructantia ex hoc in illud; oves eorum fœtosæ, abundantes in egressibus suis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 14,
      "referenceLabel": "Psalms 143:14",
      "text": "boves eorum crassæ. Non est ruina maceriæ, neque transitus, neque clamor in plateis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.143.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 15,
      "referenceLabel": "Psalms 143:15",
      "text": "Beatum dixerunt populum cui hæc sunt; beatus populus cujus Dominus Deus ejus.",
      "paragraphStart": false
    }
  ]
}
