{
  "chapter": {
    "id": "vulgate:psalms.81",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.81.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "Psalmus Asaph. Deus stetit in synagoga deorum; in medio autem deos dijudicat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.81.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "Usquequo judicatis iniquitatem, et facies peccatorum sumitis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.81.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Judicate egeno et pupillo; humilem et pauperem justificate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.81.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "Eripite pauperem, et egenum de manu peccatoris liberate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.81.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "Nescierunt, neque intellexerunt; in tenebris ambulant: movebuntur omnia fundamenta terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.81.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "Ego dixi: Dii estis, et filii Excelsi omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.81.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "Vos autem sicut homines moriemini, et sicut unus de principibus cadetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.81.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Surge, Deus, judica terram, quoniam tu hæreditabis in omnibus gentibus.",
      "paragraphStart": false
    }
  ]
}
