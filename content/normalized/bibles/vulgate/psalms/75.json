{
  "chapter": {
    "id": "vulgate:psalms.75",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.75.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "In finem, in laudibus. Psalmus Asaph, canticum ad Assyrios.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.75.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "Notus in Judæa Deus; in Israël magnum nomen ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "Et factus est in pace locus ejus, et habitatio ejus in Sion.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "Ibi confregit potentias arcuum, scutum, gladium, et bellum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "Illuminans tu mirabiliter a montibus æternis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "turbati sunt omnes insipientes corde. Dormierunt somnum suum, et nihil invenerunt omnes viri divitiarum in manibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "Ab increpatione tua, Deus Jacob, dormitaverunt qui ascenderunt equos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "Tu terribilis es; et quis resistet tibi? ex tunc ira tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "De cælo auditum fecisti judicium: terra tremuit et quievit",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "cum exsurgeret in judicium Deus, ut salvos faceret omnes mansuetos terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 11,
      "referenceLabel": "Psalms 75:11",
      "text": "Quoniam cogitatio hominis confitebitur tibi, et reliquiæ cogitationis diem festum agent tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 12,
      "referenceLabel": "Psalms 75:12",
      "text": "Vovete et reddite Domino Deo vestro, omnes qui in circuitu ejus affertis munera: terribili,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.75.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 13,
      "referenceLabel": "Psalms 75:13",
      "text": "et ei qui aufert spiritum principum: terribili apud reges terræ.",
      "paragraphStart": false
    }
  ]
}
