{
  "chapter": {
    "id": "vulgate:psalms.150",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.150.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Alleluja. Laudate Dominum in sanctis ejus; laudate eum in firmamento virtutis ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.150.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Laudate eum in virtutibus ejus; laudate eum secundum multitudinem magnitudinis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.150.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Laudate eum in sono tubæ; laudate eum in psalterio et cithara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.150.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Laudate eum in tympano et choro; laudate eum in chordis et organo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.150.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Laudate eum in cymbalis benesonantibus; laudate eum in cymbalis jubilationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.150.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Omnis spiritus laudet Dominum! Alleluja.",
      "paragraphStart": false
    }
  ]
}
