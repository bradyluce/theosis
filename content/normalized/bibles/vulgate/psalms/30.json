{
  "chapter": {
    "id": "vulgate:psalms.30",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 30,
    "referenceLabel": "Psalms 30",
    "summary": "Source text for Psalms 30 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.30.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Psalms 30:1",
      "text": "In finem. Psalmus David, pro extasi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.30.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Psalms 30:2",
      "text": "In te, Domine, speravi; non confundar in æternum: in justitia tua libera me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Psalms 30:3",
      "text": "Inclina ad me aurem tuam; accelera ut eruas me. Esto mihi in Deum protectorem, et in domum refugii, ut salvum me facias:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Psalms 30:4",
      "text": "quoniam fortitudo mea et refugium meum es tu; et propter nomen tuum deduces me et enutries me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Psalms 30:5",
      "text": "Educes me de laqueo hoc quem absconderunt mihi, quoniam tu es protector meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Psalms 30:6",
      "text": "In manus tuas commendo spiritum meum; redemisti me, Domine Deus veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Psalms 30:7",
      "text": "Odisti observantes vanitates supervacue; ego autem in Domino speravi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Psalms 30:8",
      "text": "Exsultabo, et lætabor in misericordia tua, quoniam respexisti humilitatem meam; salvasti de necessitatibus animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Psalms 30:9",
      "text": "Nec conclusisti me in manibus inimici: statuisti in loco spatioso pedes meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Psalms 30:10",
      "text": "Miserere mei, Domine, quoniam tribulor; conturbatus est in ira oculus meus, anima mea, et venter meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Psalms 30:11",
      "text": "Quoniam defecit in dolore vita mea, et anni mei in gemitibus. Infirmata est in paupertate virtus mea, et ossa mea conturbata sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Psalms 30:12",
      "text": "Super omnes inimicos meos factus sum opprobrium, et vicinis meis valde, et timor notis meis; qui videbant me foras fugerunt a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Psalms 30:13",
      "text": "Oblivioni datus sum, tamquam mortuus a corde; factus sum tamquam vas perditum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Psalms 30:14",
      "text": "quoniam audivi vituperationem multorum commorantium in circuitu. In eo dum convenirent simul adversum me, accipere animam meam consiliati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Psalms 30:15",
      "text": "Ego autem in te speravi, Domine; dixi: Deus meus es tu;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Psalms 30:16",
      "text": "in manibus tuis sortes meæ: eripe me de manu inimicorum meorum, et a persequentibus me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Psalms 30:17",
      "text": "Illustra faciem tuam super servum tuum; salvum me fac in misericordia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Psalms 30:18",
      "text": "Domine, non confundar, quoniam invocavi te. Erubescant impii, et deducantur in infernum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Psalms 30:19",
      "text": "muta fiant labia dolosa, quæ loquuntur adversus justum iniquitatem, in superbia, et in abusione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Psalms 30:20",
      "text": "Quam magna multitudo dulcedinis tuæ, Domine, quam abscondisti timentibus te; perfecisti eis qui sperant in te in conspectu filiorum hominum!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Psalms 30:21",
      "text": "Abscondes eos in abscondito faciei tuæ a conturbatione hominum; proteges eos in tabernaculo tuo, a contradictione linguarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Psalms 30:22",
      "text": "Benedictus Dominus, quoniam mirificavit misericordiam suam mihi in civitate munita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Psalms 30:23",
      "text": "Ego autem dixi in excessu mentis meæ: Projectus sum a facie oculorum tuorum: ideo exaudisti vocem orationis meæ, dum clamarem ad te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Psalms 30:24",
      "text": "Diligite Dominum, omnes sancti ejus, quoniam veritatem requiret Dominus, et retribuet abundanter facientibus superbiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.30.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Psalms 30:25",
      "text": "Viriliter agite, et confortetur cor vestrum, omnes qui speratis in Domino.",
      "paragraphStart": false
    }
  ]
}
