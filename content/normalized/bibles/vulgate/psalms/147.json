{
  "chapter": {
    "id": "vulgate:psalms.147",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.147.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Alleluja. Lauda, Jerusalem, Dominum; lauda Deum tuum, Sion.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.147.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "Quoniam confortavit seras portarum tuarum; benedixit filiis tuis in te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "Qui posuit fines tuos pacem, et adipe frumenti satiat te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "Qui emittit eloquium suum terræ: velociter currit sermo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Qui dat nivem sicut lanam; nebulam sicut cinerem spargit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "Mittit crystallum suam sicut buccellas: ante faciem frigoris ejus quis sustinebit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Emittet verbum suum, et liquefaciet ea; flabit spiritus ejus, et fluent aquæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "Qui annuntiat verbum suum Jacob, justitias et judicia sua Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.147.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "Non fecit taliter omni nationi, et judicia sua non manifestavit eis. Alleluja.",
      "paragraphStart": false
    }
  ]
}
