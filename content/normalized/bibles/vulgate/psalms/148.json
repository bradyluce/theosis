{
  "chapter": {
    "id": "vulgate:psalms.148",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.148.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Alleluja. Laudate Dominum de cælis; laudate eum in excelsis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.148.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Laudate eum, omnes angeli ejus; laudate eum, omnes virtutes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Laudate eum, sol et luna; laudate eum, omnes stellæ et lumen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Laudate eum, cæli cælorum; et aquæ omnes quæ super cælos sunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "laudent nomen Domini. Quia ipse dixit, et facta sunt; ipse mandavit, et creata sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "Statuit ea in æternum, et in sæculum sæculi; præceptum posuit, et non præteribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Laudate Dominum de terra, dracones et omnes abyssi;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "ignis, grando, nix, glacies, spiritus procellarum, quæ faciunt verbum ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "montes, et omnes colles; ligna fructifera, et omnes cedri;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "bestiæ, et universa pecora; serpentes, et volucres pennatæ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "reges terræ et omnes populi; principes et omnes judices terræ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "juvenes et virgines; senes cum junioribus, laudent nomen Domini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "quia exaltatum est nomen ejus solius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.148.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "Confessio ejus super cælum et terram; et exaltavit cornu populi sui. Hymnus omnibus sanctis ejus; filiis Israël, populo appropinquanti sibi. Alleluja.",
      "paragraphStart": false
    }
  ]
}
