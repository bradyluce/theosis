{
  "chapter": {
    "id": "vulgate:psalms.26",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.26.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "Psalmus David, priusquam liniretur. Dominus illuminatio mea et salus mea: quem timebo? Dominus protector vitæ meæ: a quo trepidabo?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.26.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "Dum appropiant super me nocentes ut edant carnes meas, qui tribulant me inimici mei, ipsi infirmati sunt et ceciderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "Si consistant adversum me castra, non timebit cor meum; si exsurgat adversum me prælium, in hoc ego sperabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "Unam petii a Domino, hanc requiram, ut inhabitem in domo Domini omnibus diebus vitæ meæ; ut videam voluptatem Domini, et visitem templum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "Quoniam abscondit me in tabernaculo suo; in die malorum protexit me in abscondito tabernaculi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "In petra exaltavit me, et nunc exaltavit caput meum super inimicos meos. Circuivi, et immolavi in tabernaculo ejus hostiam vociferationis; cantabo, et psalmum dicam Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "Exaudi, Domine, vocem meam, qua clamavi ad te; miserere mei, et exaudi me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "Tibi dixit cor meum: Exquisivit te facies mea; faciem tuam, Domine, requiram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "Ne avertas faciem tuam a me; ne declines in ira a servo tuo. Adjutor meus esto; ne derelinquas me, neque despicias me, Deus salutaris meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "Quoniam pater meus et mater mea dereliquerunt me; Dominus autem assumpsit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "Legem pone mihi, Domine, in via tua, et dirige me in semitam rectam, propter inimicos meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "Ne tradideris me in animas tribulantium me, quoniam insurrexerunt in me testes iniqui, et mentita est iniquitas sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Psalms 26:13",
      "text": "Credo videre bona Domini in terra viventium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.26.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Psalms 26:14",
      "text": "Expecta Dominum, viriliter age: et confortetur cor tuum, et sustine Dominum.",
      "paragraphStart": false
    }
  ]
}
