{
  "chapter": {
    "id": "vulgate:psalms.35",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.35.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "In finem. Servo Domini ipsi David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.35.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "Dixit injustus ut delinquat in semetipso: non est timor Dei ante oculos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "Quoniam dolose egit in conspectu ejus, ut inveniatur iniquitas ejus ad odium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "Verba oris ejus iniquitas, et dolus; noluit intelligere ut bene ageret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "Iniquitatem meditatus est in cubili suo; astitit omni viæ non bonæ: malitiam autem non odivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "Domine, in cælo misericordia tua, et veritas tua usque ad nubes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "Justitia tua sicut montes Dei; judicia tua abyssus multa. Homines et jumenta salvabis, Domine,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "quemadmodum multiplicasti misericordiam tuam, Deus. Filii autem hominum in tegmine alarum tuarum sperabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "Inebriabuntur ab ubertate domus tuæ, et torrente voluptatis tuæ potabis eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "quoniam apud te est fons vitæ, et in lumine tuo videbimus lumen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "Prætende misericordiam tuam scientibus te, et justitiam tuam his qui recto sunt corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "Non veniat mihi pes superbiæ, et manus peccatoris non moveat me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.35.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Psalms 35:13",
      "text": "Ibi ceciderunt qui operantur iniquitatem; expulsi sunt, nec potuerunt stare.",
      "paragraphStart": false
    }
  ]
}
