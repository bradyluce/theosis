{
  "chapter": {
    "id": "vulgate:psalms.77",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 77,
    "referenceLabel": "Psalms 77",
    "summary": "Source text for Psalms 77 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.77.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 1,
      "referenceLabel": "Psalms 77:1",
      "text": "Intellectus Asaph. Attendite, popule meus, legem meam; inclinate aurem vestram in verba oris mei.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.77.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 2,
      "referenceLabel": "Psalms 77:2",
      "text": "Aperiam in parabolis os meum; loquar propositiones ab initio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 3,
      "referenceLabel": "Psalms 77:3",
      "text": "Quanta audivimus, et cognovimus ea, et patres nostri narraverunt nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 4,
      "referenceLabel": "Psalms 77:4",
      "text": "Non sunt occultata a filiis eorum in generatione altera, narrantes laudes Domini et virtutes ejus, et mirabilia ejus quæ fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 5,
      "referenceLabel": "Psalms 77:5",
      "text": "Et suscitavit testimonium in Jacob, et legem posuit in Israël, quanta mandavit patribus nostris nota facere ea filiis suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 6,
      "referenceLabel": "Psalms 77:6",
      "text": "ut cognoscat generatio altera: filii qui nascentur et exsurgent, et narrabunt filiis suis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 7,
      "referenceLabel": "Psalms 77:7",
      "text": "ut ponant in Deo spem suam, et non obliviscantur operum Dei, et mandata ejus exquirant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 8,
      "referenceLabel": "Psalms 77:8",
      "text": "ne fiant, sicut patres eorum, generatio prava et exasperans; generatio quæ non direxit cor suum, et non est creditus cum Deo spiritus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 9,
      "referenceLabel": "Psalms 77:9",
      "text": "Filii Ephrem, intendentes et mittentes arcum, conversi sunt in die belli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 10,
      "referenceLabel": "Psalms 77:10",
      "text": "Non custodierunt testamentum Dei, et in lege ejus noluerunt ambulare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 11,
      "referenceLabel": "Psalms 77:11",
      "text": "Et obliti sunt benefactorum ejus, et mirabilium ejus quæ ostendit eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 12,
      "referenceLabel": "Psalms 77:12",
      "text": "Coram patribus eorum fecit mirabilia in terra Ægypti, in campo Taneos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 13,
      "referenceLabel": "Psalms 77:13",
      "text": "Interrupit mare, et perduxit eos, et statuit aquas quasi in utre:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 14,
      "referenceLabel": "Psalms 77:14",
      "text": "et deduxit eos in nube diei, et tota nocte in illuminatione ignis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 15,
      "referenceLabel": "Psalms 77:15",
      "text": "Interrupit petram in eremo, et adaquavit eos velut in abysso multa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 16,
      "referenceLabel": "Psalms 77:16",
      "text": "Et eduxit aquam de petra, et deduxit tamquam flumina aquas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 17,
      "referenceLabel": "Psalms 77:17",
      "text": "Et apposuerunt adhuc peccare ei; in iram excitaverunt Excelsum in inaquoso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 18,
      "referenceLabel": "Psalms 77:18",
      "text": "Et tentaverunt Deum in cordibus suis, ut peterent escas animabus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 19,
      "referenceLabel": "Psalms 77:19",
      "text": "Et male locuti sunt de Deo; dixerunt: Numquid poterit Deus parare mensam in deserto?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 20,
      "referenceLabel": "Psalms 77:20",
      "text": "quoniam percussit petram, et fluxerunt aquæ, et torrentes inundaverunt. Numquid et panem poterit dare, aut parare mensam populo suo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 21,
      "referenceLabel": "Psalms 77:21",
      "text": "Ideo audivit Dominus et distulit; et ignis accensus est in Jacob, et ira ascendit in Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 22,
      "referenceLabel": "Psalms 77:22",
      "text": "quia non crediderunt in Deo, nec speraverunt in salutari ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 23,
      "referenceLabel": "Psalms 77:23",
      "text": "Et mandavit nubibus desuper, et januas cæli aperuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 24,
      "referenceLabel": "Psalms 77:24",
      "text": "Et pluit illis manna ad manducandum, et panem cæli dedit eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 25,
      "referenceLabel": "Psalms 77:25",
      "text": "Panem angelorum manducavit homo; cibaria misit eis in abundantia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 26,
      "referenceLabel": "Psalms 77:26",
      "text": "Transtulit austrum de cælo, et induxit in virtute sua africum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 27,
      "referenceLabel": "Psalms 77:27",
      "text": "Et pluit super eos sicut pulverem carnes, et sicut arenam maris volatilia pennata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 28,
      "referenceLabel": "Psalms 77:28",
      "text": "Et ceciderunt in medio castrorum eorum, circa tabernacula eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 29,
      "referenceLabel": "Psalms 77:29",
      "text": "Et manducaverunt, et saturati sunt nimis, et desiderium eorum attulit eis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 30,
      "referenceLabel": "Psalms 77:30",
      "text": "non sunt fraudati a desiderio suo. Adhuc escæ eorum erant in ore ipsorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 31,
      "referenceLabel": "Psalms 77:31",
      "text": "et ira Dei ascendit super eos: et occidit pingues eorum, et electos Israël impedivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 32,
      "referenceLabel": "Psalms 77:32",
      "text": "In omnibus his peccaverunt adhuc, et non crediderunt in mirabilibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 33,
      "referenceLabel": "Psalms 77:33",
      "text": "Et defecerunt in vanitate dies eorum, et anni eorum cum festinatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 34,
      "referenceLabel": "Psalms 77:34",
      "text": "Cum occideret eos, quærebant eum et revertebantur, et diluculo veniebant ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 35,
      "referenceLabel": "Psalms 77:35",
      "text": "Et rememorati sunt quia Deus adjutor est eorum, et Deus excelsus redemptor eorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 36,
      "referenceLabel": "Psalms 77:36",
      "text": "Et dilexerunt eum in ore suo, et lingua sua mentiti sunt ei;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 37,
      "referenceLabel": "Psalms 77:37",
      "text": "cor autem eorum non erat rectum cum eo, nec fideles habiti sunt in testamento ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 38,
      "referenceLabel": "Psalms 77:38",
      "text": "Ipse autem est misericors, et propitius fiet peccatis eorum, et non disperdet eos. Et abundavit ut averteret iram suam, et non accendit omnem iram suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 39,
      "referenceLabel": "Psalms 77:39",
      "text": "Et recordatus est quia caro sunt, spiritus vadens et non rediens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 40,
      "referenceLabel": "Psalms 77:40",
      "text": "Quoties exacerbaverunt eum in deserto; in iram concitaverunt eum in inaquoso?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.41",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 41,
      "referenceLabel": "Psalms 77:41",
      "text": "Et conversi sunt, et tentaverunt Deum, et sanctum Israël exacerbaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.42",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 42,
      "referenceLabel": "Psalms 77:42",
      "text": "Non sunt recordati manus ejus, die qua redemit eos de manu tribulantis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.43",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 43,
      "referenceLabel": "Psalms 77:43",
      "text": "sicut posuit in Ægypto signa sua, et prodigia sua in campo Taneos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.44",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 44,
      "referenceLabel": "Psalms 77:44",
      "text": "et convertit in sanguinem flumina eorum, et imbres eorum, ne biberent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.45",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 45,
      "referenceLabel": "Psalms 77:45",
      "text": "Misit in eos cœnomyiam, et comedit eos, et ranam, et disperdidit eos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.46",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 46,
      "referenceLabel": "Psalms 77:46",
      "text": "et dedit ærugini fructus eorum, et labores eorum locustæ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.47",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 47,
      "referenceLabel": "Psalms 77:47",
      "text": "et occidit in grandine vineas eorum, et moros eorum in pruina;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.48",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 48,
      "referenceLabel": "Psalms 77:48",
      "text": "et tradidit grandini jumenta eorum, et possessionem eorum igni;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.49",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 49,
      "referenceLabel": "Psalms 77:49",
      "text": "misit in eos iram indignationis suæ, indignationem, et iram, et tribulationem, immissiones per angelos malos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.50",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 50,
      "referenceLabel": "Psalms 77:50",
      "text": "Viam fecit semitæ iræ suæ: non pepercit a morte animabus eorum, et jumenta eorum in morte conclusit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.51",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 51,
      "referenceLabel": "Psalms 77:51",
      "text": "et percussit omne primogenitum in terra Ægypti; primitias omnis laboris eorum in tabernaculis Cham:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.52",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 52,
      "referenceLabel": "Psalms 77:52",
      "text": "et abstulit sicut oves populum suum, et perduxit eos tamquam gregem in deserto:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.53",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 53,
      "referenceLabel": "Psalms 77:53",
      "text": "et deduxit eos in spe, et non timuerunt, et inimicos eorum operuit mare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.54",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 54,
      "referenceLabel": "Psalms 77:54",
      "text": "Et induxit eos in montem sanctificationis suæ, montem quem acquisivit dextera ejus; et ejecit a facie eorum gentes, et sorte divisit eis terram in funiculo distributionis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.55",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 55,
      "referenceLabel": "Psalms 77:55",
      "text": "et habitare fecit in tabernaculis eorum tribus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.56",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 56,
      "referenceLabel": "Psalms 77:56",
      "text": "Et tentaverunt, et exacerbaverunt Deum excelsum, et testimonia ejus non custodierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.57",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 57,
      "referenceLabel": "Psalms 77:57",
      "text": "Et averterunt se, et non servaverunt pactum: quemadmodum patres eorum, conversi sunt in arcum pravum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.58",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 58,
      "referenceLabel": "Psalms 77:58",
      "text": "In iram concitaverunt eum in collibus suis, et in sculptilibus suis ad æmulationem eum provocaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.59",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 59,
      "referenceLabel": "Psalms 77:59",
      "text": "Audivit Deus, et sprevit, et ad nihilum redegit valde Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.60",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 60,
      "referenceLabel": "Psalms 77:60",
      "text": "Et repulit tabernaculum Silo, tabernaculum suum, ubi habitavit in hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.61",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 61,
      "referenceLabel": "Psalms 77:61",
      "text": "Et tradidit in captivitatem virtutem eorum, et pulchritudinem eorum in manus inimici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.62",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 62,
      "referenceLabel": "Psalms 77:62",
      "text": "Et conclusit in gladio populum suum, et hæreditatem suam sprevit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.77.63",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 63,
      "referenceLabel": "Psalms 77:63",
      "text": "Juvenes eorum comedit ignis, et virgines eorum non sunt lamentatæ.",
      "paragraphStart": false
    },
    {
