{
  "chapter": {
    "id": "vulgate:psalms.125",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 125,
    "referenceLabel": "Psalms 125",
    "summary": "Source text for Psalms 125 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.125.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 1,
      "referenceLabel": "Psalms 125:1",
      "text": "Canticum graduum. In convertendo Dominus captivitatem Sion, facti sumus sicut consolati.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.125.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 2,
      "referenceLabel": "Psalms 125:2",
      "text": "Tunc repletum est gaudio os nostrum, et lingua nostra exsultatione. Tunc dicent inter gentes: Magnificavit Dominus facere cum eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.125.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 3,
      "referenceLabel": "Psalms 125:3",
      "text": "Magnificavit Dominus facere nobiscum; facti sumus lætantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.125.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 4,
      "referenceLabel": "Psalms 125:4",
      "text": "Converte, Domine, captivitatem nostram, sicut torrens in austro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.125.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 5,
      "referenceLabel": "Psalms 125:5",
      "text": "Qui seminant in lacrimis, in exsultatione metent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.125.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 6,
      "referenceLabel": "Psalms 125:6",
      "text": "Euntes ibant et flebant, mittentes semina sua. Venientes autem venient cum exsultatione, portantes manipulos suos.",
      "paragraphStart": false
    }
  ]
}
