{
  "chapter": {
    "id": "vulgate:psalms.9",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.9.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "In finem, pro occultis filii. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.9.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "Confitebor tibi, Domine, in toto corde meo; narrabo omnia mirabilia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "Lætabor et exsultabo in te; psallam nomini tuo, Altissime.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "In convertendo inimicum meum retrorsum; infirmabuntur, et peribunt a facie tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "Quoniam fecisti judicium meum et causam meam; sedisti super thronum, qui judicas justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "Increpasti gentes, et periit impius: nomen eorum delesti in æternum, et in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "Inimici defecerunt frameæ in finem, et civitates eorum destruxisti. Periit memoria eorum cum sonitu;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "et Dominus in æternum permanet. Paravit in judicio thronum suum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "et ipse judicabit orbem terræ in æquitate: judicabit populos in justitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "Et factus est Dominus refugium pauperi; adjutor in opportunitatibus, in tribulatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "Et sperent in te qui noverunt nomen tuum, quoniam non dereliquisti quærentes te, Domine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "Psallite Domino qui habitat in Sion; annuntiate inter gentes studia ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "quoniam requirens sanguinem eorum recordatus est; non est oblitus clamorem pauperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "Miserere mei, Domine: vide humilitatem meam de inimicis meis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "qui exaltas me de portis mortis, ut annuntiem omnes laudationes tuas in portis filiæ Sion:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "exultabo in salutari tuo. Infixæ sunt gentes in interitu quem fecerunt; in laqueo isto quem absconderunt comprehensus est pes eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "Cognoscetur Dominus judicia faciens; in operibus manuum suarum comprehensus est peccator.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "Convertantur peccatores in infernum, omnes gentes quæ obliviscuntur Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "Quoniam non in finem oblivio erit pauperis; patientia pauperum non peribit in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Exsurge, Domine; non confortetur homo: judicentur gentes in conspectu tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Psalms 9:21",
      "text": "Constitue, Domine, legislatorem super eos, ut sciant gentes quoniam homines sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Psalms 9:22",
      "text": "Ut quid, Domine, recessisti longe; despicis in opportunitatibus, in tribulatione?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Psalms 9:23",
      "text": "Dum superbit impius, incenditur pauper: comprehenduntur in consiliis quibus cogitant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Psalms 9:24",
      "text": "Quoniam laudatur peccator in desideriis animæ suæ, et iniquus benedicitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Psalms 9:25",
      "text": "Exacerbavit Dominum peccator: secundum multitudinem iræ suæ, non quæret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Psalms 9:26",
      "text": "Non est Deus in conspectu ejus; inquinatæ sunt viæ illius in omni tempore. Auferuntur judicia tua a facie ejus; omnium inimicorum suorum dominabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Psalms 9:27",
      "text": "Dixit enim in corde suo: Non movebor a generatione in generationem, sine malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Psalms 9:28",
      "text": "Cujus maledictione os plenum est, et amaritudine, et dolo; sub lingua ejus labor et dolor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Psalms 9:29",
      "text": "Sedet in insidiis cum divitibus in occultis, ut interficiat innocentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Psalms 9:30",
      "text": "Oculi ejus in pauperem respiciunt; insidiatur in abscondito, quasi leo in spelunca sua. Insidiatur ut rapiat pauperem; rapere pauperem dum attrahit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Psalms 9:31",
      "text": "In laqueo suo humiliabit eum; inclinabit se, et cadet cum dominatus fuerit pauperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Psalms 9:32",
      "text": "Dixit enim in corde suo: Oblitus est Deus; avertit faciem suam, ne videat in finem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Psalms 9:33",
      "text": "Exsurge, Domine Deus, exaltetur manus tua; ne obliviscaris pauperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Psalms 9:34",
      "text": "Propter quid irritavit impius Deum? dixit enim in corde suo: Non requiret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Psalms 9:35",
      "text": "Vides, quoniam tu laborem et dolorem consideras, ut tradas eos in manus tuas. Tibi derelictus est pauper; orphano tu eris adjutor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "Psalms 9:36",
      "text": "Contere brachium peccatoris et maligni; quæretur peccatum illius, et non invenietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "Psalms 9:37",
      "text": "Dominus regnabit in æternum, et in sæculum sæculi; peribitis, gentes, de terra illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "Psalms 9:38",
      "text": "Desiderium pauperum exaudivit Dominus; præparationem cordis eorum audivit auris tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.9.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 39,
      "referenceLabel": "Psalms 9:39",
      "text": "judicare pupillo et humili, ut non apponat ultra magnificare se homo super terram.",
      "paragraphStart": false
    }
  ]
}
