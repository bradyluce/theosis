{
  "chapter": {
    "id": "vulgate:psalms.29",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.29.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "Psalmus cantici, in dedicatione domus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.29.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "Exaltabo te, Domine, quoniam suscepisti me, nec delectasti inimicos meos super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "Domine Deus meus, clamavi ad te, et sanasti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "Domine, eduxisti ab inferno animam meam; salvasti me a descendentibus in lacum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "Psallite Domino, sancti ejus; et confitemini memoriæ sanctitatis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "Quoniam ira in indignatione ejus, et vita in voluntate ejus: ad vesperum demorabitur fletus, et ad matutinum lætitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "Ego autem dixi in abundantia mea: Non movebor in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "Domine, in voluntate tua præstitisti decori meo virtutem; avertisti faciem tuam a me, et factus sum conturbatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "Ad te, Domine, clamabo, et ad Deum meum deprecabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "Quæ utilitas in sanguine meo, dum descendo in corruptionem? numquid confitebitur tibi pulvis, aut annuntiabit veritatem tuam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "Audivit Dominus, et misertus est mei; Dominus factus est adjutor meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Psalms 29:12",
      "text": "Convertisti planctum meum in gaudium mihi; conscidisti saccum meum, et circumdedisti me lætitia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.29.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Psalms 29:13",
      "text": "ut cantet tibi gloria mea, et non compungar. Domine Deus meus, in æternum confitebor tibi.",
      "paragraphStart": false
    }
  ]
}
