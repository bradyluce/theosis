{
  "chapter": {
    "id": "vulgate:psalms.83",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 83,
    "referenceLabel": "Psalms 83",
    "summary": "Source text for Psalms 83 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.83.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 1,
      "referenceLabel": "Psalms 83:1",
      "text": "In finem, pro torcularibus filiis Core. Psalmus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.83.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 2,
      "referenceLabel": "Psalms 83:2",
      "text": "Quam dilecta tabernacula tua, Domine virtutum!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 3,
      "referenceLabel": "Psalms 83:3",
      "text": "Concupiscit, et deficit anima mea in atria Domini; cor meum et caro mea exsultaverunt in Deum vivum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 4,
      "referenceLabel": "Psalms 83:4",
      "text": "Etenim passer invenit sibi domum, et turtur nidum sibi, ubi ponat pullos suos: altaria tua, Domine virtutum, rex meus, et Deus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 5,
      "referenceLabel": "Psalms 83:5",
      "text": "Beati qui habitant in domo tua, Domine; in sæcula sæculorum laudabunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 6,
      "referenceLabel": "Psalms 83:6",
      "text": "Beatus vir cujus est auxilium abs te: ascensiones in corde suo disposuit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 7,
      "referenceLabel": "Psalms 83:7",
      "text": "in valle lacrimarum, in loco quem posuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 8,
      "referenceLabel": "Psalms 83:8",
      "text": "Etenim benedictionem dabit legislator; ibunt de virtute in virtutem: videbitur Deus deorum in Sion.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 9,
      "referenceLabel": "Psalms 83:9",
      "text": "Domine Deus virtutum, exaudi orationem meam; auribus percipe, Deus Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 10,
      "referenceLabel": "Psalms 83:10",
      "text": "Protector noster, aspice, Deus, et respice in faciem christi tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 11,
      "referenceLabel": "Psalms 83:11",
      "text": "Quia melior est dies una in atriis tuis super millia; elegi abjectus esse in domo Dei mei magis quam habitare in tabernaculis peccatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 12,
      "referenceLabel": "Psalms 83:12",
      "text": "Quia misericordiam et veritatem diligit Deus: gratiam et gloriam dabit Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.83.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 13,
      "referenceLabel": "Psalms 83:13",
      "text": "Non privabit bonis eos qui ambulant in innocentia: Domine virtutum, beatus homo qui sperat in te.",
      "paragraphStart": false
    }
  ]
}
