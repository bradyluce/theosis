{
  "chapter": {
    "id": "vulgate:psalms.138",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 138,
    "referenceLabel": "Psalms 138",
    "summary": "Source text for Psalms 138 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.138.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 1,
      "referenceLabel": "Psalms 138:1",
      "text": "In finem, psalmus David. Domine, probasti me, et cognovisti me;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.138.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 2,
      "referenceLabel": "Psalms 138:2",
      "text": "tu cognovisti sessionem meam et resurrectionem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 3,
      "referenceLabel": "Psalms 138:3",
      "text": "Intellexisti cogitationes meas de longe; semitam meam et funiculum meum investigasti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 4,
      "referenceLabel": "Psalms 138:4",
      "text": "et omnes vias meas prævidisti, quia non est sermo in lingua mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 5,
      "referenceLabel": "Psalms 138:5",
      "text": "Ecce, Domine, tu cognovisti omnia, novissima et antiqua. Tu formasti me, et posuisti super me manum tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 6,
      "referenceLabel": "Psalms 138:6",
      "text": "Mirabilis facta est scientia tua ex me; confortata est, et non potero ad eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 7,
      "referenceLabel": "Psalms 138:7",
      "text": "Quo ibo a spiritu tuo? et quo a facie tua fugiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 8,
      "referenceLabel": "Psalms 138:8",
      "text": "Si ascendero in cælum, tu illic es; si descendero in infernum, ades.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 9,
      "referenceLabel": "Psalms 138:9",
      "text": "Si sumpsero pennas meas diluculo, et habitavero in extremis maris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 10,
      "referenceLabel": "Psalms 138:10",
      "text": "etenim illuc manus tua deducet me, et tenebit me dextera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 11,
      "referenceLabel": "Psalms 138:11",
      "text": "Et dixi: Forsitan tenebræ conculcabunt me; et nox illuminatio mea in deliciis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 12,
      "referenceLabel": "Psalms 138:12",
      "text": "Quia tenebræ non obscurabuntur a te, et nox sicut dies illuminabitur: sicut tenebræ ejus, ita et lumen ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 13,
      "referenceLabel": "Psalms 138:13",
      "text": "Quia tu possedisti renes meos; suscepisti me de utero matris meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 14,
      "referenceLabel": "Psalms 138:14",
      "text": "Confitebor tibi, quia terribiliter magnificatus es; mirabilia opera tua, et anima mea cognoscit nimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 15,
      "referenceLabel": "Psalms 138:15",
      "text": "Non est occultatum os meum a te, quod fecisti in occulto; et substantia mea in inferioribus terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 16,
      "referenceLabel": "Psalms 138:16",
      "text": "Imperfectum meum viderunt oculi tui, et in libro tuo omnes scribentur. Dies formabuntur, et nemo in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 17,
      "referenceLabel": "Psalms 138:17",
      "text": "Mihi autem nimis honorificati sunt amici tui, Deus; nimis confortatus est principatus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 18,
      "referenceLabel": "Psalms 138:18",
      "text": "Dinumerabo eos, et super arenam multiplicabuntur. Exsurrexi, et adhuc sum tecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 19,
      "referenceLabel": "Psalms 138:19",
      "text": "Si occideris, Deus, peccatores, viri sanguinum, declinate a me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 20,
      "referenceLabel": "Psalms 138:20",
      "text": "quia dicitis in cogitatione: Accipient in vanitate civitates tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 21,
      "referenceLabel": "Psalms 138:21",
      "text": "Nonne qui oderunt te, Domine, oderam, et super inimicos tuos tabescebam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 22,
      "referenceLabel": "Psalms 138:22",
      "text": "Perfecto odio oderam illos, et inimici facti sunt mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 23,
      "referenceLabel": "Psalms 138:23",
      "text": "Proba me, Deus, et scito cor meum; interroga me, et cognosce semitas meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.138.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 24,
      "referenceLabel": "Psalms 138:24",
      "text": "Et vide si via iniquitatis in me est, et deduc me in via æterna.",
      "paragraphStart": false
    }
  ]
}
