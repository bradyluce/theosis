{
  "chapter": {
    "id": "vulgate:psalms.41",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 41,
    "referenceLabel": "Psalms 41",
    "summary": "Source text for Psalms 41 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.41.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Psalms 41:1",
      "text": "In finem. Intellectus filiis Core.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.41.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Psalms 41:2",
      "text": "Quemadmodum desiderat cervus ad fontes aquarum, ita desiderat anima mea ad te, Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Psalms 41:3",
      "text": "Sitivit anima mea ad Deum fortem, vivum; quando veniam, et apparebo ante faciem Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Psalms 41:4",
      "text": "Fuerunt mihi lacrimæ meæ panes die ac nocte, dum dicitur mihi quotidie: Ubi est Deus tuus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Psalms 41:5",
      "text": "Hæc recordatus sum, et effudi in me animam meam, quoniam transibo in locum tabernaculi admirabilis, usque ad domum Dei, in voce exsultationis et confessionis, sonus epulantis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Psalms 41:6",
      "text": "Quare tristis es, anima mea? et quare conturbas me? Spera in Deo, quoniam adhuc confitebor illi, salutare vultus mei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Psalms 41:7",
      "text": "et Deus meus. Ad meipsum anima mea conturbata est: propterea memor ero tui de terra Jordanis et Hermoniim a monte modico.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Psalms 41:8",
      "text": "Abyssus abyssum invocat, in voce cataractarum tuarum; omnia excelsa tua, et fluctus tui super me transierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Psalms 41:9",
      "text": "In die mandavit Dominus misericordiam suam, et nocte canticum ejus; apud me oratio Deo vitæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Psalms 41:10",
      "text": "Dicam Deo: Susceptor meus es; quare oblitus es mei? et quare contristatus incedo, dum affligit me inimicus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Psalms 41:11",
      "text": "Dum confringuntur ossa mea, exprobraverunt mihi qui tribulant me inimici mei, dum dicunt mihi per singulos dies: Ubi est Deus tuus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.41.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Psalms 41:12",
      "text": "Quare tristis es, anima mea? et quare conturbas me? Spera in Deo, quoniam adhuc confitebor illi, salutare vultus mei, et Deus meus.",
      "paragraphStart": false
    }
  ]
}
