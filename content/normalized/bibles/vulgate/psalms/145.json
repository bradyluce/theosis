{
  "chapter": {
    "id": "vulgate:psalms.145",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.145.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "Alleluja, Aggæi et Zachariæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.145.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Lauda, anima mea, Dominum. Laudabo Dominum in vita mea; psallam Deo meo quamdiu fuero. Nolite confidere in principibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "in filiis hominum, in quibus non est salus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "Exibit spiritus ejus, et revertetur in terram suam; in illa die peribunt omnes cogitationes eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "Beatus cujus Deus Jacob adjutor ejus, spes ejus in Domino Deo ipsius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "qui fecit cælum et terram, mare, et omnia quæ in eis sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "Qui custodit veritatem in sæculum; facit judicium injuriam patientibus; dat escam esurientibus. Dominus solvit compeditos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "Dominus illuminat cæcos. Dominus erigit elisos; Dominus diligit justos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "Dominus custodit advenas, pupillum et viduam suscipiet, et vias peccatorum disperdet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.145.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "Regnabit Dominus in sæcula; Deus tuus, Sion, in generationem et generationem.",
      "paragraphStart": false
    }
  ]
}
