{
  "chapter": {
    "id": "vulgate:psalms.129",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.129.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "Canticum graduum. De profundis clamavi ad te, Domine;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.129.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "Domine, exaudi vocem meam. Fiant aures tuæ intendentes in vocem deprecationis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.129.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "Si iniquitates observaveris, Domine, Domine, quis sustinebit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.129.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "Quia apud te propitiatio est; et propter legem tuam sustinui te, Domine. Sustinuit anima mea in verbo ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.129.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "speravit anima mea in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.129.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "A custodia matutina usque ad noctem, speret Israël in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.129.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "Quia apud Dominum misericordia, et copiosa apud eum redemptio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.129.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "Et ipse redimet Israël ex omnibus iniquitatibus ejus.",
      "paragraphStart": false
    }
  ]
}
