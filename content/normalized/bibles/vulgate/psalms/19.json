{
  "chapter": {
    "id": "vulgate:psalms.19",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 19,
    "referenceLabel": "Psalms 19",
    "summary": "Source text for Psalms 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.19.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Psalms 19:1",
      "text": "In finem. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.19.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Psalms 19:2",
      "text": "Exaudiat te Dominus in die tribulationis; protegat te nomen Dei Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Psalms 19:3",
      "text": "Mittat tibi auxilium de sancto, et de Sion tueatur te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Psalms 19:4",
      "text": "Memor sit omnis sacrificii tui, et holocaustum tuum pingue fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Psalms 19:5",
      "text": "Tribuat tibi secundum cor tuum, et omne consilium tuum confirmet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Psalms 19:6",
      "text": "Lætabimur in salutari tuo; et in nomine Dei nostri magnificabimur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Psalms 19:7",
      "text": "Impleat Dominus omnes petitiones tuas; nunc cognovi quoniam salvum fecit Dominus christum suum. Exaudiet illum de cælo sancto suo, in potentatibus salus dexteræ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Psalms 19:8",
      "text": "Hi in curribus, et hi in equis; nos autem in nomine Domini Dei nostri invocabimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Psalms 19:9",
      "text": "Ipsi obligati sunt, et ceciderunt; nos autem surreximus, et erecti sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.19.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Psalms 19:10",
      "text": "Domine, salvum fac regem, et exaudi nos in die qua invocaverimus te.",
      "paragraphStart": false
    }
  ]
}
