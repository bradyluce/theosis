{
  "chapter": {
    "id": "vulgate:psalms.120",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.120.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "Canticum graduum. Levavi oculos meos in montes, unde veniet auxilium mihi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.120.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Auxilium meum a Domino, qui fecit cælum et terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.120.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "Non det in commotionem pedem tuum, neque dormitet qui custodit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.120.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Ecce non dormitabit neque dormiet qui custodit Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.120.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Dominus custodit te; Dominus protectio tua super manum dexteram tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.120.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "Per diem sol non uret te, neque luna per noctem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.120.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "Dominus custodit te ab omni malo; custodiat animam tuam Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.120.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 8,
      "referenceLabel": "Psalms 120:8",
      "text": "Dominus custodiat introitum tuum et exitum tuum, ex hoc nunc et usque in sæculum.",
      "paragraphStart": false
    }
  ]
}
