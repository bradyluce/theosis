{
  "chapter": {
    "id": "vulgate:psalms.131",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 131,
    "referenceLabel": "Psalms 131",
    "summary": "Source text for Psalms 131 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.131.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 1,
      "referenceLabel": "Psalms 131:1",
      "text": "Canticum graduum. Memento, Domine, David, et omnis mansuetudinis ejus:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.131.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 2,
      "referenceLabel": "Psalms 131:2",
      "text": "sicut juravit Domino; votum vovit Deo Jacob:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 3,
      "referenceLabel": "Psalms 131:3",
      "text": "Si introiero in tabernaculum domus meæ; si ascendero in lectum strati mei;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 4,
      "referenceLabel": "Psalms 131:4",
      "text": "si dedero somnum oculis meis, et palpebris meis dormitationem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 5,
      "referenceLabel": "Psalms 131:5",
      "text": "et requiem temporibus meis, donec inveniam locum Domino, tabernaculum Deo Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 6,
      "referenceLabel": "Psalms 131:6",
      "text": "Ecce audivimus eam in Ephrata; invenimus eam in campis silvæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 7,
      "referenceLabel": "Psalms 131:7",
      "text": "Introibimus in tabernaculum ejus; adorabimus in loco ubi steterunt pedes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 8,
      "referenceLabel": "Psalms 131:8",
      "text": "Surge, Domine, in requiem tuam, tu et arca sanctificationis tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 9,
      "referenceLabel": "Psalms 131:9",
      "text": "Sacerdotes tui induantur justitiam, et sancti tui exsultent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 10,
      "referenceLabel": "Psalms 131:10",
      "text": "Propter David servum tuum non avertas faciem christi tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 11,
      "referenceLabel": "Psalms 131:11",
      "text": "Juravit Dominus David veritatem, et non frustrabitur eam: De fructu ventris tui ponam super sedem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 12,
      "referenceLabel": "Psalms 131:12",
      "text": "Si custodierint filii tui testamentum meum, et testimonia mea hæc quæ docebo eos, et filii eorum usque in sæculum sedebunt super sedem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 13,
      "referenceLabel": "Psalms 131:13",
      "text": "Quoniam elegit Dominus Sion: elegit eam in habitationem sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 14,
      "referenceLabel": "Psalms 131:14",
      "text": "Hæc requies mea in sæculum sæculi; hic habitabo, quoniam elegi eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 15,
      "referenceLabel": "Psalms 131:15",
      "text": "Viduam ejus benedicens benedicam; pauperes ejus saturabo panibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 16,
      "referenceLabel": "Psalms 131:16",
      "text": "Sacerdotes ejus induam salutari, et sancti ejus exsultatione exsultabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 17,
      "referenceLabel": "Psalms 131:17",
      "text": "Illuc producam cornu David; paravi lucernam christo meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.131.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 18,
      "referenceLabel": "Psalms 131:18",
      "text": "Inimicos ejus induam confusione; super ipsum autem efflorebit sanctificatio mea.",
      "paragraphStart": false
    }
  ]
}
