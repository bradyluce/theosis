{
  "chapter": {
    "id": "vulgate:psalms.80",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 80,
    "referenceLabel": "Psalms 80",
    "summary": "Source text for Psalms 80 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.80.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 1,
      "referenceLabel": "Psalms 80:1",
      "text": "In finem, pro torcularibus. Psalmus ipsi Asaph.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.80.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 2,
      "referenceLabel": "Psalms 80:2",
      "text": "Exsultate Deo adjutori nostro; jubilate Deo Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 3,
      "referenceLabel": "Psalms 80:3",
      "text": "Sumite psalmum, et date tympanum; psalterium jucundum cum cithara.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 4,
      "referenceLabel": "Psalms 80:4",
      "text": "Buccinate in neomenia tuba, in insigni die solemnitatis vestræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 5,
      "referenceLabel": "Psalms 80:5",
      "text": "quia præceptum in Israël est, et judicium Deo Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 6,
      "referenceLabel": "Psalms 80:6",
      "text": "Testimonium in Joseph posuit illud, cum exiret de terra Ægypti; linguam quam non noverat, audivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 7,
      "referenceLabel": "Psalms 80:7",
      "text": "Divertit ab oneribus dorsum ejus; manus ejus in cophino servierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 8,
      "referenceLabel": "Psalms 80:8",
      "text": "In tribulatione invocasti me, et liberavi te. Exaudivi te in abscondito tempestatis; probavi te apud aquam contradictionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 9,
      "referenceLabel": "Psalms 80:9",
      "text": "Audi, populus meus, et contestabor te. Israël, si audieris me,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 10,
      "referenceLabel": "Psalms 80:10",
      "text": "non erit in te deus recens, neque adorabis deum alienum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 11,
      "referenceLabel": "Psalms 80:11",
      "text": "Ego enim sum Dominus Deus tuus, qui eduxi te de terra Ægypti. Dilata os tuum, et implebo illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 12,
      "referenceLabel": "Psalms 80:12",
      "text": "Et non audivit populus meus vocem meam, et Israël non intendit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 13,
      "referenceLabel": "Psalms 80:13",
      "text": "Et dimisi eos secundum desideria cordis eorum; ibunt in adinventionibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 14,
      "referenceLabel": "Psalms 80:14",
      "text": "Si populus meus audisset me, Israël si in viis meis ambulasset,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 15,
      "referenceLabel": "Psalms 80:15",
      "text": "pro nihilo forsitan inimicos eorum humiliassem, et super tribulantes eos misissem manum meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 16,
      "referenceLabel": "Psalms 80:16",
      "text": "Inimici Domini mentiti sunt ei, et erit tempus eorum in sæcula.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.80.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 17,
      "referenceLabel": "Psalms 80:17",
      "text": "Et cibavit eos ex adipe frumenti, et de petra melle saturavit eos.",
      "paragraphStart": false
    }
  ]
}
