{
  "chapter": {
    "id": "vulgate:psalms.71",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.71.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "Psalmus, in Salomonem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.71.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "Deus, judicium tuum regi da, et justitiam tuam filio regis; judicare populum tuum in justitia, et pauperes tuos in judicio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Suscipiant montes pacem populo, et colles justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "Judicabit pauperes populi, et salvos faciet filios pauperum, et humiliabit calumniatorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "Et permanebit cum sole, et ante lunam, in generatione et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "Descendet sicut pluvia in vellus, et sicut stillicidia stillantia super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "Orietur in diebus ejus justitia, et abundantia pacis, donec auferatur luna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "Et dominabitur a mari usque ad mare, et a flumine usque ad terminos orbis terrarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "Coram illo procident Æthiopes, et inimici ejus terram lingent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "Reges Tharsis et insulæ munera offerent; reges Arabum et Saba dona adducent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "et adorabunt eum omnes reges terræ; omnes gentes servient ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "Quia liberabit pauperem a potente, et pauperem cui non erat adjutor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "Parcet pauperi et inopi, et animas pauperum salvas faciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "Ex usuris et iniquitate redimet animas eorum, et honorabile nomen eorum coram illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "Et vivet, et dabitur ei de auro Arabiæ; et adorabunt de ipso semper, tota die benedicent ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "Et erit firmamentum in terra in summis montium; superextolletur super Libanum fructus ejus, et florebunt de civitate sicut fœnum terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "Sit nomen ejus benedictum in sæcula; ante solem permanet nomen ejus. Et benedicentur in ipso omnes tribus terræ; omnes gentes magnificabunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "Benedictus Dominus Deus Israël, qui facit mirabilia solus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "Et benedictum nomen majestatis ejus in æternum, et replebitur majestate ejus omnis terra. Fiat, fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.71.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "Defecerunt laudes David, filii Jesse.",
      "paragraphStart": false
    }
  ]
}
