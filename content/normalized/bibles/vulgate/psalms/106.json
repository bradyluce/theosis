{
  "chapter": {
    "id": "vulgate:psalms.106",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 106,
    "referenceLabel": "Psalms 106",
    "summary": "Source text for Psalms 106 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.106.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 1,
      "referenceLabel": "Psalms 106:1",
      "text": "Alleluja. Confitemini Domino, quoniam bonus, quoniam in sæculum misericordia ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.106.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 2,
      "referenceLabel": "Psalms 106:2",
      "text": "Dicant qui redempti sunt a Domino, quos redemit de manu inimici, et de regionibus congregavit eos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 3,
      "referenceLabel": "Psalms 106:3",
      "text": "a solis ortu, et occasu, ab aquilone, et mari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 4,
      "referenceLabel": "Psalms 106:4",
      "text": "Erraverunt in solitudine, in inaquoso; viam civitatis habitaculi non invenerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 5,
      "referenceLabel": "Psalms 106:5",
      "text": "Esurientes et sitientes, anima eorum in ipsis defecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 6,
      "referenceLabel": "Psalms 106:6",
      "text": "Et clamaverunt ad Dominum cum tribularentur, et de necessitatibus eorum eripuit eos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 7,
      "referenceLabel": "Psalms 106:7",
      "text": "et deduxit eos in viam rectam, ut irent in civitatem habitationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 8,
      "referenceLabel": "Psalms 106:8",
      "text": "Confiteantur Domino misericordiæ ejus, et mirabilia ejus filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 9,
      "referenceLabel": "Psalms 106:9",
      "text": "Quia satiavit animam inanem, et animam esurientem satiavit bonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 10,
      "referenceLabel": "Psalms 106:10",
      "text": "Sedentes in tenebris et umbra mortis; vinctos in mendicitate et ferro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 11,
      "referenceLabel": "Psalms 106:11",
      "text": "Quia exacerbaverunt eloquia Dei, et consilium Altissimi irritaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 12,
      "referenceLabel": "Psalms 106:12",
      "text": "Et humiliatum est in laboribus cor eorum; infirmati sunt, nec fuit qui adjuvaret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 13,
      "referenceLabel": "Psalms 106:13",
      "text": "Et clamaverunt ad Dominum cum tribularentur; et de necessitatibus eorum liberavit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 14,
      "referenceLabel": "Psalms 106:14",
      "text": "Et eduxit eos de tenebris et umbra mortis, et vincula eorum dirupit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 15,
      "referenceLabel": "Psalms 106:15",
      "text": "Confiteantur Domino misericordiæ ejus, et mirabilia ejus filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 16,
      "referenceLabel": "Psalms 106:16",
      "text": "Quia contrivit portas æreas, et vectes ferreos confregit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 17,
      "referenceLabel": "Psalms 106:17",
      "text": "Suscepit eos de via iniquitatis eorum; propter injustitias enim suas humiliati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 18,
      "referenceLabel": "Psalms 106:18",
      "text": "Omnem escam abominata est anima eorum, et appropinquaverunt usque ad portas mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 19,
      "referenceLabel": "Psalms 106:19",
      "text": "Et clamaverunt ad Dominum cum tribularentur, et de necessitatibus eorum liberavit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 20,
      "referenceLabel": "Psalms 106:20",
      "text": "Misit verbum suum, et sanavit eos, et eripuit eos de interitionibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 21,
      "referenceLabel": "Psalms 106:21",
      "text": "Confiteantur Domino misericordiæ ejus, et mirabilia ejus filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 22,
      "referenceLabel": "Psalms 106:22",
      "text": "Et sacrificent sacrificium laudis, et annuntient opera ejus in exsultatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 23,
      "referenceLabel": "Psalms 106:23",
      "text": "Qui descendunt mare in navibus, facientes operationem in aquis multis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 24,
      "referenceLabel": "Psalms 106:24",
      "text": "ipsi viderunt opera Domini, et mirabilia ejus in profundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 25,
      "referenceLabel": "Psalms 106:25",
      "text": "Dixit, et stetit spiritus procellæ, et exaltati sunt fluctus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 26,
      "referenceLabel": "Psalms 106:26",
      "text": "Ascendunt usque ad cælos, et descendunt usque ad abyssos; anima eorum in malis tabescebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 27,
      "referenceLabel": "Psalms 106:27",
      "text": "Turbati sunt, et moti sunt sicut ebrius, et omnis sapientia eorum devorata est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 28,
      "referenceLabel": "Psalms 106:28",
      "text": "Et clamaverunt ad Dominum cum tribularentur; et de necessitatibus eorum eduxit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 29,
      "referenceLabel": "Psalms 106:29",
      "text": "Et statuit procellam ejus in auram, et siluerunt fluctus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 30,
      "referenceLabel": "Psalms 106:30",
      "text": "Et lætati sunt quia siluerunt; et deduxit eos in portum voluntatis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 31,
      "referenceLabel": "Psalms 106:31",
      "text": "Confiteantur Domino misericordiæ ejus, et mirabilia ejus filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 32,
      "referenceLabel": "Psalms 106:32",
      "text": "Et exaltent eum in ecclesia plebis, et in cathedra seniorum laudent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 33,
      "referenceLabel": "Psalms 106:33",
      "text": "Posuit flumina in desertum, et exitus aquarum in sitim;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 34,
      "referenceLabel": "Psalms 106:34",
      "text": "terram fructiferam in salsuginem, a malitia inhabitantium in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 35,
      "referenceLabel": "Psalms 106:35",
      "text": "Posuit desertum in stagna aquarum, et terram sine aqua in exitus aquarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 36,
      "referenceLabel": "Psalms 106:36",
      "text": "Et collocavit illic esurientes, et constituerunt civitatem habitationis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 37,
      "referenceLabel": "Psalms 106:37",
      "text": "et seminaverunt agros et plantaverunt vineas, et fecerunt fructum nativitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 38,
      "referenceLabel": "Psalms 106:38",
      "text": "Et benedixit eis, et multiplicati sunt nimis; et jumenta eorum non minoravit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 39,
      "referenceLabel": "Psalms 106:39",
      "text": "Et pauci facti sunt et vexati sunt, a tribulatione malorum et dolore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 40,
      "referenceLabel": "Psalms 106:40",
      "text": "Effusa est contemptio super principes: et errare fecit eos in invio, et non in via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.41",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 41,
      "referenceLabel": "Psalms 106:41",
      "text": "Et adjuvit pauperem de inopia, et posuit sicut oves familias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.42",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 42,
      "referenceLabel": "Psalms 106:42",
      "text": "Videbunt recti, et lætabuntur; et omnis iniquitas oppilabit os suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.106.43",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 106,
      "verseNumber": 43,
      "referenceLabel": "Psalms 106:43",
      "text": "Quis sapiens, et custodiet hæc, et intelliget misericordias Domini?",
      "paragraphStart": false
    }
  ]
}
