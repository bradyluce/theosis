{
  "chapter": {
    "id": "vulgate:psalms.36",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.36.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "Psalmus ipsi David. Noli æmulari in malignantibus, neque zelaveris facientes iniquitatem:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.36.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "quoniam tamquam fœnum velociter arescent, et quemadmodum olera herbarum cito decident.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "Spera in Domino, et fac bonitatem; et inhabita terram, et pasceris in divitiis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "Delectare in Domino, et dabit tibi petitiones cordis tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "Revela Domino viam tuam, et spera in eo, et ipse faciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "Et educet quasi lumen justitiam tuam, et judicium tuum tamquam meridiem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "Subditus esto Domino, et ora eum. Noli æmulari in eo qui prosperatur in via sua; in homine faciente injustitias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "Desine ab ira, et derelinque furorem; noli æmulari ut maligneris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "Quoniam qui malignantur exterminabuntur; sustinentes autem Dominum, ipsi hæreditabunt terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "Et adhuc pusillum, et non erit peccator; et quæres locum ejus, et non invenies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "Mansueti autem hæreditabunt terram, et delectabuntur in multitudine pacis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "Observabit peccator justum, et stridebit super eum dentibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Psalms 36:13",
      "text": "Dominus autem irridebit eum, quoniam prospicit quod veniet dies ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Psalms 36:14",
      "text": "Gladium evaginaverunt peccatores; intenderunt arcum suum: ut dejiciant pauperem et inopem, ut trucident rectos corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Psalms 36:15",
      "text": "Gladius eorum intret in corda ipsorum, et arcus eorum confringatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Psalms 36:16",
      "text": "Melius est modicum justo, super divitias peccatorum multas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Psalms 36:17",
      "text": "quoniam brachia peccatorum conterentur: confirmat autem justos Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Psalms 36:18",
      "text": "Novit Dominus dies immaculatorum, et hæreditas eorum in æternum erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Psalms 36:19",
      "text": "Non confundentur in tempore malo, et in diebus famis saturabuntur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Psalms 36:20",
      "text": "quia peccatores peribunt. Inimici vero Domini mox ut honorificati fuerint et exaltati, deficientes quemadmodum fumus deficient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Psalms 36:21",
      "text": "Mutuabitur peccator, et non solvet; justus autem miseretur et tribuet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Psalms 36:22",
      "text": "quia benedicentes ei hæreditabunt terram; maledicentes autem ei disperibunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Psalms 36:23",
      "text": "Apud Dominum gressus hominis dirigentur, et viam ejus volet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Psalms 36:24",
      "text": "Cum ceciderit, non collidetur, quia Dominus supponit manum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Psalms 36:25",
      "text": "Junior fui, etenim senui; et non vidi justum derelictum, nec semen ejus quærens panem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Psalms 36:26",
      "text": "Tota die miseretur et commodat; et semen illius in benedictione erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Psalms 36:27",
      "text": "Declina a malo, et fac bonum, et inhabita in sæculum sæculi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Psalms 36:28",
      "text": "quia Dominus amat judicium, et non derelinquet sanctos suos: in æternum conservabuntur. Injusti punientur, et semen impiorum peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Psalms 36:29",
      "text": "Justi autem hæreditabunt terram, et inhabitabunt in sæculum sæculi super eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Psalms 36:30",
      "text": "Os justi meditabitur sapientiam, et lingua ejus loquetur judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Psalms 36:31",
      "text": "Lex Dei ejus in corde ipsius, et non supplantabuntur gressus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Psalms 36:32",
      "text": "Considerat peccator justum, et quærit mortificare eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Psalms 36:33",
      "text": "Dominus autem non derelinquet eum in manibus ejus, nec damnabit eum cum judicabitur illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 34,
      "referenceLabel": "Psalms 36:34",
      "text": "Exspecta Dominum, et custodi viam ejus, et exaltabit te ut hæreditate capias terram: cum perierint peccatores, videbis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 35,
      "referenceLabel": "Psalms 36:35",
      "text": "Vidi impium superexaltatum, et elevatum sicut cedros Libani:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 36,
      "referenceLabel": "Psalms 36:36",
      "text": "et transivi, et ecce non erat; et quæsivi eum, et non est inventus locus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 37,
      "referenceLabel": "Psalms 36:37",
      "text": "Custodi innocentiam, et vide æquitatem, quoniam sunt reliquiæ homini pacifico.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 38,
      "referenceLabel": "Psalms 36:38",
      "text": "Injusti autem disperibunt simul; reliquiæ impiorum interibunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 39,
      "referenceLabel": "Psalms 36:39",
      "text": "Salus autem justorum a Domino; et protector eorum in tempore tribulationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.36.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 40,
      "referenceLabel": "Psalms 36:40",
      "text": "Et adjuvabit eos Dominus, et liberabit eos; et eruet eos a peccatoribus, et salvabit eos, quia speraverunt in eo.",
      "paragraphStart": false
    }
  ]
}
