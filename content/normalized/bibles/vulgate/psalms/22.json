{
  "chapter": {
    "id": "vulgate:psalms.22",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.22.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "Psalmus David. Dominus regit me, et nihil mihi deerit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.22.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "in loco pascuæ, ibi me collocavit. Super aquam refectionis educavit me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.22.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "animam meam convertit. Deduxit me super semitas justitiæ propter nomen suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.22.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Nam etsi ambulavero in medio umbræ mortis, non timebo mala, quoniam tu mecum es. Virga tua, et baculus tuus, ipsa me consolata sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.22.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "Parasti in conspectu meo mensam adversus eos qui tribulant me; impinguasti in oleo caput meum: et calix meus inebrians, quam præclarus est!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.22.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "Et misericordia tua subsequetur me omnibus diebus vitæ meæ; et ut inhabitem in domo Domini in longitudinem dierum.",
      "paragraphStart": false
    }
  ]
}
