{
  "chapter": {
    "id": "vulgate:psalms.93",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 93,
    "referenceLabel": "Psalms 93",
    "summary": "Source text for Psalms 93 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.93.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 1,
      "referenceLabel": "Psalms 93:1",
      "text": "Psalmus ipsi David, quarta sabbati. Deus ultionum Dominus; Deus ultionum libere egit.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.93.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 2,
      "referenceLabel": "Psalms 93:2",
      "text": "Exaltare, qui judicas terram; redde retributionem superbis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 3,
      "referenceLabel": "Psalms 93:3",
      "text": "Usquequo peccatores, Domine, usquequo peccatores gloriabuntur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 4,
      "referenceLabel": "Psalms 93:4",
      "text": "effabuntur et loquentur iniquitatem; loquentur omnes qui operantur injustitiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 5,
      "referenceLabel": "Psalms 93:5",
      "text": "Populum tuum, Domine, humiliaverunt, et hæreditatem tuam vexaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 6,
      "referenceLabel": "Psalms 93:6",
      "text": "Viduam et advenam interfecerunt, et pupillos occiderunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 7,
      "referenceLabel": "Psalms 93:7",
      "text": "Et dixerunt: Non videbit Dominus, nec intelliget Deus Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 8,
      "referenceLabel": "Psalms 93:8",
      "text": "Intelligite, insipientes in populo; et stulti, aliquando sapite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 9,
      "referenceLabel": "Psalms 93:9",
      "text": "Qui plantavit aurem non audiet? aut qui finxit oculum non considerat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 10,
      "referenceLabel": "Psalms 93:10",
      "text": "Qui corripit gentes non arguet, qui docet hominem scientiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 11,
      "referenceLabel": "Psalms 93:11",
      "text": "Dominus scit cogitationes hominum, quoniam vanæ sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 12,
      "referenceLabel": "Psalms 93:12",
      "text": "Beatus homo quem tu erudieris, Domine, et de lege tua docueris eum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 13,
      "referenceLabel": "Psalms 93:13",
      "text": "ut mitiges ei a diebus malis, donec fodiatur peccatori fovea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 14,
      "referenceLabel": "Psalms 93:14",
      "text": "Quia non repellet Dominus plebem suam, et hæreditatem suam non derelinquet,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 15,
      "referenceLabel": "Psalms 93:15",
      "text": "quoadusque justitia convertatur in judicium: et qui juxta illam, omnes qui recto sunt corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 16,
      "referenceLabel": "Psalms 93:16",
      "text": "Quis consurget mihi adversus malignantes? aut quis stabit mecum adversus operantes iniquitatem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 17,
      "referenceLabel": "Psalms 93:17",
      "text": "Nisi quia Dominus adjuvit me, paulominus habitasset in inferno anima mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 18,
      "referenceLabel": "Psalms 93:18",
      "text": "Si dicebam: Motus est pes meus: misericordia tua, Domine, adjuvabat me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 19,
      "referenceLabel": "Psalms 93:19",
      "text": "Secundum multitudinem dolorum meorum in corde meo, consolationes tuæ lætificaverunt animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 20,
      "referenceLabel": "Psalms 93:20",
      "text": "Numquid adhæret tibi sedes iniquitatis, qui fingis laborem in præcepto?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 21,
      "referenceLabel": "Psalms 93:21",
      "text": "Captabunt in animam justi, et sanguinem innocentem condemnabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 22,
      "referenceLabel": "Psalms 93:22",
      "text": "Et factus est mihi Dominus in refugium, et Deus meus in adjutorium spei meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.93.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 23,
      "referenceLabel": "Psalms 93:23",
      "text": "Et reddet illis iniquitatem ipsorum, et in malitia eorum disperdet eos: disperdet illos Dominus Deus noster.",
      "paragraphStart": false
    }
  ]
}
