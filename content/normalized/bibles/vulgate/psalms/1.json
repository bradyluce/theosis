{
  "chapter": {
    "id": "vulgate:psalms.1",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 1,
    "referenceLabel": "Psalms 1",
    "summary": "Source text for Psalms 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.1.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Psalms 1:1",
      "text": "Beatus vir qui non abiit in consilio impiorum, et in via peccatorum non stetit, et in cathedra pestilentiæ non sedit;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.1.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Psalms 1:2",
      "text": "sed in lege Domini voluntas ejus, et in lege ejus meditabitur die ac nocte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.1.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Psalms 1:3",
      "text": "Et erit tamquam lignum quod plantatum est secus decursus aquarum, quod fructum suum dabit in tempore suo: et folium ejus non defluet; et omnia quæcumque faciet prosperabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.1.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Psalms 1:4",
      "text": "Non sic impii, non sic; sed tamquam pulvis quem projicit ventus a facie terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.1.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Psalms 1:5",
      "text": "Ideo non resurgent impii in judicio, neque peccatores in concilio justorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.1.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Psalms 1:6",
      "text": "quoniam novit Dominus viam justorum, et iter impiorum peribit.",
      "paragraphStart": false
    }
  ]
}
