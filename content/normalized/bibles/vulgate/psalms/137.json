{
  "chapter": {
    "id": "vulgate:psalms.137",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.137.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "Ipsi David. Confitebor tibi, Domine, in toto corde meo, quoniam audisti verba oris mei. In conspectu angelorum psallam tibi;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.137.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "adorabo ad templum sanctum tuum, et confitebor nomini tuo: super misericordia tua et veritate tua; quoniam magnificasti super omne, nomen sanctum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.137.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "In quacumque die invocavero te, exaudi me; multiplicabis in anima mea virtutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.137.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "Confiteantur tibi, Domine, omnes reges terræ, quia audierunt omnia verba oris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.137.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "Et cantent in viis Domini, quoniam magna est gloria Domini;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.137.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "quoniam excelsus Dominus, et humilia respicit, et alta a longe cognoscit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.137.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "Si ambulavero in medio tribulationis, vivificabis me; et super iram inimicorum meorum extendisti manum tuam, et salvum me fecit dextera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.137.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "Dominus retribuet pro me. Domine, misericordia tua in sæculum; opera manuum tuarum ne despicias.",
      "paragraphStart": false
    }
  ]
}
