{
  "chapter": {
    "id": "vulgate:psalms.55",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 55,
    "referenceLabel": "Psalms 55",
    "summary": "Source text for Psalms 55 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.55.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 1,
      "referenceLabel": "Psalms 55:1",
      "text": "In finem, pro populo qui a sanctis longe factus est. David in tituli inscriptionem, cum tenuerunt eum Allophyli in Geth.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.55.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 2,
      "referenceLabel": "Psalms 55:2",
      "text": "Miserere mei, Deus, quoniam conculcavit me homo; tota die impugnans, tribulavit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 3,
      "referenceLabel": "Psalms 55:3",
      "text": "Conculcaverunt me inimici mei tota die, quoniam multi bellantes adversum me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 4,
      "referenceLabel": "Psalms 55:4",
      "text": "Ab altitudine diei timebo: ego vero in te sperabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 5,
      "referenceLabel": "Psalms 55:5",
      "text": "In Deo laudabo sermones meos; in Deo speravi: non timebo quid faciat mihi caro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 6,
      "referenceLabel": "Psalms 55:6",
      "text": "Tota die verba mea execrabantur; adversum me omnes cogitationes eorum in malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 7,
      "referenceLabel": "Psalms 55:7",
      "text": "Inhabitabunt, et abscondent; ipsi calcaneum meum observabunt. Sicut sustinuerunt animam meam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 8,
      "referenceLabel": "Psalms 55:8",
      "text": "pro nihilo salvos facies illos; in ira populos confringes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 9,
      "referenceLabel": "Psalms 55:9",
      "text": "Deus, vitam meam annuntiavi tibi; posuisti lacrimas meas in conspectu tuo, sicut et in promissione tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 10,
      "referenceLabel": "Psalms 55:10",
      "text": "tunc convertentur inimici mei retrorsum. In quacumque die invocavero te, ecce cognovi quoniam Deus meus es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 11,
      "referenceLabel": "Psalms 55:11",
      "text": "In Deo laudabo verbum; in Domino laudabo sermonem. In Deo speravi: non timebo quid faciat mihi homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 12,
      "referenceLabel": "Psalms 55:12",
      "text": "In me sunt, Deus, vota tua, quæ reddam, laudationes tibi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.55.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 13,
      "referenceLabel": "Psalms 55:13",
      "text": "quoniam eripuisti animam meam de morte, et pedes meos de lapsu, ut placeam coram Deo in lumine viventium.",
      "paragraphStart": false
    }
  ]
}
