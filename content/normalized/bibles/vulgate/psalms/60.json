{
  "chapter": {
    "id": "vulgate:psalms.60",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.60.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "In finem. In hymnis David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.60.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "Exaudi, Deus, deprecationem meam; intende orationi meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "A finibus terræ ad te clamavi, dum anxiaretur cor meum; in petra exaltasti me. Deduxisti me,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "quia factus es spes mea: turris fortitudinis a facie inimici.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "Inhabitabo in tabernaculo tuo in sæcula; protegar in velamento alarum tuarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "Quoniam tu, Deus meus, exaudisti orationem meam; dedisti hæreditatem timentibus nomen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Dies super dies regis adjicies; annos ejus usque in diem generationis et generationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "Permanet in æternum in conspectu Dei: misericordiam et veritatem ejus quis requiret?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.60.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "Sic psalmum dicam nomini tuo in sæculum sæculi, ut reddam vota mea de die in diem.",
      "paragraphStart": false
    }
  ]
}
