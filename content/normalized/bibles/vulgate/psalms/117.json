{
  "chapter": {
    "id": "vulgate:psalms.117",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 117,
    "referenceLabel": "Psalms 117",
    "summary": "Source text for Psalms 117 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.117.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 1,
      "referenceLabel": "Psalms 117:1",
      "text": "Alleluja. Confitemini Domino, quoniam bonus, quoniam in sæculum misericordia ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.117.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 2,
      "referenceLabel": "Psalms 117:2",
      "text": "Dicat nunc Israël: Quoniam bonus, quoniam in sæculum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 3,
      "referenceLabel": "Psalms 117:3",
      "text": "Dicat nunc domus Aaron: Quoniam in sæculum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 4,
      "referenceLabel": "Psalms 117:4",
      "text": "Dicant nunc qui timent Dominum: Quoniam in sæculum misericordia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 5,
      "referenceLabel": "Psalms 117:5",
      "text": "De tribulatione invocavi Dominum, et exaudivit me in latitudine Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 6,
      "referenceLabel": "Psalms 117:6",
      "text": "Dominus mihi adjutor; non timebo quid faciat mihi homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 7,
      "referenceLabel": "Psalms 117:7",
      "text": "Dominus mihi adjutor, et ego despiciam inimicos meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 8,
      "referenceLabel": "Psalms 117:8",
      "text": "Bonum est confidere in Domino, quam confidere in homine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 9,
      "referenceLabel": "Psalms 117:9",
      "text": "Bonum est sperare in Domino, quam sperare in principibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 10,
      "referenceLabel": "Psalms 117:10",
      "text": "Omnes gentes circuierunt me, et in nomine Domini, quia ultus sum in eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 11,
      "referenceLabel": "Psalms 117:11",
      "text": "Circumdantes circumdederunt me, et in nomine Domini, quia ultus sum in eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 12,
      "referenceLabel": "Psalms 117:12",
      "text": "Circumdederunt me sicut apes, et exarserunt sicut ignis in spinis: et in nomine Domini, quia ultus sum in eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 13,
      "referenceLabel": "Psalms 117:13",
      "text": "Impulsus eversus sum, ut caderem, et Dominus suscepit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 14,
      "referenceLabel": "Psalms 117:14",
      "text": "Fortitudo mea et laus mea Dominus, et factus est mihi in salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 15,
      "referenceLabel": "Psalms 117:15",
      "text": "Vox exsultationis et salutis in tabernaculis justorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 16,
      "referenceLabel": "Psalms 117:16",
      "text": "Dextera Domini fecit virtutem; dextera Domini exaltavit me: dextera Domini fecit virtutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 17,
      "referenceLabel": "Psalms 117:17",
      "text": "Non moriar, sed vivam, et narrabo opera Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 18,
      "referenceLabel": "Psalms 117:18",
      "text": "Castigans castigavit me Dominus, et morti non tradidit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 19,
      "referenceLabel": "Psalms 117:19",
      "text": "Aperite mihi portas justitiæ: ingressus in eas confitebor Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 20,
      "referenceLabel": "Psalms 117:20",
      "text": "Hæc porta Domini: justi intrabunt in eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 21,
      "referenceLabel": "Psalms 117:21",
      "text": "Confitebor tibi quoniam exaudisti me, et factus es mihi in salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 22,
      "referenceLabel": "Psalms 117:22",
      "text": "Lapidem quem reprobaverunt ædificantes, hic factus est in caput anguli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 23,
      "referenceLabel": "Psalms 117:23",
      "text": "A Domino factum est istud, et est mirabile in oculis nostris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 24,
      "referenceLabel": "Psalms 117:24",
      "text": "Hæc est dies quam fecit Dominus; exsultemus, et lætemur in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 25,
      "referenceLabel": "Psalms 117:25",
      "text": "O Domine, salvum me fac; o Domine, bene prosperare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 26,
      "referenceLabel": "Psalms 117:26",
      "text": "Benedictus qui venit in nomine Domini: benediximus vobis de domo Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 27,
      "referenceLabel": "Psalms 117:27",
      "text": "Deus Dominus, et illuxit nobis. Constituite diem solemnem in condensis, usque ad cornu altaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 28,
      "referenceLabel": "Psalms 117:28",
      "text": "Deus meus es tu, et confitebor tibi; Deus meus es tu, et exaltabo te. Confitebor tibi quoniam exaudisti me, et factus es mihi in salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.117.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 29,
      "referenceLabel": "Psalms 117:29",
      "text": "Confitemini Domino, quoniam bonus, quoniam in sæculum misericordia ejus.",
      "paragraphStart": false
    }
  ]
}
