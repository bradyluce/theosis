{
  "chapter": {
    "id": "vulgate:psalms.65",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.65.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "In finem. Canticum psalmi resurrectionis. Jubilate Deo, omnis terra;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.65.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "psalmum dicite nomini ejus; date gloriam laudi ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "Dicite Deo: Quam terribilia sunt opera tua, Domine! in multitudine virtutis tuæ mentientur tibi inimici tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "Omnis terra adoret te, et psallat tibi; psalmum dicat nomini tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "Venite, et videte opera Dei: terribilis in consiliis super filios hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "Qui convertit mare in aridam; in flumine pertransibunt pede: ibi lætabimur in ipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "Qui dominatur in virtute sua in æternum; oculi ejus super gentes respiciunt: qui exasperant non exaltentur in semetipsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "Benedicite, gentes, Deum nostrum, et auditam facite vocem laudis ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "qui posuit animam meam ad vitam, et non dedit in commotionem pedes meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "Quoniam probasti nos, Deus; igne nos examinasti, sicut examinatur argentum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "Induxisti nos in laqueum; posuisti tribulationes in dorso nostro;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "imposuisti homines super capita nostra. Transivimus per ignem et aquam, et eduxisti nos in refrigerium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "Introibo in domum tuam in holocaustis; reddam tibi vota mea",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 14,
      "referenceLabel": "Psalms 65:14",
      "text": "quæ distinxerunt labia mea: et locutum est os meum in tribulatione mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 15,
      "referenceLabel": "Psalms 65:15",
      "text": "Holocausta medullata offeram tibi, cum incenso arietum; offeram tibi boves cum hircis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 16,
      "referenceLabel": "Psalms 65:16",
      "text": "Venite, audite, et narrabo, omnes qui timetis Deum, quanta fecit animæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 17,
      "referenceLabel": "Psalms 65:17",
      "text": "Ad ipsum ore meo clamavi, et exaltavi sub lingua mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 18,
      "referenceLabel": "Psalms 65:18",
      "text": "Iniquitatem si aspexi in corde meo, non exaudiet Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 19,
      "referenceLabel": "Psalms 65:19",
      "text": "Propterea exaudivit Deus, et attendit voci deprecationis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.65.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 20,
      "referenceLabel": "Psalms 65:20",
      "text": "Benedictus Deus, qui non amovit orationem meam, et misericordiam suam a me.",
      "paragraphStart": false
    }
  ]
}
