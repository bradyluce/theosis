{
  "chapter": {
    "id": "vulgate:psalms.127",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 127,
    "referenceLabel": "Psalms 127",
    "summary": "Source text for Psalms 127 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.127.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 1,
      "referenceLabel": "Psalms 127:1",
      "text": "Canticum graduum. Beati omnes qui timent Dominum, qui ambulant in viis ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.127.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 2,
      "referenceLabel": "Psalms 127:2",
      "text": "Labores manuum tuarum quia manducabis: beatus es, et bene tibi erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.127.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 3,
      "referenceLabel": "Psalms 127:3",
      "text": "Uxor tua sicut vitis abundans in lateribus domus tuæ; filii tui sicut novellæ olivarum in circuitu mensæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.127.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 4,
      "referenceLabel": "Psalms 127:4",
      "text": "Ecce sic benedicetur homo qui timet Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.127.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 5,
      "referenceLabel": "Psalms 127:5",
      "text": "Benedicat tibi Dominus ex Sion, et videas bona Jerusalem omnibus diebus vitæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.127.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 6,
      "referenceLabel": "Psalms 127:6",
      "text": "Et videas filios filiorum tuorum: pacem super Israël.",
      "paragraphStart": false
    }
  ]
}
