{
  "chapter": {
    "id": "vulgate:psalms.70",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 70,
    "referenceLabel": "Psalms 70",
    "summary": "Source text for Psalms 70 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.70.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 1,
      "referenceLabel": "Psalms 70:1",
      "text": "Psalmus David, filiorum Jonadab, et priorum captivorum. In te, Domine, speravi; non confundar in æternum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.70.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 2,
      "referenceLabel": "Psalms 70:2",
      "text": "In justitia tua libera me, et eripe me: inclina ad me aurem tuam, et salva me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 3,
      "referenceLabel": "Psalms 70:3",
      "text": "Esto mihi in Deum protectorem, et in locum munitum, ut salvum me facias: quoniam firmamentum meum et refugium meum es tu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 4,
      "referenceLabel": "Psalms 70:4",
      "text": "Deus meus, eripe me de manu peccatoris, et de manu contra legem agentis, et iniqui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 5,
      "referenceLabel": "Psalms 70:5",
      "text": "quoniam tu es patientia mea, Domine; Domine, spes mea a juventute mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 6,
      "referenceLabel": "Psalms 70:6",
      "text": "In te confirmatus sum ex utero; de ventre matris meæ tu es protector meus; in te cantatio mea semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 7,
      "referenceLabel": "Psalms 70:7",
      "text": "Tamquam prodigium factus sum multis; et tu adjutor fortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 8,
      "referenceLabel": "Psalms 70:8",
      "text": "Repleatur os meum laude, ut cantem gloriam tuam, tota die magnitudinem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 9,
      "referenceLabel": "Psalms 70:9",
      "text": "Ne projicias me in tempore senectutis; cum defecerit virtus mea, ne derelinquas me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 10,
      "referenceLabel": "Psalms 70:10",
      "text": "Quia dixerunt inimici mei mihi, et qui custodiebant animam meam consilium fecerunt in unum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 11,
      "referenceLabel": "Psalms 70:11",
      "text": "dicentes: Deus dereliquit eum: persequimini et comprehendite eum, quia non est qui eripiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 12,
      "referenceLabel": "Psalms 70:12",
      "text": "Deus, ne elongeris a me; Deus meus, in auxilium meum respice.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 13,
      "referenceLabel": "Psalms 70:13",
      "text": "Confundantur et deficiant detrahentes animæ meæ; operiantur confusione et pudore qui quærunt mala mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 14,
      "referenceLabel": "Psalms 70:14",
      "text": "Ego autem semper sperabo, et adjiciam super omnem laudem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 15,
      "referenceLabel": "Psalms 70:15",
      "text": "Os meum annuntiabit justitiam tuam, tota die salutare tuum. Quoniam non cognovi litteraturam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 16,
      "referenceLabel": "Psalms 70:16",
      "text": "introibo in potentias Domini; Domine, memorabor justitiæ tuæ solius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 17,
      "referenceLabel": "Psalms 70:17",
      "text": "Deus, docuisti me a juventute mea; et usque nunc pronuntiabo mirabilia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 18,
      "referenceLabel": "Psalms 70:18",
      "text": "Et usque in senectam et senium, Deus, ne derelinquas me, donec annuntiem brachium tuum generationi omni quæ ventura est, potentiam tuam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 19,
      "referenceLabel": "Psalms 70:19",
      "text": "et justitiam tuam, Deus, usque in altissima; quæ fecisti magnalia, Deus: quis similis tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 20,
      "referenceLabel": "Psalms 70:20",
      "text": "Quantas ostendisti mihi tribulationes multas et malas! et conversus vivificasti me, et de abyssis terræ iterum reduxisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 21,
      "referenceLabel": "Psalms 70:21",
      "text": "Multiplicasti magnificentiam tuam; et conversus consolatus es me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 22,
      "referenceLabel": "Psalms 70:22",
      "text": "Nam et ego confitebor tibi in vasis psalmi veritatem tuam, Deus; psallam tibi in cithara, sanctus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 23,
      "referenceLabel": "Psalms 70:23",
      "text": "Exsultabunt labia mea cum cantavero tibi; et anima mea quam redemisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.70.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 24,
      "referenceLabel": "Psalms 70:24",
      "text": "Sed et lingua mea tota die meditabitur justitiam tuam, cum confusi et reveriti fuerint qui quærunt mala mihi.",
      "paragraphStart": false
    }
  ]
}
