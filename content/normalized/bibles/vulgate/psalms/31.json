{
  "chapter": {
    "id": "vulgate:psalms.31",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 31,
    "referenceLabel": "Psalms 31",
    "summary": "Source text for Psalms 31 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.31.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Psalms 31:1",
      "text": "Ipsi David intellectus. Beati quorum remissæ sunt iniquitates, et quorum tecta sunt peccata.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.31.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Psalms 31:2",
      "text": "Beatus vir cui non imputavit Dominus peccatum, nec est in spiritu ejus dolus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Psalms 31:3",
      "text": "Quoniam tacui, inveteraverunt ossa mea, dum clamarem tota die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Psalms 31:4",
      "text": "Quoniam die ac nocte gravata est super me manus tua, conversus sum in ærumna mea, dum configitur spina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Psalms 31:5",
      "text": "Delictum meum cognitum tibi feci, et injustitiam meam non abscondi. Dixi: Confitebor adversum me injustitiam meam Domino; et tu remisisti impietatem peccati mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Psalms 31:6",
      "text": "Pro hac orabit ad te omnis sanctus in tempore opportuno. Verumtamen in diluvio aquarum multarum, ad eum non approximabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Psalms 31:7",
      "text": "Tu es refugium meum a tribulatione quæ circumdedit me; exsultatio mea, erue me a circumdantibus me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Psalms 31:8",
      "text": "Intellectum tibi dabo, et instruam te in via hac qua gradieris; firmabo super te oculos meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Psalms 31:9",
      "text": "Nolite fieri sicut equus et mulus, quibus non est intellectus. In camo et freno maxillas eorum constringe, qui non approximant ad te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Psalms 31:10",
      "text": "Multa flagella peccatoris; sperantem autem in Domino misericordia circumdabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.31.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Psalms 31:11",
      "text": "Lætamini in Domino, et exsultate, justi; et gloriamini, omnes recti corde.",
      "paragraphStart": false
    }
  ]
}
