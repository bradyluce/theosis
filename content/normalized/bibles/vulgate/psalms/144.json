{
  "chapter": {
    "id": "vulgate:psalms.144",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 144,
    "referenceLabel": "Psalms 144",
    "summary": "Source text for Psalms 144 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.144.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 1,
      "referenceLabel": "Psalms 144:1",
      "text": "Laudatio ipsi David. Exaltabo te, Deus meus rex, et benedicam nomini tuo in sæculum, et in sæculum sæculi.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.144.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 2,
      "referenceLabel": "Psalms 144:2",
      "text": "Per singulos dies benedicam tibi, et laudabo nomen tuum in sæculum, et in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 3,
      "referenceLabel": "Psalms 144:3",
      "text": "Magnus Dominus, et laudabilis nimis, et magnitudinis ejus non est finis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 4,
      "referenceLabel": "Psalms 144:4",
      "text": "Generatio et generatio laudabit opera tua, et potentiam tuam pronuntiabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 5,
      "referenceLabel": "Psalms 144:5",
      "text": "Magnificentiam gloriæ sanctitatis tuæ loquentur, et mirabilia tua narrabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 6,
      "referenceLabel": "Psalms 144:6",
      "text": "Et virtutem terribilium tuorum dicent, et magnitudinem tuam narrabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 7,
      "referenceLabel": "Psalms 144:7",
      "text": "Memoriam abundantiæ suavitatis tuæ eructabunt, et justitia tua exsultabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 8,
      "referenceLabel": "Psalms 144:8",
      "text": "Miserator et misericors Dominus: patiens, et multum misericors.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 9,
      "referenceLabel": "Psalms 144:9",
      "text": "Suavis Dominus universis, et miserationes ejus super omnia opera ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 10,
      "referenceLabel": "Psalms 144:10",
      "text": "Confiteantur tibi, Domine, omnia opera tua, et sancti tui benedicant tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 11,
      "referenceLabel": "Psalms 144:11",
      "text": "Gloriam regni tui dicent, et potentiam tuam loquentur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 12,
      "referenceLabel": "Psalms 144:12",
      "text": "ut notam faciant filiis hominum potentiam tuam, et gloriam magnificentiæ regni tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 13,
      "referenceLabel": "Psalms 144:13",
      "text": "Regnum tuum regnum omnium sæculorum; et dominatio tua in omni generatione et generationem. Fidelis Dominus in omnibus verbis suis, et sanctus in omnibus operibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 14,
      "referenceLabel": "Psalms 144:14",
      "text": "Allevat Dominus omnes qui corruunt, et erigit omnes elisos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 15,
      "referenceLabel": "Psalms 144:15",
      "text": "Oculi omnium in te sperant, Domine, et tu das escam illorum in tempore opportuno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 16,
      "referenceLabel": "Psalms 144:16",
      "text": "Aperis tu manum tuam, et imples omne animal benedictione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 17,
      "referenceLabel": "Psalms 144:17",
      "text": "Justus Dominus in omnibus viis suis, et sanctus in omnibus operibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 18,
      "referenceLabel": "Psalms 144:18",
      "text": "Prope est Dominus omnibus invocantibus eum, omnibus invocantibus eum in veritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 19,
      "referenceLabel": "Psalms 144:19",
      "text": "Voluntatem timentium se faciet, et deprecationem eorum exaudiet, et salvos faciet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 20,
      "referenceLabel": "Psalms 144:20",
      "text": "Custodit Dominus omnes diligentes se, et omnes peccatores disperdet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.144.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 144,
      "verseNumber": 21,
      "referenceLabel": "Psalms 144:21",
      "text": "Laudationem Domini loquetur os meum; et benedicat omnis caro nomini sancto ejus in sæculum, et in sæculum sæculi.",
      "paragraphStart": false
    }
  ]
}
