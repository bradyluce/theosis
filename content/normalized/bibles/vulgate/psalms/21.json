{
  "chapter": {
    "id": "vulgate:psalms.21",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.21.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "In finem, pro susceptione matutina. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.21.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "Deus, Deus meus, respice in me: quare me dereliquisti? longe a salute mea verba delictorum meorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "Deus meus, clamabo per diem, et non exaudies; et nocte, et non ad insipientiam mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "Tu autem in sancto habitas, laus Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "In te speraverunt patres nostri; speraverunt, et liberasti eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "Ad te clamaverunt, et salvi facti sunt; in te speraverunt, et non sunt confusi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "Ego autem sum vermis, et non homo; opprobrium hominum, et abjectio plebis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "Omnes videntes me deriserunt me; locuti sunt labiis, et moverunt caput.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "Speravit in Domino, eripiat eum: salvum faciat eum, quoniam vult eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "Quoniam tu es qui extraxisti me de ventre, spes mea ab uberibus matris meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "In te projectus sum ex utero; de ventre matris meæ Deus meus es tu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "ne discesseris a me, quoniam tribulatio proxima est, quoniam non est qui adjuvet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Circumdederunt me vituli multi; tauri pingues obsederunt me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Psalms 21:14",
      "text": "Aperuerunt super me os suum, sicut leo rapiens et rugiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Psalms 21:15",
      "text": "Sicut aqua effusus sum, et dispersa sunt omnia ossa mea: factum est cor meum tamquam cera liquescens in medio ventris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Psalms 21:16",
      "text": "Aruit tamquam testa virtus mea, et lingua mea adhæsit faucibus meis: et in pulverem mortis deduxisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Psalms 21:17",
      "text": "Quoniam circumdederunt me canes multi; concilium malignantium obsedit me. Foderunt manus meas et pedes meos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Psalms 21:18",
      "text": "dinumeraverunt omnia ossa mea. Ipsi vero consideraverunt et inspexerunt me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Psalms 21:19",
      "text": "Diviserunt sibi vestimenta mea, et super vestem meam miserunt sortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Psalms 21:20",
      "text": "Tu autem, Domine, ne elongaveris auxilium tuum a me; ad defensionem meam conspice.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Psalms 21:21",
      "text": "Erue a framea, Deus, animam meam, et de manu canis unicam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Psalms 21:22",
      "text": "Salva me ex ore leonis, et a cornibus unicornium humilitatem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Psalms 21:23",
      "text": "Narrabo nomen tuum fratribus meis; in medio ecclesiæ laudabo te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Psalms 21:24",
      "text": "Qui timetis Dominum, laudate eum; universum semen Jacob, glorificate eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Psalms 21:25",
      "text": "Timeat eum omne semen Israël, quoniam non sprevit, neque despexit deprecationem pauperis, nec avertit faciem suam a me: et cum clamarem ad eum, exaudivit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Psalms 21:26",
      "text": "Apud te laus mea in ecclesia magna; vota mea reddam in conspectu timentium eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Psalms 21:27",
      "text": "Edent pauperes, et saturabuntur, et laudabunt Dominum qui requirunt eum: vivent corda eorum in sæculum sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Psalms 21:28",
      "text": "Reminiscentur et convertentur ad Dominum universi fines terræ; et adorabunt in conspectu ejus universæ familiæ gentium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Psalms 21:29",
      "text": "quoniam Domini est regnum, et ipse dominabitur gentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Psalms 21:30",
      "text": "Manducaverunt et adoraverunt omnes pingues terræ; in conspectu ejus cadent omnes qui descendunt in terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Psalms 21:31",
      "text": "Et anima mea illi vivet; et semen meum serviet ipsi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.21.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Psalms 21:32",
      "text": "Annuntiabitur Domino generatio ventura; et annuntiabunt cæli justitiam ejus populo qui nascetur, quem fecit Dominus.",
      "paragraphStart": false
    }
  ]
}
