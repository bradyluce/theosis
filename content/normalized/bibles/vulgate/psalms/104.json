{
  "chapter": {
    "id": "vulgate:psalms.104",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 104,
    "referenceLabel": "Psalms 104",
    "summary": "Source text for Psalms 104 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.104.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 1,
      "referenceLabel": "Psalms 104:1",
      "text": "Alleluja. Confitemini Domino, et invocate nomen ejus; annuntiate inter gentes opera ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.104.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 2,
      "referenceLabel": "Psalms 104:2",
      "text": "Cantate ei, et psallite ei; narrate omnia mirabilia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 3,
      "referenceLabel": "Psalms 104:3",
      "text": "Laudamini in nomine sancto ejus; lætetur cor quærentium Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 4,
      "referenceLabel": "Psalms 104:4",
      "text": "Quærite Dominum, et confirmamini; quærite faciem ejus semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 5,
      "referenceLabel": "Psalms 104:5",
      "text": "Mementote mirabilium ejus quæ fecit; prodigia ejus, et judicia oris ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 6,
      "referenceLabel": "Psalms 104:6",
      "text": "semen Abraham servi ejus; filii Jacob electi ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 7,
      "referenceLabel": "Psalms 104:7",
      "text": "Ipse Dominus Deus noster; in universa terra judicia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 8,
      "referenceLabel": "Psalms 104:8",
      "text": "Memor fuit in sæculum testamenti sui; verbi quod mandavit in mille generationes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 9,
      "referenceLabel": "Psalms 104:9",
      "text": "quod disposuit ad Abraham, et juramenti sui ad Isaac:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 10,
      "referenceLabel": "Psalms 104:10",
      "text": "et statuit illud Jacob in præceptum, et Israël in testamentum æternum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 11,
      "referenceLabel": "Psalms 104:11",
      "text": "dicens: Tibi dabo terram Chanaan, funiculum hæreditatis vestræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 12,
      "referenceLabel": "Psalms 104:12",
      "text": "cum essent numero brevi, paucissimi, et incolæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 13,
      "referenceLabel": "Psalms 104:13",
      "text": "Et pertransierunt de gente in gentem, et de regno ad populum alterum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 14,
      "referenceLabel": "Psalms 104:14",
      "text": "Non reliquit hominem nocere eis: et corripuit pro eis reges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 15,
      "referenceLabel": "Psalms 104:15",
      "text": "Nolite tangere christos meos, et in prophetis meis nolite malignari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 16,
      "referenceLabel": "Psalms 104:16",
      "text": "Et vocavit famem super terram, et omne firmamentum panis contrivit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 17,
      "referenceLabel": "Psalms 104:17",
      "text": "Misit ante eos virum: in servum venumdatus est, Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 18,
      "referenceLabel": "Psalms 104:18",
      "text": "Humiliaverunt in compedibus pedes ejus; ferrum pertransiit animam ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.19",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 19,
      "referenceLabel": "Psalms 104:19",
      "text": "donec veniret verbum ejus. Eloquium Domini inflammavit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.20",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 20,
      "referenceLabel": "Psalms 104:20",
      "text": "Misit rex, et solvit eum; princeps populorum, et dimisit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.21",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 21,
      "referenceLabel": "Psalms 104:21",
      "text": "Constituit eum dominum domus suæ, et principem omnis possessionis suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.22",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 22,
      "referenceLabel": "Psalms 104:22",
      "text": "ut erudiret principes ejus sicut semetipsum, et senes ejus prudentiam doceret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.23",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 23,
      "referenceLabel": "Psalms 104:23",
      "text": "Et intravit Israël in Ægyptum, et Jacob accola fuit in terra Cham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.24",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 24,
      "referenceLabel": "Psalms 104:24",
      "text": "Et auxit populum suum vehementer, et firmavit eum super inimicos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.25",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 25,
      "referenceLabel": "Psalms 104:25",
      "text": "Convertit cor eorum, ut odirent populum ejus, et dolum facerent in servos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.26",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 26,
      "referenceLabel": "Psalms 104:26",
      "text": "Misit Moysen servum suum; Aaron quem elegit ipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.27",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 27,
      "referenceLabel": "Psalms 104:27",
      "text": "Posuit in eis verba signorum suorum, et prodigiorum in terra Cham.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.28",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 28,
      "referenceLabel": "Psalms 104:28",
      "text": "Misit tenebras, et obscuravit; et non exacerbavit sermones suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.29",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 29,
      "referenceLabel": "Psalms 104:29",
      "text": "Convertit aquas eorum in sanguinem, et occidit pisces eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.30",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 30,
      "referenceLabel": "Psalms 104:30",
      "text": "Edidit terra eorum ranas in penetralibus regum ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.31",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 31,
      "referenceLabel": "Psalms 104:31",
      "text": "Dixit, et venit cœnomyia et ciniphes in omnibus finibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.32",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 32,
      "referenceLabel": "Psalms 104:32",
      "text": "Posuit pluvias eorum grandinem: ignem comburentem in terra ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.33",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 33,
      "referenceLabel": "Psalms 104:33",
      "text": "Et percussit vineas eorum, et ficulneas eorum, et contrivit lignum finium eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.34",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 34,
      "referenceLabel": "Psalms 104:34",
      "text": "Dixit, et venit locusta, et bruchus cujus non erat numerus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.35",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 35,
      "referenceLabel": "Psalms 104:35",
      "text": "et comedit omne fœnum in terra eorum, et comedit omnem fructum terræ eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.36",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 36,
      "referenceLabel": "Psalms 104:36",
      "text": "Et percussit omne primogenitum in terra eorum, primitias omnis laboris eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.37",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 37,
      "referenceLabel": "Psalms 104:37",
      "text": "Et eduxit eos cum argento et auro, et non erat in tribubus eorum infirmus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.38",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 38,
      "referenceLabel": "Psalms 104:38",
      "text": "Lætata est Ægyptus in profectione eorum, quia incubuit timor eorum super eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.39",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 39,
      "referenceLabel": "Psalms 104:39",
      "text": "Expandit nubem in protectionem eorum, et ignem ut luceret eis per noctem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.40",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 40,
      "referenceLabel": "Psalms 104:40",
      "text": "Petierunt, et venit coturnix, et pane cæli saturavit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.41",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 41,
      "referenceLabel": "Psalms 104:41",
      "text": "Dirupit petram, et fluxerunt aquæ: abierunt in sicco flumina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.42",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 42,
      "referenceLabel": "Psalms 104:42",
      "text": "Quoniam memor fuit verbi sancti sui, quod habuit ad Abraham puerum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.43",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 43,
      "referenceLabel": "Psalms 104:43",
      "text": "Et eduxit populum suum in exsultatione, et electos suos in lætitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.44",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 44,
      "referenceLabel": "Psalms 104:44",
      "text": "Et dedit illis regiones gentium, et labores populorum possederunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.104.45",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 45,
      "referenceLabel": "Psalms 104:45",
      "text": "ut custodiant justificationes ejus, et legem ejus requirant.",
      "paragraphStart": false
    }
  ]
}
