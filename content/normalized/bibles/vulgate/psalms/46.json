{
  "chapter": {
    "id": "vulgate:psalms.46",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.46.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "In finem, pro filiis Core. Psalmus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.46.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "Omnes gentes, plaudite manibus; jubilate Deo in voce exsultationis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "quoniam Dominus excelsus, terribilis, rex magnus super omnem terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "Subjecit populos nobis, et gentes sub pedibus nostris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "Elegit nobis hæreditatem suam; speciem Jacob quam dilexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "Ascendit Deus in jubilo, et Dominus in voce tubæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "Psallite Deo nostro, psallite; psallite regi nostro, psallite:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "quoniam rex omnis terræ Deus, psallite sapienter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "Regnabit Deus super gentes; Deus sedet super sedem sanctam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.46.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "Principes populorum congregati sunt cum Deo Abraham, quoniam dii fortes terræ vehementer elevati sunt.",
      "paragraphStart": false
    }
  ]
}
