{
  "chapter": {
    "id": "vulgate:psalms.8",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.8.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "In finem, pro torcularibus. Psalmus David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.8.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "Domine, Dominus noster, quam admirabile est nomen tuum in universa terra! quoniam elevata est magnificentia tua super cælos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "Ex ore infantium et lactentium perfecisti laudem propter inimicos tuos, ut destruas inimicum et ultorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "Quoniam videbo cælos tuos, opera digitorum tuorum, lunam et stellas quæ tu fundasti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "Quid est homo, quod memor es ejus? aut filius hominis, quoniam visitas eum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "Minuisti eum paulominus ab angelis; gloria et honore coronasti eum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "et constituisti eum super opera manuum tuarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "Omnia subjecisti sub pedibus ejus, oves et boves universas, insuper et pecora campi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "volucres cæli, et pisces maris qui perambulant semitas maris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.8.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Psalms 8:10",
      "text": "Domine, Dominus noster, quam admirabile est nomen tuum in universa terra!",
      "paragraphStart": false
    }
  ]
}
