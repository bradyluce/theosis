{
  "chapter": {
    "id": "vulgate:psalms.97",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.97.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "Psalmus ipsi David. Cantate Domino canticum novum, quia mirabilia fecit. Salvavit sibi dextera ejus, et brachium sanctum ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.97.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Notum fecit Dominus salutare suum; in conspectu gentium revelavit justitiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "Recordatus est misericordiæ suæ, et veritatis suæ domui Israël. Viderunt omnes termini terræ salutare Dei nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "Jubilate Deo, omnis terra; cantate, et exsultate, et psallite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "Psallite Domino in cithara; in cithara et voce psalmi;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "in tubis ductilibus, et voce tubæ corneæ. Jubilate in conspectu regis Domini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "moveatur mare, et plenitudo ejus; orbis terrarum, et qui habitant in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Flumina plaudent manu; simul montes exsultabunt",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.97.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "a conspectu Domini: quoniam venit judicare terram. Judicabit orbem terrarum in justitia, et populos in æquitate.",
      "paragraphStart": false
    }
  ]
}
