{
  "chapter": {
    "id": "vulgate:psalms.53",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 53,
    "referenceLabel": "Psalms 53",
    "summary": "Source text for Psalms 53 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.53.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 1,
      "referenceLabel": "Psalms 53:1",
      "text": "In finem, in carminibus. Intellectus David,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.53.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 2,
      "referenceLabel": "Psalms 53:2",
      "text": "cum venissent Ziphæi, et dixissent ad Saul: Nonne David absconditus est apud nos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 3,
      "referenceLabel": "Psalms 53:3",
      "text": "Deus, in nomine tuo salvum me fac, et in virtute tua judica me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 4,
      "referenceLabel": "Psalms 53:4",
      "text": "Deus, exaudi orationem meam; auribus percipe verba oris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 5,
      "referenceLabel": "Psalms 53:5",
      "text": "Quoniam alieni insurrexerunt adversum me, et fortes quæsierunt animam meam, et non proposuerunt Deum ante conspectum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 6,
      "referenceLabel": "Psalms 53:6",
      "text": "Ecce enim Deus adjuvat me, et Dominus susceptor est animæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 7,
      "referenceLabel": "Psalms 53:7",
      "text": "Averte mala inimicis meis; et in veritate tua disperde illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 8,
      "referenceLabel": "Psalms 53:8",
      "text": "Voluntarie sacrificabo tibi, et confitebor nomini tuo, Domine, quoniam bonum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.53.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 53,
      "verseNumber": 9,
      "referenceLabel": "Psalms 53:9",
      "text": "Quoniam ex omni tribulatione eripuisti me, et super inimicos meos despexit oculus meus.",
      "paragraphStart": false
    }
  ]
}
