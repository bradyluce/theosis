{
  "chapter": {
    "id": "vulgate:psalms.107",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 107,
    "referenceLabel": "Psalms 107",
    "summary": "Source text for Psalms 107 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.107.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 1,
      "referenceLabel": "Psalms 107:1",
      "text": "Canticum Psalmi, ipsi David.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.107.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 2,
      "referenceLabel": "Psalms 107:2",
      "text": "Paratum cor meum, Deus, paratum cor meum; cantabo, et psallam in gloria mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 3,
      "referenceLabel": "Psalms 107:3",
      "text": "Exsurge, gloria mea; exsurge, psalterium et cithara; exsurgam diluculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 4,
      "referenceLabel": "Psalms 107:4",
      "text": "Confitebor tibi in populis, Domine, et psallam tibi in nationibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 5,
      "referenceLabel": "Psalms 107:5",
      "text": "quia magna est super cælos misericordia tua, et usque ad nubes veritas tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 6,
      "referenceLabel": "Psalms 107:6",
      "text": "Exaltare super cælos, Deus, et super omnem terram gloria tua:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 7,
      "referenceLabel": "Psalms 107:7",
      "text": "ut liberentur dilecti tui. Salvum fac dextera tua, et exaudi me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 8,
      "referenceLabel": "Psalms 107:8",
      "text": "Deus locutus est in sancto suo: Exsultabo, et dividam Sichimam; et convallem tabernaculorum dimetiar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 9,
      "referenceLabel": "Psalms 107:9",
      "text": "Meus est Galaad, et meus est Manasses, et Ephraim susceptio capitis mei. Juda rex meus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 10,
      "referenceLabel": "Psalms 107:10",
      "text": "Moab lebes spei meæ: in Idumæam extendam calceamentum meum; mihi alienigenæ amici facti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 11,
      "referenceLabel": "Psalms 107:11",
      "text": "Quis deducet me in civitatem munitam? quis deducet me usque in Idumæam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 12,
      "referenceLabel": "Psalms 107:12",
      "text": "nonne tu, Deus, qui repulisti nos? et non exibis, Deus, in virtutibus nostris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 13,
      "referenceLabel": "Psalms 107:13",
      "text": "Da nobis auxilium de tribulatione, quia vana salus hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.107.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 107,
      "verseNumber": 14,
      "referenceLabel": "Psalms 107:14",
      "text": "In Deo faciemus virtutem; et ipse ad nihilum deducet inimicos nostros.",
      "paragraphStart": false
    }
  ]
}
