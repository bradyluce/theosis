{
  "chapter": {
    "id": "vulgate:psalms.58",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 58,
    "referenceLabel": "Psalms 58",
    "summary": "Source text for Psalms 58 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.58.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 1,
      "referenceLabel": "Psalms 58:1",
      "text": "In finem, ne disperdas. David in tituli inscriptionem, quando misit Saul et custodivit domum ejus ut eum interficeret.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.58.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 2,
      "referenceLabel": "Psalms 58:2",
      "text": "Eripe me de inimicis meis, Deus meus, et ab insurgentibus in me libera me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 3,
      "referenceLabel": "Psalms 58:3",
      "text": "Eripe me de operantibus iniquitatem, et de viris sanguinum salva me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 4,
      "referenceLabel": "Psalms 58:4",
      "text": "Quia ecce ceperunt animam meam; irruerunt in me fortes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 5,
      "referenceLabel": "Psalms 58:5",
      "text": "Neque iniquitas mea, neque peccatum meum, Domine; sine iniquitate cucurri, et direxi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 6,
      "referenceLabel": "Psalms 58:6",
      "text": "Exsurge in occursum meum, et vide: et tu, Domine Deus virtutum, Deus Israël, intende ad visitandas omnes gentes: non miserearis omnibus qui operantur iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 7,
      "referenceLabel": "Psalms 58:7",
      "text": "Convertentur ad vesperam, et famem patientur ut canes: et circuibunt civitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 8,
      "referenceLabel": "Psalms 58:8",
      "text": "Ecce loquentur in ore suo, et gladius in labiis eorum: quoniam quis audivit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 9,
      "referenceLabel": "Psalms 58:9",
      "text": "Et tu, Domine, deridebis eos; ad nihilum deduces omnes gentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 10,
      "referenceLabel": "Psalms 58:10",
      "text": "Fortitudinem meam ad te custodiam, quia, Deus, susceptor meus es:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 11,
      "referenceLabel": "Psalms 58:11",
      "text": "Deus meus misericordia ejus præveniet me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 12,
      "referenceLabel": "Psalms 58:12",
      "text": "Deus ostendet mihi super inimicos meos: ne occidas eos, nequando obliviscantur populi mei. Disperge illos in virtute tua, et depone eos, protector meus, Domine:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.13",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 13,
      "referenceLabel": "Psalms 58:13",
      "text": "delictum oris eorum, sermonem labiorum ipsorum; et comprehendantur in superbia sua. Et de execratione et mendacio annuntiabuntur",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.14",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 14,
      "referenceLabel": "Psalms 58:14",
      "text": "in consummatione: in ira consummationis, et non erunt. Et scient quia Deus dominabitur Jacob, et finium terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.15",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 15,
      "referenceLabel": "Psalms 58:15",
      "text": "Convertentur ad vesperam, et famem patientur ut canes: et circuibunt civitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.16",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 16,
      "referenceLabel": "Psalms 58:16",
      "text": "Ipsi dispergentur ad manducandum; si vero non fuerint saturati, et murmurabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.17",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 17,
      "referenceLabel": "Psalms 58:17",
      "text": "Ego autem cantabo fortitudinem tuam, et exsultabo mane misericordiam tuam: quia factus es susceptor meus, et refugium meum in die tribulationis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.58.18",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 18,
      "referenceLabel": "Psalms 58:18",
      "text": "Adjutor meus, tibi psallam, quia Deus susceptor meus es; Deus meus, misericordia mea.",
      "paragraphStart": false
    }
  ]
}
