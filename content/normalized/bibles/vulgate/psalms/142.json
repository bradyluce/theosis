{
  "chapter": {
    "id": "vulgate:psalms.142",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 142,
    "referenceLabel": "Psalms 142",
    "summary": "Source text for Psalms 142 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.142.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 1,
      "referenceLabel": "Psalms 142:1",
      "text": "Psalmus David, quando persequebatur eum Absalom filius ejus. Domine, exaudi orationem meam; auribus percipe obsecrationem meam in veritate tua; exaudi me in tua justitia.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.142.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 2,
      "referenceLabel": "Psalms 142:2",
      "text": "Et non intres in judicium cum servo tuo, quia non justificabitur in conspectu tuo omnis vivens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 3,
      "referenceLabel": "Psalms 142:3",
      "text": "Quia persecutus est inimicus animam meam; humiliavit in terra vitam meam; collocavit me in obscuris, sicut mortuos sæculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 4,
      "referenceLabel": "Psalms 142:4",
      "text": "Et anxiatus est super me spiritus meus; in me turbatum est cor meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 5,
      "referenceLabel": "Psalms 142:5",
      "text": "Memor fui dierum antiquorum; meditatus sum in omnibus operibus tuis: in factis manuum tuarum meditabar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 6,
      "referenceLabel": "Psalms 142:6",
      "text": "Expandi manus meas ad te; anima mea sicut terra sine aqua tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 7,
      "referenceLabel": "Psalms 142:7",
      "text": "Velociter exaudi me, Domine; defecit spiritus meus. Non avertas faciem tuam a me, et similis ero descendentibus in lacum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 8,
      "referenceLabel": "Psalms 142:8",
      "text": "Auditam fac mihi mane misericordiam tuam, quia in te speravi. Notam fac mihi viam in qua ambulem, quia ad te levavi animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.9",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 9,
      "referenceLabel": "Psalms 142:9",
      "text": "Eripe me de inimicis meis, Domine: ad te confugi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.10",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 10,
      "referenceLabel": "Psalms 142:10",
      "text": "Doce me facere voluntatem tuam, quia Deus meus es tu. Spiritus tuus bonus deducet me in terram rectam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.11",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 11,
      "referenceLabel": "Psalms 142:11",
      "text": "Propter nomen tuum, Domine, vivificabis me: in æquitate tua, educes de tribulatione animam meam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.142.12",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 12,
      "referenceLabel": "Psalms 142:12",
      "text": "et in misericordia tua disperdes inimicos meos, et perdes omnes qui tribulant animam meam, quoniam ego servus tuus sum.",
      "paragraphStart": false
    }
  ]
}
