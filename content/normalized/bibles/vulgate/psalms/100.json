{
  "chapter": {
    "id": "vulgate:psalms.100",
    "translationId": "vulgate",
    "bookSlug": "psalms",
    "chapterNumber": 100,
    "referenceLabel": "Psalms 100",
    "summary": "Source text for Psalms 100 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:psalms.100.1",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 1,
      "referenceLabel": "Psalms 100:1",
      "text": "Psalmus ipsi David. Misericordiam et judicium cantabo tibi, Domine; psallam,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:psalms.100.2",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 2,
      "referenceLabel": "Psalms 100:2",
      "text": "et intelligam in via immaculata: quando venies ad me? Perambulabam in innocentia cordis mei, in medio domus meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.100.3",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 3,
      "referenceLabel": "Psalms 100:3",
      "text": "Non proponebam ante oculos meos rem injustam; facientes prævaricationes odivi; non adhæsit mihi",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.100.4",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 4,
      "referenceLabel": "Psalms 100:4",
      "text": "cor pravum; declinantem a me malignum non cognoscebam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.100.5",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 5,
      "referenceLabel": "Psalms 100:5",
      "text": "Detrahentem secreto proximo suo, hunc persequebar: superbo oculo, et insatiabili corde, cum hoc non edebam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.100.6",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 6,
      "referenceLabel": "Psalms 100:6",
      "text": "Oculi mei ad fideles terræ, ut sedeant mecum; ambulans in via immaculata, hic mihi ministrabat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.100.7",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 7,
      "referenceLabel": "Psalms 100:7",
      "text": "Non habitabit in medio domus meæ qui facit superbiam; qui loquitur iniqua non direxit in conspectu oculorum meorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:psalms.100.8",
      "translationId": "vulgate",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 8,
      "referenceLabel": "Psalms 100:8",
      "text": "In matutino interficiebam omnes peccatores terræ, ut disperderem de civitate Domini omnes operantes iniquitatem.",
      "paragraphStart": false
    }
  ]
}
