{
  "chapter": {
    "id": "vulgate:wisdom.3",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 3,
    "referenceLabel": "Wisdom of Solomon 3",
    "summary": "Source text for Wisdom of Solomon 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.3.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 3:1",
      "text": "Justorum autem animæ in manu Dei sunt, et non tanget illos tormentum mortis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.3.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 3:2",
      "text": "Visi sunt oculis insipientium mori, et æstimata est afflictio exitus illorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 3:3",
      "text": "et quod a nobis est iter exterminium; illi autem sunt in pace:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 3:4",
      "text": "etsi coram hominibus tormenta passi sunt, spes illorum immortalitate plena est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 3:5",
      "text": "In paucis vexati sunt, in multis bene disponentur, quoniam Deus tentavit eos, et invenit illos dignos se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 3:6",
      "text": "Tamquam aurum in fornace probavit illos, et quasi holocausti hostiam accepit illos, et in tempore erit respectus illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 3:7",
      "text": "Fulgebunt justi et tamquam scintillæ in arundineto discurrent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 3:8",
      "text": "Judicabunt nationes, et dominabuntur populis, et regnabit Dominus illorum in perpetuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 3:9",
      "text": "Qui confidunt in illo intelligent veritatem, et fideles in dilectione acquiescent illi, quoniam donum et pax est electis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 3:10",
      "text": "Impii autem secundum quæ cogitaverunt correptionem habebunt: qui neglexerunt justum, et a Domino recesserunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 3:11",
      "text": "Sapientiam enim et disciplinam qui abjicit infelix est: et vacua est spes illorum, et labores sine fructu, et inutilia opera eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 3:12",
      "text": "Mulieres eorum insensatæ sunt, et nequissimi filii eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 3:13",
      "text": "Maledicta creatura eorum, quoniam felix est sterilis; et incoinquinata, quæ nescivit thorum in delicto, habebit fructum in respectione animarum sanctarum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 3:14",
      "text": "et spado qui non operatus est per manus suas iniquitatem, nec cogitavit adversus Deum nequissima: dabitur enim illi fidei donum electum, et sors in templo Dei acceptissima.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 3:15",
      "text": "Bonorum enim laborum gloriosus est fructus, et quæ non concidat radix sapientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 3:16",
      "text": "Filii autem adulterorum in inconsummatione erunt, et ab iniquo thoro semen exterminabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 3:17",
      "text": "Et si quidem longæ vitæ erunt, in nihilum computabuntur, et sine honore erit novissima senectus illorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 3:18",
      "text": "et si celerius defuncti fuerint, non habebunt spem, nec in die agnitionis allocutionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.3.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 3:19",
      "text": "Nationis enim iniquæ diræ sunt consummationes.",
      "paragraphStart": false
    }
  ]
}
