{
  "chapter": {
    "id": "vulgate:wisdom.7",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 7,
    "referenceLabel": "Wisdom of Solomon 7",
    "summary": "Source text for Wisdom of Solomon 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.7.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 7:1",
      "text": "Sum quidem et ego mortalis homo, similis omnibus, et ex genere terreni illius qui prior factus est: et in ventre matris figuratus sum caro;",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.7.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 7:2",
      "text": "decem mensium tempore coagulatus sum in sanguine: ex semine hominis, et delectamento somni conveniente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 7:3",
      "text": "Et ego natus accepi communem aërem, et in similiter factam decidi terram, et primam vocem similem omnibus emisi plorans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 7:4",
      "text": "In involumentis nutritus sum, et curis magnis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 7:5",
      "text": "nemo enim ex regibus aliud habuit nativitatis initium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 7:6",
      "text": "Unus ergo introitus est omnibus ad vitam, et similis exitus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 7:7",
      "text": "Propter hoc optavi, et datus est mihi sensus; et invocavi, et venit in me spiritus sapientiæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 7:8",
      "text": "et præposui illam regnis et sedibus, et divitias nihil esse duxi in comparatione illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 7:9",
      "text": "Nec comparavi illi lapidem pretiosum, quoniam omne aurum in comparatione illius arena est exigua, et tamquam lutum æstimabitur argentum in conspectu illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 7:10",
      "text": "Super salutem et speciem dilexi illam, et proposui pro luce habere illam, quoniam inextinguibile est lumen illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 7:11",
      "text": "Venerunt autem mihi omnia bona pariter cum illa, et innumerabilis honestas per manus illius;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 7:12",
      "text": "et lætatus sum in omnibus, quoniam antecedebat me ista sapientia, et ignorabam quoniam horum omnium mater est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 7:13",
      "text": "Quam sine fictione didici, et sine invidia communico, et honestatem illius non abscondo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 7:14",
      "text": "Infinitus enim thesaurus est hominibus; quo qui usi sunt, participes facti sunt amicitiæ Dei, propter disciplinæ dona commendati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 7:15",
      "text": "Mihi autem dedit Deus dicere ex sententia, et præsumere digna horum quæ mihi dantur: quoniam ipse sapientiæ dux est, et sapientium emendator.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 7:16",
      "text": "In manu enim illius et nos et sermones nostri, et omnis sapientia, et operum scientia, et disciplina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 7:17",
      "text": "Ipse enim dedit mihi horum quæ sunt scientiam veram, ut sciam dispositionem orbis terrarum, et virtutes elementorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 7:18",
      "text": "initium, et consummationem, et medietatem temporum, vicissitudinum permutationes, et commutationes temporum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 7:19",
      "text": "anni cursus, et stellarum dispositiones,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.20",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Wisdom of Solomon 7:20",
      "text": "naturas animalium, et iras bestiarum, vim ventorum, et cogitationes hominum, differentias virgultorum, et virtutes radicum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.21",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Wisdom of Solomon 7:21",
      "text": "Et quæcumque sunt absconsa et improvisa didici: omnium enim artifex docuit me sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.22",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Wisdom of Solomon 7:22",
      "text": "Est enim in illa spiritus intelligentiæ, sanctus, unicus, multiplex, subtilis, disertus, mobilis, incoinquinatus, certus, suavis, amans bonum, acutus, quem nihil vetat, benefaciens,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.23",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Wisdom of Solomon 7:23",
      "text": "humanus, benignus, stabilis, certus, securus, omnem habens virtutem, omnia prospiciens, et qui capiat omnes spiritus, intelligibilis, mundus, subtilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.24",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Wisdom of Solomon 7:24",
      "text": "Omnibus enim mobilibus mobilior est sapientia: attingit autem ubique propter suam munditiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.25",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Wisdom of Solomon 7:25",
      "text": "Vapor est enim virtutis Dei, et emanatio quædam est claritatis omnipotentis Dei sincera, et ideo nihil inquinatum in eam incurrit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.26",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Wisdom of Solomon 7:26",
      "text": "candor est enim lucis æternæ, et speculum sine macula Dei majestatis, et imago bonitatis illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.27",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Wisdom of Solomon 7:27",
      "text": "Et cum sit una, omnia potest; et in se permanens omnia innovat: et per nationes in animas sanctas se transfert; amicos Dei et prophetas constituit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.28",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Wisdom of Solomon 7:28",
      "text": "Neminem enim diligit Deus, nisi eum qui cum sapientia inhabitat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.29",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Wisdom of Solomon 7:29",
      "text": "Est enim hæc speciosior sole, et super omnem dispositionem stellarum: luci comparata, invenitur prior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.7.30",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Wisdom of Solomon 7:30",
      "text": "Illi enim succedit nox; sapientiam autem non vincit malitia.",
      "paragraphStart": false
    }
  ]
}
