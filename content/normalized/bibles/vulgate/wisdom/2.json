{
  "chapter": {
    "id": "vulgate:wisdom.2",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 2,
    "referenceLabel": "Wisdom of Solomon 2",
    "summary": "Source text for Wisdom of Solomon 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.2.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 2:1",
      "text": "Dixerunt enim cogitantes apud se non recte: Exiguum et cum tædio est tempus vitæ nostræ, et non est refrigerium in fine hominis, et non est qui agnitus sit reversus ab inferis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.2.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 2:2",
      "text": "Quia ex nihilo nati sumus, et post hoc erimus tamquam non fuerimus. Quoniam fumus flatus est in naribus nostris, et sermo scintilla ad commovendum cor nostrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 2:3",
      "text": "qua extincta, cinis erit corpus nostrum, et spiritus diffundetur tamquam mollis aër; et transibit vita nostra tamquam vestigium nubis, et sicut nebula dissolvetur quæ fugata est a radiis solis, et a calore illius aggravata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 2:4",
      "text": "Et nomen nostrum oblivionem accipiet per tempus, et nemo memoriam habebit operum nostrorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 2:5",
      "text": "Umbræ enim transitus est tempus nostrum, et non est reversio finis nostri: quoniam consignata est, et nemo revertitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 2:6",
      "text": "Venite ergo, et fruamur bonis quæ sunt, et utamur creatura tamquam in juventute celeriter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 2:7",
      "text": "Vino pretioso et unguentis nos impleamus, et non prætereat nos flos temporis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 2:8",
      "text": "Coronemus nos rosis antequam marcescant; nullum pratum sit quod non pertranseat luxuria nostra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 2:9",
      "text": "nemo nostrum exsors sit luxuriæ nostræ. Ubique relinquamus signa lætitiæ, quoniam hæc est pars nostra, et hæc est sors.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 2:10",
      "text": "Opprimamus pauperem justum, et non parcamus viduæ, nec veterani revereamur canos multi temporis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 2:11",
      "text": "sit autem fortitudo nostra lex justitiæ; quod enim infirmum est, inutile invenitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 2:12",
      "text": "Circumveniamus ergo justum, quoniam inutilis est nobis, et contrarius est operibus nostris, et improperat nobis peccata legis, et diffamat in nos peccata disciplinæ nostræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 2:13",
      "text": "Promittit se scientiam Dei habere, et filium Dei se nominat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 2:14",
      "text": "Factus est nobis in traductionem cogitationum nostrarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 2:15",
      "text": "Gravis est nobis etiam ad videndum, quoniam dissimilis est aliis vita illius, et immutatæ sunt viæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 2:16",
      "text": "Tamquam nugaces æstimati sumus ab illo, et abstinet se a viis nostris tamquam ab immunditiis, et præfert novissima justorum, et gloriatur patrem se habere Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 2:17",
      "text": "Videamus ergo si sermones illius veri sint, et tentemus quæ ventura sunt illi, et sciemus quæ erunt novissima illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 2:18",
      "text": "Si enim est verus filius Dei, suscipiet illum, et liberabit eum de manibus contrariorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 2:19",
      "text": "Contumelia et tormento interrogemus eum, ut sciamus reverentiam ejus, et probemus patientiam illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.20",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Wisdom of Solomon 2:20",
      "text": "Morte turpissima condemnemus eum; erit enim ei respectus ex sermonibus illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.21",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Wisdom of Solomon 2:21",
      "text": "Hæc cogitaverunt, et erraverunt: excæcavit enim illos malitia eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.22",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Wisdom of Solomon 2:22",
      "text": "Et nescierunt sacramenta Dei: neque mercedem speraverunt justitiæ, nec judicaverunt honorem animarum sanctarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.23",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Wisdom of Solomon 2:23",
      "text": "Quoniam Deus creavit hominem inexterminabilem, et ad imaginem similitudinis suæ fecit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.24",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Wisdom of Solomon 2:24",
      "text": "Invidia autem diaboli mors introivit in orbem terrarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.2.25",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Wisdom of Solomon 2:25",
      "text": "imitantur autem illum qui sunt ex parte illius.",
      "paragraphStart": false
    }
  ]
}
