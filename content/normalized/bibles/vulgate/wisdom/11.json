{
  "chapter": {
    "id": "vulgate:wisdom.11",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 11,
    "referenceLabel": "Wisdom of Solomon 11",
    "summary": "Source text for Wisdom of Solomon 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.11.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 11:1",
      "text": "Direxit opera eorum in manibus prophetæ sancti.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.11.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 11:2",
      "text": "Iter fecerunt per deserta quæ non habitabantur, et in locis desertis fixerunt casas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 11:3",
      "text": "Steterunt contra hostes, et de inimicis se vindicaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 11:4",
      "text": "Sitierunt, et invocaverunt te, et data est illis aqua de petra altissima, et requies sitis de lapide duro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 11:5",
      "text": "Per quæ enim pœnas passi sunt inimici illorum a defectione potus sui, et in eis cum abundarent filii Israël lætati sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 11:6",
      "text": "per hæc, cum illis deessent, bene cum illis actum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 11:7",
      "text": "Nam pro fonte quidem sempiterni fluminis, humanum sanguinem dedisti injustis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 11:8",
      "text": "Qui cum minuerentur in traductione infantium occisorum, dedisti illis abundantem aquam insperate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 11:9",
      "text": "ostendens per sitim quæ tunc fuit, quemadmodum tuos exaltares, et adversarios illorum necares.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 11:10",
      "text": "Cum enim tentati sunt, et quidem cum misericordia disciplinam accipientes, scierunt quemadmodum cum ira judicati impii tormenta paterentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 11:11",
      "text": "Hos quidem tamquam pater monens probasti; illos autem tamquam durus rex interrogans condemnasti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 11:12",
      "text": "Absentes enim, et præsentes, similiter torquebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 11:13",
      "text": "Duplex enim illos acceperat tædium et gemitus, cum memoria præteritorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 11:14",
      "text": "Cum enim audirent per sua tormenta bene secum agi, commemorati sunt Dominum, admirantes in finem exitus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 11:15",
      "text": "Quem enim in expositione prava projectum deriserunt, in finem eventus mirati sunt, non similiter justis sitientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 11:16",
      "text": "Pro cogitationibus autem insensatis iniquitatis illorum, quod quidam errantes colebant mutos serpentes et bestias supervacuas, immisisti illis multitudinem mutorum animalium in vindictam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 11:17",
      "text": "ut scirent quia per quæ peccat quis, per hæc et torquetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 11:18",
      "text": "Non enim impossibilis erat omnipotens manus tua, quæ creavit orbem terrarum ex materia invisa, immittere illis multitudinem ursorum, aut audaces leones,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 11:19",
      "text": "aut novi generis ira plenas ignotas bestias, aut vaporem ignium spirantes, aut fumi odorem proferentes, aut horrendas ab oculis scintillas emittentes;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.20",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Wisdom of Solomon 11:20",
      "text": "quarum non solum læsura poterat illos exterminare, sed et aspectus per timorem occidere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.21",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Wisdom of Solomon 11:21",
      "text": "Sed et sine his uno spiritu poterant occidi, persecutionem passi ab ipsis factis suis, et dispersi per spiritum virtutis tuæ: sed omnia in mensura, et numero et pondere disposuisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.22",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Wisdom of Solomon 11:22",
      "text": "Multum enim valere, tibi soli supererat semper: et virtuti brachii tui quis resistet?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.23",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Wisdom of Solomon 11:23",
      "text": "Quoniam tamquam momentum stateræ, sic est ante te orbis terrarum, et tamquam gutta roris antelucani quæ descendit in terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.24",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Wisdom of Solomon 11:24",
      "text": "Sed misereris omnium, quia omnia potes; et dissimulas peccata hominum, propter pœnitentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.25",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Wisdom of Solomon 11:25",
      "text": "Diligis enim omnia quæ sunt, et nihil odisti eorum quæ fecisti; nec enim odiens aliquid constituisti aut fecisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.26",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Wisdom of Solomon 11:26",
      "text": "Quomodo autem posset aliquid permanere, nisi tu voluisses? aut quod a te vocatum non esset conservaretur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.11.27",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Wisdom of Solomon 11:27",
      "text": "Parcis autem omnibus, quoniam tua sunt, Domine, qui amas animas.",
      "paragraphStart": false
    }
  ]
}
