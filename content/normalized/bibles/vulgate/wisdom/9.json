{
  "chapter": {
    "id": "vulgate:wisdom.9",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 9,
    "referenceLabel": "Wisdom of Solomon 9",
    "summary": "Source text for Wisdom of Solomon 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.9.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 9:1",
      "text": "Deus patrum meorum, et Domine misericordiæ, qui fecisti omnia verbo tuo,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.9.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 9:2",
      "text": "et sapientia tua constituisti hominem, ut dominaretur creaturæ quæ a te facta est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 9:3",
      "text": "ut disponat orbem terrarum in æquitate et justitia, et in directione cordis judicium judicet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 9:4",
      "text": "da mihi sedium tuarum assistricem sapientiam, et noli me reprobare a pueris tuis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 9:5",
      "text": "quoniam servus tuus sum ego, et filius ancillæ tuæ; homo infirmus, et exigui temporis, et minor ad intellectum judicii et legum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 9:6",
      "text": "Nam etsi quis erit consummatus inter filios hominum, si ab illo abfuerit sapientia tua, in nihilum computabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 9:7",
      "text": "Tu elegisti me regem populo tuo, et judicem filiorum tuorum et filiarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 9:8",
      "text": "et dixisti me ædificare templum in monte sancto tuo, et in civitate habitationis tuæ altare: similitudinem tabernaculi sancti tui quod præparasti ab initio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 9:9",
      "text": "Et tecum sapientia tua, quæ novit opera tua, quæ et affuit tunc cum orbem terrarum faceres, et sciebat quid esset placitum oculis tuis, et quid directum in præceptis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 9:10",
      "text": "Mitte illam de cælis sanctis tuis, et a sede magnitudinis tuæ, ut mecum sit et mecum laboret, ut sciam quid acceptum sit apud te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 9:11",
      "text": "scit enim illa omnia, et intelligit, et deducet me in operibus meis sobrie, et custodiet me in sua potentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 9:12",
      "text": "Et erunt accepta opera mea, et disponam populum tuum juste, et ero dignus sedium patris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 9:13",
      "text": "Quis enim hominum poterit scire consilium Dei? aut quis poterit cogitare quid velit Deus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 9:14",
      "text": "Cogitationes enim mortalium timidæ, et incertæ providentiæ nostræ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 9:15",
      "text": "corpus enim quod corrumpitur aggravat animam, et terrena inhabitatio deprimit sensum multa cogitantem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 9:16",
      "text": "Et difficile æstimamus quæ in terra sunt, et quæ in prospectu sunt invenimus cum labore: quæ autem in cælis sunt, quis investigabit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 9:17",
      "text": "Sensum autem tuum, quis sciet, nisi tu dederis sapientiam, et miseris spiritum sanctum tuum de altissimis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 9:18",
      "text": "et sic correctæ sint semitæ eorum qui sunt in terris, et quæ tibi placent didicerint homines?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.9.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 9:19",
      "text": "Nam per sapientiam sanati sunt quicumque placuerunt tibi, Domine, a principio.",
      "paragraphStart": false
    }
  ]
}
