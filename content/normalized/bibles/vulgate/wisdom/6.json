{
  "chapter": {
    "id": "vulgate:wisdom.6",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 6,
    "referenceLabel": "Wisdom of Solomon 6",
    "summary": "Source text for Wisdom of Solomon 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.6.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 6:1",
      "text": "Melior est sapientia quam vires, et vir prudens quam fortis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.6.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 6:2",
      "text": "Audite ergo, reges, et intelligite; discite, judices finium terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 6:3",
      "text": "Præbete aures, vos qui continetis multitudines, et placetis vobis in turbis nationum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 6:4",
      "text": "Quoniam data est a Domino potestas vobis, et virtus ab Altissimo: qui interrogabit opera vestra, et cogitationes scrutabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 6:5",
      "text": "Quoniam cum essetis ministri regni illius, non recte judicastis, nec custodistis legem justitiæ, neque secundum voluntatem Dei ambulastis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 6:6",
      "text": "Horrende et cito apparebit vobis, quoniam judicium durissimum his qui præsunt fiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 6:7",
      "text": "Exiguo enim conceditur misericordia; potentes autem potenter tormenta patientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 6:8",
      "text": "Non enim subtrahet personam cujusquam Deus, nec verebitur magnitudinem ejus cujusquam, quoniam pusillum et magnum ipse fecit, et æqualiter cura est illi de omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 6:9",
      "text": "Fortioribus autem fortior instat cruciatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 6:10",
      "text": "Ad vos ergo, reges, sunt hi sermones mei: ut discatis sapientiam, et non excidatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 6:11",
      "text": "Qui enim custodierint justa juste, justificabuntur; et qui didicerint ista, invenient quid respondeant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 6:12",
      "text": "Concupiscite ergo sermones meos; diligite illos, et habebitis disciplinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 6:13",
      "text": "Clara est, et quæ numquam marcescit, sapientia: et facile videtur ab his qui diligunt eam, et invenitur ab his qui quærunt illam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 6:14",
      "text": "Præoccupat qui se concupiscunt, ut illis se prior ostendat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 6:15",
      "text": "Qui de luce vigilaverit ad illam non laborabit; assidentem enim illam foribus suis inveniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 6:16",
      "text": "Cogitare ergo de illa sensus est consummatus, et qui vigilaverit propter illam cito securus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 6:17",
      "text": "Quoniam dignos se ipsa circuit quærens, et in viis ostendit se hilariter, et in omni providentia occurrit illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 6:18",
      "text": "Initium enim illius verissima est disciplinæ concupiscentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 6:19",
      "text": "Cura ergo disciplinæ dilectio est, et dilectio custodia legum illius est; custoditio autem legum consummatio incorruptionis est;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.20",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Wisdom of Solomon 6:20",
      "text": "incorruptio autem facit esse proximum Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.21",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Wisdom of Solomon 6:21",
      "text": "Concupiscentia itaque sapientiæ deducit ad regnum perpetuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.22",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Wisdom of Solomon 6:22",
      "text": "Si ergo delectamini sedibus et sceptris, o reges populi, diligite sapientiam, ut in perpetuum regnetis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.23",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Wisdom of Solomon 6:23",
      "text": "diligite lumen sapientiæ, omnes qui præestis populis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.24",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Wisdom of Solomon 6:24",
      "text": "Quid est autem sapientia, et quemadmodum facta sit, referam, et non abscondam a vobis sacramenta Dei: sed ab initio nativitatis investigabo, et ponam in lucem scientiam illius, et non præteribo veritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.25",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Wisdom of Solomon 6:25",
      "text": "Neque cum invidia tabescente iter habebo, quoniam talis homo non erit particeps sapientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.26",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Wisdom of Solomon 6:26",
      "text": "Multitudo autem sapientium sanitas est orbis terrarum, et rex sapiens stabilimentum populi est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.6.27",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Wisdom of Solomon 6:27",
      "text": "Ergo accipite disciplinam per sermones meos, et proderit vobis.",
      "paragraphStart": false
    }
  ]
}
