{
  "chapter": {
    "id": "vulgate:wisdom.4",
    "translationId": "vulgate",
    "bookSlug": "wisdom",
    "chapterNumber": 4,
    "referenceLabel": "Wisdom of Solomon 4",
    "summary": "Source text for Wisdom of Solomon 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:wisdom.4.1",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Wisdom of Solomon 4:1",
      "text": "O quam pulchra est casta generatio, cum claritate! immortalis est enim memoria illius, quoniam et apud Deum nota est, et apud homines.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:wisdom.4.2",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Wisdom of Solomon 4:2",
      "text": "Cum præsens est, imitantur illam, et desiderant eam cum se eduxerit; et in perpetuum coronata triumphat, incoinquinatorum certaminum præmium vincens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.3",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Wisdom of Solomon 4:3",
      "text": "Multigena autem impiorum multitudo non erit utilis, et spuria vitulamina non dabunt radices altas, nec stabile firmamentum collocabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.4",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Wisdom of Solomon 4:4",
      "text": "Etsi in ramis in tempore germinaverint, infirmiter posita, a vento commovebuntur, et a nimietate ventorum eradicabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.5",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Wisdom of Solomon 4:5",
      "text": "Confringentur enim rami inconsummati; et fructus illorum inutiles et acerbi ad manducandum, et ad nihilum apti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.6",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Wisdom of Solomon 4:6",
      "text": "Ex iniquis enim somnis filii qui nascuntur, testes sunt nequitiæ adversus parentes in interrogatione sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.7",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Wisdom of Solomon 4:7",
      "text": "Justus autem si morte præoccupatus fuerit, in refrigerio erit;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.8",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Wisdom of Solomon 4:8",
      "text": "senectus enim venerabilis est non diuturna, neque annorum numero computata: cani autem sunt sensus hominis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.9",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Wisdom of Solomon 4:9",
      "text": "et ætas senectutis vita immaculata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.10",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Wisdom of Solomon 4:10",
      "text": "Placens Deo factus est dilectus, et vivens inter peccatores translatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.11",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Wisdom of Solomon 4:11",
      "text": "Raptus est, ne malitia mutaret intellectum ejus, aut ne fictio deciperet animam illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.12",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Wisdom of Solomon 4:12",
      "text": "Fascinatio enim nugacitatis obscurat bona, et inconstantia concupiscentiæ transvertit sensum sine malitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.13",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Wisdom of Solomon 4:13",
      "text": "Consummatus in brevi, explevit tempora multa;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.14",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Wisdom of Solomon 4:14",
      "text": "placita enim erat Deo anima illius: propter hoc properavit educere illum de medio iniquitatum. Populi autem videntes, et non intelligentes, nec ponentes in præcordiis talia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.15",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Wisdom of Solomon 4:15",
      "text": "quoniam gratia Dei et misericordia est in sanctos ejus, et respectus in electos illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.16",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Wisdom of Solomon 4:16",
      "text": "Condemnat autem justus mortuus vivos impios, et juventus celerius consummata longam vitam injusti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.17",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Wisdom of Solomon 4:17",
      "text": "Videbunt enim finem sapientis, et non intelligent quid cogitaverit de illo Deus, et quare munierit illum Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.18",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Wisdom of Solomon 4:18",
      "text": "Videbunt, et contemnent eum; illos autem Dominus irridebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.19",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Wisdom of Solomon 4:19",
      "text": "Et erunt post hæc decidentes sine honore, et in contumelia inter mortuos in perpetuum: quoniam disrumpet illos inflatos sine voce, et commovebit illos a fundamentis, et usque ad supremum desolabuntur, et erunt gementes, et memoria illorum peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:wisdom.4.20",
      "translationId": "vulgate",
      "bookSlug": "wisdom",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Wisdom of Solomon 4:20",
      "text": "Venient in cogitatione peccatorum suorum timidi, et traducent illos ex adverso iniquitates ipsorum.",
      "paragraphStart": false
    }
  ]
}
