{
  "chapter": {
    "id": "vulgate:first-thessalonians.4",
    "translationId": "vulgate",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 4,
    "referenceLabel": "1 Thessalonians 4",
    "summary": "Source text for 1 Thessalonians 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-thessalonians.4.1",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 4:1",
      "text": "De cetero ergo, fratres, rogamus vos et obsecramus in Domino Jesu, ut quemadmodum accepistis a nobis quomodo oporteat vos ambulare, et placere Deo, sic et ambuletis ut abundetis magis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-thessalonians.4.2",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 4:2",
      "text": "Scitis enim quæ præcepta dederim vobis per Dominum Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.3",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 4:3",
      "text": "Hæc est enim voluntas Dei, sanctificatio vestra: ut abstineatis vos a fornicatione,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.4",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 4:4",
      "text": "ut sciat unusquisque vestrum vas suum possidere in sanctificatione, et honore:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.5",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 4:5",
      "text": "non in passione desiderii, sicut et gentes, quæ ignorant Deum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.6",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 4:6",
      "text": "et ne quis supergrediatur, neque circumveniat in negotio fratrem suum: quoniam vindex est Dominus de his omnibus, sicut prædiximus vobis, et testificati sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.7",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 4:7",
      "text": "Non enim vocavit nos Deus in immunditiam, sed in sanctificationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.8",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 4:8",
      "text": "Itaque qui hæc spernit, non hominem spernit, sed Deum: qui etiam dedit Spiritum suum Sanctum in nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.9",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 4:9",
      "text": "De caritate autem fraternitatis non necesse habemus scribere vobis: ipsi enim vos a Deo didicistis ut diligatis invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.10",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 4:10",
      "text": "Etenim illud facitis in omnes fratres in universa Macedonia. Rogamus autem vos, fratres, ut abundetis magis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.11",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 4:11",
      "text": "et operam detis ut quieti sitis, et ut vestrum negotium agatis, et operemini manibus vestris, sicut præcepimus vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.12",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 4:12",
      "text": "et ut honeste ambuletis ad eos qui foris sunt: et nullius aliquid desideretis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.13",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 4:13",
      "text": "Nolumus autem vos ignorare fratres de dormientibus, ut non contristemini sicut et ceteri, qui spem non habent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.14",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 4:14",
      "text": "Si enim credimus quod Jesus mortuus est, et resurrexit: ita et Deus eos qui dormierunt per Jesum, adducet cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.15",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 4:15",
      "text": "Hoc enim vobis dicimus in verbo Domini, quia nos, qui vivimus, qui residui sumus in adventum Domini, non præveniemus eos qui dormierunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.16",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 4:16",
      "text": "Quoniam ipse Dominus in jussu, et in voce archangeli, et in tuba Dei descendet de cælo: et mortui, qui in Christo sunt, resurgent primi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.17",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 4:17",
      "text": "Deinde nos, qui vivimus, qui relinquimur, simul rapiemur cum illis in nubibus obviam Christo in aëra, et sic semper cum Domino erimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.4.18",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 4:18",
      "text": "Itaque consolamini invicem in verbis istis.",
      "paragraphStart": false
    }
  ]
}
