{
  "chapter": {
    "id": "vulgate:first-thessalonians.5",
    "translationId": "vulgate",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-thessalonians.5.1",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "De temporibus autem, et momentis, fratres, non indigetis ut scribamus vobis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-thessalonians.5.2",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "Ipsi enim diligenter scitis quia dies Domini, sicut fur in nocte, ita veniet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.3",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "cum enim dixerint: Pax et securitas: tunc repentinus eis superveniet interitus, sicut dolor in utero habenti, et non effugient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.4",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "Vos autem, fratres, non estis in tenebris, ut vos dies illa tamquam fur comprehendat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.5",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "omnes enim vos filii lucis estis, et filii diei: non sumus noctis, neque tenebrarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.6",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "Igitur non dormiamus sicut et ceteri, sed vigilemus, et sobrii simus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.7",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "Qui enim dormiunt, nocte dormiunt: et qui ebrii sunt, nocte ebrii sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.8",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "Nos autem, qui diei sumus, sobrii simus, induti loricam fidei et caritatis, et galeam spem salutis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.9",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "quoniam non posuit nos Deus in iram, sed in acquisitionem salutis per Dominum nostrum Jesum Christum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.10",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "qui mortuus est pro nobis: ut sive vigilemus, sive dormiamus, simul cum illo vivamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.11",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "Propter quod consolamini invicem, et ædificate alterutrum, sicut et facitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.12",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "Rogamus autem vos, fratres, ut noveritis eos qui laborant inter vos, et præsunt vobis in Domino, et monent vos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.13",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "ut habeatis illos abundantius in caritate propter opus illorum: pacem habete cum eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.14",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "Rogamus autem vos, fratres, corripite inquietos, consolamini pusillanimes, suscipite infirmos, patientes estote ad omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.15",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "Videte ne quis malum pro malo alicui reddat: sed semper quod bonum est sectamini in invicem, et in omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.16",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "Semper gaudete.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.17",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "Sine intermissione orate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.18",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "In omnibus gratias agite: hæc est enim voluntas Dei in Christo Jesu in omnibus vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.19",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "Spiritum nolite extinguere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.20",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "Prophetias nolite spernere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.21",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "Omnia autem probate: quod bonum est tenete.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.22",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "Ab omni specie mala abstinete vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.23",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "Ipse autem Deus pacis sanctificet vos per omnia: ut integer spiritus vester, et anima, et corpus sine querela in adventu Domini nostri Jesu Christi servetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.24",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "Fidelis est, qui vocavit vos: qui etiam faciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.25",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "Fratres, orate pro nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.26",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "Salutate fratres omnes in osculo sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.27",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "Adjuro vos per Dominum ut legatur epistola hæc omnibus sanctis fratribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.5.28",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "Gratia Domini nostri Jesu Christi vobiscum. Amen.",
      "paragraphStart": false
    }
  ]
}
