{
  "chapter": {
    "id": "vulgate:first-thessalonians.3",
    "translationId": "vulgate",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 3,
    "referenceLabel": "1 Thessalonians 3",
    "summary": "Source text for 1 Thessalonians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-thessalonians.3.1",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 3:1",
      "text": "Propter quod non sustinentes amplius, placuit nobis remanere Athenis, solis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-thessalonians.3.2",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 3:2",
      "text": "et misimus Timotheum fratrem nostrum, et ministrum Dei in Evangelio Christi, ad confirmandos vos, et exhortandos pro fide vestra:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.3",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 3:3",
      "text": "ut nemo moveatur in tribulationibus istis: ipsi enim scitis quod in hoc positi sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.4",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 3:4",
      "text": "Nam et cum apud vos essemus, prædicebamus vobis passuros nos tribulationes, sicut et factum est, et scitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.5",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 3:5",
      "text": "Propterea et ego amplius non sustinens, misi ad cognoscendam fidem vestram: ne forte tentaverit vos is qui tentat, et inanis fiat labor noster.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.6",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 3:6",
      "text": "Nunc autem veniente Timotheo ad nos a vobis, et annuntiante nobis fidem et caritatem vestram, et quia memoriam nostri habetis bonam semper, desiderantes nos videre, sicut et nos quoque vos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.7",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 3:7",
      "text": "ideo consolati sumus, fratres, in vobis in omni necessitate et tribulatione nostra, per fidem vestram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.8",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 3:8",
      "text": "quoniam nunc vivimus, si vos statis in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.9",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 3:9",
      "text": "Quam enim gratiarum actionem possumus Deo retribuere pro vobis in omni gaudio, quo gaudemus propter vos ante Deum nostrum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.10",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 3:10",
      "text": "nocte ac die abundantius orantes, ut videamus faciem vestram, et compleamus ea quæ desunt fidei vestræ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.11",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 3:11",
      "text": "Ipse autem Deus, et Pater noster, et Dominus noster Jesus Christus, dirigat viam nostram ad vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.12",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 3:12",
      "text": "Vos autem Dominus multiplicet, et abundare faciat caritatem vestram in invicem, et in omnes, quemadmodum et nos in vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-thessalonians.3.13",
      "translationId": "vulgate",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 3:13",
      "text": "ad confirmanda corda vestra sine querela in sanctitate, ante Deum et Patrem nostrum, in adventu Domini nostri Jesu Christi cum omnibus sanctis ejus. Amen.",
      "paragraphStart": false
    }
  ]
}
