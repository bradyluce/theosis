{
  "chapter": {
    "id": "vulgate:ephesians.4",
    "translationId": "vulgate",
    "bookSlug": "ephesians",
    "chapterNumber": 4,
    "referenceLabel": "Ephesians 4",
    "summary": "Source text for Ephesians 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ephesians.4.1",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 4:1",
      "text": "Obsecro itaque vos ego vinctus in Domino, ut digne ambuletis vocatione, qua vocati estis,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ephesians.4.2",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 4:2",
      "text": "cum omni humilitate, et mansuetudine, cum patientia, supportantes invicem in caritate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.3",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 4:3",
      "text": "solliciti servare unitatem Spiritus in vinculo pacis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.4",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 4:4",
      "text": "Unum corpus, et unus Spiritus, sicut vocati estis in una spe vocationis vestræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.5",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 4:5",
      "text": "Unus Dominus, una fides, unum baptisma.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.6",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 4:6",
      "text": "Unus Deus et Pater omnium, qui est super omnes, et per omnia, et in omnibus nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.7",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 4:7",
      "text": "Unicuique autem nostrum data est gratia secundum mensuram donationis Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.8",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 4:8",
      "text": "Propter quod dicit: Ascendens in altum, captivam duxit captivitatem: dedit dona hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.9",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 4:9",
      "text": "Quod autem ascendit, quid est, nisi quia et descendit primum in inferiores partes terræ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.10",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 4:10",
      "text": "Qui descendit, ipse est et qui ascendit super omnes cælos, ut impleret omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.11",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 4:11",
      "text": "Et ipse dedit quosdam quidem apostolos, quosdam autem prophetas, alios vero evangelistas, alios autem pastores et doctores,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.12",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 4:12",
      "text": "ad consummationem sanctorum in opus ministerii, in ædificationem corporis Christi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.13",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 4:13",
      "text": "donec occurramus omnes in unitatem fidei, et agnitionis Filii Dei, in virum perfectum, in mensuram ætatis plenitudinis Christi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.14",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 4:14",
      "text": "ut jam non simus parvuli fluctuantes, et circumferamur omni vento doctrinæ in nequitia hominum, in astutia ad circumventionem erroris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.15",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 4:15",
      "text": "Veritatem autem facientes in caritate, crescamus in illo per omnia, qui est caput Christus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.16",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 4:16",
      "text": "ex quo totum corpus compactum et connexum per omnem juncturam subministrationis, secundum operationem in mensuram uniuscujusque membri, augmentum corporis facit in ædificationem sui in caritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.17",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 4:17",
      "text": "Hoc igitur dico, et testificor in Domino, ut jam non ambuletis, sicut et gentes ambulant in vanitate sensus sui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.18",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 4:18",
      "text": "tenebris obscuratum habentes intellectum, alienati a vita Dei per ignorantiam, quæ est in illis, propter cæcitatem cordis ipsorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.19",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 4:19",
      "text": "qui desperantes, semetipsos tradiderunt impudicitiæ, in operationem immunditiæ omnis in avaritiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.20",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 4:20",
      "text": "Vos autem non ita didicistis Christum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.21",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 4:21",
      "text": "si tamen illum audistis, et in ipso edocti estis, sicut est veritas in Jesu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.22",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 4:22",
      "text": "deponere vos secundum pristinam conversationem veterem hominem, qui corrumpitur secundum desideria erroris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.23",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 4:23",
      "text": "Renovamini autem spiritu mentis vestræ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.24",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 4:24",
      "text": "et induite novum hominem, qui secundum Deum creatus est in justitia, et sanctitate veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.25",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 4:25",
      "text": "Propter quod deponentes mendacium, loquimini veritatem unusquisque cum proximo suo: quoniam sumus invicem membra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.26",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 4:26",
      "text": "Irascimini, et nolite peccare: sol non occidat super iracundiam vestram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.27",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 4:27",
      "text": "Nolite locum dare diabolo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.28",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 4:28",
      "text": "qui furabatur, jam non furetur: magis autem laboret, operando manibus suis, quod bonum est, ut habeat unde tribuat necessitatem patienti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.29",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 4:29",
      "text": "Omnis sermo malus ex ore vestro non procedat: sed si quis bonus ad ædificationem fidei ut det gratiam audientibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.30",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 4:30",
      "text": "Et nolite contristare Spiritum Sanctum Dei: in quo signati estis in diem redemptionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.31",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 4:31",
      "text": "Omnis amaritudo, et ira, et indignatio, et clamor, et blasphemia tollatur a vobis cum omni malitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.4.32",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 4:32",
      "text": "Estote autem invicem benigni, misericordes, donantes invicem sicut et Deus in Christo donavit vobis.",
      "paragraphStart": false
    }
  ]
}
