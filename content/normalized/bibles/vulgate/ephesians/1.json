{
  "chapter": {
    "id": "vulgate:ephesians.1",
    "translationId": "vulgate",
    "bookSlug": "ephesians",
    "chapterNumber": 1,
    "referenceLabel": "Ephesians 1",
    "summary": "Source text for Ephesians 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ephesians.1.1",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 1:1",
      "text": "Paulus Apostolus Jesu Christi per voluntatem Dei, omnibus sanctis qui sunt Ephesi, et fidelibus in Christo Jesu.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ephesians.1.2",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 1:2",
      "text": "Gratia vobis, et pax a Deo Patre nostro, et Domino Jesu Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.3",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 1:3",
      "text": "Benedictus Deus et Pater Domini nostri Jesu Christi, qui benedixit nos in omni benedictione spirituali in cælestibus in Christo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.4",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 1:4",
      "text": "sicut elegit nos in ipso ante mundi constitutionem, ut essemus sancti et immaculati in conspectu ejus in caritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.5",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 1:5",
      "text": "Qui prædestinavit nos in adoptionem filiorum per Jesum Christum in ipsum: secundum propositum voluntatis suæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.6",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 1:6",
      "text": "in laudem gloriæ gratiæ suæ, in qua gratificavit nos in dilecto Filio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.7",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 1:7",
      "text": "In quo habemus redemptionem per sanguinem ejus, remissionem peccatorum secundum divitias gratiæ ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.8",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 1:8",
      "text": "quæ superabundavit in nobis in omni sapientia et prudentia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.9",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 1:9",
      "text": "ut notum faceret nobis sacramentum voluntatis suæ, secundum beneplacitum ejus, quod proposuit in eo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.10",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 1:10",
      "text": "in dispensatione plenitudinis temporum, instaurare omnia in Christo, quæ in cælis et quæ in terra sunt, in ipso;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.11",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 1:11",
      "text": "in quo etiam et nos sorte vocati sumus prædestinati secundum propositum ejus qui operatur omnia secundum consilium voluntatis suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.12",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 1:12",
      "text": "ut simus in laudem gloriæ ejus nos, qui ante speravimus in Christo;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.13",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 1:13",
      "text": "in quo et vos, cum audissetis verbum veritatis, Evangelium salutis vestræ, in quo et credentes signati estis Spiritu promissionis Sancto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.14",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 1:14",
      "text": "qui est pignus hæreditatis nostræ, in redemptionem acquisitionis, in laudem gloriæ ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.15",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 1:15",
      "text": "Propterea et ego audiens fidem vestram, quæ est in Domino Jesu, et dilectionem in omnes sanctos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.16",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 1:16",
      "text": "non cesso gratias agens pro vobis, memoriam vestri faciens in orationibus meis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.17",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 1:17",
      "text": "ut Deus, Domini nostri Jesu Christi Pater gloriæ, det vobis spiritum sapientiæ et revelationis in agnitione ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.18",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 1:18",
      "text": "illuminatos oculos cordis vestri, ut sciatis quæ sit spes vocationis ejus, et quæ divitiæ gloriæ hæreditatis ejus in sanctis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.19",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 1:19",
      "text": "et quæ sit supereminens magnitudo virtutis ejus in nos, qui credimus secundum operationem potentiæ virtutis ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.20",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 1:20",
      "text": "quam operatus est in Christo, suscitans illum a mortuis, et constituens ad dexteram suam in cælestibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.21",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 1:21",
      "text": "supra omnem principatum, et potestatem, et virtutem, et dominationem, et omne nomen, quod nominatur non solum in hoc sæculo, sed etiam in futuro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.22",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 1:22",
      "text": "Et omnia subjecit sub pedibus ejus: et ipsum dedit caput supra omnem ecclesiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.1.23",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 1:23",
      "text": "quæ est corpus ipsius, et plenitudo ejus, qui omnia in omnibus adimpletur.",
      "paragraphStart": false
    }
  ]
}
