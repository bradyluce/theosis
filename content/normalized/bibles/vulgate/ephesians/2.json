{
  "chapter": {
    "id": "vulgate:ephesians.2",
    "translationId": "vulgate",
    "bookSlug": "ephesians",
    "chapterNumber": 2,
    "referenceLabel": "Ephesians 2",
    "summary": "Source text for Ephesians 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ephesians.2.1",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 2:1",
      "text": "Et vos, cum essetis mortui delictis et peccatis vestris,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ephesians.2.2",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 2:2",
      "text": "in quibus aliquando ambulastis secundum sæculum mundi hujus, secundum principem potestatis aëris hujus, spiritus, qui nunc operatur in filios diffidentiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.3",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 2:3",
      "text": "in quibus et nos omnes aliquando conversati sumus in desideriis carnis nostræ, facientes voluntatem carnis et cogitationum, et eramus natura filii iræ, sicut et ceteri:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.4",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 2:4",
      "text": "Deus autem, qui dives est in misericordia, propter nimiam caritatem suam, qua dilexit nos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.5",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 2:5",
      "text": "et cum essemus mortui peccatis, convivificavit nos in Christo (cujus gratia estis salvati),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.6",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 2:6",
      "text": "et conresuscitavit, et consedere fecit in cælestibus in Christo Jesu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.7",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 2:7",
      "text": "ut ostenderet in sæculis supervenientibus abundantes divitias gratiæ suæ, in bonitate super nos in Christo Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.8",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 2:8",
      "text": "Gratia enim estis salvati per fidem, et hoc non ex vobis: Dei enim donum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.9",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 2:9",
      "text": "non ex operibus, ut ne quis glorietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.10",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 2:10",
      "text": "Ipsius enim sumus factura, creati in Christo Jesu in operibus bonis, quæ præparavit Deus ut in illis ambulemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.11",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 2:11",
      "text": "Propter quod memores estote quod aliquando vos gentes in carne, qui dicimini præputium ab ea quæ dicitur circumcisio in carne, manu facta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.12",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 2:12",
      "text": "quia eratis illo in tempore sine Christo, alienati a conversatione Israël, et hospites testamentorum, promissionis spem non habentes, et sine Deo in hoc mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.13",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 2:13",
      "text": "Nunc autem in Christo Jesu, vos, qui aliquando eratis longe, facti estis prope in sanguine Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.14",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 2:14",
      "text": "Ipse enim est pax nostra, qui fecit utraque unum, et medium parietem maceriæ solvens, inimicitias in carne sua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.15",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 2:15",
      "text": "legem mandatorum decretis evacuans, ut duos condat in semetipso in unum novum hominem, faciens pacem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.16",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 2:16",
      "text": "et reconciliet ambos in uno corpore, Deo per crucem, interficiens inimicitias in semetipso.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.17",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 2:17",
      "text": "Et veniens evangelizavit pacem vobis, qui longe fuistis, et pacem iis, qui prope.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.18",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 2:18",
      "text": "Quoniam per ipsum habemus accessum ambo in uno Spiritu ad Patrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.19",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 2:19",
      "text": "Ergo jam non estis hospites, et advenæ: sed estis cives sanctorum, et domestici Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.20",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 2:20",
      "text": "superædificati super fundamentum apostolorum, et prophetarum, ipso summo angulari lapide Christo Jesu:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.21",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 2:21",
      "text": "in quo omnis ædificatio constructa crescit in templum sanctum in Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.2.22",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 2:22",
      "text": "in quo et vos coædificamini in habitaculum Dei in Spiritu.",
      "paragraphStart": false
    }
  ]
}
