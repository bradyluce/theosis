{
  "chapter": {
    "id": "vulgate:ephesians.3",
    "translationId": "vulgate",
    "bookSlug": "ephesians",
    "chapterNumber": 3,
    "referenceLabel": "Ephesians 3",
    "summary": "Source text for Ephesians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ephesians.3.1",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 3:1",
      "text": "Hujus rei gratia, ego Paulus vinctus Christi Jesu, pro vobis gentibus,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ephesians.3.2",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 3:2",
      "text": "si tamen audistis dispensationem gratiæ Dei, quæ data est mihi in vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.3",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 3:3",
      "text": "quoniam secundum revelationem notum mihi factum est sacramentum, sicut supra scripsi in brevi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.4",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 3:4",
      "text": "prout potestis legentes intelligere prudentiam meam in mysterio Christi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.5",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 3:5",
      "text": "quod aliis generationibus non est agnitum filiis hominum, sicuti nunc revelatum est sanctis apostolis ejus et prophetis in Spiritu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.6",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 3:6",
      "text": "gentes esse cohæredes, et concorporales, et comparticipes promissionis ejus in Christo Jesu per Evangelium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.7",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 3:7",
      "text": "cujus factus sum minister secundum donum gratiæ Dei, quæ data est mihi secundum operationem virtutis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.8",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 3:8",
      "text": "Mihi omnium sanctorum minimo data est gratia hæc, in gentibus evangelizare investigabiles divitias Christi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.9",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 3:9",
      "text": "et illuminare omnes, quæ sit dispensatio sacramenti absconditi a sæculis in Deo, qui omnia creavit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.10",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 3:10",
      "text": "ut innotescat principatibus et potestatibus in cælestibus per Ecclesiam, multiformis sapientia Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.11",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 3:11",
      "text": "secundum præfinitionem sæculorum, quam fecit in Christo Jesu Domino nostro:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.12",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 3:12",
      "text": "in quo habemus fiduciam, et accessum in confidentia per fidem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.13",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 3:13",
      "text": "Propter quod peto ne deficiatis in tribulationibus meis pro vobis: quæ est gloria vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.14",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 3:14",
      "text": "Hujus rei gratia flecto genua mea ad Patrem Domini nostri Jesu Christi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.15",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 3:15",
      "text": "ex quo omnis paternitas in cælis et in terra nominatur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.16",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 3:16",
      "text": "ut det vobis secundum divitias gloriæ suæ, virtute corroborari per Spiritum ejus in interiorem hominem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.17",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 3:17",
      "text": "Christum habitare per fidem in cordibus vestris: in caritate radicati, et fundati,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.18",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 3:18",
      "text": "ut possitis comprehendere cum omnibus sanctis, quæ sit latitudo, et longitudo, et sublimitas, et profundum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.19",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 3:19",
      "text": "scire etiam supereminentem scientiæ caritatem Christi, ut impleamini in omnem plenitudinem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.20",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 3:20",
      "text": "Ei autem, qui potens est omnia facere superabundanter quam petimus aut intelligimus, secundum virtutem, quæ operatur in nobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.3.21",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 3:21",
      "text": "ipsi gloria in Ecclesia, et in Christo Jesu, in omnes generationes sæculi sæculorum. Amen.",
      "paragraphStart": false
    }
  ]
}
