{
  "chapter": {
    "id": "vulgate:ephesians.5",
    "translationId": "vulgate",
    "bookSlug": "ephesians",
    "chapterNumber": 5,
    "referenceLabel": "Ephesians 5",
    "summary": "Source text for Ephesians 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ephesians.5.1",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 5:1",
      "text": "Estote ergo imitatores Dei, sicut filii carissimi,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ephesians.5.2",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 5:2",
      "text": "et ambulate in dilectione, sicut et Christus dilexit nos, et tradidit semetipsum pro nobis, oblationem et hostiam Deo in odorem suavitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.3",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 5:3",
      "text": "Fornicatio autem, et omnis immunditia, aut avaritia, nec nominetur in vobis, sicut decet sanctos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.4",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 5:4",
      "text": "aut turpitudo, aut stultiloquium, aut scurrilitas, quæ ad rem non pertinet: sed magis gratiarum actio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.5",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 5:5",
      "text": "Hoc enim scitote intelligentes: quod omnis fornicator, aut immundus, aut avarus, quod est idolorum servitus, non habet hæreditatem in regno Christi et Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.6",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 5:6",
      "text": "Nemo vos seducat inanibus verbis: propter hæc enim venit ira Dei in filios diffidentiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.7",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 5:7",
      "text": "Nolite ergo effici participes eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.8",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 5:8",
      "text": "Eratis enim aliquando tenebræ: nunc autem lux in Domino. Ut filii lucis ambulate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.9",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 5:9",
      "text": "fructus enim lucis est in omni bonitate, et justitia, et veritate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.10",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 5:10",
      "text": "probantes quid sit beneplacitum Deo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.11",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 5:11",
      "text": "et nolite communicare operibus infructuosis tenebrarum, magis autem redarguite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.12",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 5:12",
      "text": "Quæ enim in occulto fiunt ab ipsis, turpe est et dicere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.13",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 5:13",
      "text": "Omnia autem, quæ arguuntur, a lumine manifestantur: omne enim, quod manifestatur, lumen est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.14",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 5:14",
      "text": "Propter quod dicit: Surge qui dormis, et exsurge a mortuis, et illuminabit te Christus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.15",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 5:15",
      "text": "Videte itaque, fratres, quomodo caute ambuletis: non quasi insipientes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.16",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 5:16",
      "text": "sed ut sapientes: redimentes tempus, quoniam dies mali sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.17",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 5:17",
      "text": "Propterea nolite fieri imprudentes, sed intelligentes quæ sit voluntas Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.18",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 5:18",
      "text": "Et nolite inebriari vino, in quo est luxuria, sed implemini Spiritu Sancto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.19",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 5:19",
      "text": "loquentes vobismetipsis in psalmis, et hymnis, et canticis spiritualibus, cantantes et psallentes in cordibus vestris Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.20",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 5:20",
      "text": "gratias agentes semper pro omnibus in nomine Domini nostri Jesu Christi Deo et Patri,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.21",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 5:21",
      "text": "subjecti invicem in timore Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.22",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 5:22",
      "text": "Mulieres viris suis subditæ sint, sicut Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.23",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 5:23",
      "text": "quoniam vir caput est mulieris, sicut Christus caput est Ecclesiæ: ipse, salvator corporis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.24",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 5:24",
      "text": "Sed sicut Ecclesia subjecta est Christo, ita et mulieres viris suis in omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.25",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 5:25",
      "text": "Viri, diligite uxores vestras, sicut et Christus dilexit Ecclesiam, et seipsum tradidit pro ea,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.26",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 5:26",
      "text": "ut illam sanctificaret, mundans lavacro aquæ in verbo vitæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.27",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 5:27",
      "text": "ut exhiberet ipse sibi gloriosam Ecclesiam, non habentem maculam, aut rugam, aut aliquid hujusmodi, sed ut sit sancta et immaculata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.28",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 5:28",
      "text": "Ita et viri debent diligere uxores suas ut corpora sua. Qui suam uxorem diligit, seipsum diligit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.29",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 5:29",
      "text": "Nemo enim umquam carnem suam odio habuit: sed nutrit et fovet eam, sicut et Christus Ecclesiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.30",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 5:30",
      "text": "quia membra sumus corporis ejus, de carne ejus et de ossibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.31",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 5:31",
      "text": "Propter hoc relinquet homo patrem et matrem suam, et adhærebit uxori suæ, et erunt duo in carne una.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.32",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 5:32",
      "text": "Sacramentum hoc magnum est, ego autem dico in Christo et in Ecclesia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.5.33",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Ephesians 5:33",
      "text": "Verumtamen et vos singuli, unusquisque uxorem suam sicut seipsum diligat: uxor autem timeat virum suum.",
      "paragraphStart": false
    }
  ]
}
