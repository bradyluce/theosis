{
  "chapter": {
    "id": "vulgate:ephesians.6",
    "translationId": "vulgate",
    "bookSlug": "ephesians",
    "chapterNumber": 6,
    "referenceLabel": "Ephesians 6",
    "summary": "Source text for Ephesians 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ephesians.6.1",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 6:1",
      "text": "Filii, obedite parentibus vestris in Domino: hoc enim justum est.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ephesians.6.2",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 6:2",
      "text": "Honora patrem tuum, et matrem tuam, quod est mandatum primum in promissione:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.3",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 6:3",
      "text": "ut bene sit tibi, et sis longævus super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.4",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 6:4",
      "text": "Et vos patres, nolite ad iracundiam provocare filios vestros: sed educate illos in disciplina et correptione Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.5",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 6:5",
      "text": "Servi, obedite dominis carnalibus cum timore et tremore, in simplicitate cordis vestri, sicut Christo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.6",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 6:6",
      "text": "non ad oculum servientes, quasi hominibus placentes, sed ut servi Christi, facientes voluntatem Dei ex animo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.7",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 6:7",
      "text": "cum bona voluntate servientes, sicut Domino, et non hominibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.8",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 6:8",
      "text": "scientes quoniam unusquisque quodcumque fecerit bonum, hoc recipiet a Domino, sive servus, sive liber.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.9",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 6:9",
      "text": "Et vos domini, eadem facite illis, remittentes minas: scientes quia et illorum et vester Dominus est in cælis: et personarum acceptio non est apud eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.10",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 6:10",
      "text": "De cetero, fratres, confortamini in Domino, et in potentia virtutis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.11",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 6:11",
      "text": "Induite vos armaturam Dei, ut possitis stare adversus insidias diaboli:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.12",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 6:12",
      "text": "quoniam non est nobis colluctatio adversus carnem et sanguinem, sed adversus principes, et potestates, adversus mundi rectores tenebrarum harum, contra spiritualia nequitiæ, in cælestibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.13",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 6:13",
      "text": "Propterea accipite armaturam Dei, ut possitis resistere in die malo, et in omnibus perfecti stare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.14",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 6:14",
      "text": "State ergo succincti lumbos vestros in veritate, et induti loricam justitiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.15",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 6:15",
      "text": "et calceati pedes in præparatione Evangelii pacis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.16",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 6:16",
      "text": "in omnibus sumentes scutum fidei, in quo possitis omnia tela nequissimi ignea extinguere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.17",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 6:17",
      "text": "et galeam salutis assumite, et gladium spiritus (quod est verbum Dei),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.18",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 6:18",
      "text": "per omnem orationem et obsecrationem orantes omni tempore in spiritu: et in ipso vigilantes in omni instantia et obsecratione pro omnibus sanctis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.19",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 6:19",
      "text": "et pro me, ut detur mihi sermo in apertione oris mei cum fiducia, notum facere mysterium Evangelii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.20",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 6:20",
      "text": "pro quo legatione fungor in catena, ita ut in ipso audeam, prout oportet me loqui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.21",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 6:21",
      "text": "Ut autem et vos sciatis quæ circa me sunt, quid agam, omnia vobis nota faciet Tychicus, carissimus frater, et fidelis minister in Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.22",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 6:22",
      "text": "quem misi ad vos in hoc ipsum, ut cognoscatis quæ circa nos sunt, et consoletur corda vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.23",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 6:23",
      "text": "Pax fratribus, et caritas cum fide a Deo Patre et Domino Jesu Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ephesians.6.24",
      "translationId": "vulgate",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 6:24",
      "text": "Gratia cum omnibus qui diligunt Dominum nostrum Jesum Christum in incorruptione. Amen.",
      "paragraphStart": false
    }
  ]
}
