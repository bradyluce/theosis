{
  "chapter": {
    "id": "vulgate:second-timothy.2",
    "translationId": "vulgate",
    "bookSlug": "second-timothy",
    "chapterNumber": 2,
    "referenceLabel": "2 Timothy 2",
    "summary": "Source text for 2 Timothy 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-timothy.2.1",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 2:1",
      "text": "Tu ergo fili mi, confortare in gratia, quæ est in Christo Jesu:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-timothy.2.2",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 2:2",
      "text": "et quæ audisti a me per multos testes, hæc commenda fidelibus hominibus, qui idonei erant et alios docere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.3",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 2:3",
      "text": "Labora sicut bonus miles Christi Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.4",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 2:4",
      "text": "Nemo militans Deo implicat se negotiis sæcularibus: ut ei placeat, cui se probavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.5",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 2:5",
      "text": "Nam et qui certat in agone, non coronatur nisi legitime certaverit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.6",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 2:6",
      "text": "Laborantem agricolam oportet primum de fructibus percipere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.7",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 2:7",
      "text": "Intellige quæ dico: dabit enim tibi Dominus in omnibus intellectum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.8",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 2:8",
      "text": "Memor esto Dominum Jesum Christum resurrexisse a mortuis ex semine David, secundum Evangelium meum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.9",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 2:9",
      "text": "in quo laboro usque ad vincula, quasi male operans: sed verbum Dei non est alligatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.10",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 2:10",
      "text": "Ideo omnia sustineo propter electos, ut et ipsi salutem consequantur, quæ est in Christo Jesu, cum gloria cælesti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.11",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 2:11",
      "text": "Fidelis sermo: nam si commortui sumus, et convivemus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.12",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 2:12",
      "text": "si sustinebimus, et conregnabimus: si negaverimus, et ille negabit nos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.13",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 2:13",
      "text": "si non credimus, ille fidelis permanet, negare seipsum non potest.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.14",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 2:14",
      "text": "Hæc commone, testificans coram Domino. Noli contendere verbis: ad nihil enim utile est, nisi ad subversionem audientium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.15",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 2:15",
      "text": "Sollicite cura teipsum probabilem exhibere Deo, operarium inconfusibilem, recte tractantem verbum veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.16",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 2:16",
      "text": "Profana autem et vaniloquia devita: multum enim proficiunt ad impietatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.17",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 2:17",
      "text": "et sermo eorum ut cancer serpit: ex quibus est Hymenæus et Philetus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.18",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 2:18",
      "text": "qui a veritate exciderunt, dicentes resurrectionem esse jam factam, et subverterunt quorumdam fidem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.19",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 2:19",
      "text": "Sed firmum fundamentum Dei stat, habens signaculum hoc: cognovit Dominus qui sunt ejus, et discedat ab iniquitate omnis qui nominat nomen Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.20",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 2:20",
      "text": "In magna autem domo non solum sunt vasa aurea, et argentea, sed et lignea, et fictilia: et quædam quidem in honorem, quædam autem in contumeliam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.21",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 2:21",
      "text": "Si quis ergo emundaverit se ab istis, erit vas in honorem sanctificatum, et utile Domino ad omne opus bonum paratum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.22",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 2:22",
      "text": "Juvenilia autem desideria fuge, sectare vero justitiam, fidem, spem, caritatem, et pacem cum iis qui invocant Dominum de corde puro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.23",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "2 Timothy 2:23",
      "text": "Stultas autem et sine disciplina quæstiones devita: sciens quia generant lites.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.24",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "2 Timothy 2:24",
      "text": "Servum autem Domini non oportet litigare: sed mansuetum esse ad omnes, docibilem, patientem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.25",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "2 Timothy 2:25",
      "text": "cum modestia corripientem eos qui resistunt veritati, nequando Deus det illis pœnitentiam ad cognoscendam veritatem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.2.26",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "2 Timothy 2:26",
      "text": "et resipiscant a diaboli laqueis, a quo captivi tenentur ad ipsius voluntatem.",
      "paragraphStart": false
    }
  ]
}
