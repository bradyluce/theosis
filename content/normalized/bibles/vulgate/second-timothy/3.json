{
  "chapter": {
    "id": "vulgate:second-timothy.3",
    "translationId": "vulgate",
    "bookSlug": "second-timothy",
    "chapterNumber": 3,
    "referenceLabel": "2 Timothy 3",
    "summary": "Source text for 2 Timothy 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-timothy.3.1",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 3:1",
      "text": "Hoc autem scito, quod in novissimis diebus instabunt tempora periculosa:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-timothy.3.2",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 3:2",
      "text": "erunt homines seipsos amantes, cupidi, elati, superbi, blasphemi, parentibus non obedientes, ingrati, scelesti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.3",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 3:3",
      "text": "sine affectione, sine pace, criminatores, incontinentes, immites, sine benignitate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.4",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 3:4",
      "text": "proditores, protervi, tumidi, et voluptatum amatores magis quam Dei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.5",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 3:5",
      "text": "habentes speciem quidem pietatis, virtutem autem ejus abnegantes. Et hos devita:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.6",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 3:6",
      "text": "ex his enim sunt qui penetrant domos, et captivas ducunt mulierculas oneratas peccatis, quæ ducuntur variis desideriis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.7",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 3:7",
      "text": "semper discentes, et numquam ad scientiam veritatis pervenientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.8",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 3:8",
      "text": "Quemadmodum autem Jannes et Mambres restiterunt Moysi: ita et hi resistunt veritati, homines corrupti mente, reprobi circa fidem;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.9",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 3:9",
      "text": "sed ultra non proficient: insipientia enim eorum manifesta erit omnibus, sicut et illorum fuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.10",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 3:10",
      "text": "Tu autem assecutus es meam doctrinam, institutionem, propositum, fidem, longanimitatem, dilectionem, patientiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.11",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 3:11",
      "text": "persecutiones, passiones: qualia mihi facta sunt Antiochiæ, Iconii, et Lystris: quales persecutiones sustinui, et ex omnibus eripuit me Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.12",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 3:12",
      "text": "Et omnes, qui pie volunt vivere in Christo Jesu, persecutionem patientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.13",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 3:13",
      "text": "Mali autem homines et seductores proficient in pejus, errantes, et in errorem mittentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.14",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 3:14",
      "text": "Tu vero permane in iis quæ didicisti, et credita sunt tibi: sciens a quo didiceris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.15",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 3:15",
      "text": "et quia ab infantia sacras litteras nosti, quæ te possunt instruere ad salutem, per fidem quæ est in Christo Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.16",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 3:16",
      "text": "Omnis Scriptura divinitus inspirata utilis est ad docendum, ad arguendum, ad corripiendum, et erudiendum in justitia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.3.17",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 3:17",
      "text": "ut perfectus sit homo Dei, ad omne opus bonum instructus.",
      "paragraphStart": false
    }
  ]
}
