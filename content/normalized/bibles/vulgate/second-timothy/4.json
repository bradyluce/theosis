{
  "chapter": {
    "id": "vulgate:second-timothy.4",
    "translationId": "vulgate",
    "bookSlug": "second-timothy",
    "chapterNumber": 4,
    "referenceLabel": "2 Timothy 4",
    "summary": "Source text for 2 Timothy 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-timothy.4.1",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 4:1",
      "text": "Testificor coram Deo, et Jesu Christo, qui judicaturus est vivos et mortuos, per adventum ipsius, et regnum ejus:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-timothy.4.2",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 4:2",
      "text": "prædica verbum, insta opportune, importune: argue, obsecra, increpa in omni patientia, et doctrina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.3",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 4:3",
      "text": "Erit enim tempus, cum sanam doctrinam non sustinebunt, sed ad sua desideria coacervabunt sibi magistros, prurientes auribus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.4",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 4:4",
      "text": "et a veritate quidem auditum avertent, ad fabulas autem convertentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.5",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 4:5",
      "text": "Tu vero vigila, in omnibus labora, opus fac evangelistæ, ministerium tuum imple. Sobrius esto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.6",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 4:6",
      "text": "Ego enim jam delibor, et tempus resolutionis meæ instat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.7",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 4:7",
      "text": "Bonum certamen certavi, cursum consummavi, fidem servavi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.8",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 4:8",
      "text": "In reliquo reposita est mihi corona justitiæ, quam reddet mihi Dominus in illa die, justus judex: non solum autem mihi, sed et iis, qui diligunt adventum ejus. Festina ad me venire cito.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.9",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 4:9",
      "text": "Demas enim me reliquit, diligens hoc sæculum, et abiit Thessalonicam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.10",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 4:10",
      "text": "Crescens in Galatiam, Titus in Dalmatiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.11",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 4:11",
      "text": "Lucas est mecum solus. Marcum assume, et adduc tecum: est enim mihi utilis in ministerium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.12",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 4:12",
      "text": "Tychicum autem misi Ephesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.13",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 4:13",
      "text": "Penulam, quam reliqui Troade apud Carpum, veniens affer tecum, et libros, maxime autem membranas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.14",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 4:14",
      "text": "Alexander ærarius multa mala mihi ostendit: reddet illi Dominus secundum opera ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.15",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 4:15",
      "text": "quem et tu devita: valde enim restitit verbis nostris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.16",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 4:16",
      "text": "In prima mea defensione nemo mihi affuit, sed omnes me dereliquerunt: non illis imputetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.17",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 4:17",
      "text": "Dominus autem mihi astitit, et confortavit me, ut per me prædicatio impleatur, et audiant omnes gentes: et liberatus sum de ore leonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.18",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 4:18",
      "text": "Liberavit me Dominus ab omni opere malo: et salvum faciet in regnum suum cæleste, cui gloria in sæcula sæculorum. Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.19",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "2 Timothy 4:19",
      "text": "Saluta Priscam, et Aquilam, et Onesiphori domum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.20",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "2 Timothy 4:20",
      "text": "Erastus remansit Corinthi. Trophimum autem reliqui infirmum Mileti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.21",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "2 Timothy 4:21",
      "text": "Festina ante hiemem venire. Salutant te Eubulus, et Pudens, et Linus, et Claudia, et fratres omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-timothy.4.22",
      "translationId": "vulgate",
      "bookSlug": "second-timothy",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "2 Timothy 4:22",
      "text": "Dominus Jesus Christus cum spiritu tuo. Gratia vobiscum. Amen.",
      "paragraphStart": false
    }
  ]
}
