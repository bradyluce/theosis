{
  "chapter": {
    "id": "vulgate:ezra.2",
    "translationId": "vulgate",
    "bookSlug": "ezra",
    "chapterNumber": 2,
    "referenceLabel": "Ezra 2",
    "summary": "Source text for Ezra 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ezra.2.1",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ezra 2:1",
      "text": "Hi sunt autem provinciæ filii, qui ascenderunt de captivitate, quam transtulerat Nabuchodonosor rex Babylonis in Babylonem, et reversi sunt in Jerusalem et Judam, unusquisque in civitatem suam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ezra.2.2",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ezra 2:2",
      "text": "Qui venerunt cum Zorobabel, Josue, Nehemia, Saraia, Rahelaia, Mardochai, Belsan, Mesphar, Beguai, Rehum, Baana. Numerus virorum populi Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.3",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ezra 2:3",
      "text": "filii Pharos duo millia centum septuaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.4",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ezra 2:4",
      "text": "Filii Sephatia, trecenti septuaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.5",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ezra 2:5",
      "text": "Filii Area, septingenti septuaginta quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.6",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ezra 2:6",
      "text": "Filii Phahath Moab, filiorum Josue: Joab, duo millia octingenti duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.7",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ezra 2:7",
      "text": "Filii Ælam, mille ducenti quinquaginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.8",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ezra 2:8",
      "text": "Filii Zethua, nongenti quadraginta quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.9",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ezra 2:9",
      "text": "Filii Zachai, septingenti sexaginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.10",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ezra 2:10",
      "text": "Filii Bani, sexcenti quadraginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.11",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ezra 2:11",
      "text": "Filii Bebai, sexcenti viginti tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.12",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ezra 2:12",
      "text": "Filii Azgad, mille ducenti viginti duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.13",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ezra 2:13",
      "text": "Filii Adonicam, sexcenti sexaginta sex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.14",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ezra 2:14",
      "text": "Filii Beguai, duo millia quinquaginta sex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.15",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ezra 2:15",
      "text": "Filii Adin, quadringenti quinquaginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.16",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ezra 2:16",
      "text": "Filii Ather, qui erant ex Ezechia, nonaginta octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.17",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ezra 2:17",
      "text": "Filii Besai, trecenti viginti tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.18",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ezra 2:18",
      "text": "Filii Jora, centum duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.19",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ezra 2:19",
      "text": "Filii Hasum, ducenti viginti tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.20",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ezra 2:20",
      "text": "Filii Gebbar, nonaginta quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.21",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ezra 2:21",
      "text": "Filii Bethlehem, centum viginti tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.22",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ezra 2:22",
      "text": "Viri Netupha, quinquaginta sex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.23",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Ezra 2:23",
      "text": "Viri Anathoth, centum viginti octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.24",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Ezra 2:24",
      "text": "Filii Azmaveth, quadraginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.25",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Ezra 2:25",
      "text": "Filii Cariathiarim, Cephira et Beroth, septingenti quadraginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.26",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Ezra 2:26",
      "text": "Filii Rama et Gabaa, sexcenti viginti unus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.27",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Ezra 2:27",
      "text": "Viri Machmas, centum viginti duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.28",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Ezra 2:28",
      "text": "Viri Bethel et Hai, ducenti viginti tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.29",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Ezra 2:29",
      "text": "Filii Nebo, quinquaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.30",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 30,
      "referenceLabel": "Ezra 2:30",
      "text": "Filii Megbis, centum quinquaginta sex.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.31",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 31,
      "referenceLabel": "Ezra 2:31",
      "text": "Filii Ælam alterius, mille ducenti quinquaginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.32",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 32,
      "referenceLabel": "Ezra 2:32",
      "text": "Filii Harim, trecenti viginti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.33",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 33,
      "referenceLabel": "Ezra 2:33",
      "text": "Filii Lod Hadid, et Ono, septingenti viginti quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.34",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 34,
      "referenceLabel": "Ezra 2:34",
      "text": "Filii Jericho, trecenti quadraginta quinque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.35",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 35,
      "referenceLabel": "Ezra 2:35",
      "text": "Filii Senaa, tria millia sexcenti triginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.36",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 36,
      "referenceLabel": "Ezra 2:36",
      "text": "Sacerdotes: filii Jadaia in domo Josue, nongenti septuaginta tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.37",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 37,
      "referenceLabel": "Ezra 2:37",
      "text": "Filii Emmer, mille quinquaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.38",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 38,
      "referenceLabel": "Ezra 2:38",
      "text": "Filii Pheshur, mille ducenti quadraginta septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.39",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 39,
      "referenceLabel": "Ezra 2:39",
      "text": "Filii Harim, mille decem et septem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.40",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 40,
      "referenceLabel": "Ezra 2:40",
      "text": "Levitæ: filii Josue et Cedmihel filiorum Odoviæ, septuaginta quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.41",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 41,
      "referenceLabel": "Ezra 2:41",
      "text": "Cantores: filii Asaph, centum viginti octo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.42",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 42,
      "referenceLabel": "Ezra 2:42",
      "text": "Filii janitorum: filii Sellum, filii Ater, filii Telmon, filii Accub, filii Hatitha, filii Sobai: universi centum triginta novem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.43",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 43,
      "referenceLabel": "Ezra 2:43",
      "text": "Nathinæi: filii Siha, filii Hasupha, filii Tabbaoth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.44",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 44,
      "referenceLabel": "Ezra 2:44",
      "text": "filii Ceros, filii Siaa, filii Phadon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.45",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 45,
      "referenceLabel": "Ezra 2:45",
      "text": "filii Lebana, filii Hagaba, filii Accub,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.46",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 46,
      "referenceLabel": "Ezra 2:46",
      "text": "filii Hagab, filii Semlai, filii Hanan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.47",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 47,
      "referenceLabel": "Ezra 2:47",
      "text": "filii Gaddel, filii Gaher, filii Raaia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.48",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 48,
      "referenceLabel": "Ezra 2:48",
      "text": "filii Rasin, filii Necoda, filii Gazam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.49",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 49,
      "referenceLabel": "Ezra 2:49",
      "text": "filii Aza, filii Phasea, filii Besee,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.50",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 50,
      "referenceLabel": "Ezra 2:50",
      "text": "filii Asena, filii Munim, filii Nephusim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.51",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 51,
      "referenceLabel": "Ezra 2:51",
      "text": "filii Bacbuc, filii Hacupha, filii Harhur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.52",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 52,
      "referenceLabel": "Ezra 2:52",
      "text": "filii Besluth, filii Mahida, filii Harsa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.53",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 53,
      "referenceLabel": "Ezra 2:53",
      "text": "filii Bercos, filii Sisara, filii Thema,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.54",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 54,
      "referenceLabel": "Ezra 2:54",
      "text": "filii Nasia, filii Hatipha,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.55",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 55,
      "referenceLabel": "Ezra 2:55",
      "text": "filii servorum Salomonis, filii Sotai, filii Sophereth, filii Pharuda,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.56",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 56,
      "referenceLabel": "Ezra 2:56",
      "text": "filii Jala, filii Dercon, filii Geddel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.57",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 57,
      "referenceLabel": "Ezra 2:57",
      "text": "filii Saphatia, filii Hatil, filii Phochereth, qui erant de Asebaim, filii Ami:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.58",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 58,
      "referenceLabel": "Ezra 2:58",
      "text": "omnes Nathinæi, et filii servorum Salomonis, trecenti nonaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.59",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 59,
      "referenceLabel": "Ezra 2:59",
      "text": "Et hi qui ascenderunt de Thelmala, Thelharsa, Cherub, et Adon, et Emer: et non potuerunt indicare domum patrum suorum et semen suum, utrum ex Israël essent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.60",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 60,
      "referenceLabel": "Ezra 2:60",
      "text": "Filii Dalaia, filii Tobia, filii Necoda, sexcenti quinquaginta duo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.61",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 61,
      "referenceLabel": "Ezra 2:61",
      "text": "Et de filiis sacerdotum: filii Hobia, filii Accos, filii Berzellai, qui accepit de filiabus Berzellai Galaaditis, uxorem, et vocatus est nomine eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.62",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 62,
      "referenceLabel": "Ezra 2:62",
      "text": "hi quæsierunt scripturam genealogiæ suæ, et non invenerunt, et ejecti sunt de sacerdotio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.63",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 63,
      "referenceLabel": "Ezra 2:63",
      "text": "Et dixit Athersatha eis ut non comederent de Sancto sanctorum, donec surgeret sacerdos doctus atque perfectus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.64",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 64,
      "referenceLabel": "Ezra 2:64",
      "text": "Omnis multitudo quasi unus, quadraginta duo millia trecenti sexaginta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.65",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 65,
      "referenceLabel": "Ezra 2:65",
      "text": "exceptis servis eorum, et ancillis, qui erant septem millia trecenti triginta septem: et in ipsis cantores atque cantatrices ducenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.66",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 66,
      "referenceLabel": "Ezra 2:66",
      "text": "Equi eorum septingenti triginta sex, muli eorum, ducenti quadraginta quinque,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.67",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 67,
      "referenceLabel": "Ezra 2:67",
      "text": "cameli eorum, quadringenti triginta quinque, asini eorum, sex millia septingenti viginti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.2.68",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 2,
      "verseNumber": 68,
      "referenceLabel": "Ezra 2:68",
