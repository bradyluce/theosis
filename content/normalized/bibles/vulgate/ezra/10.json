{
  "chapter": {
    "id": "vulgate:ezra.10",
    "translationId": "vulgate",
    "bookSlug": "ezra",
    "chapterNumber": 10,
    "referenceLabel": "Ezra 10",
    "summary": "Source text for Ezra 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:ezra.10.1",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Ezra 10:1",
      "text": "Sic ergo orante Esdra, et implorante eo et flente, et jacente ante templum Dei, collectus est ad eum de Israël cœtus grandis nimis virorum et mulierum et puerorum, et flevit populus fletu multo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:ezra.10.2",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Ezra 10:2",
      "text": "Et respondit Sechenias filius Jehiel de filiis Ælam, et dixit Esdræ: Nos prævaricati sumus in Deum nostrum, et duximus uxores alienigenas de populis terræ: et nunc, si est pœnitentia in Israël super hoc,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.3",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Ezra 10:3",
      "text": "percutiamus fœdus cum Domino Deo nostro, ut projiciamus universas uxores, et eos qui de his nati sunt, juxta voluntatem Domini, et eorum qui timent præceptum Domini Dei nostri: secundum legem fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.4",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Ezra 10:4",
      "text": "Surge, tuum est decernere, nosque erimus tecum: confortare, et fac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.5",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Ezra 10:5",
      "text": "Surrexit ergo Esdras, et adjuravit principes sacerdotum et Levitarum, et omnem Israël, ut facerent secundum verbum hoc: et juraverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.6",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Ezra 10:6",
      "text": "Et surrexit Esdras ante domum Dei, et abiit ad cubiculum Johanan filii Eliasib, et ingressus est illuc: panem non comedit, et aquam non bibit: lugebat enim transgressionem eorum, qui venerant de captivitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.7",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Ezra 10:7",
      "text": "Et missa est vox in Juda et in Jerusalem omnibus filiis transmigrationis, ut congregarentur in Jerusalem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.8",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Ezra 10:8",
      "text": "et omnis qui non venerit in tribus diebus juxta consilium principum et seniorum, auferetur universa substantia ejus, et ipse abjicietur de cœtu transmigrationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.9",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Ezra 10:9",
      "text": "Convenerunt igitur omnes viri Juda et Benjamin in Jerusalem tribus diebus: ipse est mensis nonus, vigesimo die mensis: et sedit omnis populus in platea domus Dei, trementes pro peccato, et pluviis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.10",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Ezra 10:10",
      "text": "Et surrexit Esdras sacerdos, et dixit ad eos: Vos transgressi estis, et duxistis uxores alienigenas, ut adderetis super delictum Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.11",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Ezra 10:11",
      "text": "Et nunc date confessionem Domino Deo patrum vestrorum, et facite placitum ejus, et separamini a populis terræ, et ab uxoribus alienigenis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.12",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Ezra 10:12",
      "text": "Et respondit universa multitudo, dixitque voce magna: Juxta verbum tuum ad nos, sic fiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.13",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Ezra 10:13",
      "text": "Verumtamen quia populus multus est, et tempus pluviæ, et non sustinemus stare foris, et opus non est diei unius vel duorum (vehementer quippe peccavimus in sermone isto),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.14",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Ezra 10:14",
      "text": "constituantur principes in universa multitudine: et omnes in civitatibus nostris qui duxerunt uxores alienigenas veniant in temporibus statutis, et cum his seniores per civitatem et civitatem, et judices ejus, donec avertatur ira Dei nostri a nobis super peccato hoc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.15",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Ezra 10:15",
      "text": "Igitur Jonathan filius Azahel, et Jaasia filius Thecue, steterunt super hoc, et Messollam et Sebethai Levites adjuverunt eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.16",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Ezra 10:16",
      "text": "feceruntque sic filii transmigrationis. Et abierunt Esdras sacerdos, et viri principes familiarum, in domos patrum suorum, et omnes per nomina sua, et sederunt in die primo mensis decimi ut quærerent rem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.17",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Ezra 10:17",
      "text": "Et consummati sunt omnes viri, qui duxerant uxores alienigenas, usque ad diem primam mensis primi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.18",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Ezra 10:18",
      "text": "Et inventi sunt de filiis sacerdotum qui duxerant uxores alienigenas. De filiis Josue filii Josedec, et fratres ejus, Maasia, et Eliezer, et Jarib, et Godolia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.19",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Ezra 10:19",
      "text": "Et dederunt manus suas ut ejicerent uxores suas, et pro delicto suo arietem de ovibus offerrent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.20",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Ezra 10:20",
      "text": "Et de filiis Emmer, Hanani, et Zebedia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.21",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Ezra 10:21",
      "text": "Et de filiis Harim, Maasia, et Elia, et Semeia, et Jehiel, et Ozias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.22",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Ezra 10:22",
      "text": "Et de filiis Pheshur, Elioënai, Maasia, Ismaël, Nathanaël, Jozabed, et Elasa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.23",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Ezra 10:23",
      "text": "Et de filiis Levitarum, Jozabed, et Semei, et Celaia, ipse est Calita, Phataia, Juda, et Eliezer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.24",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Ezra 10:24",
      "text": "Et de cantoribus, Eliasib. Et de janitoribus, Sellum, et Telem, et Uri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.25",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Ezra 10:25",
      "text": "Et ex Israël, de filiis Pharos, Remeia, et Jesia, et Melchia, et Miamin, et Eliezer, et Melchia, et Banea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.26",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Ezra 10:26",
      "text": "Et de filiis Ælam, Mathania, Zacharias, et Jehiel, et Abdi, et Jerimoth, et Elia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.27",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Ezra 10:27",
      "text": "Et de filiis Zethua, Elioënai, Eliasib, Mathania, et Jerimuth, et Zabad, et Aziza.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.28",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Ezra 10:28",
      "text": "Et de filiis Bebai, Johanan, Hanania, Zabbai, Athalai.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.29",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Ezra 10:29",
      "text": "Et de filiis Bani, Mosollam, et Melluch, et Adaia, Jasub, et Saal, et Ramoth.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.30",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Ezra 10:30",
      "text": "Et de filiis Phahath Moab, Edna, et Chalal, Banaias, et Maasias, Mathanias, Beseleel, Bennui, et Manasse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.31",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Ezra 10:31",
      "text": "Et de filiis Herem, Eliezer, Josue, Melchias, Semeias, Simeon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.32",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Ezra 10:32",
      "text": "Benjamin, Maloch, Samarias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.33",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Ezra 10:33",
      "text": "Et de filiis Hasom, Mathanai, Mathatha, Zabad, Eliphelet, Jermai, Manasse, Semei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.34",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Ezra 10:34",
      "text": "De filiis Bani, Maadi, Amram, et Vel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.35",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Ezra 10:35",
      "text": "Baneas, et Badaias, Cheliau,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.36",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Ezra 10:36",
      "text": "Vania, Marimuth, et Eliasib,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.37",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Ezra 10:37",
      "text": "Mathanias, Mathanai, et Jasi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.38",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Ezra 10:38",
      "text": "et Bani, et Bennui, Semei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.39",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "Ezra 10:39",
      "text": "et Salmias, et Nathan, et Adaias,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.40",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 40,
      "referenceLabel": "Ezra 10:40",
      "text": "et Mechnedebai, Sisai, Sarai,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.41",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 41,
      "referenceLabel": "Ezra 10:41",
      "text": "Ezrel, et Selemiau, Semeria,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.42",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 42,
      "referenceLabel": "Ezra 10:42",
      "text": "Sellum, Amaria, Joseph.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.43",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 43,
      "referenceLabel": "Ezra 10:43",
      "text": "De filiis Nebo, Jehiel, Mathathias, Zabad, Zabina, Jeddu, et Joël, et Banaia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:ezra.10.44",
      "translationId": "vulgate",
      "bookSlug": "ezra",
      "chapterNumber": 10,
      "verseNumber": 44,
      "referenceLabel": "Ezra 10:44",
      "text": "Omnes hi acceperant uxores alienigenas, et fuerunt ex eis mulieres, quæ pepererant filios.",
      "paragraphStart": false
    }
  ]
}
