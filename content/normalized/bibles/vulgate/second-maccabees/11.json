{
  "chapter": {
    "id": "vulgate:second-maccabees.11",
    "translationId": "vulgate",
    "bookSlug": "second-maccabees",
    "chapterNumber": 11,
    "referenceLabel": "2 Maccabees 11",
    "summary": "Source text for 2 Maccabees 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-maccabees.11.1",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "2 Maccabees 11:1",
      "text": "Sed parvo post tempore, Lysias procurator regis et propinquus, ac negotiorum præpositus, graviter ferens de his quæ acciderant,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-maccabees.11.2",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "2 Maccabees 11:2",
      "text": "congregatis octoginta millibus, et equitatu universo, veniebat adversus Judæos, existimans se civitatem quidem captam gentibus habitaculum facturum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.3",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "2 Maccabees 11:3",
      "text": "templum vero in pecuniæ quæstum, sicut cetera delubra gentium, habiturum, et per singulos annos venale sacerdotium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.4",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "2 Maccabees 11:4",
      "text": "nusquam recogitans Dei potestatem, sed mente effrenatus in multitudine peditum, et in millibus equitum, et in octoginta elephantis confidebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.5",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "2 Maccabees 11:5",
      "text": "Ingressus autem Judæam, et appropians Bethsuræ, quæ erat in angusto loco, ab Jerosolyma intervallo quinque stadiorum, illud præsidium expugnabat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.6",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "2 Maccabees 11:6",
      "text": "Ut autem Machabæus et qui cum eo erant cognoverunt expugnari præsidia, cum fletu et lacrimis rogabant Dominum, et omnis turba simul, ut bonum angelum mitteret ad salutem Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.7",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "2 Maccabees 11:7",
      "text": "Et ipse primus Machabæus, sumptis armis, ceteros adhortatus est simul secum periculum subire, et ferre auxilium fratribus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.8",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "2 Maccabees 11:8",
      "text": "Cumque pariter prompto animo procederent, Jerosolymis apparuit præcedens eos eques in veste candida, armis aureis hastam vibrans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.9",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "2 Maccabees 11:9",
      "text": "Tunc omnes simul benedixerunt misericordem Dominum, et convaluerunt animis: non solum homines, sed et bestias ferocissimas, et muros ferreos parati penetrare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.10",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "2 Maccabees 11:10",
      "text": "Ibant igitur prompti, de cælo habentes adjutorem et miserantem super eos Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.11",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "2 Maccabees 11:11",
      "text": "Leonum autem more impetu irruentes in hostes, prostraverunt ex eis undecim millia peditum, et equitum mille sexcentos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.12",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "2 Maccabees 11:12",
      "text": "universos autem in fugam verterunt, plures autem ex eis vulnerati nudi evaserunt. Sed et ipse Lysias turpiter fugiens evasit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.13",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "2 Maccabees 11:13",
      "text": "Et quia non insensatus erat, secum ipse reputans factam erga se diminutionem, et intelligens invictos esse Hebræos, omnipotentis Dei auxilio innitentes, misit ad eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.14",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "2 Maccabees 11:14",
      "text": "promisitque se consensurum omnibus quæ justa sunt, et regem compulsurum amicum fieri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.15",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "2 Maccabees 11:15",
      "text": "Annuit autem Machabæus precibus Lysiæ, in omnibus utilitati consulens: et quæcumque Machabæus scripsit Lysiæ de Judæis, ea rex concessit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.16",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "2 Maccabees 11:16",
      "text": "Nam erant scriptæ Judæis epistolæ a Lysia quidem hunc modum continentes: Lysias populo Judæorum salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.17",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "2 Maccabees 11:17",
      "text": "Joannes et Abesalom, qui missi fuerant a vobis, tradentes scripta, postulabant ut ea quæ per illos significabantur, implerem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.18",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "2 Maccabees 11:18",
      "text": "Quæcumque igitur regi potuerunt perferri, exposui: et quæ res permittebat, concessit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.19",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "2 Maccabees 11:19",
      "text": "Si igitur in negotiis fidem conservaveritis, et deinceps bonorum vobis causa esset, tentabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.20",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "2 Maccabees 11:20",
      "text": "De ceteris autem per singula verbo mandavi et istis, et his, qui a me missi sunt, colloqui vobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.21",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "2 Maccabees 11:21",
      "text": "Bene valete. Anno centesimo, quadragesimo octavo mensis Dioscori, die vigesima et quarta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.22",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "2 Maccabees 11:22",
      "text": "Regis autem epistola ista continebat: Rex Antiochus Lysiæ fratri salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.23",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "2 Maccabees 11:23",
      "text": "Patre nostro inter deos translato, nos volentes eos qui sunt in regno nostro sine tumultu agere, et rebus suis adhibere diligentiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.24",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "2 Maccabees 11:24",
      "text": "audivimus Judæos non consensisse patri meo ut transferrentur ad ritum Græcorum, sed tenere velle suum institutum, ac propterea postulare a nobis concedi sibi legitima sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.25",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "2 Maccabees 11:25",
      "text": "Volentes igitur hanc quoque gentem quietam esse, statuentes judicavimus templum restitui illis, ut agerent secundum suorum majorum consuetudinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.26",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "2 Maccabees 11:26",
      "text": "Bene igitur feceris, si miseris ad eos et dexteram dederis: ut cognita nostra voluntate, bono animo sint, et utilitatibus propriis deserviant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.27",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "2 Maccabees 11:27",
      "text": "Ad Judæos vero regis epistola talis erat: Rex Antiochus senatui Judæorum, et ceteris Judæis salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.28",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "2 Maccabees 11:28",
      "text": "Si valetis, sic estis ut volumus: sed et ipsi bene valemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.29",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "2 Maccabees 11:29",
      "text": "Adiit nos Menelaus, dicens velle vos descendere ad vestros, qui sunt apud nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.30",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "2 Maccabees 11:30",
      "text": "His igitur qui commeant usque ad diem trigesimum mensis Xanthici, damus dextras securitatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.31",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "2 Maccabees 11:31",
      "text": "ut Judæi utantur cibis et legibus suis, sicut et prius: et nemo eorum ullo modo molestiam patiatur de his quæ per ignorantiam gesta sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.32",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "2 Maccabees 11:32",
      "text": "Misimus autem et Menelaum, qui vos alloquatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.33",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "2 Maccabees 11:33",
      "text": "Valete. Anno centesimo quadragesimo octavo, Xanthici mensis quintadecima die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.34",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "2 Maccabees 11:34",
      "text": "Miserunt autem etiam Romani epistolam, ita se habentem: Quintus Memmius et Titus Manilius legati Romanorum, populo Judæorum salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.35",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "2 Maccabees 11:35",
      "text": "De his quæ Lysias cognatus regis concessit vobis, et nos concessimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.36",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "2 Maccabees 11:36",
      "text": "De quibus autem ad regem judicavit referendum, confestim aliquem mittere, diligentius inter vos conferentes, ut decernamus, sicut congruit vobis: nos enim Antiochiam accedimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.37",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 37,
      "referenceLabel": "2 Maccabees 11:37",
      "text": "Ideoque festinate rescribere, ut nos quoque sciamus cujus estis voluntatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-maccabees.11.38",
      "translationId": "vulgate",
      "bookSlug": "second-maccabees",
      "chapterNumber": 11,
      "verseNumber": 38,
      "referenceLabel": "2 Maccabees 11:38",
      "text": "Bene valete. Anno centesimo quadragesimo octavo, quintadecima die mensis Xanthici.",
      "paragraphStart": false
    }
  ]
}
