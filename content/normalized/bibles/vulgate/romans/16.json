{
  "chapter": {
    "id": "vulgate:romans.16",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 16,
    "referenceLabel": "Romans 16",
    "summary": "Source text for Romans 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.16.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Romans 16:1",
      "text": "Commendo autem vobis Phœben sororem nostram, quæ est in ministerio ecclesiæ, quæ est in Cenchris:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.16.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Romans 16:2",
      "text": "ut eam suscipiatis in Domino digne sanctis: et assistatis ei in quocumque negotio vestri indiguerit: etenim ipsa quoque astitit multis, et mihi ipsi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Romans 16:3",
      "text": "Salutate Priscam et Aquilam, adjutores meos in Christo Jesu",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Romans 16:4",
      "text": "(qui pro anima mea suas cervices supposuerunt: quibus non solus ego gratias ago, sed et cunctæ ecclesiæ gentium),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Romans 16:5",
      "text": "et domesticam ecclesiam eorum. Salutate Epænetum dilectum mihi, qui est primitivus Asiæ in Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Romans 16:6",
      "text": "Salutate Mariam, quæ multum laboravit in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Romans 16:7",
      "text": "Salutate Andronicum et Juniam, cognatos, et concaptivos meos: qui sunt nobiles in Apostolis, qui et ante me fuerunt in Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Romans 16:8",
      "text": "Salutate Ampliatum dilectissimum mihi in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Romans 16:9",
      "text": "Salutate Urbanum adjutorem nostrum in Christo Jesu, et Stachyn dilectum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Romans 16:10",
      "text": "Salutate Apellen probum in Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Romans 16:11",
      "text": "Salutate eos qui sunt ex Aristoboli domo. Salutate Herodionem cognatum meum. Salutate eos qui sunt ex Narcisi domo, qui sunt in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Romans 16:12",
      "text": "Salutate Tryphænam et Tryphosam, quæ laborant in Domino. Salutate Persidem carissimam, quæ multum laboravit in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Romans 16:13",
      "text": "Salutate Rufum electum in Domino, et matrem ejus, et meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Romans 16:14",
      "text": "Salutate Asyncritum, Phlegontem, Hermam, Patrobam, Hermen, et qui cum eis sunt, fratres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Romans 16:15",
      "text": "Salutate Philologum et Juliam, Nereum, et sororem ejus, et Olympiadem, et omnes qui cum eis sunt, sanctos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Romans 16:16",
      "text": "Salutate invicem in osculo sancto. Salutant vos omnes ecclesiæ Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Romans 16:17",
      "text": "Rogo autem vos fratres, ut observetis eos qui dissensiones et offendicula, præter doctrinam, quam vos didicistis, faciunt, et declinate ab illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Romans 16:18",
      "text": "Hujuscemodi enim Christo Domino nostro non serviunt, sed suo ventri: et per dulces sermones et benedictiones seducunt corda innocentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Romans 16:19",
      "text": "Vestra enim obedientia in omnem locum divulgata est. Gaudeo igitur in vobis. Sed volo vos sapientes esse in bono, et simplices in malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Romans 16:20",
      "text": "Deus autem pacis conterat Satanam sub pedibus vestris velociter. Gratia Domini nostri Jesu Christi vobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Romans 16:21",
      "text": "Salutat vos Timotheus adjutor meus, et Lucius, et Jason, et Sosipater cognati mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Romans 16:22",
      "text": "Saluto vos ego Tertius, qui scripsi epistolam, in Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Romans 16:23",
      "text": "Salutat vos Cajus hospes meus, et universa ecclesia. Salutat vos Erastus arcarius civitatis, et Quartus, frater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Romans 16:24",
      "text": "Gratia Domini nostri Jesu Christi cum omnibus vobis. Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Romans 16:25",
      "text": "Ei autem, qui potens est vos confirmare juxta Evangelium meum, et prædicationem Jesu Christi, secundum revelationem mysterii temporibus æternis taciti",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Romans 16:26",
      "text": "(quod nunc patefactum est per Scripturas prophetarum secundum præceptum æterni Dei, ad obeditionem fidei), in cunctis gentibus cogniti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.16.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Romans 16:27",
      "text": "soli sapienti Deo, per Jesum Christum, cui honor et gloria in sæcula sæculorum. Amen.",
      "paragraphStart": false
    }
  ]
}
