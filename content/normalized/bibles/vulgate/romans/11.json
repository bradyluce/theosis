{
  "chapter": {
    "id": "vulgate:romans.11",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 11,
    "referenceLabel": "Romans 11",
    "summary": "Source text for Romans 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.11.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Romans 11:1",
      "text": "Dico ergo: Numquid Deus repulit populum suum? Absit. Nam et ego Israëlita sum ex semine Abraham, de tribu Benjamin:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.11.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Romans 11:2",
      "text": "non repulit Deus plebem suam, quam præscivit. An nescitis in Elia quid dicit Scriptura? quemadmodum interpellat Deum adversum Israël:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Romans 11:3",
      "text": "Domine, prophetas tuos occiderunt, altaria tua suffoderunt: et ego relictus sum solus, et quærunt animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Romans 11:4",
      "text": "Sed quid dicit illi divinum responsum? Reliqui mihi septem millia virorum, qui non curvaverunt genua ante Baal.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Romans 11:5",
      "text": "Sic ergo et in hoc tempore reliquiæ secundum electionem gratiæ salvæ factæ sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Romans 11:6",
      "text": "Si autem gratia, jam non ex operibus: alioquin gratia jam non est gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Romans 11:7",
      "text": "Quid ergo? Quod quærebat Israël, hoc non est consecutus: electio autem consecuta est: ceteri vero excæcati sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Romans 11:8",
      "text": "sicut scriptum est: Dedit illis Deus spiritum compunctionis: oculos ut non videant, et aures ut non audiant, usque in hodiernum diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Romans 11:9",
      "text": "Et David dicit: Fiat mensa eorum in laqueum, et in captionem, et in scandalum, et in retributionem illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Romans 11:10",
      "text": "Obscurentur oculi eorum ne videant: et dorsum eorum semper incurva.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Romans 11:11",
      "text": "Dico ergo: Numquid sic offenderunt ut caderent? Absit. Sed illorum delicto, salus est gentibus ut illos æmulentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Romans 11:12",
      "text": "Quod si delictum illorum divitiæ sunt mundi, et diminutio eorum divitiæ gentium: quanto magis plenitudo eorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Romans 11:13",
      "text": "Vobis enim dico gentibus: Quamdiu quidem ego sum gentium Apostolus, ministerium meum honorificabo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Romans 11:14",
      "text": "si quomodo ad æmulandum provocem carnem meam, et salvos faciam aliquos ex illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Romans 11:15",
      "text": "Si enim amissio eorum, reconciliatio est mundi: quæ assumptio, nisi vita ex mortuis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Romans 11:16",
      "text": "Quod si delibatio sancta est, et massa: et si radix sancta, et rami.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Romans 11:17",
      "text": "Quod si aliqui ex ramis fracti sunt, tu autem cum oleaster esses, insertus es in illis, et socius radicis, et pinguedinis olivæ factus es,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Romans 11:18",
      "text": "noli gloriari adversus ramos. Quod si gloriaris: non tu radicem portas, sed radix te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Romans 11:19",
      "text": "Dices ergo: Fracti sunt rami ut ego inserar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Romans 11:20",
      "text": "Bene: propter incredulitatem fracti sunt. Tu autem fide stas: noli altum sapere, sed time.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Romans 11:21",
      "text": "Si enim Deus naturalibus ramis non pepercit: ne forte nec tibi parcat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Romans 11:22",
      "text": "Vide ergo bonitatem, et severitatem Dei: in eos quidem qui ceciderunt, severitatem: in te autem bonitatem Dei, si permanseris in bonitate, alioquin et tu excideris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Romans 11:23",
      "text": "Sed et illi, si non permanserint in incredulitate, inserentur: potens est enim Deus iterum inserere illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Romans 11:24",
      "text": "Nam si tu ex naturali excisus es oleastro, et contra naturam insertus es in bonam olivam: quanto magis ii qui secundum naturam inserentur suæ olivæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Romans 11:25",
      "text": "Nolo enim vos ignorare, fratres, mysterium hoc (ut non sitis vobis ipsis sapientes), quia cæcitas ex parte contigit in Israël, donec plenitudo gentium intraret,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Romans 11:26",
      "text": "et sic omnis Israël salvus fieret, sicut scriptum est: Veniet ex Sion, qui eripiat, et avertat impietatem a Jacob.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Romans 11:27",
      "text": "Et hoc illis a me testamentum: cum abstulero peccata eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.28",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Romans 11:28",
      "text": "Secundum Evangelium quidem, inimici propter vos: secundum electionem autem, carissimi propter patres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.29",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Romans 11:29",
      "text": "Sine pœnitentia enim sunt dona et vocatio Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.30",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Romans 11:30",
      "text": "Sicut enim aliquando et vos non credidistis Deo, nunc autem misericordiam consecuti estis propter incredulitatem illorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.31",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Romans 11:31",
      "text": "ita et isti nunc non crediderunt in vestram misericordiam: ut et ipsi misericordiam consequantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.32",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Romans 11:32",
      "text": "Conclusit enim Deus omnia in incredulitate, ut omnium misereatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.33",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Romans 11:33",
      "text": "O altitudo divitiarum sapientiæ, et scientiæ Dei: quam incomprehensibilia sunt judicia ejus, et investigabiles viæ ejus!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.34",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Romans 11:34",
      "text": "Quis enim cognovit sensum Domini? aut quis consiliarius ejus fuit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.35",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Romans 11:35",
      "text": "aut quis prior dedit illi, et retribuetur ei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.11.36",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Romans 11:36",
      "text": "Quoniam ex ipso, et per ipsum, et in ipso sunt omnia: ipsi gloria in sæcula. Amen.",
      "paragraphStart": false
    }
  ]
}
