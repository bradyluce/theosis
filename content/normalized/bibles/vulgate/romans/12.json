{
  "chapter": {
    "id": "vulgate:romans.12",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 12,
    "referenceLabel": "Romans 12",
    "summary": "Source text for Romans 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.12.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Romans 12:1",
      "text": "Obsecro itaque vos fratres per misericordiam Dei, ut exhibeatis corpora vestra hostiam viventem, sanctam, Deo placentem, rationabile obsequium vestrum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.12.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Romans 12:2",
      "text": "Et nolite conformari huic sæculo, sed reformamini in novitate sensus vestri: ut probetis quæ sit voluntas Dei bona, et beneplacens, et perfecta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Romans 12:3",
      "text": "Dico enim per gratiam quæ data est mihi, omnibus qui sunt inter vos, non plus sapere quam oportet sapere, sed sapere ad sobrietatem: et unicuique sicut Deus divisit mensuram fidei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Romans 12:4",
      "text": "Sicut enim in uno corpore multa membra habemus, omnia autem membra non eumdem actum habent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Romans 12:5",
      "text": "ita multi unum corpus sumus in Christo, singuli autem alter alterius membra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Romans 12:6",
      "text": "Habentes autem donationes secundum gratiam, quæ data est nobis, differentes: sive prophetiam secundum rationem fidei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Romans 12:7",
      "text": "sive ministerium in ministrando, sive qui docet in doctrina,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Romans 12:8",
      "text": "qui exhortatur in exhortando, qui tribuit in simplicitate, qui præest in sollicitudine, qui miseretur in hilaritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Romans 12:9",
      "text": "Dilectio sine simulatione: odientes malum, adhærentes bono:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Romans 12:10",
      "text": "caritate fraternitatis invicem diligentes: honore invicem prævenientes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Romans 12:11",
      "text": "sollicitudine non pigri: spiritu ferventes: Domino servientes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Romans 12:12",
      "text": "spe gaudentes: in tribulatione patientes: orationi instantes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Romans 12:13",
      "text": "necessitatibus sanctorum communicantes: hospitalitatem sectantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Romans 12:14",
      "text": "Benedicite persequentibus vos: benedicite, et nolite maledicere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Romans 12:15",
      "text": "Gaudere cum gaudentibus, flere cum flentibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Romans 12:16",
      "text": "idipsum invicem sentientes: non alta sapientes, sed humilibus consentientes. Nolite esse prudentes apud vosmetipsos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Romans 12:17",
      "text": "nulli malum pro malo reddentes: providentes bona non tantum coram Deo, sed etiam coram omnibus hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Romans 12:18",
      "text": "Si fieri potest, quod ex vobis est, cum omnibus hominibus pacem habentes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Romans 12:19",
      "text": "non vosmetipsos defendentes carissimi, sed date locum iræ. Scriptum est enim: Mihi vindicta: ego retribuam, dicit Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Romans 12:20",
      "text": "Sed si esurierit inimicus tuus, ciba illum: si sitit, potum da illi: hoc enim faciens, carbones ignis congeres super caput ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.12.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Romans 12:21",
      "text": "Noli vinci a malo, sed vince in bono malum.",
      "paragraphStart": false
    }
  ]
}
