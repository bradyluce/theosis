{
  "chapter": {
    "id": "vulgate:romans.8",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 8,
    "referenceLabel": "Romans 8",
    "summary": "Source text for Romans 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.8.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Romans 8:1",
      "text": "Nihil ergo nunc damnationis est iis qui sunt in Christo Jesu: qui non secundum carnem ambulant.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.8.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Romans 8:2",
      "text": "Lex enim spiritus vitæ in Christo Jesu liberavit me a lege peccati et mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Romans 8:3",
      "text": "Nam quod impossibile erat legi, in quo infirmabatur per carnem: Deus Filium suum mittens in similitudinem carnis peccati et de peccato, damnavit peccatum in carne,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Romans 8:4",
      "text": "ut justificatio legis impleretur in nobis, qui non secundum carnem ambulamus, sed secundum spiritum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Romans 8:5",
      "text": "Qui enim secundum carnem sunt, quæ carnis sunt, sapiunt: qui vero secundum spiritum sunt, quæ sunt spiritus, sentiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Romans 8:6",
      "text": "Nam prudentia carnis, mors est: prudentia autem spiritus, vita et pax:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Romans 8:7",
      "text": "quoniam sapientia carnis inimica est Deo: legi enim Dei non est subjecta, nec enim potest.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Romans 8:8",
      "text": "Qui autem in carne sunt, Deo placere non possunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Romans 8:9",
      "text": "Vos autem in carne non estis, sed in spiritu: si tamen Spiritus Dei habitat in vobis. Si quis autem Spiritum Christi non habet, hic non est ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Romans 8:10",
      "text": "Si autem Christus in vobis est, corpus quidem mortuum est propter peccatum, spiritus vero vivit propter justificationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Romans 8:11",
      "text": "Quod si Spiritus ejus, qui suscitavit Jesum a mortuis, habitat in vobis: qui suscitavit Jesum Christum a mortuis, vivificabit et mortalia corpora vestra, propter inhabitantem Spiritum ejus in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Romans 8:12",
      "text": "Ergo fratres, debitores sumus non carni, ut secundum carnem vivamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Romans 8:13",
      "text": "Si enim secundum carnem vixeritis, moriemini: si autem spiritu facta carnis mortificaveritis, vivetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Romans 8:14",
      "text": "Quicumque enim Spiritu Dei aguntur, ii sunt filii Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Romans 8:15",
      "text": "Non enim accepistis spiritum servitutis iterum in timore, sed accepistis spiritum adoptionis filiorum, in quo clamamus: Abba (Pater).",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Romans 8:16",
      "text": "Ipse enim Spiritus testimonium reddit spiritui nostro quod sumus filii Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Romans 8:17",
      "text": "Si autem filii, et hæredes: hæredes, quidem Dei, cohæredes autem Christi: si tamen compatimur ut et conglorificemur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Romans 8:18",
      "text": "Existimo enim quod non sunt condignæ passiones hujus temporis ad futuram gloriam, quæ revelabitur in nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Romans 8:19",
      "text": "Nam exspectatio creaturæ revelationem filiorum Dei exspectat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Romans 8:20",
      "text": "Vanitati enim creatura subjecta est non volens, sed propter eum, qui subjecit eam in spe:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Romans 8:21",
      "text": "quia et ipsa creatura liberabitur a servitute corruptionis in libertatem gloriæ filiorum Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Romans 8:22",
      "text": "Scimus enim quod omnis creatura ingemiscit, et parturit usque adhuc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Romans 8:23",
      "text": "Non solum autem illa, sed et nos ipsi primitias spiritus habentes: et ipsi intra nos gemimus adoptionem filiorum Dei exspectantes, redemptionem corporis nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Romans 8:24",
      "text": "Spe enim salvi facti sumus. Spes autem, quæ videtur, non est spes: nam quod videt quis, quid sperat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Romans 8:25",
      "text": "Si autem quod non videmus, speramus: per patientiam exspectamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Romans 8:26",
      "text": "Similiter autem et Spiritus adjuvat infirmitatem nostram: nam quid oremus, sicut oportet, nescimus: sed ipse Spiritus postulat pro nobis gemitibus inenarrabilibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Romans 8:27",
      "text": "Qui autem scrutatur corda, scit quid desideret Spiritus: quia secundum Deum postulat pro sanctis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.28",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Romans 8:28",
      "text": "Scimus autem quoniam diligentibus Deum omnia cooperantur in bonum, iis qui secundum propositum vocati sunt sancti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.29",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Romans 8:29",
      "text": "Nam quos præscivit, et prædestinavit conformes fieri imaginis Filii sui, ut sit ipse primogenitus in multis fratribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.30",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Romans 8:30",
      "text": "Quos autem prædestinavit, hos et vocavit: et quos vocavit, hos et justificavit: quos autem justificavit, illos et glorificavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.31",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Romans 8:31",
      "text": "Quid ergo dicemus ad hæc? si Deus pro nobis, quis contra nos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.32",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Romans 8:32",
      "text": "Qui etiam proprio Filio suo non pepercit, sed pro nobis omnibus tradidit illum: quomodo non etiam cum illo omnia nobis donavit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.33",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Romans 8:33",
      "text": "Quis accusabit adversus electos Dei? Deus qui justificat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.34",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Romans 8:34",
      "text": "quis est qui condemnet? Christus Jesus, qui mortuus est, immo qui et resurrexit, qui est ad dexteram Dei, qui etiam interpellat pro nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.35",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Romans 8:35",
      "text": "Quis ergo nos separabit a caritate Christi? tribulatio? an angustia? an fames? an nuditas? an periculum? an persecutio? an gladius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.36",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Romans 8:36",
      "text": "(Sicut scriptum est: Quia propter te mortificamur tota die: æstimati sumus sicut oves occisionis.)",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.37",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "Romans 8:37",
      "text": "Sed in his omnibus superamus propter eum qui dilexit nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.38",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "Romans 8:38",
      "text": "Certus sum enim quia neque mors, neque vita, neque angeli, neque principatus, neque virtutes, neque instantia, neque futura, neque fortitudo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.8.39",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "Romans 8:39",
      "text": "neque altitudo, neque profundum, neque creatura alia poterit nos separare a caritate Dei, quæ est in Christo Jesu Domino nostro.",
      "paragraphStart": false
    }
  ]
}
