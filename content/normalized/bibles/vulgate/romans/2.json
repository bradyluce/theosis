{
  "chapter": {
    "id": "vulgate:romans.2",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 2,
    "referenceLabel": "Romans 2",
    "summary": "Source text for Romans 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.2.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Romans 2:1",
      "text": "Propter quod inexcusabilis es, o homo omnis qui judicas. In quo enim judicas alterum, teipsum condemnas: eadem enim agis quæ judicas.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.2.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Romans 2:2",
      "text": "Scimus enim quoniam judicium Dei est secundum veritatem in eos qui talia agunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Romans 2:3",
      "text": "Existimas autem hoc, o homo, qui judicas eos qui talia agunt, et facis ea, quia tu effugies judicium Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Romans 2:4",
      "text": "an divitias bonitatis ejus, et patientiæ, et longanimitatis contemnis? ignoras quoniam benignitas Dei ad pœnitentiam te adducit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Romans 2:5",
      "text": "Secundum autem duritiam tuam, et impœnitens cor, thesaurizas tibi iram in die iræ, et revelationis justi judicii Dei,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Romans 2:6",
      "text": "qui reddet unicuique secundum opera ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Romans 2:7",
      "text": "iis quidem qui secundum patientiam boni operis, gloriam, et honorem, et incorruptionem quærunt, vitam æternam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Romans 2:8",
      "text": "iis autem qui sunt ex contentione, et qui non acquiescunt veritati, credunt autem iniquitati, ira et indignatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Romans 2:9",
      "text": "Tribulatio et angustia in omnem animam hominis operantis malum, Judæi primum, et Græci:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Romans 2:10",
      "text": "gloria autem, et honor, et pax omni operanti bonum, Judæo primum, et Græco:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Romans 2:11",
      "text": "non enim est acceptio personarum apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Romans 2:12",
      "text": "Quicumque enim sine lege peccaverunt, sine lege peribunt: et quicumque in lege peccaverunt, per legem judicabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Romans 2:13",
      "text": "Non enim auditores legis justi sunt apud Deum, sed factores legis justificabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Romans 2:14",
      "text": "Cum autem gentes, quæ legem non habent, naturaliter ea, quæ legis sunt, faciunt, ejusmodi legem non habentes, ipsi sibi sunt lex:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Romans 2:15",
      "text": "qui ostendunt opus legis scriptum in cordibus suis, testimonium reddente illis conscientia ipsorum, et inter se invicem cogitationibus accusantibus, aut etiam defendentibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Romans 2:16",
      "text": "in die, cum judicabit Deus occulta hominum, secundum Evangelium meum per Jesum Christum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Romans 2:17",
      "text": "Si autem tu Judæus cognominaris, et requiescis in lege, et gloriaris in Deo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Romans 2:18",
      "text": "et nosti voluntatem ejus, et probas utiliora, instructus per legem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Romans 2:19",
      "text": "confidis teipsum esse ducem cæcorum, lumen eorum qui in tenebris sunt,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Romans 2:20",
      "text": "eruditorem insipientium, magistrum infantium, habentem formam scientiæ, et veritatis in lege.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Romans 2:21",
      "text": "Qui ergo alium doces, teipsum non doces: qui prædicas non furandum, furaris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Romans 2:22",
      "text": "qui dicis non mœchandum, mœcharis: qui abominaris idola, sacrilegium facis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Romans 2:23",
      "text": "qui in lege gloriaris, per prævaricationem legis Deum inhonoras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Romans 2:24",
      "text": "(Nomen enim Dei per vos blasphematur inter gentes, sicut scriptum est.)",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Romans 2:25",
      "text": "Circumcisio quidem prodest, si legem observes: si autem prævaricator legis sis, circumcisio tua præputium facta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Romans 2:26",
      "text": "Si igitur præputium justitias legis custodiat, nonne præputium illius in circumcisionem reputabitur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Romans 2:27",
      "text": "et judicabit id quod ex natura est præputium, legem consummans, te, qui per litteram et circumcisionem prævaricator legis es?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.28",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Romans 2:28",
      "text": "Non enim qui in manifesto, Judæus est: neque quæ in manifesto, in carne, est circumcisio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.2.29",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Romans 2:29",
      "text": "sed qui in abscondito, Judæus est: et circumcisio cordis in spiritu, non littera: cujus laus non ex hominibus, sed ex Deo est.",
      "paragraphStart": false
    }
  ]
}
