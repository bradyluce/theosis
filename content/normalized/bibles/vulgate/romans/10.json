{
  "chapter": {
    "id": "vulgate:romans.10",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 10,
    "referenceLabel": "Romans 10",
    "summary": "Source text for Romans 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.10.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Romans 10:1",
      "text": "Fratres, voluntas quidem cordis mei, et obsecratio ad Deum, fit pro illis in salutem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.10.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Romans 10:2",
      "text": "Testimonium enim perhibeo illis quod æmulationem Dei habent, sed non secundum scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Romans 10:3",
      "text": "Ignorantes enim justitiam Dei, et suam quærentes statuere, justitiæ Dei non sunt subjecti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Romans 10:4",
      "text": "Finis enim legis, Christus, ad justitiam omni credenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Romans 10:5",
      "text": "Moyses enim scripsit, quoniam justitiam, quæ ex lege est, qui fecerit homo, vivet in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Romans 10:6",
      "text": "Quæ autem ex fide est justitia, sic dicit: Ne dixeris in corde tuo: Quis ascendet in cælum? id est, Christum deducere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Romans 10:7",
      "text": "aut, Quis descendet in abyssum? hoc est, Christum a mortuis revocare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Romans 10:8",
      "text": "Sed quid dicit Scriptura? Prope est verbum in ore tuo, et in corde tuo: hoc est verbum fidei, quod prædicamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Romans 10:9",
      "text": "Quia si confitearis in ore tuo Dominum Jesum, et in corde tuo credideris quod Deus illum suscitavit a mortuis, salvus eris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Romans 10:10",
      "text": "Corde enim creditur ad justitiam: ore autem confessio fit ad salutem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Romans 10:11",
      "text": "Dicit enim Scriptura: Omnis qui credit in illum, non confundetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Romans 10:12",
      "text": "Non enim est distinctio Judæi et Græci: nam idem Dominus omnium, dives in omnes qui invocant illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Romans 10:13",
      "text": "Omnis enim quicumque invocaverit nomen Domini, salvus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Romans 10:14",
      "text": "Quomodo ergo invocabunt, in quem non crediderunt? aut quomodo credent ei, quem non audierunt? quomodo autem audient sine prædicante?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Romans 10:15",
      "text": "quomodo vero prædicabunt nisi mittantur? sicut scriptum est: Quam speciosi pedes evangelizantium pacem, evangelizantium bona!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Romans 10:16",
      "text": "Sed non omnes obediunt Evangelio. Isaias enim dicit: Domine, quis credidit auditui nostro?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Romans 10:17",
      "text": "Ergo fides ex auditu, auditus autem per verbum Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Romans 10:18",
      "text": "Sed dico: Numquid non audierunt? Et quidem in omnem terram exivit sonus eorum, et in fines orbis terræ verba eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Romans 10:19",
      "text": "Sed dico: Numquid Israël non cognovit? Primus Moyses dicit: Ego ad æmulationem vos adducam in non gentem: in gentem insipientem, in iram vos mittam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Romans 10:20",
      "text": "Isaias autem audet, et dicit: Inventus sum a non quærentibus me: palam apparui iis qui me non interrogabant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.10.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Romans 10:21",
      "text": "Ad Israël autem dicit: Tota die expandi manus meas ad populum non credentem, et contradicentem.",
      "paragraphStart": false
    }
  ]
}
