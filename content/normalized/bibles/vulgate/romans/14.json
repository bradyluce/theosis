{
  "chapter": {
    "id": "vulgate:romans.14",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 14,
    "referenceLabel": "Romans 14",
    "summary": "Source text for Romans 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.14.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Romans 14:1",
      "text": "Infirmum autem in fide assumite, non in disceptationibus cogitationum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.14.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Romans 14:2",
      "text": "Alius enim credit se manducare omnia: qui autem infirmus est, olus manducet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Romans 14:3",
      "text": "Is qui manducat, non manducantem non spernat: et qui non manducat, manducantem non judicet: Deus enim illum assumpsit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Romans 14:4",
      "text": "Tu quis es, qui judicas alienum servum? domino suo stat, aut cadit: stabit autem: potens est enim Deus statuere illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Romans 14:5",
      "text": "Nam alius judicat diem inter diem: alius autem judicat omnem diem: unusquisque in suo sensu abundet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Romans 14:6",
      "text": "Qui sapit diem, Domino sapit, et qui manducat, Domino manducat: gratias enim agit Deo. Et qui non manducat, Domino non manducat, et gratias agit Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Romans 14:7",
      "text": "Nemo enim nostrum sibi vivit, et nemo sibi moritur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Romans 14:8",
      "text": "Sive enim vivemus, Domino vivimus: sive morimur, Domino morimur. Sive ergo vivimus, sive morimur, Domini sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Romans 14:9",
      "text": "In hoc enim Christus mortuus est, et resurrexit: ut et mortuorum et vivorum dominetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Romans 14:10",
      "text": "Tu autem quid judicas fratrem tuum? aut tu quare spernis fratrem tuum? omnes enim stabimus ante tribunal Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Romans 14:11",
      "text": "Scriptum est enim: Vivo ego, dicit Dominus, quoniam mihi flectetur omne genu: et omnis lingua confitebitur Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Romans 14:12",
      "text": "Itaque unusquisque nostrum pro se rationem reddet Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Romans 14:13",
      "text": "Non ergo amplius invicem judicemus: sed hoc judicate magis, ne ponatis offendiculum fratri, vel scandalum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Romans 14:14",
      "text": "Scio, et confido in Domino Jesu, quia nihil commune per ipsum, nisi ei qui existimat quid commune esset, illi commune est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Romans 14:15",
      "text": "Si enim propter cibum frater tuus contristatur, jam non secundum caritatem ambulas. Noli cibo tuo illum perdere, pro quo Christus mortuus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Romans 14:16",
      "text": "Non ergo blasphemetur bonum nostrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Romans 14:17",
      "text": "Non est enim regnum Dei esca et potus: sed justitia, et pax, et gaudium in Spiritu Sancto:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Romans 14:18",
      "text": "qui enim in hoc servit Christo, placet Deo, et probatus est hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Romans 14:19",
      "text": "Itaque quæ pacis sunt, sectemur: et quæ ædificationis sunt, in invicem custodiamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Romans 14:20",
      "text": "Noli propter escam destruere opus Dei, omnia quidem sunt munda: sed malum est homini, qui per offendiculum manducat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Romans 14:21",
      "text": "Bonum est non manducare carnem, et non bibere vinum, neque in quo frater tuus offenditur, aut scandalizatur, aut infirmatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Romans 14:22",
      "text": "Tu fidem habes? penes temetipsum habe coram Deo. Beatus qui non judicat semetipsum in eo quod probat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.14.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Romans 14:23",
      "text": "Qui autem discernit, si manducaverit, damnatus est: quia non ex fide. Omne autem, quod non est ex fide, peccatum est.",
      "paragraphStart": false
    }
  ]
}
