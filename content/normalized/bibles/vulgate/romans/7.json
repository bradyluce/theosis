{
  "chapter": {
    "id": "vulgate:romans.7",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 7,
    "referenceLabel": "Romans 7",
    "summary": "Source text for Romans 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.7.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Romans 7:1",
      "text": "An ignoratis, fratres (scientibus enim legem loquor), quia lex in homine dominatur quanto tempore vivit?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.7.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Romans 7:2",
      "text": "Nam quæ sub viro est mulier, vivente viro, alligata est legi: si autem mortuus fuerit vir ejus, soluta est a lege viri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Romans 7:3",
      "text": "Igitur, vivente viro, vocabitur adultera si fuerit cum alio viro: si autem mortuus fuerit vir ejus, liberata est a lege viri, ut non sit adultera si fuerit cum alio viro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Romans 7:4",
      "text": "Itaque fratres mei, et vos mortificati estis legi per corpus Christi: ut sitis alterius, qui ex mortuis resurrexit, ut fructificemus Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Romans 7:5",
      "text": "Cum enim essemus in carne, passiones peccatorum, quæ per legem erant, operabantur in membris nostris, ut fructificarent morti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Romans 7:6",
      "text": "Nunc autem soluti sumus a lege mortis, in qua detinebamur, ita ut serviamus in novitate spiritus, et non in vetustate litteræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Romans 7:7",
      "text": "Quid ergo dicemus? lex peccatum est? Absit. Sed peccatum non cognovi, nisi per legem: nam concupiscentiam nesciebam, nisi lex diceret: Non concupisces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Romans 7:8",
      "text": "Occasione autem accepta, peccatum per mandatum operatum est in me omnem concupiscentiam. Sine lege enim peccatum mortuum erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Romans 7:9",
      "text": "Ego autem vivebam sine lege aliquando: sed cum venisset mandatum, peccatum revixit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Romans 7:10",
      "text": "Ego autem mortuus sum: et inventum est mihi mandatum, quod erat ad vitam, hoc esse ad mortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Romans 7:11",
      "text": "Nam peccatum occasione accepta per mandatum, seduxit me, et per illud occidit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Romans 7:12",
      "text": "Itaque lex quidem sancta, et mandatum sanctum, et justum, et bonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Romans 7:13",
      "text": "Quod ergo bonum est, mihi factum est mors? Absit. Sed peccatum, ut appareat peccatum, per bonum operatum est mihi mortem: ut fiat supra modum peccans peccatum per mandatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Romans 7:14",
      "text": "Scimus enim quia lex spiritualis est: ego autem carnalis sum, venundatus sub peccato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Romans 7:15",
      "text": "Quod enim operor, non intelligo: non enim quod volo bonum, hoc ago: sed quod odi malum, illud facio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Romans 7:16",
      "text": "Si autem quod nolo, illud facio: consentio legi, quoniam bona est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Romans 7:17",
      "text": "Nunc autem jam non ego operor illud, sed quod habitat in me peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Romans 7:18",
      "text": "Scio enim quia non habitat in me, hoc est in carne mea, bonum. Nam velle, adjacet mihi: perficere autem bonum, non invenio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Romans 7:19",
      "text": "Non enim quod volo bonum, hoc facio: sed quod nolo malum, hoc ago.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Romans 7:20",
      "text": "Si autem quod nolo, illud facio: jam non ego operor illud, sed quod habitat in me, peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Romans 7:21",
      "text": "Invenio igitur legem, volenti mihi facere bonum, quoniam mihi malum adjacet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Romans 7:22",
      "text": "condelector enim legi Dei secundum interiorem hominem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Romans 7:23",
      "text": "video autem aliam legem in membris meis, repugnantem legi mentis meæ, et captivantem me in lege peccati, quæ est in membris meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Romans 7:24",
      "text": "Infelix ego homo, quis me liberabit de corpore mortis hujus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.7.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Romans 7:25",
      "text": "gratia Dei per Jesum Christum Dominum nostrum. Igitur ego ipse mente servio legi Dei: carne autem, legi peccati.",
      "paragraphStart": false
    }
  ]
}
