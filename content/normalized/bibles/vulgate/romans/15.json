{
  "chapter": {
    "id": "vulgate:romans.15",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 15,
    "referenceLabel": "Romans 15",
    "summary": "Source text for Romans 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.15.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Romans 15:1",
      "text": "Debemus autem nos firmiores imbecillitates infirmorum sustinere, et non nobis placere.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.15.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Romans 15:2",
      "text": "Unusquisque vestrum proximo suo placeat in bonum, ad ædificationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Romans 15:3",
      "text": "Etenim Christus non sibi placuit, sed sicut scriptum est: Improperia improperantium tibi ceciderunt super me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Romans 15:4",
      "text": "Quæcumque enim scripta sunt, ad nostram doctrinam scripta sunt: ut per patientiam, et consolationem Scripturarum, spem habeamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Romans 15:5",
      "text": "Deus autem patientiæ et solatii det vobis idipsum sapere in alterutrum secundum Jesum Christum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Romans 15:6",
      "text": "ut unanimes, uno ore honorificetis Deum et patrem Domini nostri Jesu Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Romans 15:7",
      "text": "Propter quod suscipite invicem, sicut et Christus suscepit vos in honorem Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Romans 15:8",
      "text": "Dico enim Christum Jesum ministrum fuisse circumcisionis propter veritatem Dei, ad confirmandas promissiones patrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Romans 15:9",
      "text": "gentes autem super misericordia honorare Deum, sicut scriptum est: Propterea confitebor tibi in gentibus, Domine, et nomini tuo cantabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Romans 15:10",
      "text": "Et iterum dicit: Lætamini gentes cum plebe ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Romans 15:11",
      "text": "Et iterum: Laudate omnes gentes Dominum: et magnificate eum omnes populi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Romans 15:12",
      "text": "Et rursus Isaias ait: Erit radix Jesse, et qui exsurget regere gentes, in eum gentes sperabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Romans 15:13",
      "text": "Deus autem spei repleat vos omni gaudio, et pace in credendo: ut abundetis in spe, et virtute Spiritus Sancti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Romans 15:14",
      "text": "Certus sum autem fratres mei et ego ipse de vobis, quoniam et ipsi pleni estis dilectione, repleti omni scientia, ita ut possitis alterutrum monere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Romans 15:15",
      "text": "Audacius autem scripsi vobis fratres ex parte, tamquam in memoriam vos reducens: propter gratiam, quæ data est mihi a Deo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Romans 15:16",
      "text": "ut sim minister Christi Jesu in gentibus: sanctificans Evangelium Dei, ut fiat oblatio gentium accepta, et sanctificata in Spiritu Sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Romans 15:17",
      "text": "Habeo igitur gloriam in Christo Jesu ad Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Romans 15:18",
      "text": "Non enim audeo aliquid loqui eorum, quæ per me non efficit Christus in obedientiam gentium, verbo et factis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Romans 15:19",
      "text": "in virtute signorum, et prodigiorum, in virtute Spiritus Sancti: ita ut ab Jerusalem per circuitum usque ad Illyricum repleverim Evangelium Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Romans 15:20",
      "text": "Sic autem prædicavi Evangelium hoc, non ubi nominatus est Christus, ne super alienum fundamentum ædificarem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Romans 15:21",
      "text": "sed sicut scriptum est: Quibus non est annuntiatum de eo, videbunt: et qui non audierunt, intelligent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Romans 15:22",
      "text": "Propter quod et impediebar plurimum venire ad vos, et prohibitus sum usque adhuc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Romans 15:23",
      "text": "Nunc vero ulterius locum non habens in his regionibus, cupiditatem autem habens veniendi ad vos ex multis jam præcedentibus annis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Romans 15:24",
      "text": "cum in Hispaniam proficisci cœpero, spero quod præteriens videam vos, et a vobis deducar illuc, si vobis primum ex parte fruitus fuero.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Romans 15:25",
      "text": "Nunc igitur proficiscar in Jerusalem ministrare sanctis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Romans 15:26",
      "text": "Probaverunt enim Macedonia et Achaia collationem aliquam facere in pauperes sanctorum, qui sunt in Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Romans 15:27",
      "text": "Placuit enim eis: et debitores sunt eorum. Nam si spiritualium eorum participes facti sunt gentiles, debent et in carnalibus ministrare illis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.28",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Romans 15:28",
      "text": "Hoc igitur cum consummavero, et assignavero eis fructum hunc, per vos proficiscar in Hispaniam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.29",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Romans 15:29",
      "text": "Scio autem quoniam veniens ad vos, in abundantia benedictionis Evangelii Christi veniam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.30",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Romans 15:30",
      "text": "Obsecro ergo vos fratres per Dominum nostrum Jesum Christum, et per caritatem Sancti Spiritus, ut adjuvetis me in orationibus vestris pro me ad Deum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.31",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Romans 15:31",
      "text": "ut liberer ab infidelibus, qui sunt in Judæa, et obsequii mei oblatio accepta fiat in Jerusalem sanctis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.32",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Romans 15:32",
      "text": "ut veniam ad vos in gaudio per voluntatem Dei, et refrigerer vobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.15.33",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Romans 15:33",
      "text": "Deus autem pacis sit cum omnibus vobis. Amen.",
      "paragraphStart": false
    }
  ]
}
