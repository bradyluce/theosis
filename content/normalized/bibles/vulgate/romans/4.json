{
  "chapter": {
    "id": "vulgate:romans.4",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 4,
    "referenceLabel": "Romans 4",
    "summary": "Source text for Romans 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.4.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Romans 4:1",
      "text": "Quid ergo dicemus invenisse Abraham patrem nostrum secundum carnem?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.4.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Romans 4:2",
      "text": "Si enim Abraham ex operibus justificatus est, habet gloriam, sed non apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Romans 4:3",
      "text": "Quid enim dicit Scriptura? Credidit Abraham Deo, et reputatam est illi ad justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Romans 4:4",
      "text": "Ei autem qui operatur, merces non imputatur secundum gratiam, sed secundum debitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Romans 4:5",
      "text": "Ei vero qui non operatur, credenti autem in eum, qui justificat impium, reputatur fides ejus ad justitiam secundum propositum gratiæ Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Romans 4:6",
      "text": "Sicut et David dicit beatitudinem hominis, cui Deus accepto fert justitiam sine operibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Romans 4:7",
      "text": "Beati, quorum remissæ sunt iniquitates, et quorum tecta sunt peccata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Romans 4:8",
      "text": "Beatus vir, cui non imputavit Dominus peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Romans 4:9",
      "text": "Beatitudo ergo hæc in circumcisione tantum manet, an etiam in præputio? Dicimus enim quia reputata est Abrahæ fides ad justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Romans 4:10",
      "text": "Quomodo ergo reputata est? in circumcisione, an in præputio? Non in circumcisione, sed in præputio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Romans 4:11",
      "text": "Et signum accepit circumcisionis, signaculum justitiæ fidei, quæ est in præputio: ut sit pater omnium credentium per præputium, ut reputetur et illis ad justitiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Romans 4:12",
      "text": "et sit pater circumcisionis non iis tantum, qui sunt ex circumcisione, sed et iis qui sectantur vestigia fidei, quæ est in præputio patris nostri Abrahæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Romans 4:13",
      "text": "Non enim per legem promissio Abrahæ, aut semini ejus ut hæres esset mundi: sed per justitiam fidei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Romans 4:14",
      "text": "Si enim qui ex lege, hæredes sunt: exinanita est fides, abolita est promissio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Romans 4:15",
      "text": "Lex enim iram operatur. Ubi enim non est lex, nec prævaricatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Romans 4:16",
      "text": "Ideo ex fide, ut secundum gratiam firma sit promissio omni semini, non ei qui ex lege est solum, sed et ei qui ex fide est Abrahæ, qui pater est omnium nostrum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Romans 4:17",
      "text": "(sicut scriptum est: Quia patrem multarum gentium posui te) ante Deum, cui credidit, qui vivificat mortuos, et vocat ea quæ non sunt, tamquam ea quæ sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Romans 4:18",
      "text": "qui contra spem in spem credidit, ut fieret pater multarum gentium secundum quod dictum est ei: Sic erit semen tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Romans 4:19",
      "text": "Et non infirmatus est fide, nec consideravit corpus suum emortuum, cum jam fere centum esset annorum, et emortuam vulvam Saræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Romans 4:20",
      "text": "In repromissione etiam Dei non hæsitavit diffidentia, sed confortatus est fide, dans gloriam Deo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Romans 4:21",
      "text": "plenissime sciens, quia quæcumque promisit, potens est et facere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Romans 4:22",
      "text": "Ideo et reputatum est illi ad justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Romans 4:23",
      "text": "Non est autem scriptum tantum propter ipsum quia reputatum est illi ad justitiam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Romans 4:24",
      "text": "sed et propter nos, quibus reputabitur credentibus in eum, qui suscitavit Jesum Christum Dominum nostrum a mortuis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.4.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Romans 4:25",
      "text": "qui traditus est propter delicta nostra, et resurrexit propter justificationem nostram.",
      "paragraphStart": false
    }
  ]
}
