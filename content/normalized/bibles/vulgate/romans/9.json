{
  "chapter": {
    "id": "vulgate:romans.9",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 9,
    "referenceLabel": "Romans 9",
    "summary": "Source text for Romans 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.9.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Romans 9:1",
      "text": "Veritatem dico in Christo, non mentior: testimonium mihi perhibente conscientia mea in Spiritu Sancto:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.9.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Romans 9:2",
      "text": "quoniam tristitia mihi magna est, et continuus dolor cordi meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Romans 9:3",
      "text": "Optabam enim ego ipse anathema esse a Christo pro fratribus meis, qui sunt cognati mei secundum carnem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Romans 9:4",
      "text": "qui sunt Israëlitæ, quorum adoptio est filiorum, et gloria, et testamentum, et legislatio, et obsequium, et promissa:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Romans 9:5",
      "text": "quorum patres, et ex quibus est Christus secundum carnem, qui est super omnia Deus benedictus in sæcula. Amen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Romans 9:6",
      "text": "Non autem quod exciderit verbum Dei. Non enim omnes qui ex Israël sunt, ii sunt Israëlitæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Romans 9:7",
      "text": "neque qui semen sunt Abrahæ, omnes filii: sed in Isaac vocabitur tibi semen:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Romans 9:8",
      "text": "id est, non qui filii carnis, hi filii Dei: sed qui filii sunt promissionis, æstimantur in semine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Romans 9:9",
      "text": "Promissionis enim verbum hoc est: Secundum hoc tempus veniam: et erit Saræ filius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Romans 9:10",
      "text": "Non solum autem illa: sed et Rebecca ex uno concubitu habens, Isaac patris nostri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Romans 9:11",
      "text": "Cum enim nondum nati fuissent, aut aliquid boni egissent, aut mali (ut secundum electionem propositum Dei maneret),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Romans 9:12",
      "text": "non ex operibus, sed ex vocante dictum est ei quia major serviet minori,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Romans 9:13",
      "text": "sicut scriptum est: Jacob dilexi, Esau autem odio habui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Romans 9:14",
      "text": "Quid ergo dicemus? numquid iniquitas apud Deum? Absit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Romans 9:15",
      "text": "Moysi enim dicit: Miserebor cujus misereor: et misericordiam præstabo cujus miserebor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Romans 9:16",
      "text": "Igitur non volentis, neque currentis, sed miserentis est Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Romans 9:17",
      "text": "Dicit enim Scriptura Pharaoni: Quia in hoc ipsum excitavi te, ut ostendam in te virtutem meam: et ut annuntietur nomen meum in universa terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Romans 9:18",
      "text": "Ergo cujus vult miseretur, et quem vult indurat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Romans 9:19",
      "text": "Dicis itaque mihi: Quid adhuc queritur? voluntati enim ejus quis resistit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Romans 9:20",
      "text": "O homo, tu quis es, qui respondeas Deo? numquid dicit figmentum ei qui se finxit: Quid me fecisti sic?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Romans 9:21",
      "text": "an non habet potestatem figulus luti ex eadem massa facere aliud quidem vas in honorem, aliud vero in contumeliam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Romans 9:22",
      "text": "Quod si Deus volens ostendere iram, et notum facere potentiam suam, sustinuit in multa patientia vasa iræ, apta in interitum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Romans 9:23",
      "text": "ut ostenderet divitias gloriæ suæ in vasa misericordiæ, quæ præparavit in gloriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Romans 9:24",
      "text": "Quos et vocavit nos non solum ex Judæis, sed etiam in gentibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Romans 9:25",
      "text": "sicut in Osee dicit: Vocabo non plebem meam, plebem meam: et non dilectam, dilectam: et non misericordiam consecutam, misericordiam consecutam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Romans 9:26",
      "text": "Et erit: in loco, ubi dictum est eis: Non plebs mea vos: ibi vocabuntur filii Dei vivi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Romans 9:27",
      "text": "Isaias autem clamat pro Israël: Si fuerit numerus filiorum Israël tamquam arena maris, reliquiæ salvæ fient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.28",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Romans 9:28",
      "text": "Verbum enim consummans, et abbrevians in æquitate: quia verbum breviatum faciet Dominus super terram:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.29",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Romans 9:29",
      "text": "et sicut prædixit Isaias: Nisi Dominus Sabaoth reliquisset nobis semen, sicut Sodoma facti essemus, et sicut Gomorrha similes fuissemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.30",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Romans 9:30",
      "text": "Quid ergo dicemus? Quod gentes, quæ non sectabantur justitiam, apprehenderunt justitiam: justitiam autem, quæ ex fide est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.31",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Romans 9:31",
      "text": "Israël vero sectando legem justitiæ, in legem justitiæ non pervenit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.32",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Romans 9:32",
      "text": "Quare? Quia non ex fide, sed quasi ex operibus: offenderunt enim in lapidem offensionis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.9.33",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Romans 9:33",
      "text": "sicut scriptum est: Ecce pono in Sion lapidem offensionis, et petram scandali: et omnis qui credit in eum, non confundetur.",
      "paragraphStart": false
    }
  ]
}
