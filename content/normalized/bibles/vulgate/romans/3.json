{
  "chapter": {
    "id": "vulgate:romans.3",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 3,
    "referenceLabel": "Romans 3",
    "summary": "Source text for Romans 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.3.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Romans 3:1",
      "text": "Quid ergo amplius Judæo est? aut quæ utilitas circumcisionis?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.3.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Romans 3:2",
      "text": "Multum per omnem modum. Primum quidem quia credita sunt illis eloquia Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Romans 3:3",
      "text": "Quid enim si quidam illorum non crediderunt? numquid incredulitas illorum fidem Dei evacuabit? Absit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Romans 3:4",
      "text": "Est autem Deus verax: omnis autem homo mendax, sicut scriptum est: Ut justificeris in sermonibus tuis: et vincas cum judicaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Romans 3:5",
      "text": "Si autem iniquitas nostra justitiam Dei commendat, quid dicemus? Numquid iniquus est Deus, qui infert iram?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Romans 3:6",
      "text": "secundum hominem dico. Absit. Alioquin quomodo judicabit Deus hunc mundum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Romans 3:7",
      "text": "Si enim veritas Dei in meo mendacio abundavit in gloriam ipsius: quid adhuc et ego tamquam peccator judicor?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Romans 3:8",
      "text": "et non (sicut blasphemamur, et sicut aiunt quidam nos dicere) faciamus mala ut veniant bona: quorum damnatio justa est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Romans 3:9",
      "text": "Quid ergo? præcellimus eos? Nequaquam. Causati enim sumus Judæos et Græcos omnes sub peccato esse,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Romans 3:10",
      "text": "sicut scriptum est: Quia non est justus quisquam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Romans 3:11",
      "text": "non est intelligens, non est requirens Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Romans 3:12",
      "text": "Omnes declinaverunt, simul inutiles facti sunt: non est qui faciat bonum, non est usque ad unum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Romans 3:13",
      "text": "Sepulchrum patens est guttur eorum, linguis suis dolose agebant: venenum aspidum sub labiis eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Romans 3:14",
      "text": "quorum os maledictione, et amaritudine plenum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Romans 3:15",
      "text": "veloces pedes eorum ad effundendum sanguinem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Romans 3:16",
      "text": "contritio et infelicitas in viis eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Romans 3:17",
      "text": "et viam pacis non cognoverunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Romans 3:18",
      "text": "non est timor Dei ante oculos eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Romans 3:19",
      "text": "Scimus autem quoniam quæcumque lex loquitur, iis, qui in lege sunt, loquitur: ut omne os obstruatur, et subditus fiat omnis mundus Deo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Romans 3:20",
      "text": "quia ex operibus legis non justificabitur omnis caro coram illo. Per legem enim cognitio peccati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Romans 3:21",
      "text": "Nunc autem sine lege justitia Dei manifestata est: testificata a lege et prophetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Romans 3:22",
      "text": "Justitia autem Dei per fidem Jesu Christi in omnes et super omnes qui credunt in eum: non enim est distinctio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Romans 3:23",
      "text": "omnes enim peccaverunt, et egent gloria Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.24",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Romans 3:24",
      "text": "Justificati gratis per gratiam ipsius, per redemptionem quæ est in Christo Jesu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.25",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Romans 3:25",
      "text": "quem proposuit Deus propitiationem per fidem in sanguine ipsius, ad ostensionem justitiæ suæ propter remissionem præcedentium delictorum",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.26",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Romans 3:26",
      "text": "in sustentatione Dei, ad ostensionem justitiæ ejus in hoc tempore: ut sit ipse justus, et justificans eum, qui est ex fide Jesu Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.27",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Romans 3:27",
      "text": "Ubi est ergo gloriatio tua? Exclusa est. Per quam legem? Factorum? Non: sed per legem fidei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.28",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Romans 3:28",
      "text": "Arbitramur enim justificari hominem per fidem sine operibus legis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.29",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Romans 3:29",
      "text": "An Judæorum Deus tantum? nonne et gentium? Immo et gentium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.30",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Romans 3:30",
      "text": "quoniam quidem unus est Deus, qui justificat circumcisionem ex fide, et præputium per fidem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.3.31",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Romans 3:31",
      "text": "Legem ergo destruimus per fidem? Absit: sed legem statuimus.",
      "paragraphStart": false
    }
  ]
}
