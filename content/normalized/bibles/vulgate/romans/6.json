{
  "chapter": {
    "id": "vulgate:romans.6",
    "translationId": "vulgate",
    "bookSlug": "romans",
    "chapterNumber": 6,
    "referenceLabel": "Romans 6",
    "summary": "Source text for Romans 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:romans.6.1",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Romans 6:1",
      "text": "Quid ergo dicemus? permanebimus in peccato ut gratia abundet?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:romans.6.2",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Romans 6:2",
      "text": "Absit. Qui enim mortui sumus peccato, quomodo adhuc vivemus in illo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.3",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Romans 6:3",
      "text": "an ignoratis quia quicumque baptizati sumus in Christo Jesu, in morte ipsius baptizati sumus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.4",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Romans 6:4",
      "text": "Consepulti enim sumus cum illo per baptismum in mortem: ut quomodo Christus surrexit a mortuis per gloriam Patris, ita et nos in novitate vitæ ambulemus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.5",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Romans 6:5",
      "text": "Si enim complantati facti sumus similitudini mortis ejus: simul et resurrectionis erimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.6",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Romans 6:6",
      "text": "Hoc scientes, quia vetus homo noster simul crucifixus est, ut destruatur corpus peccati, et ultra non serviamus peccato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.7",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Romans 6:7",
      "text": "Qui enim mortuus est, justificatus est a peccato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.8",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Romans 6:8",
      "text": "Si autem mortui sumus cum Christo, credimus quia simul etiam vivemus cum Christo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.9",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Romans 6:9",
      "text": "scientes quod Christus resurgens ex mortuis jam non moritur: mors illi ultra non dominabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.10",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Romans 6:10",
      "text": "Quod enim mortuus est peccato, mortuus est semel: quod autem vivit, vivit Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.11",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Romans 6:11",
      "text": "Ita et vos existimate vos mortuos quidem esse peccato, viventes autem Deo, in Christo Jesu Domino nostro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.12",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Romans 6:12",
      "text": "Non ergo regnet peccatum in vestro mortali corpore ut obediatis concupiscentiis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.13",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Romans 6:13",
      "text": "Sed neque exhibeatis membra vestra arma iniquitatis peccato: sed exhibete vos Deo, tamquam ex mortuis viventes: et membra vestra arma justitiæ Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.14",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Romans 6:14",
      "text": "Peccatum enim vobis non dominabitur: non enim sub lege estis, sed sub gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.15",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Romans 6:15",
      "text": "Quid ergo? peccabimus, quoniam non sumus sub lege, sed sub gratia? Absit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.16",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Romans 6:16",
      "text": "Nescitis quoniam cui exhibetis vos servos ad obediendum, servi estis ejus, cui obeditis, sive peccati ad mortem, sive obeditionis ad justitiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.17",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Romans 6:17",
      "text": "Gratias autem Deo quod fuistis servi peccati, obedistis autem ex corde in eam formam doctrinæ, in quam traditi estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.18",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Romans 6:18",
      "text": "Liberati autem a peccato, servi facti estis justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.19",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Romans 6:19",
      "text": "Humanum dico, propter infirmitatem carnis vestræ: sicut enim exhibuistis membra vestra servire immunditiæ, et iniquitati ad iniquitatem, ita nunc exhibete membra vestra servire justitiæ in sanctificationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.20",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Romans 6:20",
      "text": "Cum enim servi essetis peccati, liberi fuistis justitiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.21",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Romans 6:21",
      "text": "Quem ergo fructum habuistis tunc in illis, in quibus nunc erubescitis? nam finis illorum mors est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.22",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Romans 6:22",
      "text": "Nunc vero liberati a peccato, servi autem facti Deo, habetis fructum vestrum in sanctificationem, finem vero vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:romans.6.23",
      "translationId": "vulgate",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Romans 6:23",
      "text": "Stipendia enim peccati, mors. Gratia autem Dei, vita æterna, in Christo Jesu Domino nostro.",
      "paragraphStart": false
    }
  ]
}
