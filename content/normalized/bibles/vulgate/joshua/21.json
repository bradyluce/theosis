{
  "chapter": {
    "id": "vulgate:joshua.21",
    "translationId": "vulgate",
    "bookSlug": "joshua",
    "chapterNumber": 21,
    "referenceLabel": "Joshua 21",
    "summary": "Source text for Joshua 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:joshua.21.1",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Joshua 21:1",
      "text": "Accesseruntque principes familiarum Levi ad Eleazarum sacerdotem, et Josue filium Nun, et ad duces cognationum per singulas tribus filiorum Israël:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:joshua.21.2",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Joshua 21:2",
      "text": "locutique sunt ad eos in Silo terræ Chanaan, atque dixerunt: Dominus præcepit per manum Moysi, ut darentur nobis urbes ad habitandum, et suburbana earum ad alenda jumenta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.3",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Joshua 21:3",
      "text": "Dederuntque filii Israël de possessionibus suis juxta imperium Domini, civitates et suburbana earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.4",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Joshua 21:4",
      "text": "Egressaque est sors in familiam Caath filiorum Aaron sacerdotis, de tribubus Juda, et Simeon, et Benjamin, civitates tredecim:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.5",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Joshua 21:5",
      "text": "et reliquis filiorum Caath, id est Levitis, qui superfuerant, de tribubus Ephraim, et Dan, et dimidia tribu Manasse, civitates decem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.6",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Joshua 21:6",
      "text": "Porro filii Gerson egressa est sors, ut acciperent de tribubus Issachar et Aser et Nephthali, dimidiaque tribu Manasse in Basan, civitates numero tredecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.7",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Joshua 21:7",
      "text": "Et filiis Merari per cognationes suas de tribubus Ruben et Gad et Zabulon urbes duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.8",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Joshua 21:8",
      "text": "Dederuntque filii Israël Levitis civitates et suburbana earum, sicut præcepit Dominus per manum Moysi, singulis sorte tribuentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.9",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Joshua 21:9",
      "text": "De tribubus filiorum Juda et Simeon dedit Josue civitates, quarum ista sunt nomina,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.10",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Joshua 21:10",
      "text": "filiis Aaron per familias Caath Levitici generis (prima enim sors illis egressa est),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.11",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Joshua 21:11",
      "text": "Cariatharbe patris Enac, quæ vocatur Hebron, in monte Juda, et suburbana ejus per circuitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.12",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Joshua 21:12",
      "text": "Agros vero et villas ejus dederat Caleb filio Jephone ad possidendum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.13",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Joshua 21:13",
      "text": "Dedit ergo filiis Aaron sacerdotis Hebron confugii civitatem, ac suburbana ejus: et Lobnam cum suburbanis suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.14",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Joshua 21:14",
      "text": "et Jether, et Esthemo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.15",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Joshua 21:15",
      "text": "et Holon, et Dabir,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.16",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Joshua 21:16",
      "text": "et Ain, et Jeta, et Bethsames, cum suburbanis suis: civitates novem de tribubus, ut dictum est, duabus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.17",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Joshua 21:17",
      "text": "De tribu autem filiorum Benjamin, Gabaon, et Gabæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.18",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Joshua 21:18",
      "text": "et Anathoth et Almon, cum suburbanis suis: civitates quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.19",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Joshua 21:19",
      "text": "Omnes simul civitates filiorum Aaron sacerdotis, tredecim, cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.20",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Joshua 21:20",
      "text": "Reliquis vero per familias filiorum Caath Levitici generis, hæc est data possessio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.21",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Joshua 21:21",
      "text": "De tribu Ephraim urbes confugii, Sichem cum suburbanis suis in monte Ephraim, et Gazer",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.22",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Joshua 21:22",
      "text": "et Cibsaim et Beth-horon, cum suburbanis suis, civitates quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.23",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Joshua 21:23",
      "text": "De tribu quoque Dan, Eltheco et Gabathon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.24",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Joshua 21:24",
      "text": "et Ajalon et Gethremmon, cum suburbanis suis, civitates quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.25",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Joshua 21:25",
      "text": "Porro de dimidia tribu Manasse, Thanach et Gethremmon, cum suburbanis suis, civitates duæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.26",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Joshua 21:26",
      "text": "Omnes civitates decem, et suburbana earum, datæ sunt filiis Caath inferioris gradus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.27",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Joshua 21:27",
      "text": "Filiis quoque Gerson Levitici generis dedit de dimidia tribu Manasse confugii civitates, Gaulon in Basan, et Bosram, cum suburbanis suis, civitates duas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.28",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Joshua 21:28",
      "text": "Porro de tribu Issachar, Cesion, et Dabereth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.29",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Joshua 21:29",
      "text": "et Jaramoth, et Engannim, cum suburbanis suis, civitates quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.30",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Joshua 21:30",
      "text": "De tribu autem Aser, Masal et Abdon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.31",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Joshua 21:31",
      "text": "et Helcath, et Rohob, cum suburbanis suis, civitates quatuor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.32",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Joshua 21:32",
      "text": "De tribu quoque Nephthali civitates confugii, Cedes in Galilæa, et Hammoth Dor, et Carthan, cum suburbanis suis, civitates tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.33",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Joshua 21:33",
      "text": "Omnes urbes familiarum Gerson, tredecim, cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.34",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Joshua 21:34",
      "text": "Filiis autem Merari Levitis inferioris gradus per familias suas data est de tribu Zabulon, Jecnam, et Cartha",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.35",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 35,
      "referenceLabel": "Joshua 21:35",
      "text": "et Damna et Naalol, civitates quatuor cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.36",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 36,
      "referenceLabel": "Joshua 21:36",
      "text": "De tribu Ruben ultra Jordanem contra Jericho civitates refugii, Bosor in solitudine, Misor et Jaser et Jethson et Mephaath, civitates quatuor cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.37",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 37,
      "referenceLabel": "Joshua 21:37",
      "text": "De tribu Gad civitates confugii, Ramoth in Galaad, et Manaim et Hesebon et Jazer, civitates quatuor cum suburbanis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.38",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 38,
      "referenceLabel": "Joshua 21:38",
      "text": "Omnes urbes filiorum Merari per familias et cognationes suas, duodecim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.39",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 39,
      "referenceLabel": "Joshua 21:39",
      "text": "Itaque civitates universæ Levitarum in medio possessionis filiorum Israël fuerunt quadraginta octo",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.40",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 40,
      "referenceLabel": "Joshua 21:40",
      "text": "cum suburbanis suis, singulæ per familias distributæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.41",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 41,
      "referenceLabel": "Joshua 21:41",
      "text": "Deditque Dominus Deus Israëli omnem terram, quam traditurum se patribus eorum juraverat: et possederunt illam, atque habitaverunt in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.42",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 42,
      "referenceLabel": "Joshua 21:42",
      "text": "Dataque est ab eo pax in omnes per circuitum nationes: nullusque eis hostium resistere ausus est, sed cuncti in eorum ditionem redacti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.21.43",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 21,
      "verseNumber": 43,
      "referenceLabel": "Joshua 21:43",
      "text": "Ne unum quidem verbum, quod illis præstiturum se esse promiserat, irritum fuit, sed rebus expleta sunt omnia.",
      "paragraphStart": false
    }
  ]
}
