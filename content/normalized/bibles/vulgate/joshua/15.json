{
  "chapter": {
    "id": "vulgate:joshua.15",
    "translationId": "vulgate",
    "bookSlug": "joshua",
    "chapterNumber": 15,
    "referenceLabel": "Joshua 15",
    "summary": "Source text for Joshua 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:joshua.15.1",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Joshua 15:1",
      "text": "Igitur sors filiorum Judæ per cognationes suas ista fuit: a termino Edom, desertum Sin, contra meridiem, et usque ad extremam partem australis plagæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:joshua.15.2",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Joshua 15:2",
      "text": "Initium ejus a summitate maris salsissimi, et a lingua ejus, quæ respicit meridiem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.3",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Joshua 15:3",
      "text": "Egrediturque contra ascensum Scorpionis, et pertransit in Sina: ascenditque in Cadesbarne, et pervenit in Esron, ascendens ad Addar, et circuiens Carcaa,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.4",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Joshua 15:4",
      "text": "atque inde pertransiens in Asemona, et perveniens ad torrentem Ægypti: eruntque termini ejus mare magnum. Hic erit finis meridianæ plagæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.5",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Joshua 15:5",
      "text": "Ab oriente vero erit initium, mare salsissimum usque ad extrema Jordanis: et ea quæ respiciunt ad aquilonem, a lingua maris usque ad eumdem Jordanis fluvium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.6",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Joshua 15:6",
      "text": "Ascenditque terminus in Beth Hagla, et transit ab aquilone in Beth Araba, ascendens ad lapidem Boën filii Ruben:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.7",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Joshua 15:7",
      "text": "et tendens usque ad terminos Debera de valle Achor, contra aquilonem respiciens Galgala, quæ est ex adverso ascensionis Adommim, ab australi parte torrentis: transitque aquas, quæ vocantur fons solis: et erunt exitus ejus ad fontem Rogel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.8",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Joshua 15:8",
      "text": "Ascenditque per convallem filii Ennom ex latere Jebusæi ad meridiem, hæc est Jerusalem: et inde se erigens ad verticem montis, qui est contra Geennom ad occidentem in summitate vallis Raphaim contra aquilonem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.9",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Joshua 15:9",
      "text": "pertransitque a vertice montis usque ad fontem aquæ Nephtoa: et pervenit usque ad vicos montis Ephron: inclinaturque in Baala, quæ est Cariathiarim, id est, urbs silvarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.10",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Joshua 15:10",
      "text": "Et circuit de Baala contra occidentem, usque ad montem Seir: transitque juxta latus montis Jarim ad aquilonem in Cheslon: et descendit in Bethsames, transitque in Thamna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.11",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Joshua 15:11",
      "text": "Et pervenit contra aquilonem partis Accaron ex latere: inclinaturque Sechrona, et transit montem Baala: pervenitque in Jebneel, et magni maris contra occidentem fine concluditur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.12",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Joshua 15:12",
      "text": "Hi sunt termini filiorum Juda per circuitum in cognationibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.13",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Joshua 15:13",
      "text": "Caleb vero filio Jephone dedit partem in medio filiorum Juda, sicut præceperat ei Dominus: Cariath Arbe patris Enac, ipsa est Hebron.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.14",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Joshua 15:14",
      "text": "Delevitque ex ea Caleb tres filios Enac, Sesai et Ahiman et Tholmai de stirpe Enac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.15",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Joshua 15:15",
      "text": "Atque inde conscendens venit ad habitatores Dabir, quæ prius vocabatur Cariath Sepher, id est, civitas litterarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.16",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Joshua 15:16",
      "text": "Dixitque Caleb: Qui percusserit Cariath Sepher, et ceperit eam, dabo ei Axam filiam meam uxorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.17",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Joshua 15:17",
      "text": "Cepitque eam Othoniel filius Cenez frater Caleb junior: deditque ei Axam filiam suam uxorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.18",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Joshua 15:18",
      "text": "Quæ, cum pergerent simul, suasa est a viro suo ut peteret a patre suo agrum. Suspiravitque ut sedebat in asino: cui Caleb: Quid habes? inquit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.19",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Joshua 15:19",
      "text": "At illa respondit: Da mihi benedictionem: terram australem et arentem dedisti mihi; junge et irriguam. Dedit itaque ei Caleb irriguum superius et inferius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.20",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Joshua 15:20",
      "text": "Hæc est possessio tribus filiorum Juda per cognationes suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.21",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Joshua 15:21",
      "text": "Erantque civitates ab extremis partibus filiorum Juda juxta terminos Edom a meridie: Cabseel et Eder et Jagur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.22",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Joshua 15:22",
      "text": "et Cyna et Dimona et Adada,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.23",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Joshua 15:23",
      "text": "et Cades et Asor et Jethnam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.24",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Joshua 15:24",
      "text": "Ziph et Telem et Baloth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.25",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Joshua 15:25",
      "text": "Asor nova et Carioth, Hesron, hæc est Asor;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.26",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Joshua 15:26",
      "text": "Amam, Sama, et Molada,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.27",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Joshua 15:27",
      "text": "et Asergadda et Hassemon et Bethphelet,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.28",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Joshua 15:28",
      "text": "et Hasersual et Bersabee et Baziothia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.29",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Joshua 15:29",
      "text": "et Baala et Jim et Esem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.30",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Joshua 15:30",
      "text": "et Eltholad et Cesil et Harma,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.31",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Joshua 15:31",
      "text": "et Siceleg et Medemena et Sensenna,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.32",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Joshua 15:32",
      "text": "Lebaoth et Selim et Aën et Remon. Omnes civitates viginti novem, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.33",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Joshua 15:33",
      "text": "In campestribus vero: Estaol et Sarea et Asena,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.34",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Joshua 15:34",
      "text": "et Zanoë et Ængannim et Taphua et Enaim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.35",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Joshua 15:35",
      "text": "et Jerimoth et Adullam, Socho et Azeca,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.36",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Joshua 15:36",
      "text": "et Saraim et Adithaim et Gedera et Gederothaim: urbes quatuordecim, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.37",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Joshua 15:37",
      "text": "Sanan et Hadassa et Magdalgad,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.38",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Joshua 15:38",
      "text": "Delean et Masepha et Jecthel,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.39",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Joshua 15:39",
      "text": "Lachis et Bascath et Eglon,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.40",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "Joshua 15:40",
      "text": "Chebbon et Leheman et Cethlis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.41",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 41,
      "referenceLabel": "Joshua 15:41",
      "text": "et Gideroth et Bethdagon et Naama et Maceda: civitates sedecim, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.42",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 42,
      "referenceLabel": "Joshua 15:42",
      "text": "Labana et Ether et Asan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.43",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 43,
      "referenceLabel": "Joshua 15:43",
      "text": "Jephtha et Esna et Nesib,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.44",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 44,
      "referenceLabel": "Joshua 15:44",
      "text": "et Ceila et Achzib et Maresa: civitates novem, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.45",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 45,
      "referenceLabel": "Joshua 15:45",
      "text": "Accaron cum vicis et villulis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.46",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 46,
      "referenceLabel": "Joshua 15:46",
      "text": "Ab Accaron usque ad mare: omnia quæ vergunt ad Azotum et viculos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.47",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 47,
      "referenceLabel": "Joshua 15:47",
      "text": "Azotus cum vicis et villulis suis. Gaza cum vicis et villulis suis, usque ad torrentem Ægypti, et mare magnum terminus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.48",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 48,
      "referenceLabel": "Joshua 15:48",
      "text": "Et in monte: Samir et Jether et Socoth",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.49",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 49,
      "referenceLabel": "Joshua 15:49",
      "text": "et Danna et Cariathsenna, hæc est Dabir:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.50",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 50,
      "referenceLabel": "Joshua 15:50",
      "text": "Anab et Istemo et Anim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.51",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 51,
      "referenceLabel": "Joshua 15:51",
      "text": "Gosen et Olon et Gilo: civitates undecim et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.52",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 52,
      "referenceLabel": "Joshua 15:52",
      "text": "Arab et Ruma et Esaan,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.53",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 53,
      "referenceLabel": "Joshua 15:53",
      "text": "et Janum et Beththaphua et Apheca,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.54",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 54,
      "referenceLabel": "Joshua 15:54",
      "text": "Athmatha, et Cariath Arbe, hæc est Hebron, et Sior: civitates novem, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.55",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 55,
      "referenceLabel": "Joshua 15:55",
      "text": "Maon et Carmel et Ziph et Jota,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.56",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 56,
      "referenceLabel": "Joshua 15:56",
      "text": "Jezraël et Jucadam et Zanoë,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.57",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 57,
      "referenceLabel": "Joshua 15:57",
      "text": "Accain, Gabaa et Thamna: civitates decem et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.58",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 58,
      "referenceLabel": "Joshua 15:58",
      "text": "Halhul, et Besur, et Gedor,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.59",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 59,
      "referenceLabel": "Joshua 15:59",
      "text": "Mareth, et Bethanoth, et Eltecon: civitates sex et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.60",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 60,
      "referenceLabel": "Joshua 15:60",
      "text": "Cariathbaal, hæc est Cariathiarim urbs silvarum, et Arebba: civitates duæ, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.61",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 61,
      "referenceLabel": "Joshua 15:61",
      "text": "In deserto Betharaba, Meddin, et Sachacha,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.62",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 62,
      "referenceLabel": "Joshua 15:62",
      "text": "et Nebsan, et civitas salis, et Engaddi: civitates sex, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.15.63",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 15,
      "verseNumber": 63,
      "referenceLabel": "Joshua 15:63",
      "text": "Jebusæum autem habitatorem Jerusalem non potuerunt filii Juda delere: habitavitque Jebusæus cum filiis Juda in Jerusalem usque in præsentem diem.",
      "paragraphStart": false
    }
  ]
}
