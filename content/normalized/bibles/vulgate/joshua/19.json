{
  "chapter": {
    "id": "vulgate:joshua.19",
    "translationId": "vulgate",
    "bookSlug": "joshua",
    "chapterNumber": 19,
    "referenceLabel": "Joshua 19",
    "summary": "Source text for Joshua 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:joshua.19.1",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Joshua 19:1",
      "text": "Et egressa est sors secunda filiorum Simeon per cognationes suas: fuitque hæreditas",
      "paragraphStart": true
    },
    {
      "id": "vulgate:joshua.19.2",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Joshua 19:2",
      "text": "eorum in medio possessionis filiorum Juda: Bersabee et Sabee et Molada",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.3",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Joshua 19:3",
      "text": "et Hasersual, Bala et Asem",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.4",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Joshua 19:4",
      "text": "et Eltholad, Bethul et Harma",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.5",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Joshua 19:5",
      "text": "et Siceleg et Bethmarchaboth et Hasersusa",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.6",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Joshua 19:6",
      "text": "et Bethlebaoth et Sarohen: civitates tredecim, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.7",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Joshua 19:7",
      "text": "Ain et Remmon et Athar et Asan: civitates quatuor, et villæ earum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.8",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Joshua 19:8",
      "text": "omnes viculi per circuitum urbium istarum usque ad Baalath Beer Ramath contra australem plagam. Hæc est hæreditas filiorum Simeon juxta cognationes suas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.9",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Joshua 19:9",
      "text": "in possessione et funiculo filiorum Juda: quia major erat, et idcirco filii Simeon possederunt in medio hæreditatis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.10",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Joshua 19:10",
      "text": "Ceciditque sors tertia filiorum Zabulon per cognationes suas: factus est terminus possessionis eorum usque Sarid.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.11",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Joshua 19:11",
      "text": "Ascenditque de mari et Merala, et pervenit in Debbaseth, usque ad torrentem qui est contra Jeconam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.12",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Joshua 19:12",
      "text": "Et revertitur de Sared contra orientem in fines Ceseleththabor: et egreditur ad Dabereth, ascenditque contra Japhie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.13",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Joshua 19:13",
      "text": "Et inde pertransit usque ad orientalem plagam Gethepher et Thacasin: et egreditur in Remmon, Amthar et Noa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.14",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Joshua 19:14",
      "text": "Et circuit ad aquilonem Hanathon: suntque egressus ejus vallis Jephthaël,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.15",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Joshua 19:15",
      "text": "et Cateth et Naalol et Semeron et Jerala et Bethlehem: civitates duodecim, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.16",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Joshua 19:16",
      "text": "Hæc est hæreditas tribus filiorum Zabulon per cognationes suas, urbes et viculi earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.17",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Joshua 19:17",
      "text": "Issachar egressa est sors quarta per cognationes suas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.18",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Joshua 19:18",
      "text": "fuitque ejus hæreditas Jezraël et Casaloth et Sunem",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.19",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Joshua 19:19",
      "text": "et Hapharaim et Seon, et Anaharath",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.20",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Joshua 19:20",
      "text": "et Rabboth et Cesion, Abes,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.21",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Joshua 19:21",
      "text": "et Rameth, et Engannim, et Enhadda et Bethpheses.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.22",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Joshua 19:22",
      "text": "Et pervenit terminus ejus usque Thabor et Sehesima et Bethsames, eruntque exitus ejus Jordanis: civitates sedecim, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.23",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Joshua 19:23",
      "text": "Hæc est possessio filiorum Issachar per cognationes suas, urbes et viculi earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.24",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Joshua 19:24",
      "text": "Ceciditque sors quinta tribui filiorum Aser per cognationes suas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.25",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Joshua 19:25",
      "text": "fuitque terminus eorum Halcath et Chali et Beten et Axaph",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.26",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Joshua 19:26",
      "text": "et Elmelech et Amaad et Messal: et pervenit usque ad Carmelum maris et Sihor et Labanath,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.27",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Joshua 19:27",
      "text": "ac revertitur contra orientem Bethdagon: et pertransit usque Zabulon et vallem Jephthaël contra aquilonem in Bethemec et Nehiel. Egrediturque ad lævam Cabul,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.28",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Joshua 19:28",
      "text": "et Abran et Rohob et Hamon et Cana, usque ad Sidonem magnam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.29",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Joshua 19:29",
      "text": "Revertiturque in Horma usque ad civitatem munitissimam Tyrum, et usque Hosa: eruntque exitus ejus in mare de funiculo Achziba:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.30",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Joshua 19:30",
      "text": "et Amma et Aphec et Rohob: civitates viginti duæ, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.31",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Joshua 19:31",
      "text": "Hæc est possessio filiorum Aser per cognationes suas, urbesque et viculi earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.32",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Joshua 19:32",
      "text": "Filiorum Nephthali sexta sors cecidit per familias suas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.33",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Joshua 19:33",
      "text": "et cœpit terminus de Heleph et Elon in Saananim, et Adami, quæ est Neceb, et Jebnaël usque Lecum: et egressus eorum usque ad Jordanem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.34",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Joshua 19:34",
      "text": "revertiturque terminus contra occidentem in Azanotthabor, atque inde egreditur in Hucuca, et pertransit in Zabulon contra meridiem, et in Aser contra occidentem, et in Juda ad Jordanem contra ortum solis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.35",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 35,
      "referenceLabel": "Joshua 19:35",
      "text": "civitates munitissimæ, Assedim, Ser, et Emath, et Reccath et Cenereth,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.36",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 36,
      "referenceLabel": "Joshua 19:36",
      "text": "et Edema et Arama, Asor",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.37",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 37,
      "referenceLabel": "Joshua 19:37",
      "text": "et Cedes et Edrai, Enhasor,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.38",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 38,
      "referenceLabel": "Joshua 19:38",
      "text": "et Jeron et Magdalel, Horem et Bethanath et Bethsames: civitates decem et novem, et villæ earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.39",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 39,
      "referenceLabel": "Joshua 19:39",
      "text": "Hæc est possessio tribus filiorum Nephthali per cognationes suas, urbes et viculi earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.40",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 40,
      "referenceLabel": "Joshua 19:40",
      "text": "Tribui filiorum Dan per familias suas egressa est sors septima:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.41",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 41,
      "referenceLabel": "Joshua 19:41",
      "text": "et fuit terminus possessionis ejus Sara et Esthaol, et Hirsemes, id est, civitas solis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.42",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 42,
      "referenceLabel": "Joshua 19:42",
      "text": "Selebin et Ajalon et Jethela,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.43",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 43,
      "referenceLabel": "Joshua 19:43",
      "text": "Elon et Themna et Acron,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.44",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 44,
      "referenceLabel": "Joshua 19:44",
      "text": "Elthece, Gebbethon et Balaath,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.45",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 45,
      "referenceLabel": "Joshua 19:45",
      "text": "et Jud et Bane et Barach et Gethremmon:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.46",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 46,
      "referenceLabel": "Joshua 19:46",
      "text": "et Mejarcon et Arecon, cum termino qui respicit Joppen,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.47",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 47,
      "referenceLabel": "Joshua 19:47",
      "text": "et ipso fine concluditur. Ascenderuntque filii Dan, et pugnaverunt contra Lesem, ceperuntque eam: et percusserunt eam in ore gladii, et possederunt, et habitaverunt in ea, vocantes nomen ejus Lesem Dan, ex nomine Dan patris sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.48",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 48,
      "referenceLabel": "Joshua 19:48",
      "text": "Hæc est possessio tribus filiorum Dan, per cognationes suas, urbes et viculi earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.49",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 49,
      "referenceLabel": "Joshua 19:49",
      "text": "Cumque complesset sorte dividere terram singulis per tribus suas, dederunt filii Israël possessionem Josue filio Nun in medio sui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.50",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 50,
      "referenceLabel": "Joshua 19:50",
      "text": "juxta præceptum Domini, urbem quam postulavit Thamnath Saraa in monte Ephraim: et ædificavit civitatem, habitavitque in ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:joshua.19.51",
      "translationId": "vulgate",
      "bookSlug": "joshua",
      "chapterNumber": 19,
      "verseNumber": 51,
      "referenceLabel": "Joshua 19:51",
      "text": "Hæ sunt possessiones, quas sorte diviserunt Eleazar sacerdos, et Josue filius Nun, et principes familiarum ac tribuum filiorum Israël in Silo, coram Domino ad ostium tabernaculi testimonii: partitique sunt terram.",
      "paragraphStart": false
    }
  ]
}
