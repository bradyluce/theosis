{
  "chapter": {
    "id": "vulgate:first-timothy.5",
    "translationId": "vulgate",
    "bookSlug": "first-timothy",
    "chapterNumber": 5,
    "referenceLabel": "1 Timothy 5",
    "summary": "Source text for 1 Timothy 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-timothy.5.1",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 5:1",
      "text": "Seniorem ne increpaveris, sed obsecra ut patrem: juvenes, ut fratres:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-timothy.5.2",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 5:2",
      "text": "anus, ut matres: juvenculas, ut sorores in omni castitate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.3",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 5:3",
      "text": "viduas honora, quæ vere viduæ sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.4",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 5:4",
      "text": "Si qua autem vidua filios, aut nepotes habet: discat primum domum suam regere, et mutuam vicem reddere parentibus: hoc enim acceptum est coram Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.5",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 5:5",
      "text": "Quæ autem vere vidua est, et desolata, speret in Deum, et instet obsecrationibus, et orationibus nocte ac die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.6",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 5:6",
      "text": "Nam quæ in deliciis est, vivens mortua est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.7",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 5:7",
      "text": "Et hoc præcipe, ut irreprehensibiles sint.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.8",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 5:8",
      "text": "Si quis autem suorum, et maxime domesticorum, curam non habet, fidem negavit, et est infideli deterior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.9",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 5:9",
      "text": "Vidua eligatur non minus sexaginta annorum, quæ fuerit unius viri uxor,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.10",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 5:10",
      "text": "in operibus bonis testimonium habens, si filios educavit, si hospitio recepit, si sanctorum pedes lavit, si tribulationem patientibus subministravit, si omne opus bonum subsecuta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.11",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 5:11",
      "text": "Adolescentiores autem viduas devita: cum enim luxuriatæ fuerint in Christo, nubere volunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.12",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 5:12",
      "text": "habentes damnationem, quia primam fidem irritam fecerunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.13",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 5:13",
      "text": "simul autem et otiosæ discunt circuire domos: non solum otiosæ, sed et verbosæ, et curiosæ, loquentes quæ non oportet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.14",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 5:14",
      "text": "Volo ergo juniores nubere, filios procreare, matresfamilias esse, nullam occasionem dare adversario maledicti gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.15",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 5:15",
      "text": "Jam enim quædam conversæ sunt retro Satanam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.16",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 5:16",
      "text": "Si quis fidelis habet viduas, subministret illis, et non gravetur ecclesia: ut iis quæ vere viduæ sunt, sufficiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.17",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Timothy 5:17",
      "text": "Qui bene præsunt presbyteri, duplici honore digni habeantur: maxime qui laborant in verbo et doctrina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.18",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Timothy 5:18",
      "text": "Dicit enim Scriptura: Non alligabis os bovi trituranti. Et: Dignus est operarius mercede sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.19",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Timothy 5:19",
      "text": "Adversus presbyterum accusationem noli recipere, nisi sub duobus aut tribus testibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.20",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Timothy 5:20",
      "text": "Peccantes coram omnibus argue: ut et ceteri timorem habeant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.21",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Timothy 5:21",
      "text": "Testor coram Deo et Christo Jesu, et electis angelis, ut hæc custodias sine præjudicio, nihil faciens in alteram partem declinando.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.22",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Timothy 5:22",
      "text": "Manus cito nemini imposueris, neque communicaveris peccatis alienis. Teipsum castum custodi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.23",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Timothy 5:23",
      "text": "Noli adhuc aquam bibere, sed modico vino utere propter stomachum tuum, et frequentes tuas infirmitates.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.24",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Timothy 5:24",
      "text": "Quorumdam hominum peccata manifesta sunt, præcedentia ad judicium: quosdam autem et subsequuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.5.25",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Timothy 5:25",
      "text": "Similiter et facta bona, manifesta sunt: et quæ aliter se habent, abscondi non possunt.",
      "paragraphStart": false
    }
  ]
}
