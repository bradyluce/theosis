{
  "chapter": {
    "id": "vulgate:first-timothy.3",
    "translationId": "vulgate",
    "bookSlug": "first-timothy",
    "chapterNumber": 3,
    "referenceLabel": "1 Timothy 3",
    "summary": "Source text for 1 Timothy 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-timothy.3.1",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 3:1",
      "text": "Fidelis sermo: si quis episcopatum desiderat, bonum opus desiderat.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-timothy.3.2",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 3:2",
      "text": "Oportet ergo episcopum irreprehensibilem esse, unius uxoris virum, sobrium, prudentem, ornatum, pudicum, hospitalem, doctorem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.3",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 3:3",
      "text": "non vinolentum, non percussorem, sed modestum: non litigiosum, non cupidum, sed",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.4",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 3:4",
      "text": "suæ domui bene præpositum: filios habentem subditos cum omni castitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.5",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 3:5",
      "text": "Si quis autem domui suæ præesse nescit, quomodo ecclesiæ Dei diligentiam habebit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.6",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 3:6",
      "text": "Non neophytum: ne in superbiam elatus, in judicium incidat diaboli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.7",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 3:7",
      "text": "Oportet autem illum et testimonium habere bonum ab iis qui foris sunt, ut non in opprobrium incidat, et in laqueum diaboli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.8",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 3:8",
      "text": "Diaconos similiter pudicos, non bilingues, non multo vino deditos, non turpe lucrum sectantes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.9",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 3:9",
      "text": "habentes mysterium fidei in conscientia pura.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.10",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 3:10",
      "text": "Et hi autem probentur primum: et sic ministrent, nullum crimen habentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.11",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 3:11",
      "text": "Mulieres similiter pudicas, non detrahentes, sobrias, fideles in omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.12",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 3:12",
      "text": "Diaconi sint unius uxoris viri, qui filiis suis bene præsint, et suis domibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.13",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 3:13",
      "text": "Qui enim bene ministraverint, gradum bonum sibi acquirent, et multam fiduciam in fide, quæ est in Christo Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.14",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 3:14",
      "text": "Hæc tibi scribo, sperans me ad te venire cito:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.15",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 3:15",
      "text": "si autem tardavero, ut scias quomodo oporteat te in domo Dei conversari, quæ est ecclesia Dei vivi, columna et firmamentum veritatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.3.16",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 3:16",
      "text": "Et manifeste magnum est pietatis sacramentum, quod manifestatum est in carne, justificatum est in spiritu, apparuit angelis, prædicatum est gentibus, creditum est in mundo, assumptum est in gloria.",
      "paragraphStart": false
    }
  ]
}
