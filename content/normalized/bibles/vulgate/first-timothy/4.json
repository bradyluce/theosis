{
  "chapter": {
    "id": "vulgate:first-timothy.4",
    "translationId": "vulgate",
    "bookSlug": "first-timothy",
    "chapterNumber": 4,
    "referenceLabel": "1 Timothy 4",
    "summary": "Source text for 1 Timothy 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-timothy.4.1",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 4:1",
      "text": "Spiritus autem manifeste dicit, quia in novissimis temporibus discedent quidam a fide, attendentes spiritibus erroris, et doctrinis dæmoniorum,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-timothy.4.2",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 4:2",
      "text": "in hypocrisi loquentium mendacium, et cauteriatam habentium suam conscientiam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.3",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 4:3",
      "text": "prohibentium nubere, abstinere a cibis, quod Deus creavit ad percipiendum cum gratiarum actione fidelibus, et iis qui cognoverunt veritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.4",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 4:4",
      "text": "Quia omnis creatura Dei bona est, et nihil rejiciendum quod cum gratiarum actione percipitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.5",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 4:5",
      "text": "sanctificatur enim per verbum Dei, et orationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.6",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 4:6",
      "text": "Hæc proponens fratribus, bonus eris minister Christi Jesu enutritus verbis fidei, et bonæ doctrinæ, quam assecutus es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.7",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 4:7",
      "text": "Ineptas autem, et aniles fabulas devita: exerce autem teipsum ad pietatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.8",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 4:8",
      "text": "Nam corporalis exercitatio, ad modicum utilis est: pietas autem ad omnia utilis est, promissionem habens vitæ, quæ nunc est, et futuræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.9",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 4:9",
      "text": "Fidelis sermo, et omni acceptione dignus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.10",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 4:10",
      "text": "In hoc enim laboramus, et maledicimur, quia speramus in Deum vivum, qui est Salvator omnium hominum, maxime fidelium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.11",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 4:11",
      "text": "Præcipe hæc, et doce.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.12",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 4:12",
      "text": "Nemo adolescentiam tuam contemnat: sed exemplum esto fidelium in verbo, in conversatione, in caritate, in fide, in castitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.13",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 4:13",
      "text": "Dum venio, attende lectioni, exhortationi, et doctrinæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.14",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 4:14",
      "text": "Noli negligere gratiam, quæ in te est, quæ data est tibi per prophetiam, cum impositione manuum presbyterii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.15",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 4:15",
      "text": "Hæc meditare, in his esto: ut profectus tuus manifestus sit omnibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.4.16",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 4:16",
      "text": "Attende tibi, et doctrinæ: insta in illis. Hoc enim faciens, et teipsum salvum facies, et eos qui te audiunt.",
      "paragraphStart": false
    }
  ]
}
