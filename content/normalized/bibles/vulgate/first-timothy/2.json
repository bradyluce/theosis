{
  "chapter": {
    "id": "vulgate:first-timothy.2",
    "translationId": "vulgate",
    "bookSlug": "first-timothy",
    "chapterNumber": 2,
    "referenceLabel": "1 Timothy 2",
    "summary": "Source text for 1 Timothy 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-timothy.2.1",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 2:1",
      "text": "Obsecro igitur primum omnium fieri obsecrationes, orationes, postulationes, gratiarum actiones, pro omnibus hominibus:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-timothy.2.2",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 2:2",
      "text": "pro regibus, et omnibus qui in sublimitate sunt, ut quietam et tranquillam vitam agamus in omni pietate, et castitate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.3",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 2:3",
      "text": "hoc enim bonum est, et acceptum coram Salvatore nostro Deo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.4",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 2:4",
      "text": "qui omnes homines vult salvos fieri, et ad agnitionem veritatis venire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.5",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 2:5",
      "text": "Unus enim Deus, unus et mediator Dei et hominum homo Christus Jesus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.6",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 2:6",
      "text": "qui dedit redemptionem semetipsum pro omnibus, testimonium temporibus suis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.7",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 2:7",
      "text": "in quo positus sum ego prædicator, et Apostolus (veritatem dico, non mentior) doctor gentium in fide, et veritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.8",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 2:8",
      "text": "Volo ergo viros orare in omni loco, levantes puras manus sine ira et disceptatione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.9",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 2:9",
      "text": "Similiter et mulieres in habitu ornato, cum verecundia et sobrietate ornantes se, et non in tortis crinibus, aut auro, aut margaritas, vel veste pretiosa:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.10",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 2:10",
      "text": "sed quod decet mulieres, promittentes pietatem per opera bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.11",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 2:11",
      "text": "Mulier in silentio discat cum omni subjectione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.12",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 2:12",
      "text": "Docere autem mulieri non permitto, neque dominari in virum: sed esse in silentio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.13",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 2:13",
      "text": "Adam enim primus formatus est: deinde Heva:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.14",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 2:14",
      "text": "et Adam non est seductus: mulier autem seducta in prævaricatione fuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-timothy.2.15",
      "translationId": "vulgate",
      "bookSlug": "first-timothy",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 2:15",
      "text": "Salvabitur autem per filiorum generationem, si permanserit in fide, et dilectione, et sanctificatione cum sobrietate.",
      "paragraphStart": false
    }
  ]
}
