{
  "chapter": {
    "id": "vulgate:john.10",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 10,
    "referenceLabel": "John 10",
    "summary": "Source text for John 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.10.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "John 10:1",
      "text": "Amen, amen dico vobis: qui non intrat per ostium in ovile ovium, sed ascendit aliunde, ille fur est et latro.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.10.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "John 10:2",
      "text": "Qui autem intrat per ostium, pastor est ovium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "John 10:3",
      "text": "Huic ostiarius aperit, et oves vocem ejus audiunt, et proprias oves vocat nominatim, et educit eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "John 10:4",
      "text": "Et cum proprias oves emiserit, ante eas vadit: et oves illum sequuntur, quia sciunt vocem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "John 10:5",
      "text": "Alienum autem non sequuntur, sed fugiunt ab eo: quia non noverunt vocem alienorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "John 10:6",
      "text": "Hoc proverbium dixit eis Jesus: illi autem non cognoverunt quid loqueretur eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "John 10:7",
      "text": "Dixit ergo eis iterum Jesus: Amen, amen dico vobis, quia ego sum ostium ovium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "John 10:8",
      "text": "Omnes quotquot venerunt, fures sunt, et latrones, et non audierunt eos oves.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "John 10:9",
      "text": "Ego sum ostium. Per me si quis introierit, salvabitur: et ingredietur, et egredietur, et pascua inveniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "John 10:10",
      "text": "Fur non venit nisi ut furetur, et mactet, et perdat. Ego veni ut vitam habeant, et abundantius habeant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "John 10:11",
      "text": "Ego sum pastor bonus. Bonus pastor animam suam dat pro ovibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "John 10:12",
      "text": "Mercenarius autem, et qui non est pastor, cujus non sunt oves propriæ, videt lupum venientem, et dimittit oves, et fugit: et lupus rapit, et dispergit oves;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "John 10:13",
      "text": "mercenarius autem fugit, quia mercenarius est, et non pertinet ad eum de ovibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "John 10:14",
      "text": "Ego sum pastor bonus: et cognosco meas, et cognoscunt me meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "John 10:15",
      "text": "Sicut novit me Pater, et ego agnosco Patrem: et animam meam pono pro ovibus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "John 10:16",
      "text": "Et alias oves habeo, quæ non sunt ex hoc ovili: et illas oportet me adducere, et vocem meam audient, et fiet unum ovile et unus pastor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "John 10:17",
      "text": "Propterea me diligit Pater: quia ego pono animam meam, ut iterum sumam eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "John 10:18",
      "text": "Nemo tollit eam a me: sed ego pono eam a meipso, et potestatem habeo ponendi eam, et potestatem habeo iterum sumendi eam. Hoc mandatum accepi a Patre meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "John 10:19",
      "text": "Dissensio iterum facta est inter Judæos propter sermones hos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "John 10:20",
      "text": "Dicebant autem multi ex ipsis: Dæmonium habet, et insanit: quid eum auditis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "John 10:21",
      "text": "Alii dicebant: Hæc verba non sunt dæmonium habentis: numquid dæmonium potest cæcorum oculos aperire?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "John 10:22",
      "text": "Facta sunt autem Encænia in Jerosolymis, et hiems erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "John 10:23",
      "text": "Et ambulabat Jesus in templo, in porticu Salomonis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "John 10:24",
      "text": "Circumdederunt ergo eum Judæi, et dicebant ei: Quousque animam nostram tollis? si tu es Christus, dic nobis palam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "John 10:25",
      "text": "Respondit eis Jesus: Loquor vobis, et non creditis: opera quæ ego facio in nomine Patris mei, hæc testimonium perhibent de me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "John 10:26",
      "text": "sed vos non creditis, quia non estis ex ovibus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "John 10:27",
      "text": "Oves meæ vocem meam audiunt, et ego cognosco eas, et sequuntur me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "John 10:28",
      "text": "et ego vitam æternam do eis, et non peribunt in æternum, et non rapiet eas quisquam de manu mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "John 10:29",
      "text": "Pater meus quod dedit mihi, majus omnibus est: et nemo potest rapere de manu Patris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "John 10:30",
      "text": "Ego et Pater unum sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "John 10:31",
      "text": "Sustulerunt ergo lapides Judæi, ut lapidarent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "John 10:32",
      "text": "Respondit eis Jesus: Multa bona opera ostendi vobis ex Patre meo: propter quod eorum opus me lapidatis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "John 10:33",
      "text": "Responderunt ei Judæi: De bono opere non lapidamus te, sed de blasphemia; et quia tu homo cum sis, facis teipsum Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "John 10:34",
      "text": "Respondit eis Jesus: Nonne scriptum est in lege vestra, Quia ego dixi: Dii estis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "John 10:35",
      "text": "Si illos dixit deos, ad quos sermo Dei factus est, et non potest solvi Scriptura:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "John 10:36",
      "text": "quem Pater sanctificavit, et misit in mundum vos dicitis: Quia blasphemas, quia dixi: Filius Dei sum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "John 10:37",
      "text": "Si non facio opera Patris mei, nolite credere mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "John 10:38",
      "text": "Si autem facio: etsi mihi non vultis credere, operibus credite, ut cognoscatis, et credatis quia Pater in me est, et ego in Patre.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "John 10:39",
      "text": "Quærebant ergo eum apprehendere: et exivit de manibus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 40,
      "referenceLabel": "John 10:40",
      "text": "Et abiit iterum trans Jordanem, in eum locum ubi erat Joannes baptizans primum, et mansit illic;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 41,
      "referenceLabel": "John 10:41",
      "text": "et multi venerunt ad eum, et dicebant: Quia Joannes quidem signum fecit nullum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.10.42",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 42,
      "referenceLabel": "John 10:42",
      "text": "Omnia autem quæcumque dixit Joannes de hoc, vera erant. Et multi crediderunt in eum.",
      "paragraphStart": false
    }
  ]
}
