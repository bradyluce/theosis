{
  "chapter": {
    "id": "vulgate:john.13",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 13,
    "referenceLabel": "John 13",
    "summary": "Source text for John 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.13.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "John 13:1",
      "text": "Ante diem festum Paschæ, sciens Jesus quia venit hora ejus ut transeat ex hoc mundo ad Patrem: cum dilexisset suos, qui erant in mundo, in finem dilexit eos.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.13.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "John 13:2",
      "text": "Et cœna facta, cum diabolus jam misisset in cor ut traderet eum Judas Simonis Iscariotæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "John 13:3",
      "text": "sciens quia omnia dedit ei Pater in manus, et quia a Deo exivit, et ad Deum vadit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "John 13:4",
      "text": "surgit a cœna, et ponit vestimenta sua, et cum accepisset linteum, præcinxit se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "John 13:5",
      "text": "Deinde mittit aquam in pelvim, et cœpit lavare pedes discipulorum, et extergere linteo, quo erat præcinctus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "John 13:6",
      "text": "Venit ergo ad Simonem Petrum. Et dicit ei Petrus: Domine, tu mihi lavas pedes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "John 13:7",
      "text": "Respondit Jesus, et dixit ei: Quod ego facio, tu nescis modo: scies autem postea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "John 13:8",
      "text": "Dicit ei Petrus: Non lavabis mihi pedes in æternum. Respondit ei Jesus: Si non lavero te, non habebis partem mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "John 13:9",
      "text": "Dicit ei Simon Petrus: Domine, non tantum pedes meos, sed et manus, et caput.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "John 13:10",
      "text": "Dicit ei Jesus: Qui lotus est, non indiget nisi ut pedes lavet, sed est mundus totus. Et vos mundi estis, sed non omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "John 13:11",
      "text": "Sciebat enim quisnam esset qui traderet eum; propterea dixit: Non estis mundi omnes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "John 13:12",
      "text": "Postquam ergo lavit pedes eorum, et accepit vestimenta sua, cum recubuisset iterum, dixit eis: Scitis quid fecerim vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "John 13:13",
      "text": "Vos vocatis me Magister et Domine, et bene dicitis: sum etenim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "John 13:14",
      "text": "Si ergo ego lavi pedes vestros, Dominus et Magister, et vos debetis alter alterius lavare pedes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "John 13:15",
      "text": "Exemplum enim dedi vobis, ut quemadmodum ego feci vobis, ita et vos faciatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "John 13:16",
      "text": "Amen, amen dico vobis: non est servus major domino suo: neque apostolus major est eo qui misit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "John 13:17",
      "text": "Si hæc scitis, beati eritis si feceritis ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "John 13:18",
      "text": "Non de omnibus vobis dico: ego scio quos elegerim; sed ut adimpleatur Scriptura: Qui manducat mecum panem, levabit contra me calcaneum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "John 13:19",
      "text": "Amodo dico vobis, priusquam fiat: ut cum factum fuerit, credatis quia ego sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "John 13:20",
      "text": "Amen, amen dico vobis: qui accipit si quem misero, me accipit; qui autem me accipit, accipit eum qui me misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "John 13:21",
      "text": "Cum hæc dixisset Jesus, turbatus est spiritu: et protestatus est, et dixit: Amen, amen dico vobis, quia unus ex vobis tradet me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "John 13:22",
      "text": "Aspiciebant ergo ad invicem discipuli, hæsitantes de quo diceret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "John 13:23",
      "text": "Erat ergo recumbens unus ex discipulis ejus in sinu Jesu, quem diligebat Jesus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "John 13:24",
      "text": "Innuit ergo huic Simon Petrus, et dixit ei: Quis est, de quo dicit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "John 13:25",
      "text": "Itaque cum recubuisset ille supra pectus Jesu, dicit ei: Domine, quis est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "John 13:26",
      "text": "Respondit Jesus: Ille est cui ego intinctum panem porrexero. Et cum intinxisset panem, dedit Judæ Simonis Iscariotæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "John 13:27",
      "text": "Et post buccellam, introivit in eum Satanas. Et dixit ei Jesus: Quod facis, fac citius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "John 13:28",
      "text": "Hoc autem nemo scivit discumbentium ad quid dixerit ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "John 13:29",
      "text": "Quidam enim putabant, quia loculos habebat Judas, quod dixisset ei Jesus: Eme ea quæ opus sunt nobis ad diem festum: aut egenis ut aliquid daret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "John 13:30",
      "text": "Cum ergo accepisset ille buccellam, exivit continuo. Erat autem nox.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "John 13:31",
      "text": "Cum ergo exisset, dixit Jesus: Nunc clarificatus est Filius hominis, et Deus clarificatus est in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "John 13:32",
      "text": "Si Deus clarificatus est in eo, et Deus clarificabit eum in semetipso: et continuo clarificabit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "John 13:33",
      "text": "Filioli, adhuc modicum vobiscum sum. Quæretis me; et sicut dixi Judæis, quo ego vado, vos non potestis venire: et vobis dico modo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "John 13:34",
      "text": "Mandatum novum do vobis: ut diligatis invicem: sicut dilexi vos, ut et vos diligatis invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "John 13:35",
      "text": "In hoc cognoscent omnes quia discipuli mei estis, si dilectionem habueritis ad invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "John 13:36",
      "text": "Dicit ei Simon Petrus: Domine, quo vadis? Respondit Jesus: Quo ego vado non potes me modo sequi: sequeris autem postea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "John 13:37",
      "text": "Dicit ei Petrus: Quare non possum te sequi modo? animam meam pro te ponam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.13.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 13,
      "verseNumber": 38,
      "referenceLabel": "John 13:38",
      "text": "Respondit ei Jesus: Animam tuam pro me pones? amen, amen dico tibi: non cantabit gallus, donec ter me neges.",
      "paragraphStart": false
    }
  ]
}
