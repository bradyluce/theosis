{
  "chapter": {
    "id": "vulgate:john.14",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 14,
    "referenceLabel": "John 14",
    "summary": "Source text for John 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.14.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "John 14:1",
      "text": "Non turbetur cor vestrum. Creditis in Deum, et in me credite.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.14.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "John 14:2",
      "text": "In domo Patris mei mansiones multæ sunt; si quominus dixissem vobis: quia vado parare vobis locum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "John 14:3",
      "text": "Et si abiero, et præparavero vobis locum, iterum venio, et accipiam vos ad meipsum: ut ubi sum ego, et vos sitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "John 14:4",
      "text": "Et quo ego vado scitis, et viam scitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "John 14:5",
      "text": "Dicit ei Thomas: Domine, nescimus quo vadis: et quomodo possumus viam scire?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "John 14:6",
      "text": "Dicit ei Jesus: Ego sum via, et veritas, et vita. Nemo venit ad Patrem, nisi per me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "John 14:7",
      "text": "Si cognovissetis me, et Patrem meum utique cognovissetis: et amodo cognoscetis eum, et vidistis eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "John 14:8",
      "text": "Dicit ei Philippus: Domine, ostende nobis Patrem, et sufficit nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "John 14:9",
      "text": "Dicit ei Jesus: Tanto tempore vobiscum sum, et non cognovistis me? Philippe, qui videt me, videt et Patrem. Quomodo tu dicis: Ostende nobis Patrem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "John 14:10",
      "text": "Non creditis quia ego in Patre, et Pater in me est? Verba quæ ego loquor vobis, a meipso non loquor. Pater autem in me manens, ipse fecit opera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "John 14:11",
      "text": "Non creditis quia ego in Patre, et Pater in me est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "John 14:12",
      "text": "alioquin propter opera ipsa credite. Amen, amen dico vobis, qui credit in me, opera quæ ego facio, et ipse faciet, et majora horum faciet: quia ego ad Patrem vado.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "John 14:13",
      "text": "Et quodcumque petieritis Patrem in nomine meo, hoc faciam: ut glorificetur Pater in Filio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "John 14:14",
      "text": "Si quid petieritis me in nomine meo, hoc faciam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "John 14:15",
      "text": "Si diligitis me, mandata mea servate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "John 14:16",
      "text": "et ego rogabo Patrem, et alium Paraclitum dabit vobis, ut maneat vobiscum in æternum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "John 14:17",
      "text": "Spiritum veritatis, quem mundus non potest accipere, quia non videt eum, nec scit eum: vos autem cognoscetis eum, quia apud vos manebit, et in vobis erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "John 14:18",
      "text": "Non relinquam vos orphanos: veniam ad vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "John 14:19",
      "text": "Adhuc modicum, et mundus me jam non videt. Vos autem videtis me: quia ego vivo, et vos vivetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "John 14:20",
      "text": "In illo die vos cognoscetis quia ego sum in Patre meo, et vos in me, et ego in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "John 14:21",
      "text": "Qui habet mandata mea, et servat ea: ille est qui diligit me. Qui autem diligit me, diligetur a Patre meo: et ego diligam eum, et manifestabo ei meipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "John 14:22",
      "text": "Dicit ei Judas, non ille Iscariotes: Domine, quid factum est, quia manifestaturus es nobis teipsum, et non mundo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "John 14:23",
      "text": "Respondit Jesus, et dixit ei: Si quis diligit me, sermonem meum servabit, et Pater meus diliget eum, et ad eum veniemus, et mansionem apud eum faciemus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "John 14:24",
      "text": "qui non diligit me, sermones meos non servat. Et sermonem, quem audistis, non est meus: sed ejus qui misit me, Patris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "John 14:25",
      "text": "Hæc locutus sum vobis apud vos manens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "John 14:26",
      "text": "Paraclitus autem Spiritus Sanctus, quem mittet Pater in nomine meo, ille vos docebit omnia, et suggeret vobis omnia quæcumque dixero vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "John 14:27",
      "text": "Pacem relinquo vobis, pacem meam do vobis: non quomodo mundus dat, ego do vobis. Non turbetur cor vestrum, neque formidet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "John 14:28",
      "text": "Audistis quia ego dixi vobis: Vado, et venio ad vos. Si diligeretis me, gauderetis utique, quia vado ad Patrem: quia Pater major me est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "John 14:29",
      "text": "Et nunc dixi vobis priusquam fiat: ut cum factum fuerit, credatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "John 14:30",
      "text": "Jam non multa loquar vobiscum: venit enim princeps mundi hujus, et in me non habet quidquam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.14.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "John 14:31",
      "text": "Sed ut cognoscat mundus quia diligo Patrem, et sicut mandatum dedit mihi Pater, sic facio. Surgite, eamus hinc.",
      "paragraphStart": false
    }
  ]
}
