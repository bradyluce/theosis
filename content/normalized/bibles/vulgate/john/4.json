{
  "chapter": {
    "id": "vulgate:john.4",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 4,
    "referenceLabel": "John 4",
    "summary": "Source text for John 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.4.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "John 4:1",
      "text": "Ut ergo cognovit Jesus quia audierunt pharisæi quod Jesus plures discipulos facit, et baptizat, quam Joannes",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.4.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "John 4:2",
      "text": "(quamquam Jesus non baptizaret, sed discipuli ejus),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "John 4:3",
      "text": "reliquit Judæam, et abiit iterum in Galilæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "John 4:4",
      "text": "Oportebat autem eum transire per Samariam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "John 4:5",
      "text": "Venit ergo in civitatem Samariæ, quæ dicitur Sichar, juxta prædium quod dedit Jacob Joseph filio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "John 4:6",
      "text": "Erat autem ibi fons Jacob. Jesus ergo fatigatus ex itinere, sedebat sic supra fontem. Hora erat quasi sexta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "John 4:7",
      "text": "Venit mulier de Samaria haurire aquam. Dicit ei Jesus: Da mihi bibere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "John 4:8",
      "text": "(Discipuli enim ejus abierant in civitatem ut cibos emerent.)",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "John 4:9",
      "text": "Dicit ergo ei mulier illa Samaritana: Quomodo tu, Judæus cum sis, bibere a me poscis, quæ sum mulier Samaritana? non enim coutuntur Judæi Samaritanis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "John 4:10",
      "text": "Respondit Jesus, et dixit ei: Si scires donum Dei, et quis est qui dicit tibi: Da mihi bibere, tu forsitan petisses ab eo, et dedisset tibi aquam vivam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "John 4:11",
      "text": "Dicit ei mulier: Domine, neque in quo haurias habes, et puteus altus est: unde ergo habes aquam vivam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "John 4:12",
      "text": "Numquid tu major es patre nostro Jacob, qui dedit nobis puteum, et ipse ex eo bibit, et filii ejus, et pecora ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "John 4:13",
      "text": "Respondit Jesus, et dixit ei: Omnis qui bibit ex aqua hac, sitiet iterum; qui autem biberit ex aqua quam ego dabo ei, non sitiet in æternum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "John 4:14",
      "text": "sed aqua quam ego dabo ei, fiet in eo fons aquæ salientis in vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "John 4:15",
      "text": "Dicit ad eum mulier: Domine, da mihi hanc aquam, ut non sitiam, neque veniam huc haurire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "John 4:16",
      "text": "Dicit ei Jesus: Vade, voca virum tuum, et veni huc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "John 4:17",
      "text": "Respondit mulier, et dixit: Non habeo virum. Dicit ei Jesus: Bene dixisti, quia non habeo virum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "John 4:18",
      "text": "quinque enim viros habuisti, et nunc, quem habes, non est tuus vir: hoc vere dixisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "John 4:19",
      "text": "Dicit ei mulier: Domine, video quia propheta es tu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "John 4:20",
      "text": "Patres nostri in monte hoc adoraverunt, et vos dicitis, quia Jerosolymis est locus ubi adorare oportet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "John 4:21",
      "text": "Dicit ei Jesus: Mulier, crede mihi, quia venit hora, quando neque in monte hoc, neque in Jerosolymis adorabitis Patrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "John 4:22",
      "text": "Vos adoratis quod nescitis: nos adoramus quod scimus, quia salus ex Judæis est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "John 4:23",
      "text": "Sed venit hora, et nunc est, quando veri adoratores adorabunt Patrem in spiritu et veritate. Nam et Pater tales quærit, qui adorent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "John 4:24",
      "text": "Spiritus est Deus: et eos qui adorant eum, in spiritu et veritate oportet adorare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "John 4:25",
      "text": "Dicit ei mulier: Scio quia Messias venit (qui dicitur Christus): cum ergo venerit ille, nobis annuntiabit omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "John 4:26",
      "text": "Dicit ei Jesus: Ego sum, qui loquor tecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "John 4:27",
      "text": "Et continuo venerunt discipuli ejus, et mirabantur quia cum muliere loquebatur. Nemo tamen dixit: Quid quæris? aut, Quid loqueris cum ea?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "John 4:28",
      "text": "Reliquit ergo hydriam suam mulier, et abiit in civitatem, et dicit illis hominibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "John 4:29",
      "text": "Venite, et videte hominem qui dixit mihi omnia quæcumque feci: numquid ipse est Christus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "John 4:30",
      "text": "Exierunt ergo de civitate et veniebant ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "John 4:31",
      "text": "Interea rogabant eum discipuli, dicentes: Rabbi, manduca.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "John 4:32",
      "text": "Ille autem dicit eis: Ego cibum habeo manducare, quem vos nescitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "John 4:33",
      "text": "Dicebant ergo discipuli ad invicem: Numquid aliquis attulit ei manducare?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "John 4:34",
      "text": "Dicit eis Jesus: Meus cibus est ut faciam voluntatem ejus qui misit me, ut perficiam opus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "John 4:35",
      "text": "Nonne vos dicitis quod adhuc quatuor menses sunt, et messis venit? Ecce dico vobis: levate oculos vestros, et videte regiones, quia albæ sunt jam ad messem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "John 4:36",
      "text": "Et qui metit, mercedem accipit, et congregat fructum in vitam æternam: ut et qui seminat, simul gaudeat, et qui metit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "John 4:37",
      "text": "In hoc enim est verbum verum: quia alius est qui seminat, et alius est qui metit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "John 4:38",
      "text": "Ego misi vos metere quod vos non laborastis: alii laboraverunt, et vos in labores eorum introistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 39,
      "referenceLabel": "John 4:39",
      "text": "Ex civitate autem illa multi crediderunt in eum Samaritanorum, propter verbum mulieris testimonium perhibentis: Quia dixit mihi omnia quæcumque feci.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 40,
      "referenceLabel": "John 4:40",
      "text": "Cum venissent ergo ad illum Samaritani, rogaverunt eum ut ibi maneret. Et mansit ibi duos dies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 41,
      "referenceLabel": "John 4:41",
      "text": "Et multo plures crediderunt in eum propter sermonem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.42",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 42,
      "referenceLabel": "John 4:42",
      "text": "Et mulieri dicebant: Quia jam non propter tuam loquelam credimus: ipsi enim audivimus, et scimus quia hic est vere Salvator mundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.43",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 43,
      "referenceLabel": "John 4:43",
      "text": "Post duos autem dies exiit inde, et abiit in Galilæam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.44",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 44,
      "referenceLabel": "John 4:44",
      "text": "Ipse enim Jesus testimonium perhibuit, quia propheta in sua patria honorem non habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.45",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 45,
      "referenceLabel": "John 4:45",
      "text": "Cum ergo venisset in Galilæam, exceperunt eum Galilæi, cum omnia vidissent quæ fecerat Jerosolymis in die festo: et ipsi enim venerant ad diem festum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.46",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 46,
      "referenceLabel": "John 4:46",
      "text": "Venit ergo iterum in Cana Galilææ, ubi fecit aquam vinum. Et erat quidam regulus, cujus filius infirmabatur Capharnaum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.47",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 47,
      "referenceLabel": "John 4:47",
      "text": "Hic cum audisset quia Jesus adveniret a Judæa in Galilæam, abiit ad eum, et rogabat eum ut descenderet, et sanaret filium ejus: incipiebat enim mori.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.48",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 48,
      "referenceLabel": "John 4:48",
      "text": "Dixit ergo Jesus ad eum: Nisi signa et prodigia videritis, non creditis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.49",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 49,
      "referenceLabel": "John 4:49",
      "text": "Dicit ad eum regulus: Domine, descende priusquam moriatur filius meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.50",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 50,
      "referenceLabel": "John 4:50",
      "text": "Dicit ei Jesus: Vade, filius tuus vivit. Credidit homo sermoni quem dixit ei Jesus, et ibat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.51",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 51,
      "referenceLabel": "John 4:51",
      "text": "Jam autem eo descendente, servi occurrerunt ei, et nuntiaverunt dicentes, quia filius ejus viveret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.52",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 52,
      "referenceLabel": "John 4:52",
      "text": "Interrogabat ergo horam ab eis in qua melius habuerit. Et dixerunt ei: Quia heri hora septima reliquit eum febris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.53",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 53,
      "referenceLabel": "John 4:53",
      "text": "Cognovit ergo pater, quia illa hora erat in qua dixit ei Jesus: Filius tuus vivit; et credidit ipse et domus ejus tota.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.4.54",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 4,
      "verseNumber": 54,
      "referenceLabel": "John 4:54",
      "text": "Hoc iterum secundum signum fecit Jesus, cum venisset a Judæa in Galilæam.",
      "paragraphStart": false
    }
  ]
}
