{
  "chapter": {
    "id": "vulgate:john.16",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 16,
    "referenceLabel": "John 16",
    "summary": "Source text for John 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.16.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "John 16:1",
      "text": "Hæc locutus sum vobis, ut non scandalizemini.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.16.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "John 16:2",
      "text": "Absque synagogis facient vos: sed venit hora, ut omnis qui interficit vos arbitretur obsequium se præstare Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "John 16:3",
      "text": "Et hæc facient vobis, quia non noverunt Patrem, neque me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "John 16:4",
      "text": "Sed hæc locutus sum vobis, ut cum venerit hora eorum, reminiscamini quia ego dixi vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "John 16:5",
      "text": "Hæc autem vobis ab initio non dixi, quia vobiscum eram. Et nunc vado ad eum qui misit me; et nemo ex vobis interrogat me: Quo vadis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "John 16:6",
      "text": "sed quia hæc locutus sum vobis, tristitia implevit cor vestrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "John 16:7",
      "text": "Sed ego veritatem dico vobis: expedit vobis ut ego vadam: si enim non abiero, Paraclitus non veniet ad vos; si autem abiero, mittam eum ad vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "John 16:8",
      "text": "Et cum venerit ille, arguet mundum de peccato, et de justitia, et de judicio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "John 16:9",
      "text": "De peccato quidem, quia non crediderunt in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "John 16:10",
      "text": "De justitia vero, quia ad Patrem vado, et jam non videbitis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "John 16:11",
      "text": "De judicio autem, quia princeps hujus mundi jam judicatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "John 16:12",
      "text": "Adhuc multa habeo vobis dicere, sed non potestis portare modo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "John 16:13",
      "text": "Cum autem venerit ille Spiritus veritatis, docebit vos omnem veritatem: non enim loquetur a semetipso, sed quæcumque audiet loquetur, et quæ ventura sunt annuntiabit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "John 16:14",
      "text": "Ille me clarificabit, quia de meo accipiet, et annuntiabit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "John 16:15",
      "text": "Omnia quæcumque habet Pater, mea sunt. Propterea dixi: quia de meo accipiet, et annuntiabit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "John 16:16",
      "text": "Modicum, et jam non videbitis me; et iterum modicum, et videbitis me: quia vado ad Patrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "John 16:17",
      "text": "Dixerunt ergo ex discipulis ejus ad invicem: Quid est hoc quod dicit nobis: Modicum, et non videbitis me; et iterum modicum, et videbitis me, et quia vado ad Patrem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "John 16:18",
      "text": "Dicebant ergo: Quid est hoc quod dicit: Modicum? nescimus quid loquitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "John 16:19",
      "text": "Cognovit autem Jesus, quia volebant eum interrogare, et dixit eis: De hoc quæritis inter vos quia dixi: Modicum, et non videbitis me; et iterum modicum, et videbitis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "John 16:20",
      "text": "Amen, amen dico vobis: quia plorabitis, et flebitis vos, mundus autem gaudebit; vos autem contristabimini, sed tristitia vestra vertetur in gaudium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "John 16:21",
      "text": "Mulier cum parit, tristitiam habet, quia venit hora ejus; cum autem pepererit puerum, jam non meminit pressuræ propter gaudium, quia natus est homo in mundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "John 16:22",
      "text": "Et vos igitur nunc quidem tristitiam habetis, iterum autem videbo vos, et gaudebit cor vestrum: et gaudium vestrum nemo tollet a vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "John 16:23",
      "text": "Et in illo die me non rogabitis quidquam. Amen, amen dico vobis: si quid petieritis Patrem in nomine meo, dabit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "John 16:24",
      "text": "Usque modo non petistis quidquam in nomine meo: petite, et accipietis, ut gaudium vestrum sit plenum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "John 16:25",
      "text": "Hæc in proverbiis locutus sum vobis. Venit hora cum jam non in proverbiis loquar vobis, sed palam de Patre annuntiabo vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "John 16:26",
      "text": "in illo die in nomine meo petetis: et non dico vobis quia ego rogabo Patrem de vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "John 16:27",
      "text": "ipse enim Pater amat vos, quia vos me amastis, et credidistis, quia ego a Deo exivi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "John 16:28",
      "text": "Exivi a Patre, et veni in mundum: iterum relinquo mundum, et vado ad Patrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "John 16:29",
      "text": "Dicunt ei discipuli ejus: Ecce nunc palam loqueris, et proverbium nullum dicis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "John 16:30",
      "text": "nunc scimus quia scis omnia, et non opus est tibi ut quis te interroget: in hoc credimus quia a Deo existi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "John 16:31",
      "text": "Respondit eis Jesus: Modo creditis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "John 16:32",
      "text": "ecce venit hora, et jam venit, ut dispergamini unusquisque in propria, et me solum relinquatis: et non sum solus, quia Pater mecum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.16.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "John 16:33",
      "text": "Hæc locutus sum vobis, ut in me pacem habeatis. In mundo pressuram habebitis: sed confidite, ego vici mundum.",
      "paragraphStart": false
    }
  ]
}
