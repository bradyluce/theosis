{
  "chapter": {
    "id": "vulgate:john.9",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 9,
    "referenceLabel": "John 9",
    "summary": "Source text for John 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.9.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "John 9:1",
      "text": "Et præteriens Jesus vidit hominem cæcum a nativitate:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.9.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "John 9:2",
      "text": "et interrogaverunt eum discipuli ejus: Rabbi, quis peccavit, hic, aut parentes ejus, ut cæcus nasceretur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "John 9:3",
      "text": "Respondit Jesus: Neque hic peccavit, neque parentes ejus: sed ut manifestentur opera Dei in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "John 9:4",
      "text": "Me oportet operari opera ejus qui misit me, donec dies est: venit nox, quando nemo potest operari:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "John 9:5",
      "text": "quamdiu sum in mundo, lux sum mundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "John 9:6",
      "text": "Hæc cum dixisset, exspuit in terram, et fecit lutum ex sputo, et linivit lutum super oculos ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "John 9:7",
      "text": "et dixit ei: Vade, lava in natatoria Siloë (quod interpretatur Missus). Abiit ergo, et lavit, et venit videns.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "John 9:8",
      "text": "Itaque vicini, et qui viderant eum prius quia mendicus erat, dicebant: Nonne hic est qui sedebat, et mendicabat? Alii dicebant: Quia hic est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "John 9:9",
      "text": "Alii autem: Nequaquam, sed similis est ei. Ille vero dicebat: Quia ego sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "John 9:10",
      "text": "Dicebant ergo ei: Quomodo aperti sunt tibi oculi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "John 9:11",
      "text": "Respondit: Ille homo qui dicitur Jesus, lutum fecit: et unxit oculos meos, et dixit mihi: Vade ad natatoria Siloë, et lava. Et abii, et lavi, et video.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "John 9:12",
      "text": "Et dixerunt ei: Ubi est ille? Ait: Nescio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "John 9:13",
      "text": "Adducunt eum ad pharisæos, qui cæcus fuerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "John 9:14",
      "text": "Erat autem sabbatum quando lutum fecit Jesus, et aperuit oculos ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "John 9:15",
      "text": "Iterum ergo interrogabant eum pharisæi quomodo vidisset. Ille autem dixit eis: Lutum mihi posuit super oculos, et lavi, et video.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "John 9:16",
      "text": "Dicebant ergo ex pharisæis quidam: Non est hic homo a Deo, qui sabbatum non custodit. Alii autem dicebant: Quomodo potest homo peccator hæc signa facere? Et schisma erat inter eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "John 9:17",
      "text": "Dicunt ergo cæco iterum: Tu quid dicis de illo qui aperuit oculos tuos? Ille autem dixit: Quia propheta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "John 9:18",
      "text": "Non crediderunt ergo Judæi de illo, quia cæcus fuisset et vidisset, donec vocaverunt parentes ejus, qui viderat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "John 9:19",
      "text": "et interrogaverunt eos, dicentes: Hic est filius vester, quem vos dicitis quia cæcus natus est? quomodo ergo nunc videt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "John 9:20",
      "text": "Responderunt eis parentes ejus, et dixerunt: Scimus quia hic est filius noster, et quia cæcus natus est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "John 9:21",
      "text": "quomodo autem nunc videat, nescimus: aut quis ejus aperuit oculos, nos nescimus; ipsum interrogate: ætatem habet, ipse de se loquatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "John 9:22",
      "text": "Hæc dixerunt parentes ejus, quoniam timebant Judæos: jam enim conspiraverunt Judæi, ut si quis eum confiteretur esse Christum, extra synagogam fieret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "John 9:23",
      "text": "Propterea parentes ejus dixerunt: Quia ætatem habet, ipsum interrogate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "John 9:24",
      "text": "Vocaverunt ergo rursum hominem qui fuerat cæcus, et dixerunt ei: Da gloriam Deo: nos scimus quia hic homo peccator est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "John 9:25",
      "text": "Dixit ergo eis ille: Si peccator est, nescio; unum scio, quia cæcus cum essem, modo video.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "John 9:26",
      "text": "Dixerunt ergo illi: Quid fecit tibi? quomodo aperuit tibi oculos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "John 9:27",
      "text": "Respondit eis: Dixi vobis jam, et audistis: quod iterum vultis audire? numquid et vos vultis discipuli ejus fieri?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "John 9:28",
      "text": "Maledixerunt ergo ei, et dixerunt: Tu discipulus illius sis: nos autem Moysi discipuli sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "John 9:29",
      "text": "Nos scimus quia Moysi locutus est Deus; hunc autem nescimus unde sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "John 9:30",
      "text": "Respondit ille homo, et dixit eis: In hoc enim mirabile est quia vos nescitis unde sit, et aperuit meos oculos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "John 9:31",
      "text": "scimus autem quia peccatores Deus non audit: sed si quis Dei cultor est, et voluntatem ejus facit, hunc exaudit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "John 9:32",
      "text": "A sæculo non est auditum quia quis aperuit oculos cæci nati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "John 9:33",
      "text": "Nisi esset hic a Deo, non poterat facere quidquam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "John 9:34",
      "text": "Responderunt, et dixerunt ei: In peccatis natus es totus, et tu doces nos? Et ejecerunt eum foras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "John 9:35",
      "text": "Audivit Jesus quia ejecerunt eum foras: et cum invenisset eum, dixit ei: Tu credis in Filium Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "John 9:36",
      "text": "Respondit ille, et dixit: Quis est, Domine, ut credam in eum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "John 9:37",
      "text": "Et dixit ei Jesus: Et vidisti eum, et qui loquitur tecum, ipse est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "John 9:38",
      "text": "At ille ait: Credo, Domine. Et procidens adoravit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 39,
      "referenceLabel": "John 9:39",
      "text": "Et dixit Jesus: In judicium ego in hunc mundum veni: ut qui non vident videant, et qui vident cæci fiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 40,
      "referenceLabel": "John 9:40",
      "text": "Et audierunt quidam ex pharisæis qui cum ipso erant, et dixerunt ei: Numquid et nos cæci sumus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.9.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 41,
      "referenceLabel": "John 9:41",
      "text": "Dixit eis Jesus: Si cæci essetis, non haberetis peccatum. Nunc vero dicitis, Quia videmus: peccatum vestrum manet.",
      "paragraphStart": false
    }
  ]
}
