{
  "chapter": {
    "id": "vulgate:john.15",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 15,
    "referenceLabel": "John 15",
    "summary": "Source text for John 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.15.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "John 15:1",
      "text": "Ego sum vitis vera, et Pater meus agricola est.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.15.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "John 15:2",
      "text": "Omnem palmitem in me non ferentem fructum, tollet eum, et omnem qui fert fructum, purgabit eum, ut fructum plus afferat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "John 15:3",
      "text": "Jam vos mundi estis propter sermonem quem locutus sum vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "John 15:4",
      "text": "Manete in me, et ego in vobis. Sicut palmes non potest ferre fructum a semetipso, nisi manserit in vite, sic nec vos, nisi in me manseritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "John 15:5",
      "text": "Ego sum vitis, vos palmites: qui manet in me, et ego in eo, hic fert fructum multum, quia sine me nihil potestis facere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "John 15:6",
      "text": "Si quis in me non manserit, mittetur foras sicut palmes, et arescet, et colligent eum, et in ignem mittent, et ardet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "John 15:7",
      "text": "Si manseritis in me, et verba mea in vobis manserint, quodcumque volueritis petetis, et fiet vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "John 15:8",
      "text": "In hoc clarificatus est Pater meus, ut fructum plurimum afferatis, et efficiamini mei discipuli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "John 15:9",
      "text": "Sicut dilexit me Pater, et ego dilexi vos. Manete in dilectione mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "John 15:10",
      "text": "Si præcepta mea servaveritis, manebitis in dilectione mea, sicut et ego Patris mei præcepta servavi, et maneo in ejus dilectione.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "John 15:11",
      "text": "Hæc locutus sum vobis: ut gaudium meum in vobis sit, et gaudium vestrum impleatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "John 15:12",
      "text": "Hoc est præceptum meum, ut diligatis invicem, sicut dilexi vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "John 15:13",
      "text": "Majorem hac dilectionem nemo habet, ut animam suam ponat quis pro amicis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "John 15:14",
      "text": "Vos amici mei estis, si feceritis quæ ego præcipio vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "John 15:15",
      "text": "Jam non dicam vos servos: quia servus nescit quid faciat dominus ejus. Vos autem dixi amicos: quia omnia quæcumque audivi a Patre meo, nota feci vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "John 15:16",
      "text": "Non vos me elegistis, sed ego elegi vos, et posui vos ut eatis, et fructum afferatis, et fructus vester maneat: ut quodcumque petieritis Patrem in nomine meo, det vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "John 15:17",
      "text": "Hæc mando vobis: ut diligatis invicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "John 15:18",
      "text": "Si mundus vos odit, scitote quia me priorem vobis odio habuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "John 15:19",
      "text": "Si de mundo fuissetis, mundus quod suum erat diligeret: quia vero de mundo non estis, sed ego elegi vos de mundo, propterea odit vos mundus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "John 15:20",
      "text": "Mementote sermonis mei, quem ego dixi vobis: non est servus major domino suo. Si me persecuti sunt, et vos persequentur; si sermonem meum servaverunt, et vestrum servabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "John 15:21",
      "text": "Sed hæc omnia facient vobis propter nomen meum: quia nesciunt eum qui misit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "John 15:22",
      "text": "Si non venissem, et locutus fuissem eis, peccatum non haberent: nunc autem excusationem non habent de peccato suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "John 15:23",
      "text": "Qui me odit, et Patrem meum odit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "John 15:24",
      "text": "Si opera non fecissem in eis quæ nemo alius fecit, peccatum non haberent: nunc autem et viderunt, et oderunt et me, et Patrem meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "John 15:25",
      "text": "Sed ut adimpleatur sermo, qui in lege eorum scriptus est: Quia odio habuerunt me gratis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "John 15:26",
      "text": "Cum autem venerit Paraclitus, quem ego mittam vobis a Patre, Spiritum veritatis, qui a Patre procedit, ille testimonium perhibebit de me;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.15.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "John 15:27",
      "text": "et vos testimonium perhibebitis, quia ab initio mecum estis.",
      "paragraphStart": false
    }
  ]
}
