{
  "chapter": {
    "id": "vulgate:john.17",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 17,
    "referenceLabel": "John 17",
    "summary": "Source text for John 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.17.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "John 17:1",
      "text": "Hæc locutus est Jesus: et sublevatis oculis in cælum, dixit: Pater, venit hora: clarifica Filium tuum, ut Filius tuus clarificet te:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.17.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "John 17:2",
      "text": "sicut dedisti ei potestatem omnis carnis, ut omne, quod dedisti ei, det eis vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "John 17:3",
      "text": "Hæc est autem vita æterna: ut cognoscant te, solum Deum verum, et quem misisti Jesum Christum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "John 17:4",
      "text": "Ego te clarificavi super terram: opus consummavi, quod dedisti mihi ut faciam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "John 17:5",
      "text": "et nunc clarifica me tu, Pater, apud temetipsum, claritate quam habui, priusquam mundus esset, apud te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "John 17:6",
      "text": "Manifestavi nomen tuum hominibus, quos dedisti mihi de mundo: tui erant, et mihi eos dedisti: et sermonem tuum servaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "John 17:7",
      "text": "Nunc cognoverunt quia omnia quæ dedisti mihi, abs te sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "John 17:8",
      "text": "quia verba quæ dedisti mihi, dedi eis: et ipsi acceperunt, et cognoverunt vere quia a te exivi, et crediderunt quia tu me misisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "John 17:9",
      "text": "Ego pro eis rogo; non pro mundo rogo, sed pro his quos dedisti mihi: quia tui sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "John 17:10",
      "text": "et mea omnia tua sunt, et tua mea sunt: et clarificatus sum in eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "John 17:11",
      "text": "Et jam non sum in mundo, et hi in mundo sunt, et ego ad te venio. Pater sancte, serva eos in nomine tuo, quos dedisti mihi: ut sint unum, sicut et nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "John 17:12",
      "text": "Cum essem cum eis, ego servabam eos in nomine tuo. Quos dedisti mihi, custodivi: et nemo ex eis periit, nisi filius perditionis, ut Scriptura impleatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "John 17:13",
      "text": "Nunc autem ad te venio: et hæc loquor in mundo, ut habeant gaudium meum impletum in semetipsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "John 17:14",
      "text": "Ego dedi eis sermonem tuum, et mundus eos odio habuit, quia non sunt de mundo, sicut et ego non sum de mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "John 17:15",
      "text": "Non rogo ut tollas eos de mundo, sed ut serves eos a malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "John 17:16",
      "text": "De mundo non sunt, sicut et ego non sum de mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "John 17:17",
      "text": "Sanctifica eos in veritate. Sermo tuus veritas est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "John 17:18",
      "text": "Sicut tu me misisti in mundum, et ego misi eos in mundum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "John 17:19",
      "text": "et pro eis ego sanctifico meipsum: ut sint et ipsi sanctificati in veritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "John 17:20",
      "text": "Non pro eis autem rogo tantum, sed et pro eis qui credituri sunt per verbum eorum in me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "John 17:21",
      "text": "ut omnes unum sint, sicut tu Pater in me, et ego in te, ut et ipsi in nobis unum sint: ut credat mundus, quia tu me misisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "John 17:22",
      "text": "Et ego claritatem, quam dedisti mihi, dedi eis: ut sint unum, sicut et nos unum sumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "John 17:23",
      "text": "Ego in eis, et tu in me: ut sint consummati in unum: et cognoscat mundus quia tu me misisti, et dilexisti eos, sicut et me dilexisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "John 17:24",
      "text": "Pater, quos dedisti mihi, volo ut ubi sum ego, et illi sint mecum: ut videant claritatem meam, quam dedisti mihi: quia dilexisti me ante constitutionem mundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "John 17:25",
      "text": "Pater juste, mundus te non cognovit, ego autem te cognovi: et hi cognoverunt, quia tu me misisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.17.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "John 17:26",
      "text": "Et notum feci eis nomen tuum, et notum faciam: ut dilectio, qua dilexisti me, in ipsis sit, et ego in ipsis.",
      "paragraphStart": false
    }
  ]
}
