{
  "chapter": {
    "id": "vulgate:john.12",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 12,
    "referenceLabel": "John 12",
    "summary": "Source text for John 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.12.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "John 12:1",
      "text": "Jesus ergo ante sex dies Paschæ venit Bethaniam, ubi Lazarus fuerat mortuus, quem suscitavit Jesus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.12.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "John 12:2",
      "text": "Fecerunt autem ei cœnam ibi, et Martha ministrabat, Lazarus vero unus erat ex discumbentibus cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "John 12:3",
      "text": "Maria ergo accepit libram unguenti nardi pistici pretiosi, et unxit pedes Jesu, et extersit pedes ejus capillis suis: et domus impleta est ex odore unguenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "John 12:4",
      "text": "Dixit ergo unus ex discipulis ejus, Judas Iscariotes, qui erat eum traditurus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "John 12:5",
      "text": "Quare hoc unguentum non veniit trecentis denariis, et datum est egenis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "John 12:6",
      "text": "Dixit autem hoc, non quia de egenis pertinebat ad eum, sed quia fur erat, et loculos habens, ea quæ mittebantur, portabat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "John 12:7",
      "text": "Dixit ergo Jesus: Sinite illam ut in diem sepulturæ meæ servet illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "John 12:8",
      "text": "Pauperes enim semper habetis vobiscum: me autem non semper habetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "John 12:9",
      "text": "Cognovit ergo turba multa ex Judæis quia illic est, et venerunt, non propter Jesum tantum, sed ut Lazarum viderent, quem suscitavit a mortuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "John 12:10",
      "text": "Cogitaverunt autem principes sacerdotum ut et Lazarum interficerent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "John 12:11",
      "text": "quia multi propter illum abibant ex Judæis, et credebant in Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "John 12:12",
      "text": "In crastinum autem, turba multa quæ venerat ad diem festum, cum audissent quia venit Jesus Jerosolymam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "John 12:13",
      "text": "acceperunt ramos palmarum, et processerunt obviam ei, et clamabant: Hosanna, benedictus qui venit in nomine Domini, rex Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "John 12:14",
      "text": "Et invenit Jesus asellum, et sedit super eum, sicut scriptum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "John 12:15",
      "text": "Noli timere, filia Sion: ecce rex tuus venit sedens super pullum asinæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "John 12:16",
      "text": "Hæc non cognoverunt discipuli ejus primum: sed quando glorificatus est Jesus, tunc recordati sunt quia hæc erant scripta de eo, et hæc fecerunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "John 12:17",
      "text": "Testimonium ergo perhibebat turba, quæ erat cum eo quando Lazarum vocavit de monumento, et suscitavit eum a mortuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "John 12:18",
      "text": "Propterea et obviam venit ei turba: quia audierunt fecisse hoc signum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "John 12:19",
      "text": "Pharisæi ergo dixerunt ad semetipsos: Videtis quia nihil proficimus? ecce mundus totus post eum abiit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "John 12:20",
      "text": "Erant autem quidam gentiles, ex his qui ascenderant ut adorarent in die festo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "John 12:21",
      "text": "Hi ergo accesserunt ad Philippum, qui erat a Bethsaida Galilææ, et rogabant eum, dicentes: Domine, volumus Jesum videre.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "John 12:22",
      "text": "Venit Philippus, et dicit Andreæ; Andreas rursum et Philippus dixerunt Jesu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "John 12:23",
      "text": "Jesus autem respondit eis, dicens: Venit hora, ut clarificetur Filius hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "John 12:24",
      "text": "Amen, amen dico vobis, nisi granum frumenti cadens in terram, mortuum fuerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "John 12:25",
      "text": "ipsum solum manet: si autem mortuum fuerit, multum fructum affert. Qui amat animam suam, perdet eam; et qui odit animam suam in hoc mundo, in vitam æternam custodit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "John 12:26",
      "text": "Si quis mihi ministrat, me sequatur, et ubi sum ego, illic et minister meus erit. Si quis mihi ministraverit, honorificabit eum Pater meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "John 12:27",
      "text": "Nunc anima mea turbata est. Et quid dicam? Pater, salvifica me ex hac hora. Sed propterea veni in horam hanc:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "John 12:28",
      "text": "Pater, clarifica nomen tuum. Venit ergo vox de cælo: Et clarificavi, et iterum clarificabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "John 12:29",
      "text": "Turba ergo, quæ stabat, et audierat, dicebat tonitruum esse factum. Alii dicebant: Angelus ei locutus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "John 12:30",
      "text": "Respondit Jesus, et dixit: Non propter me hæc vox venit, sed propter vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "John 12:31",
      "text": "Nunc judicium est mundi: nunc princeps hujus mundi ejicietur foras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "John 12:32",
      "text": "Et ego, si exaltatus fuero a terra, omnia traham ad meipsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "John 12:33",
      "text": "(Hoc autem dicebat, significans qua morte esset moriturus.)",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "John 12:34",
      "text": "Respondit ei turba: Nos audivimus ex lege, quia Christus manet in æternum: et quomodo tu dicis: Oportet exaltari Filium hominis? quis est iste Filius hominis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "John 12:35",
      "text": "Dixit ergo eis Jesus: Adhuc modicum, lumen in vobis est. Ambulate dum lucem habetis, ut non vos tenebræ comprehendant; et qui ambulat in tenebris, nescit quo vadat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "John 12:36",
      "text": "Dum lucem habetis, credite in lucem, ut filii lucis sitis. Hæc locutus est Jesus, et abiit et abscondit se ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "John 12:37",
      "text": "Cum autem tanta signa fecisset coram eis, non credebant in eum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "John 12:38",
      "text": "ut sermo Isaiæ prophetæ impleretur, quem dixit: Domine, quis credidit auditui nostro? et brachium Domini cui revelatum est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "John 12:39",
      "text": "Propterea non poterant credere, quia iterum dixit Isaias:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "John 12:40",
      "text": "Excæcavit oculos eorum, et induravit cor eorum ut non videant oculis, et non intelligant corde, et convertantur, et sanem eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "John 12:41",
      "text": "Hæc dixit Isaias, quando vidit gloriam ejus, et locutus est de eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.42",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "John 12:42",
      "text": "Verumtamen et ex principibus multi crediderunt in eum: sed propter pharisæos non confitebantur, ut e synagoga non ejicerentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.43",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "John 12:43",
      "text": "Dilexerunt enim gloriam hominum magis quam gloriam Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.44",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "John 12:44",
      "text": "Jesus autem clamavit, et dixit: Qui credit in me, non credit in me, sed in eum qui misit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.45",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "John 12:45",
      "text": "Et qui videt me, videt eum qui misit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.46",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "John 12:46",
      "text": "Ego lux in mundum veni, ut omnis qui credit in me, in tenebris non maneat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.47",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "John 12:47",
      "text": "Et si quis audierit verba mea, et non custodierit, ego non judico eum; non enim veni ut judicem mundum, sed ut salvificem mundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.48",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 48,
      "referenceLabel": "John 12:48",
      "text": "Qui spernit me et non accipit verba mea, habet qui judicet eum. Sermo quem locutus sum, ille judicabit eum in novissimo die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.49",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 49,
      "referenceLabel": "John 12:49",
      "text": "Quia ego ex meipso non sum locutus, sed qui misit me, Pater, ipse mihi mandatum dedit quid dicam et quid loquar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.12.50",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 12,
      "verseNumber": 50,
      "referenceLabel": "John 12:50",
      "text": "Et scio quia mandatum ejus vita æterna est: quæ ergo ego loquor, sicut dixit mihi Pater, sic loquor.",
      "paragraphStart": false
    }
  ]
}
