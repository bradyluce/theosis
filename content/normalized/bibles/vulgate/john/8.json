{
  "chapter": {
    "id": "vulgate:john.8",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 8,
    "referenceLabel": "John 8",
    "summary": "Source text for John 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.8.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "John 8:1",
      "text": "Jesus autem perrexit in montem Oliveti:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.8.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "John 8:2",
      "text": "et diluculo iterum venit in templum, et omnis populus venit ad eum, et sedens docebat eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "John 8:3",
      "text": "Adducunt autem scribæ et pharisæi mulierem in adulterio deprehensam: et statuerunt eam in medio,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "John 8:4",
      "text": "et dixerunt ei: Magister, hæc mulier modo deprehensa est in adulterio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "John 8:5",
      "text": "In lege autem Moyses mandavit nobis hujusmodi lapidare. Tu ergo quid dicis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "John 8:6",
      "text": "Hoc autem dicebant tentantes eum, ut possent accusare eum. Jesus autem inclinans se deorsum, digito scribebat in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "John 8:7",
      "text": "Cum ergo perseverarent interrogantes eum, erexit se, et dixit eis: Qui sine peccato est vestrum, primus in illam lapidem mittat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "John 8:8",
      "text": "Et iterum se inclinans, scribebat in terra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "John 8:9",
      "text": "Audientes autem unus post unum exibant, incipientes a senioribus: et remansit solus Jesus, et mulier in medio stans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "John 8:10",
      "text": "Erigens autem se Jesus, dixit ei: Mulier, ubi sunt qui te accusabant? nemo te condemnavit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "John 8:11",
      "text": "Quæ dixit: Nemo, Domine. Dixit autem Jesus: Nec ego te condemnabo: vade, et jam amplius noli peccare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "John 8:12",
      "text": "Iterum ergo locutus est eis Jesus, dicens: Ego sum lux mundi: qui sequitur me, non ambulat in tenebris, sed habebit lumen vitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "John 8:13",
      "text": "Dixerunt ergo ei pharisæi: Tu de teipso testimonium perhibes; testimonium tuum non est verum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "John 8:14",
      "text": "Respondit Jesus, et dixit eis: Et si ego testimonium perhibeo de meipso, verum est testimonium meum: quia scio unde veni et quo vado; vos autem nescitis unde venio aut quo vado.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "John 8:15",
      "text": "Vos secundum carnem judicatis: ego non judico quemquam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "John 8:16",
      "text": "et si judico ego, judicium meum verum est, quia solus non sum: sed ego et qui misit me, Pater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "John 8:17",
      "text": "Et in lege vestra scriptum est, quia duorum hominum testimonium verum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "John 8:18",
      "text": "Ego sum qui testimonium perhibeo de meipso, et testimonium perhibet de me qui misit me, Pater.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "John 8:19",
      "text": "Dicebant ergo ei: Ubi est Pater tuus? Respondit Jesus: Neque me scitis, neque Patrem meum: si me sciretis, forsitan et Patrem meum sciretis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "John 8:20",
      "text": "Hæc verba locutus est Jesus in gazophylacio, docens in templo: et nemo apprehendit eum, quia necdum venerat hora ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "John 8:21",
      "text": "Dixit ergo iterum eis Jesus: Ego vado, et quæretis me, et in peccato vestro moriemini. Quo ego vado, vos non potestis venire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "John 8:22",
      "text": "Dicebant ergo Judæi: Numquid interficiet semetipsum, quia dixit: Quo ego vado, vos non potestis venire?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "John 8:23",
      "text": "Et dicebat eis: Vos de deorsum estis, ego de supernis sum. Vos de mundo hoc estis, ego non sum de hoc mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "John 8:24",
      "text": "Dixi ergo vobis quia moriemini in peccatis vestris: si enim non credideritis quia ego sum, moriemini in peccato vestro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "John 8:25",
      "text": "Dicebant ergo ei: Tu quis es? Dixit eis Jesus: Principium, qui et loquor vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "John 8:26",
      "text": "Multa habeo de vobis loqui, et judicare; sed qui me misit, verax est; et ego quæ audivi ab eo, hæc loquor in mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "John 8:27",
      "text": "Et non cognoverunt quia Patrem ejus dicebat Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "John 8:28",
      "text": "Dixit ergo eis Jesus: Cum exaltaveritis Filium hominis, tunc cognoscetis quia ego sum, et a meipso facio nihil, sed sicut docuit me Pater, hæc loquor:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "John 8:29",
      "text": "et qui me misit, mecum est, et non reliquit me solum: quia ego quæ placita sunt ei, facio semper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "John 8:30",
      "text": "Hæc illo loquente, multi crediderunt in eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "John 8:31",
      "text": "Dicebat ergo Jesus ad eos, qui crediderunt ei, Judæos: Si vos manseritis in sermone meo, vere discipuli mei eritis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "John 8:32",
      "text": "et cognoscetis veritatem, et veritas liberabit vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "John 8:33",
      "text": "Responderunt ei: Semen Abrahæ sumus, et nemini servivimus umquam: quomodo tu dicis: Liberi eritis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "John 8:34",
      "text": "Respondit eis Jesus: Amen, amen dico vobis: quia omnis qui facit peccatum, servus est peccati.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "John 8:35",
      "text": "Servus autem non manet in domo in æternum: filius autem manet in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "John 8:36",
      "text": "Si ergo vos filius liberaverit, vere liberi eritis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "John 8:37",
      "text": "Scio quia filii Abrahæ estis: sed quæritis me interficere, quia sermo meus non capit in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "John 8:38",
      "text": "Ego quod vidi apud Patrem meum, loquor: et vos quæ vidistis apud patrem vestrum, facitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "John 8:39",
      "text": "Responderunt, et dixerunt ei: Pater noster Abraham est. Dicit eis Jesus: Si filii Abrahæ estis, opera Abrahæ facite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 40,
      "referenceLabel": "John 8:40",
      "text": "Nunc autem quæritis me interficere, hominem, qui veritatem vobis locutus sum, quam audivi a Deo: hoc Abraham non fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 41,
      "referenceLabel": "John 8:41",
      "text": "Vos facitis opera patris vestri. Dixerunt itaque ei: Nos ex fornicatione non sumus nati: unum patrem habemus Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.42",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 42,
      "referenceLabel": "John 8:42",
      "text": "Dixit ergo eis Jesus: Si Deus pater vester esset, diligeretis utique et me; ego enim ex Deo processi, et veni: neque enim a meipso veni, sed ille me misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.43",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 43,
      "referenceLabel": "John 8:43",
      "text": "Quare loquelam meam non cognoscitis? Quia non potestis audire sermonem meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.44",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 44,
      "referenceLabel": "John 8:44",
      "text": "Vos ex patre diabolo estis: et desideria patris vestri vultis facere. Ille homicida erat ab initio, et in veritate non stetit: quia non est veritas in eo: cum loquitur mendacium, ex propriis loquitur, quia mendax est, et pater ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.45",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 45,
      "referenceLabel": "John 8:45",
      "text": "Ego autem si veritatem dico, non creditis mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.46",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 46,
      "referenceLabel": "John 8:46",
      "text": "Quis ex vobis arguet me de peccato? si veritatem dico vobis, quare non creditis mihi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.47",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 47,
      "referenceLabel": "John 8:47",
      "text": "Qui ex Deo est, verba Dei audit. Propterea vos non auditis, quia ex Deo non estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.48",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 48,
      "referenceLabel": "John 8:48",
      "text": "Responderunt ergo Judæi, et dixerunt ei: Nonne bene dicimus nos quia Samaritanus es tu, et dæmonium habes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.49",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 49,
      "referenceLabel": "John 8:49",
      "text": "Respondit Jesus: Ego dæmonium non habeo: sed honorifico Patrem meum, et vos inhonorastis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.50",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 50,
      "referenceLabel": "John 8:50",
      "text": "Ego autem non quæro gloriam meam: est qui quærat, et judicet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.51",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 51,
      "referenceLabel": "John 8:51",
      "text": "Amen, amen dico vobis: si quis sermonem meum servaverit, mortem non videbit in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.52",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 52,
      "referenceLabel": "John 8:52",
      "text": "Dixerunt ergo Judæi: Nunc cognovimus quia dæmonium habes. Abraham mortuus est, et prophetæ; et tu dicis: Si quis sermonem meum servaverit, non gustabit mortem in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.53",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 53,
      "referenceLabel": "John 8:53",
      "text": "Numquid tu major es patre nostro Abraham, qui mortuus est? et prophetæ mortui sunt. Quem teipsum facis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.54",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 54,
      "referenceLabel": "John 8:54",
      "text": "Respondit Jesus: Si ego glorifico meipsum, gloria mea nihil est: est Pater meus, qui glorificat me, quem vos dicitis quia Deus vester est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.55",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 55,
      "referenceLabel": "John 8:55",
      "text": "et non cognovistis eum: ego autem novi eum. Et si dixero quia non scio eum, ero similis vobis, mendax. Sed scio eum, et sermonem ejus servo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.56",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 56,
      "referenceLabel": "John 8:56",
      "text": "Abraham pater vester exsultavit ut videret diem meum: vidit, et gavisus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.57",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 57,
      "referenceLabel": "John 8:57",
      "text": "Dixerunt ergo Judæi ad eum: Quinquaginta annos nondum habes, et Abraham vidisti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.58",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 58,
      "referenceLabel": "John 8:58",
      "text": "Dixit eis Jesus: Amen, amen dico vobis, antequam Abraham fieret, ego sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.8.59",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 59,
      "referenceLabel": "John 8:59",
      "text": "Tulerunt ergo lapides, ut jacerent in eum: Jesus autem abscondit se, et exivit de templo.",
      "paragraphStart": false
    }
  ]
}
