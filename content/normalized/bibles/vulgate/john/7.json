{
  "chapter": {
    "id": "vulgate:john.7",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 7,
    "referenceLabel": "John 7",
    "summary": "Source text for John 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.7.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "John 7:1",
      "text": "Post hæc autem ambulabat Jesus in Galilæam: non enim volebat in Judæam ambulare, quia quærebant eum Judæi interficere.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.7.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "John 7:2",
      "text": "Erat autem in proximo dies festus Judæorum, Scenopegia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "John 7:3",
      "text": "Dixerunt autem ad eum fratres ejus: Transi hinc, et vade in Judæam, ut et discipuli tui videant opera tua, quæ facis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "John 7:4",
      "text": "Nemo quippe in occulto quid facit, et quærit ipse in palam esse: si hæc facis, manifesta teipsum mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "John 7:5",
      "text": "Neque enim fratres ejus credebant in eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "John 7:6",
      "text": "Dicit ergo eis Jesus: Tempus meum nondum advenit: tempus autem vestrum semper est paratum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "John 7:7",
      "text": "Non potest mundus odisse vos: me autem odit, quia ego testimonium perhibeo de illo quod opera ejus mala sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "John 7:8",
      "text": "Vos ascendite ad diem festum hunc, ego autem non ascendo ad diem festum istum: quia meum tempus nondum impletum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "John 7:9",
      "text": "Hæc cum dixisset, ipse mansit in Galilæa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "John 7:10",
      "text": "Ut autem ascenderunt fratres ejus, tunc et ipse ascendit ad diem festum non manifeste, sed quasi in occulto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "John 7:11",
      "text": "Judæi ergo quærebant eum in die festo, et dicebant: Ubi est ille?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "John 7:12",
      "text": "Et murmur multum erat in turba de eo. Quidam enim dicebant: Quia bonus est. Alii autem dicebant: Non, sed seducit turbas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "John 7:13",
      "text": "Nemo tamen palam loquebatur de illo propter metum Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "John 7:14",
      "text": "Jam autem die festo mediante, ascendit Jesus in templum, et docebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "John 7:15",
      "text": "Et mirabantur Judæi, dicentes: Quomodo hic litteras scit, cum non didicerit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "John 7:16",
      "text": "Respondit eis Jesus, et dixit: Mea doctrina non est mea, sed ejus qui misit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "John 7:17",
      "text": "Si quis voluerit voluntatem ejus facere, cognoscet de doctrina, utrum ex Deo sit, an ego a meipso loquar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "John 7:18",
      "text": "Qui a semetipso loquitur, gloriam propriam quærit; qui autem quærit gloriam ejus qui misit eum, hic verax est, et injustitia in illo non est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "John 7:19",
      "text": "Nonne Moyses dedit vobis legem: et nemo ex vobis facit legem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "John 7:20",
      "text": "Quid me quæritis interficere? Respondit turba, et dixit: Dæmonium habes: quis te quærit interficere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "John 7:21",
      "text": "Respondit Jesus et dixit eis: Unum opus feci, et omnes miramini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "John 7:22",
      "text": "propterea Moyses dedit vobis circumcisionem (non quia ex Moyse est, sed ex patribus), et in sabbato circumciditis hominem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "John 7:23",
      "text": "Si circumcisionem accipit homo in sabbato, ut non solvatur lex Moysi: mihi indignamini quia totum hominem sanum feci in sabbato?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "John 7:24",
      "text": "Nolite judicare secundum faciem, sed justum judicium judicate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "John 7:25",
      "text": "Dicebant ergo quidam ex Jerosolymis: Nonne hic est, quem quærunt interficere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "John 7:26",
      "text": "et ecce palam loquitur, et nihil ei dicunt. Numquid vere cognoverunt principes quia hic est Christus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "John 7:27",
      "text": "Sed hunc scimus unde sit: Christus autem cum venerit, nemo scit unde sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "John 7:28",
      "text": "Clamabat ergo Jesus in templo docens, et dicens: Et me scitis, et unde sim scitis: et a meipso non veni, sed est verus qui misit me, quem vos nescitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "John 7:29",
      "text": "Ego scio eum: quia ab ipso sum, et ipse me misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "John 7:30",
      "text": "Quærebant ergo eum apprehendere: et nemo misit in illum manus, quia nondum venerat hora ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "John 7:31",
      "text": "De turba autem multi crediderunt in eum, et dicebant: Christus cum venerit, numquid plura signa faciet quam quæ hic facit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "John 7:32",
      "text": "Audierunt pharisæi turbam murmurantem de illo hæc: et miserunt principes et pharisæi ministros ut apprehenderent eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "John 7:33",
      "text": "Dixit ergo eis Jesus: Adhuc modicum tempus vobiscum sum: et vado ad eum qui me misit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "John 7:34",
      "text": "Quæretis me, et non invenietis: et ubi ego sum, vos non potestis venire.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "John 7:35",
      "text": "Dixerunt ergo Judæi ad semetipsos: Quo hic iturus est, quia non inveniemus eum? numquid in dispersionem gentium iturus est, et docturus gentes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "John 7:36",
      "text": "quis est hic sermo, quem dixit: Quæretis me, et non invenietis: et ubi sum ego, vos non potestis venire?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "John 7:37",
      "text": "In novissimo autem die magno festivitatis stabat Jesus, et clamabat dicens: Si quis sitit, veniat ad me et bibat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "John 7:38",
      "text": "Qui credit in me, sicut dicit Scriptura, flumina de ventre ejus fluent aquæ vivæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "John 7:39",
      "text": "Hoc autem dixit de Spiritu, quem accepturi erant credentes in eum: nondum enim erat Spiritus datus, quia Jesus nondum erat glorificatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "John 7:40",
      "text": "Ex illa ergo turba cum audissent hos sermones ejus, dicebant: Hic est vere propheta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 41,
      "referenceLabel": "John 7:41",
      "text": "Alii dicebant: Hic est Christus. Quidam autem dicebant: Numquid a Galilæa venit Christus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.42",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 42,
      "referenceLabel": "John 7:42",
      "text": "nonne Scriptura dicit: Quia ex semine David, et de Bethlehem castello, ubi erat David, venit Christus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.43",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 43,
      "referenceLabel": "John 7:43",
      "text": "Dissensio itaque facta est in turba propter eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.44",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 44,
      "referenceLabel": "John 7:44",
      "text": "Quidam autem ex ipsis volebant apprehendere eum: sed nemo misit super eum manus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.45",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 45,
      "referenceLabel": "John 7:45",
      "text": "Venerunt ergo ministri ad pontifices et pharisæos. Et dixerunt eis illi: Quare non adduxistis illum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.46",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 46,
      "referenceLabel": "John 7:46",
      "text": "Responderunt ministri: Numquam sic locutus est homo, sicut hic homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.47",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 47,
      "referenceLabel": "John 7:47",
      "text": "Responderunt ergo eis pharisæi: Numquid et vos seducti estis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.48",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 48,
      "referenceLabel": "John 7:48",
      "text": "numquid ex principibus aliquis credidit in eum, aut ex pharisæis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.49",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 49,
      "referenceLabel": "John 7:49",
      "text": "sed turba hæc, quæ non novit legem, maledicti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.50",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 50,
      "referenceLabel": "John 7:50",
      "text": "Dixit Nicodemus ad eos, ille qui venit ad eum nocte, qui unus erat ex ipsis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.51",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 51,
      "referenceLabel": "John 7:51",
      "text": "Numquid lex nostra judicat hominem, nisi prius audierit ab ipso, et cognoverit quid faciat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.52",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 52,
      "referenceLabel": "John 7:52",
      "text": "Responderunt, et dixerunt ei: Numquid et tu Galilæus es? scrutare Scripturas, et vide quia a Galilæa propheta non surgit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.7.53",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 53,
      "referenceLabel": "John 7:53",
      "text": "Et reversi sunt unusquisque in domum suam.",
      "paragraphStart": false
    }
  ]
}
