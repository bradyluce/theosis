{
  "chapter": {
    "id": "vulgate:john.6",
    "translationId": "vulgate",
    "bookSlug": "john",
    "chapterNumber": 6,
    "referenceLabel": "John 6",
    "summary": "Source text for John 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:john.6.1",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "John 6:1",
      "text": "Post hæc abiit Jesus trans mare Galilææ, quod est Tiberiadis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:john.6.2",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "John 6:2",
      "text": "et sequebatur eum multitudo magna, quia videbant signa quæ faciebat super his qui infirmabantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.3",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "John 6:3",
      "text": "Subiit ergo in montem Jesus et ibi sedebat cum discipulis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.4",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "John 6:4",
      "text": "Erat autem proximum Pascha dies festus Judæorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.5",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "John 6:5",
      "text": "Cum sublevasset ergo oculos Jesus, et vidisset quia multitudo maxima venit ad eum, dixit ad Philippum: Unde ememus panes, ut manducent hi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.6",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "John 6:6",
      "text": "Hoc autem dicebat tentans eum: ipse enim sciebat quid esset facturus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.7",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "John 6:7",
      "text": "Respondit ei Philippus: Ducentorum denariorum panes non sufficiunt eis, ut unusquisque modicum quid accipiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.8",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "John 6:8",
      "text": "Dicit ei unus ex discipulis ejus, Andreas, frater Simonis Petri:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.9",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "John 6:9",
      "text": "Est puer unus hic qui habet quinque panes hordeaceos et duos pisces: sed hæc quid sunt inter tantos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.10",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "John 6:10",
      "text": "Dixit ergo Jesus: Facite homines discumbere. Erat autem fœnum multum in loco. Discubuerunt ergo viri, numero quasi quinque millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.11",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "John 6:11",
      "text": "Accepit ergo Jesus panes: et cum gratias egisset, distribuit discumbentibus: similiter et ex piscibus quantum volebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.12",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "John 6:12",
      "text": "Ut autem impleti sunt, dixit discipulis suis: Colligite quæ superaverunt fragmenta, ne pereant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.13",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "John 6:13",
      "text": "Collegerunt ergo, et impleverunt duodecim cophinos fragmentorum ex quinque panibus hordeaceis, quæ superfuerunt his qui manducaverant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.14",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "John 6:14",
      "text": "Illi ergo homines cum vidissent quod Jesus fecerat signum, dicebant: Quia hic est vere propheta, qui venturus est in mundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.15",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "John 6:15",
      "text": "Jesus ergo cum cognovisset quia venturi essent ut raperent eum, et facerent eum regem, fugit iterum in montem ipse solus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.16",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "John 6:16",
      "text": "Ut autem sero factum est, descenderunt discipuli ejus ad mare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.17",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "John 6:17",
      "text": "Et cum ascendissent navim, venerunt trans mare in Capharnaum: et tenebræ jam factæ erant et non venerat ad eos Jesus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.18",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "John 6:18",
      "text": "Mare autem, vento magno flante, exsurgebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.19",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "John 6:19",
      "text": "Cum remigassent ergo quasi stadia viginti quinque aut triginta, vident Jesum ambulantem supra mare, et proximum navi fieri, et timuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.20",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "John 6:20",
      "text": "Ille autem dicit eis: Ego sum, nolite timere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.21",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "John 6:21",
      "text": "Voluerunt ergo accipere eum in navim et statim navis fuit ad terram, in quam ibant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.22",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "John 6:22",
      "text": "Altera die, turba, quæ stabat trans mare, vidit quia navicula alia non erat ibi nisi una, et quia non introisset cum discipulis suis Jesus in navim, sed soli discipuli ejus abiissent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.23",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "John 6:23",
      "text": "aliæ vero supervenerunt naves a Tiberiade juxta locum ubi manducaverunt panem, gratias agente Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.24",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "John 6:24",
      "text": "Cum ergo vidisset turba quia Jesus non esset ibi, neque discipuli ejus, ascenderunt in naviculas, et venerunt Capharnaum quærentes Jesum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.25",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "John 6:25",
      "text": "Et cum invenissent eum trans mare, dixerunt ei: Rabbi, quando huc venisti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.26",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "John 6:26",
      "text": "Respondit eis Jesus, et dixit: Amen, amen dico vobis: quæritis me non quia vidistis signa, sed quia manducastis ex panibus et saturati estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.27",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "John 6:27",
      "text": "Operamini non cibum, qui perit, sed qui permanet in vitam æternam, quem Filius hominis dabit vobis. Hunc enim Pater signavit Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.28",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "John 6:28",
      "text": "Dixerunt ergo ad eum: Quid faciemus ut operemur opera Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.29",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "John 6:29",
      "text": "Respondit Jesus, et dixit eis: Hoc est opus Dei, ut credatis in eum quem misit ille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.30",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "John 6:30",
      "text": "Dixerunt ergo ei: Quod ergo tu facis signum ut videamus et credamus tibi? quid operaris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.31",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "John 6:31",
      "text": "Patres nostri manducaverunt manna in deserto, sicut scriptum est: Panem de cælo dedit eis manducare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.32",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "John 6:32",
      "text": "Dixit ergo eis Jesus: Amen, amen dico vobis: non Moyses dedit vobis panem de cælo, sed Pater meus dat vobis panem de cælo verum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.33",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "John 6:33",
      "text": "Panis enim Dei est, qui de cælo descendit, et dat vitam mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.34",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "John 6:34",
      "text": "Dixerunt ergo ad eum: Domine, semper da nobis panem hunc.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.35",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "John 6:35",
      "text": "Dixit autem eis Jesus: Ego sum panis vitæ: qui venit ad me, non esuriet, et qui credit in me, non sitiet umquam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.36",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "John 6:36",
      "text": "Sed dixi vobis quia et vidistis me, et non creditis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.37",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "John 6:37",
      "text": "Omne quod dat mihi Pater, ad me veniet: et eum qui venit ad me, non ejiciam foras:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.38",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "John 6:38",
      "text": "quia descendi de cælo, non ut faciam voluntatem meam, sed voluntatem ejus qui misit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.39",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "John 6:39",
      "text": "Hæc est autem voluntas ejus qui misit me, Patris: ut omne quod dedit mihi, non perdam ex eo, sed resuscitem illud in novissimo die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.40",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 40,
      "referenceLabel": "John 6:40",
      "text": "Hæc est autem voluntas Patris mei, qui misit me: ut omnis qui videt Filium et credit in eum, habeat vitam æternam, et ego resuscitabo eum in novissimo die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.41",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 41,
      "referenceLabel": "John 6:41",
      "text": "Murmurabant ergo Judæi de illo, quia dixisset: Ego sum panis vivus, qui de cælo descendi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.42",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 42,
      "referenceLabel": "John 6:42",
      "text": "et dicebant: Nonne hic est Jesus filius Joseph, cujus nos novimus patrem et matrem? quomodo ergo dicit hic: Quia de cælo descendi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.43",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 43,
      "referenceLabel": "John 6:43",
      "text": "Respondit ergo Jesus, et dixit eis: Nolite murmurare in invicem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.44",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 44,
      "referenceLabel": "John 6:44",
      "text": "nemo potest venire ad me, nisi Pater, qui misit me, traxerit eum; et ego resuscitabo eum in novissimo die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.45",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 45,
      "referenceLabel": "John 6:45",
      "text": "Est scriptum in prophetis: Et erunt omnes docibiles Dei. Omnis qui audivit a Patre, et didicit, venit ad me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.46",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 46,
      "referenceLabel": "John 6:46",
      "text": "Non quia Patrem vidit quisquam, nisi is, qui est a Deo, hic vidit Patrem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.47",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 47,
      "referenceLabel": "John 6:47",
      "text": "Amen, amen dico vobis: qui credit in me, habet vitam æternam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.48",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 48,
      "referenceLabel": "John 6:48",
      "text": "Ego sum panis vitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.49",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 49,
      "referenceLabel": "John 6:49",
      "text": "Patres vestri manducaverunt manna in deserto, et mortui sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.50",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 50,
      "referenceLabel": "John 6:50",
      "text": "Hic est panis de cælo descendens: ut si quis ex ipso manducaverit, non moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.51",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 51,
      "referenceLabel": "John 6:51",
      "text": "Ego sum panis vivus, qui de cælo descendi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.52",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 52,
      "referenceLabel": "John 6:52",
      "text": "Si quis manducaverit ex hoc pane, vivet in æternum: et panis quem ego dabo, caro mea est pro mundi vita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.53",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 53,
      "referenceLabel": "John 6:53",
      "text": "Litigabant ergo Judæi ad invicem, dicentes: Quomodo potest hic nobis carnem suam dare ad manducandum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.54",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 54,
      "referenceLabel": "John 6:54",
      "text": "Dixit ergo eis Jesus: Amen, amen dico vobis: nisi manducaveritis carnem Filii hominis, et biberitis ejus sanguinem, non habebitis vitam in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.55",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 55,
      "referenceLabel": "John 6:55",
      "text": "Qui manducat meam carnem, et bibit meum sanguinem, habet vitam æternam: et ego resuscitabo eum in novissimo die.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.56",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 56,
      "referenceLabel": "John 6:56",
      "text": "Caro enim mea vere est cibus: et sanguis meus, vere est potus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.57",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 57,
      "referenceLabel": "John 6:57",
      "text": "qui manducat meam carnem et bibit meum sanguinem, in me manet, et ego in illo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.58",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 58,
      "referenceLabel": "John 6:58",
      "text": "Sicut misit me vivens Pater, et ego vivo propter Patrem: et qui manducat me, et ipse vivet propter me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.59",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 59,
      "referenceLabel": "John 6:59",
      "text": "Hic est panis qui de cælo descendit. Non sicut manducaverunt patres vestri manna, et mortui sunt. Qui manducat hunc panem, vivet in æternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.60",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 60,
      "referenceLabel": "John 6:60",
      "text": "Hæc dixit in synagoga docens, in Capharnaum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.61",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 61,
      "referenceLabel": "John 6:61",
      "text": "Multi ergo audientes ex discipulis ejus, dixerunt: Durus est hic sermo, et quis potest eum audire?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.62",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 62,
      "referenceLabel": "John 6:62",
      "text": "Sciens autem Jesus apud semetipsum quia murmurarent de hoc discipuli ejus, dixit eis: Hoc vos scandalizat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.63",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 63,
      "referenceLabel": "John 6:63",
      "text": "si ergo videritis Filium hominis ascendentem ubi erat prius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:john.6.64",
      "translationId": "vulgate",
      "bookSlug": "john",
      "chapterNumber": 6,
      "verseNumber": 64,
