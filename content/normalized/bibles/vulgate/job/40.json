{
  "chapter": {
    "id": "vulgate:job.40",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 40,
    "referenceLabel": "Job 40",
    "summary": "Source text for Job 40 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.40.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Job 40:1",
      "text": "Respondens autem Dominus Job de turbine, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.40.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Job 40:2",
      "text": "Accinge sicut vir lumbos tuos: interrogabo te, et indica mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Job 40:3",
      "text": "Numquid irritum facies judicium meum, et condemnabis me, ut tu justificeris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Job 40:4",
      "text": "Et si habes brachium sicut Deus? et si voce simili tonas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Job 40:5",
      "text": "Circumda tibi decorem, et in sublime erigere, et esto gloriosus, et speciosis induere vestibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Job 40:6",
      "text": "Disperge superbos in furore tuo, et respiciens omnem arrogantem humilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Job 40:7",
      "text": "Respice cunctos superbos, et confunde eos, et contere impios in loco suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Job 40:8",
      "text": "Absconde eos in pulvere simul, et facies eorum demerge in foveam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Job 40:9",
      "text": "Et ego confitebor quod salvare te possit dextera tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Job 40:10",
      "text": "Ecce behemoth quem feci tecum, fœnum quasi bos comedet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Job 40:11",
      "text": "Fortitudo ejus in lumbis ejus, et virtus illius in umbilico ventris ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Job 40:12",
      "text": "Stringit caudam suam quasi cedrum; nervi testiculorum ejus perplexi sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Job 40:13",
      "text": "Ossa ejus velut fistulæ æris; cartilago illius quasi laminæ ferreæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Job 40:14",
      "text": "Ipse est principium viarum Dei: qui fecit eum applicabit gladium ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 15,
      "referenceLabel": "Job 40:15",
      "text": "Huic montes herbas ferunt: omnes bestiæ agri ludent ibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 16,
      "referenceLabel": "Job 40:16",
      "text": "Sub umbra dormit in secreto calami, et in locis humentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 17,
      "referenceLabel": "Job 40:17",
      "text": "Protegunt umbræ umbram ejus: circumdabunt eum salices torrentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 18,
      "referenceLabel": "Job 40:18",
      "text": "Ecce absorbebit fluvium, et non mirabitur, et habet fiduciam quod influat Jordanis in os ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 19,
      "referenceLabel": "Job 40:19",
      "text": "In oculis ejus quasi hamo capiet eum, et in sudibus perforabit nares ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 20,
      "referenceLabel": "Job 40:20",
      "text": "An extrahere poteris Leviathan hamo, et fune ligabis linguam ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 21,
      "referenceLabel": "Job 40:21",
      "text": "Numquid pones circulum in naribus ejus, aut armilla perforabis maxillam ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 22,
      "referenceLabel": "Job 40:22",
      "text": "Numquid multiplicabit ad te preces, aut loquetur tibi mollia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 23,
      "referenceLabel": "Job 40:23",
      "text": "Numquid feriet tecum pactum, et accipies eum servum sempiternum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 24,
      "referenceLabel": "Job 40:24",
      "text": "Numquid illudes ei quasi avi, aut ligabis eum ancillis tuis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 25,
      "referenceLabel": "Job 40:25",
      "text": "Concident eum amici? divident illum negotiatores?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 26,
      "referenceLabel": "Job 40:26",
      "text": "Numquid implebis sagenas pelle ejus, et gurgustium piscium capite illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 27,
      "referenceLabel": "Job 40:27",
      "text": "Pone super eum manum tuam: memento belli, nec ultra addas loqui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.40.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 40,
      "verseNumber": 28,
      "referenceLabel": "Job 40:28",
      "text": "Ecce spes ejus frustrabitur eum, et videntibus cunctis præcipitabitur.",
      "paragraphStart": false
    }
  ]
}
