{
  "chapter": {
    "id": "vulgate:job.15",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 15,
    "referenceLabel": "Job 15",
    "summary": "Source text for Job 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.15.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Job 15:1",
      "text": "Respondens autem Eliphaz Themanites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.15.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Job 15:2",
      "text": "Numquid sapiens respondebit quasi in ventum loquens, et implebit ardore stomachum suum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Job 15:3",
      "text": "Arguis verbis eum qui non est æqualis tibi, et loqueris quod tibi non expedit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Job 15:4",
      "text": "Quantum in te est, evacuasti timorem, et tulisti preces coram Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Job 15:5",
      "text": "Docuit enim iniquitas tua os tuum, et imitaris linguam blasphemantium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Job 15:6",
      "text": "Condemnabit te os tuum, et non ego: et labia tua respondebunt tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Job 15:7",
      "text": "Numquid primus homo tu natus es, et ante colles formatus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Job 15:8",
      "text": "numquid consilium Dei audisti, et inferior te erit ejus sapientia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Job 15:9",
      "text": "Quid nosti quod ignoremus? quid intelligis quod nesciamus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Job 15:10",
      "text": "Et senes et antiqui sunt in nobis, multo vetustiores quam patres tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Job 15:11",
      "text": "Numquid grande est ut consoletur te Deus? sed verba tua prava hoc prohibent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Job 15:12",
      "text": "Quid te elevat cor tuum, et quasi magna cogitans attonitos habes oculos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Job 15:13",
      "text": "Quid tumet contra Deum spiritus tuus, ut proferas de ore tuo hujuscemodi sermones?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Job 15:14",
      "text": "Quid est homo ut immaculatus sit, et ut justus appareat natus de muliere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Job 15:15",
      "text": "Ecce inter sanctos ejus nemo immutabilis, et cæli non sunt mundi in conspectu ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Job 15:16",
      "text": "Quanto magis abominabilis et inutilis homo, qui bibit quasi aquam iniquitatem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Job 15:17",
      "text": "Ostendam tibi: audi me: quod vidi, narrabo tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Job 15:18",
      "text": "Sapientes confitentur, et non abscondunt patres suos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Job 15:19",
      "text": "quibus solis data est terra, et non transivit alienus per eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Job 15:20",
      "text": "Cunctis diebus suis impius superbit, et numerus annorum incertus est tyrannidis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Job 15:21",
      "text": "Sonitus terroris semper in auribus illius: et cum pax sit, ille semper insidias suspicatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Job 15:22",
      "text": "Non credit quod reverti possit de tenebris ad lucem, circumspectans undique gladium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Job 15:23",
      "text": "Cum se moverit ad quærendum panem, novit quod paratus sit in manu ejus tenebrarum dies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Job 15:24",
      "text": "Terrebit eum tribulatio, et angustia vallabit eum, sicut regem qui præparatur ad prælium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Job 15:25",
      "text": "Tetendit enim adversus Deum manum suam, et contra Omnipotentem roboratus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Job 15:26",
      "text": "Cucurrit adversus eum erecto collo, et pingui cervice armatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Job 15:27",
      "text": "Operuit faciem ejus crassitudo, et de lateribus ejus arvina dependet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Job 15:28",
      "text": "Habitavit in civitatibus desolatis, et in domibus desertis, quæ in tumulos sunt redactæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Job 15:29",
      "text": "Non ditabitur, nec perseverabit substantia ejus, nec mittet in terra radicem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Job 15:30",
      "text": "Non recedet de tenebris: ramos ejus arefaciet flamma, et auferetur spiritu oris sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Job 15:31",
      "text": "Non credet, frustra errore deceptus, quod aliquo pretio redimendus sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Job 15:32",
      "text": "Antequam dies ejus impleantur peribit, et manus ejus arescent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Job 15:33",
      "text": "Lædetur quasi vinea in primo flore botrus ejus, et quasi oliva projiciens florem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Job 15:34",
      "text": "Congregatio enim hypocritæ sterilis, et ignis devorabit tabernacula eorum qui munera libenter accipiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.15.35",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Job 15:35",
      "text": "Concepit dolorem, et peperit iniquitatem, et uterus ejus præparat dolos.",
      "paragraphStart": false
    }
  ]
}
