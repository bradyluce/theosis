{
  "chapter": {
    "id": "vulgate:job.33",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 33,
    "referenceLabel": "Job 33",
    "summary": "Source text for Job 33 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.33.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Job 33:1",
      "text": "Audi igitur, Job, eloquia mea, et omnes sermones meos ausculta.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.33.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Job 33:2",
      "text": "Ecce aperui os meum: loquatur lingua mea in faucibus meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Job 33:3",
      "text": "Simplici corde meo sermones mei, et sententiam puram labia mea loquentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Job 33:4",
      "text": "Spiritus Dei fecit me, et spiraculum Omnipotentis vivificavit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Job 33:5",
      "text": "Si potes, responde mihi, et adversus faciem meam consiste.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Job 33:6",
      "text": "Ecce, et me sicut et te fecit Deus, et de eodem luto ego quoque formatus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Job 33:7",
      "text": "Verumtamen miraculum meum non te terreat, et eloquentia mea non sit tibi gravis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Job 33:8",
      "text": "Dixisti ergo in auribus meis, et vocem verborum tuorum audivi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Job 33:9",
      "text": "Mundus sum ego, et absque delicto: immaculatus, et non est iniquitas in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Job 33:10",
      "text": "Quia querelas in me reperit, ideo arbitratus est me inimicum sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Job 33:11",
      "text": "Posuit in nervo pedes meos; custodivit omnes semitas meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Job 33:12",
      "text": "Hoc est ergo in quo non es justificatus: respondebo tibi, quia major sit Deus homine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Job 33:13",
      "text": "Adversus eum contendis, quod non ad omnia verba responderit tibi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Job 33:14",
      "text": "Semel loquitur Deus, et secundo idipsum non repetit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Job 33:15",
      "text": "Per somnium, in visione nocturna, quando irruit sopor super homines, et dormiunt in lectulo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Job 33:16",
      "text": "tunc aperit aures virorum, et erudiens eos instruit disciplina,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Job 33:17",
      "text": "ut avertat hominem ab his quæ facit, et liberet eum de superbia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Job 33:18",
      "text": "eruens animam ejus a corruptione, et vitam illius ut non transeat in gladium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Job 33:19",
      "text": "Increpat quoque per dolorem in lectulo, et omnia ossa ejus marcescere facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Job 33:20",
      "text": "Abominabilis ei fit in vita sua panis, et animæ illius cibus ante desiderabilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Job 33:21",
      "text": "Tabescet caro ejus, et ossa, quæ tecta fuerant, nudabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Job 33:22",
      "text": "Appropinquavit corruptioni anima ejus, et vita illius mortiferis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 23,
      "referenceLabel": "Job 33:23",
      "text": "Si fuerit pro eo angelus loquens, unus de millibus, ut annuntiet hominis æquitatem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 24,
      "referenceLabel": "Job 33:24",
      "text": "miserebitur ejus, et dicet: Libera eum, ut non descendat in corruptionem: inveni in quo ei propitier.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 25,
      "referenceLabel": "Job 33:25",
      "text": "Consumpta est caro ejus a suppliciis: revertatur ad dies adolescentiæ suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 26,
      "referenceLabel": "Job 33:26",
      "text": "Deprecabitur Deum, et placabilis ei erit: et videbit faciem ejus in jubilo, et reddet homini justitiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 27,
      "referenceLabel": "Job 33:27",
      "text": "Respiciet homines, et dicet: Peccavi, et vere deliqui, et ut eram dignus, non recepi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 28,
      "referenceLabel": "Job 33:28",
      "text": "Liberavit animam suam, ne pergeret in interitum, sed vivens lucem videret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 29,
      "referenceLabel": "Job 33:29",
      "text": "Ecce hæc omnia operatur Deus tribus vicibus per singulos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 30,
      "referenceLabel": "Job 33:30",
      "text": "ut revocet animas eorum a corruptione, et illuminet luce viventium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 31,
      "referenceLabel": "Job 33:31",
      "text": "Attende, Job, et audi me: et tace, dum ego loquor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 32,
      "referenceLabel": "Job 33:32",
      "text": "Si autem habes quod loquaris, responde mihi: loquere, volo enim te apparere justum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.33.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 33,
      "verseNumber": 33,
      "referenceLabel": "Job 33:33",
      "text": "Quod si non habes, audi me: tace, et docebo te sapientiam.",
      "paragraphStart": false
    }
  ]
}
