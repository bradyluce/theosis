{
  "chapter": {
    "id": "vulgate:job.27",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 27,
    "referenceLabel": "Job 27",
    "summary": "Source text for Job 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.27.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Job 27:1",
      "text": "Addidit quoque Job, assumens parabolam suam, et dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.27.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Job 27:2",
      "text": "Vivit Deus, qui abstulit judicium meum, et Omnipotens, qui ad amaritudinem adduxit animam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Job 27:3",
      "text": "Quia donec superest halitus in me, et spiritus Dei in naribus meis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Job 27:4",
      "text": "non loquentur labia mea iniquitatem, nec lingua mea meditabitur mendacium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Job 27:5",
      "text": "Absit a me ut justos vos esse judicem: donec deficiam, non recedam ab innocentia mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Job 27:6",
      "text": "Justificationem meam, quam cœpi tenere, non deseram: neque enim reprehendit me cor meum in omni vita mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Job 27:7",
      "text": "Sit ut impius, inimicus meus, et adversarius meus quasi iniquus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Job 27:8",
      "text": "Quæ est enim spes hypocritæ, si avare rapiat, et non liberet Deus animam ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Job 27:9",
      "text": "Numquid Deus audiet clamorem ejus, cum venerit super eum angustia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Job 27:10",
      "text": "aut poterit in Omnipotente delectari, et invocare Deum omni tempore?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Job 27:11",
      "text": "Docebo vos per manum Dei quæ Omnipotens habeat, nec abscondam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Job 27:12",
      "text": "Ecce vos omnes nostis: et quid sine causa vana loquimini?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Job 27:13",
      "text": "Hæc est pars hominis impii apud Deum, et hæreditas violentorum, quam ob Omnipotente suscipient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Job 27:14",
      "text": "Si multiplicati fuerint filii ejus, in gladio erunt, et nepotes ejus non saturabuntur pane:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Job 27:15",
      "text": "qui reliqui fuerint ex eo sepelientur in interitu, et viduæ illius non plorabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Job 27:16",
      "text": "Si comportaverit quasi terram argentum, et sicut lutum præparaverit vestimenta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Job 27:17",
      "text": "præparabit quidem, sed justus vestietur illis, et argentum innocens dividet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Job 27:18",
      "text": "Ædificavit sicut tinea domum suam, et sicut custos fecit umbraculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Job 27:19",
      "text": "Dives, cum dormierit, nihil secum auferet: aperiet oculos suos, et nihil inveniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Job 27:20",
      "text": "Apprehendet eum quasi aqua inopia: nocte opprimet eum tempestas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Job 27:21",
      "text": "Tollet eum ventus urens, et auferet, et velut turbo rapiet eum de loco suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Job 27:22",
      "text": "Et mittet super eum, et non parcet: de manu ejus fugiens fugiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.27.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Job 27:23",
      "text": "Stringet super eum manus suas, et sibilabit super illum, intuens locum ejus.",
      "paragraphStart": false
    }
  ]
}
