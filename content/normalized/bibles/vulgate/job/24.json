{
  "chapter": {
    "id": "vulgate:job.24",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 24,
    "referenceLabel": "Job 24",
    "summary": "Source text for Job 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.24.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Job 24:1",
      "text": "Ab Omnipotente non sunt abscondita tempora: qui autem noverunt eum, ignorant dies illius.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.24.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Job 24:2",
      "text": "Alii terminos transtulerunt; diripuerunt greges, et paverunt eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Job 24:3",
      "text": "Asinum pupillorum abegerunt, et abstulerunt pro pignore bovem viduæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Job 24:4",
      "text": "Subverterunt pauperum viam, et oppresserunt pariter mansuetos terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Job 24:5",
      "text": "Alii quasi onagri in deserto egrediuntur ad opus suum: vigilantes ad prædam, præparant panem liberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Job 24:6",
      "text": "Agrum non suum demetunt, et vineam ejus, quem vi oppresserint, vindemiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Job 24:7",
      "text": "Nudos dimittunt homines, indumenta tollentes, quibus non est operimentum in frigore:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Job 24:8",
      "text": "quos imbres montium rigant, et non habentes velamen, amplexantur lapides.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Job 24:9",
      "text": "Vim fecerunt deprædantes pupillos, et vulgum pauperem spoliaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Job 24:10",
      "text": "Nudis et incedentibus absque vestitu, et esurientibus tulerunt spicas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Job 24:11",
      "text": "Inter acervos eorum meridiati sunt, qui calcatis torcularibus sitiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Job 24:12",
      "text": "De civitatibus fecerunt viros gemere, et anima vulneratorum clamavit: et Deus inultum abire non patitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Job 24:13",
      "text": "Ipsi fuerunt rebelles lumini: nescierunt vias ejus, nec reversi sunt per semitas ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Job 24:14",
      "text": "Mane primo consurgit homicida; interficit egenum et pauperem: per noctem vero erit quasi fur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Job 24:15",
      "text": "Oculus adulteri observat caliginem, dicens: Non me videbit oculus: et operiet vultum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Job 24:16",
      "text": "Perfodit in tenebris domos, sicut in die condixerant sibi, et ignoraverunt lucem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Job 24:17",
      "text": "Si subito apparuerit aurora, arbitrantur umbram mortis: et sic in tenebris quasi in luce ambulant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Job 24:18",
      "text": "Levis est super faciem aquæ: maledicta sit pars ejus in terra, nec ambulet per viam vinearum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Job 24:19",
      "text": "Ad nimium calorem transeat ab aquis nivium, et usque ad inferos peccatum illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Job 24:20",
      "text": "Obliviscatur ejus misericordia; dulcedo illius vermes: non sit in recordatione, sed conteratur quasi lignum infructuosum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Job 24:21",
      "text": "Pavit enim sterilem quæ non parit, et viduæ bene non fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Job 24:22",
      "text": "Detraxit fortes in fortitudine sua, et cum steterit, non credet vitæ suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Job 24:23",
      "text": "Dedit ei Deus locum pœnitentiæ, et ille abutitur eo in superbiam: oculi autem ejus sunt in viis illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Job 24:24",
      "text": "Elevati sunt ad modicum, et non subsistent: et humiliabuntur sicut omnia, et auferentur, et sicut summitates spicarum conterentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.24.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Job 24:25",
      "text": "Quod si non est ita, quis me potest arguere esse mentitum, et ponere ante Deum verba mea?",
      "paragraphStart": false
    }
  ]
}
