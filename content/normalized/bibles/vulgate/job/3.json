{
  "chapter": {
    "id": "vulgate:job.3",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 3,
    "referenceLabel": "Job 3",
    "summary": "Source text for Job 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.3.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Job 3:1",
      "text": "Post hæc aperuit Job os suum, et maledixit diei suo,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.3.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Job 3:2",
      "text": "et locutus est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Job 3:3",
      "text": "Pereat dies in qua natus sum, et nox in qua dictum est: Conceptus est homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Job 3:4",
      "text": "Dies ille vertatur in tenebras: non requirat eum Deus desuper, et non illustretur lumine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Job 3:5",
      "text": "Obscurent eum tenebræ et umbra mortis; occupet eum caligo, et involvatur amaritudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Job 3:6",
      "text": "Noctem illam tenebrosus turbo possideat; non computetur in diebus anni, nec numeretur in mensibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Job 3:7",
      "text": "Sit nox illa solitaria, nec laude digna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Job 3:8",
      "text": "Maledicant ei qui maledicunt diei, qui parati sunt suscitare Leviathan.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Job 3:9",
      "text": "Obtenebrentur stellæ caligine ejus; expectet lucem, et non videat, nec ortum surgentis auroræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Job 3:10",
      "text": "Quia non conclusit ostia ventris qui portavit me, nec abstulit mala ab oculis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Job 3:11",
      "text": "Quare non in vulva mortuus sum? egressus ex utero non statim perii?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Job 3:12",
      "text": "Quare exceptus genibus? cur lactatus uberibus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Job 3:13",
      "text": "Nunc enim dormiens silerem, et somno meo requiescerem",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Job 3:14",
      "text": "cum regibus et consulibus terræ, qui ædificant sibi solitudines;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Job 3:15",
      "text": "aut cum principibus qui possident aurum, et replent domos suas argento;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Job 3:16",
      "text": "aut sicut abortivum absconditum non subsisterem, vel qui concepti non viderunt lucem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Job 3:17",
      "text": "Ibi impii cessaverunt a tumultu, et ibi requieverunt fessi robore.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Job 3:18",
      "text": "Et quondam vincti pariter sine molestia, non audierunt vocem exactoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Job 3:19",
      "text": "Parvus et magnus ibi sunt, et servus liber a domino suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Job 3:20",
      "text": "Quare misero data est lux, et vita his qui in amaritudine animæ sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Job 3:21",
      "text": "qui expectant mortem, et non venit, quasi effodientes thesaurum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Job 3:22",
      "text": "gaudentque vehementer cum invenerint sepulchrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Job 3:23",
      "text": "viro cujus abscondita est via et circumdedit eum Deus tenebris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Job 3:24",
      "text": "Antequam comedam, suspiro; et tamquam inundantes aquæ, sic rugitus meus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Job 3:25",
      "text": "quia timor quem timebam evenit mihi, et quod verebar accidit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.3.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Job 3:26",
      "text": "Nonne dissimulavi? nonne silui? nonne quievi? et venit super me indignatio.",
      "paragraphStart": false
    }
  ]
}
