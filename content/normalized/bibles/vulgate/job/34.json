{
  "chapter": {
    "id": "vulgate:job.34",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 34,
    "referenceLabel": "Job 34",
    "summary": "Source text for Job 34 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.34.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Job 34:1",
      "text": "Pronuntians itaque Eliu, etiam hæc locutus est:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.34.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Job 34:2",
      "text": "Audite, sapientes, verba mea: et eruditi, auscultate me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Job 34:3",
      "text": "Auris enim verba probat, et guttur escas gustu dijudicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Job 34:4",
      "text": "Judicium eligamus nobis, et inter nos videamus quid sit melius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Job 34:5",
      "text": "Quia dixit Job: Justus sum, et Deus subvertit judicium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Job 34:6",
      "text": "In judicando enim me mendacium est: violenta sagitta mea absque ullo peccato.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Job 34:7",
      "text": "Quis est vir ut est Job, qui bibit subsannationem quasi aquam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Job 34:8",
      "text": "qui graditur cum operantibus iniquitatem, et ambulat cum viris impiis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Job 34:9",
      "text": "Dixit enim: Non placebit vir Deo, etiam si cucurrerit cum eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Job 34:10",
      "text": "Ideo, viri cordati, audite me: absit a Deo impietas, et ab Omnipotente iniquitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Job 34:11",
      "text": "Opus enim hominis reddet ei, et juxta vias singulorum restituet eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Job 34:12",
      "text": "Vere enim Deus non condemnabit frustra, nec Omnipotens subvertet judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Job 34:13",
      "text": "Quem constituit alium super terram? aut quem posuit super orbem quem fabricatus est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Job 34:14",
      "text": "Si direxerit ad eum cor suum, spiritum illius et flatum ad se trahet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Job 34:15",
      "text": "Deficiet omnis caro simul, et homo in cinerem revertetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Job 34:16",
      "text": "Si habes ergo intellectum, audi quod dicitur, et ausculta vocem eloquii mei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Job 34:17",
      "text": "numquid qui non amat judicium sanari potest? et quomodo tu eum qui justus est in tantum condemnas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Job 34:18",
      "text": "Qui dicit regi: Apostata; qui vocat duces impios;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Job 34:19",
      "text": "qui non accipit personas principum, nec cognovit tyrannum cum disceptaret contra pauperem: opus enim manuum ejus sunt universi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Job 34:20",
      "text": "Subito morientur, et in media nocte turbabuntur populi: et pertransibunt, et auferent violentum absque manu.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Job 34:21",
      "text": "Oculi enim ejus super vias hominum, et omnes gressus eorum considerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Job 34:22",
      "text": "Non sunt tenebræ, et non est umbra mortis, ut abscondantur ibi qui operantur iniquitatem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Job 34:23",
      "text": "neque enim ultra in hominis potestate est, ut veniat ad Deum in judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Job 34:24",
      "text": "Conteret multos, et innumerabiles, et stare faciet alios pro eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Job 34:25",
      "text": "Novit enim opera eorum, et idcirco inducet noctem, et conterentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Job 34:26",
      "text": "Quasi impios percussit eos in loco videntium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Job 34:27",
      "text": "qui quasi de industria recesserunt ab eo, et omnes vias ejus intelligere noluerunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Job 34:28",
      "text": "ut pervenire facerent ad eum clamorem egeni, et audiret vocem pauperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 29,
      "referenceLabel": "Job 34:29",
      "text": "Ipso enim concedente pacem, quis est qui condemnet? ex quo absconderit vultum, quis est qui contempletur eum, et super gentes, et super omnes homines?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 30,
      "referenceLabel": "Job 34:30",
      "text": "Qui regnare facit hominem hypocritam propter peccata populi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 31,
      "referenceLabel": "Job 34:31",
      "text": "Quia ergo ego locutus sum ad Deum, te quoque non prohibebo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 32,
      "referenceLabel": "Job 34:32",
      "text": "Si erravi, tu doce me; si iniquitatem locutus sum, ultra non addam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 33,
      "referenceLabel": "Job 34:33",
      "text": "Numquid a te Deus expetit eam, quia displicuit tibi? tu enim cœpisti loqui, et non ego: quod si quid nosti melius, loquere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 34,
      "referenceLabel": "Job 34:34",
      "text": "Viri intelligentes loquantur mihi, et vir sapiens audiat me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.35",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 35,
      "referenceLabel": "Job 34:35",
      "text": "Job autem stulte locutus est, et verba illius non sonant disciplinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.36",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 36,
      "referenceLabel": "Job 34:36",
      "text": "Pater mi, probetur Job usque ad finem: ne desinas ab homine iniquitatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.34.37",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 34,
      "verseNumber": 37,
      "referenceLabel": "Job 34:37",
      "text": "quia addit super peccata sua blasphemiam, inter nos interim constringatur: et tunc ad judicium provocet sermonibus suis Deum.",
      "paragraphStart": false
    }
  ]
}
