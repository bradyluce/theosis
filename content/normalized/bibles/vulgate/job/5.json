{
  "chapter": {
    "id": "vulgate:job.5",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 5,
    "referenceLabel": "Job 5",
    "summary": "Source text for Job 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.5.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Job 5:1",
      "text": "Voca ergo, si est qui tibi respondeat, et ad aliquem sanctorum convertere.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.5.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Job 5:2",
      "text": "Vere stultum interficit iracundia, et parvulum occidit invidia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Job 5:3",
      "text": "Ego vidi stultum firma radice, et maledixi pulchritudini ejus statim.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Job 5:4",
      "text": "Longe fient filii ejus a salute, et conterentur in porta, et non erit qui eruat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Job 5:5",
      "text": "Cujus messem famelicus comedet, et ipsum rapiet armatus, et bibent sitientes divitias ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Job 5:6",
      "text": "Nihil in terra sine causa fit, et de humo non oritur dolor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Job 5:7",
      "text": "Homo nascitur ad laborem, et avis ad volatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Job 5:8",
      "text": "Quam ob rem ego deprecabor Dominum, et ad Deum ponam eloquium meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Job 5:9",
      "text": "qui facit magna et inscrutabilia, et mirabilia absque numero;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Job 5:10",
      "text": "qui dat pluviam super faciem terræ, et irrigat aquis universa;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Job 5:11",
      "text": "qui ponit humiles in sublime, et mœrentes erigit sospitate;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Job 5:12",
      "text": "qui dissipat cogitationes malignorum, ne possint implere manus eorum quod cœperant;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Job 5:13",
      "text": "qui apprehendit sapientes in astutia eorum, et consilium pravorum dissipat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Job 5:14",
      "text": "Per diem incurrent tenebras, et quasi in nocte, sic palpabunt in meridie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Job 5:15",
      "text": "Porro salvum faciet egenum a gladio oris eorum, et de manu violenti pauperem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Job 5:16",
      "text": "Et erit egeno spes; iniquitas autem contrahet os suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Job 5:17",
      "text": "Beatus homo qui corripitur a Deo: increpationem ergo Domini ne reprobes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Job 5:18",
      "text": "quia ipse vulnerat, et medetur; percutit, et manus ejus sanabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Job 5:19",
      "text": "In sex tribulationibus liberabit te, et in septima non tanget te malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Job 5:20",
      "text": "In fame eruet te de morte, et in bello de manu gladii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Job 5:21",
      "text": "A flagello linguæ absconderis, et non timebis calamitatem cum venerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Job 5:22",
      "text": "In vastitate et fame ridebis, et bestias terræ non formidabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Job 5:23",
      "text": "Sed cum lapidibus regionum pactum tuum, et bestiæ terræ pacificæ erunt tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Job 5:24",
      "text": "Et scies quod pacem habeat tabernaculum tuum; et visitans speciem tuam, non peccabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Job 5:25",
      "text": "Scies quoque quoniam multiplex erit semen tuum, et progenies tua quasi herba terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Job 5:26",
      "text": "Ingredieris in abundantia sepulchrum, sicut infertur acervus tritici in tempore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.5.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Job 5:27",
      "text": "Ecce hoc, ut investigavimus, ita est: quod auditum, mente pertracta.",
      "paragraphStart": false
    }
  ]
}
