{
  "chapter": {
    "id": "vulgate:job.13",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 13,
    "referenceLabel": "Job 13",
    "summary": "Source text for Job 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.13.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Job 13:1",
      "text": "Ecce omnia hæc vidit oculus meus, et audivit auris mea, et intellexi singula.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.13.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Job 13:2",
      "text": "Secundum scientiam vestram et ego novi: nec inferior vestri sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Job 13:3",
      "text": "Sed tamen ad Omnipotentem loquar, et disputare cum Deo cupio:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Job 13:4",
      "text": "prius vos ostendens fabricatores mendacii, et cultores perversorum dogmatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Job 13:5",
      "text": "Atque utinam taceretis, ut putaremini esse sapientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Job 13:6",
      "text": "Audite ergo correptionem meam, et judicium labiorum meorum attendite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Job 13:7",
      "text": "Numquid Deus indiget vestro mendacio, ut pro illo loquamini dolos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Job 13:8",
      "text": "numquid faciem ejus accipitis, et pro Deo judicare nitimini?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Job 13:9",
      "text": "aut placebit ei quem celare nihil potest? aut decipietur, ut homo, vestris fraudulentiis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Job 13:10",
      "text": "Ipse vos arguet, quoniam in abscondito faciem ejus accipitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Job 13:11",
      "text": "Statim ut se commoverit, turbabit vos, et terror ejus irruet super vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Job 13:12",
      "text": "Memoria vestra comparabitur cineri, et redigentur in lutum cervices vestræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Job 13:13",
      "text": "Tacete paulisper, ut loquar quodcumque mihi mens suggesserit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Job 13:14",
      "text": "Quare lacero carnes meas dentibus meis, et animam meam porto in manibus meis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Job 13:15",
      "text": "Etiam si occiderit me, in ipso sperabo: verumtamen vias meas in conspectu ejus arguam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Job 13:16",
      "text": "Et ipse erit salvator meus: non enim veniet in conspectu ejus omnis hypocrita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Job 13:17",
      "text": "Audite sermonem meum, et ænigmata percipite auribus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Job 13:18",
      "text": "Si fuero judicatus, scio quod justus inveniar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Job 13:19",
      "text": "Quis est qui judicetur mecum? veniat: quare tacens consumor?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Job 13:20",
      "text": "Duo tantum ne facias mihi, et tunc a facie tua non abscondar:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Job 13:21",
      "text": "manum tuam longe fac a me, et formido tua non me terreat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Job 13:22",
      "text": "Voca me, et ego respondebo tibi: aut certe loquar, et tu responde mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Job 13:23",
      "text": "Quantas habeo iniquitates et peccata? scelera mea et delicta ostende mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Job 13:24",
      "text": "Cur faciem tuam abscondis, et arbitraris me inimicum tuum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Job 13:25",
      "text": "Contra folium, quod vento rapitur, ostendis potentiam tuam, et stipulam siccam persequeris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Job 13:26",
      "text": "scribis enim contra me amaritudines, et consumere me vis peccatis adolescentiæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Job 13:27",
      "text": "Posuisti in nervo pedem meum, et observasti omnes semitas meas, et vestigia pedum meorum considerasti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.13.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Job 13:28",
      "text": "qui quasi putredo consumendus sum, et quasi vestimentum quod comeditur a tinea.",
      "paragraphStart": false
    }
  ]
}
