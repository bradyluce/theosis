{
  "chapter": {
    "id": "vulgate:job.11",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 11,
    "referenceLabel": "Job 11",
    "summary": "Source text for Job 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.11.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Job 11:1",
      "text": "Respondens autem Sophar Naamathites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.11.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Job 11:2",
      "text": "Numquid qui multa loquitur, non et audiet? aut vir verbosus justificabitur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Job 11:3",
      "text": "Tibi soli tacebunt homines? et cum ceteros irriseris, a nullo confutaberis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Job 11:4",
      "text": "Dixisti enim: Purus est sermo meus, et mundus sum in conspectu tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Job 11:5",
      "text": "Atque utinam Deus loqueretur tecum, et aperiret labia sua tibi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Job 11:6",
      "text": "ut ostenderet tibi secreta sapientiæ, et quod multiplex esset lex ejus: et intelligeres quod multo minora exigaris ab eo quam meretur iniquitas tua!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Job 11:7",
      "text": "Forsitan vestigia Dei comprehendes, et usque ad perfectum Omnipotentem reperies?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Job 11:8",
      "text": "Excelsior cælo est, et quid facies? profundior inferno, et unde cognosces?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Job 11:9",
      "text": "Longior terra mensura ejus, et latior mari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Job 11:10",
      "text": "Si subverterit omnia, vel in unum coarctaverit, quis contradicet ei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Job 11:11",
      "text": "Ipse enim novit hominum vanitatem; et videns iniquitatem, nonne considerat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Job 11:12",
      "text": "Vir vanus in superbiam erigitur, et tamquam pullum onagri se liberum natum putat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Job 11:13",
      "text": "Tu autem firmasti cor tuum, et expandisti ad eum manus tuas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Job 11:14",
      "text": "Si iniquitatem quæ est in manu tua abstuleris a te, et non manserit in tabernaculo tuo injustitia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Job 11:15",
      "text": "tunc levare poteris faciem tuam absque macula; et eris stabilis, et non timebis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Job 11:16",
      "text": "Miseriæ quoque oblivisceris, et quasi aquarum quæ præterierunt recordaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Job 11:17",
      "text": "Et quasi meridianus fulgor consurget tibi ad vesperam; et cum te consumptum putaveris, orieris ut lucifer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Job 11:18",
      "text": "Et habebis fiduciam, proposita tibi spe: et defossus securus dormies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Job 11:19",
      "text": "Requiesces, et non erit qui te exterreat; et deprecabuntur faciem tuam plurimi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.11.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Job 11:20",
      "text": "Oculi autem impiorum deficient, et effugium peribit ab eis: et spes illorum abominatio animæ.",
      "paragraphStart": false
    }
  ]
}
