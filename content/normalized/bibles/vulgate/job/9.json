{
  "chapter": {
    "id": "vulgate:job.9",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 9,
    "referenceLabel": "Job 9",
    "summary": "Source text for Job 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.9.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Job 9:1",
      "text": "Et respondens Job, ait:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.9.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Job 9:2",
      "text": "Vere scio quod ita sit, et quod non justificetur homo compositus Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Job 9:3",
      "text": "Si voluerit contendere cum eo, non poterit ei respondere unum pro mille.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Job 9:4",
      "text": "Sapiens corde est, et fortis robore: quis restitit ei, et pacem habuit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Job 9:5",
      "text": "Qui transtulit montes, et nescierunt hi quos subvertit in furore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Job 9:6",
      "text": "Qui commovet terram de loco suo, et columnæ ejus concutiuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Job 9:7",
      "text": "Qui præcipit soli, et non oritur, et stellas claudit quasi sub signaculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Job 9:8",
      "text": "Qui extendit cælos solus, et graditur super fluctus maris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Job 9:9",
      "text": "Qui facit Arcturum et Oriona, et Hyadas et interiora austri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Job 9:10",
      "text": "Qui facit magna, et incomprehensibilia, et mirabilia, quorum non est numerus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Job 9:11",
      "text": "Si venerit ad me, non videbo eum; si abierit, non intelligam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Job 9:12",
      "text": "Si repente interroget, quis respondebit ei? vel quis dicere potest: Cur ita facis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Job 9:13",
      "text": "Deus, cujus iræ nemo resistere potest, et sub quo curvantur qui portant orbem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Job 9:14",
      "text": "Quantus ergo sum ego, ut respondeam ei, et loquar verbis meis cum eo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Job 9:15",
      "text": "qui etiam si habuero quippiam justum, non respondebo: sed meum judicem deprecabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Job 9:16",
      "text": "Et cum invocantem exaudierit me, non credo quod audierit vocem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Job 9:17",
      "text": "In turbine enim conteret me, et multiplicabit vulnera mea, etiam sine causa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Job 9:18",
      "text": "Non concedit requiescere spiritum meum, et implet me amaritudinibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Job 9:19",
      "text": "Si fortitudo quæritur, robustissimus est; si æquitas judicii, nemo audet pro me testimonium dicere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Job 9:20",
      "text": "Si justificare me voluero, os meum condemnabit me; si innocentem ostendero, pravum me comprobabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Job 9:21",
      "text": "Etiam si simplex fuero, hoc ipsum ignorabit anima mea, et tædebit me vitæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Job 9:22",
      "text": "Unum est quod locutus sum: et innocentem et impium ipse consumit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Job 9:23",
      "text": "Si flagellat, occidat semel, et non de pœnis innocentum rideat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Job 9:24",
      "text": "Terra data est in manus impii; vultum judicum ejus operit. Quod si non ille est, quis ergo est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Job 9:25",
      "text": "Dies mei velociores fuerunt cursore; fugerunt, et non viderunt bonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Job 9:26",
      "text": "Pertransierunt quasi naves poma portantes; sicut aquila volans ad escam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Job 9:27",
      "text": "Cum dixero: Nequaquam ita loquar: commuto faciem meam, et dolore torqueor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Job 9:28",
      "text": "Verebar omnia opera mea, sciens quod non parceres delinquenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Job 9:29",
      "text": "Si autem et sic impius sum, quare frustra laboravi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Job 9:30",
      "text": "Si lotus fuero quasi aquis nivis, et fulserint velut mundissimæ manus meæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Job 9:31",
      "text": "tamen sordibus intinges me, et abominabuntur me vestimenta mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Job 9:32",
      "text": "Neque enim viro qui similis mei est, respondebo; nec qui mecum in judicio ex æquo possit audiri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Job 9:33",
      "text": "Non est qui utrumque valeat arguere, et ponere manum suam in ambobus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Job 9:34",
      "text": "Auferat a me virgam suam, et pavor ejus non me terreat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.9.35",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Job 9:35",
      "text": "Loquar, et non timebo eum; neque enim possum metuens respondere.",
      "paragraphStart": false
    }
  ]
}
