{
  "chapter": {
    "id": "vulgate:job.18",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 18,
    "referenceLabel": "Job 18",
    "summary": "Source text for Job 18 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.18.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Job 18:1",
      "text": "Respondens autem Baldad Suhites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.18.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Job 18:2",
      "text": "Usque ad quem finem verba jactabitis? intelligite prius, et sic loquamur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Job 18:3",
      "text": "Quare reputati sumus ut jumenta, et sorduimus coram vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Job 18:4",
      "text": "Qui perdis animam tuam in furore tuo, numquid propter te derelinquetur terra, et transferentur rupes de loco suo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Job 18:5",
      "text": "Nonne lux impii extinguetur, nec splendebit flamma ignis ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Job 18:6",
      "text": "Lux obtenebrescet in tabernaculo illius, et lucerna quæ super eum est extinguetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Job 18:7",
      "text": "Arctabuntur gressus virtutis ejus, et præcipitabit eum consilium suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Job 18:8",
      "text": "Immisit enim in rete pedes suos, et in maculis ejus ambulat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Job 18:9",
      "text": "Tenebitur planta illius laqueo, et exardescet contra eum sitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Job 18:10",
      "text": "Abscondita est in terra pedica ejus, et decipula illius super semitam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Job 18:11",
      "text": "Undique terrebunt eum formidines, et involvent pedes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Job 18:12",
      "text": "Attenuetur fame robur ejus, et inedia invadat costas illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Job 18:13",
      "text": "Devoret pulchritudinem cutis ejus; consumat brachia illius primogenita mors.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Job 18:14",
      "text": "Avellatur de tabernaculo suo fiducia ejus, et calcet super eum, quasi rex, interitus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Job 18:15",
      "text": "Habitent in tabernaculo illius socii ejus qui non est; aspergatur in tabernaculo ejus sulphur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Job 18:16",
      "text": "Deorsum radices ejus siccentur: sursum autem atteratur messis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Job 18:17",
      "text": "Memoria illius pereat de terra, et non celebretur nomen ejus in plateis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Job 18:18",
      "text": "Expellet eum de luce in tenebras, et de orbe transferet eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Job 18:19",
      "text": "Non erit semen ejus, neque progenies in populo suo, nec ullæ reliquiæ in regionibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Job 18:20",
      "text": "In die ejus stupebunt novissimi, et primos invadet horror.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.18.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Job 18:21",
      "text": "Hæc sunt ergo tabernacula iniqui, et iste locus ejus qui ignorat Deum.",
      "paragraphStart": false
    }
  ]
}
