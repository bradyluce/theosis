{
  "chapter": {
    "id": "vulgate:job.29",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 29,
    "referenceLabel": "Job 29",
    "summary": "Source text for Job 29 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.29.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Job 29:1",
      "text": "Addidit quoque Job, assumens parabolam suam, et dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.29.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Job 29:2",
      "text": "Quis mihi tribuat ut sim juxta menses pristinos, secundum dies quibus Deus custodiebat me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Job 29:3",
      "text": "Quando splendebat lucerna ejus super caput meum, et ad lumen ejus ambulabam in tenebris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Job 29:4",
      "text": "sicut fui in diebus adolescentiæ meæ, quando secreto Deus erat in tabernaculo meo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Job 29:5",
      "text": "quando erat Omnipotens mecum, et in circuitu meo pueri mei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Job 29:6",
      "text": "quando lavabam pedes meos butyro, et petra fundebat mihi rivos olei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Job 29:7",
      "text": "quando procedebam ad portam civitatis, et in platea parabant cathedram mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Job 29:8",
      "text": "Videbant me juvenes, et abscondebantur: et senes assurgentes stabant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Job 29:9",
      "text": "Principes cessabant loqui, et digitum superponebant ori suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Job 29:10",
      "text": "Vocem suam cohibebant duces, et lingua eorum gutturi suo adhærebat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Job 29:11",
      "text": "Auris audiens beatificabat me, et oculus videns testimonium reddebat mihi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Job 29:12",
      "text": "eo quod liberassem pauperem vociferantem, et pupillum cui non esset adjutor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Job 29:13",
      "text": "Benedictio perituri super me veniebat, et cor viduæ consolatus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Job 29:14",
      "text": "Justitia indutus sum, et vestivi me, sicut vestimento et diademate, judicio meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Job 29:15",
      "text": "Oculus fui cæco, et pes claudo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Job 29:16",
      "text": "Pater eram pauperum, et causam quam nesciebam diligentissime investigabam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Job 29:17",
      "text": "Conterebam molas iniqui, et de dentibus illius auferebam prædam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Job 29:18",
      "text": "Dicebamque: In nidulo meo moriar, et sicut palma multiplicabo dies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Job 29:19",
      "text": "Radix mea aperta est secus aquas, et ros morabitur in messione mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Job 29:20",
      "text": "Gloria mea semper innovabitur, et arcus meus in manu mea instaurabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Job 29:21",
      "text": "Qui me audiebant, expectabant sententiam, et intenti tacebant ad consilium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Job 29:22",
      "text": "Verbis meis addere nihil audebant, et super illos stillabat eloquium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Job 29:23",
      "text": "Expectabant me sicut pluviam, et os suum aperiebant quasi ad imbrem serotinum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Job 29:24",
      "text": "Siquando ridebam ad eos, non credebant: et lux vultus mei non cadebat in terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.29.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Job 29:25",
      "text": "Si voluissem ire ad eos, sedebam primus: cumque sederem quasi rex, circumstante exercitu, eram tamen mœrentium consolator.",
      "paragraphStart": false
    }
  ]
}
