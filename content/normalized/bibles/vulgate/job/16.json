{
  "chapter": {
    "id": "vulgate:job.16",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 16,
    "referenceLabel": "Job 16",
    "summary": "Source text for Job 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.16.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Job 16:1",
      "text": "Respondens autem Job, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.16.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Job 16:2",
      "text": "Audivi frequenter talia: consolatores onerosi omnes vos estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Job 16:3",
      "text": "Numquid habebunt finem verba ventosa? aut aliquid tibi molestum est, si loquaris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Job 16:4",
      "text": "Poteram et ego similia vestri loqui, atque utinam esset anima vestra pro anima mea:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Job 16:5",
      "text": "consolarer et ego vos sermonibus, et moverem caput meum super vos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Job 16:6",
      "text": "roborarem vos ore meo, et moverem labia mea, quasi parcens vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Job 16:7",
      "text": "Sed quid agam? Si locutus fuero, non quiescet dolor meus, et si tacuero, non recedet a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Job 16:8",
      "text": "Nunc autem oppressit me dolor meus, et in nihilum redacti sunt omnes artus mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Job 16:9",
      "text": "Rugæ meæ testimonium dicunt contra me, et suscitatur falsiloquus adversus faciem meam, contradicens mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Job 16:10",
      "text": "Collegit furorem suum in me, et comminans mihi, infremuit contra me dentibus suis: hostis meus terribilibus oculis me intuitus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Job 16:11",
      "text": "Aperuerunt super me ora sua, et exprobrantes percusserunt maxillam meam: satiati sunt pœnis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Job 16:12",
      "text": "Conclusit me Deus apud iniquum, et manibus impiorum me tradidit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Job 16:13",
      "text": "Ego ille quondam opulentus, repente contritus sum: tenuit cervicem meam, confregit me, et posuit me sibi quasi in signum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Job 16:14",
      "text": "Circumdedit me lanceis suis; convulneravit lumbos meos: non pepercit, et effudit in terra viscera mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Job 16:15",
      "text": "Concidit me vulnere super vulnus: irruit in me quasi gigas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Job 16:16",
      "text": "Saccum consui super cutem meam, et operui cinere carnem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Job 16:17",
      "text": "Facies mea intumuit a fletu, et palpebræ meæ caligaverunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Job 16:18",
      "text": "Hæc passus sum absque iniquitate manus meæ, cum haberem mundas ad Deum preces.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Job 16:19",
      "text": "Terra, ne operias sanguinem meum, neque inveniat in te locum latendi clamor meus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Job 16:20",
      "text": "ecce enim in cælo testis meus, et conscius meus in excelsis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Job 16:21",
      "text": "Verbosi amici mei: ad Deum stillat oculus meus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Job 16:22",
      "text": "atque utinam sic judicaretur vir cum Deo, quomodo judicatur filius hominis cum collega suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.16.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Job 16:23",
      "text": "Ecce enim breves anni transeunt, et semitam per quam non revertar ambulo.",
      "paragraphStart": false
    }
  ]
}
