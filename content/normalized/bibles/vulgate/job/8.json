{
  "chapter": {
    "id": "vulgate:job.8",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 8,
    "referenceLabel": "Job 8",
    "summary": "Source text for Job 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.8.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Job 8:1",
      "text": "Respondens autem Baldad Suhites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.8.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Job 8:2",
      "text": "Usquequo loqueris talia, et spiritus multiplex sermones oris tui?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Job 8:3",
      "text": "Numquid Deus supplantat judicium? aut Omnipotens subvertit quod justum est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Job 8:4",
      "text": "Etiam si filii tui peccaverunt ei, et dimisit eos in manu iniquitatis suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Job 8:5",
      "text": "tu tamen si diluculo consurrexeris ad Deum, et Omnipotentem fueris deprecatus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Job 8:6",
      "text": "si mundus et rectus incesseris: statim evigilabit ad te, et pacatum reddet habitaculum justitiæ tuæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Job 8:7",
      "text": "in tantum ut si priora tua fuerint parva, et novissima tua multiplicentur nimis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Job 8:8",
      "text": "Interroga enim generationem pristinam, et diligenter investiga patrum memoriam",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Job 8:9",
      "text": "(hesterni quippe sumus, et ignoramus, quoniam sicut umbra dies nostri sunt super terram),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Job 8:10",
      "text": "et ipsi docebunt te, loquentur tibi, et de corde suo proferent eloquia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Job 8:11",
      "text": "Numquid vivere potest scirpus absque humore? aut crescere carectum sine aqua?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Job 8:12",
      "text": "Cum adhuc sit in flore, nec carpatur manu, ante omnes herbas arescit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Job 8:13",
      "text": "Sic viæ omnium qui obliviscuntur Deum, et spes hypocritæ peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Job 8:14",
      "text": "Non ei placebit vecordia sua, et sicut tela aranearum fiducia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Job 8:15",
      "text": "Innitetur super domum suam, et non stabit; fulciet eam, et non consurget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Job 8:16",
      "text": "Humectus videtur antequam veniat sol, et in ortu suo germen ejus egredietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Job 8:17",
      "text": "Super acervum petrarum radices ejus densabuntur, et inter lapides commorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Job 8:18",
      "text": "Si absorbuerit eum de loco suo, negabit eum, et dicet: Non novi te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Job 8:19",
      "text": "Hæc est enim lætitia viæ ejus, ut rursum de terra alii germinentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Job 8:20",
      "text": "Deus non projiciet simplicem, nec porriget manum malignis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Job 8:21",
      "text": "donec impleatur risu os tuum, et labia tua jubilo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.8.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Job 8:22",
      "text": "Qui oderunt te induentur confusione, et tabernaculum impiorum non subsistet.",
      "paragraphStart": false
    }
  ]
}
