{
  "chapter": {
    "id": "vulgate:job.22",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 22,
    "referenceLabel": "Job 22",
    "summary": "Source text for Job 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.22.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Job 22:1",
      "text": "Respondens autem Eliphaz Themanites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.22.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Job 22:2",
      "text": "Numquid Deo potest comparari homo, etiam cum perfectæ fuerit scientiæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Job 22:3",
      "text": "Quid prodest Deo, si justus fueris? aut quid ei confers, si immaculata fuerit via tua?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Job 22:4",
      "text": "Numquid timens arguet te, et veniet tecum in judicium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Job 22:5",
      "text": "et non propter malitiam tuam plurimam, et infinitas iniquitates tuas?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Job 22:6",
      "text": "Abstulisti enim pignus fratrum tuorum sine causa, et nudos spoliasti vestibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Job 22:7",
      "text": "Aquam lasso non dedisti, et esurienti subtraxisti panem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Job 22:8",
      "text": "In fortitudine brachii tui possidebas terram, et potentissimus obtinebas eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Job 22:9",
      "text": "Viduas dimisisti vacuas, et lacertos pupillorum comminuisti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Job 22:10",
      "text": "Propterea circumdatus es laqueis, et conturbat te formido subita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Job 22:11",
      "text": "Et putabas te tenebras non visurum, et impetu aquarum inundantium non oppressum iri?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Job 22:12",
      "text": "an non cogitas quod Deus excelsior cælo sit, et super stellarum verticem sublimetur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Job 22:13",
      "text": "Et dicis: Quid enim novit Deus? et quasi per caliginem judicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Job 22:14",
      "text": "Nubes latibulum ejus, nec nostra considerat, et circa cardines cæli perambulat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Job 22:15",
      "text": "Numquid semitam sæculorum custodire cupis, quam calcaverunt viri iniqui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Job 22:16",
      "text": "qui sublati sunt ante tempus suum, et fluvius subvertit fundamentum eorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Job 22:17",
      "text": "Qui dicebant Deo: Recede a nobis: et quasi nihil posset facere Omnipotens, æstimabant eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Job 22:18",
      "text": "cum ille implesset domos eorum bonis: quorum sententia procul sit a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Job 22:19",
      "text": "Videbunt justi, et lætabuntur, et innocens subsannabit eos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Job 22:20",
      "text": "nonne succisa est erectio eorum? et reliquias eorum devoravit ignis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Job 22:21",
      "text": "Acquiesce igitur ei, et habeto pacem, et per hæc habebis fructus optimos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Job 22:22",
      "text": "Suscipe ex ore illius legem, et pone sermones ejus in corde tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Job 22:23",
      "text": "Si reversus fueris ad Omnipotentem, ædificaberis, et longe facies iniquitatem a tabernaculo tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Job 22:24",
      "text": "Dabit pro terra silicem, et pro silice torrentes aureos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Job 22:25",
      "text": "Eritque Omnipotens contra hostes tuos, et argentum coacervabitur tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Job 22:26",
      "text": "Tunc super Omnipotentem deliciis afflues, et elevabis ad Deum faciem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Job 22:27",
      "text": "Rogabis eum, et exaudiet te, et vota tua reddes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Job 22:28",
      "text": "Decernes rem, et veniet tibi, et in viis tuis splendebit lumen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Job 22:29",
      "text": "Qui enim humiliatus fuerit, erit in gloria, et qui inclinaverit oculos, ipse salvabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.22.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Job 22:30",
      "text": "Salvabitur innocens: salvabitur autem in munditia manuum suarum.",
      "paragraphStart": false
    }
  ]
}
