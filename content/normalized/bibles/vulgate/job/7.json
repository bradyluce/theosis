{
  "chapter": {
    "id": "vulgate:job.7",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 7,
    "referenceLabel": "Job 7",
    "summary": "Source text for Job 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.7.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Job 7:1",
      "text": "Militia est vita hominis super terram, et sicut dies mercenarii dies ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.7.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Job 7:2",
      "text": "Sicut servus desiderat umbram, et sicut mercenarius præstolatur finem operis sui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Job 7:3",
      "text": "sic et ego habui menses vacuos, et noctes laboriosas enumeravi mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Job 7:4",
      "text": "Si dormiero, dicam: Quando consurgam? et rursum expectabo vesperam, et replebor doloribus usque ad tenebras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Job 7:5",
      "text": "Induta est caro mea putredine, et sordibus pulveris cutis mea aruit et contracta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Job 7:6",
      "text": "Dies mei velocius transierunt quam a texente tela succiditur, et consumpti sunt absque ulla spe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Job 7:7",
      "text": "Memento quia ventus est vita mea, et non revertetur oculus meus ut videat bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Job 7:8",
      "text": "Nec aspiciet me visus hominis; oculi tui in me, et non subsistam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Job 7:9",
      "text": "Sicut consumitur nubes, et pertransit, sic qui descenderit ad inferos, non ascendet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Job 7:10",
      "text": "Nec revertetur ultra in domum suam, neque cognoscet eum amplius locus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Job 7:11",
      "text": "Quapropter et ego non parcam ori meo: loquar in tribulatione spiritus mei; confabulabor cum amaritudine animæ meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Job 7:12",
      "text": "Numquid mare ego sum, aut cetus, quia circumdedisti me carcere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Job 7:13",
      "text": "Si dixero: Consolabitur me lectulus meus, et relevabor loquens mecum in strato meo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Job 7:14",
      "text": "terrebis me per somnia, et per visiones horrore concuties.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Job 7:15",
      "text": "Quam ob rem elegit suspendium anima mea, et mortem ossa mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Job 7:16",
      "text": "Desperavi: nequaquam ultra jam vivam: parce mihi, nihil enim sunt dies mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Job 7:17",
      "text": "Quid est homo, quia magnificas eum? aut quid apponis erga eum cor tuum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Job 7:18",
      "text": "Visitas eum diluculo, et subito probas illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Job 7:19",
      "text": "Usquequo non parcis mihi, nec dimittis me ut glutiam salivam meam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Job 7:20",
      "text": "Peccavi; quid faciam tibi, o custos hominum? quare posuisti me contrarium tibi, et factus sum mihimetipsi gravis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.7.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Job 7:21",
      "text": "Cur non tollis peccatum meum, et quare non aufers iniquitatem meam? ecce nunc in pulvere dormiam, et si mane me quæsieris, non subsistam.",
      "paragraphStart": false
    }
  ]
}
