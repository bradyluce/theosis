{
  "chapter": {
    "id": "vulgate:job.6",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 6,
    "referenceLabel": "Job 6",
    "summary": "Source text for Job 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.6.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Job 6:1",
      "text": "Respondens autem Job, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.6.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Job 6:2",
      "text": "Utinam appenderentur peccata mea quibus iram merui, et calamitas quam patior, in statera!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Job 6:3",
      "text": "Quasi arena maris hæc gravior appareret; unde et verba mea dolore sunt plena:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Job 6:4",
      "text": "quia sagittæ Domini in me sunt, quarum indignatio ebibit spiritum meum; et terrores Domini militant contra me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Job 6:5",
      "text": "Numquid rugiet onager cum habuerit herbam? aut mugiet bos cum ante præsepe plenum steterit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Job 6:6",
      "text": "aut poterit comedi insulsum, quod non est sale conditum? aut potest aliquis gustare quod gustatum affert mortem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Job 6:7",
      "text": "Quæ prius nolebat tangere anima mea, nunc, præ angustia, cibi mei sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Job 6:8",
      "text": "Quis det ut veniat petitio mea, et quod expecto tribuat mihi Deus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Job 6:9",
      "text": "et qui cœpit, ipse me conterat; solvat manum suam, et succidat me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Job 6:10",
      "text": "Et hæc mihi sit consolatio, ut affligens me dolore, non parcat, nec contradicam sermonibus Sancti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Job 6:11",
      "text": "Quæ est enim fortitudo mea, ut sustineam? aut quis finis meus, ut patienter agam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Job 6:12",
      "text": "Nec fortitudo lapidum fortitudo mea, nec caro mea ænea est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Job 6:13",
      "text": "Ecce non est auxilium mihi in me, et necessarii quoque mei recesserunt a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Job 6:14",
      "text": "Qui tollit ab amico suo misericordiam, timorem Domini derelinquit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Job 6:15",
      "text": "Fratres mei præterierunt me, sicut torrens qui raptim transit in convallibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Job 6:16",
      "text": "Qui timent pruinam, irruet super eos nix.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Job 6:17",
      "text": "Tempore quo fuerint dissipati, peribunt; et ut incaluerit, solventur de loco suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Job 6:18",
      "text": "Involutæ sunt semitæ gressuum eorum; ambulabunt in vacuum, et peribunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Job 6:19",
      "text": "Considerate semitas Thema, itinera Saba, et expectate paulisper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Job 6:20",
      "text": "Confusi sunt, quia speravi: venerunt quoque usque ad me, et pudore cooperti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Job 6:21",
      "text": "Nunc venistis; et modo videntes plagam meam, timetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Job 6:22",
      "text": "Numquid dixi: Afferte mihi, et de substantia vestra donate mihi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Job 6:23",
      "text": "vel: Liberate me de manu hostis, et de manu robustorum eruite me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Job 6:24",
      "text": "Docete me, et ego tacebo: et si quid forte ignoravi, instruite me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Job 6:25",
      "text": "Quare detraxistis sermonibus veritatis, cum e vobis nullus sit qui possit arguere me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Job 6:26",
      "text": "Ad increpandum tantum eloquia concinnatis, et in ventum verba profertis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Job 6:27",
      "text": "Super pupillum irruitis, et subvertere nitimini amicum vestrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Job 6:28",
      "text": "Verumtamen quod cœpistis explete: præbete aurem, et videte an mentiar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Job 6:29",
      "text": "Respondete, obsecro, absque contentione; et loquentes id quod justum est, judicate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.6.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Job 6:30",
      "text": "Et non invenietis in lingua mea iniquitatem, nec in faucibus meis stultitia personabit.",
      "paragraphStart": false
    }
  ]
}
