{
  "chapter": {
    "id": "vulgate:job.31",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 31,
    "referenceLabel": "Job 31",
    "summary": "Source text for Job 31 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.31.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Job 31:1",
      "text": "Pepigi fœdus cum oculis meis, ut ne cogitarem quidem de virgine.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.31.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Job 31:2",
      "text": "Quam enim partem haberet in me Deus desuper, et hæreditatem Omnipotens de excelsis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Job 31:3",
      "text": "Numquid non perditio est iniquo, et alienatio operantibus injustitiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Job 31:4",
      "text": "Nonne ipse considerat vias meas, et cunctos gressus meos dinumerat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Job 31:5",
      "text": "Si ambulavi in vanitate, et festinavit in dolo pes meus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Job 31:6",
      "text": "appendat me in statera justa, et sciat Deus simplicitatem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Job 31:7",
      "text": "Si declinavit gressus meus de via, et si secutum est oculos meos cor meum, et si manibus meis adhæsit macula,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Job 31:8",
      "text": "seram, et alius comedat, et progenies mea eradicetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Job 31:9",
      "text": "Si deceptum est cor meum super muliere, et si ad ostium amici mei insidiatus sum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Job 31:10",
      "text": "scortum alterius sit uxor mea, et super illam incurventur alii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Job 31:11",
      "text": "Hoc enim nefas est, et iniquitas maxima.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Job 31:12",
      "text": "Ignis est usque ad perditionem devorans, et omnia eradicans genimina.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Job 31:13",
      "text": "Si contempsi subire judicium cum servo meo et ancilla mea, cum disceptarent adversum me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Job 31:14",
      "text": "quid enim faciam cum surrexerit ad judicandum Deus? et cum quæsierit, quid respondebo illi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Job 31:15",
      "text": "Numquid non in utero fecit me, qui et illum operatus est, et formavit me in vulva unus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Job 31:16",
      "text": "Si negavi quod volebant pauperibus, et oculos viduæ expectare feci;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Job 31:17",
      "text": "si comedi buccellam meam solus, et non comedit pupillus ex ea",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Job 31:18",
      "text": "(quia ab infantia mea crevit mecum miseratio, et de utero matris meæ egressa est mecum);",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Job 31:19",
      "text": "si despexi pereuntem, eo quod non habuerit indumentum, et absque operimento pauperem;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Job 31:20",
      "text": "si non benedixerunt mihi latera ejus, et de velleribus ovium mearum calefactus est;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Job 31:21",
      "text": "si levavi super pupillum manum meam, etiam cum viderem me in porta superiorem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Job 31:22",
      "text": "humerus meus a junctura sua cadat, et brachium meum cum suis ossibus confringatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Job 31:23",
      "text": "Semper enim quasi tumentes super me fluctus timui Deum, et pondus ejus ferre non potui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Job 31:24",
      "text": "Si putavi aurum robur meum, et obrizo dixi: Fiducia mea;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Job 31:25",
      "text": "si lætatus sum super multis divitiis meis, et quia plurima reperit manus mea;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Job 31:26",
      "text": "si vidi solem cum fulgeret, et lunam incedentem clare,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Job 31:27",
      "text": "et lætatum est in abscondito cor meum, et osculatus sum manum meam ore meo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Job 31:28",
      "text": "quæ est iniquitas maxima, et negatio contra Deum altissimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Job 31:29",
      "text": "Si gavisus sum ad ruinam ejus qui me oderat, et exsultavi quod invenisset eum malum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Job 31:30",
      "text": "non enim dedi ad peccandum guttur meum, ut expeterem maledicens animam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Job 31:31",
      "text": "Si non dixerunt viri tabernaculi mei: Quis det de carnibus ejus, ut saturemur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 32,
      "referenceLabel": "Job 31:32",
      "text": "foris non mansit peregrinus: ostium meum viatori patuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 33,
      "referenceLabel": "Job 31:33",
      "text": "Si abscondi quasi homo peccatum meum, et celavi in sinu meo iniquitatem meam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 34,
      "referenceLabel": "Job 31:34",
      "text": "si expavi ad multitudinem nimiam, et despectio propinquorum terruit me: et non magis tacui, nec egressus sum ostium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.35",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 35,
      "referenceLabel": "Job 31:35",
      "text": "Quis mihi tribuat auditorem, ut desiderium meum audiat Omnipotens, et librum scribat ipse qui judicat,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.36",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 36,
      "referenceLabel": "Job 31:36",
      "text": "ut in humero meo portem illum, et circumdem illum quasi coronam mihi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.37",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 37,
      "referenceLabel": "Job 31:37",
      "text": "Per singulos gradus meos pronuntiabo illum, et quasi principi offeram eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.38",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 38,
      "referenceLabel": "Job 31:38",
      "text": "Si adversum me terra mea clamat, et cum ipsa sulci ejus deflent:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.39",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 39,
      "referenceLabel": "Job 31:39",
      "text": "si fructus ejus comedi absque pecunia, et animam agricolarum ejus afflixi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.31.40",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 31,
      "verseNumber": 40,
      "referenceLabel": "Job 31:40",
      "text": "pro frumento oriatur mihi tribulus, et pro hordeo spina. Finita sunt verba Job.",
      "paragraphStart": false
    }
  ]
}
