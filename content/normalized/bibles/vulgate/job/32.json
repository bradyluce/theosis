{
  "chapter": {
    "id": "vulgate:job.32",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 32,
    "referenceLabel": "Job 32",
    "summary": "Source text for Job 32 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.32.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Job 32:1",
      "text": "Omiserunt autem tres viri isti respondere Job, eo quod justus sibi videretur.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.32.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Job 32:2",
      "text": "Et iratus indignatusque est Eliu filius Barachel Buzites, de cognatione Ram: iratus est autem adversum Job, eo quod justum se esse diceret coram Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Job 32:3",
      "text": "Porro adversum amicos ejus indignatus est, eo quod non invenissent responsionem rationabilem, sed tantummodo condemnassent Job.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Job 32:4",
      "text": "Igitur Eliu expectavit Job loquentem, eo quod seniores essent qui loquebantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Job 32:5",
      "text": "Cum autem vidisset quod tres respondere non potuissent, iratus est vehementer.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Job 32:6",
      "text": "Respondensque Eliu filius Barachel Buzites, dixit: Junior sum tempore, vos autem antiquiores: idcirco, demisso capite, veritus sum vobis indicare meam sententiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Job 32:7",
      "text": "Sperabam enim quod ætas prolixior loqueretur, et annorum multitudo doceret sapientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Job 32:8",
      "text": "Sed, ut video, spiritus est in hominibus, et inspiratio Omnipotentis dat intelligentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Job 32:9",
      "text": "Non sunt longævi sapientes, nec senes intelligunt judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Job 32:10",
      "text": "Ideo dicam: Audite me: ostendam vobis etiam ego meam sapientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Job 32:11",
      "text": "Expectavi enim sermones vestros; audivi prudentiam vestram, donec disceptaremini sermonibus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Job 32:12",
      "text": "et donec putabam vos aliquid dicere, considerabam: sed, ut video, non est qui possit arguere Job, et respondere ex vobis sermonibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Job 32:13",
      "text": "Ne forte dicatis: Invenimus sapientiam: Deus projecit eum, non homo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Job 32:14",
      "text": "Nihil locutus est mihi: et ego non secundum sermones vestros respondebo illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Job 32:15",
      "text": "Extimuerunt, nec responderunt ultra, abstuleruntque a se eloquia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Job 32:16",
      "text": "Quoniam igitur expectavi, et non sunt locuti: steterunt, nec ultra responderunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Job 32:17",
      "text": "respondebo et ego partem meam, et ostendam scientiam meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Job 32:18",
      "text": "Plenus sum enim sermonibus, et coarctat me spiritus uteri mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Job 32:19",
      "text": "En venter meus quasi mustum absque spiraculo, quod lagunculas novas disrumpit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Job 32:20",
      "text": "Loquar, et respirabo paululum: aperiam labia mea, et respondebo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Job 32:21",
      "text": "Non accipiam personam viri, et Deum homini non æquabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.32.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Job 32:22",
      "text": "Nescio enim quamdiu subsistam, et si post modicum tollat me factor meus.",
      "paragraphStart": false
    }
  ]
}
