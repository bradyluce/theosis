{
  "chapter": {
    "id": "vulgate:job.14",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 14,
    "referenceLabel": "Job 14",
    "summary": "Source text for Job 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.14.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Job 14:1",
      "text": "Homo natus de muliere, brevi vivens tempore, repletur multis miseriis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.14.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Job 14:2",
      "text": "Qui quasi flos egreditur et conteritur, et fugit velut umbra, et numquam in eodem statu permanet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Job 14:3",
      "text": "Et dignum ducis super hujuscemodi aperire oculos tuos, et adducere eum tecum in judicium?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Job 14:4",
      "text": "Quis potest facere mundum de immundo conceptum semine? nonne tu qui solus es?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Job 14:5",
      "text": "Breves dies hominis sunt: numerus mensium ejus apud te est: constituisti terminos ejus, qui præteriri non poterunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Job 14:6",
      "text": "Recede paululum ab eo, ut quiescat, donec optata veniat, sicut mercenarii, dies ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Job 14:7",
      "text": "Lignum habet spem: si præcisum fuerit, rursum virescit, et rami ejus pullulant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Job 14:8",
      "text": "Si senuerit in terra radix ejus, et in pulvere emortuus fuerit truncus illius,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Job 14:9",
      "text": "ad odorem aquæ germinabit, et faciet comam, quasi cum primum plantatum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Job 14:10",
      "text": "Homo vero cum mortuus fuerit, et nudatus, atque consumptus, ubi, quæso, est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Job 14:11",
      "text": "Quomodo si recedant aquæ de mari, et fluvius vacuefactus arescat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Job 14:12",
      "text": "sic homo, cum dormierit, non resurget: donec atteratur cælum, non evigilabit, nec consurget de somno suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Job 14:13",
      "text": "Quis mihi hoc tribuat, ut in inferno protegas me, et abscondas me donec pertranseat furor tuus, et constituas mihi tempus in quo recorderis mei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Job 14:14",
      "text": "Putasne mortuus homo rursum vivat? cunctis diebus quibus nunc milito, expecto donec veniat immutatio mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Job 14:15",
      "text": "Vocabis me, et ego respondebo tibi: operi manuum tuarum porriges dexteram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Job 14:16",
      "text": "Tu quidem gressus meos dinumerasti: sed parce peccatis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Job 14:17",
      "text": "Signasti quasi in sacculo delicta mea, sed curasti iniquitatem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Job 14:18",
      "text": "Mons cadens defluit, et saxum transfertur de loco suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Job 14:19",
      "text": "lapides excavant aquæ, et alluvione paulatim terra consumitur: et hominem ergo similiter perdes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Job 14:20",
      "text": "Roborasti eum paululum, ut in perpetuum transiret: immutabis faciem ejus, et emittes eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Job 14:21",
      "text": "Sive nobiles fuerint filii ejus, sive ignobiles, non intelliget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.14.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Job 14:22",
      "text": "Attamen caro ejus, dum vivet, dolebit, et anima illius super semetipso lugebit.",
      "paragraphStart": false
    }
  ]
}
