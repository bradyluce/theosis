      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Respondens autem Baldad Suhites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.25.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "Potestas et terror apud eum est, qui facit concordiam in sublimibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.25.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Numquid est numerus militum ejus? et super quem non surget lumen illius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.25.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "Numquid justificari potest homo comparatus Deo? aut apparere mundus natus de muliere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.25.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Ecce luna etiam non splendet, et stellæ non sunt mundæ in conspectu ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.25.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "quanto magis homo putredo, et filius hominis vermis?",
      "paragraphStart": false
    }
  ]
}
