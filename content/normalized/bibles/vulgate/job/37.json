{
  "chapter": {
    "id": "vulgate:job.37",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 37,
    "referenceLabel": "Job 37",
    "summary": "Source text for Job 37 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.37.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Job 37:1",
      "text": "Super hoc expavit cor meum, et emotum est de loco suo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.37.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Job 37:2",
      "text": "Audite auditionem in terrore vocis ejus, et sonum de ore illius procedentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Job 37:3",
      "text": "Subter omnes cælos ipse considerat, et lumen illius super terminos terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Job 37:4",
      "text": "Post eum rugiet sonitus; tonabit voce magnitudinis suæ: et non investigabitur, cum audita fuerit vox ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Job 37:5",
      "text": "Tonabit Deus in voce sua mirabiliter, qui facit magna et inscrutabilia;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Job 37:6",
      "text": "qui præcipit nivi ut descendat in terram, et hiemis pluviis, et imbri fortitudinis suæ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Job 37:7",
      "text": "qui in manu omnium hominum signat, ut noverint singuli opera sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Job 37:8",
      "text": "Ingredietur bestia latibulum, et in antro suo morabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Job 37:9",
      "text": "Ab interioribus egredietur tempestas, et ab Arcturo frigus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Job 37:10",
      "text": "Flante Deo, concrescit gelu, et rursum latissimæ funduntur aquæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Job 37:11",
      "text": "Frumentum desiderat nubes, et nubes spargunt lumen suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Job 37:12",
      "text": "Quæ lustrant per circuitum, quocumque eas voluntas gubernantis duxerit, ad omne quod præceperit illis super faciem orbis terrarum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Job 37:13",
      "text": "sive in una tribu, sive in terra sua, sive in quocumque loco misericordiæ suæ eas jusserit inveniri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Job 37:14",
      "text": "Ausculta hæc, Job: sta, et considera mirabilia Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Job 37:15",
      "text": "Numquid scis quando præceperit Deus pluviis, ut ostenderent lucem nubium ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Job 37:16",
      "text": "Numquid nosti semitas nubium magnas, et perfectas scientias?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Job 37:17",
      "text": "Nonne vestimenta tua calida sunt, cum perflata fuerit terra austro?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Job 37:18",
      "text": "Tu forsitan cum eo fabricatus es cælos, qui solidissimi quasi ære fusi sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Job 37:19",
      "text": "Ostende nobis quid dicamus illi: nos quippe involvimur tenebris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Job 37:20",
      "text": "Quis narrabit ei quæ loquor? etiam si locutus fuerit homo, devorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Job 37:21",
      "text": "At nunc non vident lucem: subito aër cogetur in nubes, et ventus transiens fugabit eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Job 37:22",
      "text": "Ab aquilone aurum venit, et ad Deum formidolosa laudatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Job 37:23",
      "text": "Digne eum invenire non possumus: magnus fortitudine, et judicio, et justitia: et enarrari non potest.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.37.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Job 37:24",
      "text": "Ideo timebunt eum viri, et non audebunt contemplari omnes qui sibi videntur esse sapientes.",
      "paragraphStart": false
    }
  ]
}
