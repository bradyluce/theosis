{
  "chapter": {
    "id": "vulgate:job.4",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 4,
    "referenceLabel": "Job 4",
    "summary": "Source text for Job 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.4.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Job 4:1",
      "text": "Respondens autem Eliphaz Themanites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.4.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Job 4:2",
      "text": "Si cœperimus loqui tibi, forsitan moleste accipies; sed conceptum sermonem tenere quis poterit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Job 4:3",
      "text": "Ecce docuisti multos, et manus lassas roborasti;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Job 4:4",
      "text": "vacillantes confirmaverunt sermones tui, et genua trementia confortasti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Job 4:5",
      "text": "Nunc autem venit super te plaga, et defecisti; tetigit te, et conturbatus es.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Job 4:6",
      "text": "Ubi est timor tuus, fortitudo tua, patientia tua, et perfectio viarum tuarum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Job 4:7",
      "text": "Recordare, obsecro te, quis umquam innocens periit? aut quando recti deleti sunt?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Job 4:8",
      "text": "Quin potius vidi eos qui operantur iniquitatem, et seminant dolores, et metunt eos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Job 4:9",
      "text": "flante Deo perisse, et spiritu iræ ejus esse consumptos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Job 4:10",
      "text": "Rugitus leonis, et vox leænæ, et dentes catulorum leonum contriti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Job 4:11",
      "text": "Tigris periit, eo quod non haberet prædam, et catuli leonis dissipati sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Job 4:12",
      "text": "Porro ad me dictum est verbum absconditum, et quasi furtive suscepit auris mea venas susurri ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Job 4:13",
      "text": "In horrore visionis nocturnæ, quando solet sopor occupare homines,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Job 4:14",
      "text": "pavor tenuit me, et tremor, et omnia ossa mea perterrita sunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Job 4:15",
      "text": "et cum spiritus, me præsente, transiret, inhorruerunt pili carnis meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Job 4:16",
      "text": "Stetit quidam, cujus non agnoscebam vultum, imago coram oculis meis, et vocem quasi auræ lenis audivi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Job 4:17",
      "text": "Numquid homo, Dei comparatione, justificabitur? aut factore suo purior erit vir?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Job 4:18",
      "text": "Ecce qui serviunt ei, non sunt stabiles, et in angelis suis reperit pravitatem;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Job 4:19",
      "text": "quanto magis hi qui habitant domos luteas, qui terrenum habent fundamentum, consumentur velut a tinea?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Job 4:20",
      "text": "De mane usque ad vesperam succidentur; et quia nullus intelligit, in æternum peribunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.4.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Job 4:21",
      "text": "Qui autem reliqui fuerint, auferentur ex eis; morientur, et non in sapientia.",
      "paragraphStart": false
    }
  ]
}
