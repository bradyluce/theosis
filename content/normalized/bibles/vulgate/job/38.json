{
  "chapter": {
    "id": "vulgate:job.38",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 38,
    "referenceLabel": "Job 38",
    "summary": "Source text for Job 38 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.38.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Job 38:1",
      "text": "Respondens autem Dominus Job de turbine, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.38.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Job 38:2",
      "text": "Quis est iste involvens sententias sermonibus imperitis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Job 38:3",
      "text": "Accinge sicut vir lumbos tuos: interrogabo te, et responde mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Job 38:4",
      "text": "Ubi eras quando ponebam fundamenta terræ? indica mihi, si habes intelligentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Job 38:5",
      "text": "Quis posuit mensuras ejus, si nosti? vel quis tetendit super eam lineam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Job 38:6",
      "text": "Super quo bases illius solidatæ sunt? aut quis demisit lapidem angularem ejus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Job 38:7",
      "text": "cum me laudarent simul astra matutina, et jubilarent omnes filii Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Job 38:8",
      "text": "Quis conclusit ostiis mare, quando erumpebat quasi de vulva procedens;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Job 38:9",
      "text": "cum ponerem nubem vestimentum ejus, et caligine illud quasi pannis infantiæ obvolverem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Job 38:10",
      "text": "Circumdedi illud terminis meis, et posui vectem et ostia,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Job 38:11",
      "text": "et dixi: Usque huc venies, et non procedes amplius, et hic confringes tumentes fluctus tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Job 38:12",
      "text": "Numquid post ortum tuum præcepisti diluculo, et ostendisti auroræ locum suum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Job 38:13",
      "text": "Et tenuisti concutiens extrema terræ, et excussisti impios ex ea?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Job 38:14",
      "text": "Restituetur ut lutum signaculum, et stabit sicut vestimentum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Job 38:15",
      "text": "auferetur ab impiis lux sua, et brachium excelsum confringetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Job 38:16",
      "text": "Numquid ingressus es profunda maris, et in novissimis abyssi deambulasti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Job 38:17",
      "text": "Numquid apertæ sunt tibi portæ mortis, et ostia tenebrosa vidisti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Job 38:18",
      "text": "Numquid considerasti latitudinem terræ? indica mihi, si nosti, omnia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Job 38:19",
      "text": "in qua via lux habitet, et tenebrarum quis locus sit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Job 38:20",
      "text": "ut ducas unumquodque ad terminos suos, et intelligas semitas domus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Job 38:21",
      "text": "Sciebas tunc quod nasciturus esses, et numerum dierum tuorum noveras?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Job 38:22",
      "text": "Numquid ingressus es thesauros nivis, aut thesauros grandinis aspexisti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 23,
      "referenceLabel": "Job 38:23",
      "text": "quæ præparavi in tempus hostis, in diem pugnæ et belli?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 24,
      "referenceLabel": "Job 38:24",
      "text": "Per quam viam spargitur lux, dividitur æstus super terram?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 25,
      "referenceLabel": "Job 38:25",
      "text": "Quis dedit vehementissimo imbri cursum, et viam sonantis tonitrui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 26,
      "referenceLabel": "Job 38:26",
      "text": "ut plueret super terram absque homine in deserto, ubi nullus mortalium commoratur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 27,
      "referenceLabel": "Job 38:27",
      "text": "ut impleret inviam et desolatam, et produceret herbas virentes?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 28,
      "referenceLabel": "Job 38:28",
      "text": "Quis est pluviæ pater? vel quis genuit stillas roris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 29,
      "referenceLabel": "Job 38:29",
      "text": "De cujus utero egressa est glacies? et gelu de cælo quis genuit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 30,
      "referenceLabel": "Job 38:30",
      "text": "In similitudinem lapidis aquæ durantur, et superficies abyssi constringitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 31,
      "referenceLabel": "Job 38:31",
      "text": "Numquid conjungere valebis micantes stellas Pleiadas, aut gyrum Arcturi poteris dissipare?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 32,
      "referenceLabel": "Job 38:32",
      "text": "Numquid producis luciferum in tempore suo, et vesperum super filios terræ consurgere facis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 33,
      "referenceLabel": "Job 38:33",
      "text": "Numquid nosti ordinem cæli, et pones rationem ejus in terra?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 34,
      "referenceLabel": "Job 38:34",
      "text": "Numquid elevabis in nebula vocem tuam, et impetus aquarum operiet te?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.35",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 35,
      "referenceLabel": "Job 38:35",
      "text": "Numquid mittes fulgura, et ibunt, et revertentia dicent tibi: Adsumus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.36",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 36,
      "referenceLabel": "Job 38:36",
      "text": "Quis posuit in visceribus hominis sapientiam? vel quis dedit gallo intelligentiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.37",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 37,
      "referenceLabel": "Job 38:37",
      "text": "Quis enarrabit cælorum rationem? et concentum cæli quis dormire faciet?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.38",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 38,
      "referenceLabel": "Job 38:38",
      "text": "Quando fundebatur pulvis in terra, et glebæ compingebantur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.39",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 39,
      "referenceLabel": "Job 38:39",
      "text": "Numquid capies leænæ prædam, et animam catulorum ejus implebis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.40",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 40,
      "referenceLabel": "Job 38:40",
      "text": "quando cubant in antris, et in specubus insidiantur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.38.41",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 38,
      "verseNumber": 41,
      "referenceLabel": "Job 38:41",
      "text": "Quis præparat corvo escam suam, quando pulli ejus clamant ad Deum, vagantes, eo quod non habeant cibos?",
      "paragraphStart": false
    }
  ]
}
