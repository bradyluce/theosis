{
  "chapter": {
    "id": "vulgate:job.21",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 21,
    "referenceLabel": "Job 21",
    "summary": "Source text for Job 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.21.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Job 21:1",
      "text": "Respondens autem Job, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.21.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Job 21:2",
      "text": "Audite, quæso, sermones meos, et agite pœnitentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Job 21:3",
      "text": "Sustinete me, et ego loquar: et post mea, si videbitur, verba, ridete.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Job 21:4",
      "text": "Numquid contra hominem disputatio mea est, ut merito non debeam contristari?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Job 21:5",
      "text": "Attendite me et obstupescite, et superponite digitum ori vestro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Job 21:6",
      "text": "Et ego, quando recordatus fuero, pertimesco, et concutit carnem meam tremor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Job 21:7",
      "text": "Quare ergo impii vivunt, sublevati sunt, confortatique divitiis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Job 21:8",
      "text": "Semen eorum permanet coram eis: propinquorum turba et nepotum in conspectu eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Job 21:9",
      "text": "Domus eorum securæ sunt et pacatæ, et non est virga Dei super illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Job 21:10",
      "text": "Bos eorum concepit, et non abortivit: vacca peperit, et non est privata fœtu suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Job 21:11",
      "text": "Egrediuntur quasi greges parvuli eorum, et infantes eorum exultant lusibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Job 21:12",
      "text": "Tenent tympanum et citharam, et gaudent ad sonitum organi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Job 21:13",
      "text": "Ducunt in bonis dies suos, et in puncto ad inferna descendunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Job 21:14",
      "text": "Qui dixerunt Deo: Recede a nobis, et scientiam viarum tuarum nolumus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Job 21:15",
      "text": "Quis est Omnipotens, ut serviamus ei? et quid nobis prodest si oraverimus illum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Job 21:16",
      "text": "Verumtamen quia non sunt in manu eorum bona sua, consilium impiorum longe sit a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Job 21:17",
      "text": "Quoties lucerna impiorum extinguetur, et superveniet eis inundatio, et dolores dividet furoris sui?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Job 21:18",
      "text": "Erunt sicut paleæ ante faciem venti, et sicut favilla quam turbo dispergit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Job 21:19",
      "text": "Deus servabit filiis illius dolorem patris, et cum reddiderit, tunc sciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Job 21:20",
      "text": "Videbunt oculi ejus interfectionem suam, et de furore Omnipotentis bibet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Job 21:21",
      "text": "Quid enim ad eum pertinet de domo sua post se, et si numerus mensium ejus dimidietur?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Job 21:22",
      "text": "Numquid Deus docebit quispiam scientiam, qui excelsos judicat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Job 21:23",
      "text": "Iste moritur robustus et sanus, dives et felix:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Job 21:24",
      "text": "viscera ejus plena sunt adipe, et medullis ossa illius irrigantur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Job 21:25",
      "text": "alius vero moritur in amaritudine animæ absque ullis opibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Job 21:26",
      "text": "et tamen simul in pulvere dormient, et vermes operient eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Job 21:27",
      "text": "Certe novi cogitationes vestras, et sententias contra me iniquas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Job 21:28",
      "text": "Dicitis enim: Ubi est domus principis? et ubi tabernacula impiorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Job 21:29",
      "text": "Interrogate quemlibet de viatoribus, et hæc eadem illum intelligere cognoscetis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Job 21:30",
      "text": "quia in diem perditionis servatur malus, et ad diem furoris ducetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Job 21:31",
      "text": "Quis arguet coram eo viam ejus? et quæ fecit, quis reddet illi?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Job 21:32",
      "text": "Ipse ad sepulchra ducetur, et in congerie mortuorum vigilabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 33,
      "referenceLabel": "Job 21:33",
      "text": "Dulcis fuit glareis Cocyti, et post se omnem hominem trahet, et ante se innumerabiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.21.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 21,
      "verseNumber": 34,
      "referenceLabel": "Job 21:34",
      "text": "Quomodo igitur consolamini me frustra, cum responsio vestra repugnare ostensa sit veritati?",
      "paragraphStart": false
    }
  ]
}
