{
  "chapter": {
    "id": "vulgate:job.23",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 23,
    "referenceLabel": "Job 23",
    "summary": "Source text for Job 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.23.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Job 23:1",
      "text": "Respondens autem Job, ait:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.23.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Job 23:2",
      "text": "Nunc quoque in amaritudine est sermo meus, et manus plagæ meæ aggravata est super gemitum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Job 23:3",
      "text": "Quis mihi tribuat ut cognoscam et inveniam illum, et veniam usque ad solium ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Job 23:4",
      "text": "Ponam coram eo judicium, et os meum replebo increpationibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Job 23:5",
      "text": "ut sciam verba quæ mihi respondeat, et intelligam quid loquatur mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Job 23:6",
      "text": "Nolo multa fortitudine contendat mecum, nec magnitudinis suæ mole me premat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Job 23:7",
      "text": "Proponat æquitatem contra me, et perveniat ad victoriam judicium meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Job 23:8",
      "text": "Si ad orientem iero, non apparet; si ad occidentem, non intelligam eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Job 23:9",
      "text": "Si ad sinistram, quid agam? non apprehendam eum; si me vertam ad dexteram, non videbo illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Job 23:10",
      "text": "Ipse vero scit viam meam, et probavit me quasi aurum quod per ignem transit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Job 23:11",
      "text": "Vestigia ejus secutus est pes meus: viam ejus custodivi, et non declinavi ex ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Job 23:12",
      "text": "A mandatis labiorum ejus non recessi, et in sinu meo abscondi verba oris ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Job 23:13",
      "text": "Ipse enim solus est, et nemo avertere potest cogitationem ejus: et anima ejus quodcumque voluit, hoc fecit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Job 23:14",
      "text": "Cum expleverit in me voluntatem suam, et alia multa similia præsto sunt ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Job 23:15",
      "text": "Et idcirco a facie ejus turbatus sum, et considerans eum, timore sollicitor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Job 23:16",
      "text": "Deus mollivit cor meum, et Omnipotens conturbavit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.23.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Job 23:17",
      "text": "Non enim perii propter imminentes tenebras, nec faciem meam operuit caligo.",
      "paragraphStart": false
    }
  ]
}
