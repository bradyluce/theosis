{
  "chapter": {
    "id": "vulgate:job.26",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 26,
    "referenceLabel": "Job 26",
    "summary": "Source text for Job 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.26.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Job 26:1",
      "text": "Respondens autem Job dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.26.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Job 26:2",
      "text": "Cujus adjutor es? numquid imbecillis? et sustentas brachium ejus qui non est fortis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Job 26:3",
      "text": "Cui dedisti consilium? forsitan illi qui non habet sapientiam: et prudentiam tuam ostendisti plurimam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Job 26:4",
      "text": "Quem docere voluisti? nonne eum qui fecit spiramentum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Job 26:5",
      "text": "Ecce gigantes gemunt sub aquis, et qui habitant cum eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Job 26:6",
      "text": "Nudus est infernus coram illo, et nullum est operimentum perditioni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Job 26:7",
      "text": "Qui extendit aquilonem super vacuum, et appendit terram super nihilum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Job 26:8",
      "text": "Qui ligat aquas in nubibus suis, ut non erumpant pariter deorsum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Job 26:9",
      "text": "Qui tenet vultum solii sui, et expandit super illud nebulam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Job 26:10",
      "text": "Terminum circumdedit aquis, usque dum finiantur lux et tenebræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Job 26:11",
      "text": "Columnæ cæli contremiscunt, et pavent ad nutum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Job 26:12",
      "text": "In fortitudine illius repente maria congregata sunt, et prudentia ejus percussit superbum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Job 26:13",
      "text": "Spiritus ejus ornavit cælos, et obstetricante manu ejus, eductus est coluber tortuosus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.26.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Job 26:14",
      "text": "Ecce hæc ex parte dicta sunt viarum ejus: et cum vix parvam stillam sermonis ejus audierimus, quis poterit tonitruum magnitudinis illius intueri?",
      "paragraphStart": false
    }
  ]
}
