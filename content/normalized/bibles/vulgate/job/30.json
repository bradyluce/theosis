{
  "chapter": {
    "id": "vulgate:job.30",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 30,
    "referenceLabel": "Job 30",
    "summary": "Source text for Job 30 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.30.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Job 30:1",
      "text": "Nunc autem derident me juniores tempore, quorum non dignabar patres ponere cum canibus gregis mei:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.30.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Job 30:2",
      "text": "quorum virtus manuum mihi erat pro nihilo, et vita ipsa putabantur indigni:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Job 30:3",
      "text": "egestate et fame steriles, qui rodebant in solitudine, squallentes calamitate et miseria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Job 30:4",
      "text": "Et mandebant herbas, et arborum cortices, et radix juniperorum erat cibus eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Job 30:5",
      "text": "qui de convallibus ista rapientes, cum singula reperissent, ad ea cum clamore currebant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Job 30:6",
      "text": "In desertis habitabant torrentium, et in cavernis terræ, vel super glaream:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Job 30:7",
      "text": "qui inter hujuscemodi lætabantur, et esse sub sentibus delicias computabant:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Job 30:8",
      "text": "filii stultorum et ignobilium, et in terra penitus non parentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Job 30:9",
      "text": "Nunc in eorum canticum versus sum, et factus sum eis in proverbium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Job 30:10",
      "text": "Abominantur me, et longe fugiunt a me, et faciem meam conspuere non verentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Job 30:11",
      "text": "Pharetram enim suam aperuit, et afflixit me, et frenum posuit in os meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Job 30:12",
      "text": "Ad dexteram orientis calamitates meæ illico surrexerunt: pedes meos subverterunt, et oppresserunt quasi fluctibus semitis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Job 30:13",
      "text": "Dissipaverunt itinera mea; insidiati sunt mihi, et prævaluerunt: et non fuit qui ferret auxilium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Job 30:14",
      "text": "Quasi rupto muro, et aperta janua, irruerunt super me, et ad meas miserias devoluti sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Job 30:15",
      "text": "Redactus sum in nihilum: abstulisti quasi ventus desiderium meum, et velut nubes pertransiit salus mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Job 30:16",
      "text": "Nunc autem in memetipso marcescit anima mea, et possident me dies afflictionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Job 30:17",
      "text": "Nocte os meum perforatur doloribus, et qui me comedunt, non dormiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Job 30:18",
      "text": "In multitudine eorum consumitur vestimentum meum, et quasi capitio tunicæ succinxerunt me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Job 30:19",
      "text": "Comparatus sum luto, et assimilatus sum favillæ et cineri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Job 30:20",
      "text": "Clamo ad te, et non exaudis me: sto, et non respicis me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Job 30:21",
      "text": "Mutatus es mihi in crudelem, et in duritia manus tuæ adversaris mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Job 30:22",
      "text": "Elevasti me, et quasi super ventum ponens; elisisti me valide.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Job 30:23",
      "text": "Scio quia morti trades me, ubi constituta est domus omni viventi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Job 30:24",
      "text": "Verumtamen non ad consumptionem eorum emittis manum tuam: et si corruerint, ipse salvabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Job 30:25",
      "text": "Flebam quondam super eo qui afflictus erat, et compatiebatur anima mea pauperi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Job 30:26",
      "text": "Expectabam bona, et venerunt mihi mala: præstolabar lucem, et eruperunt tenebræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Job 30:27",
      "text": "Interiora mea efferbuerunt absque ulla requie: prævenerunt me dies afflictionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Job 30:28",
      "text": "Mœrens incedebam sine furore; consurgens, in turba clamabam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Job 30:29",
      "text": "Frater fui draconum, et socius struthionum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Job 30:30",
      "text": "Cutis mea denigrata est super me, et ossa mea aruerunt præ caumate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.30.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Job 30:31",
      "text": "Versa est in luctum cithara mea, et organum meum in vocem flentium.",
      "paragraphStart": false
    }
  ]
}
