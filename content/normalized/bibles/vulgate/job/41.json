{
  "chapter": {
    "id": "vulgate:job.41",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 41,
    "referenceLabel": "Job 41",
    "summary": "Source text for Job 41 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.41.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Job 41:1",
      "text": "Non quasi crudelis suscitabo eum: quis enim resistere potest vultui meo?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.41.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Job 41:2",
      "text": "Quis ante dedit mihi, ut reddam ei? omnia quæ sub cælo sunt, mea sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Job 41:3",
      "text": "Non parcam ei, et verbis potentibus, et ad deprecandum compositis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Job 41:4",
      "text": "Quis revelabit faciem indumenti ejus? et in medium oris ejus quis intrabit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Job 41:5",
      "text": "Portas vultus ejus quis aperiet? per gyrum dentium ejus formido.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Job 41:6",
      "text": "Corpus illius quasi scuta fusilia, compactum squamis se prementibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Job 41:7",
      "text": "Una uni conjungitur, et ne spiraculum quidem incedit per eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Job 41:8",
      "text": "Una alteri adhærebit, et tenentes se nequaquam separabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Job 41:9",
      "text": "Sternutatio ejus splendor ignis, et oculi ejus ut palpebræ diluculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Job 41:10",
      "text": "De ore ejus lampades procedunt, sicut tædæ ignis accensæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Job 41:11",
      "text": "De naribus ejus procedit fumus, sicut ollæ succensæ atque ferventis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Job 41:12",
      "text": "Halitus ejus prunas ardere facit, et flamma de ore ejus egreditur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Job 41:13",
      "text": "In collo ejus morabitur fortitudo, et faciem ejus præcedit egestas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 14,
      "referenceLabel": "Job 41:14",
      "text": "Membra carnium ejus cohærentia sibi: mittet contra eum fulmina, et ad locum alium non ferentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 15,
      "referenceLabel": "Job 41:15",
      "text": "Cor ejus indurabitur tamquam lapis, et stringetur quasi malleatoris incus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 16,
      "referenceLabel": "Job 41:16",
      "text": "Cum sublatus fuerit, timebunt angeli, et territi purgabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 17,
      "referenceLabel": "Job 41:17",
      "text": "Cum apprehenderit eum gladius, subsistere non poterit, neque hasta, neque thorax:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 18,
      "referenceLabel": "Job 41:18",
      "text": "reputabit enim quasi paleas ferrum, et quasi lignum putridum æs.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 19,
      "referenceLabel": "Job 41:19",
      "text": "Non fugabit eum vir sagittarius: in stipulam versi sunt ei lapides fundæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 20,
      "referenceLabel": "Job 41:20",
      "text": "Quasi stipulam æstimabit malleum, et deridebit vibrantem hastam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 21,
      "referenceLabel": "Job 41:21",
      "text": "Sub ipso erunt radii solis, et sternet sibi aurum quasi lutum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 22,
      "referenceLabel": "Job 41:22",
      "text": "Fervescere faciet quasi ollam profundum mare, et ponet quasi cum unguenta bulliunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 23,
      "referenceLabel": "Job 41:23",
      "text": "Post eum lucebit semita: æstimabit abyssum quasi senescentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 24,
      "referenceLabel": "Job 41:24",
      "text": "Non est super terram potestas quæ comparetur ei, qui factus est ut nullum timeret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.41.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 41,
      "verseNumber": 25,
      "referenceLabel": "Job 41:25",
      "text": "Omne sublime videt: ipse est rex super universos filios superbiæ.",
      "paragraphStart": false
    }
  ]
}
