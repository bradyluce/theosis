{
  "chapter": {
    "id": "vulgate:job.36",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 36,
    "referenceLabel": "Job 36",
    "summary": "Source text for Job 36 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.36.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Job 36:1",
      "text": "Addens quoque Eliu, hæc locutus est:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.36.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Job 36:2",
      "text": "Sustine me paululum, et indicabo tibi: adhuc enim habeo quod pro Deo loquar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Job 36:3",
      "text": "Repetam scientiam meam a principio, et operatorem meum probabo justum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Job 36:4",
      "text": "Vere enim absque mendacio sermones mei, et perfecta scientia probabitur tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Job 36:5",
      "text": "Deus potentes non abjicit, cum et ipse sit potens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Job 36:6",
      "text": "sed non salvat impios, et judicium pauperibus tribuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Job 36:7",
      "text": "Non auferet a justo oculos suos: et reges in solio collocat in perpetuum, et illi eriguntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Job 36:8",
      "text": "Et si fuerint in catenis, et vinciantur funibus paupertatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Job 36:9",
      "text": "indicabit eis opera eorum, et scelera eorum, quia violenti fuerunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Job 36:10",
      "text": "Revelabit quoque aurem eorum, ut corripiat: et loquetur, ut revertantur ab iniquitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Job 36:11",
      "text": "Si audierint et observaverint, complebunt dies suos in bono, et annos suos in gloria:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Job 36:12",
      "text": "si autem non audierint, transibunt per gladium, et consumentur in stultitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 13,
      "referenceLabel": "Job 36:13",
      "text": "Simulatores et callidi provocant iram Dei, neque clamabunt cum vincti fuerint.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 14,
      "referenceLabel": "Job 36:14",
      "text": "Morietur in tempestate anima eorum, et vita eorum inter effeminatos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 15,
      "referenceLabel": "Job 36:15",
      "text": "Eripiet de angustia sua pauperem, et revelabit in tribulatione aurem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 16,
      "referenceLabel": "Job 36:16",
      "text": "Igitur salvabit te de ore angusto latissime, et non habente fundamentum subter se: requies autem mensæ tuæ erit plena pinguedine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 17,
      "referenceLabel": "Job 36:17",
      "text": "Causa tua quasi impii judicata est: causam judiciumque recipies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 18,
      "referenceLabel": "Job 36:18",
      "text": "Non te ergo superet ira ut aliquem opprimas: nec multitudo donorum inclinet te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 19,
      "referenceLabel": "Job 36:19",
      "text": "Depone magnitudinem tuam absque tribulatione, et omnes robustos fortitudine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 20,
      "referenceLabel": "Job 36:20",
      "text": "Ne protrahas noctem, ut ascendant populi pro eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 21,
      "referenceLabel": "Job 36:21",
      "text": "Cave ne declines ad iniquitatem: hanc enim cœpisti sequi post miseriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 22,
      "referenceLabel": "Job 36:22",
      "text": "Ecce Deus excelsus in fortitudine sua, et nullus ei similis in legislatoribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 23,
      "referenceLabel": "Job 36:23",
      "text": "Quis poterit scrutari vias ejus? aut quis potest ei dicere: Operatus es iniquitatem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 24,
      "referenceLabel": "Job 36:24",
      "text": "Memento quod ignores opus ejus, de quo cecinerunt viri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 25,
      "referenceLabel": "Job 36:25",
      "text": "Omnes homines vident eum: unusquisque intuetur procul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 26,
      "referenceLabel": "Job 36:26",
      "text": "Ecce Deus magnus vincens scientiam nostram: numerus annorum ejus inæstimabilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 27,
      "referenceLabel": "Job 36:27",
      "text": "Qui aufert stillas pluviæ, et effundit imbres ad instar gurgitum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 28,
      "referenceLabel": "Job 36:28",
      "text": "qui de nubibus fluunt quæ prætexunt cuncta desuper.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 29,
      "referenceLabel": "Job 36:29",
      "text": "Si voluerit extendere nubes quasi tentorium suum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 30,
      "referenceLabel": "Job 36:30",
      "text": "et fulgurare lumine suo desuper, cardines quoque maris operiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 31,
      "referenceLabel": "Job 36:31",
      "text": "Per hæc enim judicat populos, et dat escas multis mortalibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 32,
      "referenceLabel": "Job 36:32",
      "text": "In manibus abscondit lucem, et præcepit ei ut rursus adveniat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.36.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 36,
      "verseNumber": 33,
      "referenceLabel": "Job 36:33",
      "text": "Annuntiat de ea amico suo, quod possessio ejus sit, et ad eam possit ascendere.",
      "paragraphStart": false
    }
  ]
}
