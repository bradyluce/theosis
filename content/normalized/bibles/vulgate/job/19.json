{
  "chapter": {
    "id": "vulgate:job.19",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 19,
    "referenceLabel": "Job 19",
    "summary": "Source text for Job 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.19.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Job 19:1",
      "text": "Respondens autem Job, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.19.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Job 19:2",
      "text": "Usquequo affligitis animam meam, et atteritis me sermonibus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Job 19:3",
      "text": "En decies confunditis me, et non erubescitis opprimentes me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Job 19:4",
      "text": "Nempe etsi ignoravi, mecum erit ignorantia mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Job 19:5",
      "text": "At vos contra me erigimini, et arguitis me opprobriis meis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Job 19:6",
      "text": "Saltem nunc intelligite quia Deus non æquo judicio afflixerit me, et flagellis suis me cinxerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Job 19:7",
      "text": "Ecce clamabo, vim patiens, et nemo audiet; vociferabor, et non est qui judicet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Job 19:8",
      "text": "Semitam meam circumsepsit, et transire non possum: et in calle meo tenebras posuit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Job 19:9",
      "text": "Spoliavit me gloria mea, et abstulit coronam de capite meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Job 19:10",
      "text": "Destruxit me undique, et pereo: et quasi evulsæ arbori abstulit spem meam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Job 19:11",
      "text": "Iratus est contra me furor ejus, et sic me habuit quasi hostem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Job 19:12",
      "text": "Simul venerunt latrones ejus, et fecerunt sibi viam per me, et obsederunt in gyro tabernaculum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Job 19:13",
      "text": "Fratres meos longe fecit a me, et noti mei quasi alieni recesserunt a me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Job 19:14",
      "text": "Dereliquerunt me propinqui mei, et qui me noverant obliti sunt mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Job 19:15",
      "text": "Inquilini domus meæ et ancillæ meæ sicut alienum habuerunt me, et quasi peregrinus fui in oculis eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Job 19:16",
      "text": "Servum meum vocavi, et non respondit: ore proprio deprecabar illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Job 19:17",
      "text": "Halitum meum exhorruit uxor mea, et orabam filios uteri mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Job 19:18",
      "text": "Stulti quoque despiciebant me: et cum ab eis recessissem, detrahebant mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Job 19:19",
      "text": "Abominati sunt me quondam consiliarii mei, et quem maxime diligebam, aversatus est me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Job 19:20",
      "text": "Pelli meæ, consumptis carnibus, adhæsit os meum, et derelicta sunt tantummodo labia circa dentes meos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Job 19:21",
      "text": "Miseremini mei, miseremini mei saltem vos, amici mei, quia manus Domini tetigit me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Job 19:22",
      "text": "Quare persequimini me sicut Deus, et carnibus meis saturamini?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Job 19:23",
      "text": "Quis mihi tribuat ut scribantur sermones mei? quis mihi det ut exarentur in libro",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Job 19:24",
      "text": "stylo ferreo et plumbi lamina, vel celte sculpantur in silice?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Job 19:25",
      "text": "Scio enim quod redemptor meus vivit, et in novissimo die de terra surrecturus sum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Job 19:26",
      "text": "et rursum circumdabor pelle mea, et in carne mea videbo Deum meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Job 19:27",
      "text": "quem visurus sum ego ipse, et oculi mei conspecturi sunt, et non alius: reposita est hæc spes mea in sinu meo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Job 19:28",
      "text": "Quare ergo nunc dicitis: Persequamur eum, et radicem verbi inveniamus contra eum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.19.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Job 19:29",
      "text": "Fugite ergo a facie gladii, quoniam ultor iniquitatum gladius est: et scitote esse judicium.",
      "paragraphStart": false
    }
  ]
}
