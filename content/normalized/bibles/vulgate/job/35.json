{
  "chapter": {
    "id": "vulgate:job.35",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 35,
    "referenceLabel": "Job 35",
    "summary": "Source text for Job 35 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.35.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Job 35:1",
      "text": "Igitur Eliu hæc rursum locutus est:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.35.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Job 35:2",
      "text": "Numquid æqua tibi videtur tua cogitatio, ut diceres: Justior sum Deo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Job 35:3",
      "text": "Dixisti enim: Non tibi placet quod rectum est: vel quid tibi proderit, si ego peccavero?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Job 35:4",
      "text": "Itaque ego respondebo sermonibus tuis, et amicis tuis tecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Job 35:5",
      "text": "Suspice cælum, et intuere: et contemplare æthera quod altior te sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Job 35:6",
      "text": "Si peccaveris, quid ei nocebis? et si multiplicatæ fuerint iniquitates tuæ, quid facies contra eum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Job 35:7",
      "text": "Porro si juste egeris, quid donabis ei? aut quid de manu tua accipiet?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Job 35:8",
      "text": "Homini qui similis tui est, nocebit impietas tua: et filium hominis adjuvabit justitia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Job 35:9",
      "text": "Propter multitudinem calumniatorum clamabunt, et ejulabunt propter vim brachii tyrannorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Job 35:10",
      "text": "Et non dixit: Ubi est Deus qui fecit me, qui dedit carmina in nocte;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Job 35:11",
      "text": "qui docet nos super jumenta terræ, et super volucres cæli erudit nos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Job 35:12",
      "text": "Ibi clamabunt, et non exaudiet, propter superbiam malorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Job 35:13",
      "text": "Non ergo frustra audiet Deus, et Omnipotens causas singulorum intuebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Job 35:14",
      "text": "Etiam cum dixeris: Non considerat: judicare coram illo, et expecta eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Job 35:15",
      "text": "Nunc enim non infert furorem suum, nec ulciscitur scelus valde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.35.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Job 35:16",
      "text": "Ergo Job frustra aperit os suum, et absque scientia verba multiplicat.",
      "paragraphStart": false
    }
  ]
}
