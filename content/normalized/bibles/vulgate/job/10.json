{
  "chapter": {
    "id": "vulgate:job.10",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 10,
    "referenceLabel": "Job 10",
    "summary": "Source text for Job 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.10.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Job 10:1",
      "text": "Tædet animam meam vitæ meæ; dimittam adversum me eloquium meum: loquar in amaritudine animæ meæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.10.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Job 10:2",
      "text": "Dicam Deo: Noli me condemnare; indica mihi cur me ita judices.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Job 10:3",
      "text": "Numquid bonum tibi videtur, si calumnieris me, et opprimas me opus manuum tuarum, et consilium impiorum adjuves?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Job 10:4",
      "text": "Numquid oculi carnei tibi sunt? aut sicut videt homo, et tu videbis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Job 10:5",
      "text": "Numquid sicut dies hominis dies tui, et anni tui sicut humana sunt tempora,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Job 10:6",
      "text": "ut quæras iniquitatem meam, et peccatum meum scruteris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Job 10:7",
      "text": "et scias quia nihil impium fecerim, cum sit nemo qui de manu tua possit eruere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Job 10:8",
      "text": "Manus tuæ fecerunt me, et plasmaverunt me totum in circuitu: et sic repente præcipitas me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Job 10:9",
      "text": "Memento, quæso, quod sicut lutum feceris me, et in pulverem reduces me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Job 10:10",
      "text": "Nonne sicut lac mulsisti me, et sicut caseum me coagulasti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Job 10:11",
      "text": "Pelle et carnibus vestisti me; ossibus et nervis compegisti me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Job 10:12",
      "text": "Vitam et misericordiam tribuisti mihi, et visitatio tua custodivit spiritum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Job 10:13",
      "text": "Licet hæc celes in corde tuo, tamen scio quia universorum memineris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Job 10:14",
      "text": "Si peccavi, et ad horam pepercisti mihi, cur ab iniquitate mea mundum me esse non pateris?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Job 10:15",
      "text": "Et si impius fuero, væ mihi est; et si justus, non levabo caput, saturatus afflictione et miseria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Job 10:16",
      "text": "Et propter superbiam quasi leænam capies me, reversusque mirabiliter me crucias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Job 10:17",
      "text": "Instauras testes tuos contra me, et multiplicas iram tuam adversum me, et pœnæ militant in me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Job 10:18",
      "text": "Quare de vulva eduxisti me? qui utinam consumptus essem, ne oculus me videret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Job 10:19",
      "text": "Fuissem quasi non essem, de utero translatus ad tumulum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Job 10:20",
      "text": "Numquid non paucitas dierum meorum finietur brevi? dimitte ergo me, ut plangam paululum dolorem meum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Job 10:21",
      "text": "antequam vadam, et non revertar, ad terram tenebrosam, et opertam mortis caligine:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.10.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Job 10:22",
      "text": "terram miseriæ et tenebrarum, ubi umbra mortis et nullus ordo, sed sempiternus horror inhabitat.",
      "paragraphStart": false
    }
  ]
}
