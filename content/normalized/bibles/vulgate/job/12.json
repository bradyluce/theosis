{
  "chapter": {
    "id": "vulgate:job.12",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 12,
    "referenceLabel": "Job 12",
    "summary": "Source text for Job 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.12.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Job 12:1",
      "text": "Respondens autem Job, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.12.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Job 12:2",
      "text": "Ergo vos estis soli homines, et vobiscum morietur sapientia?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Job 12:3",
      "text": "Et mihi est cor sicut et vobis, nec inferior vestri sum; quis enim hæc quæ nostis ignorat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Job 12:4",
      "text": "Qui deridetur ab amico suo, sicut ego, invocabit Deum, et exaudiet eum: deridetur enim justi simplicitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Job 12:5",
      "text": "Lampas contempta apud cogitationes divitum parata ad tempus statutum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Job 12:6",
      "text": "Abundant tabernacula prædonum, et audacter provocant Deum, cum ipse dederit omnia in manus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Job 12:7",
      "text": "Nimirum interroga jumenta, et docebunt te; et volatilia cæli, et indicabunt tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Job 12:8",
      "text": "Loquere terræ, et respondebit tibi, et narrabunt pisces maris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Job 12:9",
      "text": "Quis ignorat quod omnia hæc manus Domini fecerit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Job 12:10",
      "text": "In cujus manu anima omnis viventis, et spiritus universæ carnis hominis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Job 12:11",
      "text": "Nonne auris verba dijudicat? et fauces comedentis, saporem?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Job 12:12",
      "text": "In antiquis est sapientia, et in multo tempore prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Job 12:13",
      "text": "Apud ipsum est sapientia et fortitudo; ipse habet consilium et intelligentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Job 12:14",
      "text": "Si destruxerit, nemo est qui ædificet; si incluserit hominem, nullus est qui aperiat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Job 12:15",
      "text": "Si continuerit aquas, omnia siccabuntur; et si emiserit eas, subvertent terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Job 12:16",
      "text": "Apud ipsum est fortitudo et sapientia; ipse novit et decipientem, et eum qui decipitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Job 12:17",
      "text": "Adducit consiliarios in stultum finem, et judices in stuporem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Job 12:18",
      "text": "Balteum regum dissolvit, et præcingit fune renes eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Job 12:19",
      "text": "Ducit sacerdotes inglorios, et optimates supplantat:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Job 12:20",
      "text": "commutans labium veracium, et doctrinam senum auferens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Job 12:21",
      "text": "Effundit despectionem super principes, eos qui oppressi fuerant relevans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Job 12:22",
      "text": "Qui revelat profunda de tenebris, et producit in lucem umbram mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Job 12:23",
      "text": "Qui multiplicat gentes, et perdit eas, et subversas in integrum restituit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Job 12:24",
      "text": "Qui immutat cor principum populi terræ, et decipit eos ut frustra incedant per invium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.12.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Job 12:25",
      "text": "palpabunt quasi in tenebris, et non in luce, et errare eos faciet quasi ebrios.",
      "paragraphStart": false
    }
  ]
}
