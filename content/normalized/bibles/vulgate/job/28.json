{
  "chapter": {
    "id": "vulgate:job.28",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 28,
    "referenceLabel": "Job 28",
    "summary": "Source text for Job 28 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.28.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Job 28:1",
      "text": "Habet argentum venarum suarum principia, et auro locus est in quo conflatur.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.28.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Job 28:2",
      "text": "Ferrum de terra tollitur, et lapis solutus calore in æs vertitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Job 28:3",
      "text": "Tempus posuit tenebris, et universorum finem ipse considerat: lapidem quoque caliginis et umbram mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Job 28:4",
      "text": "Dividit torrens a populo peregrinante eos quos oblitus est pes egentis hominis, et invios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Job 28:5",
      "text": "Terra de qua oriebatur panis, in loco suo igni subversa est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Job 28:6",
      "text": "Locus sapphiri lapides ejus, et glebæ illius aurum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Job 28:7",
      "text": "Semitam ignoravit avis, nec intuitus est eam oculus vulturis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Job 28:8",
      "text": "Non calcaverunt eam filii institorum, nec pertransivit per eam leæna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Job 28:9",
      "text": "Ad silicem extendit manum suam: subvertit a radicibus montes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Job 28:10",
      "text": "In petris rivos excidit, et omne pretiosum vidit oculus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Job 28:11",
      "text": "Profunda quoque fluviorum scrutatus est, et abscondita in lucem produxit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Job 28:12",
      "text": "Sapientia vero ubi invenitur? et quis est locus intelligentiæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Job 28:13",
      "text": "Nescit homo pretium ejus, nec invenitur in terra suaviter viventium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Job 28:14",
      "text": "Abyssus dicit: Non est in me, et mare loquitur: Non est mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Job 28:15",
      "text": "Non dabitur aurum obrizum pro ea, nec appendetur argentum in commutatione ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Job 28:16",
      "text": "Non conferetur tinctis Indiæ coloribus, nec lapidi sardonycho pretiosissimo vel sapphiro.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Job 28:17",
      "text": "Non adæquabitur ei aurum vel vitrum, nec commutabuntur pro ea vasa auri.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Job 28:18",
      "text": "Excelsa et eminentia non memorabuntur comparatione ejus: trahitur autem sapientia de occultis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Job 28:19",
      "text": "Non adæquabitur ei topazius de Æthiopia, nec tincturæ mundissimæ componetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Job 28:20",
      "text": "Unde ergo sapientia venit? et quis est locus intelligentiæ?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Job 28:21",
      "text": "Abscondita est ab oculis omnium viventium: volucres quoque cæli latet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Job 28:22",
      "text": "Perditio et mors dixerunt: Auribus nostris audivimus famam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Job 28:23",
      "text": "Deus intelligit viam ejus, et ipse novit locum illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Job 28:24",
      "text": "Ipse enim fines mundi intuetur, et omnia quæ sub cælo sunt respicit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Job 28:25",
      "text": "Qui fecit ventis pondus, et aquas appendit in mensura.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Job 28:26",
      "text": "Quando ponebat pluviis legem, et viam procellis sonantibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Job 28:27",
      "text": "tunc vidit illam et enarravit, et præparavit, et investigavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.28.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Job 28:28",
      "text": "Et dixit homini: Ecce timor Domini, ipsa est sapientia; et recedere a malo, intelligentia.",
      "paragraphStart": false
    }
  ]
}
