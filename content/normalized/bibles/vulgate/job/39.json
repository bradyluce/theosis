{
  "chapter": {
    "id": "vulgate:job.39",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 39,
    "referenceLabel": "Job 39",
    "summary": "Source text for Job 39 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.39.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 1,
      "referenceLabel": "Job 39:1",
      "text": "Numquid nosti tempus partus ibicum in petris, vel parturientes cervas observasti?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.39.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 2,
      "referenceLabel": "Job 39:2",
      "text": "Dinumerasti menses conceptus earum, et scisti tempus partus earum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 3,
      "referenceLabel": "Job 39:3",
      "text": "Incurvantur ad fœtum, et pariunt, et rugitus emittunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 4,
      "referenceLabel": "Job 39:4",
      "text": "Separantur filii earum, et pergunt ad pastum: egrediuntur, et non revertuntur ad eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 5,
      "referenceLabel": "Job 39:5",
      "text": "Quis dimisit onagrum liberum, et vincula ejus quis solvit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 6,
      "referenceLabel": "Job 39:6",
      "text": "cui dedi in solitudine domum, et tabernacula ejus in terra salsuginis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 7,
      "referenceLabel": "Job 39:7",
      "text": "Contemnit multitudinem civitatis: clamorem exactoris non audit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 8,
      "referenceLabel": "Job 39:8",
      "text": "Circumspicit montes pascuæ suæ, et virentia quæque perquirit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 9,
      "referenceLabel": "Job 39:9",
      "text": "Numquid volet rhinoceros servire tibi, aut morabitur ad præsepe tuum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 10,
      "referenceLabel": "Job 39:10",
      "text": "Numquid alligabis rhinocerota ad arandum loro tuo, aut confringet glebas vallium post te?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 11,
      "referenceLabel": "Job 39:11",
      "text": "Numquid fiduciam habebis in magna fortitudine ejus, et derelinques ei labores tuos?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 12,
      "referenceLabel": "Job 39:12",
      "text": "Numquid credes illi quod sementem reddat tibi, et aream tuam congreget?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 13,
      "referenceLabel": "Job 39:13",
      "text": "Penna struthionis similis est pennis herodii et accipitris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 14,
      "referenceLabel": "Job 39:14",
      "text": "Quando derelinquit ova sua in terra, tu forsitan in pulvere calefacies ea?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 15,
      "referenceLabel": "Job 39:15",
      "text": "Obliviscitur quod pes conculcet ea, aut bestia agri conterat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 16,
      "referenceLabel": "Job 39:16",
      "text": "Duratur ad filios suos, quasi non sint sui: frustra laboravit, nullo timore cogente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 17,
      "referenceLabel": "Job 39:17",
      "text": "Privavit enim eam Deus sapientia, nec dedit illi intelligentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 18,
      "referenceLabel": "Job 39:18",
      "text": "Cum tempus fuerit, in altum alas erigit: deridet equum et ascensorem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 19,
      "referenceLabel": "Job 39:19",
      "text": "Numquid præbebis equo fortitudinem, aut circumdabis collo ejus hinnitum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 20,
      "referenceLabel": "Job 39:20",
      "text": "Numquid suscitabis eum quasi locustas? gloria narium ejus terror.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 21,
      "referenceLabel": "Job 39:21",
      "text": "Terram ungula fodit; exultat audacter: in occursum pergit armatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 22,
      "referenceLabel": "Job 39:22",
      "text": "Contemnit pavorem, nec cedit gladio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 23,
      "referenceLabel": "Job 39:23",
      "text": "Super ipsum sonabit pharetra; vibrabit hasta et clypeus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 24,
      "referenceLabel": "Job 39:24",
      "text": "fervens et fremens sorbet terram, nec reputat tubæ sonare clangorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 25,
      "referenceLabel": "Job 39:25",
      "text": "Ubi audierit buccinam, dicit: Vah! procul odoratur bellum: exhortationem ducum, et ululatum exercitus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 26,
      "referenceLabel": "Job 39:26",
      "text": "Numquid per sapientiam tuam plumescit accipiter, expandens alas suas ad austrum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 27,
      "referenceLabel": "Job 39:27",
      "text": "Numquid ad præceptum tuum elevabitur aquila, et in arduis ponet nidum suum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 28,
      "referenceLabel": "Job 39:28",
      "text": "In petris manet, et in præruptis silicibus commoratur, atque inaccessis rupibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 29,
      "referenceLabel": "Job 39:29",
      "text": "Inde contemplatur escam, et de longe oculi ejus prospiciunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.30",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 30,
      "referenceLabel": "Job 39:30",
      "text": "Pulli ejus lambent sanguinem: et ubicumque cadaver fuerit, statim adest.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.31",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 31,
      "referenceLabel": "Job 39:31",
      "text": "Et adjecit Dominus, et locutus est ad Job:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.32",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 32,
      "referenceLabel": "Job 39:32",
      "text": "Numquid qui contendit cum Deo, tam facile conquiescit? utique qui arguit Deum, debet respondere ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.33",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 33,
      "referenceLabel": "Job 39:33",
      "text": "Respondens autem Job Domino, dixit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.34",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 34,
      "referenceLabel": "Job 39:34",
      "text": "Qui leviter locutus sum, respondere quid possum? manum meam ponam super os meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.39.35",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 39,
      "verseNumber": 35,
      "referenceLabel": "Job 39:35",
      "text": "Unum locutus sum, quod utinam non dixissem: et alterum, quibus ultra non addam.",
      "paragraphStart": false
    }
  ]
}
