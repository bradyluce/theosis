{
  "chapter": {
    "id": "vulgate:job.17",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 17,
    "referenceLabel": "Job 17",
    "summary": "Source text for Job 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.17.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Job 17:1",
      "text": "Spiritus meus attenuabitur; dies mei breviabuntur: et solum mihi superest sepulchrum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.17.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Job 17:2",
      "text": "Non peccavi, et in amaritudinibus moratur oculus meus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Job 17:3",
      "text": "Libera me, Domine, et pone me juxta te, et cujusvis manus pugnet contra me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Job 17:4",
      "text": "Cor eorum longe fecisti a disciplina: propterea non exaltabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Job 17:5",
      "text": "Prædam pollicetur sociis, et oculi filiorum ejus deficient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Job 17:6",
      "text": "Posuit me quasi in proverbium vulgi, et exemplum sum coram eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Job 17:7",
      "text": "Caligavit ab indignatione oculus meus, et membra mea quasi in nihilum redacta sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Job 17:8",
      "text": "Stupebunt justi super hoc, et innocens contra hypocritam suscitabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Job 17:9",
      "text": "Et tenebit justus viam suam, et mundis manibus addet fortitudinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Job 17:10",
      "text": "Igitur omnes vos convertimini, et venite, et non inveniam in vobis ullum sapientem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Job 17:11",
      "text": "Dies mei transierunt; cogitationes meæ dissipatæ sunt, torquentes cor meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Job 17:12",
      "text": "Noctem verterunt in diem, et rursum post tenebras spero lucem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Job 17:13",
      "text": "Si sustinuero, infernus domus mea est, et in tenebris stravi lectulum meum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Job 17:14",
      "text": "Putredini dixi: Pater meus es; Mater mea, et soror mea, vermibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Job 17:15",
      "text": "Ubi est ergo nunc præstolatio mea? et patientiam meam quis considerat?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.17.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Job 17:16",
      "text": "In profundissimum infernum descendent omnia mea: putasne saltem ibi erit requies mihi?",
      "paragraphStart": false
    }
  ]
}
