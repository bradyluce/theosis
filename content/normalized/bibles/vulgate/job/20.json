{
  "chapter": {
    "id": "vulgate:job.20",
    "translationId": "vulgate",
    "bookSlug": "job",
    "chapterNumber": 20,
    "referenceLabel": "Job 20",
    "summary": "Source text for Job 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:job.20.1",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Job 20:1",
      "text": "Respondens autem Sophar Naamathites, dixit:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:job.20.2",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Job 20:2",
      "text": "Idcirco cogitationes meæ variæ succedunt sibi, et mens in diversa rapitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.3",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Job 20:3",
      "text": "Doctrinam qua me arguis audiam, et spiritus intelligentiæ meæ respondebit mihi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.4",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Job 20:4",
      "text": "Hoc scio a principio, ex quo positus est homo super terram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.5",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Job 20:5",
      "text": "quod laus impiorum brevis sit, et gaudium hypocritæ ad instar puncti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.6",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Job 20:6",
      "text": "Si ascenderit usque ad cælum superbia ejus, et caput ejus nubes tetigerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.7",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Job 20:7",
      "text": "quasi sterquilinium in fine perdetur, et qui eum viderant, dicent: Ubi est?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.8",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Job 20:8",
      "text": "Velut somnium avolans non invenietur: transiet sicut visio nocturna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.9",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Job 20:9",
      "text": "Oculus qui eum viderat non videbit, neque ultra intuebitur eum locus suus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.10",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Job 20:10",
      "text": "Filii ejus atterentur egestate, et manus illius reddent ei dolorem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.11",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Job 20:11",
      "text": "Ossa ejus implebuntur vitiis adolescentiæ ejus, et cum eo in pulvere dormient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.12",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Job 20:12",
      "text": "Cum enim dulce fuerit in ore ejus malum, abscondet illud sub lingua sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.13",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Job 20:13",
      "text": "Parcet illi, et non derelinquet illud, et celabit in gutture suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.14",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Job 20:14",
      "text": "Panis ejus in utero illius vertetur in fel aspidum intrinsecus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.15",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Job 20:15",
      "text": "Divitias quas devoravit evomet, et de ventre illius extrahet eas Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.16",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Job 20:16",
      "text": "Caput aspidum suget, et occidet eum lingua viperæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.17",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Job 20:17",
      "text": "(Non videat rivulos fluminis, torrentes mellis et butyri.)",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.18",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Job 20:18",
      "text": "Luet quæ fecit omnia, nec tamen consumetur: juxta multitudinem adinventionum suarum, sic et sustinebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.19",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Job 20:19",
      "text": "Quoniam confringens nudavit pauperes: domum rapuit, et non ædificavit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.20",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Job 20:20",
      "text": "Nec est satiatus venter ejus: et cum habuerit quæ concupierat, possidere non poterit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.21",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Job 20:21",
      "text": "Non remansit de cibo ejus, et propterea nihil permanebit de bonis ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.22",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Job 20:22",
      "text": "Cum satiatus fuerit, arctabitur: æstuabit, et omnis dolor irruet super eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.23",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Job 20:23",
      "text": "Utinam impleatur venter ejus, ut emittat in eum iram furoris sui, et pluat super illum bellum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.24",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Job 20:24",
      "text": "Fugiet arma ferrea, et irruet in arcum æreum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.25",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Job 20:25",
      "text": "Eductus, et egrediens de vagina sua, et fulgurans in amaritudine sua: vadent et venient super eum horribiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.26",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Job 20:26",
      "text": "Omnes tenebræ absconditæ sunt in occultis ejus; devorabit eum ignis qui non succenditur: affligetur relictus in tabernaculo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.27",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Job 20:27",
      "text": "Revelabunt cæli iniquitatem ejus, et terra consurget adversus eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.28",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Job 20:28",
      "text": "Apertum erit germen domus illius: detrahetur in die furoris Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:job.20.29",
      "translationId": "vulgate",
      "bookSlug": "job",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Job 20:29",
      "text": "Hæc est pars hominis impii a Deo, et hæreditas verborum ejus a Domino.",
      "paragraphStart": false
    }
  ]
}
