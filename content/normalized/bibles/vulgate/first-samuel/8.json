{
  "chapter": {
    "id": "vulgate:first-samuel.8",
    "translationId": "vulgate",
    "bookSlug": "first-samuel",
    "chapterNumber": 8,
    "referenceLabel": "1 Samuel 8",
    "summary": "Source text for 1 Samuel 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-samuel.8.1",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "1 Samuel 8:1",
      "text": "Factum est autem cum senuisset Samuel, posuit filios suos judices Israël.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-samuel.8.2",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "1 Samuel 8:2",
      "text": "Fuitque nomen filii ejus primogeniti Joël: et nomen secundi Abia, judicum in Bersabee.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.3",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "1 Samuel 8:3",
      "text": "Et non ambulaverunt filii illius in viis ejus: sed declinaverunt post avaritiam, acceperuntque munera, et perverterunt judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.4",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "1 Samuel 8:4",
      "text": "Congregati ergo universi majores natu Israël, venerunt ad Samuelem in Ramatha.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.5",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "1 Samuel 8:5",
      "text": "Dixeruntque ei: Ecce tu senuisti, et filii tui non ambulant in viis tuis: constitue nobis regem, ut judicet nos, sicut et universæ habent nationes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.6",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "1 Samuel 8:6",
      "text": "Displicuit sermo in oculis Samuelis, eo quod dixissent: Da nobis regem, ut judicet nos. Et oravit Samuel ad Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.7",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "1 Samuel 8:7",
      "text": "Dixit autem Dominus ad Samuelem: Audi vocem populi in omnibus quæ loquuntur tibi: non enim te abjecerunt, sed me, ne regnem super eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.8",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "1 Samuel 8:8",
      "text": "Juxta omnia opera sua quæ fecerunt, a die qua eduxi eos de Ægypto usque ad diem hanc: sicut dereliquerunt me, et servierunt diis alienis, sic faciunt etiam tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.9",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "1 Samuel 8:9",
      "text": "Nunc ergo vocem eorum audi: verumtamen contestare eos, et prædic eis jus regis, qui regnaturus est super eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.10",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "1 Samuel 8:10",
      "text": "Dixit itaque Samuel omnia verba Domini ad populum, qui petierat a se regem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.11",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "1 Samuel 8:11",
      "text": "Et ait: Hoc erit jus regis, qui imperaturus est vobis: filios vestros tollet, et ponet in curribus suis: facietque sibi equites et præcursores quadrigarum suarum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.12",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "1 Samuel 8:12",
      "text": "et constituet sibi tribunos, et centuriones, et aratores agrorum suorum, et messores segetum, et fabros armorum et curruum suorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.13",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "1 Samuel 8:13",
      "text": "Filias quoque vestras faciet sibi unguentarias, et focarias, et panificas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.14",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "1 Samuel 8:14",
      "text": "Agros quoque vestros, et vineas, et oliveta optima tollet, et dabit servis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.15",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "1 Samuel 8:15",
      "text": "Sed et segetes vestras et vinearum reditus addecimabit, ut det eunuchis et famulis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.16",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "1 Samuel 8:16",
      "text": "Servos etiam vestros, et ancillas, et juvenes optimos, et asinos, auferet, et ponet in opere suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.17",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "1 Samuel 8:17",
      "text": "Greges quoque vestros addecimabit, vosque eritis ei servi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.18",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "1 Samuel 8:18",
      "text": "Et clamabitis in die illa a facie regis vestri, quem elegistis vobis: et non exaudiet vos Dominus in die illa, quia petistis vobis regem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.19",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "1 Samuel 8:19",
      "text": "Noluit autem populus audire vocem Samuelis, sed dixerunt: Nequaquam: rex enim erit super nos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.20",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "1 Samuel 8:20",
      "text": "et erimus nos quoque sicut omnes gentes: et judicabit nos rex noster, et egredietur ante nos, et pugnabit bella nostra pro nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.21",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "1 Samuel 8:21",
      "text": "Et audivit Samuel omnia verba populi, et locutus est ea in auribus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-samuel.8.22",
      "translationId": "vulgate",
      "bookSlug": "first-samuel",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "1 Samuel 8:22",
      "text": "Dixit autem Dominus ad Samuelem: Audi vocem eorum, et constitue super eos regem. Et ait Samuel ad viros Israël: Vadat unusquisque in civitatem suam.",
      "paragraphStart": false
    }
  ]
}
