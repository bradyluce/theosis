{
  "chapter": {
    "id": "vulgate:leviticus.24",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 24,
    "referenceLabel": "Leviticus 24",
    "summary": "Source text for Leviticus 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.24.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 24:1",
      "text": "Et locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.24.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 24:2",
      "text": "Præcipe filiis Israël, ut afferant tibi oleum de olivis purissimum, ac lucidum, ad concinnandas lucernas jugiter,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 24:3",
      "text": "extra velum testimonii in tabernaculo fœderis. Ponetque eas Aaron a vespere usque ad mane coram Domino, cultu rituque perpetuo in generationibus vestris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 24:4",
      "text": "Super candelabrum mundissimum ponentur semper in conspectu Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 24:5",
      "text": "Accipies quoque similam, et coques ex ea duodecim panes, qui singuli habebunt duas decimas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 24:6",
      "text": "quorum senos altrinsecus super mensam purissimam coram Domino statues:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 24:7",
      "text": "et pones super eos thus lucidissimum, ut sit panis in monimentum oblationis Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 24:8",
      "text": "Per singula sabbata mutabuntur coram Domino suscepti a filiis Israël fœdere sempiterno:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 24:9",
      "text": "eruntque Aaron et filiorum ejus, ut comedant eos in loco sancto: quia Sanctum sanctorum est de sacrificiis Domini jure perpetuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 24:10",
      "text": "Ecce autem egressus filius mulieris Israëlitidis, quem pepererat de viro ægyptio inter filios Israël, jurgatus est in castris cum viro Israëlita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 24:11",
      "text": "Cumque blasphemasset nomen, et maledixisset ei, adductus est ad Moysen. (Vocabatur autem mater ejus Salumith, filia Dabri de tribu Dan.)",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 24:12",
      "text": "Miseruntque eum in carcerem, donec nossent quid juberet Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 24:13",
      "text": "Qui locutus est ad Moysen,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 24:14",
      "text": "dicens: Educ blasphemum extra castra, et ponant omnes qui audierunt, manus suas super caput ejus, et lapidet eum populus universus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 24:15",
      "text": "Et ad filios Israël loqueris: Homo, qui maledixerit Deo suo, portabit peccatum suum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 24:16",
      "text": "et qui blasphemaverit nomen Domini, morte moriatur: lapidibus opprimet eum omnis multitudo, sive ille civis, sive peregrinus fuerit. Qui blasphemaverit nomen Domini, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 24:17",
      "text": "Qui percusserit, et occiderit hominem, morte moriatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 24:18",
      "text": "Qui percusserit animal, reddet vicarium, id est, animam pro anima.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 24:19",
      "text": "Qui irrogaverit maculam cuilibet civium suorum, sicut fecit, sic fiet ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 24:20",
      "text": "fracturam pro fractura, oculum pro oculo, dentem pro dente restituet: qualem inflixerit maculam, talem sustinere cogetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 24:21",
      "text": "Qui percusserit jumentum, reddet aliud. Qui percusserit hominem, punietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 24:22",
      "text": "Æquum judicium sit inter vos, sive peregrinus, sive civis peccaverit: quia ego sum Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.24.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 24:23",
      "text": "Locutusque est Moyses ad filios Israël: et eduxerunt eum, qui blasphemaverat, extra castra, ac lapidibus oppresserunt. Feceruntque filii Israël sicut præceperat Dominus Moysi.",
      "paragraphStart": false
    }
  ]
}
