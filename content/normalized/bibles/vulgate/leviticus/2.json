{
  "chapter": {
    "id": "vulgate:leviticus.2",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 2,
    "referenceLabel": "Leviticus 2",
    "summary": "Source text for Leviticus 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.2.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 2:1",
      "text": "Anima cum obtulerit oblationem sacrificii Domino, simila erit ejus oblatio; fundetque super eam oleum, et ponet thus,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.2.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 2:2",
      "text": "ac deferet ad filios Aaron sacerdotes: quorum unus tollet pugillum plenum similæ et olei, ac totum thus, et ponet memoriale super altare in odorem suavissimum Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 2:3",
      "text": "Quod autem reliquum fuerit de sacrificio, erit Aaron et filiorum ejus, Sanctum sanctorum de oblationibus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 2:4",
      "text": "Cum autem obtuleris sacrificium coctum in clibano: de simila, panes scilicet absque fermento, conspersos oleo, et lagana azyma oleo lita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 2:5",
      "text": "Si oblatio tua fuerit de sartagine, similæ conspersæ oleo et absque fermento,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 2:6",
      "text": "divides eam minutatim, et fundes super eam oleum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 2:7",
      "text": "Sin autem de craticula fuerit sacrificium, æque simila oleo conspergetur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 2:8",
      "text": "quam offerens Domino, trades manibus sacerdotis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 2:9",
      "text": "Qui cum obtulerit eam, tollet memoriale de sacrificio, et adolebit super altare in odorem suavitatis Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 2:10",
      "text": "quidquid autem reliquum est, erit Aaron, et filiorum ejus, Sanctum sanctorum de oblationibus Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 2:11",
      "text": "Omnis oblatio quæ offeretur Domino, absque fermento fiet, nec quidquam fermenti ac mellis adolebitur in sacrificio Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 2:12",
      "text": "Primitias tantum eorum offeretis ac munera: super altare vero non imponentur in odorem suavitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 2:13",
      "text": "Quidquid obtuleris sacrificii, sale condies, nec auferes sal fœderis Dei tui de sacrificio tuo: in omni oblatione tua offeres sal.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 2:14",
      "text": "Si autem obtuleris munus primarum frugum tuarum Domino de spicis adhuc virentibus, torrebis igni, et confringes in morem farris, et sic offeres primitias tuas Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 2:15",
      "text": "fundens supra oleum, et thus imponens, quia oblatio Domini est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.2.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 2:16",
      "text": "de qua adolebit sacerdos in memoriam muneris partem farris fracti, et olei, ac totum thus.",
      "paragraphStart": false
    }
  ]
}
