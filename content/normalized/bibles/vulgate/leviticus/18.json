{
  "chapter": {
    "id": "vulgate:leviticus.18",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 18,
    "referenceLabel": "Leviticus 18",
    "summary": "Source text for Leviticus 18 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.18.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 18:1",
      "text": "Locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.18.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 18:2",
      "text": "Loquere filiis Israël, et dices ad eos: Ego Dominus Deus vester:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 18:3",
      "text": "juxta consuetudinem terræ Ægypti, in qua habitastis, non facietis: et juxta morem regionis Chanaan, ad quam ego introducturus sum vos, non agetis, nec in legitimis eorum ambulabitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 18:4",
      "text": "Facietis judicia mea, et præcepta mea servabitis, et ambulabitis in eis. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 18:5",
      "text": "Custodite leges meas atque judicia, quæ faciens homo, vivet in eis. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 18:6",
      "text": "Omnis homo ad proximam sanguinis sui non accedet, ut revelet turpitudinem ejus. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 18:7",
      "text": "Turpitudinem patris tui et turpitudinem matris tuæ non discooperies: mater tua est: non revelabis turpitudinem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 18:8",
      "text": "Turpitudinem uxoris patris tui non discooperies: turpitudo enim patris tui est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 18:9",
      "text": "Turpitudinem sororis tuæ ex patre sive ex matre, quæ domi vel foris genita est, non revelabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 18:10",
      "text": "Turpitudinem filiæ filii tui vel neptis ex filia non revelabis: quia turpitudo tua est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 18:11",
      "text": "Turpitudinem filiæ uxoris patris tui, quam peperit patri tuo, et est soror tua, non revelabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 18:12",
      "text": "Turpitudinem sororis patris tui non discooperies: quia caro est patris tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 18:13",
      "text": "Turpitudinem sororis matris tuæ non revelabis, eo quod caro sit matris tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 18:14",
      "text": "Turpitudinem patrui tui non revelabis, nec accedes ad uxorem ejus, quæ tibi affinitate conjungitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 18:15",
      "text": "Turpitudinem nurus tuæ non revelabis, quia uxor filii tui est: nec discooperies ignominiam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 18:16",
      "text": "Turpitudinem uxoris fratris tui non revelabis: quia turpitudo fratris tui est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 18:17",
      "text": "Turpitudinem uxoris tuæ et filiæ ejus non revelabis. Filiam filii ejus, et filiam filiæ illius non sumes, ut reveles ignominiam ejus: quia caro illius sunt, et talis coitus incestus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 18:18",
      "text": "Sororem uxoris tuæ in pellicatum illius non accipies, nec revelabis turpitudinem ejus adhuc illa vivente.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 18:19",
      "text": "Ad mulierem quæ patitur menstrua non accedes, nec revelabis fœditatem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 18:20",
      "text": "Cum uxore proximi tui non coibis, nec seminis commistione maculaberis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 18:21",
      "text": "De semine tuo non dabis ut consecretur idolo Moloch, nec pollues nomen Dei tui. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 18:22",
      "text": "Cum masculo non commiscearis coitu femineo, quia abominatio est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 18:23",
      "text": "Cum omni pecore non coibis, nec maculaberis cum eo. Mulier non succumbet jumento, nec miscebitur ei, quia scelus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 18:24",
      "text": "Nec polluamini in omnibus his quibus contaminatæ sunt universæ gentes, quas ego ejiciam ante conspectum vestrum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 18:25",
      "text": "et quibus polluta est terra: cujus ego scelera visitabo, ut evomat habitatores suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 18:26",
      "text": "Custodite legitima mea atque judicia, et non faciatis ex omnibus abominationibus istis, tam indigena quam colonus qui peregrinantur apud vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 18:27",
      "text": "Omnes enim execrationes istas fecerunt accolæ terræ qui fuerunt ante vos, et polluerunt eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 18:28",
      "text": "Cavete ergo ne et vos similiter evomat, cum paria feceritis, sicut evomuit gentem, quæ fuit ante vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 18:29",
      "text": "Omnis anima, quæ fecerit de abominationibus his quippiam, peribit de medio populi sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.18.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 18,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 18:30",
      "text": "Custodite mandata mea. Nolite facere quæ fecerunt hi qui fuerunt ante vos, et ne polluamini in eis. Ego Dominus Deus vester.",
      "paragraphStart": false
    }
  ]
}
