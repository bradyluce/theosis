{
  "chapter": {
    "id": "vulgate:leviticus.3",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 3,
    "referenceLabel": "Leviticus 3",
    "summary": "Source text for Leviticus 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.3.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 3:1",
      "text": "Quod si hostia pacificorum fuerit ejus oblatio, et de bobus voluerit offerre, marem sive feminam, immaculata offeret coram Domino.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.3.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 3:2",
      "text": "Ponetque manum super caput victimæ suæ, quæ immolabitur in introitu tabernaculi testimonii, fundentque filii Aaron sacerdotes sanguinem per altaris circuitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 3:3",
      "text": "Et offerent de hostia pacificorum in oblationem Domino, adipem qui operit vitalia, et quidquid pinguedinis est intrinsecus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 3:4",
      "text": "duos renes cum adipe quo teguntur ilia, et reticulum jecoris cum renunculis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 3:5",
      "text": "Adolebuntque ea super altare in holocaustum, lignis igne supposito, in oblationem suavissimi odoris Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 3:6",
      "text": "Si vero de ovibus fuerit ejus oblatio et pacificorum hostia, sive masculum obtulerit, sive feminam, immaculata erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 3:7",
      "text": "Si agnum obtulerit coram Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 3:8",
      "text": "ponet manum suam super caput victimæ suæ: quæ immolabitur in vestibulo tabernaculi testimonii: fundentque filii Aaron sanguinem ejus per circuitum altaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 3:9",
      "text": "Et offerent de pacificorum hostia sacrificium Domino: adipem et caudam totam",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 3:10",
      "text": "cum renibus, et pinguedinem quæ operit ventrem atque universa vitalia, et utrumque renunculum cum adipe qui est juxta ilia, reticulumque jecoris cum renunculis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 3:11",
      "text": "Et adolebit ea sacerdos super altare in pabulum ignis et oblationis Domini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 3:12",
      "text": "Si capra fuerit ejus oblatio, et obtulerit eam Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 3:13",
      "text": "ponet manum suam super caput ejus: immolabitque eam in introitu tabernaculi testimonii, et fundent filii Aaron sanguinem ejus per altaris circuitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 3:14",
      "text": "Tollentque ex ea in pastum ignis dominici, adipem qui operit ventrem, et qui tegit universa vitalia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 3:15",
      "text": "duos renunculos cum reticulo, quod est super eos juxta ilia, et arvinam jecoris cum renunculis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 3:16",
      "text": "adolebitque ea super altare sacerdos in alimoniam ignis, et suavissimi odoris. Omnis adeps, Domini erit",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.3.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 3:17",
      "text": "jure perpetuo in generationibus, et cunctis habitaculis vestris: nec sanguinem nec adipem omnino comedetis.",
      "paragraphStart": false
    }
  ]
}
