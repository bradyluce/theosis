{
  "chapter": {
    "id": "vulgate:leviticus.6",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 6,
    "referenceLabel": "Leviticus 6",
    "summary": "Source text for Leviticus 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.6.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 6:1",
      "text": "Locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.6.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 6:2",
      "text": "Anima quæ peccaverit, et contempto Domino, negaverit proximo suo depositum quod fidei ejus creditum fuerat, vel vi aliquid extorserit, aut calumniam fecerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 6:3",
      "text": "sive rem perditam invenerit, et inficians insuper pejeraverit, et quodlibet aliud ex pluribus fecerit, in quibus solent peccare homines,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 6:4",
      "text": "convicta delicti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 6:5",
      "text": "reddet omnia, quæ per fraudem voluit obtinere, integra, et quintam insuper partem domino cui damnum intulerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 6:6",
      "text": "Pro peccato autem suo offeret arietem immaculatum de grege, et dabit eum sacerdoti, juxta æstimationem mensuramque delicti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 6:7",
      "text": "qui rogabit pro eo coram Domino, et dimittetur illi pro singulis quæ faciendo peccavit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 6:8",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 6:9",
      "text": "Præcipe Aaron et filiis ejus: Hæc est lex holocausti: cremabitur in altari tota nocte usque mane: ignis ex eodem altari erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 6:10",
      "text": "Vestietur tunica sacerdos et feminalibus lineis: tolletque cineres, quos vorans ignis exussit, et ponens juxta altare,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 6:11",
      "text": "spoliabitur prioribus vestimentis, indutusque aliis, efferret eos extra castra, et in loco mundissimo usque ad favillam consumi faciet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 6:12",
      "text": "Ignis autem in altari semper ardebit, quem nutriet sacerdos subjiciens ligna mane per singulos dies, et imposito holocausto, desuper adolebit adipes pacificorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 6:13",
      "text": "Ignis est iste perpetuus, qui numquam deficiet in altari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 6:14",
      "text": "Hæc est lex sacrificii et libamentorum, quæ offerent filii Aaron coram Domino, et coram altari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 6:15",
      "text": "Tollet sacerdos pugillum similæ, quæ conspersa est oleo, et totum thus, quod super similam positum est: adolebitque illud in altari in monimentum odoris suavissimi Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 6:16",
      "text": "reliquam autem partem similæ comedet Aaron cum filiis suis, absque fermento: et comedet in loco sancto atrii tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 6:17",
      "text": "Ideo autem non fermentabitur, quia pars ejus in Domini offertur incensum. Sanctum sanctorum erit, sicut pro peccato atque delicto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 6:18",
      "text": "Mares tantum stirpis Aaron comedent illud. Legitimum ac sempiternum erit in generationibus vestris de sacrificiis Domini: omnis qui tetigerit illa, sanctificabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 6:19",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 6:20",
      "text": "Hæc est oblatio Aaron, et filiorum ejus, quam offerre debent Domino in die unctionis suæ. Decimam partem ephi offerent similæ in sacrificio sempiterno, medium ejus mane, et medium ejus vespere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 6:21",
      "text": "quæ in sartagine oleo conspersa frigetur. Offeret autem eam calidam in odorem suavissimum Domino",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 6:22",
      "text": "sacerdos, qui jure patri successerit, et tota cremabitur in altari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 6:23",
      "text": "Omne enim sacrificium sacerdotum igne consumetur, nec quisquam comedet ex eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 6:24",
      "text": "Locutus est autem Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 6:25",
      "text": "Loquere Aaron et filiis ejus: Ista est lex hostiæ pro peccato: in loco ubi offertur holocaustum, immolabitur coram Domino. Sanctum sanctorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 6:26",
      "text": "Sacerdos, qui offert, comedet eam in loco sancto, in atrio tabernaculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 6:27",
      "text": "Quidquid tetigerit carnes ejus, sanctificabitur. Si de sanguine illius vestis fuerit aspersa, lavabitur in loco sancto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 6:28",
      "text": "Vas autem fictile, in quo cocta est, confringetur; quod si vas æneum fuerit, defricabitur, et lavabitur aqua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 6:29",
      "text": "Omnis masculus de genere sacerdotali vescetur de carnibus ejus, quia Sanctum sanctorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.6.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 6:30",
      "text": "Hostia enim quæ cæditur pro peccato, cujus sanguis infertur in tabernaculum testimonii ad expiandum in sanctuario, non comedetur, sed comburetur igni.",
      "paragraphStart": false
    }
  ]
}
