{
  "chapter": {
    "id": "vulgate:leviticus.14",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 14,
    "referenceLabel": "Leviticus 14",
    "summary": "Source text for Leviticus 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.14.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 14:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.14.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 14:2",
      "text": "Hic est ritus leprosi, quando mundandus est. Adducetur ad sacerdotem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 14:3",
      "text": "qui egressus de castris, cum invenerit lepram esse mundatam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 14:4",
      "text": "præcipiet ei, qui purificatur, ut offerat duos passeres vivos pro se, quibus vesci licitum est, et lignum cedrinum, vermiculumque et hyssopum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 14:5",
      "text": "Et unum ex passeribus immolari jubebit in vase fictili super aquas viventes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 14:6",
      "text": "alium autem vivum cum ligno cedrino, et cocco et hyssopo, tinget in sanguine passeris immolati,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 14:7",
      "text": "quo asperget illum, qui mundandus est, septies, ut jure purgetur: et dimittet passerem vivum, ut in agrum avolet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 14:8",
      "text": "Cumque laverit homo vestimenta sua, radet omnes pilos corporis, et lavabitur aqua: purificatusque ingredietur castra, ita dumtaxat ut maneat extra tabernaculum suum septem diebus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 14:9",
      "text": "et die septimo radet capillos capitis, barbamque et supercilia, ac totius corporis pilos. Et lotis rursum vestibus et corpore,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 14:10",
      "text": "die octavo assumet duos agnos immaculatos, et ovem anniculam absque macula, et tres decimas similæ in sacrificium, quæ conspersa sit oleo, et seorsum olei sextarium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 14:11",
      "text": "Cumque sacerdos purificans hominem, statuerit eum, et hæc omnia coram Domino in ostio tabernaculi testimonii,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 14:12",
      "text": "tollet agnum et offeret eum pro delicto, oleique sextarium: et oblatis ante Dominum omnibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 14:13",
      "text": "immolabit agnum, ubi solet immolari hostia pro peccato, et holocaustum, id est, in loco sancto. Sicut enim pro peccato, ita et pro delicto ad sacerdotem pertinet hostia: Sancta sanctorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 14:14",
      "text": "Assumensque sacerdos de sanguine hostiæ, quæ immolata est pro delicto, ponet super extremum auriculæ dextræ ejus qui mundatur, et super pollices manus dextræ et pedis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 14:15",
      "text": "et de olei sextario mittet in manum suam sinistram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 14:16",
      "text": "tingetque digitum dextrum in eo, et asperget coram Domino septies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 14:17",
      "text": "Quod autem reliquum est olei in læva manu, fundet super extremum auriculæ dextræ ejus qui mundatur, et super pollices manus ac pedis dextri, et super sanguinem qui effusus est pro delicto,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 14:18",
      "text": "et super caput ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 14:19",
      "text": "Rogabitque pro eo coram Domino, et faciet sacrificium pro peccato: tunc immolabit holocaustum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 14:20",
      "text": "et ponet illud in altari cum libamentis suis, et homo rite mundabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 14:21",
      "text": "Quod si pauper est, et non potest manus ejus invenire quæ dicta sunt pro delicto, assumet agnum ad oblationem, ut roget pro eo sacerdos, decimamque partem similæ conspersæ oleo in sacrificium, et olei sextarium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 14:22",
      "text": "duosque turtures sive duos pullos columbæ, quorum unus sit pro peccato, et alter in holocaustum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 14:23",
      "text": "offeretque ea die octavo purificationis suæ sacerdoti, ad ostium tabernaculi testimonii coram Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 14:24",
      "text": "Qui suscipiens agnum pro delicto et sextarium olei, levabit simul:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 14:25",
      "text": "immolatoque agno, de sanguine ejus ponet super extremum auriculæ dextræ illius qui mundatur, et super pollices manus ejus ac pedis dextri:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 14:26",
      "text": "olei vero partem mittet in manum suam sinistram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 14:27",
      "text": "in quo tingens digitum dextræ manus asperget septies coram Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 14:28",
      "text": "tangetque extremum dextræ auriculæ illius qui mundatur, et pollices manus ac pedis dextri, in loco sanguinis qui effusus est pro delicto:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 14:29",
      "text": "reliquam autem partem olei, quæ est in sinistra manu, mittet super caput purificati, ut placet pro eo Dominum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 14:30",
      "text": "et turturem sive pullum columbæ offeret,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 14:31",
      "text": "unum pro delicto, et alterum in holocaustum cum libamentis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 14:32",
      "text": "Hoc est sacrificium leprosi, qui habere non potest omnia in emundationem sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 14:33",
      "text": "Locutusque est Dominus ad Moysen et Aaron, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 14:34",
      "text": "Cum ingressi fueritis terram Chanaan, quam ego dabo vobis in possessionem, si fuerit plaga lepræ in ædibus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.35",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Leviticus 14:35",
      "text": "ibit cujus est domus, nuntians sacerdoti, et dicet: Quasi plaga lepræ videtur mihi esse in domo mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.36",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Leviticus 14:36",
      "text": "At ille præcipiet ut efferant universa de domo, priusquam ingrediatur eam, et videat utrum leprosa sit, ne immunda fiant omnia quæ in domo sunt. Intrabitque postea ut consideret lepram domus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.37",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 37,
      "referenceLabel": "Leviticus 14:37",
      "text": "et cum viderit in parietibus illius quasi valliculas pallore sive rubore deformes, et humiliores superficie reliqua,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.38",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 38,
      "referenceLabel": "Leviticus 14:38",
      "text": "egredietur ostium domus, et statim claudet illam septem diebus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.39",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 39,
      "referenceLabel": "Leviticus 14:39",
      "text": "Reversusque die septimo, considerabit eam: si invenerit crevisse lepram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.40",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 40,
      "referenceLabel": "Leviticus 14:40",
      "text": "jubebit erui lapides in quibus lepra est, et projici eos extra civitatem in locum immundum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.41",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 41,
      "referenceLabel": "Leviticus 14:41",
      "text": "domum autem ipsam radi intrinsecus per circuitum, et spargi pulverem rasuræ extra urbem in locum immundum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.42",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 42,
      "referenceLabel": "Leviticus 14:42",
      "text": "lapidesque alios reponi pro his qui ablati fuerint, et luto alio liniri domum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.43",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 43,
      "referenceLabel": "Leviticus 14:43",
      "text": "Sin autem postquam eruti sunt lapides, et pulvis erasus, et alia terra lita,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.44",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 44,
      "referenceLabel": "Leviticus 14:44",
      "text": "ingressus sacerdos viderit reversam lepram, et parietes respersos maculis, lepra est perseverans, et immunda domus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.45",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 45,
      "referenceLabel": "Leviticus 14:45",
      "text": "quam statim destruent, et lapides ejus ac ligna, atque universum pulverem projicient extra oppidum in locum immundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.46",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 46,
      "referenceLabel": "Leviticus 14:46",
      "text": "Qui intraverit domum quando clausa est, immundus erit usque ad vesperum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.47",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 47,
      "referenceLabel": "Leviticus 14:47",
      "text": "et qui dormierit in ea, et comederit quippiam, lavabit vestimenta sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.48",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 48,
      "referenceLabel": "Leviticus 14:48",
      "text": "Quod si introiens sacerdos viderit lepram non crevisse in domo, postquam denuo lita fuerit, purificabit eam reddita sanitate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.49",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 49,
      "referenceLabel": "Leviticus 14:49",
      "text": "et in purificationem ejus sumet duos passeres, lignumque cedrinum, et vermiculum atque hyssopum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.50",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 50,
      "referenceLabel": "Leviticus 14:50",
      "text": "et immolato uno passere in vase fictili super aquas vivas,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.51",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 51,
      "referenceLabel": "Leviticus 14:51",
      "text": "tollet lignum cedrinum, et hyssopum, et coccum, et passerem vivum, et tinget omnia in sanguine passeris immolati, atque in aquis viventibus, et asperget domum septies,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.52",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 52,
      "referenceLabel": "Leviticus 14:52",
      "text": "purificabitque eam tam in sanguine passeris quam in aquis viventibus, et in passere vivo, lignoque cedrino et hyssopo atque vermiculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.53",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 53,
      "referenceLabel": "Leviticus 14:53",
      "text": "Cumque dimiserit passerem avolare in agrum libere, orabit pro domo, et jure mundabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.54",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 54,
      "referenceLabel": "Leviticus 14:54",
      "text": "Ista est lex omnis lepræ et percussuræ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.55",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 55,
      "referenceLabel": "Leviticus 14:55",
      "text": "lepræ vestium et domorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.56",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 56,
      "referenceLabel": "Leviticus 14:56",
      "text": "cicatricis et erumpentium papularum, lucentis maculæ, et in varias species, coloribus immutatis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.14.57",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 14,
      "verseNumber": 57,
      "referenceLabel": "Leviticus 14:57",
      "text": "ut possit sciri quo tempore mundum quid, vel immundum sit.",
      "paragraphStart": false
    }
  ]
}
