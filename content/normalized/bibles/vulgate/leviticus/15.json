{
  "chapter": {
    "id": "vulgate:leviticus.15",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 15,
    "referenceLabel": "Leviticus 15",
    "summary": "Source text for Leviticus 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.15.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 15:1",
      "text": "Locutusque est Dominus ad Moysen et Aaron, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.15.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 15:2",
      "text": "Loquimini filiis Israël, et dicite eis: Vir, qui patitur fluxum seminis, immundus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 15:3",
      "text": "Et tunc judicabitur huic vitio subjacere, cum per singula momenta adhæserit carni ejus, atque concreverit fœdus humor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 15:4",
      "text": "Omne stratum, in quo dormierit, immundum erit, et ubicumque sederit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 15:5",
      "text": "Si quis hominum tetigerit lectum ejus, lavabit vestimenta sua, et ipse lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 15:6",
      "text": "Si sederit ubi ille sederat, et ipse lavabit vestimenta sua: et lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 15:7",
      "text": "Qui tetigerit carnem ejus, lavabit vestimenta sua: et ipse lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 15:8",
      "text": "Si salivam hujuscemodi homo jecerit super eum qui mundus est, lavabit vestimenta sua: et lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 15:9",
      "text": "Sagma, super quo sederit, immundum erit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 15:10",
      "text": "et quidquid sub eo fuerit, qui fluxum seminis patitur, pollutum erit usque ad vesperum. Qui portaverit horum aliquid, lavabit vestimenta sua: et ipse lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 15:11",
      "text": "Omnis, quem tetigerit qui talis est, non lotis ante manibus, lavabit vestimenta sua, et lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 15:12",
      "text": "Vas fictile quod tetigerit confringetur: vas autem ligneum lavabitur aqua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 15:13",
      "text": "Si sanatus fuerit qui hujuscemodi sustinet passionem, numerabit septem dies post emundationem sui, et lotis vestibus et toto corpore in aquis viventibus, erit mundus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 15:14",
      "text": "Die autem octavo sumet duos turtures, aut duos pullos columbæ, et veniet in conspectum Domini ad ostium tabernaculi testimonii, dabitque eos sacerdoti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 15:15",
      "text": "qui faciet unum pro peccato et alterum in holocaustum: rogabitque pro eo coram Domino, ut emundetur a fluxi seminis sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 15:16",
      "text": "Vir de quo egreditur semen coitus, lavabit aqua omne corpus suum: et immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 15:17",
      "text": "Vestem et pellem, quam habuerit, lavabit aqua, et immunda erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 15:18",
      "text": "Mulier, cum qua coierit, lavabitur aqua, et immunda erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 15:19",
      "text": "Mulier, quæ redeunte mense patitur fluxum sanguinis, septem diebus separabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 15:20",
      "text": "Omnis qui tetigerit eam, immundus erit usque ad vesperum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 15:21",
      "text": "et in quo dormierit vel sederit diebus separationis suæ, polluetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 15:22",
      "text": "Qui tetigerit lectum ejus, lavabit vestimenta sua: et ipse lotus aqua, immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 15:23",
      "text": "Omne vas, super quo illa sederit, quisquis attigerit, lavabit vestimenta sua: et ipse lotus aqua, pollutus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 15:24",
      "text": "Si coierit cum ea vir tempore sanguinis menstrualis, immundus erit septem diebus: et omne stratum, in quo dormierit, polluetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 15:25",
      "text": "Mulier, quæ patitur multis diebus fluxum sanguinis non in tempore menstruali, vel quæ post menstruum sanguinem fluere non cessat, quamdiu subjacet huic passioni, immunda erit quasi sit in tempore menstruo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 15:26",
      "text": "Omne stratum, in quo dormierit, et vas in quo sederit, pollutum erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 15:27",
      "text": "Quicumque tetigerit ea, lavabit vestimenta sua: et ipse lotus aqua, immundus erit usque ad vesperam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 15:28",
      "text": "Si steterit sanguis, et fluere cessaverit, numerabit septem dies purificationis suæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 15:29",
      "text": "et die octavo offeret pro se sacerdoti duos turtures, aut duos pullos columbarum, ad ostium tabernaculi testimonii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 15:30",
      "text": "qui unum faciet pro peccato, et alterum in holocaustum, rogabitque pro ea coram Domino, et pro fluxu immunditiæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 15:31",
      "text": "Docebitis ergo filios Israël ut caveant immunditiam, et non moriantur in sordibus suis, cum polluerint tabernaculum meum quod est inter eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 15:32",
      "text": "Ista est lex ejus, qui patitur fluxum seminis, et qui polluitur coitu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.15.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 15:33",
      "text": "et quæ menstruis temporibus separatur, vel quæ jugi fluit sanguine, et hominis qui dormierit cum ea.",
      "paragraphStart": false
    }
  ]
}
