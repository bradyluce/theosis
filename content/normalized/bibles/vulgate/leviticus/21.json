{
  "chapter": {
    "id": "vulgate:leviticus.21",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 21,
    "referenceLabel": "Leviticus 21",
    "summary": "Source text for Leviticus 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.21.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 21:1",
      "text": "Dixit quoque Dominus ad Moysen: Loquere ad sacerdotes filios Aaron, et dices ad eos: Ne contaminetur sacerdos in mortibus civium suorum,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.21.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 21:2",
      "text": "nisi tantum in consanguineis, ac propinquis, id est, super patre et matre, et filio, et filia, fratre quoque,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 21:3",
      "text": "et sorore virgine quæ non est nupta viro:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 21:4",
      "text": "sed nec in principe populi sui contaminabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 21:5",
      "text": "Non radent caput, nec barbam, neque in carnibus suis facient incisuras.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 21:6",
      "text": "Sancti erunt Deo suo, et non polluent nomen ejus: incensum enim Domini, et panes Dei sui offerunt, et ideo sancti erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 21:7",
      "text": "Scortum et vile prostibulum non ducent uxorem, nec eam quæ repudiata est a marito: quia consecrati sunt Deo suo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 21:8",
      "text": "et panes propositionis offerunt. Sint ergo sancti, quia et ego sanctus sum, Dominus qui sanctifico eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 21:9",
      "text": "Sacerdotis filia si deprehensa fuerit in stupro, et violaverit nomen patris sui, flammis exuretur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 21:10",
      "text": "Pontifex, id est, sacerdos maximus inter fratres suos, super cujus caput fusum est unctionis oleum, et cujus manus in sacerdotio consecratæ sunt, vestitusque est sanctis vestibus, caput suum non discooperiet, vestimenta non scindet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 21:11",
      "text": "et ad omnem mortuum non ingredietur omnino: super patre quoque suo et matre non contaminabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 21:12",
      "text": "Nec egredietur de sanctis, ne polluat sanctuarium Domini, quia oleum sanctæ unctionis Dei sui super eum est. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 21:13",
      "text": "Virginem ducet uxorem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 21:14",
      "text": "viduam autem et repudiatam, et sordidam, atque meretricem non accipiet, sed puellam de populo suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 21:15",
      "text": "ne commisceat stirpem generis sui vulgo gentis suæ: quia ego Dominus, qui sanctifico eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 21:16",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 21:17",
      "text": "Loquere ad Aaron: Homo de semine tuo per familias qui habuerit maculam, non offeret panes Deo suo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 21:18",
      "text": "nec accedet ad ministerium ejus: si cæcus fuerit, si claudus, si parvo vel grandi, vel torto naso,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 21:19",
      "text": "si fracto pede, si manu,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 21:20",
      "text": "si gibbus, si lippus, si albuginem habens in oculo, si jugem scabiem, si impetiginem in corpore, vel herniosus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 21:21",
      "text": "Omnis qui habuerit maculam de semine Aaron sacerdotis, non accedet offerre hostias Domino, nec panes Deo suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 21:22",
      "text": "vescetur tamen panibus qui offeruntur in sanctuario,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 21:23",
      "text": "ita dumtaxat, ut intra velum non ingrediatur, nec accedat ad altare, quia maculam habet, et contaminare non debet sanctuarium meum. Ego Dominus qui sanctifico eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.21.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 21:24",
      "text": "Locutus est ergo Moyses ad Aaron, et ad filios ejus, et ad omnem Israël cuncta quæ fuerant sibi imperata.",
      "paragraphStart": false
    }
  ]
}
