{
  "chapter": {
    "id": "vulgate:leviticus.19",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 19,
    "referenceLabel": "Leviticus 19",
    "summary": "Source text for Leviticus 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.19.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 19:1",
      "text": "Locutus est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.19.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 19:2",
      "text": "Loquere ad omnem cœtum filiorum Israël, et dices ad eos: Sancti estote, quia ego sanctus sum, Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 19:3",
      "text": "Unusquisque patrem suum, et matrem suam timeat. Sabbata mea custodite. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 19:4",
      "text": "Nolite converti ad idola, nec deos conflatiles faciatis vobis. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 19:5",
      "text": "Si immolaveritis hostiam pacificorum Domino, ut sit placabilis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 19:6",
      "text": "eo die quo fuerit immolata, comedetis eam, et die altero: quidquid autem residuum fuerit in diem tertium, igne comburetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 19:7",
      "text": "Si quis post biduum comederit ex ea, profanus erit, et impietatis reus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 19:8",
      "text": "portabitque iniquitatem suam, quia sanctum Domini polluit, et peribit anima illa de populo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 19:9",
      "text": "Cumque messueris segetes terræ tuæ, non tondebis usque ad solum superficiem terræ, nec remanentes spicas colliges,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 19:10",
      "text": "neque in vinea tua racemos et grana decidentia congregabis: sed pauperibus et peregrinis carpenda dimittes. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 19:11",
      "text": "Non facietis furtum. Non mentiemini, nec decipiet unusquisque proximum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 19:12",
      "text": "Non perjurabis in nomine meo, nec pollues nomen Dei tui. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 19:13",
      "text": "Non facies calumniam proximo tuo nec vi opprimes eum. Non morabitur opus mercenarii tui apud te usque mane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 19:14",
      "text": "Non maledices surdo, nec coram cæco pones offendiculum: sed timebis Dominum Deum tuum, quia ego sum Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 19:15",
      "text": "Non facies quod iniquum est, nec injuste judicabis. Non consideres personam pauperis, nec honores vultum potentis. Juste judica proximo tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 19:16",
      "text": "Non eris criminator, nec susurro in populo. Non stabis contra sanguinem proximi tui. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 19:17",
      "text": "Non oderis fratrem tuum in corde tuo, sed publice argue eum, ne habeas super illo peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 19:18",
      "text": "Non quæras ultionem, nec memor eris injuriæ civium tuorum. Diliges amicum tuum sicut teipsum. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 19:19",
      "text": "Leges meas custodite. Jumentum tuum non facies coire cum alterius generis animantibus. Agrum tuum non seres diverso semine. Veste, quæ ex duobus texta est, non indueris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 19:20",
      "text": "Homo, si dormierit cum muliere coitu seminis, quæ sit ancilla etiam nubilis, et tamen pretio non redempta, nec libertate donata: vapulabunt ambo, et non morientur, quia non fuit libera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 19:21",
      "text": "Pro delicto autem suo offeret Domino ad ostium tabernaculi testimonii arietem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 19:22",
      "text": "orabitque pro eo sacerdos, et pro peccato ejus coram Domino, et repropitiabitur ei, dimitteturque peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 19:23",
      "text": "Quando ingressi fueritis terram, et plantaveritis in ea ligna pomifera, auferetis præputia eorum: poma, quæ germinant, immunda erunt vobis, nec edetis ex eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 19:24",
      "text": "Quarto autem anno omnis fructus eorum sanctificabitur, laudabilis Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 19:25",
      "text": "Quinto autem anno comedetis fructus, congregantes poma, quæ proferunt. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 19:26",
      "text": "Non comedetis cum sanguine. Non augurabimini, nec observabitis somnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 19:27",
      "text": "Neque in rotundum attondebitis comam, nec radetis barbam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 19:28",
      "text": "Et super mortuo non incidetis carnem vestram, neque figuras aliquas aut stigmata facietis vobis. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 19:29",
      "text": "Ne prostituas filiam tuam, ne contaminetur terra et impleatur piaculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 19:30",
      "text": "Sabbata mea custodite, et sanctuarium meum metuite. Ego Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 19:31",
      "text": "Non declinetis ad magos, nec ab ariolis aliquid sciscitemini, ut polluamini per eos. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 19:32",
      "text": "Coram cano capite consurge, et honora personam senis: et time Dominum Deum tuum. Ego sum Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 19:33",
      "text": "Si habitaverit advena in terra vestra, et moratus fuerit inter vos, non exprobretis ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 19:34",
      "text": "sed sit inter vos quasi indigena, et diligetis eum quasi vosmetipsos: fuistis enim et vos advenæ in terra Ægypti. Ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.35",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 35,
      "referenceLabel": "Leviticus 19:35",
      "text": "Nolite facere iniquum aliquid in judicio, in regula, in pondere, in mensura.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.36",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 36,
      "referenceLabel": "Leviticus 19:36",
      "text": "Statera justa, et æqua sint pondera, justus modius, æquusque sextarius. Ego Dominus Deus vester, qui eduxi vos de terra Ægypti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.19.37",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 19,
      "verseNumber": 37,
      "referenceLabel": "Leviticus 19:37",
      "text": "Custodite omnia præcepta mea, et universa judicia, et facite ea. Ego Dominus.",
      "paragraphStart": false
    }
  ]
}
