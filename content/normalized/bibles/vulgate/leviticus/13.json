{
  "chapter": {
    "id": "vulgate:leviticus.13",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 13,
    "referenceLabel": "Leviticus 13",
    "summary": "Source text for Leviticus 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.13.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 13:1",
      "text": "Locutusque est Dominus ad Moysen, et Aaron, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.13.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 13:2",
      "text": "Homo, in cujus cute et carne ortus fuerit diversus color, sive pustula, aut quasi lucens quippiam, id est, plaga lepræ, adducetur ad Aaron sacerdotem, vel ad unum quemlibet filiorum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 13:3",
      "text": "Qui cum viderit lepram in cute, et pilos in album mutatos colorem, ipsamque speciem lepræ humiliorem cute et carne reliqua: plaga lepræ est, et ad arbitrium ejus separabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 13:4",
      "text": "Sin autem lucens candor fuerit in cute, nec humilior carne reliqua, et pili coloris pristini, recludet eum sacerdos septem diebus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 13:5",
      "text": "et considerabit die septimo: et si quidem lepra ultra non creverit, nec transierit in cute priores terminos, rursum recludet eum septem diebus aliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 13:6",
      "text": "Et die septimo contemplabitur: si obscurior fuerit lepra, et non creverit in cute, mundabit eum, quia scabies est: lavabitque homo vestimenta sua, et mundus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 13:7",
      "text": "Quod si postquam a sacerdote visus est, et redditus munditiæ, iterum lepra creverit: adducetur ad eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 13:8",
      "text": "et immunditiæ condemnabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 13:9",
      "text": "Plaga lepræ si fuerit in homine, adducetur ad sacerdotem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 13:10",
      "text": "et videbit eum. Cumque color albus in cute fuerit, et capillorum mutaverit aspectum, ipsa quoque caro viva apparuerit:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 13:11",
      "text": "lepra vetustissima judicabitur, atque inolita cuti. Contaminabit itaque eum sacerdos, et non recludet, quia perspicuæ immunditiæ est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 13:12",
      "text": "Sin autem effloruerit discurrens lepra in cute, et operuerit omnem cutem a capite usque ad pedes, quidquid sub aspectum oculorum cadit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 13:13",
      "text": "considerabit eum sacerdos, et teneri lepra mundissima judicabit: eo quod omnis in candorem versa sit, et idcirco homo mundus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 13:14",
      "text": "Quando vero caro vivens in eo apparuerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 13:15",
      "text": "tunc sacerdotis judicio polluetur, et inter immundos reputabitur: caro enim viva, si lepra aspergitur, immunda est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 13:16",
      "text": "Quod si rursum versa fuerit in alborem, et totum hominem operuerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 13:17",
      "text": "considerabit eum sacerdos, et mundum esse decernet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 13:18",
      "text": "Caro autem et cutis in qua ulcus natum est, et sanatum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 13:19",
      "text": "et in loco ulceris cicatrix alba apparuerit, sive subrufa, adducetur homo ad sacerdotem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 13:20",
      "text": "Qui cum viderit locum lepræ humiliorem carne reliqua, et pilos versos in candorem, contaminabit eum: plaga enim lepræ orta est in ulcere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 13:21",
      "text": "Quod si pilus coloris est pristini, et cicatrix subobscura, et vicina carne non est humilior, recludet eum septem diebus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 13:22",
      "text": "et si quidem creverit, adjudicabit eum lepræ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 13:23",
      "text": "sin autem steterit in loco suo, ulceris est cicatrix, et homo mundus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 13:24",
      "text": "Caro autem et cutis, quam ignis exusserit, et sanata albam sive rufam habuerit cicatricem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 13:25",
      "text": "considerabit eam sacerdos: et ecce versa est in alborem, et locus ejus reliqua cute est humilior, contaminabit eum, quia plaga lepræ in cicatrice orta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 13:26",
      "text": "Quod si pilorum color non fuerit immutatus, nec humilior plaga carne reliqua, et ipsa lepræ species fuerit subobscura, recludet eum septem diebus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 13:27",
      "text": "et die septimo contemplabitur: si creverit in cute lepra, contaminabit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 13:28",
      "text": "Sin autem in loco suo candor steterit non satis clarus, plaga combustionis est, et idcirco mundabitur, quia cicatrix est combusturæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 13:29",
      "text": "Vir, sive mulier, in cujus capite vel barba germinaverit lepra, videbit eos sacerdos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 13:30",
      "text": "Et si quidem humilior fuerit locus carne reliqua, et capillus flavus, solitoque subtilior, contaminabit eos, quia lepra capitis ac barbæ est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 13:31",
      "text": "Sin autem viderit locum maculæ æqualem vicinæ carni, et capillum nigrum: recludet eum septem diebus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 13:32",
      "text": "et die septimo intuebitur. Si non creverit macula, et capillus sui coloris est, et locus plagæ carni reliquæ æqualis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 13:33",
      "text": "radetur homo absque loco maculæ, et includetur septem diebus aliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 13:34",
      "text": "Si die septimo visa fuerit stetisse plaga in loco suo, nec humilior carne reliqua, mundabit eum: lotisque vestibus suis, mundus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.35",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "Leviticus 13:35",
      "text": "Sin autem post emundationem rursus creverit macula in cute,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.36",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "Leviticus 13:36",
      "text": "non quæret amplius utrum capillus in flavum colorem sit immutatus, quia aperte immundus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.37",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "Leviticus 13:37",
      "text": "Porro si steterit macula, et capilli nigri fuerint, noverit hominem sanatum esse, et confidenter eum pronuntiet mundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.38",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 38,
      "referenceLabel": "Leviticus 13:38",
      "text": "Vir, sive mulier, in cujus cute candor apparuerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.39",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 39,
      "referenceLabel": "Leviticus 13:39",
      "text": "intuebitur eos sacerdos. Si deprehenderit subobscurum alborem lucere in cute, sciat non esse lepram, sed maculam coloris candidi, et hominem mundum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.40",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 40,
      "referenceLabel": "Leviticus 13:40",
      "text": "Vir, de cujus capite capilli fluunt, calvus et mundus est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.41",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 41,
      "referenceLabel": "Leviticus 13:41",
      "text": "et si a fronte ceciderint pili, recalvaster et mundus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.42",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 42,
      "referenceLabel": "Leviticus 13:42",
      "text": "Sin autem in calvitio sive in recalvatione albus vel rufus color fuerit exortus,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.43",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 43,
      "referenceLabel": "Leviticus 13:43",
      "text": "et hoc sacerdos viderit, condemnabit eum haud dubiæ lepræ, quæ orta est in calvitio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.44",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 44,
      "referenceLabel": "Leviticus 13:44",
      "text": "Quicumque ergo maculatus fuerit lepra, et separatus est ad arbitrium sacerdotis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.45",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 45,
      "referenceLabel": "Leviticus 13:45",
      "text": "habebit vestimenta dissuta, caput nudum, os veste contectum, contaminatum ac sordidum se clamabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.46",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 46,
      "referenceLabel": "Leviticus 13:46",
      "text": "Omni tempore quo leprosus est et immundus, solus habitabit extra castra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.47",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 47,
      "referenceLabel": "Leviticus 13:47",
      "text": "Vestis lanea sive linea, quæ lepram habuerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.48",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 48,
      "referenceLabel": "Leviticus 13:48",
      "text": "in stamine atque subtegmine, aut certe pellis, vel quidquid ex pelle confectum est,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.49",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 49,
      "referenceLabel": "Leviticus 13:49",
      "text": "si alba vel rufa macula fuerit infecta, lepra reputabitur, ostendeturque sacerdoti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.50",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 50,
      "referenceLabel": "Leviticus 13:50",
      "text": "qui consideratam recludet septem diebus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.51",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 51,
      "referenceLabel": "Leviticus 13:51",
      "text": "et die septimo rursus aspiciens, si deprehenderit crevisse, lepra perseverans est: pollutum judicabit vestimentum, et omne in quo fuerit inventa:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.52",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 52,
      "referenceLabel": "Leviticus 13:52",
      "text": "et idcirco comburetur flammis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.53",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 53,
      "referenceLabel": "Leviticus 13:53",
      "text": "Quod si eam viderit non crevisse,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.54",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 54,
      "referenceLabel": "Leviticus 13:54",
      "text": "præcipiet, et lavabunt id in quo lepra est, recludetque illud septem diebus aliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.55",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 55,
      "referenceLabel": "Leviticus 13:55",
      "text": "Et cum viderit faciem quidem pristinam non reversam, nec tamen crevisse lepram, immundum judicabit, et igne comburet, eo quod infusa sit in superficie vestimenti, vel per totum, lepra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.56",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 56,
      "referenceLabel": "Leviticus 13:56",
      "text": "Sin autem obscurior fuerit locus lepræ, postquam vestis est lota, abrumpet eum, et a solido dividet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.57",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 57,
      "referenceLabel": "Leviticus 13:57",
      "text": "Quod si ultra apparuerit in his locis, quæ prius immaculata erant, lepra volatilis et vaga, debet igne comburi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.58",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 58,
      "referenceLabel": "Leviticus 13:58",
      "text": "Si cessaverit, lavabit aqua ea, quæ pura sunt, secundo, et munda erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.13.59",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 13,
      "verseNumber": 59,
      "referenceLabel": "Leviticus 13:59",
      "text": "Ista est lex lepræ vestimenti lanei et linei, staminis, atque subtegminis, omnisque supellectilis pelliceæ, quomodo mundari debeat, vel contaminari.",
      "paragraphStart": false
    }
  ]
}
