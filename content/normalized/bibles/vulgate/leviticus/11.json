{
  "chapter": {
    "id": "vulgate:leviticus.11",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 11,
    "referenceLabel": "Leviticus 11",
    "summary": "Source text for Leviticus 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.11.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 11:1",
      "text": "Locutusque est Dominus ad Moysen et Aaron, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.11.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 11:2",
      "text": "Dicite filiis Israël: Hæc sunt animalia quæ comedere debetis de cunctis animantibus terræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 11:3",
      "text": "omne quod habet divisam ungulam, et ruminat in pecoribus, comedetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 11:4",
      "text": "Quidquid autem ruminat quidem, et habet ungulam, sed non dividit eam, sicut camelus et cetera, non comedetis illud, et inter immunda reputabitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 11:5",
      "text": "Chœrogryllus qui ruminat, ungulamque non dividit, immundus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 11:6",
      "text": "Lepus quoque: nam et ipse ruminat, sed ungulam non dividit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 11:7",
      "text": "Et sus: qui cum ungulam dividat, non ruminat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 11:8",
      "text": "Horum carnibus non vescemini, nec cadavera contingetis, quia immunda sunt vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 11:9",
      "text": "Hæc sunt quæ gignuntur in aquis, et vesci licitum est: omne quod habet pinnulas et squamas, tam in mari quam in fluminibus et stagnis, comedetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 11:10",
      "text": "Quidquid autem pinnulas et squamas non habet, eorum quæ in aquis moventur et vivunt, abominabile vobis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 11:11",
      "text": "execrandumque erit: carnes eorum non comedetis, et morticina vitabitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 11:12",
      "text": "Cuncta quæ non habent pinnulas et squamas in aquis, polluta erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 11:13",
      "text": "Hæc sunt quæ de avibus comedere non debetis, et vitanda sunt vobis: aquilam, et gryphem, et haliæetum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 11:14",
      "text": "et milvum ac vulturem juxta genus suum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 11:15",
      "text": "et omne corvini generis in similitudinem suam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 11:16",
      "text": "struthionem, et noctuam, et larum, et accipitrem juxta genus suum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 11:17",
      "text": "bubonem, et mergulum, et ibin,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 11:18",
      "text": "et cygnum, et onocrotalum, et porphyrionem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 11:19",
      "text": "herodionem, et charadrion juxta genus suum, upupam quoque, et vespertilionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 11:20",
      "text": "Omne de volucribus quod graditur super quatuor pedes, abominabile erit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 11:21",
      "text": "Quidquid autem ambulat quidem super quatuor pedes, sed habet longiora retro crura, per quæ salit super terram,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 11:22",
      "text": "comedere debetis, ut est bruchus in genere suo, et attacus atque ophiomachus, ac locusta, singula juxta genus suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 11:23",
      "text": "Quidquid autem ex volucribus quatuor tantum habet pedes, execrabile erit vobis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 11:24",
      "text": "et quicumque morticina eorum tetigerit, polluetur, et erit immundus usque ad vesperum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 11:25",
      "text": "et si necesse fuerit ut portet quippiam horum mortuum, lavabit vestimenta sua, et immundus erit usque ad occasum solis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 11:26",
      "text": "Omne animal quod habet quidem ungulam, sed non dividit eam, nec ruminat, immundum erit: et qui tetigerit illud, contaminabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 11:27",
      "text": "Quod ambulat super manus ex cunctis animantibus, quæ incedunt quadrupedia, immundum erit: qui tetigerit morticina eorum, polluetur usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 11:28",
      "text": "Et qui portaverit hujuscemodi cadavera, lavabit vestimenta sua, et immundus erit usque ad vesperum: quia omnia hæc immunda sunt vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 11:29",
      "text": "Hæc quoque inter polluta reputabuntur de his quæ moventur in terra, mustela et mus et crocodilus, singula juxta genus suum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 11:30",
      "text": "mygale, et chamæleon, et stellio, et lacerta, et talpa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 11:31",
      "text": "Omnia hæc immunda sunt. Qui tetigerit morticina eorum, immundus erit usque ad vesperum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 11:32",
      "text": "et super quod ceciderit quidquam de morticinis eorum, polluetur, tam vas ligneum et vestimentum, quam pelles et cilicia: et in quocumque fit opus, tingentur aqua, et polluta erunt usque ad vesperum, et sic postea mundabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 11:33",
      "text": "Vas autem fictile, in quod horum quidquam intro cecidit, polluetur, et idcirco frangendum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 11:34",
      "text": "Omnis cibus, quem comedetis, si fusa fuerit super eum aqua, immundus erit: et omne liquens quod bibitur de universo vase, immundum erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.35",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Leviticus 11:35",
      "text": "Et quidquid de morticinis hujuscemodi ceciderit super illud, immundum erit: sive clibani, sive chytropodes, destruentur, et immundi erunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.36",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Leviticus 11:36",
      "text": "Fontes vero et cisternæ, et omnis aquarum congregatio munda erit. Qui morticinum eorum tetigerit, polluetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.37",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 37,
      "referenceLabel": "Leviticus 11:37",
      "text": "Si ceciderit super sementem, non polluet eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.38",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 38,
      "referenceLabel": "Leviticus 11:38",
      "text": "Si autem quispiam aqua sementem perfuderit, et postea morticinis tacta fuerit, illico polluetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.39",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 39,
      "referenceLabel": "Leviticus 11:39",
      "text": "Si mortuum fuerit animal, quod licet vobis comedere, qui cadaver ejus tetigerit, immundus erit usque ad vesperum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.40",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 40,
      "referenceLabel": "Leviticus 11:40",
      "text": "et qui comederit ex eo quippiam, sive portaverit, lavabit vestimenta sua, et immundus erit usque ad vesperum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.41",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 41,
      "referenceLabel": "Leviticus 11:41",
      "text": "Omne quod reptat super terram, abominabile erit, nec assumetur in cibum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.42",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 42,
      "referenceLabel": "Leviticus 11:42",
      "text": "Quidquid super pectus quadrupes graditur, et multos habet pedes, sive per humum trahitur, non comedetis, quia abominabile est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.43",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 43,
      "referenceLabel": "Leviticus 11:43",
      "text": "Nolite contaminare animas vestras, nec tangatis quidquam eorum, ne immundi sitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.44",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 44,
      "referenceLabel": "Leviticus 11:44",
      "text": "Ego enim sum Dominus Deus vester: sancti estote, quia ego sanctus sum. Ne polluatis animas vestras in omni reptili quod movetur super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.45",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 45,
      "referenceLabel": "Leviticus 11:45",
      "text": "Ego enim sum Dominus, qui eduxi vos de terra Ægypti, ut essem vobis in Deum. Sancti eritis, quia ego sanctus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.46",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 46,
      "referenceLabel": "Leviticus 11:46",
      "text": "Ista est lex animantium ac volucrum, et omnis animæ viventis, quæ movetur in aqua, et reptat in terra,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.11.47",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 11,
      "verseNumber": 47,
      "referenceLabel": "Leviticus 11:47",
      "text": "ut differentias noveritis mundi et immundi, et sciatis quid comedere et quid respuere debeatis.",
      "paragraphStart": false
    }
  ]
}
