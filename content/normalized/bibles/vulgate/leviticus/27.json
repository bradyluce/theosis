{
  "chapter": {
    "id": "vulgate:leviticus.27",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 27,
    "referenceLabel": "Leviticus 27",
    "summary": "Source text for Leviticus 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.27.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 27:1",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.27.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 27:2",
      "text": "Loquere filiis Israël, et dices ad eos: Homo qui votum fecerit, et spoponderit Deo animam suam, sub æstimatione dabit pretium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 27:3",
      "text": "Si fuerit masculus a vigesimo anno usque ad sexagesimum annum, dabit quinquaginta siclos argenti ad mensuram sanctuarii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 27:4",
      "text": "si mulier, triginta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 27:5",
      "text": "A quinto autem anno usque ad vigesimum, masculus dabit viginti siclos: femina, decem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 27:6",
      "text": "Ab uno mense usque ad annum quintum, pro masculo dabuntur quinque sicli: pro femina, tres.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 27:7",
      "text": "Sexagenarius et ultra masculus dabit quindecim siclos: femina, decem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 27:8",
      "text": "Si pauper fuerit, et æstimationem reddere non valebit, stabit coram sacerdote: et quantum ille æstimaverit, et viderit eum posse reddere, tantum dabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 27:9",
      "text": "Animal autem, quod immolari potest Domino, si quis voverit, sanctum erit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 27:10",
      "text": "et mutari non poterit, id est, nec melius malo, nec pejus bono: quod si mutaverit, et ipsum quod mutatum est, et illud pro quo mutatum est, consecratum erit Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 27:11",
      "text": "Animal immundum, quod immolari Domino non potest, si quis voverit, adducetur ante sacerdotem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 27:12",
      "text": "qui judicans utrum bonum an malum sit, statuet pretium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 27:13",
      "text": "Quod si dare voluerit is qui offert, addet supra æstimationem quintam partem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 27:14",
      "text": "Homo si voverit domum suam, et sanctificaverit Domino, considerabit eam sacerdos utrum bona an mala sit, et juxta pretium, quod ab eo fuerit constitutum, venundabitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 27:15",
      "text": "sin autem ille qui voverat, voluerit redimere eam, dabit quintam partem æstimationis supra, et habebit domum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 27:16",
      "text": "Quod si agrum possessionis suæ voverit, et consecraverit Domino, juxta mensuram sementis æstimabitur pretium: si triginta modiis hordei seritur terra, quinquaginta siclis venundetur argenti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 27:17",
      "text": "Si statim ab anno incipientis jubilæi voverit agrum, quanto valere potest, tanto æstimabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 27:18",
      "text": "Sin autem post aliquantum temporis, supputabit sacerdos pecuniam juxta annorum, qui reliqui sunt, numerum usque ad jubilæum, et detrahetur ex pretio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 27:19",
      "text": "Quod si voluerit redimere agrum ille qui voverat, addet quintam partem æstimatæ pecuniæ, et possidebit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 27:20",
      "text": "Sin autem noluerit redimere, sed alteri cuilibet fuerit venundatus, ultra eum qui voverat redimere non poterit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 27:21",
      "text": "Quia cum jubilæi venerit dies, sanctificatus erit Domino, et possessio consecrata ad jus pertinet sacerdotum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 27:22",
      "text": "Si ager emptus est, et non de possessione majorum sanctificatus fuerit Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 27:23",
      "text": "supputabit sacerdos juxta annorum numerum usque ad jubilæum, pretium: et dabit ille qui voverat eum, Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 27:24",
      "text": "In jubilæo autem revertetur ad priorem dominum, qui vendiderat eum, et habuerat in sorte possessionis suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 27:25",
      "text": "Omnis æstimatio siclo sanctuarii ponderabitur. Siclus viginti obolos habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 27:26",
      "text": "Primogenita, quæ ad Dominum pertinent, nemo sanctificare poterit et vovere: sive bos, sive ovis fuerit, Domini sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 27:27",
      "text": "Quod si immundum est animal, redimet qui obtulit, juxta æstimationem tuam, et addet quintam partem pretii: si redimere noluerit, vendetur alteri quantocumque a te fuerit æstimatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 27:28",
      "text": "Omne quod Domino consecratur, sive homo fuerit, sive animal, sive ager, non vendetur, nec redimi poterit. Quidquid semel fuerit consecratum, Sanctum sanctorum erit Domino:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 27:29",
      "text": "et omnis consecratio, quæ offertur ab homine, non redimetur, sed morte morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 27:30",
      "text": "Omnes decimæ terræ, sive de frugibus, sive de pomis arborum, Domini sunt, et illi sanctificantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 27:31",
      "text": "Si quis autem voluerit redimere decimas suas, addet quintam partem earum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 27:32",
      "text": "Omnium decimarum bovis et ovis et capræ, quæ sub pastoris virga transeunt, quidquid decimum venerit, sanctificabitur Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 27:33",
      "text": "Non eligetur nec bonum nec malum, nec altero commutabitur, si quis mutaverit: et quod mutatum est, et pro quo mutatum est, sanctificabitur Domino, et non redimetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.27.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 27,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 27:34",
      "text": "Hæc sunt præcepta, quæ mandavit Dominus Moysi ad filios Israël in monte Sinai.",
      "paragraphStart": false
    }
  ]
}
