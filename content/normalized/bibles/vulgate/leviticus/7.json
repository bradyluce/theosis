{
  "chapter": {
    "id": "vulgate:leviticus.7",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 7,
    "referenceLabel": "Leviticus 7",
    "summary": "Source text for Leviticus 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.7.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 7:1",
      "text": "Hæc quoque lex hostiæ pro delicto, Sancta sanctorum est:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.7.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 7:2",
      "text": "idcirco ubi immolabitur holocaustum, mactabitur et victima pro delicto: sanguis ejus per gyrum altaris fundetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 7:3",
      "text": "Offerent ex ea caudam et adipem qui operit vitalia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 7:4",
      "text": "duos renunculos, et pinguedinem quæ juxta ilia est, reticulumque jecoris cum renunculis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 7:5",
      "text": "Et adolebit ea sacerdos super altare: incensum est Domini pro delicto.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 7:6",
      "text": "Omnis masculus de sacerdotali genere, in loco sancto vescetur his carnibus, quia Sanctum sanctorum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 7:7",
      "text": "Sicut pro peccato offertur hostia, ita et pro delicto: utriusque hostiæ lex una erit: ad sacerdotem, qui eam obtulerit, pertinebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 7:8",
      "text": "Sacerdos qui offert holocausti victimam, habebit pellem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 7:9",
      "text": "Et omne sacrificium similæ, quod coquitur in clibano, et quidquid in craticula, vel in sartagine præparatur, ejus erit sacerdotis a quo offertur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 7:10",
      "text": "sive oleo conspersa, sive arida fuerint, cunctis filiis Aaron mensura æqua per singulos dividetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 7:11",
      "text": "Hæc est lex hostiæ pacificorum quæ offertur Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 7:12",
      "text": "Si pro gratiarum actione oblatio fuerit, offerent panes absque fermento conspersos oleo, et lagana azyma uncta oleo, coctamque similam, et collyridas olei admistione conspersas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 7:13",
      "text": "panes quoque fermentatos cum hostia gratiarum, quæ immolatur pro pacificis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 7:14",
      "text": "ex quibus unus pro primitiis offeretur Domino, et erit sacerdotis qui fundet hostiæ sanguinem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 7:15",
      "text": "cujus carnes eadem comedentur die, nec remanebit ex eis quidquam usque mane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 7:16",
      "text": "Si voto, vel sponte quispiam obtulerit hostiam, eadem similiter edetur die: sed et si quid in crastinum remanserit, vesci licitum est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 7:17",
      "text": "quidquid autem tertius invenerit dies, ignis absumet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 7:18",
      "text": "Si quis de carnibus victimæ pacificorum die tertio comederit, irrita fiet oblatio, nec proderit offerenti: quin potius quæcumque anima tali se edulio contaminaverit, prævaricationis rea erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 7:19",
      "text": "Caro, quæ aliquid tetigerit immundum, non comedetur, sed comburetur igni: qui fuerit mundus, vescetur ex ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 7:20",
      "text": "Anima polluta quæ ederit de carnibus hostiæ pacificorum, quæ oblata est Domino, peribit de populis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 7:21",
      "text": "Et quæ tetigerit immunditiam hominis, vel jumenti, sive omnis rei quæ polluere potest, et comederit de hujuscemodi carnibus, interibit de populis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 7:22",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 7:23",
      "text": "Loquere filiis Israël: Adipem ovis, et bovis, et capræ non comedetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 7:24",
      "text": "Adipem cadaveris morticini, et ejus animalis, quod a bestia captum est, habebitis in varios usus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 7:25",
      "text": "Si quis adipem, qui offerri debet in incensum Domini, comederit, peribit de populo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 7:26",
      "text": "Sanguinem quoque omnis animalis non sumetis in cibo, tam de avibus quam de pecoribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 7:27",
      "text": "Omnis anima, quæ ederit sanguinem, peribit de populis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 7:28",
      "text": "Locutusque est Dominus ad Moysen, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 7:29",
      "text": "Loquere filiis Israël, dicens: Qui offert victimam pacificorum Domino, offerat simul et sacrificium, id est, libamenta ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 7:30",
      "text": "Tenebit manibus adipem hostiæ, et pectusculum: cumque ambo oblata Domino consecraverit, tradet sacerdoti,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 7:31",
      "text": "qui adolebit adipem super altare, pectusculum autem erit Aaron et filiorum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 7:32",
      "text": "Armus quoque dexter de pacificorum hostiis cedet in primitias sacerdotis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 7:33",
      "text": "Qui obtulerit sanguinem et adipem filiorum Aaron, ipse habebit et armum dextrum in portione sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 7:34",
      "text": "Pectusculum enim elevationis, et armum separationis, tuli a filiis Israël de hostiis eorum pacificis, et dedi Aaron sacerdoti, et filiis ejus, lege perpetua, ab omni populo Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.35",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Leviticus 7:35",
      "text": "Hæc est unctio Aaron et filiorum ejus in cæremoniis Domini die qua obtulit eos Moyses, ut sacerdotio fungerentur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.36",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Leviticus 7:36",
      "text": "et quæ præcepit eis dari Dominus a filiis Israël religione perpetua in generationibus suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.37",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Leviticus 7:37",
      "text": "Ista est lex holocausti, et sacrificii pro peccato atque delicto, et pro consecratione et pacificorum victimis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.7.38",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "Leviticus 7:38",
      "text": "quam constituit Dominus Moysi in monte Sinai, quando mandabit filiis Israël ut offerrent oblationes suas Domino in deserto Sinai.",
      "paragraphStart": false
    }
  ]
}
