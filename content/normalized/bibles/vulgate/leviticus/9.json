{
  "chapter": {
    "id": "vulgate:leviticus.9",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 9,
    "referenceLabel": "Leviticus 9",
    "summary": "Source text for Leviticus 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.9.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 9:1",
      "text": "Facto autem octavo die, vocavit Moyses Aaron, et filios ejus, ac majores natu Israël, dixitque ad Aaron:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.9.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 9:2",
      "text": "Tolle de armento vitulum pro peccato, et arietem in holocaustum, utrumque immaculatum, et offer illos coram Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 9:3",
      "text": "Et ad filios Israël loqueris: Tollite hircum pro peccato, et vitulum, atque agnum, anniculos, et sine macula in holocaustum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 9:4",
      "text": "bovem et arietem pro pacificis: et immolate eos coram Domino, in sacrificio singulorum similam conspersam oleo offerentes: hodie enim Dominus apparebit vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 9:5",
      "text": "Tulerunt ergo cuncta quæ jusserat Moyses ad ostium tabernaculi: ubi cum omnis multitudo astaret,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 9:6",
      "text": "ait Moyses: Iste est sermo, quem præcepit Dominus: facite, et apparebit vobis gloria ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 9:7",
      "text": "Et dixit ad Aaron: Accede ad altare, et immola pro peccato tuo: offer holocaustum, et deprecare pro te et pro populo: cumque mactaveris hostiam populi, ora pro eo, sicut præcepit Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 9:8",
      "text": "Statimque Aaron accedens ad altare, immolavit vitulum pro peccato suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 9:9",
      "text": "cujus sanguinem obtulerunt ei filii sui: in quo tingens digitum, tetigit cornua altaris, et fudit residuum ad basim ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 9:10",
      "text": "Adipemque, et renunculos, ac reticulum jecoris, quæ sunt pro peccato, adolevit super altare, sicut præceperat Dominus Moysi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 9:11",
      "text": "carnes vero et pellem ejus extra castra combussit igni.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 9:12",
      "text": "Immolavit et holocausti victimam: obtuleruntque ei filii sui sanguinem ejus, quem fudit per altaris circuitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 9:13",
      "text": "Ipsam etiam hostiam in frusta concisam, cum capite et membris singulis obtulerunt; quæ omnia super altare cremavit igni,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 9:14",
      "text": "lotis aqua prius intestinis et pedibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 9:15",
      "text": "Et pro peccato populi offerens, mactavit hircum: expiatoque altari,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 9:16",
      "text": "fecit holocaustum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 9:17",
      "text": "addens in sacrificio libamenta, quæ pariter offeruntur, et adolens ea super altare, absque cæremoniis holocausti matutini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 9:18",
      "text": "Immolavit et bovem atque arietem, hostias pacificas populi: obtuleruntque ei filii sui sanguinem, quem fudit super altare in circuitum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 9:19",
      "text": "Adipem autem bovis, et caudam arietis, renunculosque cum adipibus suis, et reticulum jecoris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 9:20",
      "text": "posuerunt super pectora: cumque cremati essent adipes super altare,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 9:21",
      "text": "pectora eorum, et armos dextros separavit Aaron, elevans coram Domino, sicut præceperat Moyses.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 9:22",
      "text": "Et extendens manus ad populum, benedixit ei. Sicque completis hostiis pro peccato, et holocaustis, et pacificis, descendit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 9:23",
      "text": "Ingressi autem Moyses et Aaron in tabernaculum testimonii, et deinceps egressi, benedixerunt populo. Apparuitque gloria Domini omni multitudini:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.9.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 9:24",
      "text": "et ecce egressus ignis a Domino, devoravit holocaustum, et adipes qui erant super altare. Quod cum vidissent turbæ, laudaverunt Dominum, ruentes in facies suas.",
      "paragraphStart": false
    }
  ]
}
