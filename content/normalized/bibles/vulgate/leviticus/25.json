{
  "chapter": {
    "id": "vulgate:leviticus.25",
    "translationId": "vulgate",
    "bookSlug": "leviticus",
    "chapterNumber": 25,
    "referenceLabel": "Leviticus 25",
    "summary": "Source text for Leviticus 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:leviticus.25.1",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Leviticus 25:1",
      "text": "Locutusque est Dominus ad Moysen in monte Sinai, dicens:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:leviticus.25.2",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Leviticus 25:2",
      "text": "Loquere filiis Israël, et dices ad eos: Quando ingressi fueritis terram quam ego dabo vobis, sabbatizes sabbatum Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.3",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Leviticus 25:3",
      "text": "Sex annis seres agrum tuum, et sex annis putabis vineam tuam, colligesque fructus ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.4",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Leviticus 25:4",
      "text": "septimo autem anno sabbatum erit terræ, requietionis Domini: agrum non seres, et vineam non putabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.5",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Leviticus 25:5",
      "text": "Quæ sponte gignet humus, non metes: et uvas primitiarum tuarum non colliges quasi vindemiam: annus enim requietionis terræ est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.6",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Leviticus 25:6",
      "text": "sed erunt vobis in cibum, tibi et servo tuo, ancillæ et mercenario tuo, et advenæ qui peregrinantur apud te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.7",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Leviticus 25:7",
      "text": "jumentis tuis et pecoribus, omnia quæ nascuntur præbebunt cibum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.8",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Leviticus 25:8",
      "text": "Numerabis quoque tibi septem hebdomadas annorum, id est, septies septem, quæ simul faciunt annos quadraginta novem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.9",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Leviticus 25:9",
      "text": "et clanges buccina mense septimo, decima die mensis, propitiationis tempore, in universa terra vestra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.10",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Leviticus 25:10",
      "text": "Sanctificabisque annum quinquagesimum, et vocabis remissionem cunctis habitatoribus terræ tuæ: ipse est enim jubilæus. Revertetur homo ad possessionem suam, et unusquisque rediet ad familiam pristinam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.11",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Leviticus 25:11",
      "text": "quia jubilæus est, et quinquagesimus annus. Non seretis neque metetis sponte in agro nascentia, et primitias vindemiæ non colligetis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.12",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Leviticus 25:12",
      "text": "ob sanctificationem jubilæi: sed statim oblata comedetis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.13",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Leviticus 25:13",
      "text": "Anno jubilæi, redient omnes ad possessiones suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.14",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Leviticus 25:14",
      "text": "Quando vendes quippiam civi tuo, vel emes ab eo, ne contristes fratrem tuum, sed juxta numerum annorum jubilæi emes ab eo,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.15",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Leviticus 25:15",
      "text": "et juxta supputationem frugum vendet tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.16",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Leviticus 25:16",
      "text": "Quanto plures anni remanserint post jubilæum, tanto crescet et pretium: et quanto minus temporis numeraveris, tanto minoris et emptio constabit: tempus enim frugum vendet tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.17",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Leviticus 25:17",
      "text": "Nolite affligere contribules vestros, sed timeat unusquisque Deum suum, quia ego Dominus Deus vester.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.18",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Leviticus 25:18",
      "text": "Facite præcepta mea, et judicia custodite, et implete ea: ut habitare possitis in terra absque ullo pavore,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.19",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Leviticus 25:19",
      "text": "et gignat vobis humus fructus suos, quibus vescamini usque ad saturitatem, nullius impetum formidantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.20",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Leviticus 25:20",
      "text": "Quod si dixeritis: Quid comedemus anno septimo, si non severimus, neque collegerimus fruges nostras?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.21",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Leviticus 25:21",
      "text": "dabo benedictionem meam vobis anno sexto, et faciet fructus trium annorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.22",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Leviticus 25:22",
      "text": "seretisque anno octavo, et comedetis veteres fruges usque ad nonum annum: donec nova nascantur, edetis vetera.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.23",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Leviticus 25:23",
      "text": "Terra quoque non vendetur in perpetuum, quia mea est, et vos advenæ et coloni mei estis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.24",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Leviticus 25:24",
      "text": "unde cuncta regio possessionis vestræ sub redemptionis conditione vendetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.25",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Leviticus 25:25",
      "text": "Si attenuatus frater tuus vendiderit possessiunculam suam, et voluerit propinquus ejus, potest redimere quod ille vendiderat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.26",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Leviticus 25:26",
      "text": "Sin autem non habuerit proximum, et ipse pretium ad redimendum potuerit invenire,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.27",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Leviticus 25:27",
      "text": "computabuntur fructus ex eo tempore quo vendidit: et quod reliquum est, reddet emptori, sicque recipiet possessionem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.28",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Leviticus 25:28",
      "text": "Quod si non invenerit manus ejus ut reddat pretium, habebit emptor quod emerat, usque ad annum jubilæum. In ipso enim omnis venditio redibit ad dominum et ad possessorem pristinum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.29",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 29,
      "referenceLabel": "Leviticus 25:29",
      "text": "Qui vendiderit domum intra urbis muros, habebit licentiam redimendi, donec unus impleatur annus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.30",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 30,
      "referenceLabel": "Leviticus 25:30",
      "text": "Si non redemerit, et anni circulus fuerit evolutus, emptor possidebit eam, et posteri ejus in perpetuum, et redimi non poterit, etiam in jubilæo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.31",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 31,
      "referenceLabel": "Leviticus 25:31",
      "text": "Sin autem in villa domus, quæ muros non habet, agrorum jure vendetur: si ante redempta non fuerit, in jubilæo revertetur ad dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.32",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 32,
      "referenceLabel": "Leviticus 25:32",
      "text": "Ædes Levitarum quæ in urbibus sunt, semper possunt redimi:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.33",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 33,
      "referenceLabel": "Leviticus 25:33",
      "text": "si redemptæ non fuerint, in jubilæo revertentur ad dominos, quia domus urbium Levitarum pro possessionibus sunt inter filios Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.34",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 34,
      "referenceLabel": "Leviticus 25:34",
      "text": "Suburbana autem eorum non veneant, quia possessio sempiterna est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.35",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 35,
      "referenceLabel": "Leviticus 25:35",
      "text": "Si attenuatus fuerit frater tuus, et infirmus manu, et susceperis eum quasi advenam et peregrinum, et vixerit tecum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.36",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 36,
      "referenceLabel": "Leviticus 25:36",
      "text": "ne accipias usuras ab eo, nec amplius quam dedisti: time Deum tuum, ut vivere possit frater tuus apud te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.37",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 37,
      "referenceLabel": "Leviticus 25:37",
      "text": "Pecuniam tuam non dabis ei ad usuram, et frugum superabundantiam non exiges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.38",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 38,
      "referenceLabel": "Leviticus 25:38",
      "text": "Ego Dominus Deus vester, qui eduxi vos de terra Ægypti, ut darem vobis terram Chanaan, et essem vester Deus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.39",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 39,
      "referenceLabel": "Leviticus 25:39",
      "text": "Si paupertate compulsus vendiderit se tibi frater tuus, non eum opprimes servitute famulorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.40",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 40,
      "referenceLabel": "Leviticus 25:40",
      "text": "sed quasi mercenarius et colonus erit: usque ad annum jubilæum operabitur apud te,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.41",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 41,
      "referenceLabel": "Leviticus 25:41",
      "text": "et postea egredietur cum liberis suis, et revertetur ad cognationem, ad possessionem patrum suorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.42",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 42,
      "referenceLabel": "Leviticus 25:42",
      "text": "Mei enim servi sunt, et ego eduxi eos de terra Ægypti: non veneant conditione servorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.43",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 43,
      "referenceLabel": "Leviticus 25:43",
      "text": "ne affligas eum per potentiam, sed metuito Deum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.44",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 44,
      "referenceLabel": "Leviticus 25:44",
      "text": "Servus et ancilla sint vobis de nationibus quæ in circuitu vestro sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.45",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 45,
      "referenceLabel": "Leviticus 25:45",
      "text": "et de advenis qui peregrinantur apud vos, vel qui ex his nati fuerint in terra vestra, hos habebitis famulos:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.46",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 46,
      "referenceLabel": "Leviticus 25:46",
      "text": "et hæreditario jure transmittetis ad posteros, ac possidebitis in æternum: fratres autem vestros filios Israël ne opprimatis per potentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.47",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 47,
      "referenceLabel": "Leviticus 25:47",
      "text": "Si invaluerit apud vos manus advenæ atque peregrini, et attenuatus frater tuus vendiderit se ei, aut cuiquam de stirpe ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.48",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 48,
      "referenceLabel": "Leviticus 25:48",
      "text": "post venditionem potest redimi. Qui voluerit ex fratribus suis, redimet eum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.49",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 49,
      "referenceLabel": "Leviticus 25:49",
      "text": "et patruus, et patruelis, et consanguineus, et affinis. Sin autem et ipse potuerit, redimet se,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.50",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 50,
      "referenceLabel": "Leviticus 25:50",
      "text": "supputatis dumtaxat annis a tempore venditionis suæ usque ad annum jubilæum: et pecunia, qua venditus fuerat, juxta annorum numerum, et rationem mercenarii supputata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.51",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 51,
      "referenceLabel": "Leviticus 25:51",
      "text": "Si plures fuerint anni qui remanent usque ad jubilæum, secundum hos reddet et pretium:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.52",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 52,
      "referenceLabel": "Leviticus 25:52",
      "text": "si pauci, ponet rationem cum eo juxta annorum numerum, et reddet emptori quod reliquum est annorum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.53",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 53,
      "referenceLabel": "Leviticus 25:53",
      "text": "quibus ante servivit mercedibus imputatis: non affliget eum violenter in conspectu tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.54",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 54,
      "referenceLabel": "Leviticus 25:54",
      "text": "Quod si per hæc redimi non potuerit, anno jubilæo egredietur cum liberis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:leviticus.25.55",
      "translationId": "vulgate",
      "bookSlug": "leviticus",
      "chapterNumber": 25,
      "verseNumber": 55,
      "referenceLabel": "Leviticus 25:55",
      "text": "Mei enim sunt servi filii Israël, quos eduxi de terra Ægypti.",
      "paragraphStart": false
    }
  ]
}
