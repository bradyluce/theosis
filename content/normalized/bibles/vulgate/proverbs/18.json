{
  "chapter": {
    "id": "vulgate:proverbs.18",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 18,
    "referenceLabel": "Proverbs 18",
    "summary": "Source text for Proverbs 18 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.18.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 18:1",
      "text": "Occasiones quærit qui vult recedere ab amico: omni tempore erit exprobrabilis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.18.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 18:2",
      "text": "Non recipit stultus verba prudentiæ, nisi ea dixeris quæ versantur in corde ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 18:3",
      "text": "Impius, cum in profundum venerit peccatorum, contemnit; sed sequitur eum ignominia et opprobrium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 18:4",
      "text": "Aqua profunda verba ex ore viri, et torrens redundans fons sapientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 18:5",
      "text": "Accipere personam impii non est bonum, ut declines a veritate judicii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 18:6",
      "text": "Labia stulti miscent se rixis, et os ejus jurgia provocat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 18:7",
      "text": "Os stulti contritio ejus, et labia ipsius ruina animæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 18:8",
      "text": "Verba bilinguis quasi simplicia, et ipsa perveniunt usque ad interiora ventris. Pigrum dejicit timor; animæ autem effeminatorum esurient.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 18:9",
      "text": "Qui mollis et dissolutus est in opere suo frater est sua opera dissipantis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 18:10",
      "text": "Turris fortissima nomen Domini; ad ipsum currit justus, et exaltabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 18:11",
      "text": "Substantia divitis urbs roboris ejus, et quasi murus validus circumdans eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 18:12",
      "text": "Antequam conteratur, exaltatur cor hominis, et antequam glorificetur, humiliatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 18:13",
      "text": "Qui prius respondet quam audiat, stultum se esse demonstrat, et confusione dignum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 18:14",
      "text": "Spiritus viri sustentat imbecillitatem suam; spiritum vero ad irascendum facilem quis poterit sustinere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 18:15",
      "text": "Cor prudens possidebit scientiam, et auris sapientium quærit doctrinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 18:16",
      "text": "Donum hominis dilatat viam ejus, et ante principes spatium ei facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 18:17",
      "text": "Justus prior est accusator sui: venit amicus ejus, et investigabit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 18:18",
      "text": "Contradictiones comprimit sors, et inter potentes quoque dijudicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 18:19",
      "text": "Frater qui adjuvatur a fratre quasi civitas firma, et judicia quasi vectes urbium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 18:20",
      "text": "De fructu oris viri replebitur venter ejus, et genimina labiorum ipsius saturabunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 18:21",
      "text": "Mors et vita in manu linguæ; qui diligunt eam comedent fructus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 18:22",
      "text": "Qui invenit mulierem bonam invenit bonum, et hauriet jucunditatem a Domino. Qui expellit mulierem bonam expellit bonum; qui autem tenet adulteram stultus est et impius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 18:23",
      "text": "Cum obsecrationibus loquetur pauper, et dives effabitur rigide.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.18.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 18:24",
      "text": "Vir amabilis ad societatem magis amicus erit quam frater.",
      "paragraphStart": false
    }
  ]
}
