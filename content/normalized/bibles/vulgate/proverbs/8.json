{
  "chapter": {
    "id": "vulgate:proverbs.8",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 8,
    "referenceLabel": "Proverbs 8",
    "summary": "Source text for Proverbs 8 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.8.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 8:1",
      "text": "Numquid non sapientia clamitat, et prudentia dat vocem suam?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.8.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 8:2",
      "text": "In summis excelsisque verticibus supra viam, in mediis semitis stans,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 8:3",
      "text": "juxta portas civitatis, in ipsis foribus loquitur, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 8:4",
      "text": "O viri, ad vos clamito, et vox mea ad filios hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 8:5",
      "text": "Intelligite, parvuli, astutiam, et insipientes, animadvertite.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 8:6",
      "text": "Audite, quoniam de rebus magnis locutura sum, et aperientur labia mea ut recta prædicent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 8:7",
      "text": "Veritatem meditabitur guttur meum, et labia mea detestabuntur impium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 8:8",
      "text": "Justi sunt omnes sermones mei: non est in eis pravum quid, neque perversum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 8:9",
      "text": "recti sunt intelligentibus, et æqui invenientibus scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 8:10",
      "text": "Accipite disciplinam meam, et non pecuniam; doctrinam magis quam aurum eligite:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 8:11",
      "text": "melior est enim sapientia cunctis pretiosissimis, et omne desiderabile ei non potest comparari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 8:12",
      "text": "Ego sapientia, habito in consilio, et eruditis intersum cogitationibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 8:13",
      "text": "Timor Domini odit malum: arrogantiam, et superbiam, et viam pravam, et os bilingue, detestor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 8:14",
      "text": "Meum est consilium et æquitas; mea est prudentia, mea est fortitudo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 8:15",
      "text": "Per me reges regnant, et legum conditores justa decernunt;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 8:16",
      "text": "per me principes imperant, et potentes decernunt justitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 8:17",
      "text": "Ego diligentes me diligo, et qui mane vigilant ad me, invenient me.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 8:18",
      "text": "Mecum sunt divitiæ et gloria, opes superbæ et justitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 8:19",
      "text": "Melior est enim fructus meus auro et lapide pretioso, et genimina mea argento electo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 8:20",
      "text": "In viis justitiæ ambulo, in medio semitarum judicii:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 8:21",
      "text": "ut ditem diligentes me, et thesauros eorum repleam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 8:22",
      "text": "Dominus possedit me in initio viarum suarum antequam quidquam faceret a principio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 8:23",
      "text": "Ab æterno ordinata sum, et ex antiquis antequam terra fieret.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 8:24",
      "text": "Nondum erant abyssi, et ego jam concepta eram: necdum fontes aquarum eruperant,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 8:25",
      "text": "necdum montes gravi mole constiterant: ante colles ego parturiebar.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 8:26",
      "text": "Adhuc terram non fecerat, et flumina, et cardines orbis terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 8:27",
      "text": "Quando præparabat cælos, aderam; quando certa lege et gyro vallabat abyssos;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 8:28",
      "text": "quando æthera firmabat sursum, et librabat fontes aquarum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 8:29",
      "text": "quando circumdabat mari terminum suum, et legem ponebat aquis, ne transirent fines suos; quando appendebat fundamenta terræ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 8:30",
      "text": "cum eo eram, cuncta componens. Et delectabar per singulos dies, ludens coram eo omni tempore,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 8:31",
      "text": "ludens in orbe terrarum; et deliciæ meæ esse cum filiis hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 8:32",
      "text": "Nunc ergo, filii, audite me: beati qui custodiunt vias meas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 8:33",
      "text": "Audite disciplinam, et estote sapientes, et nolite abjicere eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.34",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 8:34",
      "text": "Beatus homo qui audit me, et qui vigilat ad fores meas quotidie, et observat ad postes ostii mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.35",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 8:35",
      "text": "Qui me invenerit, inveniet vitam, et hauriet salutem a Domino.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.8.36",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Proverbs 8:36",
      "text": "Qui autem in me peccaverit, lædet animam suam; omnes qui me oderunt diligunt mortem.",
      "paragraphStart": false
    }
  ]
}
