{
  "chapter": {
    "id": "vulgate:proverbs.17",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 17,
    "referenceLabel": "Proverbs 17",
    "summary": "Source text for Proverbs 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.17.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 17:1",
      "text": "Melior est buccella sicca cum gaudio quam domus plena victimis cum jurgio.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.17.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 17:2",
      "text": "Servus sapiens dominabitur filiis stultis, et inter fratres hæreditatem dividet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 17:3",
      "text": "Sicut igne probatur argentum et aurum camino, ita corda probat Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 17:4",
      "text": "Malus obedit linguæ iniquæ, et fallax obtemperat labiis mendacibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 17:5",
      "text": "Qui despicit pauperem exprobrat factori ejus, et qui ruina lætatur alterius non erit impunitus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 17:6",
      "text": "Corona senum filii filiorum, et gloria filiorum patres eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 17:7",
      "text": "Non decent stultum verba composita, nec principem labium mentiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 17:8",
      "text": "Gemma gratissima exspectatio præstolantis; quocumque se vertit, prudenter intelligit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 17:9",
      "text": "Qui celat delictum quærit amicitias; qui altero sermone repetit, separat fœderatos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 17:10",
      "text": "Plus proficit correptio apud prudentem, quam centum plagæ apud stultum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 17:11",
      "text": "Semper jurgia quærit malus: angelus autem crudelis mittetur contra eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 17:12",
      "text": "Expedit magis ursæ occurrere raptis fœtibus, quam fatuo confidenti in stultitia sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 17:13",
      "text": "Qui reddit mala pro bonis, non recedet malum de domo ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 17:14",
      "text": "Qui dimittit aquam caput est jurgiorum, et antequam patiatur contumeliam judicium deserit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 17:15",
      "text": "Qui justificat impium, et qui condemnat justum, abominabilis est uterque apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 17:16",
      "text": "Quid prodest stulto habere divitias, cum sapientiam emere non possit? Qui altum facit domum suam quærit ruinam, et qui evitat discere incidet in mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 17:17",
      "text": "Omni tempore diligit qui amicus est, et frater in angustiis comprobatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 17:18",
      "text": "Stultus homo plaudet manibus, cum spoponderit pro amico suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 17:19",
      "text": "Qui meditatur discordias diligit rixas, et qui exaltat ostium quærit ruinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 17:20",
      "text": "Qui perversi cordis est non inveniet bonum, et qui vertit linguam incidet in malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 17:21",
      "text": "Natus est stultus in ignominiam suam; sed nec pater in fatuo lætabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 17:22",
      "text": "Animus gaudens ætatem floridam facit; spiritus tristis exsiccat ossa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 17:23",
      "text": "Munera de sinu impius accipit, ut pervertat semitas judicii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 17:24",
      "text": "In facie prudentis lucet sapientia; oculi stultorum in finibus terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 17:25",
      "text": "Ira patris filius stultus, et dolor matris quæ genuit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 17:26",
      "text": "Non est bonum damnum inferre justo, nec percutere principem qui recta judicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 17:27",
      "text": "Qui moderatur sermones suos doctus et prudens est, et pretiosi spiritus vir eruditus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.17.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 17:28",
      "text": "Stultus quoque, si tacuerit, sapiens reputabitur, et si compresserit labia sua, intelligens.",
      "paragraphStart": false
    }
  ]
}
