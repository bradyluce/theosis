{
  "chapter": {
    "id": "vulgate:proverbs.21",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 21,
    "referenceLabel": "Proverbs 21",
    "summary": "Source text for Proverbs 21 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.21.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 21:1",
      "text": "Sicut divisiones aquarum, ita cor regis in manu Domini: quocumque voluerit, inclinabit illud.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.21.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 21:2",
      "text": "Omnis via viri recta sibi videtur: appendit autem corda Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 21:3",
      "text": "Facere misericordiam et judicium magis placet Domino quam victimæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 21:4",
      "text": "Exaltatio oculorum est dilatatio cordis; lucerna impiorum peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 21:5",
      "text": "Cogitationes robusti semper in abundantia; omnis autem piger semper in egestate est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 21:6",
      "text": "Qui congregat thesauros lingua mendacii vanus et excors est, et impingetur ad laqueos mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 21:7",
      "text": "Rapinæ impiorum detrahent eos, quia noluerunt facere judicium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 21:8",
      "text": "Perversa via viri aliena est; qui autem mundus est, rectum opus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 21:9",
      "text": "Melius est sedere in angulo domatis, quam cum muliere litigiosa, et in domo communi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 21:10",
      "text": "Anima impii desiderat malum: non miserebitur proximo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 21:11",
      "text": "Mulctato pestilente, sapientior erit parvulus, et si sectetur sapientem, sumet scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 21:12",
      "text": "Excogitat justus de domo impii, ut detrahat impios a malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 21:13",
      "text": "Qui obturat aurem suam ad clamorem pauperis, et ipse clamabit, et non exaudietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 21:14",
      "text": "Munus absconditum extinguit iras, et donum in sinu indignationem maximam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 21:15",
      "text": "Gaudium justo est facere judicium, et pavor operantibus iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 21:16",
      "text": "Vir qui erraverit a via doctrinæ in cœtu gigantum commorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 21:17",
      "text": "Qui diligit epulas in egestate erit; qui amat vinum et pinguia non ditabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 21:18",
      "text": "Pro justo datur impius, et pro rectis iniquus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 21:19",
      "text": "Melius est habitare in terra deserta quam cum muliere rixosa et iracunda.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 21:20",
      "text": "Thesaurus desiderabilis, et oleum in habitaculo justi: et imprudens homo dissipabit illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 21:21",
      "text": "Qui sequitur justitiam et misericordiam inveniet vitam, justitiam, et gloriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 21:22",
      "text": "Civitatem fortium ascendit sapiens, et destruxit robur fiduciæ ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 21:23",
      "text": "Qui custodit os suum et linguam suam custodit ab angustiis animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 21:24",
      "text": "Superbus et arrogans vocatur indoctus, qui in ira operatur superbiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 21:25",
      "text": "Desideria occidunt pigrum: noluerunt enim quidquam manus ejus operari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 21:26",
      "text": "Tota die concupiscit et desiderat; qui autem justus est, tribuet, et non cessabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 21:27",
      "text": "Hostiæ impiorum abominabiles, quia offeruntur ex scelere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 21:28",
      "text": "Testis mendax peribit; vir obediens loquetur victoriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 21:29",
      "text": "Vir impius procaciter obfirmat vultum suum; qui autem rectus est corrigit viam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 21:30",
      "text": "Non est sapientia, non est prudentia, non est consilium contra Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.21.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 21:31",
      "text": "Equus paratur ad diem belli; Dominus autem salutem tribuit.",
      "paragraphStart": false
    }
  ]
}
