{
  "chapter": {
    "id": "vulgate:proverbs.7",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 7,
    "referenceLabel": "Proverbs 7",
    "summary": "Source text for Proverbs 7 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.7.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 7:1",
      "text": "Fili mi, custodi sermones meos, et præcepta mea reconde tibi. Fili,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.7.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 7:2",
      "text": "serva mandata mea, et vives; et legem meam quasi pupillam oculi tui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 7:3",
      "text": "liga eam in digitis tuis, scribe illam in tabulis cordis tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 7:4",
      "text": "Dic sapientiæ: Soror mea es, et prudentiam voca amicam tuam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 7:5",
      "text": "ut custodiant te a muliere extranea, et ab aliena quæ verba sua dulcia facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 7:6",
      "text": "De fenestra enim domus meæ per cancellos prospexi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 7:7",
      "text": "et video parvulos; considero vecordem juvenem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 7:8",
      "text": "qui transit per plateam juxta angulum et prope viam domus illius graditur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 7:9",
      "text": "in obscuro, advesperascente die, in noctis tenebris et caligine.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 7:10",
      "text": "Et ecce occurrit illi mulier ornatu meretricio, præparata ad capiendas animas: garrula et vaga,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 7:11",
      "text": "quietis impatiens, nec valens in domo consistere pedibus suis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 7:12",
      "text": "nunc foris, nunc in plateis, nunc juxta angulos insidians.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 7:13",
      "text": "Apprehensumque deosculatur juvenem, et procaci vultu blanditur, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 7:14",
      "text": "Victimas pro salute vovi; hodie reddidi vota mea:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 7:15",
      "text": "idcirco egressa sum in occursum tuum, desiderans te videre, et reperi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 7:16",
      "text": "Intexui funibus lectulum meum; stravi tapetibus pictis ex Ægypto:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 7:17",
      "text": "aspersi cubile meum myrrha, et aloë, et cinnamomo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 7:18",
      "text": "Veni, inebriemur uberibus, et fruamur cupitis amplexibus donec illucescat dies.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 7:19",
      "text": "Non est enim vir in domo sua: abiit via longissima:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 7:20",
      "text": "sacculum pecuniæ secum tulit; in die plenæ lunæ reversurus est in domum suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 7:21",
      "text": "Irretivit eum multis sermonibus, et blanditiis labiorum protraxit illum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 7:22",
      "text": "Statim eam sequitur quasi bos ductus ad victimam, et quasi agnus lasciviens, et ignorans quod ad vincula stultus trahatur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 7:23",
      "text": "donec transfigat sagitta jecur ejus, velut si avis festinet ad laqueum, et nescit quod de periculo animæ illius agitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 7:24",
      "text": "Nunc ergo, fili mi, audi me, et attende verbis oris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 7:25",
      "text": "Ne abstrahatur in viis illius mens tua, neque decipiaris semitis ejus;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 7:26",
      "text": "multos enim vulneratos dejecit, et fortissimi quique interfecti sunt ab ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.7.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 7:27",
      "text": "Viæ inferi domus ejus, penetrantes in interiora mortis.",
      "paragraphStart": false
    }
  ]
}
