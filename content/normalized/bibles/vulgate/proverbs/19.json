{
  "chapter": {
    "id": "vulgate:proverbs.19",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 19,
    "referenceLabel": "Proverbs 19",
    "summary": "Source text for Proverbs 19 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.19.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 19:1",
      "text": "Melior est pauper qui ambulat in simplicitate sua quam dives torquens labia sua, et insipiens.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.19.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 19:2",
      "text": "Ubi non est scientia animæ, non est bonum, et qui festinus est pedibus offendet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 19:3",
      "text": "Stultitia hominis supplantat gressus ejus, et contra Deum fervet animo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 19:4",
      "text": "Divitiæ addunt amicos plurimos; a paupere autem et hi quos habuit separantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 19:5",
      "text": "Testis falsus non erit impunitus, et qui mendacia loquitur non effugiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 19:6",
      "text": "Multi colunt personam potentis, et amici sunt dona tribuentis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 19:7",
      "text": "Fratres hominis pauperis oderunt eum; insuper et amici procul recesserunt ab eo. Qui tantum verba sectatur nihil habebit;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 19:8",
      "text": "qui autem possessor est mentis diligit animam suam, et custos prudentiæ inveniet bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 19:9",
      "text": "Falsus testis non erit impunitus, et qui loquitur mendacia peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 19:10",
      "text": "Non decent stultum deliciæ, nec servum dominari principibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 19:11",
      "text": "Doctrina viri per patientiam noscitur, et gloria ejus est iniqua prætergredi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 19:12",
      "text": "Sicut fremitus leonis, ita et regis ira, et sicut ros super herbam, ita et hilaritas ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 19:13",
      "text": "Dolor patris filius stultus, et tecta jugiter perstillantia litigiosa mulier.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 19:14",
      "text": "Domus et divitiæ dantur a parentibus; a Domino autem proprie uxor prudens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 19:15",
      "text": "Pigredo immittit soporem, et anima dissoluta esuriet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 19:16",
      "text": "Qui custodit mandatum custodit animam suam; qui autem negligit viam suam mortificabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 19:17",
      "text": "Fœneratur Domino qui miseretur pauperis, et vicissitudinem suam reddet ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 19:18",
      "text": "Erudi filium tuum; ne desperes: ad interfectionem autem ejus ne ponas animam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 19:19",
      "text": "Qui impatiens est sustinebit damnum, et cum rapuerit, aliud apponet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 19:20",
      "text": "Audi consilium, et suscipe disciplinam, ut sis sapiens in novissimis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 19:21",
      "text": "Multæ cogitationes in corde viri; voluntas autem Domini permanebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 19:22",
      "text": "Homo indigens misericors est, et melior est pauper quam vir mendax.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 19:23",
      "text": "Timor Domini ad vitam, et in plenitudine commorabitur absque visitatione pessima.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 19:24",
      "text": "Abscondit piger manum suam sub ascella, nec ad os suum applicat eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 19:25",
      "text": "Pestilente flagellato stultus sapientior erit; si autem corripueris sapientem, intelliget disciplinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 19:26",
      "text": "Qui affligit patrem, et fugat matrem, ignominiosus est et infelix.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 19:27",
      "text": "Non cesses, fili, audire doctrinam, nec ignores sermones scientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 19:28",
      "text": "Testis iniquus deridet judicium, et os impiorum devorat iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.19.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 19:29",
      "text": "Parata sunt derisoribus judicia, et mallei percutientes stultorum corporibus.",
      "paragraphStart": false
    }
  ]
}
