{
  "chapter": {
    "id": "vulgate:proverbs.29",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.29.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "Viro qui corripientem dura cervice contemnit, repentinus ei superveniet interitus, et eum sanitas non sequetur.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.29.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "In multiplicatione justorum lætabitur vulgus; cum impii sumpserint principatum, gemet populus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "Vir qui amat sapientiam lætificat patrem suum; qui autem nutrit scorta perdet substantiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "Rex justus erigit terram; vir avarus destruet eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "Homo qui blandis fictisque sermonibus loquitur amico suo rete expandit gressibus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "Peccantem virum iniquum involvet laqueus, et justus laudabit atque gaudebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "Novit justus causam pauperum; impius ignorat scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Homines pestilentes dissipant civitatem; sapientes vero avertunt furorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "Vir sapiens si cum stulto contenderit, sive irascatur, sive rideat, non inveniet requiem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "Viri sanguinum oderunt simplicem; justi autem quærunt animam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "Totum spiritum suum profert stultus; sapiens differt, et reservat in posterum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "Princeps qui libenter audit verba mendacii, omnes ministros habet impios.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "Pauper et creditor obviaverunt sibi: utriusque illuminator est Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "Rex qui judicat in veritate pauperes, thronus ejus in æternum firmabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "Virga atque correptio tribuit sapientiam; puer autem qui dimittitur voluntati suæ confundit matrem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "In multiplicatione impiorum multiplicabuntur scelera, et justi ruinas eorum videbunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Erudi filium tuum, et refrigerabit te, et dabit delicias animæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "Cum prophetia defecerit, dissipabitur populus; qui vero custodit legem beatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "Servus verbis non potest erudiri, quia quod dicis intelligit, et respondere contemnit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "Vidisti hominem velocem ad loquendum? stultitia magis speranda est quam illius correptio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "Qui delicate a pueritia nutrit servum suum postea sentiet eum contumacem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "Vir iracundus provocat rixas, et qui ad indignandum facilis est erit ad peccandum proclivior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "Superbum sequitur humilitas, et humilem spiritu suscipiet gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "Qui cum fure participat odit animam suam; adjurantem audit, et non indicat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "Qui timet hominem cito corruet; qui sperat in Domino sublevabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Multi requirunt faciem principis, et judicium a Domino egreditur singulorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.29.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "Abominantur justi virum impium, et abominantur impii eos qui in recta sunt via. Verbum custodiens filius extra perditionem erit.",
      "paragraphStart": false
    }
  ]
}
