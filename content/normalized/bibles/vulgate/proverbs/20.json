{
  "chapter": {
    "id": "vulgate:proverbs.20",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 20,
    "referenceLabel": "Proverbs 20",
    "summary": "Source text for Proverbs 20 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.20.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 20:1",
      "text": "Luxuriosa res vinum, et tumultuosa ebrietas: quicumque his delectatur non erit sapiens.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.20.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 20:2",
      "text": "Sicut rugitus leonis, ita et terror regis: qui provocat eum peccat in animam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 20:3",
      "text": "Honor est homini qui separat se a contentionibus; omnes autem stulti miscentur contumeliis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 20:4",
      "text": "Propter frigus piger arare noluit; mendicabit ergo æstate, et non dabitur illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 20:5",
      "text": "Sicut aqua profunda, sic consilium in corde viri; sed homo sapiens exhauriet illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 20:6",
      "text": "Multi homines misericordes vocantur; virum autem fidelem quis inveniet?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 20:7",
      "text": "Justus qui ambulat in simplicitate sua beatos post se filios derelinquet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 20:8",
      "text": "Rex qui sedet in solio judicii dissipat omne malum intuitu suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 20:9",
      "text": "Quis potest dicere: Mundum est cor meum; purus sum a peccato?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 20:10",
      "text": "Pondus et pondus, mensura et mensura: utrumque abominabile est apud Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 20:11",
      "text": "Ex studiis suis intelligitur puer, si munda et recta sint opera ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 20:12",
      "text": "Aurem audientem, et oculum videntem: Dominus fecit utrumque.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 20:13",
      "text": "Noli diligere somnum, ne te egestas opprimat: aperi oculos tuos, et saturare panibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 20:14",
      "text": "Malum est, malum est, dicit omnis emptor; et cum recesserit, tunc gloriabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 20:15",
      "text": "Est aurum et multitudo gemmarum, et vas pretiosum labia scientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 20:16",
      "text": "Tolle vestimentum ejus qui fidejussor extitit alieni, et pro extraneis aufer pignus ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 20:17",
      "text": "Suavis est homini panis mendacii, et postea implebitur os ejus calculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 20:18",
      "text": "Cogitationes consiliis roborantur, et gubernaculis tractanda sunt bella.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 20:19",
      "text": "Ei qui revelat mysteria, et ambulat fraudulenter, et dilatat labia sua, ne commiscearis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 20:20",
      "text": "Qui maledicit patri suo et matri, extinguetur lucerna ejus in mediis tenebris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 20:21",
      "text": "hæreditas ad quam festinatur in principio, in novissimo benedictione carebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 20:22",
      "text": "Ne dicas: Reddam malum: exspecta Dominum, et liberabit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 20:23",
      "text": "Abominatio est apud Dominum pondus et pondus; statera dolosa non est bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 20:24",
      "text": "A Domino diriguntur gressus viri: quis autem hominum intelligere potest viam suam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 20:25",
      "text": "Ruina est homini devorare sanctos, et post vota retractare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 20:26",
      "text": "Dissipat impios rex sapiens, et incurvat super eos fornicem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 20:27",
      "text": "Lucerna Domini spiraculum hominis, quæ investigat omnia secreta ventris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 20:28",
      "text": "Misericordia et veritas custodiunt regem, et roboratur clementia thronus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 20:29",
      "text": "Exsultatio juvenum fortitudo eorum, et dignitas senum canities.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.20.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 20:30",
      "text": "Livor vulneris absterget mala, et plagæ in secretioribus ventris.",
      "paragraphStart": false
    }
  ]
}
