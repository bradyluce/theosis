{
  "chapter": {
    "id": "vulgate:proverbs.11",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 11,
    "referenceLabel": "Proverbs 11",
    "summary": "Source text for Proverbs 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.11.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 11:1",
      "text": "Statera dolosa abominatio est apud Dominum, et pondus æquum voluntas ejus.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.11.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 11:2",
      "text": "Ubi fuerit superbia, ibi erit et contumelia; ubi autem est humilitas, ibi et sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 11:3",
      "text": "Simplicitas justorum diriget eos, et supplantatio perversorum vastabit illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 11:4",
      "text": "Non proderunt divitiæ in die ultionis; justitia autem liberabit a morte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 11:5",
      "text": "Justitia simplicis diriget viam ejus, et in impietate sua corruet impius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 11:6",
      "text": "Justitia rectorum liberabit eos, et in insidiis suis capientur iniqui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 11:7",
      "text": "Mortuo homine impio, nulla erit ultra spes, et exspectatio sollicitorum peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 11:8",
      "text": "Justus de angustia liberatus est, et tradetur impius pro eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 11:9",
      "text": "Simulator ore decipit amicum suum; justi autem liberabuntur scientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 11:10",
      "text": "In bonis justorum exsultabit civitas, et in perditione impiorum erit laudatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 11:11",
      "text": "Benedictione justorum exaltabitur civitas, et ore impiorum subvertetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 11:12",
      "text": "Qui despicit amicum suum indigens corde est; vir autem prudens tacebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 11:13",
      "text": "Qui ambulat fraudulenter, revelat arcana; qui autem fidelis est animi, celat amici commissum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 11:14",
      "text": "Ubi non est gubernator, populus corruet; salus autem, ubi multa consilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 11:15",
      "text": "Affligetur malo qui fidem facit pro extraneo; qui autem cavet laqueos securus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 11:16",
      "text": "Mulier gratiosa inveniet gloriam, et robusti habebunt divitias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 11:17",
      "text": "Benefacit animæ suæ vir misericors; qui autem crudelis est, etiam propinquos abjicit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 11:18",
      "text": "Impius facit opus instabile, seminanti autem justitiam merces fidelis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 11:19",
      "text": "Clementia præparat vitam, et sectatio malorum mortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 11:20",
      "text": "Abominabile Domino cor pravum, et voluntas ejus in iis qui simpliciter ambulant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 11:21",
      "text": "Manus in manu non erit innocens malus; semen autem justorum salvabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 11:22",
      "text": "Circulus aureus in naribus suis, mulier pulchra et fatua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 11:23",
      "text": "Desiderium justorum omne bonum est; præstolatio impiorum furor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 11:24",
      "text": "Alii dividunt propria, et ditiores fiunt; alii rapiunt non sua, et semper in egestate sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 11:25",
      "text": "Anima quæ benedicit impinguabitur, et qui inebriat, ipse quoque inebriabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 11:26",
      "text": "Qui abscondit frumenta maledicetur in populis; benedictio autem super caput vendentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 11:27",
      "text": "Bene consurgit diluculo qui quærit bona; qui autem investigator malorum est, opprimetur ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 11:28",
      "text": "Qui confidit in divitiis suis corruet: justi autem quasi virens folium germinabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 11:29",
      "text": "Qui conturbat domum suam possidebit ventos, et qui stultus est serviet sapienti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 11:30",
      "text": "Fructus justi lignum vitæ, et qui suscipit animas sapiens est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.11.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 11:31",
      "text": "Si justus in terra recipit, quanto magis impius et peccator!",
      "paragraphStart": false
    }
  ]
}
