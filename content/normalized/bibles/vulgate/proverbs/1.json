{
  "chapter": {
    "id": "vulgate:proverbs.1",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 1,
    "referenceLabel": "Proverbs 1",
    "summary": "Source text for Proverbs 1 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.1.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 1:1",
      "text": "Parabolæ Salomonis, filii David, regis Israël,",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.1.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 1:2",
      "text": "ad sciendam sapientiam et disciplinam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 1:3",
      "text": "ad intelligenda verba prudentiæ, et suscipiendam eruditionem doctrinæ, justitiam, et judicium, et æquitatem:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 1:4",
      "text": "ut detur parvulis astutia, adolescenti scientia et intellectus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 1:5",
      "text": "Audiens sapiens, sapientior erit, et intelligens gubernacula possidebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 1:6",
      "text": "Animadvertet parabolam et interpretationem, verba sapientum et ænigmata eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 1:7",
      "text": "Timor Domini principium sapientiæ; sapientiam atque doctrinam stulti despiciunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 1:8",
      "text": "Audi, fili mi, disciplinam patris tui, et ne dimittas legem matris tuæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 1:9",
      "text": "ut addatur gratia capiti tuo, et torques collo tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 1:10",
      "text": "Fili mi, si te lactaverint peccatores, ne acquiescas eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 1:11",
      "text": "Si dixerint: Veni nobiscum, insidiemur sanguini; abscondamus tendiculas contra insontem frustra;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 1:12",
      "text": "deglutiamus eum sicut infernus viventem, et integrum quasi descendentem in lacum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 1:13",
      "text": "omnem pretiosam substantiam reperiemus; implebimus domos nostras spoliis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 1:14",
      "text": "sortem mitte nobiscum, marsupium unum sit omnium nostrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 1:15",
      "text": "fili mi, ne ambules cum eis; prohibe pedem tuum a semitis eorum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 1:16",
      "text": "pedes enim illorum ad malum currunt, et festinant ut effundant sanguinem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 1:17",
      "text": "Frustra autem jacitur rete ante oculos pennatorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 1:18",
      "text": "Ipsi quoque contra sanguinem suum insidiantur, et moliuntur fraudes contra animas suas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 1:19",
      "text": "Sic semitæ omnis avari: animas possidentium rapiunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 1:20",
      "text": "Sapientia foris prædicat; in plateis dat vocem suam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 1:21",
      "text": "in capite turbarum clamitat; in foribus portarum urbis profert verba sua, dicens:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 1:22",
      "text": "Usquequo, parvuli, diligitis infantiam, et stulti ea quæ sibi sunt noxia cupient, et imprudentes odibunt scientiam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 1:23",
      "text": "convertimini ad correptionem meam. En proferam vobis spiritum meum, et ostendam vobis verba mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 1:24",
      "text": "Quia vocavi, et renuistis; extendi manum meam, et non fuit qui aspiceret:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 1:25",
      "text": "despexistis omne consilium meum, et increpationes meas neglexistis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 1:26",
      "text": "Ego quoque in interitu vestro ridebo, et subsannabo cum vobis id quod timebatis advenerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 1:27",
      "text": "Cum irruerit repentina calamitas, et interitus quasi tempestas ingruerit; quando venerit super vos tribulatio et angustia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 1:28",
      "text": "tunc invocabunt me, et non exaudiam; mane consurgent, et non invenient me:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 1:29",
      "text": "eo quod exosam habuerint disciplinam, et timorem Domini non susceperint,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 1:30",
      "text": "nec acquieverint consilio meo, et detraxerint universæ correptioni meæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 1:31",
      "text": "Comedent igitur fructus viæ suæ, suisque consiliis saturabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 1:32",
      "text": "Aversio parvulorum interficiet eos, et prosperitas stultorum perdet illos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.1.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 1:33",
      "text": "Qui autem me audierit, absque terrore requiescet, et abundantia perfruetur, timore malorum sublato.",
      "paragraphStart": false
    }
  ]
}
