{
  "chapter": {
    "id": "vulgate:proverbs.10",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.10.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "Filius sapiens lætificat patrem, filius vero stultus mœstitia est matris suæ.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.10.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Nil proderunt thesauri impietatis, justitia vero liberabit a morte.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "Non affliget Dominus fame animam justi, et insidias impiorum subvertet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "Egestatem operata est manus remissa; manus autem fortium divitias parat. Qui nititur mendaciis, hic pascit ventos; idem autem ipse sequitur aves volantes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "Qui congregat in messe, filius sapiens est; qui autem stertit æstate, filius confusionis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "Benedictio Domini super caput justi; os autem impiorum operit iniquitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "Memoria justi cum laudibus, et nomen impiorum putrescet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "Sapiens corde præcepta suscipit; stultus cæditur labiis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "Qui ambulat simpliciter ambulat confidenter; qui autem depravat vias suas manifestus erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "Qui annuit oculo dabit dolorem; et stultus labiis verberabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "Vena vitæ os justi, et os impiorum operit iniquitatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Odium suscitat rixas, et universa delicta operit caritas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "In labiis sapientis invenitur sapientia, et virga in dorso ejus qui indiget corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "Sapientes abscondunt scientiam; os autem stulti confusioni proximum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "Substantia divitis, urbs fortitudinis ejus; pavor pauperum egestas eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "Opus justi ad vitam, fructus autem impii ad peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "Via vitæ custodienti disciplinam; qui autem increpationes relinquit, errat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "Abscondunt odium labia mendacia; qui profert contumeliam, insipiens est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "In multiloquio non deerit peccatum, qui autem moderatur labia sua prudentissimus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "Argentum electum lingua justi; cor autem impiorum pro nihilo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "Labia justi erudiunt plurimos; qui autem indocti sunt in cordis egestate morientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "Benedictio Domini divites facit, nec sociabitur eis afflictio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "Quasi per risum stultus operatur scelus, sapientia autem est viro prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "Quod timet impius veniet super eum; desiderium suum justus dabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "Quasi tempestas transiens non erit impius; justus autem quasi fundamentum sempiternum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "Sicut acetum dentibus, et fumus oculis, sic piger his qui miserunt eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "Timor Domini apponet dies, et anni impiorum breviabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "Exspectatio justorum lætitia, spes autem impiorum peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "Fortitudo simplicis via Domini, et pavor his qui operantur malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "Justus in æternum non commovebitur, impii autem non habitabunt super terram.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "Os justi parturiet sapientiam; lingua pravorum peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.10.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "Labia justi considerant placita, et os impiorum perversa.",
      "paragraphStart": false
    }
  ]
}
