{
  "chapter": {
    "id": "vulgate:proverbs.3",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 3,
    "referenceLabel": "Proverbs 3",
    "summary": "Source text for Proverbs 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.3.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 3:1",
      "text": "Fili mi, ne obliviscaris legis meæ, et præcepta mea cor tuum custodiat:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.3.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 3:2",
      "text": "longitudinem enim dierum, et annos vitæ, et pacem, apponent tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 3:3",
      "text": "Misericordia et veritas te non deserant; circumda eas gutturi tuo, et describe in tabulis cordis tui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 3:4",
      "text": "et invenies gratiam, et disciplinam bonam, coram Deo et hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 3:5",
      "text": "Habe fiduciam in Domino ex toto corde tuo, et ne innitaris prudentiæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 3:6",
      "text": "In omnibus viis tuis cogita illum, et ipse diriget gressus tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 3:7",
      "text": "Ne sis sapiens apud temetipsum; time Deum, et recede a malo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 3:8",
      "text": "sanitas quippe erit umbilico tuo, et irrigatio ossium tuorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 3:9",
      "text": "Honora Dominum de tua substantia, et de primitiis omnium frugum tuarum da ei:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 3:10",
      "text": "et implebuntur horrea tua saturitate, et vino torcularia tua redundabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 3:11",
      "text": "Disciplinam Domini, fili mi, ne abjicias, nec deficias cum ab eo corriperis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 3:12",
      "text": "quem enim diligit Dominus, corripit, et quasi pater in filio complacet sibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 3:13",
      "text": "Beatus homo qui invenit sapientiam, et qui affluit prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 3:14",
      "text": "Melior est acquisitio ejus negotiatione argenti, et auri primi et purissimi fructus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 3:15",
      "text": "Pretiosior est cunctis opibus, et omnia quæ desiderantur huic non valent comparari.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 3:16",
      "text": "Longitudo dierum in dextera ejus, et in sinistra illius divitiæ et gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 3:17",
      "text": "Viæ ejus viæ pulchræ, et omnes semitæ illius pacificæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 3:18",
      "text": "Lignum vitæ est his qui apprehenderint eam, et qui tenuerit eam beatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 3:19",
      "text": "Dominus sapientia fundavit terram; stabilivit cælos prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 3:20",
      "text": "Sapientia illius eruperunt abyssi, et nubes rore concrescunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 3:21",
      "text": "Fili mi, ne effluant hæc ab oculis tuis. Custodi legem atque consilium,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 3:22",
      "text": "et erit vita animæ tuæ, et gratia faucibus tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 3:23",
      "text": "Tunc ambulabis fiducialiter in via tua, et pes tuus non impinget.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 3:24",
      "text": "Si dormieris, non timebis; quiesces, et suavis erit somnus tuus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 3:25",
      "text": "Ne paveas repentino terrore, et irruentes tibi potentias impiorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 3:26",
      "text": "Dominus enim erit in latere tuo, et custodiet pedem tuum, ne capiaris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 3:27",
      "text": "Noli prohibere benefacere eum qui potest: si vales, et ipse benefac.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 3:28",
      "text": "Ne dicas amico tuo: Vade, et revertere: cras dabo tibi: cum statim possis dare.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 3:29",
      "text": "Ne moliaris amico tuo malum, cum ille in te habeat fiduciam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 3:30",
      "text": "Ne contendas adversus hominem frustra, cum ipse tibi nihil mali fecerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 3:31",
      "text": "Ne æmuleris hominem injustum, nec imiteris vias ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 3:32",
      "text": "quia abominatio Domini est omnis illusor, et cum simplicibus sermocinatio ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 3:33",
      "text": "Egestas a Domino in domo impii; habitacula autem justorum benedicentur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.34",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 3:34",
      "text": "Ipse deludet illusores, et mansuetis dabit gratiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.3.35",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 3:35",
      "text": "Gloriam sapientes possidebunt; stultorum exaltatio ignominia.",
      "paragraphStart": false
    }
  ]
}
