{
  "chapter": {
    "id": "vulgate:proverbs.4",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 4,
    "referenceLabel": "Proverbs 4",
    "summary": "Source text for Proverbs 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.4.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 4:1",
      "text": "Audite, filii, disciplinam patris, et attendite ut sciatis prudentiam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.4.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 4:2",
      "text": "Donum bonum tribuam vobis: legem meam ne derelinquatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 4:3",
      "text": "Nam et ego filius fui patris mei, tenellus et unigenitus coram matre mea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 4:4",
      "text": "Et docebat me, atque dicebat: Suscipiat verba mea cor tuum; custodi præcepta mea, et vives.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 4:5",
      "text": "Posside sapientiam, posside prudentiam: ne obliviscaris, neque declines a verbis oris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 4:6",
      "text": "Ne dimittas eam, et custodiet te: dilige eam, et conservabit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 4:7",
      "text": "Principium sapientiæ: posside sapientiam, et in omni possessione tua acquire prudentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 4:8",
      "text": "Arripe illam, et exaltabit te; glorificaberis ab ea cum eam fueris amplexatus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 4:9",
      "text": "Dabit capiti tuo augmenta gratiarum, et corona inclyta proteget te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 4:10",
      "text": "Audi, fili mi, et suscipe verba mea, ut multiplicentur tibi anni vitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 4:11",
      "text": "Viam sapientiæ monstrabo tibi; ducam te per semitas æquitatis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 4:12",
      "text": "quas cum ingressus fueris, non arctabuntur gressus tui, et currens non habebis offendiculum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 4:13",
      "text": "Tene disciplinam, ne dimittas eam; custodi illam, quia ipsa est vita tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 4:14",
      "text": "Ne delecteris in semitis impiorum, nec tibi placeat malorum via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 4:15",
      "text": "Fuge ab ea, nec transeas per illam; declina, et desere eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 4:16",
      "text": "Non enim dormiunt nisi malefecerint, et rapitur somnus ab eis nisi supplantaverint.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 4:17",
      "text": "Comedunt panem impietatis, et vinum iniquitatis bibunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 4:18",
      "text": "Justorum autem semita quasi lux splendens procedit, et crescit usque ad perfectam diem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 4:19",
      "text": "Via impiorum tenebrosa; nesciunt ubi corruant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 4:20",
      "text": "Fili mi, ausculta sermones meos, et ad eloquia mea inclina aurem tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 4:21",
      "text": "Ne recedant ab oculis tuis: custodi ea in medio cordis tui:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 4:22",
      "text": "vita enim sunt invenientibus ea, et universæ carni sanitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 4:23",
      "text": "Omni custodia serva cor tuum, quia ex ipso vita procedit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 4:24",
      "text": "Remove a te os pravum, et detrahentia labia sint procul a te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 4:25",
      "text": "Oculi tui recta videant, et palpebræ tuæ præcedant gressus tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 4:26",
      "text": "Dirige semitam pedibus tuis, et omnes viæ tuæ stabilientur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.4.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 4:27",
      "text": "Ne declines ad dexteram neque ad sinistram; averte pedem tuum a malo: vias enim quæ a dextris sunt novit Dominus: perversæ vero sunt quæ a sinistris sunt. Ipse autem rectos faciet cursus tuos, itinera autem tua in pace producet.",
      "paragraphStart": false
    }
  ]
}
