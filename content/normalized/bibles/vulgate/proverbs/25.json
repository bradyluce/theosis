{
  "chapter": {
    "id": "vulgate:proverbs.25",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 25,
    "referenceLabel": "Proverbs 25",
    "summary": "Source text for Proverbs 25 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.25.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 25:1",
      "text": "Hæ quoque parabolæ Salomonis, quas transtulerunt viri Ezechiæ regis Juda.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.25.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 25:2",
      "text": "Gloria Dei est celare verbum, et gloria regum investigare sermonem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 25:3",
      "text": "Cælum sursum, et terra deorsum, et cor regum inscrutabile.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 25:4",
      "text": "Aufer rubiginem de argento, et egredietur vas purissimum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 25:5",
      "text": "Aufer impietatem de vultu regis, et firmabitur justitia thronus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 25:6",
      "text": "Ne gloriosus appareas coram rege, et in loco magnorum ne steteris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 25:7",
      "text": "Melius est enim ut dicatur tibi: Ascende huc, quam ut humilieris coram principe.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 25:8",
      "text": "Quæ viderunt oculi tui ne proferas in jurgio cito, ne postea emendare non possis, cum dehonestaveris amicum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 25:9",
      "text": "Causam tuam tracta cum amico tuo, et secretum extraneo ne reveles:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 25:10",
      "text": "ne forte insultet tibi cum audierit, et exprobrare non cesset. Gratia et amicitia liberant: quas tibi serva, ne exprobrabilis fias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 25:11",
      "text": "Mala aurea in lectis argenteis, qui loquitur verbum in tempore suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 25:12",
      "text": "Inauris aurea, et margaritum fulgens, qui arguit sapientem et aurem obedientem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 25:13",
      "text": "Sicut frigus nivis in die messis, ita legatus fidelis ei qui misit eum: animam ipsius requiescere facit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 25:14",
      "text": "Nubes, et ventus, et pluviæ non sequentes, vir gloriosus et promissa non complens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 25:15",
      "text": "Patientia lenietur princeps, et lingua mollis confringet duritiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 25:16",
      "text": "Mel invenisti: comede quod sufficit tibi, ne forte satiatus evomas illud.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 25:17",
      "text": "Subtrahe pedem tuum de domo proximi tui, nequando satiatus oderit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 25:18",
      "text": "Jaculum, et gladius, et sagitta acuta, homo qui loquitur contra proximum suum falsum testimonium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 25:19",
      "text": "Dens putridus, et pes lassus, qui sperat super infideli in die angustiæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 25:20",
      "text": "et amittit pallium in die frigoris. Acetum in nitro, qui cantat carmina cordi pessimo. Sicut tinea vestimento, et vermis ligno, ita tristitia viri nocet cordi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 25:21",
      "text": "Si esurierit inimicus tuus, ciba illum; si sitierit, da ei aquam bibere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 25:22",
      "text": "prunas enim congregabis super caput ejus, et Dominus reddet tibi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 25:23",
      "text": "Ventus aquilo dissipat pluvias, et facies tristis linguam detrahentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 25:24",
      "text": "Melius est sedere in angulo domatis quam cum muliere litigiosa et in domo communi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 25:25",
      "text": "Aqua frigida animæ sitienti, et nuntius bonus de terra longinqua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 25:26",
      "text": "Fons turbatus pede et vena corrupta, justus cadens coram impio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 25:27",
      "text": "Sicut qui mel multum comedit non est ei bonum, sic qui scrutator est majestatis opprimetur a gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.25.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 25,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 25:28",
      "text": "Sicut urbs patens et absque murorum ambitu, ita vir qui non potest in loquendo cohibere spiritum suum.",
      "paragraphStart": false
    }
  ]
}
