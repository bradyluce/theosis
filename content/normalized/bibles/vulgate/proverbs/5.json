{
  "chapter": {
    "id": "vulgate:proverbs.5",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 5,
    "referenceLabel": "Proverbs 5",
    "summary": "Source text for Proverbs 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.5.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 5:1",
      "text": "Fili mi, attende ad sapientiam meam, et prudentiæ meæ inclina aurem tuam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.5.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 5:2",
      "text": "ut custodias cogitationes, et disciplinam labia tua conservent. Ne attendas fallaciæ mulieris;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 5:3",
      "text": "favus enim distillans labia meretricis, et nitidius oleo guttur ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 5:4",
      "text": "novissima autem illius amara quasi absinthium, et acuta quasi gladius biceps.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 5:5",
      "text": "Pedes ejus descendunt in mortem, et ad inferos gressus illius penetrant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 5:6",
      "text": "Per semitam vitæ non ambulant; vagi sunt gressus ejus et investigabiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 5:7",
      "text": "Nunc ergo fili mi, audi me, et ne recedas a verbis oris mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 5:8",
      "text": "Longe fac ab ea viam tuam, et ne appropinques foribus domus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 5:9",
      "text": "Ne des alienis honorem tuum, et annos tuos crudeli:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 5:10",
      "text": "ne forte implentur extranei viribus tuis, et labores tui sint in domo aliena,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 5:11",
      "text": "et gemas in novissimis, quando consumpseris carnes tuas et corpus tuum, et dicas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 5:12",
      "text": "Cur detestatus sum disciplinam, et increpationibus non acquievit cor meum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 5:13",
      "text": "nec audivi vocem docentium me, et magistris non inclinavi aurem meam?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 5:14",
      "text": "pene fui in omni malo, in medio ecclesiæ et synagogæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 5:15",
      "text": "Bibe aquam de cisterna tua, et fluenta putei tui;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 5:16",
      "text": "deriventur fontes tui foras, et in plateis aquas tuas divide.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 5:17",
      "text": "Habeto eas solus, nec sint alieni participes tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 5:18",
      "text": "Sit vena tua benedicta, et lætare cum muliere adolescentiæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 5:19",
      "text": "Cerva carissima, et gratissimus hinnulus: ubera ejus inebrient te in omni tempore; in amore ejus delectare jugiter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 5:20",
      "text": "Quare seduceris, fili mi, ab aliena, et foveris in sinu alterius?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 5:21",
      "text": "Respicit Dominus vias hominis, et omnes gressus ejus considerat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 5:22",
      "text": "Iniquitates suas capiunt impium, et funibus peccatorum suorum constringitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.5.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 5:23",
      "text": "Ipse morietur, quia non habuit disciplinam, et in multitudine stultitiæ suæ decipietur.",
      "paragraphStart": false
    }
  ]
}
