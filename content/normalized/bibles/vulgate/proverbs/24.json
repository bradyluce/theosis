{
  "chapter": {
    "id": "vulgate:proverbs.24",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 24,
    "referenceLabel": "Proverbs 24",
    "summary": "Source text for Proverbs 24 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.24.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 24:1",
      "text": "Ne æmuleris viros malos, nec desideres esse cum eis:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.24.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 24:2",
      "text": "quia rapinas meditatur mens eorum, et fraudes labia eorum loquuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 24:3",
      "text": "Sapientia ædificabitur domus, et prudentia roborabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 24:4",
      "text": "In doctrina replebuntur cellaria, universa substantia pretiosa et pulcherrima.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 24:5",
      "text": "Vir sapiens fortis est, et vir doctus robustus et validus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 24:6",
      "text": "quia cum dispositione initur bellum, et erit salus ubi multa consilia sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 24:7",
      "text": "Excelsa stulto sapientia; in porta non aperiet os suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 24:8",
      "text": "Qui cogitat mala facere stultus vocabitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 24:9",
      "text": "cogitatio stulti peccatum est, et abominatio hominum detractor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 24:10",
      "text": "Si desperaveris lassus in die angustiæ, imminuetur fortitudo tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 24:11",
      "text": "Erue eos qui ducuntur ad mortem, et qui trahuntur ad interitum, liberare ne cesses.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 24:12",
      "text": "Si dixeris: Vires non suppetunt; qui inspector est cordis ipse intelligit: et servatorem animæ tuæ nihil fallit, reddetque homini juxta opera sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 24:13",
      "text": "Comede, fili mi, mel, quia bonum est, et favum dulcissimum gutturi tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 24:14",
      "text": "Sic et doctrina sapientiæ animæ tuæ: quam cum inveneris, habebis in novissimis spem, et spes tua non peribit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 24:15",
      "text": "Ne insidieris, et quæras impietatem in domo justi, neque vastes requiem ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 24:16",
      "text": "Septies enim cadet justus, et resurget: impii autem corruent in malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 24:17",
      "text": "Cum ceciderit inimicus tuus ne gaudeas, et in ruina ejus ne exsultet cor tuum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 24:18",
      "text": "ne forte videat Dominus, et displiceat ei, et auferat ab eo iram suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 24:19",
      "text": "Ne contendas cum pessimis, nec æmuleris impios:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 24:20",
      "text": "quoniam non habent futurorum spem mali, et lucerna impiorum extinguetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 24:21",
      "text": "Time Dominum, fili mi, et regem, et cum detractoribus non commiscearis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 24:22",
      "text": "quoniam repente consurget perditio eorum, et ruinam utriusque quis novit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 24:23",
      "text": "Hæc quoque sapientibus. Cognoscere personam in judicio non est bonum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 24:24",
      "text": "Qui dicunt impio: Justus es: maledicent eis populi, et detestabuntur eos tribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 24:25",
      "text": "Qui arguunt eum laudabuntur, et super ipsos veniet benedictio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 24:26",
      "text": "Labia deosculabitur qui recta verba respondet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 24:27",
      "text": "Præpara foris opus tuum, et diligenter exerce agrum tuum, ut postea ædifices domum tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 24:28",
      "text": "Ne sis testis frustra contra proximum tuum, nec lactes quemquam labiis tuis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 24:29",
      "text": "Ne dicas: Quomodo fecit mihi, sic faciam ei; reddam unicuique secundum opus suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 24:30",
      "text": "Per agrum hominis pigri transivi, et per vineam viri stulti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 24:31",
      "text": "et ecce totum repleverant urticæ, et operuerant superficiem ejus spinæ, et maceria lapidum destructa erat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 24:32",
      "text": "Quod cum vidissem, posui in corde meo, et exemplo didici disciplinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 24:33",
      "text": "Parum, inquam, dormies, modicum dormitabis; pauxillum manus conseres ut quiescas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.24.34",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 24:34",
      "text": "et veniet tibi quasi cursor egestas, et mendicitas quasi vir armatus.",
      "paragraphStart": false
    }
  ]
}
