{
  "chapter": {
    "id": "vulgate:proverbs.12",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.12.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "Qui diligit disciplinam diligit scientiam; qui autem odit increpationes insipiens est.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.12.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "Qui bonus est hauriet gratiam a Domino; qui autem confidit in cogitationibus suis impie agit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "Non roborabitur homo ex impietate, et radix justorum non commovebitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "Mulier diligens corona est viro suo; et putredo in ossibus ejus, quæ confusione res dignas gerit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "Cogitationes justorum judicia, et consilia impiorum fraudulenta.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "Verba impiorum insidiantur sanguini; os justorum liberabit eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "Verte impios, et non erunt; domus autem justorum permanebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "Doctrina sua noscetur vir; qui autem vanus et excors est patebit contemptui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "Melior est pauper et sufficiens sibi quam gloriosus et indigens pane.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "Novit justus jumentorum suorum animas; viscera autem impiorum crudelia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "Qui operatur terram suam satiabitur panibus; qui autem sectatur otium stultissimus est. Qui suavis est in vini demorationibus, in suis munitionibus relinquit contumeliam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "Desiderium impii munimentum est pessimorum; radix autem justorum proficiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "Propter peccata labiorum ruina proximat malo; effugiet autem justus de angustia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "De fructu oris sui unusquisque replebitur bonis, et juxta opera manuum suarum retribuetur ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "Via stulti recta in oculis ejus; qui autem sapiens est audit consilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "Fatuus statim indicat iram suam; qui autem dissimulat injuriam callidus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "Qui quod novit loquitur, index justitiæ est; qui autem mentitur, testis est fraudulentus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "Est qui promittit, et quasi gladio pungitur conscientiæ: lingua autem sapientium sanitas est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "Labium veritatis firmum erit in perpetuum; qui autem testis est repentinus, concinnat linguam mendacii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "Dolus in corde cogitantium mala; qui autem pacis ineunt consilia, sequitur eos gaudium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "Non contristabit justum quidquid ei acciderit: impii autem replebuntur malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Abominatio est Domino labia mendacia; qui autem fideliter agunt placent ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "Homo versatus celat scientiam, et cor insipientium provocat stultitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "Manus fortium dominabitur; quæ autem remissa est, tributis serviet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "Mœror in corde viri humiliabit illum, et sermone bono lætificabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "Qui negligit damnum propter amicum, justus est; iter autem impiorum decipiet eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "Non inveniet fraudulentus lucrum, et substantia hominis erit auri pretium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.12.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "In semita justitiæ vita; iter autem devium ducit ad mortem.",
      "paragraphStart": false
    }
  ]
}
