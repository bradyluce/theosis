{
  "chapter": {
    "id": "vulgate:proverbs.9",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.9.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "Sapientia ædificavit sibi domum: excidit columnas septem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.9.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "Immolavit victimas suas, miscuit vinum, et proposuit mensam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "Misit ancillas suas ut vocarent ad arcem et ad mœnia civitatis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "Si quis est parvulus, veniat ad me. Et insipientibus locuta est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "Venite, comedite panem meum, et bibite vinum quod miscui vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "Relinquite infantiam, et vivite, et ambulate per vias prudentiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "Qui erudit derisorem, ipse injuriam sibi facit, et qui arguit impium, sibi maculam generat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "Noli arguere derisorem, ne oderit te: argue sapientem, et diliget te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "Da sapienti occasionem, et addetur ei sapientia; doce justum, et festinabit accipere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "Principium sapientiæ timor Domini, et scientia sanctorum prudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "Per me enim multiplicabuntur dies tui, et addentur tibi anni vitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "Si sapiens fueris, tibimetipsi eris; si autem illusor, solus portabis malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "Mulier stulta et clamosa, plenaque illecebris, et nihil omnino sciens,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "sedit in foribus domus suæ, super sellam in excelso urbis loco,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "ut vocaret transeuntes per viam, et pergentes itinere suo:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "Qui est parvulus declinet ad me. Et vecordi locuta est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "Aquæ furtivæ dulciores sunt, et panis absconditus suavior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.9.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "Et ignoravit quod ibi sint gigantes, et in profundis inferni convivæ ejus.",
      "paragraphStart": false
    }
  ]
}
