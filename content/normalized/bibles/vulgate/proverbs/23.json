{
  "chapter": {
    "id": "vulgate:proverbs.23",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 23,
    "referenceLabel": "Proverbs 23",
    "summary": "Source text for Proverbs 23 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.23.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 23:1",
      "text": "Quando sederis ut comedas cum principe, diligenter attende quæ apposita sunt ante faciem tuam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.23.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 23:2",
      "text": "Et statue cultrum in gutture tuo: si tamen habes in potestate animam tuam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 23:3",
      "text": "Ne desideres de cibis ejus, in quo est panis mendacii.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 23:4",
      "text": "Noli laborare ut diteris, sed prudentiæ tuæ pone modum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 23:5",
      "text": "Ne erigas oculos tuos ad opes quas non potes habere, quia facient sibi pennas quasi aquilæ, et volabunt in cælum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 23:6",
      "text": "Ne comedas cum homine invido, et ne desideres cibos ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 23:7",
      "text": "quoniam in similitudinem arioli et conjectoris æstimat quod ignorat. Comede et bibe, dicet tibi; et mens ejus non est tecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 23:8",
      "text": "Cibos quos comederas evomes, et perdes pulchros sermones tuos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 23:9",
      "text": "In auribus insipientium ne loquaris, qui despicient doctrinam eloquii tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 23:10",
      "text": "Ne attingas parvulorum terminos, et agrum pupillorum ne introëas:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 23:11",
      "text": "propinquus enim illorum fortis est, et ipse judicabit contra te causam illorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 23:12",
      "text": "Ingrediatur ad doctrinam cor tuum, et aures tuæ ad verba scientiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 23:13",
      "text": "Noli subtrahere a puero disciplinam: si enim percusseris eum virga, non morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 23:14",
      "text": "Tu virga percuties eum, et animam ejus de inferno liberabis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 23:15",
      "text": "Fili mi, si sapiens fuerit animus tuus, gaudebit tecum cor meum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 23:16",
      "text": "et exsultabunt renes mei, cum locuta fuerint rectum labia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 23:17",
      "text": "Non æmuletur cor tuum peccatores, sed in timore Domini esto tota die:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 23:18",
      "text": "quia habebis spem in novissimo, et præstolatio tua non auferetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 23:19",
      "text": "Audi, fili mi, et esto sapiens, et dirige in via animum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 23:20",
      "text": "Noli esse in conviviis potatorum, nec in comessationibus eorum qui carnes ad vescendum conferunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 23:21",
      "text": "quia vacantes potibus et dantes symbola consumentur, et vestietur pannis dormitatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 23:22",
      "text": "Audi patrem tuum, qui genuit te, et ne contemnas cum senuerit mater tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 23:23",
      "text": "Veritatem eme, et noli vendere sapientiam, et doctrinam, et intelligentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 23:24",
      "text": "Exsultat gaudio pater justi; qui sapientem genuit, lætabitur in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 23:25",
      "text": "Gaudeat pater tuus et mater tua, et exsultet quæ genuit te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 23:26",
      "text": "Præbe, fili mi, cor tuum mihi, et oculi tui vias meas custodiant.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 23:27",
      "text": "Fovea enim profunda est meretrix, et puteus angustus aliena.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 23:28",
      "text": "Insidiatur in via quasi latro, et quos incautos viderit, interficiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 23:29",
      "text": "Cui væ? cujus patri væ? cui rixæ? cui foveæ? cui sine causa vulnera? cui suffusio oculorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 23:30",
      "text": "nonne his qui commorantur in vino, et student calicibus epotandis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 23:31",
      "text": "Ne intuearis vinum quando flavescit, cum splenduerit in vitro color ejus: ingreditur blande,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 23:32",
      "text": "sed in novissimo mordebit ut coluber, et sicut regulus venena diffundet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 23:33",
      "text": "Oculi tui videbunt extraneas, et cor tuum loquetur perversa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.34",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 23:34",
      "text": "Et eris sicut dormiens in medio mari, et quasi sopitus gubernator, amisso clavo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.23.35",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 23:35",
      "text": "Et dices: Verberaverunt me, sed non dolui; traxerunt me, et ego non sensi. Quando evigilabo, et rursus vina reperiam?",
      "paragraphStart": false
    }
  ]
}
