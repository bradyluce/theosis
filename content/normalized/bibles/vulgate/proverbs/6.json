{
  "chapter": {
    "id": "vulgate:proverbs.6",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 6,
    "referenceLabel": "Proverbs 6",
    "summary": "Source text for Proverbs 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.6.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 6:1",
      "text": "Fili mi, si spoponderis pro amico tuo, defixisti apud extraneum manum tuam:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.6.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 6:2",
      "text": "illaqueatus es verbis oris tui, et captus propriis sermonibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 6:3",
      "text": "Fac ergo quod dico, fili mi, et temetipsum libera, quia incidisti in manum proximi tui. Discurre, festina, suscita amicum tuum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 6:4",
      "text": "Ne dederis somnum oculis tuis, nec dormitent palpebræ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 6:5",
      "text": "Eruere quasi damula de manu, et quasi avis de manu aucupis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 6:6",
      "text": "Vade ad formicam, o piger, et considera vias ejus, et disce sapientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 6:7",
      "text": "Quæ cum non habeat ducem, nec præceptorem, nec principem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 6:8",
      "text": "parat in æstate cibum sibi, et congregat in messe quod comedat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 6:9",
      "text": "Usquequo, piger, dormies? quando consurges e somno tuo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 6:10",
      "text": "Paululum dormies, paululum dormitabis, paululum conseres manus ut dormias;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 6:11",
      "text": "et veniet tibi quasi viator egestas, et pauperies quasi vir armatus. Si vero impiger fueris, veniet ut fons messis tua, et egestas longe fugiet a te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 6:12",
      "text": "Homo apostata, vir inutilis, graditur ore perverso;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 6:13",
      "text": "annuit oculis, terit pede, digito loquitur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 6:14",
      "text": "pravo corde machinatur malum, et omni tempore jurgia seminat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 6:15",
      "text": "Huic extemplo veniet perditio sua, et subito conteretur, nec habebit ultra medicinam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 6:16",
      "text": "Sex sunt quæ odit Dominus, et septimum detestatur anima ejus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 6:17",
      "text": "oculos sublimes, linguam mendacem, manus effundentes innoxium sanguinem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 6:18",
      "text": "cor machinans cogitationes pessimas, pedes veloces ad currendum in malum,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 6:19",
      "text": "proferentem mendacia testem fallacem, et eum qui seminat inter fratres discordias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 6:20",
      "text": "Conserva, fili mi, præcepta patris tui, et ne dimittas legem matris tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 6:21",
      "text": "Liga ea in corde tuo jugiter, et circumda gutturi tuo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 6:22",
      "text": "Cum ambulaveris, gradiantur tecum; cum dormieris, custodiant te: et evigilans loquere cum eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 6:23",
      "text": "Quia mandatum lucerna est, et lex lux, et via vitæ increpatio disciplinæ:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 6:24",
      "text": "ut custodiant te a muliere mala, et a blanda lingua extraneæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 6:25",
      "text": "Non concupiscat pulchritudinem ejus cor tuum, nec capiaris nutibus illius:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 6:26",
      "text": "pretium enim scorti vix est unius panis, mulier autem viri pretiosam animam capit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 6:27",
      "text": "Numquid potest homo abscondere ignem in sinu suo, ut vestimenta illius non ardeant?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 6:28",
      "text": "aut ambulare super prunas, ut non comburantur plantæ ejus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 6:29",
      "text": "sic qui ingreditur ad mulierem proximi sui, non erit mundus cum tetigerit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 6:30",
      "text": "Non grandis est culpa cum quis furatus fuerit: furatur enim ut esurientem impleat animam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 6:31",
      "text": "deprehensus quoque reddet septuplum, et omnem substantiam domus suæ tradet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 6:32",
      "text": "Qui autem adulter est, propter cordis inopiam perdet animam suam;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 6:33",
      "text": "turpitudinem et ignominiam congregat sibi, et opprobrium illius non delebitur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.34",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 6:34",
      "text": "quia zelus et furor viri non parcet in die vindictæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.6.35",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 6:35",
      "text": "nec acquiescet cujusquam precibus, nec suscipiet pro redemptione dona plurima.",
      "paragraphStart": false
    }
  ]
}
