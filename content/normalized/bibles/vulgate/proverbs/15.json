{
  "chapter": {
    "id": "vulgate:proverbs.15",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.15.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "Responsio mollis frangit iram; sermo durus suscitat furorem.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.15.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "Lingua sapientium ornat scientiam; os fatuorum ebullit stultitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "In omni loco, oculi Domini contemplantur bonos et malos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "Lingua placabilis lignum vitæ; quæ autem immoderata est conteret spiritum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "Stultus irridet disciplinam patris sui; qui autem custodit increpationes astutior fiet. In abundanti justitia virtus maxima est: cogitationes autem impiorum eradicabuntur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "Domus justi plurima fortitudo, et in fructibus impii conturbatio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "Labia sapientium disseminabunt scientiam; cor stultorum dissimile erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "Victimæ impiorum abominabiles Domino; vota justorum placabilia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "Abominatio est Domino via impii; qui sequitur justitiam diligitur ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "Doctrina mala deserenti viam vitæ; qui increpationes odit, morietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "Infernus et perditio coram Domino; quanto magis corda filiorum hominum!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "Non amat pestilens eum qui se corripit, nec ad sapientes graditur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "Cor gaudens exhilarat faciem; in mœrore animi dejicitur spiritus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "Cor sapientis quærit doctrinam, et os stultorum pascitur imperitia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "Omnes dies pauperis, mali; secura mens quasi juge convivium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "Melius est parum cum timore Domini, quam thesauri magni et insatiabiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "Melius est vocari ad olera cum caritate, quam ad vitulum saginatum cum odio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "Vir iracundus provocat rixas; qui patiens est mitigat suscitatas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "Iter pigrorum quasi sepes spinarum; via justorum absque offendiculo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "Filius sapiens lætificat patrem, et stultus homo despicit matrem suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "Stultitia gaudium stulto, et vir prudens dirigit gressus suos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "Dissipantur cogitationes ubi non est consilium; ubi vero sunt plures consiliarii, confirmantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "Lætatur homo in sententia oris sui, et sermo opportunus est optimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "Semita vitæ super eruditum, ut declinet de inferno novissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "Domum superborum demolietur Dominus, et firmos faciet terminos viduæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "Abominatio Domini cogitationes malæ, et purus sermo pulcherrimus firmabitur ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "Conturbat domum suam qui sectatur avaritiam; qui autem odit munera, vivet. Per misericordiam et fidem purgantur peccata: per timorem autem Domini declinat omnis a malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "Mens justi meditatur obedientiam; os impiorum redundat malis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "Longe est Dominus ab impiis, et orationes justorum exaudiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "Lux oculorum lætificat animam; fama bona impinguat ossa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "Auris quæ audit increpationes vitæ in medio sapientium commorabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "Qui abjicit disciplinam despicit animam suam; qui autem acquiescit increpationibus possessor est cordis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.15.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "Timor Domini disciplina sapientiæ, et gloriam præcedit humilitas.",
      "paragraphStart": false
    }
  ]
}
