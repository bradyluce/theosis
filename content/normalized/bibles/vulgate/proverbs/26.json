{
  "chapter": {
    "id": "vulgate:proverbs.26",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 26,
    "referenceLabel": "Proverbs 26",
    "summary": "Source text for Proverbs 26 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.26.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 26:1",
      "text": "Quomodo nix in æstate, et pluviæ in messe, sic indecens est stulto gloria.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.26.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 26:2",
      "text": "Sicut avis ad alia transvolans, et passer quolibet vadens, sic maledictum frustra prolatum in quempiam superveniet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 26:3",
      "text": "Flagellum equo, et camus asino, et virga in dorso imprudentium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 26:4",
      "text": "Ne respondeas stulto juxta stultitiam suam, ne efficiaris ei similis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 26:5",
      "text": "Responde stulto juxta stultitiam suam, ne sibi sapiens esse videatur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 26:6",
      "text": "Claudus pedibus, et iniquitatem bibens, qui mittit verba per nuntium stultum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 26:7",
      "text": "Quomodo pulchras frustra habet claudus tibias, sic indecens est in ore stultorum parabola.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 26:8",
      "text": "Sicut qui mittit lapidem in acervum Mercurii, ita qui tribuit insipienti honorem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 26:9",
      "text": "Quomodo si spina nascatur in manu temulenti, sic parabola in ore stultorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 26:10",
      "text": "Judicium determinat causas, et qui imponit stulto silentium iras mitigat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 26:11",
      "text": "Sicut canis qui revertitur ad vomitum suum, sic imprudens qui iterat stultitiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 26:12",
      "text": "Vidisti hominem sapientem sibi videri? magis illo spem habebit insipiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 26:13",
      "text": "Dicit piger: Leo est in via, et leæna in itineribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 26:14",
      "text": "Sicut ostium vertitur in cardine suo, ita piger in lectulo suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 26:15",
      "text": "Abscondit piger manum sub ascella sua, et laborat si ad os suum eam converterit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 26:16",
      "text": "Sapientior sibi piger videtur septem viris loquentibus sententias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 26:17",
      "text": "Sicut qui apprehendit auribus canem, sic qui transit impatiens et commiscetur rixæ alterius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 26:18",
      "text": "Sicut noxius est qui mittit sagittas et lanceas in mortem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 26:19",
      "text": "ita vir fraudulenter nocet amico suo, et cum fuerit deprehensus dicit: Ludens feci.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 26:20",
      "text": "Cum defecerint ligna extinguetur ignis, et susurrone subtracto, jurgia conquiescent.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 26:21",
      "text": "Sicut carbones ad prunas, et ligna ad ignem, sic homo iracundus suscitat rixas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 26:22",
      "text": "Verba susurronis quasi simplicia, et ipsa perveniunt ad intima ventris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 26:23",
      "text": "Quomodo si argento sordido ornare velis vas fictile, sic labia tumentia cum pessimo corde sociata.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 26:24",
      "text": "Labiis suis intelligitur inimicus, cum in corde tractaverit dolos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 26:25",
      "text": "Quando submiserit vocem suam, ne credideris ei, quoniam septem nequitiæ sunt in corde illius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 26:26",
      "text": "Qui operit odium fraudulenter, revelabitur malitia ejus in consilio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 26:27",
      "text": "Qui fodit foveam incidet in eam, et qui volvit lapidem revertetur ad eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.26.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 26:28",
      "text": "Lingua fallax non amat veritatem, et os lubricum operatur ruinas.",
      "paragraphStart": false
    }
  ]
}
