{
  "chapter": {
    "id": "vulgate:proverbs.16",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.16.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "Hominis est animam præparare, et Domini gubernare linguam.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.16.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 16:2",
      "text": "Omnes viæ hominis patent oculis ejus; spirituum ponderator est Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "Revela Domino opera tua, et dirigentur cogitationes tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 16:4",
      "text": "Universa propter semetipsum operatus est Dominus; impium quoque ad diem malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 16:5",
      "text": "Abominatio Domini est omnis arrogans; etiamsi manus ad manum fuerit, non est innocens. Initium viæ bonæ facere justitiam; accepta est autem apud Deum magis quam immolare hostias.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "Misericordia et veritate redimitur iniquitas, et in timore Domini declinatur a malo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 16:7",
      "text": "Cum placuerint Domino viæ hominis, inimicos quoque ejus convertet ad pacem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "Melius est parum cum justitia quam multi fructus cum iniquitate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "Cor hominis disponit viam suam, sed Domini est dirigere gressus ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "Divinatio in labiis regis; in judicio non errabit os ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "Pondus et statera judicia Domini sunt, et opera ejus omnes lapides sacculi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "Abominabiles regi qui agunt impie, quoniam justitia firmatur solium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "Voluntas regum labia justa; qui recta loquitur diligetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "Indignatio regis nuntii mortis, et vir sapiens placabit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "In hilaritate vultus regis vita, et clementia ejus quasi imber serotinus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "Posside sapientiam, quia auro melior est, et acquire prudentiam, quia pretiosior est argento.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "Semita justorum declinat mala; custos animæ suæ servat viam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "Contritionem præcedit superbia, et ante ruinam exaltatur spiritus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "Melius est humiliari cum mitibus quam dividere spolia cum superbis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "Eruditus in verbo reperiet bona, et qui sperat in Domino beatus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "Qui sapiens est corde appellabitur prudens, et qui dulcis eloquio majora percipiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "Fons vitæ eruditio possidentis; doctrina stultorum fatuitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "Cor sapientis erudiet os ejus, et labiis ejus addet gratiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "Favus mellis composita verba; dulcedo animæ sanitas ossium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "Est via quæ videtur homini recta, et novissima ejus ducunt ad mortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "Anima laborantis laborat sibi, quia compulit eum os suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "Vir impius fodit malum, et in labiis ejus ignis ardescit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "Homo perversus suscitat lites, et verbosus separat principes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "Vir iniquus lactat amicum suum, et ducit eum per viam non bonam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "Qui attonitis oculis cogitat prava, mordens labia sua perficit malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "Corona dignitatis senectus, quæ in viis justitiæ reperietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "Melior est patiens viro forti, et qui dominatur animo suo expugnatore urbium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.16.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "Sortes mittuntur in sinum, sed a Domino temperantur.",
      "paragraphStart": false
    }
  ]
}
