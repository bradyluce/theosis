{
  "chapter": {
    "id": "vulgate:proverbs.31",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 31,
    "referenceLabel": "Proverbs 31",
    "summary": "Source text for Proverbs 31 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.31.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 31:1",
      "text": "Verba Lamuelis regis. Visio qua erudivit eum mater sua.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.31.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 31:2",
      "text": "Quid, dilecte mi? quid, dilecte uteri mei? quid, dilecte votorum meorum?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 31:3",
      "text": "Ne dederis mulieribus substantiam tuam, et divitias tuas ad delendos reges.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 31:4",
      "text": "Noli regibus, o Lamuel, noli regibus dare vinum, quia nullum secretum est ubi regnat ebrietas;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 31:5",
      "text": "et ne forte bibant, et obliviscantur judiciorum, et mutent causam filiorum pauperis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 31:6",
      "text": "Date siceram mœrentibus, et vinum his qui amaro sunt animo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 31:7",
      "text": "Bibant, et obliviscantur egestatis suæ, et doloris sui non recordentur amplius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 31:8",
      "text": "Aperi os tuum muto, et causis omnium filiorum qui pertranseunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 31:9",
      "text": "Aperi os tuum, decerne quod justum est, et judica inopem et pauperem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 31:10",
      "text": "Mulierem fortem quis inveniet? procul et de ultimis finibus pretium ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 31:11",
      "text": "Confidit in ea cor viri sui, et spoliis non indigebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 31:12",
      "text": "Reddet ei bonum, et non malum, omnibus diebus vitæ suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 31:13",
      "text": "Quæsivit lanam et linum, et operata est consilia manuum suarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 31:14",
      "text": "Facta est quasi navis institoris, de longe portans panem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 31:15",
      "text": "Et de nocte surrexit, deditque prædam domesticis suis, et cibaria ancillis suis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 31:16",
      "text": "Consideravit agrum, et emit eum; de fructu manuum suarum plantavit vineam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 31:17",
      "text": "Accinxit fortitudine lumbos suos, et roboravit brachium suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 31:18",
      "text": "Gustavit, et vidit quia bona est negotiatio ejus; non extinguetur in nocte lucerna ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 31:19",
      "text": "Manum suam misit ad fortia, et digiti ejus apprehenderunt fusum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 31:20",
      "text": "Manum suam aperuit inopi, et palmas suas extendit ad pauperem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 31:21",
      "text": "Non timebit domui suæ a frigoribus nivis; omnes enim domestici ejus vestiti sunt duplicibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 31:22",
      "text": "Stragulatam vestem fecit sibi; byssus et purpura indumentum ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 31:23",
      "text": "Nobilis in portis vir ejus, quando sederit cum senatoribus terræ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 31:24",
      "text": "Sindonem fecit, et vendidit, et cingulum tradidit Chananæo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 31:25",
      "text": "Fortitudo et decor indumentum ejus, et ridebit in die novissimo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 31:26",
      "text": "Os suum aperuit sapientiæ, et lex clementiæ in lingua ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 31:27",
      "text": "Consideravit semitas domus suæ, et panem otiosa non comedit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 31:28",
      "text": "Surrexerunt filii ejus, et beatissimam prædicaverunt; vir ejus, et laudavit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 31:29",
      "text": "Multæ filiæ congregaverunt divitias; tu supergressa es universas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 31:30",
      "text": "Fallax gratia, et vana est pulchritudo: mulier timens Dominum, ipsa laudabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.31.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 31,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 31:31",
      "text": "Date ei de fructu manuum suarum, et laudent eam in portis opera ejus.",
      "paragraphStart": false
    }
  ]
}
