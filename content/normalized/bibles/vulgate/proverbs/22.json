{
  "chapter": {
    "id": "vulgate:proverbs.22",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 22,
    "referenceLabel": "Proverbs 22",
    "summary": "Source text for Proverbs 22 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.22.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 22:1",
      "text": "Melius est nomen bonum quam divitiæ multæ; super argentum et aurum gratia bona.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.22.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 22:2",
      "text": "Dives et pauper obviaverunt sibi: utriusque operator est Dominus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 22:3",
      "text": "Callidus vidit malum, et abscondit se; innocens pertransiit, et afflictus est damno.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 22:4",
      "text": "Finis modestiæ timor Domini, divitiæ, et gloria, et vita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 22:5",
      "text": "Arma et gladii in via perversi; custos autem animæ suæ longe recedit ab eis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 22:6",
      "text": "Proverbium est: adolescens juxta viam suam; etiam cum senuerit, non recedet ab ea.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 22:7",
      "text": "Dives pauperibus imperat, et qui accipit mutuum servus est fœnerantis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 22:8",
      "text": "Qui seminat iniquitatem metet mala, et virga iræ suæ consummabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 22:9",
      "text": "Qui pronus est ad misericordiam benedicetur: de panibus enim suis dedit pauperi. Victoriam et honorem acquiret qui dat munera; animam autem aufert accipientium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 22:10",
      "text": "Ejice derisorem, et exibit cum eo jurgium, cessabuntque causæ et contumeliæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 22:11",
      "text": "Qui diligit cordis munditiam, propter gratiam labiorum suorum habebit amicum regem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 22:12",
      "text": "Oculi Domini custodiunt scientiam, et supplantantur verba iniqui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 22:13",
      "text": "Dicit piger: Leo est foris; in medio platearum occidendus sum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 22:14",
      "text": "Fovea profunda os alienæ: cui iratus est Dominus, incidet in eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 22:15",
      "text": "Stultitia colligata est in corde pueri, et virga disciplinæ fugabit eam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 22:16",
      "text": "Qui calumniatur pauperem ut augeat divitias suas, dabit ipse ditiori, et egebit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 22:17",
      "text": "Inclina aurem tuam, et audi verba sapientium: appone autem cor ad doctrinam meam,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 22:18",
      "text": "quæ pulchra erit tibi cum servaveris eam in ventre tuo, et redundabit in labiis tuis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 22:19",
      "text": "ut sit in Domino fiducia tua, unde et ostendi eam tibi hodie.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 22:20",
      "text": "Ecce descripsi eam tibi tripliciter, in cogitationibus et scientia:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 22:21",
      "text": "ut ostenderem tibi firmitatem et eloquia veritatis, respondere ex his illis qui miserunt te.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 22:22",
      "text": "Non facias violentiam pauperi quia pauper est, neque conteras egenum in porta:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 22:23",
      "text": "quia judicabit Dominus causam ejus, et configet eos qui confixerunt animam ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 22:24",
      "text": "Noli esse amicus homini iracundo, neque ambules cum viro furioso:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 22:25",
      "text": "ne forte discas semitas ejus, et sumas scandalum animæ tuæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 22:26",
      "text": "Noli esse cum his qui defigunt manus suas, et qui vades se offerunt pro debitis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 22:27",
      "text": "si enim non habes unde restituas, quid causæ est ut tollat operimentum de cubili tuo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 22:28",
      "text": "Ne transgrediaris terminos antiquos, quos posuerunt patres tui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.22.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 22:29",
      "text": "Vidisti virum velocem in opere suo? coram regibus stabit, nec erit ante ignobiles.",
      "paragraphStart": false
    }
  ]
}
