{
  "chapter": {
    "id": "vulgate:proverbs.2",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 2,
    "referenceLabel": "Proverbs 2",
    "summary": "Source text for Proverbs 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.2.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 2:1",
      "text": "Fili mi, si susceperis sermones meos, et mandata mea absconderis penes te:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.2.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 2:2",
      "text": "ut audiat sapientiam auris tua, inclina cor tuum ad cognoscendam prudentiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 2:3",
      "text": "Si enim sapientiam invocaveris, et inclinaveris cor tuum prudentiæ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 2:4",
      "text": "si quæsieris eam quasi pecuniam, et sicut thesauros effoderis illam:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 2:5",
      "text": "tunc intelliges timorem Domini, et scientiam Dei invenies,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 2:6",
      "text": "quia Dominus dat sapientiam, et ex ore ejus prudentia et scientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 2:7",
      "text": "Custodiet rectorum salutem, et proteget gradientes simpliciter,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 2:8",
      "text": "servans semitas justitiæ, et vias sanctorum custodiens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 2:9",
      "text": "Tunc intelliges justitiam, et judicium, et æquitatem, et omnem semitam bonam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 2:10",
      "text": "Si intraverit sapientia cor tuum, et scientia animæ tuæ placuerit,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 2:11",
      "text": "consilium custodiet te, et prudentia servabit te:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 2:12",
      "text": "ut eruaris a via mala, et ab homine qui perversa loquitur;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 2:13",
      "text": "qui relinquunt iter rectum, et ambulant per vias tenebrosas;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 2:14",
      "text": "qui lætantur cum malefecerint, et exsultant in rebus pessimis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 2:15",
      "text": "quorum viæ perversæ sunt, et infames gressus eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 2:16",
      "text": "Ut eruaris a muliere aliena, et ab extranea quæ mollit sermones suos,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 2:17",
      "text": "et relinquit ducem pubertatis suæ,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 2:18",
      "text": "et pacti Dei sui oblita est. Inclinata est enim ad mortem domus ejus, et ad inferos semitæ ipsius.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 2:19",
      "text": "Omnes qui ingrediuntur ad eam non revertentur, nec apprehendent semitas vitæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 2:20",
      "text": "Ut ambules in via bona, et calles justorum custodias:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 2:21",
      "text": "qui enim recti sunt habitabunt in terra, et simplices permanebunt in ea;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.2.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 2:22",
      "text": "impii vero de terra perdentur, et qui inique agunt auferentur ex ea.",
      "paragraphStart": false
    }
  ]
}
