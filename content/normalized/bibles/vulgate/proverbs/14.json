{
  "chapter": {
    "id": "vulgate:proverbs.14",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.14.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Sapiens mulier ædificat domum suam; insipiens exstructam quoque manibus destruet.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.14.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "Ambulans recto itinere, et timens Deum, despicitur ab eo qui infami graditur via.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "In ore stulti virga superbiæ; labia autem sapientium custodiunt eos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Ubi non sunt boves, præsepe vacuum est; ubi autem plurimæ segetes, ibi manifesta est fortitudo bovis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "Testis fidelis non mentitur; profert autem mendacium dolosus testis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "Quærit derisor sapientiam, et non invenit; doctrina prudentium facilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Vade contra virum stultum, et nescit labia prudentiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "Sapientia callidi est intelligere viam suam, et imprudentia stultorum errans.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "Stultus illudet peccatum, et inter justos morabitur gratia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "Cor quod novit amaritudinem animæ suæ, in gaudio ejus non miscebitur extraneus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "Domus impiorum delebitur: tabernacula vero justorum germinabunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "Est via quæ videtur homini justa, novissima autem ejus deducunt ad mortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Risus dolore miscebitur, et extrema gaudii luctus occupat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "Viis suis replebitur stultus, et super eum erit vir bonus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "Innocens credit omni verbo; astutus considerat gressus suos. Filio doloso nihil erit boni; servo autem sapienti prosperi erunt actus, et dirigetur via ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "Sapiens timet, et declinat a malo; stultus transilit, et confidit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "Impatiens operabitur stultitiam, et vir versutus odiosus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "Possidebunt parvuli stultitiam, et exspectabunt astuti scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "Jacebunt mali ante bonos, et impii ante portas justorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "Etiam proximo suo pauper odiosus erit: amici vero divitum multi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "Qui despicit proximum suum peccat; qui autem miseretur pauperis beatus erit. Qui credit in Domino misericordiam diligit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "Errant qui operantur malum; misericordia et veritas præparant bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "In omni opere erit abundantia; ubi autem verba sunt plurima, ibi frequenter egestas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "Corona sapientium divitiæ eorum; fatuitas stultorum imprudentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "Liberat animas testis fidelis, et profert mendacia versipellis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "In timore Domini fiducia fortitudinis, et filiis ejus erit spes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "Timor Domini fons vitæ, ut declinent a ruina mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "In multitudine populi dignitas regis, et in paucitate plebis ignominia principis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "Qui patiens est multa gubernatur prudentia; qui autem impatiens est exaltat stultitiam suam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "Vita carnium sanitas cordis; putredo ossium invidia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "Qui calumniatur egentem exprobrat factori ejus; honorat autem eum qui miseretur pauperis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "In malitia sua expelletur impius: sperat autem justus in morte sua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "In corde prudentis requiescit sapientia, et indoctos quosque erudiet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.34",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Justitia elevat gentem; miseros autem facit populos peccatum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.14.35",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "Acceptus est regi minister intelligens; iracundiam ejus inutilis sustinebit.",
      "paragraphStart": false
    }
  ]
}
