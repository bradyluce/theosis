{
  "chapter": {
    "id": "vulgate:proverbs.28",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 28,
    "referenceLabel": "Proverbs 28",
    "summary": "Source text for Proverbs 28 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.28.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 28:1",
      "text": "Fugit impius nemine persequente; justus autem, quasi leo confidens, absque terrore erit.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.28.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 28:2",
      "text": "Propter peccata terræ multi principes ejus; et propter hominis sapientiam, et horum scientiam quæ dicuntur, vita ducis longior erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 28:3",
      "text": "Vir pauper calumnians pauperes similis est imbri vehementi in quo paratur fames.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 28:4",
      "text": "Qui derelinquunt legem laudant impium; qui custodiunt, succenduntur contra eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 28:5",
      "text": "Viri mali non cogitant judicium; qui autem inquirunt Dominum animadvertunt omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 28:6",
      "text": "Melior est pauper ambulans in simplicitate sua quam dives in pravis itineribus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 28:7",
      "text": "Qui custodit legem filius sapiens est; qui autem comessatores pascit confundit patrem suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 28:8",
      "text": "Qui coacervat divitias usuris et fœnore, liberali in pauperes congregat eas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 28:9",
      "text": "Qui declinat aures suas ne audiat legem, oratio ejus erit execrabilis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 28:10",
      "text": "Qui decipit justos in via mala, in interitu suo corruet, et simplices possidebunt bona ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 28:11",
      "text": "Sapiens sibi videtur vir dives; pauper autem prudens scrutabitur eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 28:12",
      "text": "In exsultatione justorum multa gloria est; regnantibus impiis, ruinæ hominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 28:13",
      "text": "Qui abscondit scelera sua non dirigetur; qui autem confessus fuerit et reliquerit ea, misericordiam consequetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 28:14",
      "text": "Beatus homo qui semper est pavidus; qui vero mentis est duræ corruet in malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 28:15",
      "text": "Leo rugiens et ursus esuriens, princeps impius super populum pauperem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 28:16",
      "text": "Dux indigens prudentia multos opprimet per calumniam; qui autem odit avaritiam, longi fient dies ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 28:17",
      "text": "Hominem qui calumniatur animæ sanguinem, si usque ad lacum fugerit, nemo sustinet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 28:18",
      "text": "Qui ambulat simpliciter salvus erit; qui perversis graditur viis concidet semel.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 28:19",
      "text": "Qui operatur terram suam satiabitur panibus; qui autem sectatur otium replebitur egestate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 28:20",
      "text": "Vir fidelis multum laudabitur; qui autem festinat ditari non erit innocens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 28:21",
      "text": "Qui cognoscit in judicio faciem non bene facit; iste et pro buccella panis deserit veritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 28:22",
      "text": "Vir qui festinat ditari, et aliis invidet, ignorat quod egestas superveniet ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 28:23",
      "text": "Qui corripit hominem gratiam postea inveniet apud eum, magis quam ille qui per linguæ blandimenta decipit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 28:24",
      "text": "Qui subtrahit aliquid a patre suo et a matre, et dicit hoc non esse peccatum, particeps homicidæ est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 28:25",
      "text": "Qui se jactat et dilatat, jurgia concitat; qui vero sperat in Domino sanabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 28:26",
      "text": "Qui confidit in corde suo stultus est; qui autem graditur sapienter, ipse salvabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 28:27",
      "text": "Qui dat pauperi non indigebit; qui despicit deprecantem sustinebit penuriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.28.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 28:28",
      "text": "Cum surrexerint impii, abscondentur homines; cum illi perierint, multiplicabuntur justi.",
      "paragraphStart": false
    }
  ]
}
