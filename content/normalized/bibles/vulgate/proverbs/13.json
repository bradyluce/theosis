{
  "chapter": {
    "id": "vulgate:proverbs.13",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.13.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "Filius sapiens doctrina patris; qui autem illusor est non audit cum arguitur.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.13.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "De fructu oris sui homo satiabitur bonis: anima autem prævaricatorum iniqua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "Qui custodit os suum custodit animam suam; qui autem inconsideratus est ad loquendum, sentiet mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "Vult et non vult piger; anima autem operantium impinguabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "Verbum mendax justus detestabitur; impius autem confundit, et confundetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "Justitia custodit innocentis viam, impietas autem peccatorem supplantat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "Est quasi dives, cum nihil habeat, et est quasi pauper, cum in multis divitiis sit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "Redemptio animæ viri divitiæ suæ; qui autem pauper est, increpationem non sustinet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "Lux justorum lætificat: lucerna autem impiorum extinguetur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "Inter superbos semper jurgia sunt; qui autem agunt omnia cum consilio, reguntur sapientia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "Substantia festinata minuetur; quæ autem paulatim colligitur manu, multiplicabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "Spes quæ differtur affligit animam; lignum vitæ desiderium veniens.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "Qui detrahit alicui rei, ipse se in futurum obligat; qui autem timet præceptum, in pace versabitur. Animæ dolosæ errant in peccatis: justi autem misericordes sunt, et miserantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "Lex sapientis fons vitæ, ut declinet a ruina mortis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "Doctrina bona dabit gratiam; in itinere contemptorum vorago.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "Astutus omnia agit cum consilio; qui autem fatuus est aperit stultitiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "Nuntius impii cadet in malum; legatus autem fidelis, sanitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "Egestas et ignominia ei qui deserit disciplinam; qui autem acquiescit arguenti glorificabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "Desiderium si compleatur delectat animam; detestantur stulti eos qui fugiunt mala.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "Qui cum sapientibus graditur sapiens erit; amicus stultorum similis efficietur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "Peccatores persequitur malum, et justis retribuentur bona.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "Bonus reliquit hæredes filios et nepotes, et custoditur justo substantia peccatoris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "Multi cibi in novalibus patrum, et aliis congregantur absque judicio.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "Qui parcit virgæ odit filium suum; qui autem diligit illum instanter erudit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.13.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "Justus comedit et replet animam suam; venter autem impiorum insaturabilis.",
      "paragraphStart": false
    }
  ]
}
