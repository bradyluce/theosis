{
  "chapter": {
    "id": "vulgate:proverbs.30",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 30,
    "referenceLabel": "Proverbs 30",
    "summary": "Source text for Proverbs 30 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.30.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 30:1",
      "text": "Verba Congregantis, filii Vomentis. Visio quam locutus est vir cum quo est Deus, et qui Deo secum morante confortatus, ait:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.30.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 30:2",
      "text": "Stultissimus sum virorum, et sapientia hominum non est mecum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 30:3",
      "text": "Non didici sapientiam, et non novi scientiam sanctorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 30:4",
      "text": "Quis ascendit in cælum, atque descendit? quis continuit spiritum in manibus suis? quis colligavit aquas quasi in vestimento? quis suscitavit omnes terminos terræ? quod nomen est ejus, et quod nomen filii ejus, si nosti?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 30:5",
      "text": "Omnis sermo Dei ignitus: clypeus est sperantibus in se.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 30:6",
      "text": "Ne addas quidquam verbis illius, et arguaris, inveniarisque mendax.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 30:7",
      "text": "Duo rogavi te: ne deneges mihi antequam moriar:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 30:8",
      "text": "vanitatem et verba mendacia longe fac a me; mendicitatem et divitias ne dederis mihi: tribue tantum victui meo necessaria,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 30:9",
      "text": "ne forte satiatus illiciar ad negandum, et dicam: Quis est Dominus? aut egestate compulsus, furer, et perjurem nomen Dei mei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 30:10",
      "text": "Ne accuses servum ad dominum suum, ne forte maledicat tibi, et corruas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 30:11",
      "text": "Generatio quæ patri suo maledicit, et quæ matri suæ non benedicit;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 30:12",
      "text": "generatio quæ sibi munda videtur, et tamen non est lota a sordibus suis;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 30:13",
      "text": "generatio cujus excelsi sunt oculi, et palpebræ ejus in alta surrectæ;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 30:14",
      "text": "generatio quæ pro dentibus gladios habet, et commandit molaribus suis, ut comedat inopes de terra, et pauperes ex hominibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 30:15",
      "text": "Sanguisugæ duæ sunt filiæ, dicentes: Affer, affer. Tria sunt insaturabilia, et quartum quod numquam dicit: Sufficit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 30:16",
      "text": "Infernus, et os vulvæ, et terra quæ non satiatur aqua: ignis vero numquam dicit: Sufficit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 30:17",
      "text": "Oculum qui subsannat patrem, et qui despicit partum matris suæ, effodiant eum corvi de torrentibus, et comedant eum filii aquilæ!",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 30:18",
      "text": "Tria sunt difficilia mihi, et quartum penitus ignoro:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 30:19",
      "text": "viam aquilæ in cælo, viam colubri super petram, viam navis in medio mari, et viam viri in adolescentia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 30:20",
      "text": "Talis est et via mulieris adulteræ, quæ comedit, et tergens os suum dicit: Non sum operata malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 30:21",
      "text": "Per tria movetur terra, et quartum non potest sustinere:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 30:22",
      "text": "per servum, cum regnaverit; per stultum, cum saturatus fuerit cibo;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 30:23",
      "text": "per odiosam mulierem, cum in matrimonio fuerit assumpta; et per ancillam, cum fuerit hæres dominæ suæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 30:24",
      "text": "Quatuor sunt minima terræ, et ipsa sunt sapientiora sapientibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 30:25",
      "text": "formicæ, populus infirmus, qui præparat in messe cibum sibi;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 30:26",
      "text": "lepusculus, plebs invalida, qui collocat in petra cubile suum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 30:27",
      "text": "regem locusta non habet, et egreditur universa per turmas suas;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.28",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 30:28",
      "text": "stellio manibus nititur, et moratur in ædibus regis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.29",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 30:29",
      "text": "Tria sunt quæ bene gradiuntur, et quartum quod incedit feliciter:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.30",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 30:30",
      "text": "leo, fortissimus bestiarum, ad nullius pavebit occursum;",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.31",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 30:31",
      "text": "gallus succinctus lumbos; et aries; nec est rex, qui resistat ei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.32",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 30:32",
      "text": "Est qui stultus apparuit postquam elevatus est in sublime; si enim intellexisset, ori suo imposuisset manum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.30.33",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 30,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 30:33",
      "text": "Qui autem fortiter premit ubera ad eliciendum lac exprimit butyrum; et qui vehementer emungit elicit sanguinem; et qui provocat iras producit discordias.",
      "paragraphStart": false
    }
  ]
}
