{
  "chapter": {
    "id": "vulgate:proverbs.27",
    "translationId": "vulgate",
    "bookSlug": "proverbs",
    "chapterNumber": 27,
    "referenceLabel": "Proverbs 27",
    "summary": "Source text for Proverbs 27 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:proverbs.27.1",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 27:1",
      "text": "Ne glorieris in crastinum, ignorans quid superventura pariat dies.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:proverbs.27.2",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 27:2",
      "text": "Laudet te alienus, et non os tuum; extraneus, et non labia tua.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.3",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 27:3",
      "text": "Grave est saxum, et onerosa arena, sed ira stulti utroque gravior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.4",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 27:4",
      "text": "Ira non habet misericordiam nec erumpens furor, et impetum concitati ferre quis poterit?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.5",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 27:5",
      "text": "Melior est manifesta correptio quam amor absconditus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.6",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 27:6",
      "text": "Meliora sunt vulnera diligentis quam fraudulenta oscula odientis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.7",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 27:7",
      "text": "Anima saturata calcabit favum, et anima esuriens etiam amarum pro dulci sumet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.8",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 27:8",
      "text": "Sicut avis transmigrans de nido suo, sic vir qui derelinquit locum suum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.9",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 27:9",
      "text": "Unguento et variis odoribus delectatur cor, et bonis amici consiliis anima dulcoratur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.10",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 27:10",
      "text": "Amicum tuum et amicum patris tui ne dimiseris, et domum fratris tui ne ingrediaris in die afflictionis tuæ. Melior est vicinus juxta quam frater procul.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.11",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 27:11",
      "text": "Stude sapientiæ, fili mi, et lætifica cor meum, ut possis exprobranti respondere sermonem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.12",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 27:12",
      "text": "Astutus videns malum, absconditus est: parvuli transeuntes sustinuerunt dispendia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.13",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 27:13",
      "text": "Tolle vestimentum ejus qui spopondit pro extraneo, et pro alienis aufer ei pignus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.14",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 27:14",
      "text": "Qui benedicit proximo suo voce grandi, de nocte consurgens maledicenti similis erit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.15",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 27:15",
      "text": "Tecta perstillantia in die frigoris et litigiosa mulier comparantur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.16",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 27:16",
      "text": "Qui retinet eam quasi qui ventum teneat, et oleum dexteræ suæ vocabit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.17",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 27:17",
      "text": "Ferrum ferro exacuitur, et homo exacuit faciem amici sui.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.18",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 27:18",
      "text": "Qui servat ficum comedet fructus ejus, et qui custos est domini sui glorificabitur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.19",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 27:19",
      "text": "Quomodo in aquis resplendent vultus prospicientium, sic corda hominum manifesta sunt prudentibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.20",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 27:20",
      "text": "Infernus et perditio numquam implentur: similiter et oculi hominum insatiabiles.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.21",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 27:21",
      "text": "Quomodo probatur in conflatorio argentum et in fornace aurum, sic probatur homo ore laudantis. Cor iniqui inquirit mala, cor autem rectum inquirit scientiam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.22",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 27:22",
      "text": "Si contuderis stultum in pila quasi ptisanas feriente desuper pilo, non auferetur ab eo stultitia ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.23",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 27:23",
      "text": "Diligenter agnosce vultum pecoris tui, tuosque greges considera:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.24",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 27:24",
      "text": "non enim habebis jugiter potestatem, sed corona tribuetur in generationem et generationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.25",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 27:25",
      "text": "Aperta sunt prata, et apparuerunt herbæ virentes, et collecta sunt fœna de montibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.26",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 27:26",
      "text": "Agni ad vestimentum tuum, et hædi ad agri pretium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:proverbs.27.27",
      "translationId": "vulgate",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 27:27",
      "text": "Sufficiat tibi lac caprarum in cibos tuos, et in necessaria domus tuæ, et ad victum ancillis tuis.",
      "paragraphStart": false
    }
  ]
}
