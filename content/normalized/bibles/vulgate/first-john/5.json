{
  "chapter": {
    "id": "vulgate:first-john.5",
    "translationId": "vulgate",
    "bookSlug": "first-john",
    "chapterNumber": 5,
    "referenceLabel": "1 John 5",
    "summary": "Source text for 1 John 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-john.5.1",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 John 5:1",
      "text": "Omnis qui credit quoniam Jesus est Christus, ex Deo natus est. Et omnis qui diligit eum qui genuit, diligit et eum qui natus est ex eo.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-john.5.2",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 John 5:2",
      "text": "In hoc cognoscimus quoniam diligamus natos Dei, cum Deum diligamus, et mandata ejus faciamus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.3",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 John 5:3",
      "text": "Hæc est enim caritas Dei, ut mandata ejus custodiamus: et mandata ejus gravia non sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.4",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 John 5:4",
      "text": "Quoniam omne quod natum est ex Deo, vincit mundum: et hæc est victoria, quæ vincit mundum, fides nostra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.5",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 John 5:5",
      "text": "Quis est, qui vincit mundum, nisi qui credit quoniam Jesus est Filius Dei?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.6",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 John 5:6",
      "text": "Hic est, qui venit per aquam et sanguinem, Jesus Christus: non in aqua solum, sed in aqua et sanguine. Et Spiritus est, qui testificatur quoniam Christus est veritas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.7",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 John 5:7",
      "text": "Quoniam tres sunt, qui testimonium dant in cælo: Pater, Verbum, et Spiritus Sanctus: et hi tres unum sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.8",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 John 5:8",
      "text": "Et tres sunt, qui testimonium dant in terra: spiritus, et aqua, et sanguis: et hi tres unum sunt.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.9",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 John 5:9",
      "text": "Si testimonium hominum accipimus, testimonium Dei majus est: quoniam hoc est testimonium Dei, quod majus est, quoniam testificatus est de Filio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.10",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 John 5:10",
      "text": "Qui credit in Filium Dei, habet testimonium Dei in se. Qui non credit Filio, mendacem facit eum: quia non credit in testimonium quod testificatus est Deus de Filio suo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.11",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 John 5:11",
      "text": "Et hoc est testimonium, quoniam vitam æternam dedit nobis Deus: et hæc vita in Filio ejus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.12",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 John 5:12",
      "text": "Qui habet Filium, habet vitam: qui non habet Filium, vitam non habet.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.13",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 John 5:13",
      "text": "Hæc scribo vobis ut sciatis quoniam vitam habetis æternam, qui creditis in nomine Filii Dei.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.14",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 John 5:14",
      "text": "Et hæc est fiducia, quam habemus ad eum: quia quodcumque petierimus, secundum voluntatem ejus, audit nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.15",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 John 5:15",
      "text": "Et scimus quia audit nos quidquid petierimus: scimus quoniam habemus petitiones quas postulamus ab eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.16",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 John 5:16",
      "text": "Qui scit fratrem suum peccare peccatum non ad mortem, petat, et dabitur ei vita peccanti non ad mortem. Est peccatum ad mortem: non pro illo dico ut roget quis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.17",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 John 5:17",
      "text": "Omnis iniquitas, peccatum est: et est peccatum ad mortem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.18",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 John 5:18",
      "text": "Scimus quia omnis qui natus est ex Deo, non peccat: sed generatio Dei conservat eum, et malignus non tangit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.19",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 John 5:19",
      "text": "Scimus quoniam ex Deo sumus: et mundus totus in maligno positus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.20",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 John 5:20",
      "text": "Et scimus quoniam Filius Dei venit, et dedit nobis sensum ut cognoscamus verum Deum, et simus in vero Filio ejus. Hic est verus Deus, et vita æterna.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.5.21",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 John 5:21",
      "text": "Filioli, custodite vos a simulacris. Amen.",
      "paragraphStart": false
    }
  ]
}
