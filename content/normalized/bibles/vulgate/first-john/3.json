{
  "chapter": {
    "id": "vulgate:first-john.3",
    "translationId": "vulgate",
    "bookSlug": "first-john",
    "chapterNumber": 3,
    "referenceLabel": "1 John 3",
    "summary": "Source text for 1 John 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-john.3.1",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 John 3:1",
      "text": "Videte qualem caritatem dedit nobis Pater, ut filii Dei nominemur et simus. Propter hoc mundus non novit nos: quia non novit eum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-john.3.2",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 John 3:2",
      "text": "Carissimi, nunc filii Dei sumus: et nondum apparuit quid erimus. Scimus quoniam cum apparuerit, similes ei erimus: quoniam videbimus eum sicuti est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.3",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 John 3:3",
      "text": "Et omnis qui habet hanc spem in eo, sanctificat se, sicut et ille sanctus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.4",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 John 3:4",
      "text": "Omnis qui facit peccatum, et iniquitatem facit: et peccatum est iniquitas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.5",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 John 3:5",
      "text": "Et scitis quia ille apparuit ut peccata nostra tolleret: et peccatum in eo non est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.6",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 John 3:6",
      "text": "Omnis qui in eo manet, non peccat: et omnis qui peccat, non vidit eum, nec cognovit eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.7",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 John 3:7",
      "text": "Filioli, nemo vos seducat. Qui facit justitiam, justus est, sicut et ille justus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.8",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 John 3:8",
      "text": "Qui facit peccatum, ex diabolo est: quoniam ab initio diabolus peccat. In hoc apparuit Filius Dei, ut dissolvat opera diaboli.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.9",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 John 3:9",
      "text": "Omnis qui natus est ex Deo, peccatum non facit: quoniam semen ipsius in eo manet, et non potest peccare, quoniam ex Deo natus est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.10",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 John 3:10",
      "text": "In hoc manifesti sunt filii Dei, et filii diaboli. Omnis qui non est justus, non est ex Deo, et qui non diligit fratrem suum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.11",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 John 3:11",
      "text": "quoniam hæc est annuntiatio, quam audistis ab initio, ut diligatis alterutrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.12",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 John 3:12",
      "text": "Non sicut Cain, qui ex maligno erat, et occidit fratrem suum. Et propter quid occidit eum? Quoniam opera ejus maligna erant: fratris autem ejus, justa.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.13",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 John 3:13",
      "text": "Nolite mirari, fratres, si odit vos mundus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.14",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 John 3:14",
      "text": "Nos scimus quoniam translati sumus de morte ad vitam, quoniam diligimus fratres. Qui non diligit, manet in morte:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.15",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 John 3:15",
      "text": "omnis qui odit fratrem suum, homicida est. Et scitis quoniam omnis homicida non habet vitam æternam in semetipso manentem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.16",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 John 3:16",
      "text": "In hoc cognovimus caritatem Dei, quoniam ille animam suam pro nobis posuit: et nos debemus pro fratribus animas ponere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.17",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 John 3:17",
      "text": "Qui habuerit substantiam hujus mundi, et viderit fratrem suum necessitatem habere, et clauserit viscera sua ab eo: quomodo caritas Dei manet in eo?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.18",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 John 3:18",
      "text": "Filioli mei, non diligamus verbo neque lingua, sed opere et veritate:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.19",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 John 3:19",
      "text": "in hoc cognoscimus quoniam ex veritate sumus: et in conspectu ejus suadebimus corda nostra.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.20",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 John 3:20",
      "text": "Quoniam si reprehenderit nos cor nostrum: major est Deus corde nostro, et novit omnia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.21",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 John 3:21",
      "text": "Carissimi, si cor nostrum non reprehenderit nos, fiduciam habemus ad Deum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.22",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 John 3:22",
      "text": "et quidquid petierimus, accipiemus ab eo: quoniam mandata ejus custodimus, et ea, quæ sunt placita coram eo, facimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.23",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "1 John 3:23",
      "text": "Et hoc est mandatum ejus: ut credamus in nomine Filii ejus Jesu Christi: et diligamus alterutrum, sicut dedit mandatum nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.3.24",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "1 John 3:24",
      "text": "Et qui servat mandata ejus, in illo manet, et ipse in eo: et in hoc scimus quoniam manet in nobis, de Spiritu quem dedit nobis.",
      "paragraphStart": false
    }
  ]
}
