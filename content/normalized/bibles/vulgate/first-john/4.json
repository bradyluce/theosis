{
  "chapter": {
    "id": "vulgate:first-john.4",
    "translationId": "vulgate",
    "bookSlug": "first-john",
    "chapterNumber": 4,
    "referenceLabel": "1 John 4",
    "summary": "Source text for 1 John 4 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:first-john.4.1",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 John 4:1",
      "text": "Carissimi, nolite omni spiritui credere, sed probate spiritus si ex Deo sint: quoniam multi pseudoprophetæ exierunt in mundum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:first-john.4.2",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 John 4:2",
      "text": "In hoc cognoscitur Spiritus Dei: omnis spiritus qui confitetur Jesum Christum in carne venisse, ex Deo est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.3",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 John 4:3",
      "text": "et omnis spiritus qui solvit Jesum, ex Deo non est, et hic est antichristus, de quo audistis quoniam venit, et nunc jam in mundo est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.4",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 John 4:4",
      "text": "Vos ex Deo estis filioli, et vicistis eum, quoniam major est qui in vobis est, quam qui in mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.5",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 John 4:5",
      "text": "Ipsi de mundo sunt: ideo de mundo loquuntur, et mundus eos audit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.6",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 John 4:6",
      "text": "Nos ex Deo sumus. Qui novit Deum, audit nos; qui non est ex Deo, non audit nos: in hoc cognoscimus Spiritum veritatis, et spiritum erroris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.7",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 John 4:7",
      "text": "Carissimi, diligamus nos invicem: quia caritas ex Deo est. Et omnis qui diligit, ex Deo natus est, et cognoscit Deum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.8",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 John 4:8",
      "text": "Qui non diligit, non novit Deum: quoniam Deus caritas est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.9",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 John 4:9",
      "text": "In hoc apparuit caritas Dei in nobis, quoniam Filium suum unigenitum misit Deus in mundum, ut vivamus per eum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.10",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 John 4:10",
      "text": "In hoc est caritas: non quasi nos dilexerimus Deum, sed quoniam ipse prior dilexit nos, et misit Filium suum propitiationem pro peccatis nostris.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.11",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 John 4:11",
      "text": "Carissimi, si sic Deus dilexit nos: et nos debemus alterutrum diligere.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.12",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 John 4:12",
      "text": "Deum nemo vidit umquam. Si diligamus invicem, Deus in nobis manet, et caritas ejus in nobis perfecta est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.13",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 John 4:13",
      "text": "In hoc cognoscimus quoniam in eo manemus, et ipse in nobis: quoniam de Spiritu suo dedit nobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.14",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 John 4:14",
      "text": "Et nos vidimus, et testificamur quoniam Pater misit Filium suum Salvatorem mundi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.15",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 John 4:15",
      "text": "Quisquis confessus fuerit quoniam Jesus est Filius Dei, Deus in eo manet, et ipse in Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.16",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 John 4:16",
      "text": "Et nos cognovimus, et credidimus caritati, quam habet Deus in nobis. Deus caritas est: et qui manet in caritate, in Deo manet, et Deus in eo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.17",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 John 4:17",
      "text": "In hoc perfecta est caritas Dei nobiscum, ut fiduciam habeamus in die judicii: quia sicut ille est, et nos sumus in hoc mundo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.18",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 John 4:18",
      "text": "Timor non est in caritate: sed perfecta caritas foras mittit timorem, quoniam timor pœnam habet: qui autem timet, non est perfectus in caritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.19",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 John 4:19",
      "text": "Nos ergo diligamus Deum, quoniam Deus prior dilexit nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.20",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 John 4:20",
      "text": "Si quis dixerit: Quoniam diligo Deum, et fratrem suum oderit, mendax est. Qui enim non diligit fratrem suum quem vidit, Deum, quem non vidit, quomodo potest diligere?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:first-john.4.21",
      "translationId": "vulgate",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 John 4:21",
      "text": "Et hoc mandatum habemus a Deo: ut qui diligit Deum, diligat et fratrem suum.",
      "paragraphStart": false
    }
  ]
}
