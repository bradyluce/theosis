{
  "chapter": {
    "id": "vulgate:second-corinthians.6",
    "translationId": "vulgate",
    "bookSlug": "second-corinthians",
    "chapterNumber": 6,
    "referenceLabel": "2 Corinthians 6",
    "summary": "Source text for 2 Corinthians 6 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-corinthians.6.1",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 6:1",
      "text": "Adjuvantes autem exhortamur ne in vacuum gratiam Dei recipiatis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-corinthians.6.2",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 6:2",
      "text": "Ait enim: Tempore accepto exaudivi te, et in die salutis adjuvi te. Ecce nunc tempus acceptabile, ecce nunc dies salutis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.3",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 6:3",
      "text": "Nemini dantes ullam offensionem, ut non vituperetur ministerium nostrum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.4",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 6:4",
      "text": "sed in omnibus exhibeamus nosmetipsos sicut Dei ministros in multa patientia, in tribulationibus, in necessitatibus, in angustiis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.5",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 6:5",
      "text": "in plagis, in carceribus, in seditionibus, in laboribus, in vigiliis, in jejuniis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.6",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 6:6",
      "text": "in castitate, in scientia, in longanimitate, in suavitate, in Spiritu Sancto, in caritate non ficta,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.7",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 6:7",
      "text": "in verbo veritatis, in virtute Dei, per arma justitiæ a dextris et a sinistris,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.8",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 6:8",
      "text": "per gloriam, et ignobilitatem, per infamiam, et bonam famam: ut seductores, et veraces, sicut qui ignoti, et cogniti:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.9",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 6:9",
      "text": "quasi morientes, et ecce vivimus: ut castigati, et non mortificati:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.10",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 6:10",
      "text": "quasi tristes, semper autem gaudentes: sicut egentes, multos autem locupletantes: tamquam nihil habentes, et omnia possidentes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.11",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 6:11",
      "text": "Os nostrum patet ad vos, o Corinthii; cor nostrum dilatatum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.12",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 6:12",
      "text": "Non angustiamini in nobis: angustiamini autem in visceribus vestris:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.13",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 6:13",
      "text": "eamdem autem habentes remunerationem, tamquam filiis dico, dilatamini et vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.14",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 6:14",
      "text": "Nolite jugum ducere cum infidelibus. Quæ enim participatio justitiæ cum iniquitate? aut quæ societas luci ad tenebras?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.15",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 6:15",
      "text": "quæ autem conventio Christi ad Belial? aut quæ pars fideli cum infideli?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.16",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 6:16",
      "text": "qui autem consensus templo Dei cum idolis? vos enim estis templum Dei vivi, sicut dicit Deus: Quoniam inhabitabo in illis, et inambulabo inter eos, et ero illorum Deus, et ipsi erunt mihi populus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.17",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 6:17",
      "text": "Propter quod exite de medio eorum, et separamini, dicit Dominus, et immundum ne tetigeritis:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.6.18",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 6:18",
      "text": "et ego recipiam vos: et ero vobis in patrem, et vos eritis mihi in filios et filias, dicit Dominus omnipotens.",
      "paragraphStart": false
    }
  ]
}
