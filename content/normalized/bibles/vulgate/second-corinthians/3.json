{
  "chapter": {
    "id": "vulgate:second-corinthians.3",
    "translationId": "vulgate",
    "bookSlug": "second-corinthians",
    "chapterNumber": 3,
    "referenceLabel": "2 Corinthians 3",
    "summary": "Source text for 2 Corinthians 3 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-corinthians.3.1",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 3:1",
      "text": "Incipimus iterum nosmetipsos commendare? aut numquid egemus (sicut quidam) commendatitiis epistolis ad vos, aut ex vobis?",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-corinthians.3.2",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 3:2",
      "text": "Epistola nostra vos estis, scripta in cordibus nostris, quæ scitur, et legitur ab omnibus hominibus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.3",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 3:3",
      "text": "manifestati quod epistola estis Christi, ministrata a nobis, et scripta non atramento, sed Spiritu Dei vivi: non in tabulis lapideis, sed in tabulis cordis carnalibus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.4",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 3:4",
      "text": "Fiduciam autem talem habemus per Christum ad Deum:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.5",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 3:5",
      "text": "non quod sufficientes simus cogitare aliquid a nobis, quasi ex nobis: sed sufficientia nostra ex Deo est:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.6",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 3:6",
      "text": "qui et idoneos nos fecit ministros novi testamenti: non littera, sed Spiritu: littera enim occidit, Spiritus autem vivificat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.7",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 3:7",
      "text": "Quod si ministratio mortis litteris deformata in lapidibus fuit in gloria, ita ut non possent intendere filii Israël in faciem Moysi propter gloriam vultus ejus, quæ evacuatur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.8",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 3:8",
      "text": "quomodo non magis ministratio Spiritus erit in gloria?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.9",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 3:9",
      "text": "Nam si ministratio damnationis gloria est: multo magis abundat ministerium justitiæ in gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.10",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 3:10",
      "text": "Nam nec glorificatum est, quod claruit in hac parte, propter excellentem gloriam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.11",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 3:11",
      "text": "Si enim quod evacuatur, per gloriam est: multo magis quod manet, in gloria est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.12",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 3:12",
      "text": "Habentes igitur talem spem, multa fiducia utimur:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.13",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 3:13",
      "text": "et non sicut Moyses ponebat velamen super faciem suam, ut non intenderent filii Israël in faciem ejus, quod evacuatur,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.14",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 3:14",
      "text": "sed obtusi sunt sensus eorum. Usque in hodiernum enim diem, idipsum velamen in lectione veteris testamenti manet non revelatum (quoniam in Christo evacuatur),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.15",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 3:15",
      "text": "sed usque in hodiernum diem, cum legitur Moyses, velamen positum est super cor eorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.16",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 3:16",
      "text": "Cum autem conversus fuerit ad Dominum, auferetur velamen.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.17",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 3:17",
      "text": "Dominus autem Spiritus est: ubi autem Spiritus Domini, ibi libertas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.3.18",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 3:18",
      "text": "Nos vero omnes, revelata facie gloriam Domini speculantes, in eamdem imaginem transformamur a claritate in claritatem, tamquam a Domini Spiritu.",
      "paragraphStart": false
    }
  ]
}
