{
  "chapter": {
    "id": "vulgate:second-corinthians.11",
    "translationId": "vulgate",
    "bookSlug": "second-corinthians",
    "chapterNumber": 11,
    "referenceLabel": "2 Corinthians 11",
    "summary": "Source text for 2 Corinthians 11 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-corinthians.11.1",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 11:1",
      "text": "Utinam sustineretis modicum quid insipientiæ meæ, sed et supportare me:",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-corinthians.11.2",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 11:2",
      "text": "æmulor enim vos Dei æmulatione. Despondi enim vos uni viro, virginem castam exhibere Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.3",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 11:3",
      "text": "Timeo autem ne sicut serpens Hevam seduxit astutia sua, ita corrumpantur sensus vestri, et excidant a simplicitate, quæ est in Christo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.4",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 11:4",
      "text": "Nam si is qui venit, alium Christum prædicat, quem non prædicavimus, aut alium spiritum accipitis, quem non accepistis: aut aliud Evangelium, quod non recepistis: recte pateremini.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.5",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 11:5",
      "text": "Existimo enim nihil me minus fecisse a magnis Apostolis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.6",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 11:6",
      "text": "Nam etsi imperitus sermone, sed non scientia, in omnibus autem manifestati sumus vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.7",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 11:7",
      "text": "Aut numquid peccatum feci, meipsum humilians, ut vos exaltemini? quoniam gratis Evangelium Dei evangelizavi vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.8",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 11:8",
      "text": "Alias ecclesias expoliavi, accipiens stipendium ad ministerium vestrum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.9",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 11:9",
      "text": "Et cum essem apud vos, et egerem, nulli onerosus fui: nam quod mihi deerat, suppleverunt fratres, qui venerunt a Macedonia: et in omnibus sine onere me vobis servavi, et servabo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.10",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 11:10",
      "text": "Est veritas Christi in me, quoniam hæc gloriatio non infringetur in me in regionibus Achaiæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.11",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 11:11",
      "text": "Quare? quia non diligo vos? Deus scit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.12",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 11:12",
      "text": "Quod autem facio, et faciam: ut amputem occasionem eorum qui volunt occasionem, ut in quo gloriantur, inveniantur sicut et nos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.13",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 11:13",
      "text": "Nam ejusmodi pseudoapostoli sunt operarii subdoli, transfigurantes se in apostolos Christi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.14",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 11:14",
      "text": "Et non mirum: ipse enim Satanas transfigurat se in angelum lucis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.15",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 11:15",
      "text": "Non est ergo magnum, si ministri ejus transfigurentur velut ministri justitiæ: quorum finis erit secundum opera ipsorum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.16",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 11:16",
      "text": "Iterum dico (ne quis me putet insipientem esse, alioquin velut insipientem accipite me, ut et ego modicum quid glorier),",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.17",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 11:17",
      "text": "quod loquor, non loquor secundum Deum, sed quasi in insipientia, in hac substantia gloriæ.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.18",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 11:18",
      "text": "Quoniam multi gloriantur secundum carnem: et ego gloriabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.19",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 11:19",
      "text": "Libenter enim suffertis insipientes, cum sitis ipsi sapientes.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.20",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 11:20",
      "text": "Sustinetis enim si quis vos in servitutem redigit, si quis devorat, si quis accipit, si quis extollitur, si quis in faciem vos cædit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.21",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 11:21",
      "text": "Secundum ignobilitatem dico, quasi nos infirmi fuerimus in hac parte. In quo quis audet (in insipientia dico) audeo et ego:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.22",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "2 Corinthians 11:22",
      "text": "Hebræi sunt, et ego: Israëlitæ sunt, et ego: semen Abrahæ sunt, et ego.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.23",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "2 Corinthians 11:23",
      "text": "Ministri Christi sunt (ut minus sapiens dico), plus ego: in laboribus plurimis, in carceribus abundantius, in plagis supra modum, in mortibus frequenter.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.24",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "2 Corinthians 11:24",
      "text": "A Judæis quinquies, quadragenas, una minus, accepi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.25",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "2 Corinthians 11:25",
      "text": "Ter virgis cæsus sum, semel lapidatus sum: ter naufragium feci, nocte et die in profundo maris fui,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.26",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "2 Corinthians 11:26",
      "text": "in itineribus sæpe, periculis fluminum, periculis latronum, periculis ex genere, periculis ex gentibus, periculis in civitate, periculis in solitudine, periculis in mari, periculis in falsis fratribus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.27",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "2 Corinthians 11:27",
      "text": "in labore et ærumna, in vigiliis multis, in fame et siti, in jejuniis multis, in frigore et nuditate,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.28",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "2 Corinthians 11:28",
      "text": "præter illa quæ extrinsecus sunt, instantia mea quotidiana, sollicitudo omnium ecclesiarum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.29",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "2 Corinthians 11:29",
      "text": "Quis infirmatur, et ego non infirmor? quis scandalizatur, et ego non uror?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.30",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "2 Corinthians 11:30",
      "text": "Si gloriari oportet, quæ infirmitatis meæ sunt, gloriabor.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.31",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "2 Corinthians 11:31",
      "text": "Deus et Pater Domini nostri Jesu Christi, qui est benedictus in sæcula, scit quod non mentior.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.32",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "2 Corinthians 11:32",
      "text": "Damasci præpositus gentis Aretæ regis custodiebat civitatem Damascenorum ut me comprehenderet:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.11.33",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "2 Corinthians 11:33",
      "text": "et per fenestram in sporta dimissus sum per murum, et sic effugi manus ejus.",
      "paragraphStart": false
    }
  ]
}
