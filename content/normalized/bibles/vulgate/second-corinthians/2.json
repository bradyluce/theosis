{
  "chapter": {
    "id": "vulgate:second-corinthians.2",
    "translationId": "vulgate",
    "bookSlug": "second-corinthians",
    "chapterNumber": 2,
    "referenceLabel": "2 Corinthians 2",
    "summary": "Source text for 2 Corinthians 2 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-corinthians.2.1",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 2:1",
      "text": "Statui autem hoc ipsum apud me, ne iterum in tristitia venirem ad vos.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-corinthians.2.2",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 2:2",
      "text": "Si enim ego contristo vos: et quis est, qui me lætificet, nisi qui contristatur ex me?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.3",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 2:3",
      "text": "Et hoc ipsum scripsi vobis, ut non cum venero, tristitiam super tristitiam habeam, de quibus oportuerat me gaudere: confidens in omnibus vobis, quia meum gaudium, omnium vestrum est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.4",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 2:4",
      "text": "Nam ex multa tribulatione et angustia cordis scripsi vobis per multas lacrimas: non ut contristemini, sed ut sciatis, quam caritatem habeam abundantius in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.5",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 2:5",
      "text": "Si quis autem contristavit, non me contristavit: sed ex parte, ut non onerem omnes vos.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.6",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 2:6",
      "text": "Sufficit illi, qui ejusmodi est, objurgatio hæc, quæ fit a pluribus:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.7",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 2:7",
      "text": "ita ut e contrario magis donetis, et consolemini, ne forte abundantiori tristitia absorbeatur qui ejusmodi est.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.8",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 2:8",
      "text": "Propter quod obsecro vos, ut confirmetis in illum caritatem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.9",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 2:9",
      "text": "Ideo enim et scripsi, ut cognoscam experimentum vestrum, an in omnibus obedientes sitis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.10",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 2:10",
      "text": "Cui autem aliquid donastis, et ego: nam et ego quod donavi, si quid donavi, propter vos in persona Christi,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.11",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 2:11",
      "text": "ut non circumveniamur a Satana: non enim ignoramus cogitationes ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.12",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 2:12",
      "text": "Cum venissem autem Troadem propter Evangelium Christi, et ostium mihi apertum esset in Domino,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.13",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 2:13",
      "text": "non habui requiem spiritui meo, eo quod non invenerim Titum fratrem meum, sed valefaciens eis, profectus sum in Macedoniam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.14",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 2:14",
      "text": "Deo autem gratias, qui semper triumphat nos in Christo Jesu, et odorem notitiæ suæ manifestat per nos in omni loco:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.15",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 2:15",
      "text": "quia Christi bonus odor sumus Deo in iis qui salvi fiunt, et in iis qui pereunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.16",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 2:16",
      "text": "aliis quidem odor mortis in mortem: aliis autem odor vitæ in vitam. Et ad hæc quis tam idoneus?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.2.17",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 2:17",
      "text": "non enim sumus sicut plurimi, adulterantes verbum Dei, sed ex sinceritate, sed sicut ex Deo, coram Deo, in Christo loquimur.",
      "paragraphStart": false
    }
  ]
}
