{
  "chapter": {
    "id": "vulgate:second-corinthians.5",
    "translationId": "vulgate",
    "bookSlug": "second-corinthians",
    "chapterNumber": 5,
    "referenceLabel": "2 Corinthians 5",
    "summary": "Source text for 2 Corinthians 5 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-corinthians.5.1",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 5:1",
      "text": "Scimus enim quoniam si terrestris domus nostra hujus habitationis dissolvatur, quod ædificationem ex Deo habemus, domum non manufactam, æternam in cælis.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-corinthians.5.2",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 5:2",
      "text": "Nam et in hoc ingemiscimus, habitationem nostram, quæ de cælo est, superindui cupientes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.3",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 5:3",
      "text": "si tamen vestiti, non nudi inveniamur.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.4",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 5:4",
      "text": "Nam et qui sumus in hoc tabernaculo, ingemiscimus gravati: eo quod nolumus expoliari, sed supervestiri, ut absorbeatur quod mortale est, a vita.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.5",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 5:5",
      "text": "Qui autem efficit nos in hoc ipsum, Deus, qui dedit nobis pignus Spiritus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.6",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 5:6",
      "text": "Audentes igitur semper, scientes quoniam dum sumus in corpore, peregrinamur a Domino",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.7",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 5:7",
      "text": "(per fidem enim ambulamus, et non per speciem):",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.8",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 5:8",
      "text": "audemus autem, et bonam voluntatem habemus magis peregrinari a corpore, et præsentes esse ad Dominum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.9",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 5:9",
      "text": "Et ideo contendimus, sive absentes, sive præsentes, placere illi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.10",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 5:10",
      "text": "Omnes enim nos manifestari oportet ante tribunal Christi, ut referat unusquisque propria corporis, prout gessit, sive bonum, sive malum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.11",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 5:11",
      "text": "Scientes ergo timorem Domini, hominibus suademus, Deo autem manifesti sumus. Spero autem et in conscientiis vestris manifestos nos esse.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.12",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 5:12",
      "text": "Non iterum commendamus nos vobis, sed occasionem damus vobis gloriandi pro nobis: ut habeatis ad eos qui in facie gloriantur, et non in corde.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.13",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 5:13",
      "text": "Sive enim mente excedimus Deo: sive sobrii sumus, vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.14",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 5:14",
      "text": "Caritas enim Christi urget nos: æstimantes hoc, quoniam si unus pro omnibus mortuus est, ergo omnes mortui sunt:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.15",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 5:15",
      "text": "et pro omnibus mortuus est Christus: ut, et qui vivunt, jam non sibi vivant, sed ei qui pro ipsis mortuus est et resurrexit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.16",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 5:16",
      "text": "Itaque nos ex hoc neminem novimus secundum carnem. Et si cognovimus secundum carnem Christum, sed nunc jam non novimus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.17",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 5:17",
      "text": "Si qua ergo in Christo nova creatura, vetera transierunt: ecce facta sunt omnia nova.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.18",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 5:18",
      "text": "Omnia autem ex Deo, qui nos reconciliavit sibi per Christum: et dedit nobis ministerium reconciliationis,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.19",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 5:19",
      "text": "quoniam quidem Deus erat in Christo mundum reconcilians sibi, non reputans illis delicta ipsorum, et posuit in nobis verbum reconciliationis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.20",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 5:20",
      "text": "Pro Christo ergo legatione fungimur, tamquam Deo exhortante per nos. Obsecramus pro Christo, reconciliamini Deo.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.5.21",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 5:21",
      "text": "Eum, qui non noverat peccatum, pro nobis peccatum fecit, ut nos efficeremur justitia Dei in ipso.",
      "paragraphStart": false
    }
  ]
}
