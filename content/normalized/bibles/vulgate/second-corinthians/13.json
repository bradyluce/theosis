{
  "chapter": {
    "id": "vulgate:second-corinthians.13",
    "translationId": "vulgate",
    "bookSlug": "second-corinthians",
    "chapterNumber": 13,
    "referenceLabel": "2 Corinthians 13",
    "summary": "Source text for 2 Corinthians 13 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-corinthians.13.1",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 13:1",
      "text": "Ecce tertio hoc venio ad vos: in ore duorum vel trium testium stabit omne verbum.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-corinthians.13.2",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 13:2",
      "text": "Prædixi, et prædico, ut præsens, et nunc absens iis qui ante peccaverunt, et ceteris omnibus, quoniam si venero iterum, non parcam.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.3",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 13:3",
      "text": "An experimentum quæritis ejus, qui in me loquitur Christus, qui in vobis non infirmatur, sed potens est in vobis?",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.4",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 13:4",
      "text": "Nam etsi crucifixus est ex infirmitate: sed vivit ex virtute Dei. Nam et nos infirmi sumus in illo: sed vivemus cum eo ex virtute Dei in vobis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.5",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 13:5",
      "text": "Vosmetipsos tentate si estis in fide: ipsi vos probate. An non cognoscitis vosmetipsos quia Christus Jesus in vobis est? nisi forte reprobi estis.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.6",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 13:6",
      "text": "Spero autem quod cognoscetis, quia nos non sumus reprobi.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.7",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 13:7",
      "text": "Oramus autem Deum ut nihil mali faciatis, non ut nos probati appareamus, sed ut vos quod bonum est faciatis: nos autem ut reprobi simus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.8",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 13:8",
      "text": "Non enim possumus aliquid adversus veritatem, sed pro veritate.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.9",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 13:9",
      "text": "Gaudemus enim, quoniam nos infirmi sumus, vos autem potentes estis. Hoc et oramus, vestram consummationem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.10",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 13:10",
      "text": "Ideo hæc absens scribo, ut non præsens durius agam secundum potestatem, quam Dominus dedit mihi in ædificationem, et non in destructionem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.11",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 13:11",
      "text": "De cetero, fratres, gaudete, perfecti estote, exhortamini, idem sapite, pacem habete, et Deus pacis et dilectionis erit vobiscum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.12",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 13:12",
      "text": "Salutate invicem in osculo sancto. Salutant vos omnes sancti.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-corinthians.13.13",
      "translationId": "vulgate",
      "bookSlug": "second-corinthians",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 13:13",
      "text": "Gratia Domini nostri Jesu Christi, et caritas Dei, et communicatio Sancti Spiritus sit cum omnibus vobis. Amen.",
      "paragraphStart": false
    }
  ]
}
