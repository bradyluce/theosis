{
  "chapter": {
    "id": "vulgate:second-chronicles.17",
    "translationId": "vulgate",
    "bookSlug": "second-chronicles",
    "chapterNumber": 17,
    "referenceLabel": "2 Chronicles 17",
    "summary": "Source text for 2 Chronicles 17 in Clementine Vulgate."
  },
  "verses": [
    {
      "id": "vulgate:second-chronicles.17.1",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "2 Chronicles 17:1",
      "text": "Regnavit autem Josaphat filius ejus pro eo, et invaluit contra Israël.",
      "paragraphStart": true
    },
    {
      "id": "vulgate:second-chronicles.17.2",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "2 Chronicles 17:2",
      "text": "Constituitque militum numeros in cunctis urbibus Juda quæ erant vallatæ muris. Præsidiaque disposuit in terra Juda, et in civitatibus Ephraim quas ceperat Asa pater ejus.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.3",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "2 Chronicles 17:3",
      "text": "Et fuit Dominus cum Josaphat, quia ambulavit in viis David patris sui primis: et non speravit in Baalim,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.4",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "2 Chronicles 17:4",
      "text": "sed in Deo patris sui: et perrexit in præceptis illius, et non juxta peccata Israël.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.5",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "2 Chronicles 17:5",
      "text": "Confirmavitque Dominus regnum in manu ejus, et dedit omnis Juda munera Josaphat: factæque sunt ei infinitæ divitiæ, et multa gloria.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.6",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "2 Chronicles 17:6",
      "text": "Cumque sumpsisset cor ejus audaciam propter vias Domini, etiam excelsa et lucos de Juda abstulit.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.7",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "2 Chronicles 17:7",
      "text": "Tertio autem anno regni sui misit de principibus suis Benhail, et Obdiam, et Zachariam, et Nathanaël, et Michæam, ut docerent in civitatibus Juda:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.8",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "2 Chronicles 17:8",
      "text": "et cum eis Levitas Semeiam, et Nathaniam, et Zabadiam, Asaël quoque, et Semiramoth, et Jonathan, Adoniamque et Thobiam, et Thobadoniam Levitas, et cum eis Elisama, et Joran sacerdotes:",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.9",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "2 Chronicles 17:9",
      "text": "docebantque populum in Juda, habentes librum legis Domini, et circuibant cunctas urbes Juda, atque erudiebant populum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.10",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "2 Chronicles 17:10",
      "text": "Itaque factus est pavor Domini super omnia regna terrarum quæ erant per gyrum Juda, nec audebant bellare contra Josaphat.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.11",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "2 Chronicles 17:11",
      "text": "Sed et Philisthæi Josaphat munera deferebant, et vectigal argenti: Arabes quoque adducebant pecora, arietum septem millia septingenta, et hircorum totidem.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.12",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "2 Chronicles 17:12",
      "text": "Crevit ergo Josaphat, et magnificatus est usque in sublime: atque ædificavit in Juda domos ad instar turrium, urbesque muratas.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.13",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "2 Chronicles 17:13",
      "text": "Et multa opera paravit in urbibus Juda: viri quoque bellatores et robusti erant in Jerusalem,",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.14",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "2 Chronicles 17:14",
      "text": "quorum iste numerus per domos atque familias singulorum: in Juda principes exercitus, Ednas dux, et cum eo robustissimi viri trecenta millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.15",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "2 Chronicles 17:15",
      "text": "Post hunc Johanan princeps, et cum eo ducenta octoginta millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.16",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "2 Chronicles 17:16",
      "text": "Post istum quoque Amasias filius Zechri, consecratus Domino, et cum eo ducenta millia virorum fortium.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.17",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "2 Chronicles 17:17",
      "text": "Hunc sequebatur robustus ad prælia Eliada, et cum eo tenentium arcum et clypeum ducenta millia.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.18",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "2 Chronicles 17:18",
      "text": "Post istum etiam Jozabad, et cum eo centum octoginta millia expeditorum militum.",
      "paragraphStart": false
    },
    {
      "id": "vulgate:second-chronicles.17.19",
      "translationId": "vulgate",
      "bookSlug": "second-chronicles",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "2 Chronicles 17:19",
      "text": "Hi omnes erant ad manum regis, exceptis aliis quos posuerat in urbibus muratis in universo Juda.",
      "paragraphStart": false
    }
  ]
}
