{
  "chapter": {
    "id": "brenton:first-chronicles.1",
    "translationId": "brenton",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:first-chronicles.1.1",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "ADAM, Seth, Enos,",
      "paragraphStart": true
    },
    {
      "id": "brenton:first-chronicles.1.2",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "and Cainan, Maleleel, Jared,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.3",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Enoch, Mathusala, Lamech,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.4",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Noe: the sons of Noe, Sem, Cham, Japheth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.5",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "The sons of Japheth, Gamer, Magog, Madaim, Jovan, Helisa, Thobel, Mosoch, and Thiras.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.6",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "And the sons of Gamer, Aschanaz, and Riphath, and Thorgama.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.7",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "And the sons of Jovan, Helisa, and Tharsis, the Citians, and Rhodians.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.8",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "And the sons of Cham, Chus, and Mesraim, Phud and Chanaan.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.9",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "And the sons of Chus, Saba, and Evila, and Sabatha, and Regma, and Sebethaca: and the sons of Regma, Saba, and Dadan.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.10",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "And Chus begot Nebrod: he began to be a mighty hunter on the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.17",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "The sons of Sem, Ælam, and Assur,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.24",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "and Arphaxad, Sala,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.25",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Eber, Pheleg, Ragan,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.26",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Seruch, Nachor, Tharrha,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.27",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Abraam.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.28",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "And the sons of Abraam, Isaac, and Ismael.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.29",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "And these are their generations: the first-born of Ismael, Nabæoth, and Kedar, Nabdeel, Massam,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.30",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "Masma, Iduma, Masse, Chondan, Thæman,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.31",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Jettur, Naphes, Kedma: these are the sons of Ismael.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.32",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "And the sons of Chettura Abraam's concubine:—and she bore him Zembram, Jexan, Madiam, Madam, Sobac, Soe: and the sons of Jexan; Dædan, and Sabai;",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.33",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "and the sons of Madiam; Gephar, and Opher, and Enoch, and Abida, and Eldada; all these were the sons of Chettura.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.34",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "And Abraam begot Isaac: and the sons of Isaac were Jacob, and Esau.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.35",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "The sons of Esau, Eliphaz, and Raguel, and Jeul, and Jeglom, and Core.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.36",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "The sons of Eliphaz: Thæman, and Omar, Sophar, and Goötham, and Kenez, and Thamna, and Amalec.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.37",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "And the sons of Raguel, Naches, Zare, Some, and Moze.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.38",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "The sons of Seir, Lotan, Sobal, Sebegon, Ana, Deson, Osar, and Disan.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.39",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "And the sons of Lotan, Chorri, and Æman; and the sister of Lotan was Thamna.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.40",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "The sons of Sobal; Alon, Machanath, Tæbel, Sophi, and Onan: and the sons of Sebegon; Æth, and Sonan.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.41",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "The sons of Sonan, Dæson: and the sons of Dæson; Emeron, and Asebon, and Jethram, and Charran.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.42",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "And the sons of Hosar, Balaam, and Zucam, and Acan: the sons of Disan, Os, and Aran.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.43",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "And these are their kings, Balac the son of Beor; and the name of his city was Dennaba.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.44",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "And Balac died, and Jobab the son of Zara of Bosorrha reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.45",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "And Jobab died, and Asom of the land of the Thæmanites reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.46",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "And Asom died, and Adad the son of Barad reigned in his stead, who smote Madiam in the plain of Moab: and the name of his city was Gethaim.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.47",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "And Adad died, and Sebla of Masecca reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.48",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "And Sebla died, and Saul of Rhoboth by the river reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.49",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "And Saul died, and Balaennor son of Achobor reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.50",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "And Balaennor died, and Adad son of Barad reigned in his stead; and the name of his city was Phogor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.51",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "The princes of Edom: prince Thamna, prince Golada, prince Jether,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.52",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "prince Elibamas, prince Elas, prince Phinon,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.53",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "prince Kenez, prince Thæman, prince Babsar, prince Magediel,",
      "paragraphStart": false
    },
    {
      "id": "brenton:first-chronicles.1.54",
      "translationId": "brenton",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "prince Zaphoin. These are the princes of Edom.",
      "paragraphStart": false
    }
  ]
}
