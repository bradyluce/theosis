{
  "chapter": {
    "id": "brenton:sirach.5",
    "translationId": "brenton",
    "bookSlug": "sirach",
    "chapterNumber": 5,
    "referenceLabel": "Sirach 5",
    "summary": "Source text for Sirach 5 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:sirach.5.1",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Sirach 5:1",
      "text": "Set not thy heart upon thy goods; and say not, I have enough for my life.",
      "paragraphStart": true
    },
    {
      "id": "brenton:sirach.5.2",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Sirach 5:2",
      "text": "Follow not thine own mind and thy strength, to walk in the ways of thy heart:",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.3",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Sirach 5:3",
      "text": "Thou shalt eat up thy leaves, and lose thy fruit, and leave thyself as a dry tree.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.4",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Sirach 5:4",
      "text": "A wicked soul shall destroy him that hath it, and shall make him to be laughed to scorn of his enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.5",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Sirach 5:5",
      "text": "Sweet language will multiply friends: and a fairspeaking tongue will increase kind greetings.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.6",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Sirach 5:6",
      "text": "Be in peace with many: nevertheless have but one counsellor of a thousand.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.7",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Sirach 5:7",
      "text": "If thou wouldest get a friend, prove him first, and be not hasty to credit him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.8",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Sirach 5:8",
      "text": "For some man is a friend for his own occasion, and will not abide in the day of thy trouble.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.9",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Sirach 5:9",
      "text": "And there is a friend, who being turned to enmity and strife will discover thy reproach.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.10",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Sirach 5:10",
      "text": "Again, some friend is a companion at the table, and will not continue in the day of thy affliction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.11",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Sirach 5:11",
      "text": "But in thy prosperity he will be as thyself, and will be bold over thy servants.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.12",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Sirach 5:12",
      "text": "If thou be brought low, he will be against thee, and will hide himself from thy face.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.13",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Sirach 5:13",
      "text": "Separate thyself from thine enemies, and take heed of thy friends.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.14",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Sirach 5:14",
      "text": "A faithful friend is a strong defence: and he that hath found such an one hath found a treasure.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.15",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Sirach 5:15",
      "text": "Nothing doth countervail a faithful friend, and his excellency is invaluable.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.16",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Sirach 5:16",
      "text": "A faithful friend is the medicine of life; and they that fear the Lord shall find him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.17",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Sirach 5:17",
      "text": "Whoso feareth the Lord shall direct his friendship aright: for as he is, so shall his neighbour be also.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.18",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Sirach 5:18",
      "text": "My son, gather instruction from thy youth up: so shalt thou find wisdom till thine old age.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.19",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Sirach 5:19",
      "text": "Come unto her as one that ploweth and soweth, and wait for her good fruits: for thou shalt not toil much in labouring about her, but thou shalt eat of her fruits right soon.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.20",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Sirach 5:20",
      "text": "She is very unpleasant to the unlearned: he that is without understanding will not remain with her.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.21",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Sirach 5:21",
      "text": "She will lie upon him as a mighty stone of trial; and he will cast her from him ere it be long.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.22",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Sirach 5:22",
      "text": "For wisdom is according to her name, and she is not manifest unto many.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.23",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Sirach 5:23",
      "text": "Give ear, my son, receive my advice, and refuse not my counsel,",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.24",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Sirach 5:24",
      "text": "and put thy feet into her fetters, and thy neck into her chain.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.25",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Sirach 5:25",
      "text": "Bow down thy shoulder, and bear her, and be not grieved with her bonds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.26",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Sirach 5:26",
      "text": "Come unto her with thy whole heart, and keep her ways with all thy power.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.27",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Sirach 5:27",
      "text": "Search, and seek, and she shall be made known unto thee: and when thou hast got hold of her, let her not go.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.28",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Sirach 5:28",
      "text": "For at the last thou shalt find her rest, and that shall be turned to thy joy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.29",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Sirach 5:29",
      "text": "Then shall her fetters be a strong defence for thee, and her chains a robe of glory.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.30",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Sirach 5:30",
      "text": "For there is a golden ornament upon her, and her bands are purple lace.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.31",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Sirach 5:31",
      "text": "Thou shalt put her on as a robe of honour, and shalt put her about thee as a crown of joy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.32",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Sirach 5:32",
      "text": "My son, if thou wilt, thou shalt be taught: and if thou wilt apply thy mind, thou shalt be prudent.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.33",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Sirach 5:33",
      "text": "If thou love to hear, thou shalt receive understanding: and if thou bow thine ear, thou shalt be wise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.34",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Sirach 5:34",
      "text": "Stand in the multitude of the elders; and cleave unto him that is wise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.35",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "Sirach 5:35",
      "text": "Be willing to hear every godly discourse: and let not the parables of understanding escape thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.36",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "Sirach 5:36",
      "text": "And if thou seest a man of understanding, get thee betimes unto him, and let thy foot wear the steps of his door.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.5.37",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "Sirach 5:37",
      "text": "Let thy mind be upon the ordinances of the Lord, and meditate continually in his commandments: he shall establish thine heart, and give thee wisdom at thine own desire.",
      "paragraphStart": false
    }
  ]
}
