{
  "chapter": {
    "id": "brenton:sirach.4",
    "translationId": "brenton",
    "bookSlug": "sirach",
    "chapterNumber": 4,
    "referenceLabel": "Sirach 4",
    "summary": "Source text for Sirach 4 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:sirach.4.1",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Sirach 4:1",
      "text": "My son, defraud not the poor of his living, and make not the needy eyes to wait long.",
      "paragraphStart": true
    },
    {
      "id": "brenton:sirach.4.2",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Sirach 4:2",
      "text": "Make not a hungry soul sorrowful; neither provoke a man in his distress.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.3",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Sirach 4:3",
      "text": "Add not more trouble to a heart that is vexed; and defer not to give to him that is in need.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.4",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Sirach 4:4",
      "text": "Reject not the supplication of the afflicted; neither turn away thy face from a poor man.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.5",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Sirach 4:5",
      "text": "Turn not away thine eye from the needy, and give him none occasion to curse thee:",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.6",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Sirach 4:6",
      "text": "for if he curse thee in the bitterness of his soul, his prayer shall be heard of him that made him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.7",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Sirach 4:7",
      "text": "Get thyself the love of the congregation, and bow thy head to a great man.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.8",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Sirach 4:8",
      "text": "Let it not grieve thee to bow down thine ear to the poor, and give him a friendly answer with meekness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.9",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Sirach 4:9",
      "text": "Deliver him that suffereth wrong from the hand of the oppressor; and be not fainthearted when thou sittest in judgment.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.10",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Sirach 4:10",
      "text": "Be as a father unto the fatherless, and instead of a husband unto their mother: so shalt thou be as the son of the most High, and he shall love thee more than thy mother doth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.11",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Sirach 4:11",
      "text": "Wisdom exalteth her children, and layeth hold of them that seek her.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.12",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Sirach 4:12",
      "text": "He that loveth her loveth life; and they that seek to her early shall be filled with joy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.13",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Sirach 4:13",
      "text": "He that holdeth her fast shall inherit glory; and wheresoever she entereth, the Lord will bless.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.14",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Sirach 4:14",
      "text": "They that serve her shall minister to the Holy One: and them that love her the Lord doth love.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.15",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Sirach 4:15",
      "text": "Whoso giveth ear unto her shall judge the nations: and he that attendeth unto her shall dwell securely.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.16",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Sirach 4:16",
      "text": "If a man commit himself unto her, he shall inherit her; and his generation shall hold her in possession.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.17",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Sirach 4:17",
      "text": "For at the first she will walk with him by crooked ways, and bring fear and dread upon him, and torment him with her discipline, until she may trust his soul, and try him by her laws.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.18",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Sirach 4:18",
      "text": "Then will she return the straight way unto him, and comfort him, and shew him her secrets.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.19",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Sirach 4:19",
      "text": "But if he go wrong, she will forsake him, and give him over to his own ruin.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.20",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Sirach 4:20",
      "text": "Observe the opportunity, and beware of evil; and be not ashamed when it concerneth thy soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.21",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Sirach 4:21",
      "text": "For there is a shame that bringeth sin; and there is a shame which is glory and grace.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.22",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Sirach 4:22",
      "text": "Accept no person against thy soul, and let not the reverence of any man cause thee to fall.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.23",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Sirach 4:23",
      "text": "And refrain not to speak, when there is occasion to do good, and hide not thy wisdom in her beauty.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.24",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Sirach 4:24",
      "text": "For by speech wisdom shall be known: and learning by the word of the tongue.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.25",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Sirach 4:25",
      "text": "In no wise speak against the truth; but be abashed of the error of thine ignorance.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.26",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Sirach 4:26",
      "text": "Be not ashamed to confess thy sins; and force not the course of the river.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.27",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Sirach 4:27",
      "text": "Make not thyself an underling to a foolish man; neither accept the person of the mighty.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.28",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Sirach 4:28",
      "text": "Strive for the truth unto death, and the Lord shall fight for thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.29",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Sirach 4:29",
      "text": "Be not hasty in thy tongue, and in thy deeds slack and remiss.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.30",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Sirach 4:30",
      "text": "Be not as a lion in thy house, nor frantic among thy servants.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.4.31",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Sirach 4:31",
      "text": "Let not thine hand be stretched out to receive, and shut when thou shouldest repay.",
      "paragraphStart": false
    }
  ]
}
