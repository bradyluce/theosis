{
  "chapter": {
    "id": "brenton:sirach.33",
    "translationId": "brenton",
    "bookSlug": "sirach",
    "chapterNumber": 33,
    "referenceLabel": "Sirach 33",
    "summary": "Source text for Sirach 33 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:sirach.33.1",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Sirach 33:1",
      "text": "Have mercy upon us, O Lord God of all, and behold us:",
      "paragraphStart": true
    },
    {
      "id": "brenton:sirach.33.2",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Sirach 33:2",
      "text": "and send thy fear upon all the nations that seek not after thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.3",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Sirach 33:3",
      "text": "Lift up thy hand against the strange nations, and let them see thy power.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.4",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Sirach 33:4",
      "text": "As thou wast sanctified in us before them: so be thou magnified among them before us.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.5",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Sirach 33:5",
      "text": "And let them know thee, as we have known thee, that there is no God but only thou, O God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.6",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Sirach 33:6",
      "text": "Shew new signs, and make other strange wonders: glorify thy hand and thy right arm, that they may set forth thy wondrous works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.7",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Sirach 33:7",
      "text": "Raise up indignation, and pour out wrath: take away the adversary, and destroy the enemy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.8",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Sirach 33:8",
      "text": "Make the time short, remember the covenant, and let them declare thy wonderful works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.9",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Sirach 33:9",
      "text": "Let him that escapeth be consumed by the rage of the fire; and let them perish that oppress the people.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.10",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Sirach 33:10",
      "text": "Smite in sunder the heads of the rulers of the heathen, that say, There is none other but we.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.11",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Sirach 33:11",
      "text": "Gather all the tribes of Jacob together.",
      "paragraphStart": false
    },
    {
      "id": "brenton:sirach.33.12",
      "translationId": "brenton",
      "bookSlug": "sirach",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Sirach 33:12",
      "text": "A cheerful and good heart will have a care of his meat and diet.",
      "paragraphStart": false
    }
  ]
}
