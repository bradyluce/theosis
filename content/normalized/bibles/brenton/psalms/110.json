{
  "chapter": {
    "id": "brenton:psalms.110",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 110,
    "referenceLabel": "Psalms 110",
    "summary": "Source text for Psalms 110 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.110.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 1,
      "referenceLabel": "Psalms 110:1",
      "text": "Alleluia. - I will give thee thanks, O Lord, with my whole heart, in the council of the upright, and in the congregation.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.110.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 2,
      "referenceLabel": "Psalms 110:2",
      "text": "The works of the Lord are great, sought out according to all his will.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 3,
      "referenceLabel": "Psalms 110:3",
      "text": "His work is worthy of thanksgiving and honour: and his righteousness endures for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 4,
      "referenceLabel": "Psalms 110:4",
      "text": "He has caused his wonderful works to be remembered: the Lord is merciful and compassionate.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 5,
      "referenceLabel": "Psalms 110:5",
      "text": "He has given food to them that fear him: he will remember his covenant for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 6,
      "referenceLabel": "Psalms 110:6",
      "text": "He has declared to his people the power of his works, to give them the inheritance of the heathen.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 7,
      "referenceLabel": "Psalms 110:7",
      "text": "The works of his hands are truth and judgement: all his commandments are sure:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 8,
      "referenceLabel": "Psalms 110:8",
      "text": "established for ever and ever, done in truth and uprightness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 9,
      "referenceLabel": "Psalms 110:9",
      "text": "He sent redemption to his people: he commanded his covenant for ever: holy and fearful is his name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.110.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 110,
      "verseNumber": 10,
      "referenceLabel": "Psalms 110:10",
      "text": "The fear of the Lord is the beginning of wisdom, and all that act accordingly have a good understanding; his praise endures for ever and ever.",
      "paragraphStart": false
    }
  ]
}
