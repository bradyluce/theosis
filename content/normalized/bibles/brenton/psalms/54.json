{
  "chapter": {
    "id": "brenton:psalms.54",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.54.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "For the end, among Hymns of instruction by David. ✡ 52:4 Rom. 3. 10-12.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.54.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "Hearken, O God, to my prayer; and disregard not my supplication.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "Attend to me, and hearken to me: I was grieved in my meditation, and troubled;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "because of the voice of the enemy, and because of the oppression of the sinner: for they brought iniquity against me, and were wrathfully angry with me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "My heart was troubled within me; and the fear of death fell upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "Fear and trembling came upon me, and darkness covered me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "And I said, O that I had wings as those of a dove! then would I flee away, and be at rest.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 8,
      "referenceLabel": "Psalms 54:8",
      "text": "Lo! I have fled afar off, and lodged in the wilderness. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 9,
      "referenceLabel": "Psalms 54:9",
      "text": "I waited for him that should deliver me from distress of spirit and tempest.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 10,
      "referenceLabel": "Psalms 54:10",
      "text": "Destroy, O Lord, and divide their tongues: for I have seen iniquity and gainsaying in the city.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 11,
      "referenceLabel": "Psalms 54:11",
      "text": "Day and night he shall go round about it upon its walls: iniquity and sorrow and unrighteousness are in the midst of it;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 12,
      "referenceLabel": "Psalms 54:12",
      "text": "and usury and craft have not failed from its streets.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 13,
      "referenceLabel": "Psalms 54:13",
      "text": "For if an enemy had reproached me, I would have endured it; and if one who hated me had spoken vauntingly against me, I would have hid myself from him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 14,
      "referenceLabel": "Psalms 54:14",
      "text": "But thou, O man likeminded, my guide, and my acquaintance,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 15,
      "referenceLabel": "Psalms 54:15",
      "text": "who in companionship with me sweetened our food: we walked in the house of God in concord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 16,
      "referenceLabel": "Psalms 54:16",
      "text": "Let death come upon them, and let them go down alive into Hades, for iniquity is in their dwellings, in the midst of them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 17,
      "referenceLabel": "Psalms 54:17",
      "text": "I cried to God, and the Lord hearkened to me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 18,
      "referenceLabel": "Psalms 54:18",
      "text": "Evening, and morning, and at noon I will declare and make known my wants: and he shall hear my voice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 19,
      "referenceLabel": "Psalms 54:19",
      "text": "He shall deliver my soul in peace from them that draw nigh to me: for they were with me in many cases.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 20,
      "referenceLabel": "Psalms 54:20",
      "text": "God shall hear, and bring them low, even he that has existed from eternity. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 21,
      "referenceLabel": "Psalms 54:21",
      "text": "He has reached forth his hand for retribution; they have profaned his covenant.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 22,
      "referenceLabel": "Psalms 54:22",
      "text": "They were scattered at the anger of his countenance, and his heart drew nigh",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 23,
      "referenceLabel": "Psalms 54:23",
      "text": "✡ Cast thy care upon the Lord, and he shall sustain thee; he shall never suffer the righteous to be moved.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.54.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 24,
      "referenceLabel": "Psalms 54:24",
      "text": "But thou, O God, shalt bring them down to the pit of destruction; bloody and crafty men shall not live out half their days; but I will hope in thee, O Lord.",
      "paragraphStart": false
    }
  ]
}
