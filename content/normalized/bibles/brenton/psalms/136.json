{
  "chapter": {
    "id": "brenton:psalms.136",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.136.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "For David, a Psalm of Jeremias. By the rivers of Babylon, there we sat; and wept when we remembered Sion.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.136.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "We hung our harps on the willows in the midst of it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "For there they that had taken us captive asked of us the words of a song; and they that had carried us away asked a hymn, saying, Sing us one of the songs of Sion.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "How should we sing the Lord’s song in a strange land?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "If I forget thee, O Jerusalem, let my right hand forget its skill.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "May my tongue cleave to my throat, if I do not remember thee; if I do not prefer Jerusalem as the chief of my joy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "Remember, O Lord, the children of Edom in the day of Jerusalem; who said, Rase it, rase it, even to its foundations.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "Wretched daughter of Babylon! blessed shall he be who shall reward thee as thou hast rewarded us.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.136.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "Blessed shall he be who shall seize and dash thine infants against the rock.",
      "paragraphStart": false
    }
  ]
}
