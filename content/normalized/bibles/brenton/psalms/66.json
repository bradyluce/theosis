{
  "chapter": {
    "id": "brenton:psalms.66",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.66.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "For the end, a Psalm of David among the Hymns.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.66.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "God be merciful to us, and bless us; and cause his face to shine upon us. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.66.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "That men may know thy way on the earth, thy salvation among all nations.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.66.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "Let the nations, O God, give thanks to thee; let all the nations give thanks to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.66.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Let the nations rejoice and exult, for thou shalt judge the peoples in equity, and shalt guide the nations on the earth. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.66.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "Let the peoples, O God, give thanks to thee; let all the peoples give thanks to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.66.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "The earth has yielded her fruit; let God, our God, bless us.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.66.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "Let God bless us; and let all the ends of the earth fear him.",
      "paragraphStart": false
    }
  ]
}
