{
  "chapter": {
    "id": "brenton:psalms.143",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 143,
    "referenceLabel": "Psalms 143",
    "summary": "Source text for Psalms 143 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.143.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 1,
      "referenceLabel": "Psalms 143:1",
      "text": "A Psalm of David concerning Goliad. - Blessed be the Lord my God, who instructs my hands for battle, and my fingers for war.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.143.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 2,
      "referenceLabel": "Psalms 143:2",
      "text": "My mercy, and my refuge; my helper, and my deliverer; my protector, in whom I have trusted; who subdues my people under me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 3,
      "referenceLabel": "Psalms 143:3",
      "text": "Lord, what is man, that thou art made known to him? or the son of man, that thou takest account of him?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 4,
      "referenceLabel": "Psalms 143:4",
      "text": "Man is like to vanity: his days pass as a shadow.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 5,
      "referenceLabel": "Psalms 143:5",
      "text": "O Lord, bow thy heavens, and come down: touch the mountains, and they shall smoke.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 6,
      "referenceLabel": "Psalms 143:6",
      "text": "Send lightning, and thou shalt scatter them: send forth thine arrows, and thou shalt discomfit them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 7,
      "referenceLabel": "Psalms 143:7",
      "text": "Send forth thine hand from on high; rescue me, and deliver me out of great waters, out of the hand of strange children;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 8,
      "referenceLabel": "Psalms 143:8",
      "text": "whose mouth has spoken vanity, and their right hand is a right hand of iniquity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 9,
      "referenceLabel": "Psalms 143:9",
      "text": "O God, I will sing a new song to thee: I will play to thee on a psaltery of ten strings.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 10,
      "referenceLabel": "Psalms 143:10",
      "text": "Even to him who gives salvation to kings: who redeems his servant David from the hurtful sword.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 11,
      "referenceLabel": "Psalms 143:11",
      "text": "Deliver me, and rescue me from the hand of strange children, whose mouth has spoken vanity, and their right hand is a right hand of iniquity;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 12,
      "referenceLabel": "Psalms 143:12",
      "text": "whose children are as plants, strengthened in their youth: their daughters are beautiful, sumptuously adorned after the similitude of a temple.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 13,
      "referenceLabel": "Psalms 143:13",
      "text": "Their garners are full, and bursting with one kind of store after another; their sheep are prolific, multiplying in their streets.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 14,
      "referenceLabel": "Psalms 143:14",
      "text": "Their oxen are fat: there is no falling down of a hedge, nor going out, nor cry in their folds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.143.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 15,
      "referenceLabel": "Psalms 143:15",
      "text": "Men bless the people to whom this lot belongs, but blessed is the people whose God is the Lord.",
      "paragraphStart": false
    }
  ]
}
