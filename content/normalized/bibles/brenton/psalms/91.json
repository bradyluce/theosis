{
  "chapter": {
    "id": "brenton:psalms.91",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.91.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "It is a good thing to give thanks to the Lord, and to sing praises to thy name, O thou Most High;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "to proclaim thy mercy in the morning, and thy truth by night,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "on a psaltery of ten strings, with a song on the harp.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "For thou, O Lord, hast made me glad with thy work: and in the operations of thy hands will I exult.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "How have thy works been magnified, O Lord! thy thoughts are very deep.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "A foolish man will not know, and a senseless man will not understand this.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "When the sinners spring up as the grass, and all the workers of iniquity have watched; it is that they may be utterly destroyed for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "But thou, O Lord, art most high for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "For, behold, thine enemies shall perish; and all the workers of iniquity shall be scattered.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "But my horn shall be exalted as the horn of a unicorn; and mine old age with rich mercy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "And mine eye has seen mine enemies, and mine ear shall hear the wicked that rise up against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "The righteous shall flourish as a palm-tree: he shall be increased as the cedar in Libanus. O Lord, as in Heb. ✡ 90:12 Mat. 4. 6. 91:8 Perhaps, 'come to light'.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "They that are planted in the house of the Lord shall flourish in the courts of our God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "Then shall they be increased in a fine old age; and they shall be prosperous; that they may declare",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.91.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "that the Lord my God is righteous, and there is no iniquity in him.",
      "paragraphStart": false
    }
  ]
}
