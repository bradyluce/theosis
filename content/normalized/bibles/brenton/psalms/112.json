{
  "chapter": {
    "id": "brenton:psalms.112",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.112.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Alleluia. - Praise the Lord, ye servants of his, praise, the name of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.112.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "Let the name of the Lord be blessed, from this present time and for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "From the rising of the sun to his setting, the name of the Lord is to be praised.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "The Lord is high above all the nations; his glory is above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "Who is as the Lord our God? who dwells in the high places,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "and yet looks upon the low things in heaven, and on the earth:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "who lifts up the poor from the earth, and raises up the needy from the dunghill;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "to set him with princes, even with the princes of his people:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.112.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "who settles the barren woman in a house, as a mother rejoicing over children.",
      "paragraphStart": false
    }
  ]
}
