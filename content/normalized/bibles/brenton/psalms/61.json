{
  "chapter": {
    "id": "brenton:psalms.61",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.61.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "For the end, a Psalm of David for Idithun.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.61.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "Shall not my soul be subjected to God? for of him is my salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "For he is my God and my Saviour; my helper, I shall not be moved very much.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "How long will ye assault a man? ye are all slaughtering as with a bowed wall and a broken hedge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "They only took counsel to set at nought mine honour: I ran in thirst: with their mouth they blessed, but with their heart they cursed. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "Nevertheless do thou, my soul, be subjected to God; for of him is my patient hope.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "For he is my God and my Saviour; my helper, I shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "In God is my salvation and my glory: he is the God of my help, and my hope is in God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 9,
      "referenceLabel": "Psalms 61:9",
      "text": "Hope in him, all ye congregation of the people; pour out your hearts before him, for God is our helper. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 10,
      "referenceLabel": "Psalms 61:10",
      "text": "But the sons of men are vain; the sons of men are false, so as to be deceitful in the balances; they are all alike formed out of vanity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 11,
      "referenceLabel": "Psalms 61:11",
      "text": "Trust not in unrighteousness, and lust not after robberies: if wealth should flow in, set not your heart upon it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 12,
      "referenceLabel": "Psalms 61:12",
      "text": "God has spoken once, and I have heard these two things, that power is of God;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.61.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 13,
      "referenceLabel": "Psalms 61:13",
      "text": "and mercy is thine, O Lord; for thou wilt recompense every one according to his works.",
      "paragraphStart": false
    }
  ]
}
