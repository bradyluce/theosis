{
  "chapter": {
    "id": "brenton:psalms.34",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.34.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "A Psalm of David. - Judge thou, O Lord, them that injure me, fight against them that fight against me.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.34.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "Take hold of shield and buckler, and arise for my help.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "Bring forth a sword, and stop the way against them that persecute me: say to my soul, I am thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "Let them that seek my soul be ashamed and confounded: let them that devise evils against me be turned back and put to shame.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "Let them be as dust before the wind, and an angel of the Lord afflicting them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "Let their way be dark and slippery, and an angel of the Lord persecuting them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "For without cause they have hid for me their destructive snare: without a cause they have reproached my soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "Let a snare which they know not come upon them; and the gin which they hid take them; and let them fall into the very same snare.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "But my soul shall exult in the Lord: it shall delight in his salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "All my bones shall say, O Lord, who is like to thee? delivering the poor out of the hand of them that are stronger than he, yea, the poor and needy one from them that spoil him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "Unjust witnesses arose, and asked me of things I knew not.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "They rewarded me evil for good, and bereavement to my soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "But I, when they troubled me, put on sackcloth, and humbled my soul with fasting: and my prayer shall return to my own bosom.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "I behaved agreeably towards them as if it had been our neighbour or brother: I humbled myself as one mourning and sad of countenance.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "Yet they rejoiced against me, and plagues were plentifully brought against me, and I knew it not: they were scattered, but repented not.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "They tempted me, they sneered at me most contemptuously, they gnashed their teeth upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "O Lord, when wilt thou look upon me? Deliver my soul from their mischief, mine only-begotten one from the lions.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "I will give thanks to thee even in a great congregation: in an abundant people I will praise thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "Let not them that are mine enemies without a cause rejoice against me; who hate me for nothing, and wink with their eyes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "For to me they spoke peaceably, but imagined deceits in their anger.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "And they opened wide their mouth upon me; they said Aha, aha, our eyes have seen it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "Thou hast seen it, O Lord: keep not silence: O Lord, withdraw not thyself from me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 23,
      "referenceLabel": "Psalms 34:23",
      "text": "Awake, O Lord, and attend to my judgement, even to my cause, my God and my Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 24,
      "referenceLabel": "Psalms 34:24",
      "text": "Judge me, O Lord, according to thy righteousness, O Lord my God; and let them not rejoice against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 25,
      "referenceLabel": "Psalms 34:25",
      "text": "Let them not say in their hearts, Aha, aha, it is pleasing to our soul: neither let them say, We have devoured him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 26,
      "referenceLabel": "Psalms 34:26",
      "text": "Let them be confounded and ashamed together that rejoice at my afflictions: let them be clothed with shame and confusion that speak great swelling words against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 27,
      "referenceLabel": "Psalms 34:27",
      "text": "Let them that rejoice in my righteousness exult and be glad: and let them say continually, The Lord be magnified, who desire the peace of his servant.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.34.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 28,
      "referenceLabel": "Psalms 34:28",
      "text": "And my tongue shall meditate on thy righteousness, and on thy praise all the day.",
      "paragraphStart": false
    }
  ]
}
