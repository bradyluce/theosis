{
  "chapter": {
    "id": "brenton:psalms.51",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.51.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "For the end, a Psalm of instruction by David,",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.51.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "when Doec the Idumean came and told Saul, and said to him, David is gone to the house of Abimelech.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "Why dost thou, O mighty man, boast of iniquity in thy mischief? All the day",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "thy tongue has devised unrighteousness; like a sharpened razor thou hast wrought deceit.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "Thou hast loved wickedness more than goodness; unrighteousness better than to speak righteousness. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "Thou hast loved all words of destruction, and a deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "Therefore may God destroy thee for ever, may he pluck thee up and utterly remove thee from thy dwelling, and thy root from the land of the living. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "And the righteous shall see, and fear, and shall laugh at him, and say,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "Behold the man who made not God his help; but trusted in the abundance of his wealth, and strengthened himself in his vanity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "But I am as a fruitful olive in the house of God: I have trusted in the mercy of God for ever, even for evermore.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.51.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "I will give thanks to thee for ever, for thou hast done it: and I will wait on thy name; for it is good before thy saints.",
      "paragraphStart": false
    }
  ]
}
