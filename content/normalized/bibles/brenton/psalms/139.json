{
  "chapter": {
    "id": "brenton:psalms.139",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.139.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "A Psalm of David. O Lord, I have cried to thee; hear me: attend to the voice of my supplication, when I cry to thee.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.139.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Let my prayer be set forth before thee as incense; the lifting up of my hands as an evening sacrifice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Set a watch, O Lord, on my mouth, and a strong door about my lips.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "Incline not my heart to evil things, to employ pretexts for sins, with men who work iniquity: and let me not unite with their choice ones.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "The righteous shall chasten me with mercy, and reprove me: but let not the oil of the sinner anoint my head: for yet shall my prayer also be in their pleasures.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "Their mighty ones have been swallowed up near the rock: they shall hear my words, for they are sweet.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "As a lump of earth is crushed upon the ground, our bones have been scattered by the mouth of the grave.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "For mine eyes are to thee, O Lord God: I have hoped in thee; take not away my life.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "Keep me from the snare which they have set for me, and from the stumblingblocks of them that work iniquity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "Sinners shall fall by their own net: I am alone until I shall escape.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "Coals of fire shall fall upon them on the earth; and thou shalt cast them down in afflictions: they shall not bear up under them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "A talkative man shall not prosper on the earth: evils shall hunt the unrighteous man to destruction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "I know that the Lord will maintain the cause of the poor, and the right of the needy ones.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.139.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "Surely the righteous shall give thanks to thy name: the upright shall dwell in thy presence.",
      "paragraphStart": false
    }
  ]
}
