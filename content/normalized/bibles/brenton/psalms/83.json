{
  "chapter": {
    "id": "brenton:psalms.83",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 83,
    "referenceLabel": "Psalms 83",
    "summary": "Source text for Psalms 83 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.83.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 1,
      "referenceLabel": "Psalms 83:1",
      "text": "For the end, a Psalm for the sons of Core, concerning the wine-presses.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.83.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 2,
      "referenceLabel": "Psalms 83:2",
      "text": "How amiable are thy tabernacles, O Lord of hosts!",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 3,
      "referenceLabel": "Psalms 83:3",
      "text": "My soul longs, and faints for the courts of the Lord: my heart and my flesh have exulted in the living God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 4,
      "referenceLabel": "Psalms 83:4",
      "text": "Yea, the sparrow has found himself a home, and the turtle-dove a nest for herself, where she may lay her young, even thine altars, O Lord of hosts, my King, and my God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 5,
      "referenceLabel": "Psalms 83:5",
      "text": "Blessed are they that dwell in thy house: they will praise thee evermore. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 6,
      "referenceLabel": "Psalms 83:6",
      "text": "Blessed is the man whose help is of thee, O Lord; in his heart he has purposed to go up",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 7,
      "referenceLabel": "Psalms 83:7",
      "text": "the valley of weeping, to the place which he has appointed, for there the law-giver will grant blessings.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 8,
      "referenceLabel": "Psalms 83:8",
      "text": "They shall go from strength to strength: the God of gods shall be seen in Sion.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 9,
      "referenceLabel": "Psalms 83:9",
      "text": "O Lord God of hosts, hear my prayer: hearken, O God of Jacob. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 10,
      "referenceLabel": "Psalms 83:10",
      "text": "Behold, O God our defender, and look upon the face of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 11,
      "referenceLabel": "Psalms 83:11",
      "text": "For one day in thy courts is better than thousands. I would rather be an abject in the house of God, than dwell in the tents of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 12,
      "referenceLabel": "Psalms 83:12",
      "text": "For the Lord loves mercy and truth: God will give grace and glory: the Lord will not withhold good things from them that walk in innocence.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.83.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 83,
      "verseNumber": 13,
      "referenceLabel": "Psalms 83:13",
      "text": "O Lord of hosts, blessed is the man that trusts in thee.",
      "paragraphStart": false
    }
  ]
}
