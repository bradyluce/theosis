{
  "chapter": {
    "id": "brenton:psalms.135",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.135.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Alleluia. - Give thanks to the Lord: for he is good: for his mercy endures for ever.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.135.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "Give thanks to the God of gods; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Give thanks to the Lord of lords: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "To him who along has wrought great wonders: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "To him who made the heavens by understanding; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "To him who established the earth on the waters; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "To him who alone made great lights; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "The sun to rule by day; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "The moon and the stars to rule the night; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "To him who smote Egypt with their first-born; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "And brought Israel out of the midst of them; for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "with a strong hand, and a high arm: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "To him who divided the Red Sea into parts: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "and brought Israel through the midst of it: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "and overthrew Pharao and his host in the Red Sea: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "To him who led his people through the wilderness: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "To him who smote great kings: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "and slew mighty kings; for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "Seon king of the Amorites: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "and Og king of Basan: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "and gave their land for an inheritance: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 22,
      "referenceLabel": "Psalms 135:22",
      "text": "even an inheritance to Israel his servant: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 23,
      "referenceLabel": "Psalms 135:23",
      "text": "For the Lord remembered us in our low estate; for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 24,
      "referenceLabel": "Psalms 135:24",
      "text": "and redeemed us from our enemies; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 25,
      "referenceLabel": "Psalms 135:25",
      "text": "Who gives food to all flesh; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.135.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 26,
      "referenceLabel": "Psalms 135:26",
      "text": "Give thanks to the God of heaven; for his mercy endures for ever.",
      "paragraphStart": false
    }
  ]
}
