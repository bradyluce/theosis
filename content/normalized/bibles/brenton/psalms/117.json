{
  "chapter": {
    "id": "brenton:psalms.117",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 117,
    "referenceLabel": "Psalms 117",
    "summary": "Source text for Psalms 117 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.117.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 1,
      "referenceLabel": "Psalms 117:1",
      "text": "Alleluia. Give thanks to the Lord; for he is good: for his mercy endures for ever.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.117.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 2,
      "referenceLabel": "Psalms 117:2",
      "text": "Let now the house of Israel say, that he is good: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 3,
      "referenceLabel": "Psalms 117:3",
      "text": "Let now the house of Aaron say, that he is good: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 4,
      "referenceLabel": "Psalms 117:4",
      "text": "Let now all that fear the Lord say, that he is good: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 5,
      "referenceLabel": "Psalms 117:5",
      "text": "I called on the Lord out of affliction: and he hearkened to me, so as to bring me into a wide place.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 6,
      "referenceLabel": "Psalms 117:6",
      "text": "✡ The Lord is my helper; and I will not fear what man shall do to me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 7,
      "referenceLabel": "Psalms 117:7",
      "text": "The Lord is my helper; and I shall see my desire upon mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 8,
      "referenceLabel": "Psalms 117:8",
      "text": "It is better to trust in the Lord than to trust in man.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 9,
      "referenceLabel": "Psalms 117:9",
      "text": "It is better to hope in the Lord, than to hope in princes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 10,
      "referenceLabel": "Psalms 117:10",
      "text": "All nations compassed me about: but in the name of the Lord I repulsed them. ✡ 115:1 2 Cor. 4. 13. ✡ 116:1 Rom. 15. 11. ✡ 117:6 Heb. 13. 6.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 11,
      "referenceLabel": "Psalms 117:11",
      "text": "They completely compassed me about: but in the name of the Lord I repulsed them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 12,
      "referenceLabel": "Psalms 117:12",
      "text": "They compassed me about as bees do a honeycomb, and they burst into flame as fire among thorns: but in the name of the Lord I repulsed them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 13,
      "referenceLabel": "Psalms 117:13",
      "text": "I was thrust, and sorely shaken, that I might fall: but the Lord helped me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 14,
      "referenceLabel": "Psalms 117:14",
      "text": "The Lord is my strength and my song, and is become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 15,
      "referenceLabel": "Psalms 117:15",
      "text": "The voice of exultation and salvation is in the tabernacles of the righteous: the right hand of the Lord has wrought mightily.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 16,
      "referenceLabel": "Psalms 117:16",
      "text": "The right hand of the Lord has exalted me: the right hand of the Lord has wrought powerfully.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 17,
      "referenceLabel": "Psalms 117:17",
      "text": "I shall not die, but live, and recount the works of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 18,
      "referenceLabel": "Psalms 117:18",
      "text": "The Lord has chastened me sore: but he has not given me up to death.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 19,
      "referenceLabel": "Psalms 117:19",
      "text": "Open to me the gates of righteousness: I will go into them, and give praise to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 20,
      "referenceLabel": "Psalms 117:20",
      "text": "This is the gate of the Lord: the righteous shall enter by it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 21,
      "referenceLabel": "Psalms 117:21",
      "text": "I will give thanks to thee; because thou hast heard me, and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 22,
      "referenceLabel": "Psalms 117:22",
      "text": "✡ The stone which the builders rejected, the same is become the head of the corner.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 23,
      "referenceLabel": "Psalms 117:23",
      "text": "This has been done of the Lord; and it is wonderful in our eyes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 24,
      "referenceLabel": "Psalms 117:24",
      "text": "This is the day which the Lord has made: let us exult and rejoice in it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 25,
      "referenceLabel": "Psalms 117:25",
      "text": "O Lord, save now: O Lord, send now prosperity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 26,
      "referenceLabel": "Psalms 117:26",
      "text": "✡ Blessed is he that comes in the name of the Lord: we have blessed you out of the house of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 27,
      "referenceLabel": "Psalms 117:27",
      "text": "God is the Lord, and he has shined upon us: celebrate the feast with thick branches, binding the victims even to the horns of the altar.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 28,
      "referenceLabel": "Psalms 117:28",
      "text": "Thou art my God, and I will give thee thanks: thou art my God, and I will exalt thee. I will give thanks to thee, for thou hast heard me, and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.117.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 117,
      "verseNumber": 29,
      "referenceLabel": "Psalms 117:29",
      "text": "Give thanks to the Lord; for he is good: for his mercy endures for ever.",
      "paragraphStart": false
    }
  ]
}
