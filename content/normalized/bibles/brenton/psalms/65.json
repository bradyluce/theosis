{
  "chapter": {
    "id": "brenton:psalms.65",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 65,
    "referenceLabel": "Psalms 65",
    "summary": "Source text for Psalms 65 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.65.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 1,
      "referenceLabel": "Psalms 65:1",
      "text": "For the end, a Song of a Psalm of resurrection. Shout unto God, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.65.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 2,
      "referenceLabel": "Psalms 65:2",
      "text": "O sing praises to his name; give glory to his praise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 3,
      "referenceLabel": "Psalms 65:3",
      "text": "Say unto God, How awful are thy works! through the greatness of thy power thine enemies shall lie to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 4,
      "referenceLabel": "Psalms 65:4",
      "text": "Let all the earth worship thee, and sing to thee; let them sing to thy name. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 5,
      "referenceLabel": "Psalms 65:5",
      "text": "Come and behold the works of God; he is terrible in his counsels beyond the children of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 6,
      "referenceLabel": "Psalms 65:6",
      "text": "Who turns the sea into dry land; they shall go through the river on foot; there shall we rejoice in him,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 7,
      "referenceLabel": "Psalms 65:7",
      "text": "who by his power is Lord over the age, his eyes look upon the nations; let not them that provoke him be exalted in themselves. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 8,
      "referenceLabel": "Psalms 65:8",
      "text": "Bless our God, ye Gentiles, and make the voice of his praise to be heard;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 9,
      "referenceLabel": "Psalms 65:9",
      "text": "who quickens my soul in life, and does not suffer my feet to be moved.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 10,
      "referenceLabel": "Psalms 65:10",
      "text": "For thou, O God, hast proved us; thou hast tried us with fire as silver is tried.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 11,
      "referenceLabel": "Psalms 65:11",
      "text": "Thou broughtest us into the snare; thou laidest afflictions on our back.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 12,
      "referenceLabel": "Psalms 65:12",
      "text": "Thou didst mount men upon our heads; we went through fire and water; but thou broughtest us out into a place of refreshment.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 13,
      "referenceLabel": "Psalms 65:13",
      "text": "I will go into thine house with whole-burnt-offerings; I will pay thee my vows,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 14,
      "referenceLabel": "Psalms 65:14",
      "text": "which my lips framed, and my mouth uttered in my affliction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 15,
      "referenceLabel": "Psalms 65:15",
      "text": "I will offer to thee whole-burnt-sacrifices full of marrow, with incense and rams; I will sacrifice to thee oxen with goats. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 16,
      "referenceLabel": "Psalms 65:16",
      "text": "Come, hear, and I will tell, all ye that fear God, how great things he has done for my soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 17,
      "referenceLabel": "Psalms 65:17",
      "text": "I cried to him with my mouth, and exalted him with my tongue.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 18,
      "referenceLabel": "Psalms 65:18",
      "text": "If I have regarded iniquity in my heart, let not the Lord hearken to me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 19,
      "referenceLabel": "Psalms 65:19",
      "text": "Therefore God has hearkened to me; he has attended to the voice of my prayer.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.65.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 65,
      "verseNumber": 20,
      "referenceLabel": "Psalms 65:20",
      "text": "Blessed be God, who has not turned away my prayer, nor his mercy from me.",
      "paragraphStart": false
    }
  ]
}
