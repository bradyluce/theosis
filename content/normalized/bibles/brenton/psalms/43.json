{
  "chapter": {
    "id": "brenton:psalms.43",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 43,
    "referenceLabel": "Psalms 43",
    "summary": "Source text for Psalms 43 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.43.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 1,
      "referenceLabel": "Psalms 43:1",
      "text": "For the end, ✡ 43:23 Rom. 8. 36.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.43.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 2,
      "referenceLabel": "Psalms 43:2",
      "text": "My heart has uttered a good matter: I declare my works to the king: my tongue is the pen of a quick writer.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 3,
      "referenceLabel": "Psalms 43:3",
      "text": "Thou art more beautiful than the sons of men: grace has been shed forth on thy lips: therefore God has blessed thee for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 4,
      "referenceLabel": "Psalms 43:4",
      "text": "Gird thy sword upon thy thigh, O Mighty One, in thy comeliness, and in thy beauty;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 5,
      "referenceLabel": "Psalms 43:5",
      "text": "and bend thy bow, and prosper, and reign, because of truth and meekness and righteousness; and thy right hand shall guide thee wonderfully.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 6,
      "referenceLabel": "Psalms 43:6",
      "text": "Thy weapons are sharpened, Mighty One, (the nations shall fall under thee) they are in the heart of the king's enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 7,
      "referenceLabel": "Psalms 43:7",
      "text": "✡ Thy throne, O God, is for ever and ever: the sceptre of thy kingdom is a sceptre of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 8,
      "referenceLabel": "Psalms 43:8",
      "text": "Thou hast loved righteousness, and hated iniquity: therefore God, thy God, has anointed thee with the oil of gladness beyond thy fellows.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 9,
      "referenceLabel": "Psalms 43:9",
      "text": "Myrrh, and stacte, and cassia are exhaled from thy garments, and out of the ivory palaces,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 10,
      "referenceLabel": "Psalms 43:10",
      "text": "with which kings' daughters have gladdened thee for thine honour: the queen stood by on thy right hand, clothed in vesture wrought with gold, and arrayed in divers colours.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 11,
      "referenceLabel": "Psalms 43:11",
      "text": "Hear, O daughter, and see, and incline thine ear; forget also thy people, and thy father's house.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 12,
      "referenceLabel": "Psalms 43:12",
      "text": "Because the king has desired thy beauty; for he is thy Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 13,
      "referenceLabel": "Psalms 43:13",
      "text": "And the daughter of Tyre shall adore him with gifts; the rich of the people of the land shall supplicate thy favour.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 14,
      "referenceLabel": "Psalms 43:14",
      "text": "All her glory is that of the daughter of the king of Esebon, robed as she is in golden fringed garments,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 15,
      "referenceLabel": "Psalms 43:15",
      "text": "in embroidered clothing: virgins shall be brought to the king after her: her fellows shall be brought to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 16,
      "referenceLabel": "Psalms 43:16",
      "text": "They shall be brought with gladness and exultation: they shall be led into the king's temple.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 17,
      "referenceLabel": "Psalms 43:17",
      "text": "Instead of thy fathers children are born to thee: thou shalt make them princes over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 18,
      "referenceLabel": "Psalms 43:18",
      "text": "They shall make mention of thy name from generation to generation: therefore shall the nations give thanks to thee for ever, even for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 19,
      "referenceLabel": "Psalms 43:19",
      "text": "And our heart has not gone back; but thou hast turned aside our paths from thy way.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 20,
      "referenceLabel": "Psalms 43:20",
      "text": "For thou hast laid us low in a place of affliction, and the shadow of death has covered us.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 21,
      "referenceLabel": "Psalms 43:21",
      "text": "If we have forgotten the name of our God, and if we have spread out our hands to a strange god; shall not God search these things out?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 22,
      "referenceLabel": "Psalms 43:22",
      "text": "for he knows the secrets of the heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 23,
      "referenceLabel": "Psalms 43:23",
      "text": "✡ For, for thy sake we are killed all the day long; we are counted as sheep for slaughter.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 24,
      "referenceLabel": "Psalms 43:24",
      "text": "Awake, wherefore sleepest thou, O Lord? arise, and do not cast us off for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 25,
      "referenceLabel": "Psalms 43:25",
      "text": "Wherefore turnest thou thy face away, and forgettest our poverty and our affliction?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 26,
      "referenceLabel": "Psalms 43:26",
      "text": "For our soul has been brought down to the dust; our belly has cleaved to the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.43.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 43,
      "verseNumber": 27,
      "referenceLabel": "Psalms 43:27",
      "text": "Arise, O Lord, help us, and redeem us for thy name's sake. for alternate strains by the sons of Core; for instruction, a Song concerning the beloved.",
      "paragraphStart": false
    }
  ]
}
