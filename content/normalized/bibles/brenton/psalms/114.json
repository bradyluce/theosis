{
  "chapter": {
    "id": "brenton:psalms.114",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.114.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "Alleluia. I am well pleased, because the Lord will hearken to the voice of my supplication.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.114.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Because he has inclined his ear to me, therefore will I call upon him while I live.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "The pangs of death compassed me; the dangers of hell found me: I found affliction and sorrow.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "Then I called on the name of the Lord: O Lord, deliver my soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "The Lord is merciful and righteous; yea, our God has pity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "The Lord preserves the simple: I was brought low, and he delivered me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Return to thy rest, O my soul; for the Lord has dealt bountifully with thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "For he has delivered my soul from death, mine eyes from tears, and my feet from falling.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.114.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 9,
      "referenceLabel": "Psalms 114:9",
      "text": "I shall be well-pleasing before the Lord in the land of the living.",
      "paragraphStart": false
    }
  ]
}
