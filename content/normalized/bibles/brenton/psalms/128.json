{
  "chapter": {
    "id": "brenton:psalms.128",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.128.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "A Song of Degrees. - Many a time have they warred against me from my youth, let Israel now say:",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.128.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "Many a time have they warred against me from my youth: and yet they prevailed not against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.128.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "The sinners wrought upon my back: they prolonged their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.128.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "The righteous Lord has cut asunder the necks of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.128.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "Let all that hate Sion be put to shame and turned back.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.128.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "Let them be as the grass of the house-tops, which withers before it is plucked up.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.128.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 7,
      "referenceLabel": "Psalms 128:7",
      "text": "Wherewith the reaper fills not his hand, nor he that makes up the sheaves, his bosom.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.128.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 8,
      "referenceLabel": "Psalms 128:8",
      "text": "Neither do they that go by say, The blessing of the Lord be upon you: we have blessed you in the name of the Lord.",
      "paragraphStart": false
    }
  ]
}
