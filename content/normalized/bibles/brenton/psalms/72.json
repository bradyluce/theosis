{
  "chapter": {
    "id": "brenton:psalms.72",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.72.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "A Psalm for Asaph. - How good is God to Israel, to the upright in heart!",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.72.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "But my feet were almost overthrown; my goings very nearly slipped.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "For I was jealous of the transgressors, beholding the tranquility of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "For there is no sign of reluctance in their death: and they have firmness under their affliction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "They are not in the troubles of other men; and they shall not be scourged with other men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "Therefore pride has possessed them; they have clothed themselves with their injustice and ungodliness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "Their injustice shall go forth as out of fatness: they have fulfilled their intention.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "They have taken counsel and spoken in wickedness: they have uttered unrighteousness loftily.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "They have set their mouth against heaven, and their tongue has gone through upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "Therefore shall my people return hither: and full days shall be found with them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "And they said, How does God know? and is there knowledge in the Most High?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "Behold, these are the sinners, and they that prosper always: they have possessed wealth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "And I said, Verily in vain have I justified my heart, and washed my hands in innocency.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "For I was plagued all the day, and my reproof was every morning.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "If I said, I will speak thus; behold, I should have broken covenant with the generation of thy children.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "And I undertook to understand this, but it is too hard for me,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "until I go into the sanctuary of God; and so understand the latter end.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Surely thou hast appointed judgements to them because of their crafty dealings: thou hast cast them down when they were lifted up.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "How have they become desolate! suddenly they have failed: they have perished because of their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "As the dream of one awakening, O Lord, in thy city thou wilt despise their image.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 21,
      "referenceLabel": "Psalms 72:21",
      "text": "For my heart has rejoiced, and my reins have been gladdened.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 22,
      "referenceLabel": "Psalms 72:22",
      "text": "But I was vile and knew not: I became brutish before thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 23,
      "referenceLabel": "Psalms 72:23",
      "text": "Yet I am continually with thee: thou hast holden my right hand.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 24,
      "referenceLabel": "Psalms 72:24",
      "text": "Thou hast guided me by thy counsel, and thou hast taken me to thyself with glory.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 25,
      "referenceLabel": "Psalms 72:25",
      "text": "For what have I in heaven but thee? and what have I desired upon the earth beside thee?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 26,
      "referenceLabel": "Psalms 72:26",
      "text": "My heart and my flesh have failed: but God is the strength of my heart, and God is my portion for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 27,
      "referenceLabel": "Psalms 72:27",
      "text": "For, behold, they that remove themselves far from thee shall perish: thou hast destroyed every one that goes a whoring from thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.72.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 28,
      "referenceLabel": "Psalms 72:28",
      "text": "But it is good for me to cleave close to God, to put my trust in the Lord; that I may proclaim all thy praises in the gates of the daughter of Sion.",
      "paragraphStart": false
    }
  ]
}
