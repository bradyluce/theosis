{
  "chapter": {
    "id": "brenton:psalms.142",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 142,
    "referenceLabel": "Psalms 142",
    "summary": "Source text for Psalms 142 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.142.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 1,
      "referenceLabel": "Psalms 142:1",
      "text": "David's Psalm of praise. I will exalt thee, my God, my king; and I will bless thy name for ever and ever.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.142.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 2,
      "referenceLabel": "Psalms 142:2",
      "text": "Every day will I bless thee, and I will praise thy name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 3,
      "referenceLabel": "Psalms 142:3",
      "text": "The Lord is great, and greatly to be praised; and there is no end of his greatness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 4,
      "referenceLabel": "Psalms 142:4",
      "text": "Generation after generation shall praise thy works, and tell of thy power.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 5,
      "referenceLabel": "Psalms 142:5",
      "text": "And they shall speak of the glorious majesty of thy holiness, and recount thy wonders.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 6,
      "referenceLabel": "Psalms 142:6",
      "text": "And they shall speak of the power of thy terrible acts; and recount thy greatness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 7,
      "referenceLabel": "Psalms 142:7",
      "text": "They shall utter the memory of the abundance of thy goodness, and shall exult in thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 8,
      "referenceLabel": "Psalms 142:8",
      "text": "The Lord is compassionate, and merciful; long-suffering, and abundant in mercy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 9,
      "referenceLabel": "Psalms 142:9",
      "text": "The Lord is good to those that wait on him; and his compassions are over all his works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 10,
      "referenceLabel": "Psalms 142:10",
      "text": "Let all thy works, O Lord, give thanks to thee; and let thy saints bless thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 11,
      "referenceLabel": "Psalms 142:11",
      "text": "They shall speak of the glory of thy kingdom, and talk of thy dominion;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 12,
      "referenceLabel": "Psalms 142:12",
      "text": "to make known to the sons of men thy power, and the glorious majesty of thy kingdom.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 13,
      "referenceLabel": "Psalms 142:13",
      "text": "Thy kingdom is an everlasting kingdom, and thy dominion endures through all generations. 13a The Lord is faithful in his words, and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 14,
      "referenceLabel": "Psalms 142:14",
      "text": "The Lord supports all that are falling, and sets up all that are broken down.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 15,
      "referenceLabel": "Psalms 142:15",
      "text": "The eyes of all wait upon thee; and thou givest them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 16,
      "referenceLabel": "Psalms 142:16",
      "text": "Thou openest thine hands, and fillest every living thing with pleasure.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 17,
      "referenceLabel": "Psalms 142:17",
      "text": "The Lord is righteous in all his ways, and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 18,
      "referenceLabel": "Psalms 142:18",
      "text": "The Lord is near to all that call upon him, to all that call upon him in truth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 19,
      "referenceLabel": "Psalms 142:19",
      "text": "He will perform the desire of them that fear him: and he will hear their supplication, and save them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 20,
      "referenceLabel": "Psalms 142:20",
      "text": "The Lord preserves all that love him: but all sinners he will utterly destroy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.142.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 21,
      "referenceLabel": "Psalms 142:21",
      "text": "My mouth shall speak the praise of the Lord: and let all flesh bless his holy name for ever and ever.",
      "paragraphStart": false
    }
  ]
}
