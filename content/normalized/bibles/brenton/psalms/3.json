{
  "chapter": {
    "id": "brenton:psalms.3",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.3.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "A Psalm of David, when he fled from the presence of his son Abessalom.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.3.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "O Lord, why are they that afflict me multiplied? many rise up against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "Many say concerning my soul, There is no deliverance for him in his God. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "But thou, O Lord, art my helper: my glory, and the one that lifts up my head.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "I cried to the Lord with my voice, and he heard me out of his holy mountain. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "I lay down and slept; I awaked; for the Lord will help me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "I will not be afraid of ten thousands of people, who beset me round about.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Arise, Lord; deliver me, my God: for thou hast smitten all who were without cause mine enemies; thou hast broken the teeth of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.3.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Psalms 3:9",
      "text": "Deliverance is the Lord's, and thy blessing is upon thy people.",
      "paragraphStart": false
    }
  ]
}
