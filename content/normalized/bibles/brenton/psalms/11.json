{
  "chapter": {
    "id": "brenton:psalms.11",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 11,
    "referenceLabel": "Psalms 11",
    "summary": "Source text for Psalms 11 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.11.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "For the end, a Psalm of David, upon the eighth.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.11.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "Save me, O Lord; for the godly man has failed; for truth is diminished from among the children of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "Every one has spoken vanity to his neighbour: their lips are deceitful, they have spoken with a double heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "Let the Lord destroy all the deceitful lips, and the tongue that speaks great words:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "who have said, We will magnify our tongue; our lips are our own: who is Lord of us?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "Because of the misery of the poor, and because of the sighing of the needy, now will I arise, saith the Lord, I will set them in safety; I will speak to them thereof openly.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "The oracles of the Lord are pure oracles; as silver tried in the fire, proved in a furnace of earth, purified seven times.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Psalms 11:8",
      "text": "Thou, O Lord, shalt keep us, and shalt preserve us, from this generation, and for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.11.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Psalms 11:9",
      "text": "The ungodly walk around: according to thy greatness thou hast greatly exalted the sons of men.",
      "paragraphStart": false
    }
  ]
}
