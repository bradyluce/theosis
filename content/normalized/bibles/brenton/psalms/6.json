{
  "chapter": {
    "id": "brenton:psalms.6",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.6.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "For the end, a Psalm of David among the Hymns for the eighth.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.6.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "O Lord, rebuke me not in thy wrath, neither chasten me in thine anger.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "Pity me, O Lord; for I am weak: heal me, O Lord; for my bones are vexed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "My soul also is grievously vexed: but thou, O Lord, how long?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "Return, O Lord, deliver my soul: save me for thy mercy's sake.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "For in death no man remembers thee: and who will give thee thanks in Hades?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "I am wearied with my groaning; I shall wash my bed every night; I shall water my couch with my tears.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "Mine eye is troubled because of my wrath; I am worn out because of all my enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "Depart from me, all ye that work iniquity; for the Lord has heard the voice of my weeping.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "The Lord has hearkened to my petition; the Lord has accepted my prayer.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.6.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Psalms 6:11",
      "text": "Let all mine enemies be put to shame and sore troubled: let them be turned back and grievously put to shame speedily.",
      "paragraphStart": false
    }
  ]
}
