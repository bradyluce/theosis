{
  "chapter": {
    "id": "brenton:psalms.69",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.69.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "For the end, by David for a remembrance, that the Lord may save me.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.69.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "Draw nigh, O God, to my help.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.69.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "Let them be ashamed and confounded that seek my soul: let them be turned backward and put to shame, that wish me evil.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.69.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "Let them that say to me, Aha, aha, be turned back and put to shame immediately.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.69.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "Let all that seek thee exult and be glad in thee: and let those that love thy salvation say continually, Let God be magnified.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.69.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "But I am poor and needy; O God, help me: thou art my helper and deliverer, O Lord, delay not.",
      "paragraphStart": false
    }
  ]
}
