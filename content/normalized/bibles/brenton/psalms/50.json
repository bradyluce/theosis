{
  "chapter": {
    "id": "brenton:psalms.50",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.50.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "For the end, a Psalm of David,",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.50.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "when Nathan the prophet came to him, when he had gone in to Bersabee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Have mercy upon me, O God, according to thy great mercy; and according to the multitude of thy compassions blot out my transgression.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "Wash me thoroughly from mine iniquity, and cleanse me from my sin.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "For I am conscious of mine iniquity; and my sin is continually before me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "Against thee only have I sinned, and done evil before thee: that thou mightest be justified in thy sayings, and mightest overcome when thou art judged.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "For, behold, I was conceived in iniquities, and in sins did my mother conceive me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "For, behold, thou lovest truth: thou hast manifested to me the secret and hidden things of thy wisdom.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "Thou shalt sprinkle me with hyssop, and I shall be purified: thou shalt wash me, and I shall be made whiter than snow.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "Thou shalt cause me to hear gladness and joy: the afflicted bones shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "Turn away thy face from my sins, and blot out all mine iniquities.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "Create in me a clean heart, O God; and renew a right spirit in my inward parts.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Cast me not away from thy presence; and remove not thy Holy Spirit from me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Restore to me the joy of thy salvation: establish me with thy directing Spirit.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "Then will I teach transgressors thy ways; and ungodly men shall turn to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "Deliver me from blood-guiltiness, O God, the God of my salvation: and my tongue shall joyfully declare thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "O Lord, thou shalt open my lips; and my mouth shall declare thy praise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "For if thou desiredst sacrifice, I would have given it: thou wilt not take pleasure in whole-burnt-offerings.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "Sacrifice to God is a broken spirit: a broken and humbled heart God will not despise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "Do good, O Lord, to Sion in thy good pleasure; and let the walls of Jerusalem be built.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.50.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "Then shalt thou be pleased with a sacrifice of righteousness, offering, and wholeburnt-sacrifices: then shall they offer calves upon thine altar.",
      "paragraphStart": false
    }
  ]
}
