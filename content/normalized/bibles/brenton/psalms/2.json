{
  "chapter": {
    "id": "brenton:psalms.2",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.2.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "✡ Wherefore did the heathen rage, and the nations imagine vain things?",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.2.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "The kings of the earth stood up, and the rulers gathered themselves together, against the Lord, and against his Christ;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "saying, Let us break through their bonds, and cast away their yoke from us.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "He that dwells in the heavens shall laugh them to scorn, and the Lord shall mock them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "Then shall he speak to them in his anger, and trouble them in his fury.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "But I have been made king by him on Sion his holy mountain,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "declaring the ordinance of the Lord: the Lord said to me, ✡ Thou art my Son, to-day have I begotten thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "Ask of me, and I will give thee the heathen for thine inheritance, and the ends of the earth for thy possession.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "Thou shalt rule them with a rod of iron; thou shalt dash them in pieces as a potter's vessel.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "Now therefore understand, ye kings: be instructed, all ye that judge the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "Serve the Lord with fear, and rejoice in him with trembling.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.2.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "Accept correction, lest at any time the Lord be angry, and ye should perish from the righteous way: whensoever his wrath shall be suddenly kindled, blessed are all they that trust in him.",
      "paragraphStart": false
    }
  ]
}
