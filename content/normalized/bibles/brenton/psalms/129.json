{
  "chapter": {
    "id": "brenton:psalms.129",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.129.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "A Song of Degrees. - Out of the depths have I cried to thee, O Lord.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.129.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "O Lord, hearken to my voice; let thine ears be attentive to the voice of my supplication.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.129.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "If thou, O Lord, shouldest mark iniquities, O Lord, who shall stand?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.129.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "For with thee is forgiveness: for thy name’s sake",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.129.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "have I waited for thee, O Lord, my soul has waited for thy word.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.129.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "My soul has hoped in the Lord; from the morning watch till night.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.129.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "Let Israel hope in the Lord: for with the Lord is mercy, and with him is plenteous redemption.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.129.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "And he shall redeem Israel from all his iniquities.",
      "paragraphStart": false
    }
  ]
}
