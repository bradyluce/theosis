{
  "chapter": {
    "id": "brenton:psalms.90",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.90.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "Praise of a Song, by David. - He that dwells in the help of the Highest, shall sojourn under the shelter of the God of heaven.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.90.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "He shall say to the Lord, Thou art my helper and my refuge: my God; I will hope in him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "For he shall deliver thee from the snare of the hunters, from every troublesome matter.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "He shall overshadow thee with his shoulders, and thou shalt trust under his wings: his truth shall cover thee with a shield.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Thou shalt not be afraid of terror by night; nor of the arrow flying by day;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "nor of the evil thing that walks in darkness; nor of calamity, and the evil spirit at noon-day.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "A thousand shall fall at thy side, and ten thousand at thy right hand; but it shall not come nigh thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Only with thine eyes shalt thou observe and see the reward of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "For thou, O Lord, art my hope: thou, my soul, hast made the Most High thy refuge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "No evils shall come upon thee, and no scourge shall draw night to thy dwelling.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "For he shall give his angels charge concerning thee, to keep thee in all thy ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "They shall bear thee up on their hands, lest at any time thou dash thy foot against a stone.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Thou shalt tread on the asp and basilisk: and thou shalt trample on the lion and dragon.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "For he has hoped in me, and I will deliver him: I will protect him, because he has known my name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "He shall call upon me, and I will hearken to him: I am with him in affliction; and I will deliver him, and glorify him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.90.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "I will satisfy him with length of days, and shew him my salvation.",
      "paragraphStart": false
    }
  ]
}
