{
  "chapter": {
    "id": "brenton:psalms.68",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 68,
    "referenceLabel": "Psalms 68",
    "summary": "Source text for Psalms 68 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.68.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 1,
      "referenceLabel": "Psalms 68:1",
      "text": "For the end, a Psalm of David, for alternate strains.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.68.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 2,
      "referenceLabel": "Psalms 68:2",
      "text": "Save me, O God; for the waters have come in to my soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 3,
      "referenceLabel": "Psalms 68:3",
      "text": "I am stuck fast in deep mire, and there is no standing: I am come in to the depths of the sea, and a storm has overwhelmed me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 4,
      "referenceLabel": "Psalms 68:4",
      "text": "I am weary of crying, my throat has become hoarse; mine eyes have failed by my waiting on my God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 5,
      "referenceLabel": "Psalms 68:5",
      "text": "They that hate me without a cause are more than the hairs of my head: my enemies that persecute me unrighteously are strengthened: then I restored that which I took not away.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 6,
      "referenceLabel": "Psalms 68:6",
      "text": "O God, thou knowest my foolishness; and my transgressions are not hidden from thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 7,
      "referenceLabel": "Psalms 68:7",
      "text": "Let not them that wait on thee, O Lord of hosts, be ashamed on my account: let not them that seek thee, be ashamed on my account, O God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 8,
      "referenceLabel": "Psalms 68:8",
      "text": "For I have suffered reproach for thy sake; shame has covered my face.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 9,
      "referenceLabel": "Psalms 68:9",
      "text": "I became strange to my brethren, and a stranger to my mother's children.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 10,
      "referenceLabel": "Psalms 68:10",
      "text": "✡ For the zeal of thine house has eaten me up; and the reproaches of them that reproached thee are fallen upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 11,
      "referenceLabel": "Psalms 68:11",
      "text": "And I bowed down my soul with fasting, and that was made my reproach.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 12,
      "referenceLabel": "Psalms 68:12",
      "text": "And I put on sackcloth for my covering; and I became a proverb to them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 13,
      "referenceLabel": "Psalms 68:13",
      "text": "They that sit in the gate talked against me, and they that drank wine sang against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 14,
      "referenceLabel": "Psalms 68:14",
      "text": "But I will cry to thee, O Lord, in my prayer; O God, it is a propitious time: in the multitude of thy mercy hear me, in the truth of thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 15,
      "referenceLabel": "Psalms 68:15",
      "text": "Save me from the mire, that I stick not in it: let me be delivered from them that hate me, and from the deep waters.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 16,
      "referenceLabel": "Psalms 68:16",
      "text": "Let not the waterflood drown me, nor let the deep swallow me up; neither let the well shut its mouth upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 17,
      "referenceLabel": "Psalms 68:17",
      "text": "Hear me, O Lord; for thy mercy is good: according to the multitude of thy compassions look upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 18,
      "referenceLabel": "Psalms 68:18",
      "text": "And turn not away thy face from thy servant; for I am afflicted: hear me speedily.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 19,
      "referenceLabel": "Psalms 68:19",
      "text": "Draw nigh to my soul and redeem it: deliver me because of mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 20,
      "referenceLabel": "Psalms 68:20",
      "text": "For thou knowest my reproach, and my shame, and my confusion; all that afflict me are before thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 21,
      "referenceLabel": "Psalms 68:21",
      "text": "My soul has waited for reproach and misery; and I waited for one to grieve with me, but there was none; and for one to comfort me, but I found none.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 22,
      "referenceLabel": "Psalms 68:22",
      "text": "They gave me also gall for my food, and made me drink vinegar for my thirst.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 23,
      "referenceLabel": "Psalms 68:23",
      "text": "✡ Let their table before them be for a snare, and for a recompence, and for a stumbling-block.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 24,
      "referenceLabel": "Psalms 68:24",
      "text": "Let their eyes be darkened that they should not see; and bow down their back continually.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 25,
      "referenceLabel": "Psalms 68:25",
      "text": "Pour out thy wrath upon them, and let the fury of thine anger take hold on them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 26,
      "referenceLabel": "Psalms 68:26",
      "text": "✡ Let their habitation be made desolate; and let there be no inhabitant in their tents:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 27,
      "referenceLabel": "Psalms 68:27",
      "text": "because they persecuted him whom thou hast smitten; and they have added to the grief of my wounds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 28,
      "referenceLabel": "Psalms 68:28",
      "text": "Add iniquity to their iniquity; and let them not come into thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 29,
      "referenceLabel": "Psalms 68:29",
      "text": "Let them be blotted out of the book of the living, and let them not be written with the righteous.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.30",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 30,
      "referenceLabel": "Psalms 68:30",
      "text": "I am poor and sorrowful; but the salvation of thy countenance has helped me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.31",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 31,
      "referenceLabel": "Psalms 68:31",
      "text": "I will praise the name of my God with a song, I will magnify him with praise;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.32",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 32,
      "referenceLabel": "Psalms 68:32",
      "text": "and this shall please God more than a young calf having horns and hoofs.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.33",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 33,
      "referenceLabel": "Psalms 68:33",
      "text": "Let the poor see and rejoice; seek the Lord diligently, and ye shall live.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.34",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 34,
      "referenceLabel": "Psalms 68:34",
      "text": "For the Lord hears the poor, and does not set at nought his fettered ones.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.35",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 35,
      "referenceLabel": "Psalms 68:35",
      "text": "Let the heavens and the earth praise him, the sea, and all things moving in them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.36",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 36,
      "referenceLabel": "Psalms 68:36",
      "text": "For God will save Sion, and the cities of Judea shall be built; and men shall dwell there, and inherit it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.68.37",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 68,
      "verseNumber": 37,
      "referenceLabel": "Psalms 68:37",
      "text": "And the seed of his servants shall possess it, and they that love his name shall dwell therein. ✡ 68:10 John 2. 17; Rom. 15. 3. ✡ 68:23 Rom. 11. 9,10. ✡ 68:26 Acts 1. 20.",
      "paragraphStart": false
    }
  ]
}
