{
  "chapter": {
    "id": "brenton:psalms.9",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.9.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "For the end, a Psalm of David. In the Lord I have put my trust: how will ye say to my soul, Flee to the mountains as a sparrow?",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.9.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "For behold the sinners have bent their bow, they have prepared their arrows for the quiver, to shoot privily at the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "For they have pulled down what thou didst frame, but what has the righteous done?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "The Lord is in his holy temple, as for the Lord, his throne is in heaven: his eyes look upon the poor, his eyelids try the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "The Lord tries the righteous and the ungodly: and he that loves unrighteousness hates his own soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "He shall rain upon sinners snares, fire, and brimstone, and a stormy blast shall be the portion of their cup.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "For the Lord is righteous, and loves righteousness; his face beholds uprightness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "but the Lord endures for ever: he has prepared his throne for judgment.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "And he will judge the world in righteousness, he will judge the nations in uprightness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "The Lord also is become a refuge for the poor, a seasonable help, in affliction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "And let them that know thy name hope in thee: for thou, O Lord, hast not failed them that diligently seek thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "Sing praises to the Lord, who dwells in Sion: declare his dealings among the nations.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "For he remembered them, in making inquisition for blood: he has not forgotten the supplication of the poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "Have mercy upon me, O Lord; look upon my affliction which I suffer of mine enemies, thou that liftest me up from the gates of death:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "that I may declare all thy praises in the gates of the daughter of Sion: I will exult in thy salvation. ✡ 8:3 Mat. 21. 16. ✡ 8:5 Heb. 2. 6-9.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "The heathen are caught in the destruction which they planned: in the very snare which they hid is their foot taken.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "The Lord is known as executing judgments: the sinner is taken in the works of his hands. A song of Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "Let sinners be driven away into Hades, even all the nations that forget God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "For the poor shall not be forgotten for ever: the patience of the needy ones shall not perish for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Arise, O Lord, let not man prevail: let the heathen be judged before thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Psalms 9:21",
      "text": "Appoint, O Lord, a lawgiver over them: let the heathen know that they are men. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Psalms 9:22",
      "text": "Why standest thou afar off, O Lord? why dost thou overlook us in times of need, in affliction?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Psalms 9:23",
      "text": "While the ungodly one acts proudly, the poor is hotly pursued: the wicked are taken in the crafty counsels which they imagine.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Psalms 9:24",
      "text": "Because the sinner praises himself for the desires of his heart; and the unjust one blesses himself.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Psalms 9:25",
      "text": "The sinner has provoked the Lord: according to the abundance of his pride he will not seek after him: God is not before him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Psalms 9:26",
      "text": "His ways are profane at all times; thy judgments are removed from before him: he will gain the mastery over all his enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Psalms 9:27",
      "text": "For he has said in his heart, I shall not be moved, continuing without evil from generation to generation. ✡",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Psalms 9:28",
      "text": "Whose mouth is full of cursing, and bitterness, and fraud: under his tongue are trouble and pain.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Psalms 9:29",
      "text": "He lies in wait with rich men in secret places, in order to slay the innocent: his eyes are set against the poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.30",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Psalms 9:30",
      "text": "He lies in wait in secret as a lion in his den: he lies in wait to ravish the poor, to ravish the poor when he draws him after him: he will bring him down in his snare.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.31",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Psalms 9:31",
      "text": "He will bow down and fall when he has mastered the poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.32",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Psalms 9:32",
      "text": "For he has said in his heart, God has forgotten: he has turned away his face so as never to look.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.33",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Psalms 9:33",
      "text": "Arise, O Lord God; let thy hand be lifted up: forget not the poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.34",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Psalms 9:34",
      "text": "Wherefore has the wicked provoked God? for he has said in his heart, He will not require it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.35",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Psalms 9:35",
      "text": "Thou seest it; for thou dost observe trouble and wrath, to deliver them into thy hands: the poor has been left to thee; thou wast a helper to the orphan.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.36",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "Psalms 9:36",
      "text": "Break thou the arm of the sinner and wicked man: his sin shall be sought for, and shall not be found.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.37",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "Psalms 9:37",
      "text": "The Lord shall reign for ever, even for ever and ever: ye Gentiles shall perish out of his land.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.38",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "Psalms 9:38",
      "text": "The Lord has heard the desire of the poor: thine ear has inclined to the preparation of their heart;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.9.39",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 39,
      "referenceLabel": "Psalms 9:39",
      "text": "to plead for the orphan and afflicted, that man may no more boast upon the earth.",
      "paragraphStart": false
    }
  ]
}
