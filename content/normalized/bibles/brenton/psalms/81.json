{
  "chapter": {
    "id": "brenton:psalms.81",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.81.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "A Psalm for Asaph. - God stands in the assembly of gods; and in the midst of them will judge gods.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.81.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "How long will ye judge unrighteously, and accept the persons of sinners? Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.81.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Judge the orphan and poor: do justice to the low and needy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.81.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "Rescue the needy, and deliver the poor out of the hand of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.81.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "They know not, nor understand; they walk on in darkness: all the foundations of the earth shall be shaken.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.81.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "I have said, Ye are gods; and all of you children of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.81.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "But ye die as men, and fall as one of the princes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.81.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Arise, O God, judge the earth: for thou shalt inherit all nations.",
      "paragraphStart": false
    }
  ]
}
