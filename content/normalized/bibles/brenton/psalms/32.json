{
  "chapter": {
    "id": "brenton:psalms.32",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 32,
    "referenceLabel": "Psalms 32",
    "summary": "Source text for Psalms 32 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.32.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 1,
      "referenceLabel": "Psalms 32:1",
      "text": "A Psalm of David. - Rejoice in the Lord, ye righteous; praise becomes the upright.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.32.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 2,
      "referenceLabel": "Psalms 32:2",
      "text": "Praise the Lord on the harp; platy to him on a psaltery of ten strings.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 3,
      "referenceLabel": "Psalms 32:3",
      "text": "Sing to him a new song; play skillfully with a loud noise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 4,
      "referenceLabel": "Psalms 32:4",
      "text": "For the word of the Lord is right; and all his works are faithful.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 5,
      "referenceLabel": "Psalms 32:5",
      "text": "He loves mercy and judgement; the earth is full the mercy of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 6,
      "referenceLabel": "Psalms 32:6",
      "text": "By the word of the Lord the heavens were established; and all the host of them by the breath of his mouth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 7,
      "referenceLabel": "Psalms 32:7",
      "text": "Who gathers the waters of the sea as in a bottle; who lays up the deeps in treasuries.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 8,
      "referenceLabel": "Psalms 32:8",
      "text": "Let all the earth fear the Lord; and let all that dwell in the world be moved because of him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 9,
      "referenceLabel": "Psalms 32:9",
      "text": "For he spoke, and they were made; he commanded, and they were created.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 10,
      "referenceLabel": "Psalms 32:10",
      "text": "The Lord frustrates the counsels of the nations; he brings to nought also the reasonings of the peoples, and brings to nought the counsels of princes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 11,
      "referenceLabel": "Psalms 32:11",
      "text": "But the counsel of the Lord endures for ever, the thoughts of his heart from generation to generation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 12,
      "referenceLabel": "Psalms 32:12",
      "text": "Blessed is the nation whose God is the Lord; the people whom he has chosen for his own inheritance.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 13,
      "referenceLabel": "Psalms 32:13",
      "text": "The Lord looks out of heaven; he beholds all the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 14,
      "referenceLabel": "Psalms 32:14",
      "text": "He looks from his prepared habitation on all the dwellers on the earth;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 15,
      "referenceLabel": "Psalms 32:15",
      "text": "who fashioned their hearts alone; who understands all their works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 16,
      "referenceLabel": "Psalms 32:16",
      "text": "A king is not saved by reason of a great host; and a giant shall not be delivered by the greatness of his strength.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 17,
      "referenceLabel": "Psalms 32:17",
      "text": "A horse is vain for safety; neither shall he be delivered by the greatness of his power.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 18,
      "referenceLabel": "Psalms 32:18",
      "text": "Behold, the eyes of the Lord are on them that fear him, those that hope in his mercy;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 19,
      "referenceLabel": "Psalms 32:19",
      "text": "to deliver their souls from death, and to keep them alive in famine.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 20,
      "referenceLabel": "Psalms 32:20",
      "text": "Our soul waits on the Lord; for he is our helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 21,
      "referenceLabel": "Psalms 32:21",
      "text": "For our heart shall rejoice in him, and we have hoped in his holy name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.32.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 32,
      "verseNumber": 22,
      "referenceLabel": "Psalms 32:22",
      "text": "Let thy mercy, O Lord, be upon us, according as we have hoped in thee.",
      "paragraphStart": false
    }
  ]
}
