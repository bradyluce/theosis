    "chapterNumber": 119,
    "referenceLabel": "Psalms 119",
    "summary": "Source text for Psalms 119 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.119.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 1,
      "referenceLabel": "Psalms 119:1",
      "text": "A Song of Degrees. - In mine affliction I cried to the Lord, and he hearkened to me.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.119.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 2,
      "referenceLabel": "Psalms 119:2",
      "text": "Deliver my soul, O Lord, from unjust lips, and from a deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.119.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 3,
      "referenceLabel": "Psalms 119:3",
      "text": "What should be given to thee, and what should be added to thee, for thy crafty tongue?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.119.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 4,
      "referenceLabel": "Psalms 119:4",
      "text": "Sharpened weapons of the mighty, with coals of the desert.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.119.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 5,
      "referenceLabel": "Psalms 119:5",
      "text": "Woe is me, that my sojourning is prolonged; I have tabernacled among the tents of Kedar.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.119.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 6,
      "referenceLabel": "Psalms 119:6",
      "text": "My soul has long been a sojourner;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.119.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 119,
      "verseNumber": 7,
      "referenceLabel": "Psalms 119:7",
      "text": "I was peaceable among them that hated peace; when I spoke to them, they warred against me without a cause.",
      "paragraphStart": false
    }
  ]
}
