{
  "chapter": {
    "id": "brenton:psalms.8",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.8.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "For the end, concerning the wine-presses, a Psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.8.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "O Lord, our Lord, how wonderful is thy name in all the earth! for thy magnificence is exalted above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "✡ Out of the mouth of babes and sucklings hast thou perfected praise, because of thine enemies; that thou mightest put down the enemy and avenger.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "For I will regard the heavens, the work of thy fingers; the moon and stars, which thou hast established.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "✡ What is man, that thou art mindful of him? or the son of man, that thou visitest him?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "Thou madest him a little less than angels, thou hast crowned him with glory and honour;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "and thou hast set him over the works of thy hands: thou hast put all things under his feet:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "sheep and all oxen, yea, and the cattle of the field;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "the birds of the sky, and the fish of the sea, the creatures passing through the paths of the sea.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.8.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Psalms 8:10",
      "text": "O Lord our Lord, how wonderful is thy name in all the earth!",
      "paragraphStart": false
    }
  ]
}
