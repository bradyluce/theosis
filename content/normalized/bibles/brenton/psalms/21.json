{
  "chapter": {
    "id": "brenton:psalms.21",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.21.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "A Psalm of David. The Lord tends me as a shepherd, and I shall want nothing.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.21.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "In a place of green grass, there he has made me dwell: he has nourished me by the water of rest.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "He has restored my soul: he has guided me into the paths of righteousness, for his name's sake.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "Yea, even if I should walk in the midst of the shadow of death, I will not be afraid of evils: for thou art with me; thy rod and thy staff, these have comforted me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "Thou hast prepared a table before me in presence of them that afflict me: thou hast thoroughly anointed my head with oil; and thy cup cheers me like the best wine.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "Thy mercy also shall follow me all the days of my life: and my dwelling shall be in the house of the Lord for a very long time.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "But I am a worm, and not a man; a reproach of men, and scorn of the people.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "All that saw me mocked me: they spoke with their lips, they shook the head, saying,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "He hoped in the Lord: let him deliver him, let him save him, because he takes pleasure in him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "For thou art he that drew me out of the womb; my hope from my mother's breasts.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "I was cast on thee from the womb: thou art my God from my mother's belly.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "Stand not aloof from me; for affliction is near; for there is no helper.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Many bullocks have compassed me: fat bulls have beset me round.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Psalms 21:14",
      "text": "They have opened their mouth against me, as a ravening and roaring lion.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Psalms 21:15",
      "text": "I am poured out like water, and all my bones are loosened: my heart in the midst of my belly is become like melting wax.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Psalms 21:16",
      "text": "My strength is dried up like a potsherd; and my tongue is glued to my throat; and thou hast brought me down to the dust of death.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Psalms 21:17",
      "text": "For many dogs have compassed me: the assembly of the wicked doers has beset me round: they pierced my hands and my feet.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Psalms 21:18",
      "text": "They counted all my bones; and they observed and looked upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Psalms 21:19",
      "text": "✡ They parted my garments among themselves, and cast lots upon my raiment.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Psalms 21:20",
      "text": "But thou, O Lord, remove not my help afar off: be ready for mine aid.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Psalms 21:21",
      "text": "Deliver my soul from the sword; my only-begotten one from the power of the dog.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Psalms 21:22",
      "text": "Save me from the lion's mouth; and regard my lowliness from the horns of the unicorns.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Psalms 21:23",
      "text": "I will declare thy name to my brethren: in the midst of the church will I sing praise to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Psalms 21:24",
      "text": "Ye that fear the Lord, praise him; all ye seed of Jacob, glorify him: let all the seed of Israel fear him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Psalms 21:25",
      "text": "For he has not despised nor been angry at the supplication of the poor; nor turned away his face from me; but when I cried to him, he heard me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Psalms 21:26",
      "text": "My praise is of thee in the great congregation: I will pay my vows before them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Psalms 21:27",
      "text": "The poor shall eat and be satisfied; and they shall praise the Lord that seek him: their heart shall live for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 28,
      "referenceLabel": "Psalms 21:28",
      "text": "All the ends of the earth shall remember and turn to the Lord: and all the kindreds of the nations shall worship before him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 29,
      "referenceLabel": "Psalms 21:29",
      "text": "For the kingdom is the Lord's; and he is the governor of the nations.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.30",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 30,
      "referenceLabel": "Psalms 21:30",
      "text": "All the fat ones of the earth have eaten and worshipped: all that go down to the earth shall fall down before him: my soul also lives to him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.31",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 31,
      "referenceLabel": "Psalms 21:31",
      "text": "And my seed shall serve him: the generation that is coming shall be reported to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.21.32",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 32,
      "referenceLabel": "Psalms 21:32",
      "text": "And they shall report his righteousness to the people that shall be born, whom the Lord has made. ✡ 21:19 Mat. 27. 35.",
      "paragraphStart": false
    }
  ]
}
