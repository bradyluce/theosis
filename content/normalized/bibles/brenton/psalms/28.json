{
  "chapter": {
    "id": "brenton:psalms.28",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 28,
    "referenceLabel": "Psalms 28",
    "summary": "Source text for Psalms 28 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.28.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Psalms 28:1",
      "text": "A Psalm of David on the occasion of the solemn assembly of the Tabernacle. Bring to the Lord, ye sons of God, bring to the Lord young rams; bring to the Lord glory and honour.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.28.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Psalms 28:2",
      "text": "Bring to the Lord glory, due to his name; worship the Lord in his holy court.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Psalms 28:3",
      "text": "The voice of the Lord is upon the waters: the God of glory has thundered: the Lord is upon many waters.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Psalms 28:4",
      "text": "The voice of the Lord is mighty; the voice of the Lord is full of majesty.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Psalms 28:5",
      "text": "There is the voice of the Lord who breaks the cedars; the Lord will break the cedars of Libanus.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Psalms 28:6",
      "text": "And he will beat them small, even Libanus itself, like a calf; and the beloved one is as a young unicorn.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Psalms 28:7",
      "text": "There is a voice of the Lord who divides a flame of fire.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Psalms 28:8",
      "text": "A voice of the Lord who shakes the wilderness; the Lord will shake the wilderness of Cades.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Psalms 28:9",
      "text": "The voice of the Lord strengthens the hinds, and will uncover the thickets: and in his temple every one speaks of his glory.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Psalms 28:10",
      "text": "The Lord will dwell on the waterflood: and the Lord will sit a king for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.28.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Psalms 28:11",
      "text": "The Lord will give strength to his people; the Lord will bless his people with peace.",
      "paragraphStart": false
    }
  ]
}
