{
  "chapter": {
    "id": "brenton:psalms.146",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.146.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Alleluia, a Psalm of Aggæus and Zacharias. Praise ye the Lord: for psalmody is a good thing; let praise be sweetly sung to our God.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.146.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "The Lord builds up Jerusalem; and he will gather together the dispersed of Israel.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "He heals the broken in heart, and binds up their wounds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "He numbers the multitudes of stars; and calls them all by names.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Great is our Lord, and great is his strength; and his understanding is infinite.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "The Lord lifts up the meek; but brings sinners down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "Begin the song with thanksgiving to the Lord; sing praises on the harp to our God:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "who covers the heaven with clouds, who prepares rain for the earth, who causes grass to spring up on the mountains, [and green herb for the service of men;]",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "and gives to cattle their food, and to the young ravens that call upon him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "He will not take pleasure in the strength of a horse; neither is he well-pleased with the legs of a man.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.146.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 11,
      "referenceLabel": "Psalms 146:11",
      "text": "The Lord takes pleasure in them that fear him, and in all that hope in his mercy.",
      "paragraphStart": false
    }
  ]
}
