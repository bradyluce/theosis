{
  "chapter": {
    "id": "brenton:psalms.123",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 123,
    "referenceLabel": "Psalms 123",
    "summary": "Source text for Psalms 123 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.123.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 1,
      "referenceLabel": "Psalms 123:1",
      "text": "A Song of Degrees. - If it had not been that the Lord was among us, let Israel now say;",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.123.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 2,
      "referenceLabel": "Psalms 123:2",
      "text": "if it had not been that the Lord was among us, when men rose up against us;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.123.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 3,
      "referenceLabel": "Psalms 123:3",
      "text": "verily they would have swallowed us up alive, when their wrath was kindled against us:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.123.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 4,
      "referenceLabel": "Psalms 123:4",
      "text": "verily the water would have drowned us, our soul would have gone under the torrent.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.123.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 5,
      "referenceLabel": "Psalms 123:5",
      "text": "Yea, our soul would have gone under the overwhelming water.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.123.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 6,
      "referenceLabel": "Psalms 123:6",
      "text": "Blessed be the Lord, who has not given us for a prey to their teeth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.123.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 7,
      "referenceLabel": "Psalms 123:7",
      "text": "Our soul has been delivered as a sparrow from the snare of the fowlers: the snare is broken, and we are delivered.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.123.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 123,
      "verseNumber": 8,
      "referenceLabel": "Psalms 123:8",
      "text": "Our help is in the name of the Lord, who made heaven and earth.",
      "paragraphStart": false
    }
  ]
}
