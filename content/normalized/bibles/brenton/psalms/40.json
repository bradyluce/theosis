{
  "chapter": {
    "id": "brenton:psalms.40",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 40,
    "referenceLabel": "Psalms 40",
    "summary": "Source text for Psalms 40 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.40.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 1,
      "referenceLabel": "Psalms 40:1",
      "text": "For the end, a Psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.40.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 2,
      "referenceLabel": "Psalms 40:2",
      "text": "Blessed is the man who thinks on the poor and needy: the Lord shall deliver him in an evil day.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 3,
      "referenceLabel": "Psalms 40:3",
      "text": "May the Lord preserve him and keep him alive, and bless him on the earth, and not deliver him into the hands of his enemy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 4,
      "referenceLabel": "Psalms 40:4",
      "text": "May the Lord help him upon the bed of his pain; thou hast made all his bed in his sickness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 5,
      "referenceLabel": "Psalms 40:5",
      "text": "I said, O Lord, have mercy upon me; heal my soul; for I have sinned against thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 6,
      "referenceLabel": "Psalms 40:6",
      "text": "Mine enemies have spoken evil against me, saying, When shall he die, and his name perish?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 7,
      "referenceLabel": "Psalms 40:7",
      "text": "And if he came to see me, his heart spoke vainly; he gathered iniquity to himself; he went forth and spoke in like manner.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 8,
      "referenceLabel": "Psalms 40:8",
      "text": "All my enemies whispered against me; against me they devised my hurt.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 9,
      "referenceLabel": "Psalms 40:9",
      "text": "They denounced a wicked word against me, saying, Now that he lies, shall he not rise up again?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 10,
      "referenceLabel": "Psalms 40:10",
      "text": "For even the man of my peace, in whom I trusted, ✡ who ate my bread, lifted up his heel against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 11,
      "referenceLabel": "Psalms 40:11",
      "text": "But thou, O Lord, have compassion upon me, and raise me up, and I shall requite them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 12,
      "referenceLabel": "Psalms 40:12",
      "text": "By this I know that thou hast delighted in me, because mine enemy shall not rejoice over me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 13,
      "referenceLabel": "Psalms 40:13",
      "text": "But thou didst help me because of mine innocence, and hast established me before thee for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.40.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 40,
      "verseNumber": 14,
      "referenceLabel": "Psalms 40:14",
      "text": "Blessed be the Lord God of Israel from everlasting, and to everlasting. So be it, so be it.",
      "paragraphStart": false
    }
  ]
}
