{
  "chapter": {
    "id": "brenton:psalms.94",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 94,
    "referenceLabel": "Psalms 94",
    "summary": "Source text for Psalms 94 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.94.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 1,
      "referenceLabel": "Psalms 94:1",
      "text": "The praise of a Song by David. - Come, let us exult in the Lord; let us make a joyful noise to God our Saviour.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.94.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 2,
      "referenceLabel": "Psalms 94:2",
      "text": "Let us come before his presence with thanksgiving, and make a joyful noise to him with psalms.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 3,
      "referenceLabel": "Psalms 94:3",
      "text": "For the Lord is a great God, and a great king over all gods: for the Lord will not cast off his people.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 4,
      "referenceLabel": "Psalms 94:4",
      "text": "For the ends of the earth are in his hands; and the heights of the mountains are his.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 5,
      "referenceLabel": "Psalms 94:5",
      "text": "For the sea is his, and he made it: and his hands formed the dry land.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 6,
      "referenceLabel": "Psalms 94:6",
      "text": "Come, let us worship and fall down before him; and weep before the Lord that made us.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 7,
      "referenceLabel": "Psalms 94:7",
      "text": "For he is our God; and we are the people of his pasture, and the sheep of his hand.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 8,
      "referenceLabel": "Psalms 94:8",
      "text": "To-day, if ye will hear his voice, harden not your hearts, as in the provocation, according to the day of irritation in the wilderness:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 9,
      "referenceLabel": "Psalms 94:9",
      "text": "where your fathers tempted me, proved me, and saw my works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 10,
      "referenceLabel": "Psalms 94:10",
      "text": "Forty years was I grieved with this generation, and said, They do always err in their heart, and they have not known my ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.94.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 94,
      "verseNumber": 11,
      "referenceLabel": "Psalms 94:11",
      "text": "So I sware in my wrath, They shall not enter into my rest.",
      "paragraphStart": false
    }
  ]
}
