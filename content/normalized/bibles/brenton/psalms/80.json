{
  "chapter": {
    "id": "brenton:psalms.80",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 80,
    "referenceLabel": "Psalms 80",
    "summary": "Source text for Psalms 80 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.80.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 1,
      "referenceLabel": "Psalms 80:1",
      "text": "A Song of a Psalm for Asaph.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.80.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 2,
      "referenceLabel": "Psalms 80:2",
      "text": "How long will ye judge unrighteously, and accept the persons of sinners? Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 3,
      "referenceLabel": "Psalms 80:3",
      "text": "Judge the orphan and poor: do justice to the low and needy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 4,
      "referenceLabel": "Psalms 80:4",
      "text": "Rescue the needy, and deliver the poor out of the hand of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 5,
      "referenceLabel": "Psalms 80:5",
      "text": "They know not, nor understand; they walk on in darkness: all the foundations of the earth shall be shaken.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 6,
      "referenceLabel": "Psalms 80:6",
      "text": "I have said, Ye are gods; and all of you children of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 7,
      "referenceLabel": "Psalms 80:7",
      "text": "But ye die as men, and fall as one of the princes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 8,
      "referenceLabel": "Psalms 80:8",
      "text": "Arise, O God, judge the earth: for thou shalt inherit all nations.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 9,
      "referenceLabel": "Psalms 80:9",
      "text": "Hear, my people, and I will speak to thee, O Israel; and I will testify to thee: if thou wilt hearken to me;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 10,
      "referenceLabel": "Psalms 80:10",
      "text": "there shall be no new god in thee; neither shalt thou worship a strange god.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 11,
      "referenceLabel": "Psalms 80:11",
      "text": "For I am the Lord thy God, that brought thee out of the land of Egypt: open thy mouth wide, and I will fill it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 12,
      "referenceLabel": "Psalms 80:12",
      "text": "But my people hearkened not to my voice; and Israel gave no heed to me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 13,
      "referenceLabel": "Psalms 80:13",
      "text": "So I let them go after the ways of their own hearts: they will go on in their own ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 14,
      "referenceLabel": "Psalms 80:14",
      "text": "If my people had hearkened to me, if Israel had walked in my ways,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 15,
      "referenceLabel": "Psalms 80:15",
      "text": "I should have put down their enemies very quickly, and should have laid my hand upon those that afflicted them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 16,
      "referenceLabel": "Psalms 80:16",
      "text": "The Lord's enemies should have lied to him: but their time shall be for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.80.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 80,
      "verseNumber": 17,
      "referenceLabel": "Psalms 80:17",
      "text": "And he fed them with the fat of wheat; and satisfied them with honey out of the rock.",
      "paragraphStart": false
    }
  ]
}
