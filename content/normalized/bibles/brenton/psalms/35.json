{
  "chapter": {
    "id": "brenton:psalms.35",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.35.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "A Psalm of David. Fret not thyself because of evil-doers, neither be envious of them that do iniquity.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.35.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "For they shall soon be withered as the grass, and shall soon fall away as the green herbs.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "Hope in the Lord, and do good; and dwell on the land, and thou shalt be fed with the wealth of it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "Delight thyself in the Lord; and he shall grant thee the requests of thine heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "Disclose thy way to the Lord, and hope in him; and he shall bring it to pass.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "And he shall bring forth thy righteousness as the light, and thy judgment as the noon-day.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "Submit thyself to the Lord, and supplicate him: fret not thyself because of him that prospers in his way, at the man that does unlawful deeds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "Cease from anger, and forsake wrath: fret not thyself so as to do evil.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "For evil-doers shall be destroyed: but they that wait on the Lord, they shall inherit the land.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "And yet a little while, and the sinner shall not be, and thou shalt seek for his place, and shalt not find it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "But the meek shall inherit the earth; and shall delight themselves in the abundance of peace.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "The sinner will watch for the righteous, and gnash his teeth upon him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Psalms 35:13",
      "text": "But the Lord shall laugh at him: for he foresees that his day will come.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Psalms 35:14",
      "text": "Sinners have drawn their swords, they have bent their bow, to cast down the poor and needy one, and to slay the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Psalms 35:15",
      "text": "Let their sword enter into their own heart, and their bows be broken.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Psalms 35:16",
      "text": "A little is better to the righteous than abundant wealth of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Psalms 35:17",
      "text": "For the arms of sinners shall be broken; but the Lord supports the righteous.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Psalms 35:18",
      "text": "The Lord knows the ways of the perfect; and their inheritance shall be for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Psalms 35:19",
      "text": "They shall not be ashamed in an evil time; and in days of famine they shall be satisfied.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Psalms 35:20",
      "text": "For the sinners shall perish; and the enemies of the Lord at the moment of their being honoured and exalted have utterly vanished like smoke.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Psalms 35:21",
      "text": "The sinner borrows, and will not pay again: but the righteous has compassion, and gives.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Psalms 35:22",
      "text": "For they that bless him shall inherit the earth; and they that curse him shall be utterly destroyed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Psalms 35:23",
      "text": "The steps of a man are rightly ordered by the Lord: and he will take pleasure in his way.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Psalms 35:24",
      "text": "When he falls, he shall not be ruined: for the Lord supports his hand.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Psalms 35:25",
      "text": "I was once young, indeed I am now old; yet I have not seen the righteous forsaken, nor his seed seeking bread.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Psalms 35:26",
      "text": "He is merciful, and lends continually; and his seed shall be blessed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Psalms 35:27",
      "text": "Turn aside from evil, and do good; and dwell for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Psalms 35:28",
      "text": "For the Lord loves judgment, and will not forsake his saints; they shall be preserved for ever: the blameless shall be avenged, but the seed of the ungodly shall be utterly destroyed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 29,
      "referenceLabel": "Psalms 35:29",
      "text": "But the righteous shall inherit the earth, and dwell upon it for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.30",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 30,
      "referenceLabel": "Psalms 35:30",
      "text": "The mouth of the righteous will meditate wisdom, and his tongue will speak of judgment.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.31",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 31,
      "referenceLabel": "Psalms 35:31",
      "text": "The law of his God is in his heart; and his steps shall not slide.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.32",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 32,
      "referenceLabel": "Psalms 35:32",
      "text": "The sinner watches the righteous, and seeks to slay him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.33",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 33,
      "referenceLabel": "Psalms 35:33",
      "text": "But the Lord will not leave him in his hands, nor by any means condemn him when he is judged.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.34",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 34,
      "referenceLabel": "Psalms 35:34",
      "text": "Wait on the Lord, and keep his way, and he shall exalt thee to inherit the land: when the wicked are destroyed, thou shalt see it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.35",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 35,
      "referenceLabel": "Psalms 35:35",
      "text": "I saw the ungodly very highly exalting himself, and lifting himself up like the cedars of Libanus.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.36",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 36,
      "referenceLabel": "Psalms 35:36",
      "text": "Yet I passed by, and lo! he was not: and I sought him, but his place was not found.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.37",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 37,
      "referenceLabel": "Psalms 35:37",
      "text": "Maintain innocence, and behold uprightness: for there is a remnant to the peaceable man.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.38",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 38,
      "referenceLabel": "Psalms 35:38",
      "text": "But the transgressors shall be utterly destroyed together: the remnants of the ungodly shall be utterly destroyed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.39",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 39,
      "referenceLabel": "Psalms 35:39",
      "text": "But the salvation of the righteous is of the Lord; and he is their defender in the time of affliction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.35.40",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 40,
      "referenceLabel": "Psalms 35:40",
      "text": "And the Lord shall help them, and deliver them: and he shall rescue them from sinners, and save them, because they have hoped in him.",
      "paragraphStart": false
    }
  ]
}
