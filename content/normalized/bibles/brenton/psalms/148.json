{
  "chapter": {
    "id": "brenton:psalms.148",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.148.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "This Psalm is a genuine one of David, though supernumerary, composed when he fought in single combat with Goliad. I was small among my brethren, and youngest in my father's house: I tended my father's sheep.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.148.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "My hands formed a musical instrument, and my fingers tuned a psaltery.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "And who shall tell my Lord? the Lord himself, he himself hears.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "He sent forth his angel, and took me from my father's sheep, and he anointed me with the oil of his anointing.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "My brothers were handsome and tall; but the Lord did not take pleasure in them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "I went forth to meet the Philistine; and he cursed me by his idols.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "But I drew his own sword, and beheaded him, and removed reproach from the children of Israel.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "to bind their kings with fetters, and their nobles with manacles of iron;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "to execute on them the judgment written: this honour have all his saints.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "wild beasts, and all cattle; reptiles, and winged birds:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "kings of the earth, and all peoples; princes, and all judges of the earth:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "young men and virgins, old men with youths:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "let them praise the name of the Lord: for his name only is exalted; his praise is above the earth and heaven,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.148.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "and he shall exalt the horn of his people, there is a hymn for all his saints, even of the children of Israel, a people who draw near to him.",
      "paragraphStart": false
    }
  ]
}
