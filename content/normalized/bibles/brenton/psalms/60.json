{
  "chapter": {
    "id": "brenton:psalms.60",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.60.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "For the end, among the Hymns of David.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.60.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "O God, hearken to my petition; attend to my prayer.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "From the ends of the earth have I cried to thee, when my heart was in trouble: thou liftedst me up on a rock, thou didst guide me:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "because thou wert my hope, a tower of strength from the face of the enemy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "I will dwell in thy tabernacle for ever; I will shelter myself under the shadow of thy wings. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "For thou, O God, hast heard my prayers; thou hast given an inheritance to them that fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Thou shalt add days to the days of the king; thou shalt lengthen his years to all generations.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "He shall endure for ever before God: which of them will seek out his mercy and truth?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.60.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "So will I sing to thy name for ever and ever, that I may daily perform my vows.",
      "paragraphStart": false
    }
  ]
}
