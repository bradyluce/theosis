{
  "chapter": {
    "id": "brenton:psalms.88",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.88.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "A Psalm of a Song for the Sabbath-day.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.88.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "He shall say to the Lord, Thou art my helper and my refuge: my God; I will hope in him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "For he shall deliver thee from the snare of the hunters, from every troublesome matter.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "He shall overshadow thee with his shoulders, and thou shalt trust under his wings: his truth shall cover thee with a shield.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "Thou shalt not be afraid of terror by night; nor of the arrow flying by day;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "nor of the evil thing that walks in darkness; nor of calamity, and the evil spirit at noon-day.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "A thousand shall fall at thy side, and ten thousand at thy right hand; but it shall not come nigh thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "Only with thine eyes shalt thou observe and see the reward of sinners.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "For thou, O Lord, art my hope: thou, my soul, hast made the Most High thy refuge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "No evils shall come upon thee, and no scourge shall draw nigh to thy dwelling.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "For he shall give his angels charge concerning thee, to keep thee in all thy ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "✡ They shall bear thee up on their hands, lest at any time thou dash thy foot against a stone.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "Thou shalt tread on the asp and basilisk: and thou shalt trample on the lion and dragon.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "For he has hoped in me, and I will deliver him: I will protect him, because he has known my name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "He shall call upon me, and I will hearken to him: I am with him in affliction; and I will deliver him, and glorify him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "I will satisfy him with length of days, and shew him my salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "And let the brightness of the Lord our God be upon us: and do thou direct for us the works of our hands.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "For thou art the boast of their strength; and in thy good pleasure shall our horn be exalted,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 19,
      "referenceLabel": "Psalms 88:19",
      "text": "for our help is of the Lord; and of the Holy One of Israel, our king.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 20,
      "referenceLabel": "Psalms 88:20",
      "text": "Then thou spokest in vision to thy children, and saidst, I have laid help on a mighty one; I have exalted one chosen out of my people.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 21,
      "referenceLabel": "Psalms 88:21",
      "text": "✡ I have found David my servant; I have anointed him by my holy mercy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 22,
      "referenceLabel": "Psalms 88:22",
      "text": "For my hand shall support him; and mine arm shall strengthen him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 23,
      "referenceLabel": "Psalms 88:23",
      "text": "The enemy shall have no advantage against him; and the son of transgression shall not hurt him again.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 24,
      "referenceLabel": "Psalms 88:24",
      "text": "And I will hew down his foes before him, and put to flight those that hate him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 25,
      "referenceLabel": "Psalms 88:25",
      "text": "But my truth and my mercy shall be with him; and in my name shall his horn be exalted.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 26,
      "referenceLabel": "Psalms 88:26",
      "text": "And I will set his hand in the sea, and his right hand in the rivers.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 27,
      "referenceLabel": "Psalms 88:27",
      "text": "He shall call upon me, saying, Thou art my Father, my God, and the helper of my salvation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 28,
      "referenceLabel": "Psalms 88:28",
      "text": "And I will make him my first-born, higher than the kings of the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 29,
      "referenceLabel": "Psalms 88:29",
      "text": "I will keep my mercy for him for ever, and my covenant shall be firm with him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.30",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 30,
      "referenceLabel": "Psalms 88:30",
      "text": "And I will establish his seed for ever and ever, and his throne as the days of heaven.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.31",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 31,
      "referenceLabel": "Psalms 88:31",
      "text": "If his children should forsake my law, and walk not in my judgments;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.32",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 32,
      "referenceLabel": "Psalms 88:32",
      "text": "if they should profane my ordinances, and not keep my commandments;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.33",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 33,
      "referenceLabel": "Psalms 88:33",
      "text": "I will visit their transgressions with a rod, and their sins with scourges.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.34",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 34,
      "referenceLabel": "Psalms 88:34",
      "text": "But my mercy I will not utterly remove from him, nor wrong my truth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.35",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 35,
      "referenceLabel": "Psalms 88:35",
      "text": "Neither will I by any means profane my covenant; and I will not make void the things that proceed out of my lips.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.36",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 36,
      "referenceLabel": "Psalms 88:36",
      "text": "Once have I sworn by my holiness, that I will not lie to David.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.37",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 37,
      "referenceLabel": "Psalms 88:37",
      "text": "His seed shall endure for ever, and his throne as the sun before me;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.38",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 38,
      "referenceLabel": "Psalms 88:38",
      "text": "and as the moon that is established for ever, and as the faithful witness in heaven. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.39",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 39,
      "referenceLabel": "Psalms 88:39",
      "text": "But thou hast cast off and set at nought, thou hast rejected thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.40",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 40,
      "referenceLabel": "Psalms 88:40",
      "text": "Thou hast overthrown the covenant of thy servant; thou hast profaned his sanctuary, casting it to the ground.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.41",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 41,
      "referenceLabel": "Psalms 88:41",
      "text": "Thou hast broken down all his hedges; thou hast made his strong holds a terror.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.42",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 42,
      "referenceLabel": "Psalms 88:42",
      "text": "All that go by the way have spoiled him: he is become a reproach to his neighbours.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.43",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 43,
      "referenceLabel": "Psalms 88:43",
      "text": "Thou hast exalted the right hand of his enemies; thou hast made all his enemies to rejoice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.44",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 44,
      "referenceLabel": "Psalms 88:44",
      "text": "Thou hast turned back the help of his sword, and hast not helped him in the battle.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.45",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 45,
      "referenceLabel": "Psalms 88:45",
      "text": "Thou hast deprived him of glory: thou hast broken down his throne to the ground. ✡ 88:21 Acts 13. 22.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.46",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 46,
      "referenceLabel": "Psalms 88:46",
      "text": "Thou hast shortened the days of his throne: thou hast poured shame upon him. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.47",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 47,
      "referenceLabel": "Psalms 88:47",
      "text": "How long, O Lord, wilt thou turn away, for ever? shall thine anger flame out as fire?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.48",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 48,
      "referenceLabel": "Psalms 88:48",
      "text": "Remember what my being is: for hast thou created all the sons of men in vain?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.49",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 49,
      "referenceLabel": "Psalms 88:49",
      "text": "What man is there who shall live, and not see death? shall any one deliver his soul from the hand of Hades? Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.50",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 50,
      "referenceLabel": "Psalms 88:50",
      "text": "Where are thine ancient mercies, O Lord, which thou swarest to David in thy truth?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.51",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 51,
      "referenceLabel": "Psalms 88:51",
      "text": "Remember, O Lord, the reproach of thy servants, which I have borne in my bosom, even the reproach of many nations;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.52",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 52,
      "referenceLabel": "Psalms 88:52",
      "text": "wherewith thine enemies have reviled, O Lord: wherewith they have reviled the recompence of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.88.53",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 53,
      "referenceLabel": "Psalms 88:53",
      "text": "Blessed be the Lord for ever. So be it, so be it.",
      "paragraphStart": false
    }
  ]
}
