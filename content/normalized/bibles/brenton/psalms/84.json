{
  "chapter": {
    "id": "brenton:psalms.84",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.84.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "A Psalm of a Song for the sons of Core. His foundations are in the holy mountains.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.84.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "The Lord loves the gates of Sion, more than all the tabernacles of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Glorious things have been spoken of thee, O city of God. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "I will make mention of Raab and Babylon to them that know me: behold also the Philistines, and Tyre, and the people of the Ethiopians: these were born there.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "A man shall say, Sion is my mother; and such a man was born in her; and the Highest himself has founded her.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "The Lord shall recount it in the writing of the people, and of these princes that",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "The dwelling of all within thee is as the dwelling of those that rejoice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "There is none like to thee, O Lord, among the gods; and there are no works like to thy works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "All nations whom thou hast made shall come, and shall worship before thee, O Lord; and shall glorify thy name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "For thou art great, and doest wonders: thou art the only and the great God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "Guide me, O Lord, in thy way, and I will walk in thy truth: let my heart rejoice, that I may fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "I will give thee thanks, O Lord my God, with all my heart; and I will glorify thy name for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "For thy mercy is great toward me; and thou hast delivered my soul from the lowest hell.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 14,
      "referenceLabel": "Psalms 84:14",
      "text": "O God, transgressors have risen up against me, and an assembly of violent men have sought my life; and have not set thee before them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 15,
      "referenceLabel": "Psalms 84:15",
      "text": "But thou, O Lord God, art compassionate and merciful, long-suffering, and abundant in mercy and true.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 16,
      "referenceLabel": "Psalms 84:16",
      "text": "Look thou upon me, and have mercy upon me: give thy strength to thy servant, and save the son of thine handmaid.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.84.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 17,
      "referenceLabel": "Psalms 84:17",
      "text": "Establish with me a token for good; and let them that hate me see it and be ashamed; because thou, O Lord, hast helped me, and comforted me.",
      "paragraphStart": false
    }
  ]
}
