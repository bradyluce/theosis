{
  "chapter": {
    "id": "brenton:psalms.121",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.121.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "A Song of Degrees. - I was glad when they said to me, Let us go into the house of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.121.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "Our feet stood in thy courts, O Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "Jerusalem is built as a city whose fellowship is complete.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "For thither the tribes went up, the tribes of the Lord, as a testimony for Israel, to give thanks unto the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "For there are set thrones for judgement, even thrones for the house of David.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "Pray now for the peace of Jerusalem: and let there be prosperity to them that love thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "Let peace, I pray, be within thine host, and prosperity in thy palaces.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "For the sake of my brethren and my neighbours, I have indeed spoken peace concerning thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.121.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 9,
      "referenceLabel": "Psalms 121:9",
      "text": "Because of the house of the Lord our God, I have diligently sought thy good.",
      "paragraphStart": false
    }
  ]
}
