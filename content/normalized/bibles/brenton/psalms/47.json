{
  "chapter": {
    "id": "brenton:psalms.47",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.47.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "A Psalm of praise for the sons of Core on the second day of the week.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.47.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "Great is the Lord, and greatly to be praised in the city of our God, in his holy mountain.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "The city of the great King is well planted on the mountains of Sion, with the joy of the whole earth, on the sides of the north.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "God is known in her palaces, when he undertakes to help her.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "For, behold, the kings of the earth were assembled, they came together.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "They saw, and so they wondered: they were troubled, they were moved.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "Trembling took hold on them: there were the pangs as of a woman in travail.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "Thou wilt break the ships of Tharsis with a vehement wind.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "As we have heard, so have we also seen, in the city of the Lord of hosts, in the city of our God: God has founded it for ever. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 10,
      "referenceLabel": "Psalms 47:10",
      "text": "We have thought of thy mercy, O God, in the midst of thy people.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 11,
      "referenceLabel": "Psalms 47:11",
      "text": "According to thy name, O God, so is also thy praise to the ends of the earth: thy right hand is full of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 12,
      "referenceLabel": "Psalms 47:12",
      "text": "Let mount Sion rejoice, let the daughters of Judæa exult, because of thy judgments, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 13,
      "referenceLabel": "Psalms 47:13",
      "text": "Go round about Sion, and encompass her: tell ye her towers.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 14,
      "referenceLabel": "Psalms 47:14",
      "text": "Mark ye well her strength, and observe her palaces; that ye may tell the next generation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.47.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 15,
      "referenceLabel": "Psalms 47:15",
      "text": "For this is our God for ever and ever: he will be our guide for evermore.",
      "paragraphStart": false
    }
  ]
}
