{
  "chapter": {
    "id": "brenton:psalms.127",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 127,
    "referenceLabel": "Psalms 127",
    "summary": "Source text for Psalms 127 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.127.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 1,
      "referenceLabel": "Psalms 127:1",
      "text": "A Song of Degrees. - Blessed are all they that fear the Lord; who walk in his ways.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.127.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 2,
      "referenceLabel": "Psalms 127:2",
      "text": "Thou shalt eat the labours of thy hands: blessed art thou, and it shall be well with thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.127.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 3,
      "referenceLabel": "Psalms 127:3",
      "text": "Thy wife shall be as a fruitful vine on the sides of thy house: thy children as young olive-plants round about thy table.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.127.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 4,
      "referenceLabel": "Psalms 127:4",
      "text": "Behold, thus shall the man be blessed that fears the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.127.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 5,
      "referenceLabel": "Psalms 127:5",
      "text": "May the Lord bless thee out of Sion; and mayest thou see the prosperity of Jerusalem all the days of thy life.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.127.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 127,
      "verseNumber": 6,
      "referenceLabel": "Psalms 127:6",
      "text": "And mayest thou see thy children’s children. Peace be upon Israel.",
      "paragraphStart": false
    }
  ]
}
