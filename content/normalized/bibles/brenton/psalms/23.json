{
  "chapter": {
    "id": "brenton:psalms.23",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.23.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "A Psalm of David. Judge me, O Lord; for I have walked in my innocence: and hoping in the Lord I shall not be moved.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.23.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "Prove me, O Lord, and try me; purify as with fire my reins and my heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "For thy mercy is before mine eyes: and I am well pleased with thy truth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "I have not sat with the council of vanity, and will in nowise enter in with transgressors.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "I have hated the assembly of wicked doers; and will not sit with ungodly men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "I will wash my hands in innocency, and compass thine altar, O Lord:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Psalms 23:7",
      "text": "to hear the voice of praise, and to declare all thy wonderful works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Psalms 23:8",
      "text": "O Lord, I have loved the beauty of thy house, and the place of the tabernacle of thy glory.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Psalms 23:9",
      "text": "Destroy not my soul together with the ungodly, nor my life with bloody men:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Psalms 23:10",
      "text": "in whose hands are iniquities, and their right hand is filled with bribes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Psalms 23:11",
      "text": "But I have walked in my innocence: redeem me, and have mercy upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Psalms 23:12",
      "text": "My foot stands in an even place: in the congregations will I bless thee, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Psalms 23:13",
      "text": "His soul shall dwell in prosperity; and his seed shall inherit the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Psalms 23:14",
      "text": "The Lord is the strength of them that fear him; and his covenant is to manifest",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Psalms 23:15",
      "text": "Mine eyes are continually to the Lord; for he shall draw my feet out of the snare.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Psalms 23:16",
      "text": "Look upon me, and have mercy upon me; for I am an only child and poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Psalms 23:17",
      "text": "The afflictions of my heart have been multiplied; deliver me from my distresses.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Psalms 23:18",
      "text": "Look upon mine affliction and my trouble; and forgive all my sins.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Psalms 23:19",
      "text": "Look upon mine enemies; for they have been multiplied; and they have hated me with unjust hatred.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Psalms 23:20",
      "text": "Keep my soul, and deliver me: let me not be ashamed; for I have hoped in thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Psalms 23:21",
      "text": "The harmless and upright joined themselves to me: for I waited for thee, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.23.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Psalms 23:22",
      "text": "Deliver Israel, O God, out of all his afflictions.",
      "paragraphStart": false
    }
  ]
}
