{
  "chapter": {
    "id": "brenton:psalms.138",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 138,
    "referenceLabel": "Psalms 138",
    "summary": "Source text for Psalms 138 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.138.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 1,
      "referenceLabel": "Psalms 138:1",
      "text": "For the end, a Psalm of David. - O Lord, thou hast proved me, and known me.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.138.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 2,
      "referenceLabel": "Psalms 138:2",
      "text": "Thou knowest my down-sitting and mine up-rising: thou understandest my thoughts long before.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 3,
      "referenceLabel": "Psalms 138:3",
      "text": "Thou hast traced my path and my bed, and hast foreseen all my ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 4,
      "referenceLabel": "Psalms 138:4",
      "text": "For there is no unrighteous word in my tongue: behold, O Lord, thou hast known all things,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 5,
      "referenceLabel": "Psalms 138:5",
      "text": "the last and the first: thou hast fashioned me, and laid thine hand upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 6,
      "referenceLabel": "Psalms 138:6",
      "text": "The knowledge of thee is too wonderful for me; it is very difficult, I cannot attain to it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 7,
      "referenceLabel": "Psalms 138:7",
      "text": "Whither shall I go from thy Spirit? and whither shall I flee from my presence?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 8,
      "referenceLabel": "Psalms 138:8",
      "text": "If I should go up to heaven, thou art there: if I should go down to hell, thou art present.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 9,
      "referenceLabel": "Psalms 138:9",
      "text": "If I should spread my wings to fly straight forward, and sojourn at the extremity of the sea, it would be vain,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 10,
      "referenceLabel": "Psalms 138:10",
      "text": "for even there thy hand would guide me, and thy right hand would hold me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 11,
      "referenceLabel": "Psalms 138:11",
      "text": "When I said, Surely the darkness will cover me; even the night was light in my luxury.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 12,
      "referenceLabel": "Psalms 138:12",
      "text": "For darkness will not be darkness with thee; but night will be light as day: as its darkness, so shall its light be to thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 13,
      "referenceLabel": "Psalms 138:13",
      "text": "For thou, O Lord, hast possessed my reins; thou hast helped me from my mother’s womb.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 14,
      "referenceLabel": "Psalms 138:14",
      "text": "I will give thee thanks; for thou art fearfully wondrous; wondrous are thy works; and my soul knows it well.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 15,
      "referenceLabel": "Psalms 138:15",
      "text": "My bones, which thou madest in secret were not hidden from thee, nor my substance, in the lowest parts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 16,
      "referenceLabel": "Psalms 138:16",
      "text": "Thine eyes saw my unwrought substance, and all men shall be written in thy book; they shall be formed by day, though there should for a time be no one among them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 17,
      "referenceLabel": "Psalms 138:17",
      "text": "But thy friends, O God, have been greatly honoured by me; their rule has been greatly strengthened.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 18,
      "referenceLabel": "Psalms 138:18",
      "text": "I will number them, and they shall be multiplied beyond the sand; I awake, and am still with thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 19,
      "referenceLabel": "Psalms 138:19",
      "text": "Oh that thou wouldest slay the wicked, O God; depart from me, ye men of blood.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 20,
      "referenceLabel": "Psalms 138:20",
      "text": "For thou wilt say concerning their thought, that they shall take thy cities in vain.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 21,
      "referenceLabel": "Psalms 138:21",
      "text": "Have I not hated them, O Lord, that hate thee? and wasted away because of thine enemies?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 22,
      "referenceLabel": "Psalms 138:22",
      "text": "I have hated them with perfect hatred; they were counted my enemies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 23,
      "referenceLabel": "Psalms 138:23",
      "text": "Prove me, O God, and know my heart; examine me, and know my paths;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.138.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 138,
      "verseNumber": 24,
      "referenceLabel": "Psalms 138:24",
      "text": "and see if there is any way of iniquity in me, and lead me in an everlasting way.",
      "paragraphStart": false
    }
  ]
}
