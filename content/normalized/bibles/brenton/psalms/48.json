{
  "chapter": {
    "id": "brenton:psalms.48",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 48,
    "referenceLabel": "Psalms 48",
    "summary": "Source text for Psalms 48 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.48.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 1,
      "referenceLabel": "Psalms 48:1",
      "text": "A Psalm for Asaph. The God of gods, the Lord, has spoken, and called the earth from the rising of the sun to the going down thereof.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.48.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 2,
      "referenceLabel": "Psalms 48:2",
      "text": "Out of Sion comes the excellence of his beauty.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 3,
      "referenceLabel": "Psalms 48:3",
      "text": "God, our God, shall come manifestly, and shall not keep silence: a fire shall be kindled before him, and round about him there shall be a very great tempest.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 4,
      "referenceLabel": "Psalms 48:4",
      "text": "He shall summon the heaven above, and the earth, that he may ✡ judge his people.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 5,
      "referenceLabel": "Psalms 48:5",
      "text": "Assemble ye his saints to him, those that have engaged in a covenant with him upon sacrifices.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 6,
      "referenceLabel": "Psalms 48:6",
      "text": "And the heavens shall declare his righteousness: for God is judge. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 7,
      "referenceLabel": "Psalms 48:7",
      "text": "Hear, my people, and I will speak to thee, O Israel: and I will testify to thee: I am God, thy God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 8,
      "referenceLabel": "Psalms 48:8",
      "text": "I will not reprove thee on account of thy sacrifices; for thy whole-burnt-offerings are before me continually.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 9,
      "referenceLabel": "Psalms 48:9",
      "text": "I will take no bullocks out of thine house, nor he-goats out of thy flocks.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 10,
      "referenceLabel": "Psalms 48:10",
      "text": "For all the wild beasts of the thicket are mine, the cattle on the mountains, and oxen.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 11,
      "referenceLabel": "Psalms 48:11",
      "text": "I know all the birds of the sky; and the beauty of the field is mine.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 12,
      "referenceLabel": "Psalms 48:12",
      "text": "If I should be hungry, I will not tell thee: for the world is mine, and the fulness of it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 13,
      "referenceLabel": "Psalms 48:13",
      "text": "Will I eat the flesh of bulls, or drink the blood of goats?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 14,
      "referenceLabel": "Psalms 48:14",
      "text": "Offer to God the sacrifice of praise; and pay thy vows to the Most High.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 15,
      "referenceLabel": "Psalms 48:15",
      "text": "And call upon me in the day of affliction; and I will deliver thee, and thou shalt glorify me. Pause. ✡ 49:4 Heb. 10. 30.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 16,
      "referenceLabel": "Psalms 48:16",
      "text": "But to the sinner God has said, Why dost thou declare my ordinances, and take up my covenant in thy mouth?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 17,
      "referenceLabel": "Psalms 48:17",
      "text": "Whereas thou hast hated instruction, and hast cast my words behind thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 18,
      "referenceLabel": "Psalms 48:18",
      "text": "If thou sawest a thief, thou rannest along with him, and hast cast in thy lot with adulterers.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 19,
      "referenceLabel": "Psalms 48:19",
      "text": "Thy mouth has multiplied wickedness, and thy tongue has framed deceit.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 20,
      "referenceLabel": "Psalms 48:20",
      "text": "Thou didst sit and speak against thy brother, and didst scandalise thy mother's son.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 21,
      "referenceLabel": "Psalms 48:21",
      "text": "These things thou didst, and I kept silence: thou thoughtest wickedly that I should be like thee; but I will reprove thee, and set thine offences before thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 22,
      "referenceLabel": "Psalms 48:22",
      "text": "Now consider these things, ye that forget God, lest he rend you, and there be no deliverer.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.48.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 48,
      "verseNumber": 23,
      "referenceLabel": "Psalms 48:23",
      "text": "The sacrifice of praise will glorify me: and that is the way wherein I will shew to him the salvation of God.",
      "paragraphStart": false
    }
  ]
}
