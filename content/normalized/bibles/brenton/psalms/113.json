{
  "chapter": {
    "id": "brenton:psalms.113",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.113.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Alleluia. - At the going forth of Israel from Egypt, of the house of Jacob from a barbarous people,",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.113.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Judea became his sanctuary, and Israel his dominion.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "The sea saw and fled: Jordan was turned back.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "The mountains skipped like rams, and the hills like lambs.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "What ailed thee, O sea, that thou fleddest? and thou Jordan, that thou wast turned back?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "Ye mountains, that ye skipped like rams, and ye hills, like lambs?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "The earth trembled at the presence of the Lord, at the presence of the God of Jacob;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "who turned the rock into pools of water, and the flint into fountains of water.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "Not to us, O Lord, not to us, but to thy name give glory, because of thy mercy and thy truth;",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.113.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 10,
      "referenceLabel": "Psalms 113:10",
      "text": "lest at any time the nations should say, Where is their God?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 11,
      "referenceLabel": "Psalms 113:11",
      "text": "But our God has done in heaven and on earth, whatsoever he has pleased.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 12,
      "referenceLabel": "Psalms 113:12",
      "text": "The idols of the nations are silver and gold, the works of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 13,
      "referenceLabel": "Psalms 113:13",
      "text": "They have a mouth, but they cannot speak; they have eyes, but they cannot see:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 14,
      "referenceLabel": "Psalms 113:14",
      "text": "they have ears, but they cannot hear; they have noses, but they cannot smell;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 15,
      "referenceLabel": "Psalms 113:15",
      "text": "they have hands, but they cannot handle; they have feet, but they cannot walk: they cannot speak through their throat.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 16,
      "referenceLabel": "Psalms 113:16",
      "text": "Let those that make them become like to them, and all who trust in them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 17,
      "referenceLabel": "Psalms 113:17",
      "text": "The house of Israel trusts in the Lord: he is their helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 18,
      "referenceLabel": "Psalms 113:18",
      "text": "The house of Aaron trusts in the Lord: he is their helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 19,
      "referenceLabel": "Psalms 113:19",
      "text": "They that fear the Lord trust in the Lord: he is their helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 20,
      "referenceLabel": "Psalms 113:20",
      "text": "The Lord has remembered us, and blessed us: he has blessed the house of Israel, he has blessed the house of Aaron.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 21,
      "referenceLabel": "Psalms 113:21",
      "text": "He has blessed them that fear the Lord, both small and great.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 22,
      "referenceLabel": "Psalms 113:22",
      "text": "The Lord add blessings to you and to your children.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 23,
      "referenceLabel": "Psalms 113:23",
      "text": "Blessed are ye of the Lord, who made the heaven and the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 24,
      "referenceLabel": "Psalms 113:24",
      "text": "The heaven of heavens belongs to the Lord: but he has given the earth to the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 25,
      "referenceLabel": "Psalms 113:25",
      "text": "The dead shall not praise thee, O Lord, nor any that go down to Hades.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.113.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 26,
      "referenceLabel": "Psalms 113:26",
      "text": "But we, the living, will bless the Lord, from henceforth and for ever.",
      "paragraphStart": false
    }
  ]
}
