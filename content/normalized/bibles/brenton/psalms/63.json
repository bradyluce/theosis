{
  "chapter": {
    "id": "brenton:psalms.63",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.63.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "For the end, a Psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.63.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "Hear my prayer, O God, when I make my petition to thee; deliver my soul from fear of the enemy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Thou hast sheltered me from the conspiracy of them that do wickedly; from the multitude of them that work iniquity;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "who have sharpened their tongues as a sword; they have bent their bow maliciously;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "to shoot in secret at the blameless; they will shoot him suddenly, and will not fear.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "They have set up for themselves an evil matter, they have given counsel to hide snares; they have said, Who shall see them?",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "They have searched out iniquity; they have wearied themselves with searching diligently, a man shall approach and the heart is deep,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "and God shall be exalted, their wounds were caused by the weapon of the foolish children,",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "and their tongues have set him at nought, all that saw them were troubled;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "and every man was alarmed, and they related the works of God, and understood his deeds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.63.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "The righteous shall rejoice in the Lord, and hope on him, and all the upright in heart shall be praised.",
      "paragraphStart": false
    }
  ]
}
