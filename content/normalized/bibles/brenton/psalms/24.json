{
  "chapter": {
    "id": "brenton:psalms.24",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.24.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "A Psalm of David. - To thee, O Lord, have I lifted up my soul.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.24.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "O my God, I have trusted in thee: let me not be confounded, neither let mine enemies laugh me to scorn.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "For none of them that wait on thee shall in any wise be ashamed: let them be ashamed that transgress without cause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "Shew me thy ways, O Lord; and teach me thy paths.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "Lead me in thy truth, and teach me: for thou art God my Saviour: and I have waited on thee all the day.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "Remember thy compassions, O Lord, and thy mercies, for they are from everlasting.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Remember not the sins of my youth, nor my sins of ignorance: remember me according to thy mercy, for thy goodness’ sake, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Good and upright is the Lord: therefore will he instruct sinners in the way.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "The meek will he guide in judgement: the meek will he teach his ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "All the ways of the Lord are mercy and truth to them that seek his covenant and his testimonies.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Psalms 24:11",
      "text": "For thy name’s sake, O Lord, do thou also be merciful to my sin; for it is great.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Psalms 24:12",
      "text": "Who is the man that fears the Lord? he shall instruct him in the way which he has chosen.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Psalms 24:13",
      "text": "His soul shall dwell in prosperity; and his seed shall inherit the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Psalms 24:14",
      "text": "The Lord is the strength of them that fear him; and his covenant is to manifest truth to them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Psalms 24:15",
      "text": "Mine eyes are continually to the Lord; for he shall draw my feet out of the snare.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Psalms 24:16",
      "text": "Look upon me, and have mercy upon me; for I am an only child and poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Psalms 24:17",
      "text": "The afflictions of my heart have been multiplied; deliver me from my distresses.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Psalms 24:18",
      "text": "Look upon mine affliction and my trouble; and forgive all my sins.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Psalms 24:19",
      "text": "Look upon mine enemies; for they have been multiplied; and they have hated me with unjust hatred.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Psalms 24:20",
      "text": "Keep my soul, and deliver me: let me not be ashamed; for I have hoped in thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Psalms 24:21",
      "text": "The harmless and upright joined themselves to me: for I waited for thee, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.24.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Psalms 24:22",
      "text": "Deliver Israel, O God, out of all his afflictions.",
      "paragraphStart": false
    }
  ]
}
