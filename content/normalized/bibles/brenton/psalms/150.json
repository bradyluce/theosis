{
  "chapter": {
    "id": "brenton:psalms.150",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.150.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Alleluia. Praise God in his holy places: praise him in the firmament of his power.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.150.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Praise him on account of his mighty acts: praise him according to his abundant greatness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.150.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Praise him with the sound of a trumpet: praise him with psaltery and harp.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.150.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Praise him with timbrel and dance: praise him with stringed instruments and the organ.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.150.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Praise him with melodious cymbals: praise him with loud cymbals.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.150.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Let every thing that has breath praise the Lord.",
      "paragraphStart": false
    }
  ]
}
