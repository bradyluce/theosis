{
  "chapter": {
    "id": "brenton:psalms.103",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.103.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "A Psalm of David. - Bless the Lord, O my soul. O Lord my God, thou art very great; thou hast clothed thyself with praise and honour:",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.103.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "who dost robe thyself with light as with a garment; spreading out the heaven as a curtain.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "Who covers his chambers with waters; who makes the clouds his chariot; who walks on the wings of the wind.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "Who makes his angels spirits, and his ministers a flaming fire.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "Who establishes the earth on her sure foundation: it shall not be moved for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "The deep, as it were a garment, is his covering: the waters shall stand on the hills.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "At thy rebuke they shall flee; at the voice of thy thunder they shall be alarmed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "They go up to the mountains, and down to the plains, to the place which thou hast founded for them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "Thou hast set a bound which they shall not pass, neither shall they turn again to cover the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "He sends forth his fountains among the valleys: the waters shall run between the mountains.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "They shall give drink to all the wild beasts of the field: the wild asses shall take of them to quench their thirst.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "By them shall the birds of the sky lodge: they shall utter a voice out of the midst of the rocks.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "He waters the mountains from his chambers: the earth shall be satisfied with the fruit of thy works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "He makes grass to grow for the cattle, and green herb for the service of men, to bring bread out of the earth;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "and wine makes glad the heart of man, to make his face cheerful with oil: and bread strengthens man’s heart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.16",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "The trees of the plain shall be full of sap; even the cedars of Libanus which he has planted.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.17",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "There the sparrows will build their nests; and the house of the heron takes the lead among them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.18",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "The high mountains are a refuge for the stags, and the rock for the rabbits.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.19",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "He appointed the moon for seasons: the sun knows his going down.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.20",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Thou didst make darkness, and it was night; in it all the wild beasts of the forest will be abroad:",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.21",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "even young lions roaring for prey, and to seek meat for themselves from God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.22",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "The sun arises, and they shall be gathered together, and shall lie down in their dens.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.23",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 23,
      "referenceLabel": "Psalms 103:23",
      "text": "Man shall go forth to his work, and to his labour till evening.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.24",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 24,
      "referenceLabel": "Psalms 103:24",
      "text": "How great are thy works, O Lord! in wisdom hast thou wrought them all: the earth is filled with thy creation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.25",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 25,
      "referenceLabel": "Psalms 103:25",
      "text": "So is this great and wide sea: there are things creeping innumerable, small animals and great.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.26",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 26,
      "referenceLabel": "Psalms 103:26",
      "text": "There go the ships; and this dragon whom thou hast made to play in it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.27",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 27,
      "referenceLabel": "Psalms 103:27",
      "text": "All wait upon thee, to give them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.28",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 28,
      "referenceLabel": "Psalms 103:28",
      "text": "When thou hast given it them, they will gather it; and when thou hast opened thine hand, they shall all be filled with good.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.29",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 29,
      "referenceLabel": "Psalms 103:29",
      "text": "But when thou hast turned away thy face, they shall be troubled: thou wilt take away their breath, and they shall fail, and return to their dust.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.30",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 30,
      "referenceLabel": "Psalms 103:30",
      "text": "Thou shalt send forth thy Spirit, and they shall be created; and thou shalt renew the face of the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.31",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 31,
      "referenceLabel": "Psalms 103:31",
      "text": "Let the glory of the Lord be for ever: the Lord shall rejoice in his works;",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.32",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 32,
      "referenceLabel": "Psalms 103:32",
      "text": "who looks upon the earth, and makes it tremble; who touches the mountains, and they smoke.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.33",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 33,
      "referenceLabel": "Psalms 103:33",
      "text": "I will sing to the Lord while I live; I will sing praise to my God while I exist.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.34",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 34,
      "referenceLabel": "Psalms 103:34",
      "text": "Let my meditation be sweet to him: and I will rejoice in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.103.35",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 35,
      "referenceLabel": "Psalms 103:35",
      "text": "Let the sinners fail from off the earth, and transgressors, so that they shall be no more. Bless the Lord, O my soul.",
      "paragraphStart": false
    }
  ]
}
