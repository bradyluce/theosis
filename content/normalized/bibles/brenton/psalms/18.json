{
  "chapter": {
    "id": "brenton:psalms.18",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 18,
    "referenceLabel": "Psalms 18",
    "summary": "Source text for Psalms 18 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.18.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Psalms 18:1",
      "text": "For the end, a Psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.18.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Psalms 18:2",
      "text": "The heavens declare the glory of God; and the firmament proclaims the work of his hands.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Psalms 18:3",
      "text": "Day to day utters speech, and night to night proclaims knowledge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Psalms 18:4",
      "text": "There are no speeches or words, in which their voices are not heard.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Psalms 18:5",
      "text": "✡ Their voice is gone out into all the earth, and their words to the ends of the world.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Psalms 18:6",
      "text": "In the sun he has set his tabernacle; and he comes forth as a bridegroom out of his chamber: he will exult as a giant to run his course.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Psalms 18:7",
      "text": "His going forth is from the extremity of heaven, and his circuit to the other end of heaven: and no one shall be hidden from his heat.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Psalms 18:8",
      "text": "The law of the Lord is perfect, converting souls: the testimony of the Lord is faithful, instructing babes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Psalms 18:9",
      "text": "The ordinances of the Lord are right, rejoicing the heart: the commandment of the Lord is bright, enlightening the eyes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Psalms 18:10",
      "text": "The fear of the Lord is pure, enduring for ever and ever: the judgments of the Lord are true, and justified altogether.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Psalms 18:11",
      "text": "To be desired more than gold, and much precious stone: sweeter also than honey and the honey-comb.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Psalms 18:12",
      "text": "For thy servant keeps to them: in the keeping of them there is great reward.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Psalms 18:13",
      "text": "Who will understand his transgressions? purge thou me from my secret sins.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Psalms 18:14",
      "text": "And spare thy servant the attack of strangers: if they do not gain the dominion over me, then shall I be blameless, and I shall be clear from great sin. ✡ 18:5",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.18.15",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Psalms 18:15",
      "text": "So shall the sayings of my mouth, and the meditation of my heart, be pleasing continually before thee, O Lord my helper, and my redeemer.",
      "paragraphStart": false
    }
  ]
}
