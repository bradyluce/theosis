{
  "chapter": {
    "id": "brenton:psalms.55",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 55,
    "referenceLabel": "Psalms 55",
    "summary": "Source text for Psalms 55 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.55.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 1,
      "referenceLabel": "Psalms 55:1",
      "text": "For the end, concerning the people that were removed from the sanctuary, by David for a memorial, when the Philistines caught him in Geth.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.55.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 2,
      "referenceLabel": "Psalms 55:2",
      "text": "Have mercy upon me, O God; for man has trodden me down; all the day long he warring has afflicted me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 3,
      "referenceLabel": "Psalms 55:3",
      "text": "Mine enemies have trodden me down all the day from the dawning of the day; for there are many warring against me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 4,
      "referenceLabel": "Psalms 55:4",
      "text": "They shall be afraid, but I will trust in thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 5,
      "referenceLabel": "Psalms 55:5",
      "text": "In God I will praise my words; all the day have I hoped in God; I will not fear what flesh shall do to me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 6,
      "referenceLabel": "Psalms 55:6",
      "text": "All the day long they have abominated my words; all their devices are against me for evil.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 7,
      "referenceLabel": "Psalms 55:7",
      "text": "They will dwell near and hide themselves; they will watch my steps, accordingly as I have waited patiently in my soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 8,
      "referenceLabel": "Psalms 55:8",
      "text": "Thou wilt on no account save them; thou wilt bring down the people in wrath.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 9,
      "referenceLabel": "Psalms 55:9",
      "text": "O God, I have declared my life to thee; thou hast set my tears before thee, even according to thy promise.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 10,
      "referenceLabel": "Psalms 55:10",
      "text": "Mine enemies shall be turned back, in the day wherein I shall call upon thee; behold, I know that thou art my God.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 11,
      "referenceLabel": "Psalms 55:11",
      "text": "In God will I praise his word; in the Lord will I praise his saying.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 12,
      "referenceLabel": "Psalms 55:12",
      "text": "I have hoped in God; I will not be afraid of what man shall do to me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 13,
      "referenceLabel": "Psalms 55:13",
      "text": "The vows of thy praise, O God, which I will pay, are upon me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.55.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 55,
      "verseNumber": 14,
      "referenceLabel": "Psalms 55:14",
      "text": "For thou hast delivered my soul from death, and my feet from sliding, that I should be well-pleasing before God in the land of the living.",
      "paragraphStart": false
    }
  ]
}
