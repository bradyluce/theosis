{
  "chapter": {
    "id": "brenton:psalms.20",
    "translationId": "brenton",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:psalms.20.1",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "For the end, a Psalm of David.",
      "paragraphStart": true
    },
    {
      "id": "brenton:psalms.20.2",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "O Lord, the king shall rejoice in thy strength; and in thy salvation he shall greatly exult.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.3",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "Thou hast granted him the desire of his soul, and hast not withheld from him the request of his lips. Pause.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.4",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "For thou hast prevented him with blessings of goodness: thou hast set upon his head a crown of precious stone.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.5",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "He asked life of thee, and thou gavest him length of days for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.6",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "His glory is great in thy salvation: thou wilt crown him with glory and majesty.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.7",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "For thou wilt give him a blessing for ever and ever: thou wilt gladden him with joy with thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.8",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "For the king trusts in the Lord, and through the mercy of the Highest he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.9",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Let thy hand be found by all thine enemies: let thy right hand find all that hate thee.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.10",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Psalms 20:10",
      "text": "Thou shalt make them as a fiery oven at the time of thy presence: the Lord shall trouble them in his anger, and fire shall devour them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.11",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Psalms 20:11",
      "text": "Thou shalt destroy their fruit from the earth, and their seed from among the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.12",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Psalms 20:12",
      "text": "For they intended evils against thee; they imagined a device which they shall by no means be able to perform.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.13",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Psalms 20:13",
      "text": "For thou shalt make them turn their back in thy latter end, thou wilt prepare their face.",
      "paragraphStart": false
    },
    {
      "id": "brenton:psalms.20.14",
      "translationId": "brenton",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Psalms 20:14",
      "text": "Be thou exalted, O Lord, in thy strength: we will sing and praise thy mighty acts.",
      "paragraphStart": false
    }
  ]
}
