{
  "chapter": {
    "id": "brenton:proverbs.10",
    "translationId": "brenton",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:proverbs.10.1",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "A wise son makes his father glad: but a foolish son is a grief to his mother.",
      "paragraphStart": true
    },
    {
      "id": "brenton:proverbs.10.2",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Treasures shall not profit the lawless: but righteousness shall deliver from death.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.3",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "The Lord will not famish a righteous soul: but he will overthrow the life of the ungodly.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.4",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "Poverty brings a man low: but the hands of the vigorous make rich. 4a A son who is instructed shall be wise, and shall use the fool for a servant.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.5",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "A wise son is saved from heat: but a lawless son is blighted of the winds in harvest.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.6",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "The blessing of the Lord is upon the head of the just: but untimely grief shall cover the mouth of the ungodly.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.7",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "The memory of the just is praised; but the name of the ungodly man is extinguished.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.8",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "A wise man in heart will receive commandments; but he that is unguarded in his lips shall be overthrown in his perverseness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.9",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "He that walks simply, walks confidently; but he that perverts his ways shall be known.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.10",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "He that winks with his eyes deceitfully, procures griefs for men; but he that reproves boldly is a peacemaker.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.11",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "There is a fountain of life in the hand of a righteous man; but destruction shall cover the mouth of the ungodly.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.12",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Hatred stirs up strife; but affection covers all that do not love strife.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.13",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "He that brings forth wisdom from his lips smites the fool with a rod.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.14",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "The wise will hide discretion; but the mouth of the hasty draws near to ruin.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.15",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "The wealth of rich men is a strong city; but poverty is the ruin of the ungodly.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.16",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "The works of the righteous produce life; but the fruits of the ungodly produce sins.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.17",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "Instruction keeps the right ways of life; but instruction unchastened goes astray.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.18",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "Righteous lips cover enmity; but they that utter railings are most foolish.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.19",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "By a multitude of words thou shalt not escape sin; but if thou refrain thy lips thou wilt be prudent.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.20",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "The tongue of the just is tried silver; but the heart of the ungodly shall fail.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.21",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "The lips of the righteous know sublime truths: but the foolish die in want.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.22",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "The blessing of the Lord is upon the head of the righteous; it enriches him, and grief of heart shall not be added to it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.23",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "A fool does mischief in sport; but wisdom brings forth prudence for a man.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.24",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "The ungodly is engulphed in destruction; but the desire of the righteous is acceptable.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.25",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "When the storm passes by, the ungodly vanishes away; but the righteous turns aside and escapes for ever.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.26",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "As a sour grape is hurtful to the teeth, and smoke to the eyes, so iniquity hurts those that practise it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.27",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "The fear of the Lord adds length of days: but the years of the ungodly shall be shortened.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.28",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "Joy rests long with the righteous: but the hope of the ungodly shall perish.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.29",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "The fear of the Lord is a strong hold of the saints: but ruin comes to them that work wickedness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.30",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "The righteous shall never fail: but the ungodly shall not dwell in the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.31",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "The mouth of the righteous drops wisdom: but the tongue of the unjust shall perish.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.10.32",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "The lips of just men drop grace: but the mouth of the ungodly is perverse.",
      "paragraphStart": false
    }
  ]
}
