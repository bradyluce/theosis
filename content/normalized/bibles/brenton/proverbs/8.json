{
  "chapter": {
    "id": "brenton:proverbs.8",
    "translationId": "brenton",
    "bookSlug": "proverbs",
    "chapterNumber": 8,
    "referenceLabel": "Proverbs 8",
    "summary": "Source text for Proverbs 8 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:proverbs.8.1",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 8:1",
      "text": "Thou shalt proclaim wisdom, that understanding may be obedient to thee.",
      "paragraphStart": true
    },
    {
      "id": "brenton:proverbs.8.2",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 8:2",
      "text": "For she is on lofty eminences, and stands in the midst of the ways.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.3",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 8:3",
      "text": "For she sits by the gates of princes, and sings in the entrances, saying,",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.4",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 8:4",
      "text": "You, O men, I exhort; and utter my voice to the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.5",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 8:5",
      "text": "O ye simple, understand subtlety, and ye that are untaught, imbibe knowledge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.6",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 8:6",
      "text": "Hearken to me; for I will speak solemn truths; and will produce right sayings from my lips.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.7",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 8:7",
      "text": "For my throat shall meditate truth; and false lips are an abomination before me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.8",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 8:8",
      "text": "All the words of my mouth are in righteousness; there is nothing in them wrong or perverse.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.9",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 8:9",
      "text": "They are all evident to those that understand, and right to those that find knowledge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.10",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 8:10",
      "text": "Receive instruction, and not silver; and knowledge rather than tried gold.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.11",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 8:11",
      "text": "For wisdom is better than precious stones; and no valuable substance is of equal worth with it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.12",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 8:12",
      "text": "I wisdom have dwelt with counsel and knowledge, and I have called upon understanding.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.13",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 8:13",
      "text": "The fear of the Lord hates unrighteousness, and insolence, and pride, and the ways of wicked men; and I hate the perverse ways of bad men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.14",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 8:14",
      "text": "Counsel and safety are mine: prudence is mine, and strength is mine.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.15",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 8:15",
      "text": "By me kings reign, and princes decree justice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.16",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 8:16",
      "text": "By me nobles become great, and monarchs by me rule over the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.17",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 8:17",
      "text": "I love those that love me; and they that seek me shall find me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.18",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 8:18",
      "text": "Wealth and glory belong to me; yea, abundant possessions and righteousness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.19",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 8:19",
      "text": "It is better to have my fruit than to have gold and precious stones; and my produce is better than choice silver.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.20",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 8:20",
      "text": "I walk in ways of righteousness, and am conversant with the paths of judgment;",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.21",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 8:21",
      "text": "that I may divide substance to them that love me, and may fill their treasures with good things. 21a If I declare to you the things that daily happen, I will remember also to recount the things of old.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.22",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 8:22",
      "text": "The Lord made me the beginning of his ways for his works.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.23",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 8:23",
      "text": "He established me before time was in the beginning, before he made the earth:",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.24",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 8:24",
      "text": "even before he made the depths; before the fountains of water came forth:",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.25",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 8:25",
      "text": "before the mountains were settled, and before all hills, he begets me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.26",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 8:26",
      "text": "The Lord made countries and uninhabited tracts, and the highest inhabited parts of the world.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.27",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 8:27",
      "text": "When he prepared the heaven, I was present with him; and when he prepared his throne upon the winds:",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.28",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 8:28",
      "text": "and when he strengthened the clouds above; and when he secured the fountains of the earth:",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.29",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 8:29",
      "text": "and when he strengthened the foundations of the earth:",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.30",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 8:30",
      "text": "I was by him, suiting myself to him, I was that wherein he took delight; and daily I rejoiced in his presence continually.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.31",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 8:31",
      "text": "For he rejoiced when he had completed the world, and rejoiced among the children of men. Proverbs 9:18d",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.32",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 8:32",
      "text": "Now then, my son, hear me: blessed is the man who shall hearken to me, and the mortal who shall keep my ways;",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.34",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 8:34",
      "text": "watching daily at my doors, waiting at the posts of my entrances.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.35",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 8:35",
      "text": "For my outgoings are the outgoings of life, and in them is prepared favour from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.8.36",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Proverbs 8:36",
      "text": "But they that sin against me act wickedly against their own souls: and they that hate me love death.",
      "paragraphStart": false
    }
  ]
}
