{
  "chapter": {
    "id": "brenton:proverbs.14",
    "translationId": "brenton",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:proverbs.14.1",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Wise women build houses: but a foolish one digs hers down with her hands.",
      "paragraphStart": true
    },
    {
      "id": "brenton:proverbs.14.2",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "He that walks uprightly fears the Lord; but he that is perverse in his ways shall be dishonoured.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.3",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "Out of the mouth of fools comes a rod of pride; but the lips of the wise preserve them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.4",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Where no oxen are, the cribs are clean; but where there is abundant produce, the strength of the ox is apparent.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.5",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "A faithful witness does not lie; but an unjust witness kindles falsehoods.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.6",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "Thou shalt seek wisdom with bad men, and shalt not find it; but discretion is easily available with the prudent.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.7",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "All things are adverse to a foolish man; but wise lips are the weapons of discretion.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.8",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "The wisdom of the prudent will understand their ways; but the folly of fools leads astray.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.9",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "The houses of transgressors will need purification; but the houses of the just are acceptable.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.10",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "If a man's mind is intelligent, his soul is sorrowful; and when he rejoices, he has no fellowship with pride.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.11",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "The houses of ungodly men shall be utterly destroyed; but the tabernacles of them that walk uprightly shall stand.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.12",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "There is a way which seems to be right with men, but the ends of it reach to the depth of hell.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.13",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Grief mingles not with mirth; and joy in the end comes to grief.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.14",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "A stout-hearted man shall be filled with his own ways; and a good man with his own thoughts.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.15",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "The simple believes every word: but the prudent man betakes himself to afterthought.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.16",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "A wise man fears, and departs from evil; but the fool trusts in himself, and joins himself with the transgressor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.17",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "A passionate man acts inconsiderately; but a sensible man bears up under many things.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.18",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "Fools shall have mischief for their portion; but the prudent shall take fast hold of understanding.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.19",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "Evil men shall fall before the good; and the ungodly shall attend at the gates of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.20",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "Friends will hate poor friends; but the friends of the rich are many.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.21",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "He that dishonours the needy sins: but he that has pity on the poor is most blessed.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.22",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "They that go astray devise evils: but the good devise mercy and truth. The framers of evil do not understand mercy and truth: but compassion and faithfulness are with the framers of good.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.23",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "With every one who is careful there is abundance: but the pleasure-taking and indolent shall be in want.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.24",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "A prudent man is the crown of the wise: but the occupation of fools is evil.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.25",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "A faithful witness shall deliver a soul from evil: but a deceitful man kindles falsehoods.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.26",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "In the fear of the Lord is strong confidence: and he leaves his children a support.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.27",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "The commandment of the Lord is a fountain of life; and it causes men to turn aside from the snare of death.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.28",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "In a populous nation is the glory of a king: but in the failure of people is the ruin of a prince.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.29",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "A man slow to wrath abounds in wisdom: but a man of impatient spirit is very foolish.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.30",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "A meek-spirited man is a healer of the heart: but a sensitive heart is a corruption of the bones.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.31",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "He that oppresses the needy provokes his Maker: but he that honours him has pity upon the poor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.32",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "The ungodly shall be driven away in his wickedness: but he who is secure in his own holiness is just.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.33",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "There is wisdom in the good heart of a man: but in the heart of fools it is not discerned.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.34",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Righteousness exalts a nation: but sins diminish tribes.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.14.35",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "An understanding servant is acceptable to a king; and by his good behaviour he removes disgrace.",
      "paragraphStart": false
    }
  ]
}
