{
  "chapter": {
    "id": "brenton:proverbs.27",
    "translationId": "brenton",
    "bookSlug": "proverbs",
    "chapterNumber": 27,
    "referenceLabel": "Proverbs 27",
    "summary": "Source text for Proverbs 27 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:proverbs.27.1",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 27:1",
      "text": "Boast not of to-morrow; for thou knowest not what the next day shall bring forth.",
      "paragraphStart": true
    },
    {
      "id": "brenton:proverbs.27.2",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 27:2",
      "text": "Let thy neighbour, and not thine own mouth, praise thee; a stranger, and not thine own lips.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.3",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 27:3",
      "text": "A stone is heavy, and sand cumbersome; but a fool's wrath is heavier than both.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.4",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 27:4",
      "text": "Wrath is merciless, and anger sharp: but envy can bear nothing.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.5",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 27:5",
      "text": "Open reproofs are better than secret love.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.6",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 27:6",
      "text": "The wounds of a friend are more to be trusted than the spontaneous kisses of an enemy.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.7",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 27:7",
      "text": "A full soul scorns honeycombs; but to a hungry soul even bitter things appear sweet.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.8",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 27:8",
      "text": "As when a bird flies down from its own nest, so a man is brought into bondage whenever he estranges himself from his own place.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.9",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 27:9",
      "text": "The heart delights in ointments and wines and perfumes: but the soul is broken by calamities.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.10",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 27:10",
      "text": "Thine own friend, and thy father's friend, forsake not; and when thou art in distress go not into thy brother's house: better is a friend that is near than a brother living far off.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.11",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 27:11",
      "text": "Son, be wise, that thy heart may rejoice; and remove thou from thyself reproachful words.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.12",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 27:12",
      "text": "A wise man, when evils are approaching, hides himself; but fools pass on, and will be punished.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.13",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 27:13",
      "text": "Take away the man's garment, (for a scorner has passed by) whoever lays waste another's goods.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.14",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 27:14",
      "text": "Whosoever shall bless a friend in the morning with a loud voice, shall seem to differ nothing from one who curses him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.15",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 27:15",
      "text": "On a stormy day drops of rain drive a man out of his house; so also does a railing woman drive a man out of his own house.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.16",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 27:16",
      "text": "The north wind is sharp, but it is called by name propitious.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.17",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 27:17",
      "text": "Iron sharpens iron; and a man sharpens his friend's countenance.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.18",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 27:18",
      "text": "He that plants a fig-tree shall eat the fruits of it: so he that waits on his own master shall be honoured.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.19",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 27:19",
      "text": "As faces are not like other faces, so neither are the thoughts of men.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.20",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 27:20",
      "text": "Hell and destruction are not filled; so also are the eyes of men insatiable. 20a [He that fixes his eye is an abomination to the Lord; and the uninstructed do not restrain their tongue.]",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.21",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 27:21",
      "text": "Fire is the trial for silver and gold; and a man is tried by the mouth of them that praise him. 21a The heart of the transgressor seeks after mischiefs; but an upright heart seeks knowledge.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.22",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 27:22",
      "text": "Though thou scourge a fool, disgracing him in the midst of the council, thou wilt still in no wise remove his folly from him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.23",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 27:23",
      "text": "Do thou thoroughly know the number of thy flock, and pay attention to thine herds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.24",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 27:24",
      "text": "For a man has not strength and power for ever; neither does he transmit it from generation to generation.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.25",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 27:25",
      "text": "Take care of the herbage in the field, and thou shalt cut grass, and gather the mountain hay;",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.26",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 27:26",
      "text": "that thou mayest have wool of sheep for clothing: pay attention to the land, that thou mayest have lambs.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.27.27",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 27,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 27:27",
      "text": "My son, thou hast from me words very useful for thy life, and for the life of thy servants.",
      "paragraphStart": false
    }
  ]
}
