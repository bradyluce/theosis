{
  "chapter": {
    "id": "brenton:proverbs.29",
    "translationId": "brenton",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:proverbs.29.1",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "A reprover is better than a stiff-necked man: for when the latter is suddenly set on fire, there shall be no remedy.",
      "paragraphStart": true
    },
    {
      "id": "brenton:proverbs.29.2",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "When the righteous are praised, the people will rejoice: but when the ungodly rule, men mourn.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.3",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "When a man loves wisdom, his father rejoices: but he that keeps harlots will waste wealth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.4",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "A righteous king establishes a country: but a transgressor destroys it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.5",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "He that prepares a net in the way of his own friend, entangles his own feet in it.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.6",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "A great snare is spread for a sinner: but the righteous shall be in joy and gladness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.7",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "A righteous man knows how to judge for the poor: but the ungodly understands not knowledge; and the poor man has not an understanding mind.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.8",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Lawless men burn down a city: but wise men turn away wrath.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.9",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "A wise man shall judge nations: but a worthless man being angry laughs and fears not.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.10",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "Bloody men hate a holy person, but the upright will seek his soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.11",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "A fool utters all his mind: but the wise reserves his in part.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.12",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "When a king hearkens to unjust language, all his subjects are transgressors.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.13",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "When the creditor and debtor meet together, the Lord oversees them both.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.14",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "When a king judges the poor in truth, his throne shall be established for a testimony.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.15",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "Stripes and reproofs give wisdom: but an erring child disgraces his parents.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.16",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "When the ungodly abound, sins abound: but when they fall, the righteous are warned.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.17",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Chasten thy son, and he shall give thee rest; and he shall give honour to thy soul.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.18",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "There shall be no interpreter to a sinful nation: but he that observes the law is",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.19",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "A stubborn servant will not be reproved by words: for even if he understand, still he will not obey.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.20",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "If thou see a man hasty in his words, know that the fool has hope rather than he.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.21",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "He that lives wantonly from a child, shall be a servant, and in the end shall grieve over himself.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.22",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "A furious man stirs up strife, and a passionate man digs up sin.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.23",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "Pride brings a man low, but the Lord upholds the humble-minded with honour.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.24",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "He that shares with a thief, hates his own soul: and if any having heard an oath uttered tell not of it,",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.25",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "they fearing and reverencing men unreasonably have been overthrown, but he that trusts in the Lord shall rejoice. Ungodliness causes a man to stumble: but he that trusts in his master shall be safe.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.26",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Many wait on the favour of rulers; but justice comes to a man from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.29.27",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "A righteous man is an abomination to an unrighteous man, and the direct way is an abomination to the sinner. 1",
      "paragraphStart": false
    }
  ]
}
