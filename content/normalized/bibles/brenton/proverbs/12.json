{
  "chapter": {
    "id": "brenton:proverbs.12",
    "translationId": "brenton",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:proverbs.12.1",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "He that loves instruction loves sense, but he that hates reproofs is a fool.",
      "paragraphStart": true
    },
    {
      "id": "brenton:proverbs.12.2",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "He that has found favour with the Lord is made better; but a transgressor shall be passed over in silence.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.3",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "A man shall not prosper by wickedness; but the roots of the righteous shall not be taken up.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.4",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "A virtuous woman is a crown to her husband; but as a worm in wood, so a bad woman destroys her husband.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.5",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "The thoughts of the righteous are true judgments; but ungodly men devise deceits.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.6",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "The words of ungodly men are crafty; but the mouth of the upright shall deliver them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.7",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "When the ungodly is overthrown, he vanishes away; but the houses of the just remain.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.8",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "The mouth of an understanding man is praised by a man; but he that is dull of heart is had in derision.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.9",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "Better is a man in dishonour serving himself, than one honouring himself and wanting bread.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.10",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "A righteous man has pity for the lives of his cattle; but the bowels of the ungodly are unmerciful.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.11",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "He that tills his own land shall be satisfied with bread; but they that pursue vanities are void of understanding. 11a He that enjoys himself in banquets of wine, shall leave dishonour in his own strong holds.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.12",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "The desires of the ungodly are evil; but the roots of the godly are firmly set.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.13",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "For the sin of his lips a sinner falls into snares; but a righteous man escapes from them. 13a He whose looks are gentle shall be pitied, but he that contends in the gates will afflict souls.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.14",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "The soul of a man shall be filled with good from the fruits of his mouth; and the recompence of his lips shall be given to him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.15",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "The ways of fools are right in their own eyes; but a wise man hearkens to counsels.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.16",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "A fool declares his wrath the same day; but a prudent man hides his own disgrace.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.17",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "A righteous man declares the open truth; but an unjust witness is deceitful.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.18",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "Some wound as they speak, like swords; but the tongues of the wise heal.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.19",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "True lips establish testimony; but a hasty witness has an unjust tongue.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.20",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "There is deceit in the heart of him that imagines evil; but they that love peace shall rejoice.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.21",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "No injustice will please a just man; but the ungodly will be filled with mischief.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.22",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Lying lips are an abomination to the Lord; but he that deals faithfully is accepted with him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.23",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "An understanding man is a throne of wisdom; but the heart of fools shall meet with curses.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.24",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "The hand of chosen men shall easily obtain rule; but the deceitful shall be for a prey.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.25",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "A terrible word troubles the heart of a righteous man; but a good message rejoices him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.26",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "A just arbitrator shall be his own friend; but mischief shall pursue sinners; and the way of ungodly men shall lead them astray.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.27",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "A deceitful man shall catch no game; but a blameless man is a precious possession.",
      "paragraphStart": false
    },
    {
      "id": "brenton:proverbs.12.28",
      "translationId": "brenton",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "In the ways of righteousness is life; but the ways of those that remember injuries lead to death.",
      "paragraphStart": false
    }
  ]
}
