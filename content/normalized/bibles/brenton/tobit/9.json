{
  "chapter": {
    "id": "brenton:tobit.9",
    "translationId": "brenton",
    "bookSlug": "tobit",
    "chapterNumber": 9,
    "referenceLabel": "Tobit 9",
    "summary": "Source text for Tobit 9 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:tobit.9.1",
      "translationId": "brenton",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Tobit 9:1",
      "text": "Then Tobias called Raphael, and said unto him,",
      "paragraphStart": true
    },
    {
      "id": "brenton:tobit.9.2",
      "translationId": "brenton",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Tobit 9:2",
      "text": "Brother Azarias, take with thee a servant, and two camels, and go to Rages of Media to Gabael, and bring me the money, and bring him to the wedding.",
      "paragraphStart": false
    },
    {
      "id": "brenton:tobit.9.3",
      "translationId": "brenton",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Tobit 9:3",
      "text": "For Raguel hath sworn that I shall not depart.",
      "paragraphStart": false
    },
    {
      "id": "brenton:tobit.9.4",
      "translationId": "brenton",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Tobit 9:4",
      "text": "But my father counteth the days; and if I tarry long, he will be very sorry.",
      "paragraphStart": false
    },
    {
      "id": "brenton:tobit.9.5",
      "translationId": "brenton",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Tobit 9:5",
      "text": "So Raphael went out, and lodged with Gabael, and gave him the handwriting: who brought forth bags which were sealed up, and gave them to him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:tobit.9.6",
      "translationId": "brenton",
      "bookSlug": "tobit",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Tobit 9:6",
      "text": "And early in the morning they went forth both together, and came to the wedding: and Tobias blessed his wife.",
      "paragraphStart": false
    }
  ]
}
