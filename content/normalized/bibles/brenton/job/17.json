{
  "chapter": {
    "id": "brenton:job.17",
    "translationId": "brenton",
    "bookSlug": "job",
    "chapterNumber": 17,
    "referenceLabel": "Job 17",
    "summary": "Source text for Job 17 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:job.17.1",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Job 17:1",
      "text": "I perish, carried away by the wind, and I seek for burial, and obtain it not.",
      "paragraphStart": true
    },
    {
      "id": "brenton:job.17.2",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Job 17:2",
      "text": "Weary I intreat; and what have I done? and strangers have stolen my goods.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.3",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Job 17:3",
      "text": "Who is this? let him join hands with me.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.4",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Job 17:4",
      "text": "For thou hast hid their heart from wisdom; therefore thou shalt not exalt them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.5",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Job 17:5",
      "text": "He shall promise mischief to his companions: but their eyes have failed for their children.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.6",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Job 17:6",
      "text": "But thou hast made me a byword among the nations, and I am become a scorn to them.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.7",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Job 17:7",
      "text": "For my eyes are dimmed through pain; I have been grievously beset by all.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.8",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Job 17:8",
      "text": "Wonder has seized true men upon this; and let the just rise up against the transgressor.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.9",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Job 17:9",
      "text": "But let the faithful hold on his own way, and let him that is pure of hands take courage.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.10",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Job 17:10",
      "text": "Howbeit, do ye all strengthen yourselves and come now, for I do not find truth in you.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.11",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Job 17:11",
      "text": "My days have passed in groaning, and my heart-strings are broken.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.12",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Job 17:12",
      "text": "I have turned the night into day: the light is short because of darkness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.13",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Job 17:13",
      "text": "For if I remain, Hades is my habitation: and my bed has been made in darkness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.14",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Job 17:14",
      "text": "I have called upon death to be my father, and corruption to be my mother and sister.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.15",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Job 17:15",
      "text": "Where then is yet my hope? or where shall I see my good?",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.17.16",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Job 17:16",
      "text": "Will they go down with me to Hades, or shall we go down together to the tomb?",
      "paragraphStart": false
    }
  ]
}
