{
  "chapter": {
    "id": "brenton:job.18",
    "translationId": "brenton",
    "bookSlug": "job",
    "chapterNumber": 18,
    "referenceLabel": "Job 18",
    "summary": "Source text for Job 18 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:job.18.1",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Job 18:1",
      "text": "Then Job answered and said,",
      "paragraphStart": true
    },
    {
      "id": "brenton:job.18.2",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Job 18:2",
      "text": "How long wilt thou continue? forbear, that we also may speak.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.3",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Job 18:3",
      "text": "For wherefore have we been silent before thee like brutes?",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.4",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Job 18:4",
      "text": "Anger has possessed thee: for what if thou shouldest die; would the earth under heaven be desolate? or shall the mountains be overthrown from their foundations?",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.5",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Job 18:5",
      "text": "But the light of the ungodly shall be quenched, and their flame shall not go up.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.6",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Job 18:6",
      "text": "His light shall be darkness in his habitation, and his lamp shall be put out with him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.7",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Job 18:7",
      "text": "Let the meanest of men spoil his goods, and let his counsel deceive him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.8",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Job 18:8",
      "text": "His foot also has been caught in a snare, and let it be entangled in a net.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.9",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Job 18:9",
      "text": "And let snares come upon him: he shall strengthen those that thirst for his destruction.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.10",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Job 18:10",
      "text": "His snare is hid in the earth, and that which shall take him is by the path.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.11",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Job 18:11",
      "text": "Let pains destroy him round about, and let many enemies come about him,",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.12",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Job 18:12",
      "text": "vex him with distressing hunger: and a signal destruction has been prepared for him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.13",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Job 18:13",
      "text": "Let the soles of his feet be devoured: and death shall consume his beauty.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.14",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Job 18:14",
      "text": "And let health be utterly banished from his tabernacle, and let distress seize upon him with a charge from the king.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.15",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Job 18:15",
      "text": "It shall dwell in his tabernacle in his night: his excellency shall be sown with brimstone.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.16",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Job 18:16",
      "text": "His roots shall be dried up from beneath, and his crop shall fall away from above.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.17",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Job 18:17",
      "text": "Let his memorial perish out of the earth, and his name shall be publicly cast out.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.18",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Job 18:18",
      "text": "Let one drive him from light into darkness.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.19",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Job 18:19",
      "text": "He shall not be known among his people, nor his house preserved on the earth.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.20",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Job 18:20",
      "text": "But strangers shall dwell in his possessions: the last groaned for him, and wonder seized the first.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.18.21",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Job 18:21",
      "text": "These are the houses of the unrighteous, and this is the place of them that know not the Lord.",
      "paragraphStart": false
    }
  ]
}
