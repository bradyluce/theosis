{
  "chapter": {
    "id": "brenton:job.25",
    "translationId": "brenton",
    "bookSlug": "job",
    "chapterNumber": 25,
    "referenceLabel": "Job 25",
    "summary": "Source text for Job 25 in Brenton Septuagint."
  },
  "verses": [
    {
      "id": "brenton:job.25.1",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "But Job answered and said,",
      "paragraphStart": true
    },
    {
      "id": "brenton:job.25.2",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "What beginning or fear is his—even he that makes all things in the highest?",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.25.3",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "For let none think that there is a respite for robbers: and upon whom will there not come a snare from him?",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.25.4",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "For how shall a mortal be just before the Lord? or who that is born of a woman shall purify himself?",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.25.5",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "If he gives an order to the moon, then it shines not; and the stars are not pure before him.",
      "paragraphStart": false
    },
    {
      "id": "brenton:job.25.6",
      "translationId": "brenton",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "But alas! man is corruption, and the son of man a worm.",
      "paragraphStart": false
    }
  ]
}
