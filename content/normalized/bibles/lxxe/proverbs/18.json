{
  "chapter": {
    "id": "lxxe:proverbs.18",
    "translationId": "lxxe",
    "bookSlug": "proverbs",
    "chapterNumber": 18,
    "referenceLabel": "Proverbs 18",
    "summary": "Source text for Proverbs 18 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:proverbs.18.1",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 18:1",
      "text": "A man who wishes to separate from friends seeks excuses; but at all times he will be liable to reproach.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:proverbs.18.2",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 18:2",
      "text": "A senseless man feels no need of wisdom, for he is rather led by folly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.3",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 18:3",
      "text": "When an ungodly man comes into a depth of evils, he despises them; but dishonour and reproach come upon him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.4",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 18:4",
      "text": "A word in the heart of a man is a deep water, and a river and fountain of life spring forth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.5",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 18:5",
      "text": "It is not good to accept the person of the ungodly, nor is it holy to pervert justice in judgement.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.6",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 18:6",
      "text": "The lips of a fool bring him into troubles, and his bold mouth calls for death.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.7",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 18:7",
      "text": "A fool’s mouth is ruin to him, and his lips are a snare to his soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.8",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 18:8",
      "text": "Fear casts down the slothful; and the souls of the effeminate shall hunger.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.9",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 18:9",
      "text": "A man who helps not himself by his labour is brother of him that ruins himself.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.10",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 18:10",
      "text": "The name of the Lord is of great strength; and the righteous running to it are exalted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.11",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 18:11",
      "text": "The wealth of a rich man is a strong city; and its glory casts a broad shadow.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.12",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 18:12",
      "text": "Before ruin a man’s heart is exalted, and before honour it is humble.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.13",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 18:13",
      "text": "Whoso answers a word before he hears a cause, it is folly and reproach to him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.14",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 18:14",
      "text": "A wise servant calms a man’s anger; but who can endure a faint-hearted man?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.15",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 18:15",
      "text": "The heart of the sensible man purchases discretion; and the ears of the wise seek understanding.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.16",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 18:16",
      "text": "A man’s gift enlarges him, and seats him among princes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.17",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 18:17",
      "text": "A righteous man accuses himself at the beginning of his speech, but when he has entered upon the attack, the adversary is reproved.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.18",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 18:18",
      "text": "A silent man quells strifes, and determines between great powers.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.19",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 18:19",
      "text": "A brother helped by a brother is as a strong and high city; and is as strong as a well-founded palace.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.20",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 18:20",
      "text": "A man fills his belly with the fruits of his mouth; and he shall be satisfied with the fruits of his lips.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.21",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 18:21",
      "text": "Life and death are in the power of the tongue; and they that rule it shall eat the fruits thereof.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.22",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 18:22",
      "text": "He that has found a good wife has found favours, and has received gladness from God. He that puts away a good wife, puts away a good thing, and he that keeps an adulteress is foolish and ungodly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.18.23",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 18:23",
      "text": "The folly of a man spoils his ways: and he blames God in his heart.",
      "paragraphStart": false
    }
  ]
}
