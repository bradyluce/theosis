{
  "chapter": {
    "id": "lxxe:proverbs.16",
    "translationId": "lxxe",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:proverbs.16.1",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "All the works of the humble man are manifest with God; but the ungodly shall perish in an evil day.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:proverbs.16.3",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "Every one that is proud in heart is unclean before God, and he that unjustly strikes hands with hand shall not be held guiltless.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.6",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "The beginning of a good way is to do justly; and it is more acceptable with God than to offer sacrifices.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.8",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "He that seeks the Lord shall find knowledge with righteousness: and they that rightly seek him shall find peace.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.9",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "All of the works of the Lord are done with righteousness; and the ungodly man is kept for the evil day.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.10",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "There is an oracle upon the lips of a king; and his mouth shall not err in judgement.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.11",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "The poise of the balance is righteousness with the Lord; and his works are righteous measures.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.12",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "An evil-doer is an abomination to a king; for the throne of rule is established by righteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.13",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "Righteous lips are acceptable to a king; and he loves right words.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.14",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "The anger of a king is a messenger of death; but a wise man will pacify him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.15",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "The son of a king is in the light of life; and they that are in favour with him are as a cloud of latter rain.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.16",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "The brood of wisdom is more to be chosen than gold, and the brood of prudence more to be chosen than silver.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.17",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "The paths of life turn aside from evil; and the ways of righteousness are length of life. He that receives instruction shall be in prosperity; and he that regards reproofs shall be made wise. He that keeps his ways, preserves his own soul; and he that loves his life will spare his mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.18",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "Pride goes before destruction, and folly before a fall.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.19",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "Better is a meek-spirited man with lowliness, than one who divides spoils with the proud.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.20",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "He who is skillful in business finds good: but he that trusts in God is most blessed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.21",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "Men call the wise and understanding evil: but they that are pleasing in speech shall hear more.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.22",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "Understanding is a fountain of life to its possessors; but the instruction of fools is evil.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.23",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "The heart of the wise will discern the things which proceed from his own mouth; and on his lips he will wear knowledge.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.24",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "Good words are honeycombs, and the sweetness thereof is a healing of the soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.25",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "There are ways that seem to be right to a man, but the end of them looks to the depth of hell.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.26",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "A man who labours, labours for himself, and drives from him his own ruin.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.27",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "But the perverse bears destruction upon his own mouth: a foolish man digs up evil for himself, and treasures fire on his own lips.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.28",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "A perverse man spreads mischief, and will kindle a torch of deceit with mischiefs; and he separates friends.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.29",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "A transgressor tries to ensnare friends, and leads them in ways that are not good.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.30",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "And the man that fixes his eyes devises perverse things, and marks out with his lips all evil: he is a furnace of wickedness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.31",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "Old age is a crown of honour, but it is found in the ways of righteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.32",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "A man slow to anger is better than a strong man; and he that governs his temper better than he that takes a city.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:proverbs.16.33",
      "translationId": "lxxe",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "All evils come upon the ungodly into their bosoms; but all righteous things come of the Lord.",
      "paragraphStart": false
    }
  ]
}
