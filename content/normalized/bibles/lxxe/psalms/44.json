{
  "chapter": {
    "id": "lxxe:psalms.44",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 44,
    "referenceLabel": "Psalms 44",
    "summary": "Source text for Psalms 44 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.44.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 1,
      "referenceLabel": "Psalms 44:1",
      "text": "For the end, a Psalm for instruction, for the sons of Core. - O God, we have heard with our ears, our fathers have told us, the work which thou wroughtest in their days, in the days of old.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.44.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 2,
      "referenceLabel": "Psalms 44:2",
      "text": "Thine hand utterly destroyed the heathen, and thou didst plant them: thou didst afflict the nations, and cast them out.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 3,
      "referenceLabel": "Psalms 44:3",
      "text": "For they inherited not the land by their own sword, and their own arm did not deliver them; but thy right hand, and thine arm, and the light of thy countenance, because thou wert well pleased in them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 4,
      "referenceLabel": "Psalms 44:4",
      "text": "Thou art indeed my King and my God, who commandest deliverances for Jacob.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 5,
      "referenceLabel": "Psalms 44:5",
      "text": "In thee will we push down our enemies, and in thy name will we bring to nought them that rise up against us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 6,
      "referenceLabel": "Psalms 44:6",
      "text": "For I will not trust in my bow, and my sword shall not save me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 7,
      "referenceLabel": "Psalms 44:7",
      "text": "For thou hast saved us from them that afflicted us, and hast put to shame them that hated us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 8,
      "referenceLabel": "Psalms 44:8",
      "text": "In God will we make our boast all the day, and to thy name will we give thanks for ever. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 9,
      "referenceLabel": "Psalms 44:9",
      "text": "But now thou hast cast off, and put us to shame; and thou wilt not go forth with our hosts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 10,
      "referenceLabel": "Psalms 44:10",
      "text": "Thou hast turned us back before our enemies; and they that hated us spoiled for themselves.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 11,
      "referenceLabel": "Psalms 44:11",
      "text": "Thou madest us as sheep for meat; and thou scatteredst us among the nations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 12,
      "referenceLabel": "Psalms 44:12",
      "text": "Thou hast sold thy people without price, and there was no profit by their exchange.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 13,
      "referenceLabel": "Psalms 44:13",
      "text": "Thou hast made us a reproach to our neighbours, a scorn and derision them that are round about us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 14,
      "referenceLabel": "Psalms 44:14",
      "text": "Thou hast made us a proverb among the Gentiles, a shaking of the head among the nations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 15,
      "referenceLabel": "Psalms 44:15",
      "text": "All the day my shame is before me, and the confusion of my face has covered me,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 16,
      "referenceLabel": "Psalms 44:16",
      "text": "because of the voice of the slanderer and reviler; because of the enemy and avenger.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 17,
      "referenceLabel": "Psalms 44:17",
      "text": "All these things are come upon us: but we have not forgotten thee, neither have we dealt unrighteously in thy covenant.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 18,
      "referenceLabel": "Psalms 44:18",
      "text": "And our heart has not gone back; but thou hast turned aside our paths from thy way.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 19,
      "referenceLabel": "Psalms 44:19",
      "text": "For thou hast laid us low in a place of affliction, and the shadow of death has covered us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 20,
      "referenceLabel": "Psalms 44:20",
      "text": "If we have forgotten the name of our God, and if we have spread out our hands to a strange god; shall not God search these things out?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 21,
      "referenceLabel": "Psalms 44:21",
      "text": "for he knows the secrets of the heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 22,
      "referenceLabel": "Psalms 44:22",
      "text": "For, for thy sake we are killed all the day long; we are counted as sheep for slaughter.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 23,
      "referenceLabel": "Psalms 44:23",
      "text": "Awake, wherefore sleepest thou, O Lord? arise, and do not cast us off for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 24,
      "referenceLabel": "Psalms 44:24",
      "text": "Wherefore turnest thou thy face away, and forgettest our poverty and our affliction?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 25,
      "referenceLabel": "Psalms 44:25",
      "text": "For our soul has been brought down to the dust; our belly has cleaved to the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.44.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 44,
      "verseNumber": 26,
      "referenceLabel": "Psalms 44:26",
      "text": "Arise, O Lord, help us, and redeem us for thy name’s sake.",
      "paragraphStart": false
    }
  ]
}
