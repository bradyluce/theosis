{
  "chapter": {
    "id": "lxxe:psalms.136",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 136,
    "referenceLabel": "Psalms 136",
    "summary": "Source text for Psalms 136 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.136.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "Alleluia. - Give thanks to the Lord: for he is good: for his mercy endures for ever.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.136.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "Give thanks to the God of gods; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "Give thanks to the Lord of lords: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "To him who along has wrought great wonders: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "To him who made the heavens by understanding; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "To him who established the earth on the waters; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "To him who alone made great lights; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "The sun to rule by day; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "The moon and the stars to rule the night; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 10,
      "referenceLabel": "Psalms 136:10",
      "text": "To him who smote Egypt with their first-born; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 11,
      "referenceLabel": "Psalms 136:11",
      "text": "And brought Israel out of the midst of them; for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 12,
      "referenceLabel": "Psalms 136:12",
      "text": "with a strong hand, and a high arm: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 13,
      "referenceLabel": "Psalms 136:13",
      "text": "To him who divided the Red Sea into parts: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 14,
      "referenceLabel": "Psalms 136:14",
      "text": "and brought Israel through the midst of it: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 15,
      "referenceLabel": "Psalms 136:15",
      "text": "and overthrew Pharao and his host in the Red Sea: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 16,
      "referenceLabel": "Psalms 136:16",
      "text": "To him who led his people through the wilderness: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 17,
      "referenceLabel": "Psalms 136:17",
      "text": "To him who smote great kings: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 18,
      "referenceLabel": "Psalms 136:18",
      "text": "and slew mighty kings; for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 19,
      "referenceLabel": "Psalms 136:19",
      "text": "Seon king of the Amorites: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 20,
      "referenceLabel": "Psalms 136:20",
      "text": "and Og king of Basan: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 21,
      "referenceLabel": "Psalms 136:21",
      "text": "and gave their land for an inheritance: for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 22,
      "referenceLabel": "Psalms 136:22",
      "text": "even an inheritance to Israel his servant: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 23,
      "referenceLabel": "Psalms 136:23",
      "text": "For the Lord remembered us in our low estate; for his mercy endures for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 24,
      "referenceLabel": "Psalms 136:24",
      "text": "and redeemed us from our enemies; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 25,
      "referenceLabel": "Psalms 136:25",
      "text": "Who gives food to all flesh; for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.136.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 26,
      "referenceLabel": "Psalms 136:26",
      "text": "Give thanks to the God of heaven; for his mercy endures for ever.",
      "paragraphStart": false
    }
  ]
}
