{
  "chapter": {
    "id": "lxxe:psalms.29",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.29.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "A Psalm of David on the occasion of the solemn assembly of the Tabernacle. - Bring to the Lord, ye sons of God, bring to the Lord young rams; bring to the Lord glory and honour.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.29.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "Bring to the Lord glory, due to his name; worship the lord in his holy court.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "The voice of the Lord is upon the waters: the God of glory has thundered: the Lord is upon many waters.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "The voice of the Lord is mighty; the voice of the Lord is full of majesty.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "There is the voice of the Lord who breaks the cedars; the Lord will break the cedars of Libanus.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "And he will beat them small, even Libanus itself, like a calf; and the beloved one is as a young unicorn.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "There is a voice of the Lord who divides a flame of fire.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "A voice of the Lord who shakes the wilderness; the Lord will shake the wilderness of Cades.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "The voice of the Lord strengthens the hinds, and will uncover the thickets: and in his temple every one speaks of his glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "The Lord will dwell on the waterflood: and the Lord will sit a king for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.29.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "The Lord will give strength to his people; the Lord will bless his people with peace.",
      "paragraphStart": false
    }
  ]
}
