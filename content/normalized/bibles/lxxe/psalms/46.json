{
  "chapter": {
    "id": "lxxe:psalms.46",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.46.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "For the end, a Psalm for the sons of Core. - Clap your hands, all ye nations; shout to God with a voice of exultation.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.46.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "For the Lord most high is terrible; he is a great king over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "He has subdued the peoples under us, and the nations under our feet.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "He has chosen out his inheritance for us, the beauty of Jacob which he loved. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "God is gone up with a shout, the Lord with a sound of a trumpet.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "Sing praises to our God, sing praises: sing praises to our King, sing praises.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "For God is king of all the earth: sing praises with understanding.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "God reigns over the nations: God sits upon the throne of his holiness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "The rulers of the people are assembled with the God of Abraam: for God’s mighty ones of the earth have been greatly exalted.",
      "paragraphStart": false
    }
  ]
}
