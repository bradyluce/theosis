{
  "chapter": {
    "id": "lxxe:psalms.46",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.46.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "For the end, for the sons of Core; a Psalm concerning secret things. - God is our refuge and strength, a help in the afflictions that have come heavily upon us.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.46.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "Therefore will we not fear when the earth is troubled, and the mountains are removed into the depths of the seas.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "Their waters have roared and been troubled, the mountains have been troubled by his might. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "The flowings of the river gladden the city of God: the Most High has sanctified his tabernacle.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "God is in the midst of her; she shall not be moved: God shall help her with his countenance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "The nations were troubled, the kingdoms tottered: he uttered his voice, the earth shook.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "The Lord of hosts is with us; the God of Jacob is our helper. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "Come, and behold the works of the Lord, what wonders he has achieved on the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "Putting an end to wars as far as the ends of the earth; he will crush the bow, and break in pieces the weapon, and burn the bucklers with fire.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "Be still, and know that I am God: I will be exalted among the nations, I will be exalted in the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.46.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Psalms 46:11",
      "text": "The Lord of hosts is with us; the God of Jacob is our helper.",
      "paragraphStart": false
    }
  ]
}
