{
  "chapter": {
    "id": "lxxe:psalms.33",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.33.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "A Psalm of David. - Rejoice in the Lord, ye righteous; praise becomes the upright.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.33.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Praise the Lord on the harp; platy to him on a psaltery of ten strings.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "Sing to him a new song; play skillfully with a loud noise.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "For the word of the Lord is right; and all his works are faithful.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "He loves mercy and judgement; the earth is full the mercy of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "By the word of the Lord the heavens were established; and all the host of them by the breath of his mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "Who gathers the waters of the sea as in a bottle; who lays up the deeps in treasuries.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Let all the earth fear the Lord; and let all that dwell in the world be moved because of him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "For he spoke, and they were made; he commanded, and they were created.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "The Lord frustrates the counsels of the nations; he brings to nought also the reasonings of the peoples, and brings to nought the counsels of princes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "But the counsel of the Lord endures for ever, the thoughts of his heart from generation to generation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Blessed is the nation whose God is the Lord; the people whom he has chosen for his own inheritance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "The Lord looks out of heaven; he beholds all the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "He looks from his prepared habitation on all the dwellers on the earth;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "who fashioned their hearts alone; who understands all their works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "A king is not saved by reason of a great host; and a giant shall not be delivered by the greatness of his strength.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "A horse is vain for safety; neither shall he be delivered by the greatness of his power.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Behold, the eyes of the Lord are on them that fear him, those that hope in his mercy;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "to deliver their souls from death, and to keep them alive in famine.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Our soul waits on the Lord; for he is our helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "For our heart shall rejoice in him, and we have hoped in his holy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.33.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Let thy mercy, O Lord, be upon us, according as we have hoped in thee.",
      "paragraphStart": false
    }
  ]
}
