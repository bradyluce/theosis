{
  "chapter": {
    "id": "lxxe:psalms.21",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.21.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "For the end, a Psalm of David. - O Lord, the king shall rejoice in thy strength; and in thy salvation he shall greatly exult.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.21.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "Thou hast granted him the desire of his soul, and hast not withheld from him the request of his lips. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "For thou hast prevented him with blessings of goodness: thou has set upon his head a crown of precious stone.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "He asked life of thee, and thou gavest him length of days for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "His glory is great in thy salvation: thou wilt crown him with glory and majesty.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "For thou wilt give him a blessing for ever and ever: thou wilt gladden him with joy with thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "For the king trusts in the Lord, and through the mercy of the Highest he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "Let thy hand be found by all thine enemies: let thy right hand find all that hate thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "Thou shalt make them as a fiery oven at the time of thy presence: the Lord shall trouble them in his anger, and fire shall devour them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "Thou shalt destroy their fruit from the earth, and their seed from among the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "For they intended evils against thee; they imagined a device which they shall by no means be able to perform.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "For thou shalt make them turn their back in thy latter end, thou wilt prepare their face.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.21.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Be thou exalted, O Lord, in thy strength: we will sing and praise thy mighty acts.",
      "paragraphStart": false
    }
  ]
}
