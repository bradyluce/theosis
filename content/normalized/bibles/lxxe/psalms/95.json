{
  "chapter": {
    "id": "lxxe:psalms.95",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.95.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "When the house was built after the Captivity, a Song of David. - Sing to the Lord a new song; sing to the Lord, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.95.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Sing to the Lord, bless his name: proclaim his salvation from day to day.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "Publish his glory among the Gentiles, his wonderful works among all people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "For the Lord is great, and greatly to be praised: he is terrible above all gods.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "For all the gods of the heathen are devils: but the Lord made the heavens.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "Thanksgiving and beauty are before him: holiness and majesty are in his sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "Bring to the Lord, ye families of the Gentiles, bring to the Lord glory and honour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "Bring to the Lord the glory becoming his name: take offerings, and go into his courts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "Worship the Lord in his holy court: let all the earth tremble before him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "Say among the heathen, The Lord reigns: for he has established the world so that it shall not be moved: he shall judge the people in righteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Let the heavens rejoice, and the earth exult; let the sea be moved, and the fullness of it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 12,
      "referenceLabel": "Psalms 95:12",
      "text": "The plains shall rejoice, and all things in them: then shall all the trees of the wood exult before the presence of the Lord:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 13,
      "referenceLabel": "Psalms 95:13",
      "text": "for he comes, for he comes to judge the earth; he shall judge the world in righteousness, and the people with his truth.",
      "paragraphStart": false
    }
  ]
}
