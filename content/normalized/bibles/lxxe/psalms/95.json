{
  "chapter": {
    "id": "lxxe:psalms.95",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.95.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "The praise of a Song by David. - Come, let us exult in the Lord; let us make a joyful noise to God our Saviour.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.95.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Let us come before his presence with thanksgiving, and make a joyful noise to him with psalms.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "For the Lord is a great God, and a great king over all gods: for the Lord will not cast off his people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "For the ends of the earth are in his hands; and the heights of the mountains are his.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "For the sea is his, and he made it: and his hands formed the dry land.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "Come, let us worship and fall down before him; and weep before the Lord that made us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "For he is our God; and we are the people of his pasture, and the sheep of his hand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "To-day, if ye will hear his voice, harden not your hearts, as in the provocation, according to the day of irritation in the wilderness:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "where your fathers tempted me, proved me, and saw my works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "Forty years was I grieved with this generation, and said, They do always err in their heart, and they have not known my ways.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.95.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "So I sware in my wrath, They shall not enter into my rest.",
      "paragraphStart": false
    }
  ]
}
