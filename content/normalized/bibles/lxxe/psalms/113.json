{
  "chapter": {
    "id": "lxxe:psalms.113",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.113.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Alleluia. - Praise the Lord, ye servants of his, praise, the name of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.113.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Let the name of the Lord be blessed, from this present time and for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "From the rising of the sun to his setting, the name of the Lord is to be praised.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "The Lord is high above all the nations; his glory is above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "Who is as the Lord our God? who dwells in the high places,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "and yet looks upon the low things in heaven, and on the earth:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "who lifts up the poor from the earth, and raises up the needy from the dunghill;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "to set him with princes, even with the princes of his people:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.113.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "who settles the barren woman in a house, as a mother rejoicing over children.",
      "paragraphStart": false
    }
  ]
}
