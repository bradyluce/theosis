{
  "chapter": {
    "id": "lxxe:psalms.93",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 93,
    "referenceLabel": "Psalms 93",
    "summary": "Source text for Psalms 93 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.93.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 1,
      "referenceLabel": "Psalms 93:1",
      "text": "A Psalm of David for the fourth day of the week. - The Lord is a God of vengeance; the God of vengeance has declared himself.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.93.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 2,
      "referenceLabel": "Psalms 93:2",
      "text": "Be thou exalted, thou that judgest the earth: render a reward to the proud.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 3,
      "referenceLabel": "Psalms 93:3",
      "text": "How long shall sinners, O Lord, how long shall sinners boast?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 4,
      "referenceLabel": "Psalms 93:4",
      "text": "They will utter and speak unrighteousness; all the workers of iniquity will speak so.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 5,
      "referenceLabel": "Psalms 93:5",
      "text": "They have afflicted thy people, O Lord, and hurt thine heritage.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 6,
      "referenceLabel": "Psalms 93:6",
      "text": "They have slain the widow and fatherless, and murdered the stranger.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 7,
      "referenceLabel": "Psalms 93:7",
      "text": "And they said, The Lord shall not see, neither shall the God of Jacob understand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 8,
      "referenceLabel": "Psalms 93:8",
      "text": "Understand now, ye simple among the people; and ye fools, at length be wise.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 9,
      "referenceLabel": "Psalms 93:9",
      "text": "He that planted the ear, does he not hear? or he that formed the eye, does not he perceive?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 10,
      "referenceLabel": "Psalms 93:10",
      "text": "He that chastises the heathen, shall not he punish, even he that teaches man knowledge?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 11,
      "referenceLabel": "Psalms 93:11",
      "text": "The Lord knows the thoughts of men, that they are vain.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 12,
      "referenceLabel": "Psalms 93:12",
      "text": "Blessed is the man whomsoever thou shalt chasten, O Lord, and shalt teach him out of thy law;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 13,
      "referenceLabel": "Psalms 93:13",
      "text": "to give him rest from evil days, until a pit be digged for the sinful one.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 14,
      "referenceLabel": "Psalms 93:14",
      "text": "For the Lord will not cast off his people, neither will he forsake his inheritance;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 15,
      "referenceLabel": "Psalms 93:15",
      "text": "until righteousness return to judgement, and all the upright in heart shall follow it. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 16,
      "referenceLabel": "Psalms 93:16",
      "text": "Who will rise up for me against the transgressors? or who will stand up with me against the workers of iniquity?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 17,
      "referenceLabel": "Psalms 93:17",
      "text": "If the Lord had not helped me, my soul had almost sojourned in Hades.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 18,
      "referenceLabel": "Psalms 93:18",
      "text": "If I said, My foot has been moved;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 19,
      "referenceLabel": "Psalms 93:19",
      "text": "thy mercy, O Lord, helped me. O Lord, according to the multitude of my griefs within my heart, thy consolation have soothed my soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 20,
      "referenceLabel": "Psalms 93:20",
      "text": "Shall the throne of iniquity have fellowship with thee, which frames mischief by an ordinance?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 21,
      "referenceLabel": "Psalms 93:21",
      "text": "They will hunt for the soul of the righteous, and condemn innocent blood.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 22,
      "referenceLabel": "Psalms 93:22",
      "text": "But the Lord was my refuge; and my God the helper of my hope.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.93.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 93,
      "verseNumber": 23,
      "referenceLabel": "Psalms 93:23",
      "text": "And he will recompense to them their iniquity and their wickedness: the Lord our God shall utterly destroy them.",
      "paragraphStart": false
    }
  ]
}
