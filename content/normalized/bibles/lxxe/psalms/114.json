{
  "chapter": {
    "id": "lxxe:psalms.114",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.114.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "Alleluia. - At the going forth of Israel from Egypt, of the house of Jacob from a barbarous people,",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.114.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Judea became his sanctuary, and Israel his dominion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.114.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "The sea saw and fled: Jordan was turned back.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.114.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "The mountains skipped like rams, and the hills like lambs.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.114.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "What ailed thee, O sea, that thou fleddest? and thou Jordan, that thou wast turned back?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.114.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "Ye mountains, that ye skipped like rams, and ye hills, like lambs?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.114.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "The earth trembled at the presence of the Lord, at the presence of the God of Jacob;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.114.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "who turned the rock into pools of water, and the flint into fountains of water.",
      "paragraphStart": false
    }
  ]
}
