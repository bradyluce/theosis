{
  "chapter": {
    "id": "lxxe:psalms.116",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 116,
    "referenceLabel": "Psalms 116",
    "summary": "Source text for Psalms 116 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.116.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 1,
      "referenceLabel": "Psalms 116:1",
      "text": "Alleluia. - I am well pleased, because the Lord will hearken to the voice of my supplication.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.116.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 2,
      "referenceLabel": "Psalms 116:2",
      "text": "Because he has inclined his ear to me, therefore will I call upon him while I live.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 3,
      "referenceLabel": "Psalms 116:3",
      "text": "The pangs of death compassed me; the dangers of hell found me: I found affliction and sorrow.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 4,
      "referenceLabel": "Psalms 116:4",
      "text": "Then I called on the name of the Lord: O Lord, deliver my soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 5,
      "referenceLabel": "Psalms 116:5",
      "text": "The Lord is merciful and righteous; yea, our God has pity.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 6,
      "referenceLabel": "Psalms 116:6",
      "text": "The Lord preserves the simple: I was brought low, and he delivered me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 7,
      "referenceLabel": "Psalms 116:7",
      "text": "Return to thy rest, O my soul; for the Lord has dealt bountifully with thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 8,
      "referenceLabel": "Psalms 116:8",
      "text": "For he has delivered my soul from death, mine eyes from tears, and my feet from falling.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 9,
      "referenceLabel": "Psalms 116:9",
      "text": "I shall be well-pleasing before the Lord in the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 10,
      "referenceLabel": "Psalms 116:10",
      "text": "Alleluia: I believed, wherefore I have spoken: but I was greatly afflicted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 11,
      "referenceLabel": "Psalms 116:11",
      "text": "And I said in mine amazement, Every man is a liar.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 12,
      "referenceLabel": "Psalms 116:12",
      "text": "What shall I render to the Lord for all the things wherein he has rewarded me?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 13,
      "referenceLabel": "Psalms 116:13",
      "text": "I will take the cup of salvation, and call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 14,
      "referenceLabel": "Psalms 116:14",
      "text": "I will pay my vows to the Lord, in the presence of all his people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 15,
      "referenceLabel": "Psalms 116:15",
      "text": "Precious in the sight of the Lord is the death of his saints.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 16,
      "referenceLabel": "Psalms 116:16",
      "text": "O Lord, I am thy servant; I am thy servant, and the son of thine handmaid: thou hast burst by bonds asunder.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 17,
      "referenceLabel": "Psalms 116:17",
      "text": "I will offer to thee the sacrifice of praise, and will call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 18,
      "referenceLabel": "Psalms 116:18",
      "text": "I will pay my vows unto the Lord, in the presence of all his people,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.116.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 19,
      "referenceLabel": "Psalms 116:19",
      "text": "in the courts of the Lord’s house, in the midst of thee, Jerusalem.",
      "paragraphStart": false
    }
  ]
}
