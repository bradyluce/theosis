{
  "chapter": {
    "id": "lxxe:psalms.35",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.35.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "For the end, by David the servant of the Lord. - The transgressor, that he may sin, says within himself, that there is no fear of God before his eyes.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.35.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "For he has dealt craftily before him, to discover his iniquity and hate it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "The words of his mouth are transgression and deceit: he is not inclined to understand how to do good.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "He devises iniquity on his bed; he gives himself to every evil way; and does not abhor evil.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "O Lord, thy mercy is in the heaven; and thy truth reaches to the clouds.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "Thy righteousness is as the mountains of God, thy judgements are as a great deep: O Lord, thou wilt preserve men and beasts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "How hast thou multiplied thy mercy, O God! so the children of men shall trust in the shelter of thy wings.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "They shall be fully satisfied with the fatness of thine house; and thou shalt cause them to drink of the full stream of thy delights.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "For with thee is the fountain of life: in thy light we shall see light.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "Extend thy mercy to them that know thee; and thy righteousness to the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "Let not the foot of pride come against me, and let not the hand of sinners move me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.35.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "There have all the workers of iniquity fallen: they are cast out, and shall not be able to stand.",
      "paragraphStart": false
    }
  ]
}
