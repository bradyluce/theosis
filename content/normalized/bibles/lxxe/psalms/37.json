{
  "chapter": {
    "id": "lxxe:psalms.37",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.37.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "A Psalm of David for remembrance concerning the Sabbath-day. - O Lord, rebuke me not in thy wrath, neither chasten me in thine anger.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.37.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "For thy weapons are fixed in me, and thou hast pressed thy hand heavily upon me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "For there is no health in my flesh because of thine anger; there is no peace to my bones because of my sins.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "For my transgressions have gone over mine head: they have pressed heavily upon me like a weighty burden.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "My bruises have become noisome and corrupt, because of my foolishness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "I have been wretched and bowed down continually: I went with a mourning countenance all the day.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "For my soul is filled with mockings; and there is no health in my flesh.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "I have been afflicted and brought down exceedingly: I have roared for the groaning of my heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "But all my desire is before thee; and my groaning is not hidden from thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "My heart is troubled, my strength has failed me; and the light of mine eyes is not with me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "My friends and my neighbours drew near before me, and stood still; and my nearest of kin stood afar off.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "While they pressed hard upon me that sought my soul: and they that sought my hurt spoke vanities, and devised deceits all the day.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "But I, as a deaf man, heard not; and was as a dumb man not opening his mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "And I was as a man that hears not, and who has no reproofs in his mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "For I hoped in thee, O Lord: thou wilt hear, O Lord my God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "For I said, Lest mine enemies rejoice against me: for when my feet were moved, they spoke boastingly against me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "For I am ready for plagues, and my grief is continually before me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "For I will declare mine iniquity, and be distressed for my sin.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "But mine enemies live, and are mightier than I: and they that hate me unjustly are multiplied.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "They that reward evil for good slandered me; because I followed righteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "Forsake me not, O Lord my God: depart not from me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.37.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "Draw nigh to my help, O Lord of my salvation.",
      "paragraphStart": false
    }
  ]
}
