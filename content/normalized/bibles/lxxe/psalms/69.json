{
  "chapter": {
    "id": "lxxe:psalms.69",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.69.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "For the end, a Psalm of David, for alternate strains. - Save me, O God; for the waters have come in to my soul.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.69.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "I am stuck fast in deep mire, and there is no standing: I am come in to the depths of the sea, and a storm has overwhelmed me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "I am weary of crying, my throat has become hoarse; mine eyes have failed by my waiting on my God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "They that hate me without a cause are more than the hairs of my head: my enemies that persecute me unrighteously are strengthened: then I restored that which I took not away.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "O God, thou knowest my foolishness; and my transgressions are not hidden from thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "Let not them that wait on thee, O Lord of hosts, be ashamed on my account: let not them that seek thee, be ashamed on my account, O God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 7,
      "referenceLabel": "Psalms 69:7",
      "text": "For I have suffered reproach for thy sake; shame has covered my face.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 8,
      "referenceLabel": "Psalms 69:8",
      "text": "I became strange to my brethren, and a stranger to my mother’s children.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 9,
      "referenceLabel": "Psalms 69:9",
      "text": "For the zeal of thine house has eaten me up; and the reproaches of them that reproached thee are fallen upon me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 10,
      "referenceLabel": "Psalms 69:10",
      "text": "And I bowed down my soul with fasting, and that was made my reproach.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 11,
      "referenceLabel": "Psalms 69:11",
      "text": "And I put on sackcloth for my covering; and I became a proverb to them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 12,
      "referenceLabel": "Psalms 69:12",
      "text": "They that sit in the gate talked against me, and they that drank wine sang against me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 13,
      "referenceLabel": "Psalms 69:13",
      "text": "But I will cry to thee, O Lord, in my prayer; O God, it is a propitious time: in the multitude of thy mercy hear me, in the truth of thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 14,
      "referenceLabel": "Psalms 69:14",
      "text": "Save me from the mire, that I stick not in it: let me be delivered from them that hate me, and from the deep waters.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 15,
      "referenceLabel": "Psalms 69:15",
      "text": "Let not the waterflood drown me, nor let the deep swallow me up; neither let the well shut its mouth upon me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 16,
      "referenceLabel": "Psalms 69:16",
      "text": "Hear me, O Lord; for thy mercy is good: according to the multitude of thy compassions look upon me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 17,
      "referenceLabel": "Psalms 69:17",
      "text": "And turn not away thy face from thy servant; for I am afflicted: hear me speedily.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 18,
      "referenceLabel": "Psalms 69:18",
      "text": "Draw nigh to my soul and redeem it: deliver me because of mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 19,
      "referenceLabel": "Psalms 69:19",
      "text": "For thou knowest my reproach, and my shame, and my confusion; all that afflict me are before thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 20,
      "referenceLabel": "Psalms 69:20",
      "text": "My soul has waited for reproach and misery; and I waited for one to grieve with me, but there was none; and for one to comfort me, but I found none.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 21,
      "referenceLabel": "Psalms 69:21",
      "text": "They gave me also gall for my food, and made me drink vinegar for my thirst.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 22,
      "referenceLabel": "Psalms 69:22",
      "text": "Let their table before them be for a snare, and for a recompense, and for a stumbling-block.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 23,
      "referenceLabel": "Psalms 69:23",
      "text": "Let their eyes be darkened that they should not see; and bow down their back continually.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 24,
      "referenceLabel": "Psalms 69:24",
      "text": "Pour out thy wrath upon them, and let the fury of thine anger take hold on them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 25,
      "referenceLabel": "Psalms 69:25",
      "text": "Let their habitation be made desolate; and let there be no inhabitant in their tents:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 26,
      "referenceLabel": "Psalms 69:26",
      "text": "Because they persecuted him whom thou hast smitten; and they have added to the grief of my wounds.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 27,
      "referenceLabel": "Psalms 69:27",
      "text": "Add iniquity to their iniquity; and let them not come into thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 28,
      "referenceLabel": "Psalms 69:28",
      "text": "Let them be blotted out of the book of the living, and let them not be written with the righteous.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.29",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 29,
      "referenceLabel": "Psalms 69:29",
      "text": "I am poor and sorrowful; but the salvation of thy countenance has helped me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.30",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 30,
      "referenceLabel": "Psalms 69:30",
      "text": "I will praise the name of my God with a song, I will magnify him with praise;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.31",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 31,
      "referenceLabel": "Psalms 69:31",
      "text": "and this shall please God more than a young calf having horns and hoofs.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.32",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 32,
      "referenceLabel": "Psalms 69:32",
      "text": "Let the poor see and rejoice; seek the Lord diligently, and ye shall live.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.33",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 33,
      "referenceLabel": "Psalms 69:33",
      "text": "For the Lord hears the poor, and does not set at nought his fettered ones.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.34",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 34,
      "referenceLabel": "Psalms 69:34",
      "text": "Let the heavens and the earth praise him, the sea, and all things moving in them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.35",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 35,
      "referenceLabel": "Psalms 69:35",
      "text": "For God will save Sion, and the cities of Judea shall be built; and men shall dwell there, and inherit it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.69.36",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 36,
      "referenceLabel": "Psalms 69:36",
      "text": "And the seed of his servants shall possess it, and they that love his name shall dwell therein.",
      "paragraphStart": false
    }
  ]
}
