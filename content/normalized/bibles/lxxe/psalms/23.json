{
  "chapter": {
    "id": "lxxe:psalms.23",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.23.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "A Psalm for David on the first day of the week. - The earth is the Lord’s and the fullness thereof; the world, and all that dwell in it.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.23.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "He has founded it upon the seas, and prepared it upon the rivers.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "Who shall go up to the mountain of the Lord, and who shall stand in his holy place?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "He that is innocent in his hands and pure in his heart; who has not lifted up his soul to vanity, nor sworn deceitfully to his neighbour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "He shall receive a blessing from the Lord, and mercy from God his Saviour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "This is the generation of them that seek him, that seek the face of the God of Jacob. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Psalms 23:7",
      "text": "Lift up your gates, ye princes, and be ye lifted up, ye everlasting doors; and the king of glory shall come in.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Psalms 23:8",
      "text": "Who is this king of Glory? the Lord strong and mighty, the Lord mighty in battle.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Psalms 23:9",
      "text": "Lift up your gates, ye princes; and be ye lift up, ye everlasting doors; and the king of glory shall come in.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.23.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Psalms 23:10",
      "text": "Who is this king of glory? The Lord of hosts, he is this king of glory.",
      "paragraphStart": false
    }
  ]
}
