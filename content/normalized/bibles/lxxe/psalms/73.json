{
  "chapter": {
    "id": "lxxe:psalms.73",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 73,
    "referenceLabel": "Psalms 73",
    "summary": "Source text for Psalms 73 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.73.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 1,
      "referenceLabel": "Psalms 73:1",
      "text": "A Psalm for Asaph. - How good is God to Israel, to the upright in heart!",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.73.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 2,
      "referenceLabel": "Psalms 73:2",
      "text": "But my feet were almost overthrown; my goings very nearly slipped.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 3,
      "referenceLabel": "Psalms 73:3",
      "text": "For I was jealous of the transgressors, beholding the tranquility of sinners.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 4,
      "referenceLabel": "Psalms 73:4",
      "text": "For there is no sign of reluctance in their death: and they have firmness under their affliction.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 5,
      "referenceLabel": "Psalms 73:5",
      "text": "They are not in the troubles of other men; and they shall not be scourged with other men.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 6,
      "referenceLabel": "Psalms 73:6",
      "text": "Therefore pride has possessed them; they have clothed themselves with their injustice and ungodliness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 7,
      "referenceLabel": "Psalms 73:7",
      "text": "Their injustice shall go forth as out of fatness: they have fulfilled their intention.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 8,
      "referenceLabel": "Psalms 73:8",
      "text": "They have taken counsel and spoken in wickedness: they have uttered unrighteousness loftily.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 9,
      "referenceLabel": "Psalms 73:9",
      "text": "They have set their mouth against heaven, and their tongue has gone through upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 10,
      "referenceLabel": "Psalms 73:10",
      "text": "Therefore shall my people return hither: and full days shall be found with them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 11,
      "referenceLabel": "Psalms 73:11",
      "text": "And they said, How does God know? and is there knowledge in the Most High?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 12,
      "referenceLabel": "Psalms 73:12",
      "text": "Behold, these are the sinners, and they that prosper always: they have possessed wealth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 13,
      "referenceLabel": "Psalms 73:13",
      "text": "And I said, Verily in vain have I justified my heart, and washed my hands in innocency.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 14,
      "referenceLabel": "Psalms 73:14",
      "text": "For I was plagued all the day, and my reproof was every morning.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 15,
      "referenceLabel": "Psalms 73:15",
      "text": "If I said, I will speak thus; behold, I should have broken covenant with the generation of thy children.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 16,
      "referenceLabel": "Psalms 73:16",
      "text": "And I undertook to understand this, but it is too hard for me,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 17,
      "referenceLabel": "Psalms 73:17",
      "text": "until I go into the sanctuary of God; and so understand the latter end.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 18,
      "referenceLabel": "Psalms 73:18",
      "text": "Surely thou hast appointed judgements to them because of their crafty dealings: thou hast cast them down when they were lifted up.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 19,
      "referenceLabel": "Psalms 73:19",
      "text": "How have they become desolate! suddenly they have failed: they have perished because of their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 20,
      "referenceLabel": "Psalms 73:20",
      "text": "As the dream of one awakening, O Lord, in thy city thou wilt despise their image.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 21,
      "referenceLabel": "Psalms 73:21",
      "text": "For my heart has rejoiced, and my reins have been gladdened.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 22,
      "referenceLabel": "Psalms 73:22",
      "text": "But I was vile and knew not: I became brutish before thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 23,
      "referenceLabel": "Psalms 73:23",
      "text": "Yet I am continually with thee: thou hast holden my right hand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 24,
      "referenceLabel": "Psalms 73:24",
      "text": "Thou hast guided me by thy counsel, and thou hast taken me to thyself with glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 25,
      "referenceLabel": "Psalms 73:25",
      "text": "For what have I in heaven but thee? and what have I desired upon the earth beside thee?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 26,
      "referenceLabel": "Psalms 73:26",
      "text": "My heart and my flesh have failed: but God is the strength of my heart, and God is my portion for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 27,
      "referenceLabel": "Psalms 73:27",
      "text": "For, behold, they that remove themselves far from thee shall perish: thou hast destroyed every one that goes a whoring from thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.73.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 28,
      "referenceLabel": "Psalms 73:28",
      "text": "But it is good for me to cleave close to God, to put my trust in the Lord; that I may proclaim all thy praises in the gates of the daughter of Sion.",
      "paragraphStart": false
    }
  ]
}
