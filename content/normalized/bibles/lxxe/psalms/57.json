{
  "chapter": {
    "id": "lxxe:psalms.57",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 57,
    "referenceLabel": "Psalms 57",
    "summary": "Source text for Psalms 57 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.57.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 1,
      "referenceLabel": "Psalms 57:1",
      "text": "For the end. Destroy not: by David, for a memorial. - If ye do indeed speak righteousness, then do ye judge rightly, ye sons of men.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.57.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 2,
      "referenceLabel": "Psalms 57:2",
      "text": "For ye work iniquities in your hearts in the earth: your hands plot unrighteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 3,
      "referenceLabel": "Psalms 57:3",
      "text": "Sinners have gone astray from the womb: they go astray from the belly: they speak lies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 4,
      "referenceLabel": "Psalms 57:4",
      "text": "Their venom is like that of a serpent; as that of a deaf asp, and that stops her ears;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 5,
      "referenceLabel": "Psalms 57:5",
      "text": "which will not hear the voice of charmers, nor heed the charm prepared skillfully by the wise.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 6,
      "referenceLabel": "Psalms 57:6",
      "text": "God has crushed their teeth in their mouth: God has broken the cheek-teeth of the lions.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 7,
      "referenceLabel": "Psalms 57:7",
      "text": "They shall utterly pass away like water running through: he shall bend his bow till they shall fail.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 8,
      "referenceLabel": "Psalms 57:8",
      "text": "They shall be destroyed as melted wax: the fire has fallen and they have not seen the sun.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 9,
      "referenceLabel": "Psalms 57:9",
      "text": "Before your thorns feel the white thorn, he shall swallow you up as living, as in his wrath.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 10,
      "referenceLabel": "Psalms 57:10",
      "text": "The righteous shall rejoice when he sees the vengeance of the ungodly: he shall wash his hands in the blood of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.57.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 11,
      "referenceLabel": "Psalms 57:11",
      "text": "And a man shall say, Verily then there is a reward for the righteous: verily there is a God that judges them in the earth.",
      "paragraphStart": false
    }
  ]
}
