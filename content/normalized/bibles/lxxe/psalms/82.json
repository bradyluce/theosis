{
  "chapter": {
    "id": "lxxe:psalms.82",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.82.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "A Psalm for Asaph. - God stands in the assembly of gods; and in the midst of them will judge gods.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.82.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "How long will ye judge unrighteously, and accept the persons of sinners? Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.82.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "Judge the orphan and poor: do justice to the low and needy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.82.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Rescue the needy, and deliver the poor out of the hand of the sinner.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.82.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "They know not, nor understand; they walk on in darkness: all the foundations of the earth shall be shaken.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.82.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "I have said, Ye are gods; and all of you children of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.82.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "But ye die as men, and fall as one of the princes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.82.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Arise, O God, judge the earth: for thou shalt inherit all nations.",
      "paragraphStart": false
    }
  ]
}
