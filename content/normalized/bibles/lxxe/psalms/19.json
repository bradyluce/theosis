{
  "chapter": {
    "id": "lxxe:psalms.19",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 19,
    "referenceLabel": "Psalms 19",
    "summary": "Source text for Psalms 19 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.19.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Psalms 19:1",
      "text": "For the end, a Psalm of David. - The Lord hear thee in the day of trouble; the name of the God of Jacob defend thee.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.19.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Psalms 19:2",
      "text": "Send thee help from the sanctuary, and aid thee out of Sion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Psalms 19:3",
      "text": "Remember all thy sacrifice, and enrich thy whole-burnt-offering. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Psalms 19:4",
      "text": "Grant thee according to thy heart, and fulfill all thy desire.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Psalms 19:5",
      "text": "We will exult in thy salvation, and in the name of our God shall we be magnified: the Lord fulfil all thy petitions.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Psalms 19:6",
      "text": "Now I know that the Lord has saved his Christ: he shall hear him from his holy heaven: the salvation of his right hand is mighty.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Psalms 19:7",
      "text": "Some glory in chariots, and some in horses: but we will glory in the name of the Lord our God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Psalms 19:8",
      "text": "They are overthrown and fallen: but we are risen, and have been set upright.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.19.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Psalms 19:9",
      "text": "O Lord, save the king: and hear us in whatever day we call upon thee.",
      "paragraphStart": false
    }
  ]
}
