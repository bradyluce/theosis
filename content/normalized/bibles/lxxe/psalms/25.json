{
  "chapter": {
    "id": "lxxe:psalms.25",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.25.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "A Psalm of David. - To thee, O Lord, have I lifted up my soul.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.25.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "O my God, I have trusted in thee: let me not be confounded, neither let mine enemies laugh me to scorn.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "For none of them that wait on thee shall in any wise be ashamed: let them be ashamed that transgress without cause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "Shew me thy ways, O Lord; and teach me thy paths.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "Lead me in thy truth, and teach me: for thou art God my Saviour: and I have waited on thee all the day.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "Remember thy compassions, O Lord, and thy mercies, for they are from everlasting.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "Remember not the sins of my youth, nor my sins of ignorance: remember me according to thy mercy, for thy goodness’ sake, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "Good and upright is the Lord: therefore will he instruct sinners in the way.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "The meek will he guide in judgement: the meek will he teach his ways.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "All the ways of the Lord are mercy and truth to them that seek his covenant and his testimonies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "For thy name’s sake, O Lord, do thou also be merciful to my sin; for it is great.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "Who is the man that fears the Lord? he shall instruct him in the way which he has chosen.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Psalms 25:13",
      "text": "His soul shall dwell in prosperity; and his seed shall inherit the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Psalms 25:14",
      "text": "The Lord is the strength of them that fear him; and his covenant is to manifest truth to them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Psalms 25:15",
      "text": "Mine eyes are continually to the Lord; for he shall draw my feet out of the snare.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Psalms 25:16",
      "text": "Look upon me, and have mercy upon me; for I am an only child and poor.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Psalms 25:17",
      "text": "The afflictions of my heart have been multiplied; deliver me from my distresses.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Psalms 25:18",
      "text": "Look upon mine affliction and my trouble; and forgive all my sins.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Psalms 25:19",
      "text": "Look upon mine enemies; for they have been multiplied; and they have hated me with unjust hatred.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Psalms 25:20",
      "text": "Keep my soul, and deliver me: let me not be ashamed; for I have hoped in thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Psalms 25:21",
      "text": "The harmless and upright joined themselves to me: for I waited for thee, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.25.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Psalms 25:22",
      "text": "Deliver Israel, O God, out of all his afflictions.",
      "paragraphStart": false
    }
  ]
}
