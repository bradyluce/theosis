{
  "chapter": {
    "id": "lxxe:psalms.34",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.34.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "A Psalm of David, when he changed his countenance before Abimelech; and he let him go, and he departed. - I will bless the Lord at all times: his praise shall be continually in my mouth.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.34.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "My soul shall boast herself in the Lord: let the meek hear, and rejoice.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "Magnify ye the Lord with me, and let us exalt his name together.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "I sought the Lord diligently, and he hearkened to me, and delivered me from all my sojournings.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "Draw near to him, and be enlightened: and your faces shall not by any means be ashamed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "This poor man cried, and the Lord hearkened to him, and delivered him out of all his afflictions.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "The angel of the Lord will encamp round about them that fear him, and will deliver them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "Taste and see that the Lord is good: blessed is the man who hopes in him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "Fear the Lord, all ye his saints: for there is no want to them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "The rich have become poor and hungry: but they that seek the Lord diligently shall not want any good thing. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "Come, ye children, hear me: I will teach you the fear of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "What man is there that desires life, loving to see good days?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "Keep thy tongue from evil, and thy lips from speaking guile.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "Turn away from evil, and do good; seek peace, and pursue it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "The eyes of the Lord are over the righteous, and his ears are open to their prayer:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "but the face of the Lord is against them that do evil, to destroy their memorial from the earth. The righteous cried, and the Lord hearkened to them,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "and delivered them out of all their afflictions.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "The Lord is near to them that are of a contrite heart; and will save the lowly in spirit.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "Many are the afflictions of the righteous: but out of them all Lord will deliver them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "He keeps all their bones: not one of them shall be broken.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "The death of sinners is evil: and they that hate righteousness will go wrong.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.34.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "The Lord will redeem the souls of his servants: and none of those that hope in him shall go wrong.",
      "paragraphStart": false
    }
  ]
}
