{
  "chapter": {
    "id": "lxxe:psalms.85",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.85.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "For the end, a Psalm for the sons of Core. - O Lord, thou has taken pleasure in thy land: thou hast turned back the captivity of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.85.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "Thou hast forgiven thy people their transgressions; thou has covered all their sins. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "Thou has caused all thy wrath to cease: thou hast turned from thy fierce anger.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "Turn us, O God of our salvation, and turn thy anger away from us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "Wouldest thou be angry with us for ever? or wilt thou continue thy wrath from generation to generation?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "O God, thou wilt turn and quicken us; and thy people shall rejoice in thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "Shew us thy mercy, O Lord, and grant us thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "I will hear what the Lord God will say concerning me: for he shall speak peace to his people, and to his saints, and to those that turn their heart toward him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "Moreover his salvation is near them that fear him; that glory may dwell in our land.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "Mercy and truth are met together: righteousness and peace have kissed each other.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Truth has sprung out of the earth; and righteousness has looked down from heaven.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "For the Lord will give goodness; and our land shall yield her fruit.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.85.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "Righteousness shall go before him; and shall set his steps in the way.",
      "paragraphStart": false
    }
  ]
}
