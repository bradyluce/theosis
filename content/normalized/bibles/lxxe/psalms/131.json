{
  "chapter": {
    "id": "lxxe:psalms.131",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 131,
    "referenceLabel": "Psalms 131",
    "summary": "Source text for Psalms 131 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.131.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 1,
      "referenceLabel": "Psalms 131:1",
      "text": "A Song of Degrees. - Lord, remember David, and all his meekness:",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.131.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 2,
      "referenceLabel": "Psalms 131:2",
      "text": "how he sware to the Lord, and vowed to the God of Jacob, saying,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 3,
      "referenceLabel": "Psalms 131:3",
      "text": "I will not go into the tabernacle of my house; I will not go up to the couch of my bed;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 4,
      "referenceLabel": "Psalms 131:4",
      "text": "I will not give sleep to mine eyes, nor slumber to mine eyelids, nor rest to my temples,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 5,
      "referenceLabel": "Psalms 131:5",
      "text": "until I find a place for the Lord, a tabernacle for the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 6,
      "referenceLabel": "Psalms 131:6",
      "text": "Behold, we heard of it in Ephratha; we found it in the fields of the wood.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 7,
      "referenceLabel": "Psalms 131:7",
      "text": "Let us enter into his tabernacles: let us worship at the place where his feet stood.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 8,
      "referenceLabel": "Psalms 131:8",
      "text": "Arise, O Lord, into thy rest; thou, and the ark of thine holiness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 9,
      "referenceLabel": "Psalms 131:9",
      "text": "Thy priests shall clothe themselves with righteousness; and thy saints shall exult.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 10,
      "referenceLabel": "Psalms 131:10",
      "text": "For the sake of thy servant David turn not away the face of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 11,
      "referenceLabel": "Psalms 131:11",
      "text": "The Lord sware in truth to David, and he will not annul it, saying, Of the fruit of thy body will I set a king upon thy throne.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 12,
      "referenceLabel": "Psalms 131:12",
      "text": "If thy children will deep my covenant, and these my testimonies which I shall teach them, their children also shall sit upon thy throne for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 13,
      "referenceLabel": "Psalms 131:13",
      "text": "For the Lord has elected Sion, he has chosen her for a habitation for himself, saying,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 14,
      "referenceLabel": "Psalms 131:14",
      "text": "This is my rest for ever: here will I dwell; for I have chosen it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 15,
      "referenceLabel": "Psalms 131:15",
      "text": "I will surely bless her provision: I will satisfy her poor with bread.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 16,
      "referenceLabel": "Psalms 131:16",
      "text": "I will clothe her priests with salvation; and her saints shall greatly exult.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 17,
      "referenceLabel": "Psalms 131:17",
      "text": "There will I cause to spring up a horn to David: I have prepared a lamp for mine anointed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.131.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 131,
      "verseNumber": 18,
      "referenceLabel": "Psalms 131:18",
      "text": "His enemies will I clothe with a shame; but upon himself shall my holiness flourish.",
      "paragraphStart": false
    }
  ]
}
