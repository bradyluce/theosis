{
  "chapter": {
    "id": "lxxe:psalms.137",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.137.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "For David, a Psalm of Jeremias. By the rivers of Babylon, there we sat; and wept when we remembered Sion.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.137.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "We hung our harps on the willows in the midst of it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "For there they that had taken us captive asked of us the words of a song; and they that had carried us away asked a hymn, saying, Sing us one of the songs of Sion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "How should we sing the Lord’s song in a strange land?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "If I forget thee, O Jerusalem, let my right hand forget its skill.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "May my tongue cleave to my throat, if I do not remember thee; if I do not prefer Jerusalem as the chief of my joy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "Remember, O Lord, the children of Edom in the day of Jerusalem; who said, Rase it, rase it, even to its foundations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "Wretched daughter of Babylon! blessed shall he be who shall reward thee as thou hast rewarded us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.137.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 9,
      "referenceLabel": "Psalms 137:9",
      "text": "Blessed shall he be who shall seize and dash thine infants against the rock.",
      "paragraphStart": false
    }
  ]
}
