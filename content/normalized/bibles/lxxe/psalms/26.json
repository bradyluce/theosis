{
  "chapter": {
    "id": "lxxe:psalms.26",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.26.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "A Psalm of David. - Judge me, O Lord; for I have walked in my innocence: and hoping in the Lord I shall not be moved.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.26.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "Prove me, O Lord, and try me; purify as with fire my reins and my heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "For thy mercy is before mine eyes: and I am well pleased with thy truth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "I have not sat with the council of vanity, and will in nowise enter in with transgressors.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "I have hated the assembly of wicked doers; and will not sit with ungodly men.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "I will wash my hands in innocency, and compass thine altar, O Lord:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "to hear the voice of praise, and to declare all thy wonderful works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "O Lord, I have loved the beauty of thy house, and the place of the tabernacle of thy glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "Destroy not my soul together with the ungodly, nor my life with bloody men:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "in whose hands are iniquities, and their right hand is filled with bribes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "But I have walked in my innocence: redeem me, and have mercy upon me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.26.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "My foot stands in an even place: in the congregations will I bless thee, O Lord.",
      "paragraphStart": false
    }
  ]
}
