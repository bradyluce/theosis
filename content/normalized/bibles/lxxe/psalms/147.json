{
  "chapter": {
    "id": "lxxe:psalms.147",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.147.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Alleluia, a Psalm of Aggaeus and Zacharias. Praise the Lord, O Jerusalem; praise thy God, O Sion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "For he has strengthened the bars of thy gates; he has blessed thy children within thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "He makes thy borders peaceful, and fills thee with the flour of wheat.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "He sends his oracle to the earth: his word will run swiftly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "He gives snow like wool: he scatters the mist like ashes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "Casting forth his ice like morsels: who shall stand before his cold?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "He shall send out his word, and melt them: he shall blow with his wind, and the waters shall flow.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "He sends his word to Jacob, his ordinances and judgements to Israel.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "He has not done so to any other nation; and he has not shewn them his judgements.",
      "paragraphStart": false
    }
  ]
}
