{
  "chapter": {
    "id": "lxxe:psalms.147",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.147.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Alleluia, a Psalm of Aggaeus and Zacharias. Praise ye the Lord: for psalmody is a good thing; let praise be sweetly sung to our God.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.147.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "The Lord builds up Jerusalem; and he will gather together the dispersed of Israel.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "He heals the broken in heart, and binds up their wounds.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "He numbers the multitudes of stars; and calls them all by names.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Great is our Lord, and great is his strength; and his understanding is infinite.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "The Lord lifts up the meek; but brings sinners down to the ground.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Begin the song with thanksgiving to the Lord; sing praises on the harp to our God:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "who covers the heaven with clouds, who prepares rain for the earth, who causes grass to spring up on the mountains, and green herb for the service of men;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "and gives cattle their food, and to the young ravens that call upon him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 10,
      "referenceLabel": "Psalms 147:10",
      "text": "He will not take pleasure in the strength of a horse; neither is he well-pleased with the legs of a man.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 11,
      "referenceLabel": "Psalms 147:11",
      "text": "The Lord takes pleasure in them that fear him, and in all that hope in his mercy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 12,
      "referenceLabel": "Psalms 147:12",
      "text": "Alleluia, a Psalm of Aggaeus and Zacharias. Praise the Lord, O Jerusalem; praise thy God, O Sion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 13,
      "referenceLabel": "Psalms 147:13",
      "text": "For he has strengthened the bars of thy gates; he has blessed thy children within thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 14,
      "referenceLabel": "Psalms 147:14",
      "text": "He makes thy borders peaceful, and fills thee with the flour of wheat.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 15,
      "referenceLabel": "Psalms 147:15",
      "text": "He sends his oracle to the earth: his word will run swiftly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 16,
      "referenceLabel": "Psalms 147:16",
      "text": "He gives snow like wool: he scatters the mist like ashes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 17,
      "referenceLabel": "Psalms 147:17",
      "text": "Casting forth his ice like morsels: who shall stand before his cold?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 18,
      "referenceLabel": "Psalms 147:18",
      "text": "He shall send out his word, and melt them: he shall blow with his wind, and the waters shall flow.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 19,
      "referenceLabel": "Psalms 147:19",
      "text": "He sends his word to Jacob, his ordinances and judgements to Israel.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.147.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 20,
      "referenceLabel": "Psalms 147:20",
      "text": "He has not done so to any other nation; and he has not shewn them his judgements.",
      "paragraphStart": false
    }
  ]
}
