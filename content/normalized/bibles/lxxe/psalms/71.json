{
  "chapter": {
    "id": "lxxe:psalms.71",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.71.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "For Solomon. - O God, give thy judgement to the king, and thy righteousness to the king’s son;",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.71.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "that he may judge thy people with righteousness, and thy poor with judgement.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Let the mountains and the hills raise peace to thy people:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "he shall judge the poor of the people in righteousness, and save the children of the needy; and shall bring low the false accuser.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "And he shall continue as long as the sun, and before the moon for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "He shall come down as rain upon a fleece; and as drops falling upon the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "In his days shall righteousness spring up; and abundance of peace till the moon be removed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "And he shall have dominion from sea to sea, and from the river to the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "The Ethiopians shall fall down before him; and his enemies shall lick the dust.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "The kings of Tharsis, and the isles, shall bring presents: the kings of the Arabians and Saba shall offer gifts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "And all kings shall worship him; all the Gentiles shall serve him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "For he has delivered the poor from the oppressor; and the needy who had no helper.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "He shall spare the poor and needy, and shall deliver the souls of the needy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "He shall redeem their souls from usury and injustice: and their name shall be precious before him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "And he shall live, and there shall be given him of the gold of Arabia: and men shall pray for him continually; and all the day shall they praise him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "There shall be an establishment on the earth on the tops of the mountains: the fruit thereof shall be exalted above Libanus, and they of the city shall flourish as grass of the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "Let his name be blessed for ever: his name shall endure longer than the sun: and all the tribes of the earth shall be blessed in him: all nations shall call him blessed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "Blessed is the Lord God of Israel, who alone does wonders.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "And blessed is his glorious name for ever, even for ever and ever: and all the earth shall be filled with his glory. So be it, so be it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.71.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "The hymns of David the son of Jessae are ended.",
      "paragraphStart": false
    }
  ]
}
