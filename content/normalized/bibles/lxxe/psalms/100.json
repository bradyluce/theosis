  "verses": [
    {
      "id": "lxxe:psalms.100.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 1,
      "referenceLabel": "Psalms 100:1",
      "text": "A Psalm for Thanksgiving. - Make a joyful noise to the Lord, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.100.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 2,
      "referenceLabel": "Psalms 100:2",
      "text": "Serve the Lord with gladness; come before his presence with exultation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.100.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 3,
      "referenceLabel": "Psalms 100:3",
      "text": "Know that the Lord he is God; he made us, and not we ourselves; we are his people, and the sheep of his pasture.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.100.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 4,
      "referenceLabel": "Psalms 100:4",
      "text": "Enter into his gates with thanksgiving, and his courts with hymns; give thanks to him, praise his name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.100.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 5,
      "referenceLabel": "Psalms 100:5",
      "text": "For the Lord is good, his mercy is for ever; and his truth endures to generation and generation.",
      "paragraphStart": false
    }
  ]
}
