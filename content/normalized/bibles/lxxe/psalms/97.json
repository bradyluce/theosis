{
  "chapter": {
    "id": "lxxe:psalms.97",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.97.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "A Psalm of David. Sing to the Lord a new song; for the Lord has wrought wonderful works, his right hand, and his holy arm, have wrought salvation for him.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.97.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "The Lord has made known his salvation, he has revealed his righteousness in the sight of the nations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "He has remembered his mercy to Jacob, and his truth to the house of Israel; all the ends of the earth have seen the salvation of our God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "Shout to God, all the earth; sing, and exult, and sing psalms.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "Sing to the Lord with a harp, with a harp, and the voice of a psalm.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "With trumpets of metal, and the sound of a trumpet of horn make a joyful noise to the Lord before the king.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "Let the sea be moved, and the fullness of it; the world, and they that dwell in it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "The rivers shall clap their hands together; the mountains shall exult.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "For he is come to judge the earth; he shall judge the world in righteousness, and the nations in uprightness.",
      "paragraphStart": false
    }
  ]
}
