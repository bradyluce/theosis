{
  "chapter": {
    "id": "lxxe:psalms.97",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.97.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "For David, when his land is established. - The Lord reigns, let the earth exult, let many islands rejoice.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.97.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Cloud, and darkness are round about him; righteousness and judgement are the establishment of his throne.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "Fire shall go before him, and burn up his enemies round about.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "His lightnings appeared to the world; the earth saw, and trembled.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "The mountains melted like wax at the presence of the Lord, at the presence of the Lord of the whole earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "The heavens have declared his righteousness, and all the people have seen his glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "Let all that worship graven images be ashamed, who boast of their idols; worship him, all ye his angels.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Sion heard and rejoiced; and the daughters of Judea exulted, because of thy judgements, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "For thou art Lord most high over all the earth; thou art greatly exalted above all gods.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 10,
      "referenceLabel": "Psalms 97:10",
      "text": "Ye that love the Lord, hate evil; the Lord preserves the souls of his saints; he shall deliver them from the hand of sinners.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 11,
      "referenceLabel": "Psalms 97:11",
      "text": "Light is sprung up for the righteous, and gladness for the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.97.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 12,
      "referenceLabel": "Psalms 97:12",
      "text": "Rejoice in the Lord, ye righteous; and give thanks for a remembrance of his holiness.",
      "paragraphStart": false
    }
  ]
}
