{
  "chapter": {
    "id": "lxxe:psalms.148",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.148.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Alleluia, a Psalm of Aggaeus and Zacharias. - Praise ye the Lord from the heavens: praise him in the highest.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.148.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Praise ye him, all his angels: praise ye him, all his hosts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Praise him, sun and moon; praise him, all ye stars and light.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Praise him, ye heavens of heavens, and the water that is above the heavens.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "Let them praise the name of the Lord: for he spoke, and they were made; he commanded, and they were created.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "He has established them for ever, even for ever and ever: he has made an ordinance, and it shall not pass away.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Praise the Lord from the earth, ye serpents, and all deeps.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "Fire, hail, snow, ice, stormy wind; the things that perform his word.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "Mountains, and all hills; fruitful trees, and all cedars:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "wild beasts, and all cattle; reptiles, and winged birds:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "kings of the earth, and all peoples; princes, and all judges of the earth:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "young men and virgins, old men with youths:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "let them praise the name of the Lord: for his name only is exalted; his praise is above the earth and heaven,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.148.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "and he shall exalt the horn of his people, there is a hymn for all his saints, even of the children of Israel, a people who draw near to him.",
      "paragraphStart": false
    }
  ]
}
