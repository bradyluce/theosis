{
  "chapter": {
    "id": "lxxe:psalms.124",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.124.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "A Song of Degrees. - If it had not been that the Lord was among us, let Israel now say;",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.124.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "if it had not been that the Lord was among us, when men rose up against us;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.124.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "verily they would have swallowed us up alive, when their wrath was kindled against us:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.124.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "verily the water would have drowned us, our soul would have gone under the torrent.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.124.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "Yea, our soul would have gone under the overwhelming water.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.124.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 6,
      "referenceLabel": "Psalms 124:6",
      "text": "Blessed be the Lord, who has not given us for a prey to their teeth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.124.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 7,
      "referenceLabel": "Psalms 124:7",
      "text": "Our soul has been delivered as a sparrow from the snare of the fowlers: the snare is broken, and we are delivered.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.124.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 8,
      "referenceLabel": "Psalms 124:8",
      "text": "Our help is in the name of the Lord, who made heaven and earth.",
      "paragraphStart": false
    }
  ]
}
