{
  "chapter": {
    "id": "lxxe:psalms.79",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 79,
    "referenceLabel": "Psalms 79",
    "summary": "Source text for Psalms 79 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.79.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 1,
      "referenceLabel": "Psalms 79:1",
      "text": "For the end, for alternate strains, a testimony for Asaph, a Psalm concerning the Assyrian. - Attend, O Shepherd of Israel, who guidest Joseph like a flock; thou who sittest upon the cherubs, manifest thyself;",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.79.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 2,
      "referenceLabel": "Psalms 79:2",
      "text": "before Ephraim and Benjamin and Manasse, stir up thy power, and come to deliver us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 3,
      "referenceLabel": "Psalms 79:3",
      "text": "Turn us, O God, and cause thy face to shine; and we shall be delivered.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 4,
      "referenceLabel": "Psalms 79:4",
      "text": "O Lord God of hosts, how long art thou angry with the prayer of thy servant?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 5,
      "referenceLabel": "Psalms 79:5",
      "text": "Thou wilt feed us with bread of tears; and wilt cause us to drink tears by measure.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 6,
      "referenceLabel": "Psalms 79:6",
      "text": "Thou has made us a strife to our neighbours; and our enemies have mocked at us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 7,
      "referenceLabel": "Psalms 79:7",
      "text": "Turn us, O Lord God of hosts, and cause thy face to shine; and we shall be saved. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 8,
      "referenceLabel": "Psalms 79:8",
      "text": "Thou hast transplanted a vine out of Egypt: thou hast cast out the heathen, and planted it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 9,
      "referenceLabel": "Psalms 79:9",
      "text": "Thou madest a way before it, and didst cause its roots to strike, and the land was filled with it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 10,
      "referenceLabel": "Psalms 79:10",
      "text": "Its shadow covered the mountains, and its shoots equalled the goodly cedars.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 11,
      "referenceLabel": "Psalms 79:11",
      "text": "It sent forth its branches to the sea, and its shoots to the river.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 12,
      "referenceLabel": "Psalms 79:12",
      "text": "Wherefore hast thou broken down its hedge, while all that pass by the way pluck it?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 13,
      "referenceLabel": "Psalms 79:13",
      "text": "The boar out of the wood has laid it waste, and the wild beast has devoured it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 14,
      "referenceLabel": "Psalms 79:14",
      "text": "O God of hosts, turn, we pray thee: look on us from heaven, and behold and visit this vine;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 15,
      "referenceLabel": "Psalms 79:15",
      "text": "and restore that which thy right hand has planted: and look on the son of man whom thou didst strengthen for thyself.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 16,
      "referenceLabel": "Psalms 79:16",
      "text": "It is burnt with fire and dug up: they shall perish at the rebuke of thy presence.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 17,
      "referenceLabel": "Psalms 79:17",
      "text": "Let thy hand be upon the man of thy right hand, and upon the son of man whom thou didst strengthen for thyself.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 18,
      "referenceLabel": "Psalms 79:18",
      "text": "So will we not depart from thee: thou shalt quicken us, and we will call upon thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.79.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 79,
      "verseNumber": 19,
      "referenceLabel": "Psalms 79:19",
      "text": "Turn us, O Lord God of hosts, and make thy face to shine; and we shall be saved.",
      "paragraphStart": false
    }
  ]
}
