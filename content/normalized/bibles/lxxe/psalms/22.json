{
  "chapter": {
    "id": "lxxe:psalms.22",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.22.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "For the end, concerning the morning aid, a Psalm of David. - O God, my God, attend to me: why hast thou forsaken me? the account of my transgressions is far from my salvation.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.22.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "O my God, I will cry to thee by day, but thou wilt not hear: and by night, and it shall not be accounted for folly to me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "But thou, the praise of Israel, dwellest in a sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "Our fathers hoped in thee; they hoped, and thou didst deliver them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "They cried to thee, and were saved: they hoped in thee, and were not ashamed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "But I am a worm, and not a man; a reproach of men, and scorn of the people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Psalms 22:7",
      "text": "All that saw me mocked me: they spoke with their lips, they shook the head, saying,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Psalms 22:8",
      "text": "He hoped in the Lord: let him deliver him, let him save him, because he takes pleasure in him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Psalms 22:9",
      "text": "For thou art he that drew me out of the womb; my hope from my mother’s breasts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Psalms 22:10",
      "text": "I was cast on thee from the womb: thou art my God from my mother’s belly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Psalms 22:11",
      "text": "Stand not aloof from me; for affliction is near; for there is no helper.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Psalms 22:12",
      "text": "Many bullocks have compassed me: fat bulls have beset me round.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Psalms 22:13",
      "text": "They have opened their mouth against me, as a ravening and roaring lion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Psalms 22:14",
      "text": "I am poured out like water, and all my bones are loosened: my heart in the midst of my belly is become like melting wax.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Psalms 22:15",
      "text": "My strength is dried up, like a potsherd; and my tongue is glued to my throat; and thou hast brought me down to the dust of death.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Psalms 22:16",
      "text": "For many dogs have compassed me: the assembly of the wicked doers has beset me round: they pierced my hands and my feet.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Psalms 22:17",
      "text": "They counted all my bones; and they observed and looked upon me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Psalms 22:18",
      "text": "They parted my garments among themselves, and cast lots upon my raiment.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Psalms 22:19",
      "text": "But thou, O Lord, remove not my help afar off: be ready for mine aid.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Psalms 22:20",
      "text": "Deliver my soul from the sword; my only-begotten one from the power of the dog.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Psalms 22:21",
      "text": "Save me from the lion’s mouth; and regard my lowliness from the horns of the unicorns.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Psalms 22:22",
      "text": "I will declare thy name to my brethren: in the midst of the church will I sing praise to thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Psalms 22:23",
      "text": "Ye that fear the Lord, praise him; all ye seed of Jacob, glorify him: let all the seed of Israel fear him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Psalms 22:24",
      "text": "For he has not despised nor been angry at the supplication of the poor; nor turned away his face from me; but when I cried to him, he heard me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Psalms 22:25",
      "text": "My praise is of thee in the great congregation: I will pay my vows before them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Psalms 22:26",
      "text": "The poor shall eat and be satisfied; and they shall praise the Lord that seek him: their heart shall live for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Psalms 22:27",
      "text": "All the ends of the earth shall remember and turn to the Lord: and all the kindreds of the nations shall worship before him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Psalms 22:28",
      "text": "For the kingdom is the Lord’s; and he is the governor of the nations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.29",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Psalms 22:29",
      "text": "All the fat ones of the earth have eaten and worshipped: all that go down to the earth shall fall down before him: my soul also lives to him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.30",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Psalms 22:30",
      "text": "And my seed shall serve him: the generation that is coming shall be reported to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.22.31",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Psalms 22:31",
      "text": "And they shall report his righteousness to the people that shall be born, whom the Lord has made.",
      "paragraphStart": false
    }
  ]
}
