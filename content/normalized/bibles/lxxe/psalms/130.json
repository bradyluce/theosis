{
  "chapter": {
    "id": "lxxe:psalms.130",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 130,
    "referenceLabel": "Psalms 130",
    "summary": "Source text for Psalms 130 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.130.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 1,
      "referenceLabel": "Psalms 130:1",
      "text": "A Song of Degrees. - Out of the depths have I cried to thee, O Lord.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.130.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 2,
      "referenceLabel": "Psalms 130:2",
      "text": "O Lord, hearken to my voice; let thine ears be attentive to the voice of my supplication.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.130.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 3,
      "referenceLabel": "Psalms 130:3",
      "text": "If thou, O Lord, shouldest mark iniquities, O Lord, who shall stand?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.130.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 4,
      "referenceLabel": "Psalms 130:4",
      "text": "For with thee is forgiveness: for thy name’s sake",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.130.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 5,
      "referenceLabel": "Psalms 130:5",
      "text": "have I waited for thee, O Lord, my soul has waited for thy word.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.130.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 6,
      "referenceLabel": "Psalms 130:6",
      "text": "My soul has hoped in the Lord; from the morning watch till night.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.130.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 7,
      "referenceLabel": "Psalms 130:7",
      "text": "Let Israel hope in the Lord: for with the Lord is mercy, and with him is plenteous redemption.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.130.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 8,
      "referenceLabel": "Psalms 130:8",
      "text": "And he shall redeem Israel from all his iniquities.",
      "paragraphStart": false
    }
  ]
}
