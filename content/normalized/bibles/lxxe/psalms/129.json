{
  "chapter": {
    "id": "lxxe:psalms.129",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.129.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "A Song of Degrees. - Many a time have they warred against me from my youth, let Israel now say:",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.129.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "Many a time have they warred against me from my youth: and yet they prevailed not against me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.129.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "The sinners wrought upon my back: they prolonged their iniquity.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.129.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "The righteous Lord has cut asunder the necks of sinners.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.129.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "Let all that hate Sion be put to shame and turned back.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.129.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "Let them be as the grass of the house-tops, which withers before it is plucked up.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.129.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "Wherewith the reaper fills not his hand, nor he that makes up the sheaves, his bosom.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.129.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "Neither do they that go by say, The blessing of the Lord be upon you: we have blessed you in the name of the Lord.",
      "paragraphStart": false
    }
  ]
}
