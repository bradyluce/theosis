{
  "chapter": {
    "id": "lxxe:psalms.101",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 101,
    "referenceLabel": "Psalms 101",
    "summary": "Source text for Psalms 101 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.101.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 1,
      "referenceLabel": "Psalms 101:1",
      "text": "A Prayer for the Poor; when he is deeply afflicted, and pours out his supplication before the Lord. - Hear my prayer, O Lord, and let my cry come to thee.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.101.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 2,
      "referenceLabel": "Psalms 101:2",
      "text": "Turn not away thy face from me: in the day when I am afflicted, incline thine ear to me: in the day when I shall call upon thee, speedily hear me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 3,
      "referenceLabel": "Psalms 101:3",
      "text": "For my days have vanished like smoke, and my bones have been parched like a stick.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 4,
      "referenceLabel": "Psalms 101:4",
      "text": "I am blighted like grass, and my heart is dried up; for I have forgotten to eat my bread.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 5,
      "referenceLabel": "Psalms 101:5",
      "text": "By reason of the voice of my groaning, my bone has cleaved to my flesh.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 6,
      "referenceLabel": "Psalms 101:6",
      "text": "I have become like a pelican of the wilderness;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 7,
      "referenceLabel": "Psalms 101:7",
      "text": "I have become like an owl in a ruined house. I have watched, and am become as a sparrow dwelling alone on a roof.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 8,
      "referenceLabel": "Psalms 101:8",
      "text": "All the day long mine enemies have reproached me; and they that praised me have sworn against me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 9,
      "referenceLabel": "Psalms 101:9",
      "text": "For I have eaten ashes as it were bread, and mingled my drink with weeping;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 10,
      "referenceLabel": "Psalms 101:10",
      "text": "because of thine anger and thy wrath: for thou hast lifted me up, and dashed me down.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 11,
      "referenceLabel": "Psalms 101:11",
      "text": "My days have declined like a shadow; and I am withered like grass.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 12,
      "referenceLabel": "Psalms 101:12",
      "text": "But thou, Lord, endurest for ever, and thy memorial to generation and generation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 13,
      "referenceLabel": "Psalms 101:13",
      "text": "Thou shalt arise, and have mercy upon Sion: for it is time to have mercy upon her, for the set time is come.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 14,
      "referenceLabel": "Psalms 101:14",
      "text": "For thy servants have taken pleasure in her stones, and they shall pity her dust.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 15,
      "referenceLabel": "Psalms 101:15",
      "text": "So the nations shall fear thy name, O Lord, and all kings thy glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 16,
      "referenceLabel": "Psalms 101:16",
      "text": "For the Lord shall build up Sion, and shall appear in his glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 17,
      "referenceLabel": "Psalms 101:17",
      "text": "He has had regard to the prayer of the lowly, and has not despised their petition.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 18,
      "referenceLabel": "Psalms 101:18",
      "text": "Let this be written for another generation; and the people that shall be created shall praise the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 19,
      "referenceLabel": "Psalms 101:19",
      "text": "For he has looked out from the height of his sanctuary; the Lord looked upon the earth from heaven;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 20,
      "referenceLabel": "Psalms 101:20",
      "text": "to hear the groaning of the fettered ones, to loosen the sons of the slain;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 21,
      "referenceLabel": "Psalms 101:21",
      "text": "to proclaim the name of the Lord in Sion, and his praise in Jerusalem;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 22,
      "referenceLabel": "Psalms 101:22",
      "text": "when the people are gathered together, and the kings, to serve the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 23,
      "referenceLabel": "Psalms 101:23",
      "text": "He answered him in the way of his strength: tell me the fewness of my days.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 24,
      "referenceLabel": "Psalms 101:24",
      "text": "Take me not away in the midst of my days: thy years are through all generations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 25,
      "referenceLabel": "Psalms 101:25",
      "text": "In the beginning thou, O Lord, didst lay the foundation of the earth; and the heavens are the works of thine hands.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 26,
      "referenceLabel": "Psalms 101:26",
      "text": "They shall perish, but thou remainest: and they all shall wax old as a garment; and as a vesture shalt thou fold them, and they shall be changed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 27,
      "referenceLabel": "Psalms 101:27",
      "text": "But thou art the same, and thy years shall not fail.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.101.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 101,
      "verseNumber": 28,
      "referenceLabel": "Psalms 101:28",
      "text": "The children of thy servants shall dwell securely, and their seed shall prosper for ever.",
      "paragraphStart": false
    }
  ]
}
