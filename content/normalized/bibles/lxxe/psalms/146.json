{
  "chapter": {
    "id": "lxxe:psalms.146",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.146.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Alleluia, a Psalm of Aggaeus and Zacharias. - My soul, praise the Lord.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.146.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "While I live will I praise the Lord: I will sing praises to my God as long as I exist.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "Trust not in princes, nor in the children of men, in whom there is no safety.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "His breath shall go forth, and he shall return to his earth; in that day all his thoughts shall perish.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Blessed is he whose helper is the God of Jacob, whose hope is in the Lord his God:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "who made heaven, and earth, the sea, and all things in them: who keeps truth for ever:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "who executes judgement for the wronged: who gives food to the hungry. The Lord looses the fettered ones:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "the Lord gives wisdom to the blind: The Lord sets up the broken down: the Lord loves the righteous: the Lord preserves the strangers;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "he will relieve the orphan and widow: but will utterly remove the way of sinners.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.146.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "The Lord shall reign for ever, even thy God, O Sion, to all generations.",
      "paragraphStart": false
    }
  ]
}
