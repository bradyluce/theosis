{
  "chapter": {
    "id": "lxxe:psalms.87",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.87.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "A song of a Psalm for the sons of Core for the end, upon Maeleth for responsive strains, of instruction for Æman the Israelite. - O Lord God of my salvation, I have cried by day and in the night before thee.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.87.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "Let my prayer come in before thee; incline thine ear to my supplication, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "For my soul is filled with troubles, and my life has drawn nigh to Hades.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "I have been reckoned with them that go down to the pit; I became as a man without help;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "free among the dead, as the slain ones cast out, who sleep in the tomb; whom thou rememberest no more; and they are rejected from thy hand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "They laid me in the lowest pit, in dark places, and in the shadow of death.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "Thy wrath has pressed heavily upon me, and thou hast brought upon me all thy billows. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 8,
      "referenceLabel": "Psalms 87:8",
      "text": "Thou hast removed my acquaintance far from me; they have made me an abomination to themselves; I have been delivered up, and have not gone forth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 9,
      "referenceLabel": "Psalms 87:9",
      "text": "Mine eyes are dimmed from poverty; but I cried to thee, O Lord, all the day; I spread forth my hands to thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 10,
      "referenceLabel": "Psalms 87:10",
      "text": "Wilt thou work wonders for the dead? or shall physicians raise them up, that they shall praise thee?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 11,
      "referenceLabel": "Psalms 87:11",
      "text": "Shall any one declare thy mercy in the tomb? and thy truth in destruction?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 12,
      "referenceLabel": "Psalms 87:12",
      "text": "Shall thy wonders be known in darkness? and thy righteousness in a forgotten land?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 13,
      "referenceLabel": "Psalms 87:13",
      "text": "But I cried to thee, O Lord; and in the morning shall my prayer prevent thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 14,
      "referenceLabel": "Psalms 87:14",
      "text": "Wherefore, O Lord, dost thou reject my prayer, and turn thy face away from me?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 15,
      "referenceLabel": "Psalms 87:15",
      "text": "I am poor and in troubles from my youth; and having been exalted, I was brought low and into despair.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 16,
      "referenceLabel": "Psalms 87:16",
      "text": "Thy wrath has passed over me; and thy terrors have greatly disquieted me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 17,
      "referenceLabel": "Psalms 87:17",
      "text": "They compassed me like water; all the day they beset me together.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.87.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 18,
      "referenceLabel": "Psalms 87:18",
      "text": "Thou hast put far from me every friend, and mine acquaintances because of my wretchedness.",
      "paragraphStart": false
    }
  ]
}
