{
  "chapter": {
    "id": "lxxe:psalms.125",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 125,
    "referenceLabel": "Psalms 125",
    "summary": "Source text for Psalms 125 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.125.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 1,
      "referenceLabel": "Psalms 125:1",
      "text": "A Song of Degrees. - When the Lord turned the captivity of Sion, we became as comforted ones.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.125.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 2,
      "referenceLabel": "Psalms 125:2",
      "text": "Then was our mouth filled with joy, and our tongue with exultation: then would they say among the Gentiles,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.125.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 3,
      "referenceLabel": "Psalms 125:3",
      "text": "The Lord has done great things among them. The Lord has done great things for us, we became joyful.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.125.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 4,
      "referenceLabel": "Psalms 125:4",
      "text": "Turn, O Lord, our captivity, as the steams in the south.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.125.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 5,
      "referenceLabel": "Psalms 125:5",
      "text": "They that sow in tears shall reap in joy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.125.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 125,
      "verseNumber": 6,
      "referenceLabel": "Psalms 125:6",
      "text": "They went on and wept as they cast their seeds; but they shall surely come with exultation, bringing their sheaves with them.",
      "paragraphStart": false
    }
  ]
}
