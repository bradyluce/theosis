{
  "chapter": {
    "id": "lxxe:psalms.86",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.86.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "A Psalm of a Song for the sons of Core. - His foundations are in the holy mountains.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.86.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "The Lord loves the gates of Sion, more than all the tabernacles of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Glorious things have been spoken of thee, O city of God. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "I will make mention of Raab and Babylon to them that know me: behold also the Philistines, and Tyre, and the people of the Ethiopians: these were born there.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "A man shall say, Sion is my mother; and such a man was born in her; and the Highest himself has founded her.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "The Lord shall recount it in the writing of the people, and of these princes that were born in her.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "The dwelling of all within thee is as the dwelling of those that rejoice.",
      "paragraphStart": false
    }
  ]
}
