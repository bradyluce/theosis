{
  "chapter": {
    "id": "lxxe:psalms.86",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.86.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "A Prayer of David. - O Lord, incline thine ear, and hearken to me; for I am poor and needy.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.86.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "Preserve my soul, for I am holy; save thy servant, O God, who hopes in thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "Pity me, O Lord: for to thee will I cry all the day.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "Rejoice the soul of thy servant: for to thee, O Lord, have I lifted up my soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "For thou, O Lord, art kind, and gentle; and plenteous in mercy to all that call upon thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "Give ear to my prayer, O Lord; and attend to the voice of my supplication.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "In the day of my trouble I cried to thee: for thou didst hear me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 8,
      "referenceLabel": "Psalms 86:8",
      "text": "There is none like to thee, O Lord, among the gods; and there are no works like to thy works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 9,
      "referenceLabel": "Psalms 86:9",
      "text": "All nations whom thou hast made shall come, and shall worship before thee, O Lord; and shall glorify thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 10,
      "referenceLabel": "Psalms 86:10",
      "text": "For thou art great, and doest wonders: thou art the only and the great God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 11,
      "referenceLabel": "Psalms 86:11",
      "text": "Guide me, O Lord, in thy way, and I will walk in thy truth: let my heart rejoice, that I may fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 12,
      "referenceLabel": "Psalms 86:12",
      "text": "I will give thee thanks, O Lord my God, with all my heart; and I will glorify thy name for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 13,
      "referenceLabel": "Psalms 86:13",
      "text": "For thy mercy is great toward me; and thou hast delivered my soul from the lowest hell.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 14,
      "referenceLabel": "Psalms 86:14",
      "text": "O God, transgressors have risen up against me, and an assembly of violent men have sought my life; and have not set thee before them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 15,
      "referenceLabel": "Psalms 86:15",
      "text": "But thou, O Lord God, art compassionate and merciful, long-suffering, and abundant in mercy and true.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 16,
      "referenceLabel": "Psalms 86:16",
      "text": "Look thou upon me, and have mercy upon me: give thy strength to thy servant, and save the son of thine handmaid.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.86.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 17,
      "referenceLabel": "Psalms 86:17",
      "text": "Establish with me a token for good; and let them that hate me see it and be ashamed; because thou, O Lord, hast helped me, and comforted me.",
      "paragraphStart": false
    }
  ]
}
