  "verses": [
    {
      "id": "lxxe:psalms.99.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "A Psalm for Thanksgiving. - Make a joyful noise to the Lord, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.99.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "Serve the Lord with gladness; come before his presence with exultation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.99.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Know that the Lord he is God; he made us, and not we ourselves; we are his people, and the sheep of his pasture.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.99.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "Enter into his gates with thanksgiving, and his courts with hymns; give thanks to him, praise his name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.99.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "For the Lord is good, his mercy is for ever; and his truth endures to generation and generation.",
      "paragraphStart": false
    }
  ]
}
