{
  "chapter": {
    "id": "lxxe:psalms.111",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.111.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Alleluia. - Blessed is the man that fears the Lord: he will delight greatly in his commandments.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.111.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "His seed shall be mighty in the earth: the generation of the upright shall be blessed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "Glory and riches shall be in his house; and his righteousness endures for evermore.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "To the upright light has sprung up in darkness: he is pitiful, and merciful, and righteous.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "The good man is he that pities and lends: he will direct his affairs with judgement.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "For he shall not be moved for ever; the righteous shall be in everlasting remembrance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "He shall not be afraid of any evil report: his heart is ready to trust in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "His heart is established, he shall not fear, till he shall see his desire upon his enemies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "He has dispersed abroad; he has given to the poor; his righteousness endures for evermore: his horn shall be exalted with honour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "The sinner shall see and be angry, he shall gnash his teeth, and consume away: the desire of the sinner shall perish.",
      "paragraphStart": false
    }
  ]
}
