{
  "chapter": {
    "id": "lxxe:psalms.111",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.111.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Alleluia. - I will give thee thanks, O Lord, with my whole heart, in the council of the upright, and in the congregation.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.111.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "The works of the Lord are great, sought out according to all his will.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "His work is worthy of thanksgiving and honour: and his righteousness endures for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "He has caused his wonderful works to be remembered: the Lord is merciful and compassionate.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "He has given food to them that fear him: he will remember his covenant for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "He has declared to his people the power of his works, to give them the inheritance of the heathen.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "The works of his hands are truth and judgement: all his commandments are sure:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "established for ever and ever, done in truth and uprightness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "He sent redemption to his people: he commanded his covenant for ever: holy and fearful is his name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.111.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "The fear of the Lord is the beginning of wisdom, and all that act accordingly have a good understanding; his praise endures for ever and ever.",
      "paragraphStart": false
    }
  ]
}
