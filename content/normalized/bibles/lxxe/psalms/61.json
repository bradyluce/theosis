{
  "chapter": {
    "id": "lxxe:psalms.61",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.61.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "For the end, among the Hymns of David. - O God, hearken to my petition; attend to my prayer.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.61.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "From the ends of the earth have I cried to thee, when my heart was in trouble: thou liftedst me up on a rock thou didst guide me:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.61.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "because thou wert my hope, a tower of strength from the face of the enemy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.61.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "I will dwell in thy tabernacle for ever; I will shelter myself under the shadow of thy wings. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.61.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "For thou, O God, hast heard my prayers; thou hast given an inheritance to them that fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.61.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "Thou shalt add days to the days of the king; thou shalt lengthen his years to all generations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.61.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "He shall endure for ever before God: which of them will seek out his mercy and truth?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.61.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "So will I sing to thy name for ever and ever, that I may daily perform my vows.",
      "paragraphStart": false
    }
  ]
}
