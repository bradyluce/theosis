{
  "chapter": {
    "id": "lxxe:psalms.120",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.120.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "A Song of Degrees. - I lifted up mine eyes to the mountains, whence my help shall come.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.120.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "My help shall come from the Lord, who made the heaven and the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "Let not thy foot be moved; and let not thy keeper slumber.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Behold, he that keeps Israel shall not slumber nor sleep.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "The Lord shall keep thee: the Lord is thy shelter upon thy right hand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "The sun shall not burn thee by day, neither the moon by night.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "May the Lord preserve thee from all evil: the Lord shall keep thy soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 8,
      "referenceLabel": "Psalms 120:8",
      "text": "The Lord shall keep thy coming in, and thy going out, from henceforth and even for ever.",
      "paragraphStart": false
    }
  ]
}
