  "verses": [
    {
      "id": "lxxe:psalms.120.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "A Song of Degrees. - In mine affliction I cried to the Lord, and he hearkened to me.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.120.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "Deliver my soul, O Lord, from unjust lips, and from a deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "What should be given to thee, and what should be added to thee, for thy crafty tongue?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "Sharpened weapons of the mighty, with coals of the desert.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Woe is me, that my sojourning is prolonged; I have tabernacled among the tents of Kedar.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "My soul has long been a sojourner;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.120.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "I was peaceable among them that hated peace; when I spoke to them, they warred against me without a cause.",
      "paragraphStart": false
    }
  ]
}
