{
  "chapter": {
    "id": "lxxe:psalms.84",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.84.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "For the end, a Psalm for the sons of Core. - O Lord, thou has taken pleasure in thy land: thou hast turned back the captivity of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.84.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "Thou hast forgiven thy people their transgressions; thou has covered all their sins. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Thou has caused all thy wrath to cease: thou hast turned from thy fierce anger.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Turn us, O God of our salvation, and turn thy anger away from us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Wouldest thou be angry with us for ever? or wilt thou continue thy wrath from generation to generation?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "O God, thou wilt turn and quicken us; and thy people shall rejoice in thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "Shew us thy mercy, O Lord, and grant us thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "I will hear what the Lord God will say concerning me: for he shall speak peace to his people, and to his saints, and to those that turn their heart toward him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Moreover his salvation is near them that fear him; that glory may dwell in our land.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "Mercy and truth are met together: righteousness and peace have kissed each other.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "Truth has sprung out of the earth; and righteousness has looked down from heaven.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "For the Lord will give goodness; and our land shall yield her fruit.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.84.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 13,
      "referenceLabel": "Psalms 84:13",
      "text": "Righteousness shall go before him; and shall set his steps in the way.",
      "paragraphStart": false
    }
  ]
}
