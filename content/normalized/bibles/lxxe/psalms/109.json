{
  "chapter": {
    "id": "lxxe:psalms.109",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.109.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "For the end, a Psalm of David. - O God, pass not over my praise in silence;",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.109.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "for the mouth of the sinner and the mouth of the crafty man have been opened against me: they have spoken against me with a crafty tongue.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "And they have compassed me with words of hatred; and fought against me without a cause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "Instead of loving me, they falsely accused me: but I continued to pray.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "And they rewarded me evil for good, and hatred for my love.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "Set thou a sinner against him; and let the devil stand at his right hand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "When he is judged, let him go forth condemned: and let his prayer become sin.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 8,
      "referenceLabel": "Psalms 109:8",
      "text": "Let his days be few: and let another take his office of overseer.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 9,
      "referenceLabel": "Psalms 109:9",
      "text": "Let his children be orphans, and his wife a widow.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 10,
      "referenceLabel": "Psalms 109:10",
      "text": "Let his children wander without a dwelling-place, and beg: let them be cast out of their habitations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 11,
      "referenceLabel": "Psalms 109:11",
      "text": "Let his creditor exact all that belongs to him: and let strangers spoil his labours.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 12,
      "referenceLabel": "Psalms 109:12",
      "text": "Let him have no helper; neither let there be any one to have compassion on his fatherless children.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 13,
      "referenceLabel": "Psalms 109:13",
      "text": "Let his children be given up to utter destruction: in one generation let his name be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 14,
      "referenceLabel": "Psalms 109:14",
      "text": "Let the iniquity of his fathers be remembered before the Lord; and let not the sin of his mother be blotted out.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 15,
      "referenceLabel": "Psalms 109:15",
      "text": "Let them be before the Lord continually; and let their memorial be blotted out from the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 16,
      "referenceLabel": "Psalms 109:16",
      "text": "Because he remembered not to shew mercy, but persecuted the needy and poor man, and that to slay him that was pricked in the heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 17,
      "referenceLabel": "Psalms 109:17",
      "text": "He loved cursing also, and it shall come upon him; and he took not pleasure in blessing, so it shall be removed far from him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 18,
      "referenceLabel": "Psalms 109:18",
      "text": "Yea, he put on cursing as a garment, and it is come as water into his bowels, and as oil into his bones.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 19,
      "referenceLabel": "Psalms 109:19",
      "text": "Let it be to him as a garment which he puts on, and as a girdle with which he girds himself continually.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 20,
      "referenceLabel": "Psalms 109:20",
      "text": "This is the dealing of the Lord with those who falsely accuse me, and of them that speak evil against my soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 21,
      "referenceLabel": "Psalms 109:21",
      "text": "But thou, O Lord, Lord, deal mercifully with me, for thy name’s sake: for thy mercy is good.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 22,
      "referenceLabel": "Psalms 109:22",
      "text": "Deliver me, for I am poor and needy; and my heart is troubled within me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 23,
      "referenceLabel": "Psalms 109:23",
      "text": "I am removed as a shadow in its going down: I am tossed up and down like locusts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 24,
      "referenceLabel": "Psalms 109:24",
      "text": "My knees are weakened through fasting, and my flesh is changed by reason of the want of oil.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 25,
      "referenceLabel": "Psalms 109:25",
      "text": "I became also a reproach to them: when they saw me they shook their heads.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 26,
      "referenceLabel": "Psalms 109:26",
      "text": "Help me, O Lord my God; and save me according to thy mercy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 27,
      "referenceLabel": "Psalms 109:27",
      "text": "And let them know that this is thy hand; and that thou, Lord, hast wrought it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 28,
      "referenceLabel": "Psalms 109:28",
      "text": "Let them curse, but thou shalt bless: let them that rise up against me be ashamed, but let thy servant rejoice.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.29",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 29,
      "referenceLabel": "Psalms 109:29",
      "text": "Let those that falsely accuse me be clothed with shame, and let them cover themselves with their shame as with a mantle.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.30",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 30,
      "referenceLabel": "Psalms 109:30",
      "text": "I will give thanks to the Lord abundantly with my mouth; and in the midst of many I will praise him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.109.31",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 31,
      "referenceLabel": "Psalms 109:31",
      "text": "For he stood on the right hand of the poor, to save me from them that persecute my soul.",
      "paragraphStart": false
    }
  ]
}
