{
  "chapter": {
    "id": "lxxe:psalms.41",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 41,
    "referenceLabel": "Psalms 41",
    "summary": "Source text for Psalms 41 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.41.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Psalms 41:1",
      "text": "For the end, a Psalm of David. - Blessed is the man who thinks, on the poor and needy: the Lord shall deliver him in an evil day.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.41.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Psalms 41:2",
      "text": "May the Lord preserve him and keep him alive, and bless him on the earth, and not deliver him into the hands of his enemy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Psalms 41:3",
      "text": "May the Lord help him upon the bed of his pain; thou hast made all his bed in his sickness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Psalms 41:4",
      "text": "I said, O Lord, have mercy upon me; heal my soul; for I have sinned against thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Psalms 41:5",
      "text": "Mine enemies have spoken evil against me, saying, When shall he die, and his name perish?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Psalms 41:6",
      "text": "And if he came to see me, his heart spoke vainly; he gathered iniquity to himself; he went forth and spoke in like manner.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Psalms 41:7",
      "text": "All my enemies whispered against me; against me they devised my hurt.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Psalms 41:8",
      "text": "They denounced a wicked word against me, saying, Now that he lies, shall he not rise up again?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Psalms 41:9",
      "text": "For even the man of my peace, in whom I trusted, who ate my bread, lifted up his heel against me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Psalms 41:10",
      "text": "But thou, O Lord, have compassion upon me, and raise me up, and I shall requite them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Psalms 41:11",
      "text": "By this I know that thou hast delighted in me, because mine enemy shall not rejoice over me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Psalms 41:12",
      "text": "But thou didst help me because of mine innocence, and hast established me before thee for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.41.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Psalms 41:13",
      "text": "Blessed be the Lord God of Israel from everlasting, and to everlasting. So be it, so be it.",
      "paragraphStart": false
    }
  ]
}
