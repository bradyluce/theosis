{
  "chapter": {
    "id": "lxxe:psalms.115",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.115.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Alleluia: I believed, wherefore I have spoken: but I was greatly afflicted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "And I said in mine amazement, Every man is a liar.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "What shall I render to the Lord for all the things wherein he has rewarded me?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "I will take the cup of salvation, and call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "I will pay my vows to the Lord, in the presence of all his people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "Precious in the sight of the Lord is the death of his saints.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "O Lord, I am thy servant; I am thy servant, and the son of thine handmaid: thou hast burst by bonds asunder.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "I will offer to thee the sacrifice of praise, and will call upon the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "I will pay my vows unto the Lord, in the presence of all his people,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "in the courts of the Lord’s house, in the midst of thee, Jerusalem.",
      "paragraphStart": false
    }
  ]
}
