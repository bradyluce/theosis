{
  "chapter": {
    "id": "lxxe:psalms.115",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.115.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Not to us, O Lord, not to us, but to thy name give glory, because of thy mercy and thy truth;",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.115.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "lest at any time the nations should say, Where is their God?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "But our God has done in heaven and on earth, whatsoever he has pleased.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "The idols of the nations are silver and gold, the works of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "They have a mouth, but they cannot speak; they have eyes, but they cannot see:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "they have ears, but they cannot hear; they have noses, but they cannot smell;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "they have hands, but they cannot handle; they have feet, but they cannot walk: they cannot speak through their throat.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "Let those that make them become like to them, and all who trust in them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "The house of Israel trusts in the Lord: he is their helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "The house of Aaron trusts in the Lord: he is their helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 11,
      "referenceLabel": "Psalms 115:11",
      "text": "They that fear the Lord trust in the Lord: he is their helper and defender.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 12,
      "referenceLabel": "Psalms 115:12",
      "text": "The Lord has remembered us, and blessed us: he has blessed the house of Israel, he has blessed the house of Aaron.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 13,
      "referenceLabel": "Psalms 115:13",
      "text": "He has blessed them that fear the Lord, both small and great.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 14,
      "referenceLabel": "Psalms 115:14",
      "text": "The Lord add blessings to you and to your children.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 15,
      "referenceLabel": "Psalms 115:15",
      "text": "Blessed are ye of the Lord, who made the heaven and the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 16,
      "referenceLabel": "Psalms 115:16",
      "text": "The heaven of heavens belongs to the Lord: but he has given the earth to the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 17,
      "referenceLabel": "Psalms 115:17",
      "text": "The dead shall not praise thee, O Lord, nor any that go down to Hades.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.115.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 18,
      "referenceLabel": "Psalms 115:18",
      "text": "But we, the living, will bless the Lord, from henceforth and for ever.",
      "paragraphStart": false
    }
  ]
}
