{
  "chapter": {
    "id": "lxxe:psalms.134",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 134,
    "referenceLabel": "Psalms 134",
    "summary": "Source text for Psalms 134 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.134.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 1,
      "referenceLabel": "Psalms 134:1",
      "text": "Alleluia. - Praise ye the name of the Lord; praise the Lord, ye his servants,",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.134.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 2,
      "referenceLabel": "Psalms 134:2",
      "text": "who stand in the house of the Lord, in the courts of the house of our God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 3,
      "referenceLabel": "Psalms 134:3",
      "text": "Praise ye the Lord; for the Lord is good: sing praises to his name; for it is good.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 4,
      "referenceLabel": "Psalms 134:4",
      "text": "For the Lord has chosen Jacob for himself, and Israel for his peculiar treasure.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 5,
      "referenceLabel": "Psalms 134:5",
      "text": "For I know that the Lord is great, and our Lord is above all gods;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 6,
      "referenceLabel": "Psalms 134:6",
      "text": "all that the Lord willed, he did in heaven, and on the earth, in the sea, and in all deeps.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 7,
      "referenceLabel": "Psalms 134:7",
      "text": "Who brings up clouds from the extremity of the earth: he has made lightnings for the rain: he brings winds out of his treasures.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 8,
      "referenceLabel": "Psalms 134:8",
      "text": "Who smote the first-born of Egypt, both of man and beast.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 9,
      "referenceLabel": "Psalms 134:9",
      "text": "He sent signs and wonders into the midst of thee, O Egypt, on Pharao, and on all his servants.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 10,
      "referenceLabel": "Psalms 134:10",
      "text": "Who smote many nations, and slew mighty kings;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 11,
      "referenceLabel": "Psalms 134:11",
      "text": "Seon king of the Amorites, and Og king of Basan, and all the kingdoms of Chanaan:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 12,
      "referenceLabel": "Psalms 134:12",
      "text": "and gave their land for an inheritance, an inheritance to Israel his people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 13,
      "referenceLabel": "Psalms 134:13",
      "text": "O Lord, thy name endures for ever, and thy memorial to all generations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 14,
      "referenceLabel": "Psalms 134:14",
      "text": "For the Lord shall judge his people, and comfort himself concerning his servants.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 15,
      "referenceLabel": "Psalms 134:15",
      "text": "The idols of the heathen are silver and gold, the works of men’s hands.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 16,
      "referenceLabel": "Psalms 134:16",
      "text": "They have a mouth, but they cannot speak; they have eyes, but they cannot see;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 17,
      "referenceLabel": "Psalms 134:17",
      "text": "they have ears, but they cannot hear; for there is no breath in their mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 18,
      "referenceLabel": "Psalms 134:18",
      "text": "Let those who make them be made like to them; and all those who trust in them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 19,
      "referenceLabel": "Psalms 134:19",
      "text": "O house of Israel, bless ye the Lord: O house of Aaron, bless ye the Lord:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 20,
      "referenceLabel": "Psalms 134:20",
      "text": "O house of Levi, bless ye the Lord: ye that fear the Lord, bless the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.134.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 134,
      "verseNumber": 21,
      "referenceLabel": "Psalms 134:21",
      "text": "Blessed in Sion be the Lord, who dwells in Jerusalem.",
      "paragraphStart": false
    }
  ]
}
