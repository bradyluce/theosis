{
  "chapter": {
    "id": "lxxe:psalms.90",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.90.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "A Prayer of Moses the man of God. - Lord, thou hast been our refuge in all generations.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.90.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Before the mountains existed, and before the earth and the world were formed, even from age to age, Thou art.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "Turn not man back to his low place, whereas thou saidst, Return, ye sons of men?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "For a thousand years in thy sight are as the yesterday which is past, and as a watch in the night.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Years shall be vanity to them: let the morning pass away as grass.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "In the morning let it flower, and pass away: in the evening let it droop, let it be withered and dried up.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "For we have perished in thine anger, and in thy wrath we have been troubled.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Thou hast set our transgressions before thee: our age is in the light of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "For all our days are gone, and we have passed away in thy wrath: our years have spun out their tale as a spider.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "As for the days of our years, in them are seventy years; and if men should be in strength, eighty years: and the greater part of them would be labour and trouble; for weakness overtakes us, and we shall be chastened.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Who knows the power of thy wrath?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "and who knows how to number his days because of the fear of thy wrath? So manifest thy right hand, and those that are instructed in wisdom in the heart.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Return, O Lord, how long? and be intreated concerning thy servants.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "We have been satisfied in the morning with thy mercy; and we did exult and rejoice:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "let us rejoice in all our days, in return for the days wherein thou didst afflict us, the years wherein we saw evil.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "And look upon thy servants, and upon thy works; and guide their children.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.90.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 17,
      "referenceLabel": "Psalms 90:17",
      "text": "And let the brightness of the Lord our God be upon us: and do thou direct for us the works of our hands.",
      "paragraphStart": false
    }
  ]
}
