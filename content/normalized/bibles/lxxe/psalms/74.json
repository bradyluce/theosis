{
  "chapter": {
    "id": "lxxe:psalms.74",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 74,
    "referenceLabel": "Psalms 74",
    "summary": "Source text for Psalms 74 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.74.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 1,
      "referenceLabel": "Psalms 74:1",
      "text": "For the end, Destroy not, a Psalm of a Song for Asaph. - We will give thanks to thee, O God, we will give thanks, and call upon thy name: I will declare all thy wonderful works.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.74.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 2,
      "referenceLabel": "Psalms 74:2",
      "text": "When I shall take a set time, I will judge righteously.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 3,
      "referenceLabel": "Psalms 74:3",
      "text": "The earth is dissolved, and all that dwell in it: I have strengthened its pillars. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 4,
      "referenceLabel": "Psalms 74:4",
      "text": "I said unto the transgressors, Do not transgress; and to the sinners, Lift not up the horn.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 5,
      "referenceLabel": "Psalms 74:5",
      "text": "Lift not up your horn on high; speak not unrighteousness against God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 6,
      "referenceLabel": "Psalms 74:6",
      "text": "For good comes neither from the east, nor from the west, nor from the desert mountains.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 7,
      "referenceLabel": "Psalms 74:7",
      "text": "For God is the judge; he puts down one, and raises up another.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 8,
      "referenceLabel": "Psalms 74:8",
      "text": "For there is a cup in the hand of the Lord, full of unmingled wine; and he has turned it from side to side, but its dregs have not been wholly poured out; all the sinners of the earth shall drink them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 9,
      "referenceLabel": "Psalms 74:9",
      "text": "But I will exult for ever: I will sing praises to the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.74.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 74,
      "verseNumber": 10,
      "referenceLabel": "Psalms 74:10",
      "text": "And I will break all the horns of sinners; but the horns of the righteous one shall be exalted.",
      "paragraphStart": false
    }
  ]
}
