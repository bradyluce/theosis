{
  "chapter": {
    "id": "lxxe:psalms.103",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 103,
    "referenceLabel": "Psalms 103",
    "summary": "Source text for Psalms 103 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.103.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 1,
      "referenceLabel": "Psalms 103:1",
      "text": "A Psalm of David. - Bless the Lord, O my soul; and all that is within me, bless his holy name.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.103.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 2,
      "referenceLabel": "Psalms 103:2",
      "text": "Bless the Lord, O my soul, and forget not all his praises:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 3,
      "referenceLabel": "Psalms 103:3",
      "text": "who forgives all thy transgressions, who heals all thy diseases;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 4,
      "referenceLabel": "Psalms 103:4",
      "text": "who redeems thy life from corruption; who crowns thee with mercy and compassion;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 5,
      "referenceLabel": "Psalms 103:5",
      "text": "who satisfies thy desire with good things: so that thy youth shall be renewed like that of the eagle.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 6,
      "referenceLabel": "Psalms 103:6",
      "text": "The Lord executes mercy and judgement for all that are injured.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 7,
      "referenceLabel": "Psalms 103:7",
      "text": "He made known his ways to Moses, his will to the children of Israel.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 8,
      "referenceLabel": "Psalms 103:8",
      "text": "The Lord is compassionate and pitiful, long-suffering, and full of mercy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 9,
      "referenceLabel": "Psalms 103:9",
      "text": "He will not be always angry; neither will he be wrathful for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 10,
      "referenceLabel": "Psalms 103:10",
      "text": "He has not dealt with us according to our sins, nor recompensed us according to our iniquities.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 11,
      "referenceLabel": "Psalms 103:11",
      "text": "For as the heaven is high above the earth, the Lord has so increased his mercy toward them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 12,
      "referenceLabel": "Psalms 103:12",
      "text": "As far as the east is from the west, so far has he removed our transgressions from us.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 13,
      "referenceLabel": "Psalms 103:13",
      "text": "As a father pities his children, the Lord pities them that fear him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 14,
      "referenceLabel": "Psalms 103:14",
      "text": "For he knows our frame: remember that we are dust.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 15,
      "referenceLabel": "Psalms 103:15",
      "text": "As for man, his days are as grass; as a flower of the field, so shall he flourish.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 16,
      "referenceLabel": "Psalms 103:16",
      "text": "For the wind passes over it, and it shall not be; and it shall know its place no more.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 17,
      "referenceLabel": "Psalms 103:17",
      "text": "But the mercy of the Lord is from generation to generation upon them that fear him, and his righteousness to children’s children;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 18,
      "referenceLabel": "Psalms 103:18",
      "text": "to them that keep his covenant, and remember his commandments to do them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 19,
      "referenceLabel": "Psalms 103:19",
      "text": "The Lord has prepared his throne in the heaven; and his kingdom rules over all.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 20,
      "referenceLabel": "Psalms 103:20",
      "text": "Bless the Lord, all ye his angels, mighty in strength, who perform his bidding, ready to hearken to the voice of his words.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 21,
      "referenceLabel": "Psalms 103:21",
      "text": "Bless the Lord, all ye his hosts; ye ministers of his that do his will.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.103.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 103,
      "verseNumber": 22,
      "referenceLabel": "Psalms 103:22",
      "text": "Bless the Lord, all his works, in every place of his dominion: bless the Lord, O my soul.",
      "paragraphStart": false
    }
  ]
}
