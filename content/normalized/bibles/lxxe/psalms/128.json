    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.128.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "A Song of Degrees. - Blessed are all they that fear the Lord; who walk in his ways.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.128.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "Thou shalt eat the labours of thy hands: blessed art thou, and it shall be well with thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.128.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Thy wife shall be as a fruitful vine on the sides of thy house: thy children as young olive-plants round about thy table.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.128.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Behold, thus shall the man be blessed that fears the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.128.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "May the Lord bless thee out of Sion; and mayest thou see the prosperity of Jerusalem all the days of thy life.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.128.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "And mayest thou see thy children’s children. Peace be upon Israel.",
      "paragraphStart": false
    }
  ]
}
