{
  "chapter": {
    "id": "lxxe:psalms.112",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.112.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Alleluia. - Blessed is the man that fears the Lord: he will delight greatly in his commandments.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.112.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "His seed shall be mighty in the earth: the generation of the upright shall be blessed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "Glory and riches shall be in his house; and his righteousness endures for evermore.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "To the upright light has sprung up in darkness: he is pitiful, and merciful, and righteous.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "The good man is he that pities and lends: he will direct his affairs with judgement.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "For he shall not be moved for ever; the righteous shall be in everlasting remembrance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "He shall not be afraid of any evil report: his heart is ready to trust in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "His heart is established, he shall not fear, till he shall see his desire upon his enemies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "He has dispersed abroad; he has given to the poor; his righteousness endures for evermore: his horn shall be exalted with honour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.112.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 10,
      "referenceLabel": "Psalms 112:10",
      "text": "The sinner shall see and be angry, he shall gnash his teeth, and consume away: the desire of the sinner shall perish.",
      "paragraphStart": false
    }
  ]
}
