{
  "chapter": {
    "id": "lxxe:psalms.108",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.108.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "Song of a Psalm by David. - O God, my heart is ready, my heart is ready; I will sing and sing psalms with my glory.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.108.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "Awake, psaltery and harp; I will awake early.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "I will give thanks to thee, O Lord, among the people; I will sing praise to thee among the Gentiles.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "For thy mercy is great above the heavens, and thy truth reaches to the clouds.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "Be thou exalted, O God, above the heavens; and thy glory above all the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "That thy beloved ones may be delivered, save with thy right hand, and hear me. God has spoken in his sanctuary;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "I will be exalted, and will divide Sicima, and will measure out the valley of tents.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "Galaad is mine; and Manasses is mine; and Ephraim is the help of mine head; Judas is my king;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "Moab is the caldron of my hope; over Idumea will I cast my sandal; the Philistines are made subject to me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Who will bring me into the fortified city? or who will guide me to Idumea?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "Wilt not thou, O God, who hast rejected us? and wilt not thou, O God, go forth with our hosts?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "Give us help from tribulation: for vain is the help of man.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.108.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "Through God we shall do valiantly; and he will bring to nought our enemies.",
      "paragraphStart": false
    }
  ]
}
