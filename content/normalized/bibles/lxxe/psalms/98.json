{
  "chapter": {
    "id": "lxxe:psalms.98",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 98,
    "referenceLabel": "Psalms 98",
    "summary": "Source text for Psalms 98 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.98.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 1,
      "referenceLabel": "Psalms 98:1",
      "text": "A Psalm of David. - The Lord reigns; —let the people rage; it is he that sits upon the cherubs, let the earth be moved.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.98.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 2,
      "referenceLabel": "Psalms 98:2",
      "text": "The Lord is great in Sion, and is high over all the people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 3,
      "referenceLabel": "Psalms 98:3",
      "text": "Let them give thanks to thy great name; for it is terrible and holy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 4,
      "referenceLabel": "Psalms 98:4",
      "text": "And the king’s honour loves judgement; thou hast prepared equity, thou hast wrought judgement and justice in Jacob.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 5,
      "referenceLabel": "Psalms 98:5",
      "text": "Exalt ye the Lord our God, and worship at his footstool; for he is holy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 6,
      "referenceLabel": "Psalms 98:6",
      "text": "Moses and Aaron among his priests, and Samuel among them that call upon his name; they called upon the Lord, and he heard them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 7,
      "referenceLabel": "Psalms 98:7",
      "text": "He spoke to them in a pillar of cloud; they kept his testimonies, and the ordinances which he gave them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 8,
      "referenceLabel": "Psalms 98:8",
      "text": "O Lord our God, thou heardest them; O God, thou becamest propitious to them, though thou didst take vengeance on all their devices.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.98.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 9,
      "referenceLabel": "Psalms 98:9",
      "text": "Exalt ye the Lord our God, and worship at his holy mountain; for the Lord our God is holy.",
      "paragraphStart": false
    }
  ]
}
