{
  "chapter": {
    "id": "lxxe:psalms.88",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.88.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "A Psalm of instruction for Ætham the Israelite. - I will sing of thy mercies, O Lord, for ever: I will declare thy truth with my mouth to all generations.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.88.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "For thou hast said, Mercy shall be built up for ever: thy truth shall be established in the heavens.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "I made a covenant with my chosen ones, I sware unto David my servant.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "I will establish thy seed for ever, and build up thy throne to all generations. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "The heavens shall declare thy wonders, O Lord; and thy truth in the assembly of the saints.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "For who in the heavens shall be compared to the Lord? and who shall be likened to the Lord among the sons of God?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "God is glorified in the council of the saints; great and terrible toward all that are round about him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "O Lord God of hosts, who is like to thee? thou art mighty, O Lord, and thy truth is round about thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "Thou rulest the power of the sea; and thou calmest the tumult of its waves.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "Thou has brought down the proud as one that is slain; and with the arm of thy power thou has scattered thine enemies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "The heavens are thine, and the earth is thine: thou hast founded the world, and the fullness of it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "Thou hast created the north and the west: Thabor and Hermon shall rejoice in thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "Thine is the mighty arm: let thy hand be strengthened, let thy right hand be exalted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "Justice and judgement are the establishment of thy throne: mercy and truth shall go before thy face.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "Blessed is the people that knows the joyful sound: they shall walk, O Lord, in the light of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "And in thy name shall they rejoice all the day: and in thy righteousness shall they be exalted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "For thou art the boast of their strength; and in thy good pleasure shall our horn be exalted,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "for our help is of the Lord; and of the Holy One of Israel, our king.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 19,
      "referenceLabel": "Psalms 88:19",
      "text": "Then thou spokest in vision to thy children, and saidst, I have laid help on a mighty one; I have exalted one chosen out of my people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 20,
      "referenceLabel": "Psalms 88:20",
      "text": "I have found David my servant; I have anointed him by my holy mercy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 21,
      "referenceLabel": "Psalms 88:21",
      "text": "For my hand shall support him; and mine arm shall strengthen him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 22,
      "referenceLabel": "Psalms 88:22",
      "text": "The enemy shall have no advantage against him; and the son of transgression shall not hurt him again.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 23,
      "referenceLabel": "Psalms 88:23",
      "text": "And I will hew down his foes before him, and put to flight those that hate him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 24,
      "referenceLabel": "Psalms 88:24",
      "text": "But my truth and my mercy shall be with him; and in my name shall his horn be exalted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 25,
      "referenceLabel": "Psalms 88:25",
      "text": "And I will set his hand in the sea, and his right hand in the rivers.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 26,
      "referenceLabel": "Psalms 88:26",
      "text": "He shall call upon me, saying, Thou art my Father, my God, and the helper of my salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 27,
      "referenceLabel": "Psalms 88:27",
      "text": "And I will make him my first-born, higher than the kings of the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 28,
      "referenceLabel": "Psalms 88:28",
      "text": "I will keep my mercy for him for ever, and my covenant shall be firm with him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.29",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 29,
      "referenceLabel": "Psalms 88:29",
      "text": "And I will establish his seed for ever and ever, and his throne as the days of heaven.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.30",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 30,
      "referenceLabel": "Psalms 88:30",
      "text": "If his children should forsake my law, and walk not in my judgements;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.31",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 31,
      "referenceLabel": "Psalms 88:31",
      "text": "if they should profane my ordinances, and not keep my commandments;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.32",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 32,
      "referenceLabel": "Psalms 88:32",
      "text": "I will visit their transgressions with a rod, and their sins with scourges.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.33",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 33,
      "referenceLabel": "Psalms 88:33",
      "text": "But my mercy I will not utterly remove from him, nor wrong my truth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.34",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 34,
      "referenceLabel": "Psalms 88:34",
      "text": "Neither will I by any means profane my covenant; and I will not make void the things that proceed out of my lips.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.35",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 35,
      "referenceLabel": "Psalms 88:35",
      "text": "Once have I sworn by my holiness, that I will not lie to David.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.36",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 36,
      "referenceLabel": "Psalms 88:36",
      "text": "His see shall endure for ever, and his throne as the sun before me;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.37",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 37,
      "referenceLabel": "Psalms 88:37",
      "text": "and as the moon that is established for ever, and as the faithful witness in heaven. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.38",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 38,
      "referenceLabel": "Psalms 88:38",
      "text": "But thou hast cast off and set at nought, thou has rejected thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.39",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 39,
      "referenceLabel": "Psalms 88:39",
      "text": "Thou hast overthrown the covenant of thy servant; thou has profaned his sanctuary, casting it to the ground.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.40",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 40,
      "referenceLabel": "Psalms 88:40",
      "text": "Thou hast broken down all his hedges; thou hast made his strong holds a terror.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.41",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 41,
      "referenceLabel": "Psalms 88:41",
      "text": "All that go by the way have spoiled him: he is become a reproach to his neighbours.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.42",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 42,
      "referenceLabel": "Psalms 88:42",
      "text": "Thou hast exalted the right hand of his enemies; thou hast made all his enemies to rejoice.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.43",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 43,
      "referenceLabel": "Psalms 88:43",
      "text": "Thou hast turned back the help of his sword, and hast not helped him in the battle.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.44",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 44,
      "referenceLabel": "Psalms 88:44",
      "text": "Thou hast deprived him of glory: thou hast broken down his throne to the ground.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.45",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 45,
      "referenceLabel": "Psalms 88:45",
      "text": "Thou hast shortened the days of his throne: thou hast poured shame upon him. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.46",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 46,
      "referenceLabel": "Psalms 88:46",
      "text": "How long, O Lord, wilt thou turn away, for ever? shall thine anger flame out as fire?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.47",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 47,
      "referenceLabel": "Psalms 88:47",
      "text": "Remember what my being is: for hast thou created all the sons of men in vain?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.48",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 48,
      "referenceLabel": "Psalms 88:48",
      "text": "What man is there who shall live, and not see death? shall any one deliver his soul from the hand of Hades? Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.49",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 49,
      "referenceLabel": "Psalms 88:49",
      "text": "Where are thine ancient mercies, O Lord, which thou swarest to David in thy truth?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.50",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 50,
      "referenceLabel": "Psalms 88:50",
      "text": "Remember, O Lord, the reproach of thy servants, which I have borne in my bosom, even the reproach of many nations;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.51",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 51,
      "referenceLabel": "Psalms 88:51",
      "text": "wherewith thine enemies have reviled, O Lord: wherewith they have reviled the recompense of thine anointed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.88.52",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 52,
      "referenceLabel": "Psalms 88:52",
      "text": "Blessed be the Lord for ever. So be it, so be it.",
      "paragraphStart": false
    }
  ]
}
