{
  "chapter": {
    "id": "lxxe:psalms.62",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 62,
    "referenceLabel": "Psalms 62",
    "summary": "Source text for Psalms 62 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.62.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 1,
      "referenceLabel": "Psalms 62:1",
      "text": "A Psalm of David, when he was in the wilderness of Idumea. - O God, my God, I cry to thee early; my soul has thirsted for thee: how often has my flesh longed after thee, in a barren and trackless and dry land!",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.62.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 2,
      "referenceLabel": "Psalms 62:2",
      "text": "Thus have I appeared before thee in the sanctuary, that I might see thy power and thy glory.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 3,
      "referenceLabel": "Psalms 62:3",
      "text": "For thy mercy is better than life: my lips shall praise thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 4,
      "referenceLabel": "Psalms 62:4",
      "text": "Thus will I bless thee during my life: I will lift up my hands in thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 5,
      "referenceLabel": "Psalms 62:5",
      "text": "Let my soul be filled as with marrow and fatness; and my joyful lips shall praise thy name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 6,
      "referenceLabel": "Psalms 62:6",
      "text": "Forasmuch as I have remembered thee on my bed: in the early seasons I have meditated on thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 7,
      "referenceLabel": "Psalms 62:7",
      "text": "For thou hast been my helper, and in the shelter of thy wings will I rejoice.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 8,
      "referenceLabel": "Psalms 62:8",
      "text": "My soul has kept very close behind thee: thy right hand has upheld me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 9,
      "referenceLabel": "Psalms 62:9",
      "text": "But they vainly sought after my soul; they shall go into the lowest parts of the earth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 10,
      "referenceLabel": "Psalms 62:10",
      "text": "They shall be delivered up to the power of the sword; they shall be portions for foxes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.62.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 11,
      "referenceLabel": "Psalms 62:11",
      "text": "But the king shall rejoice in God; every one that swears by him shall be praised; for the mouth of them that speak unjust things has been stopped.",
      "paragraphStart": false
    }
  ]
}
