{
  "chapter": {
    "id": "lxxe:psalms.76",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.76.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "For the end, for Idithun, a Psalm of Asaph. - I cried to the Lord with my voice, yea, my voice was addressed to God; and he gave heed to me.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.76.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "In the day of mine affliction I earnestly sought the Lord; even with my hands by night before him, and I was not deceived; my soul refused to be comforted.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "I remembered God, and rejoiced; I poured out my complaint, and my soul fainted. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "All mine enemies set a watch against me: I was troubled, and spoke not.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "I considered the days of old, and remembered ancient years.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "And I meditated; I communed with my heart by night, and diligently searched my spirit, saying,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "Will the Lord cast off for ever? and will he be well pleased no more?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "Will he cut off his mercy for ever, even for ever and ever?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "Will God forget to pity? or will he shut up his compassions in his wrath? Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "And I said, Now I have begun; this is the change of the right hand of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "I remembered the works of the Lord; for I will remember thy wonders from the beginning.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "And I will meditate on all thy works, and will consider thy doings.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 13,
      "referenceLabel": "Psalms 76:13",
      "text": "O God, thy way is in the sanctuary; who is a great God as our God?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 14,
      "referenceLabel": "Psalms 76:14",
      "text": "Thou art the God that doest wonders; thou hast made known thy power among the nations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 15,
      "referenceLabel": "Psalms 76:15",
      "text": "Thou hast with thine arm redeemed thy people, the sons of Jacob and Joseph. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 16,
      "referenceLabel": "Psalms 76:16",
      "text": "The waters saw thee, O God, the waters saw thee, and feared; and the depths were troubled.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 17,
      "referenceLabel": "Psalms 76:17",
      "text": "There was an abundant sound of waters: the clouds uttered a voice; for thine arrows went abroad.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 18,
      "referenceLabel": "Psalms 76:18",
      "text": "The voice of thy thunder was abroad, and around thy lightnings appeared to the world; the earth trembled and quaked.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 19,
      "referenceLabel": "Psalms 76:19",
      "text": "Thy way is in the sea, and thy paths in many waters, and thy footsteps cannot be known.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 20,
      "referenceLabel": "Psalms 76:20",
      "text": "Thou didst guide thy people as sheep by the hand of Moses and Aaron.",
      "paragraphStart": false
    }
  ]
}
