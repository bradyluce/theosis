{
  "chapter": {
    "id": "lxxe:psalms.76",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.76.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "For the end, among the Hymns, a Psalm for Asaph; a Song for the Assyrian. - God is known in Judea: his name is great in Israel.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.76.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "And his place has been in peace, and his dwelling-place in Sion.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "There he broke the power of the bows, the shield, and the sword, and the battle. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "Thou dost wonderfully shine forth from the everlasting mountains.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "All the simple ones in heart were troubled; all the men of wealth have slept their sleep, and have found nothing in their hands.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "At thy rebuke, O God of Jacob, the riders on horses slumbered.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "Thou art terrible; and who shall withstand thee, because of thine anger?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "Thou didst cause judgement to be heard from heaven; the earth feared, and was still,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "when God arose to judgement, to save all the meek in heart. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "For the inward thought of man shall give thanks to thee: and the memorial of his inward thought shall keep a feast to thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "Vow, and pay your vows to the Lord our God; all that are round about him shall bring gifts, even to him that is terrible,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.76.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "and that takes away the spirits of princes; to him that is terrible among the kings of the earth.",
      "paragraphStart": false
    }
  ]
}
