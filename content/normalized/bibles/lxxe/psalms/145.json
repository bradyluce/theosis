{
  "chapter": {
    "id": "lxxe:psalms.145",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.145.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "David’s Psalm of praise. - I will exalt thee, my God, my king; and I will bless thy name for ever and ever.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.145.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Every day will I bless thee, and I will praise thy name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "The Lord is great, and greatly to be praised; and there is no end to his greatness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "Generation after generation shall praise thy works, and tell of thy power.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "And they shall speak of the glorious majesty of thy holiness, and recount thy wonders.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "And they shall speak of the power of thy terrible acts; and recount thy greatness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "They shall utter the memory of the abundance of thy goodness, and shall exult in thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "The Lord is compassionate, and merciful; long suffering, and abundant in mercy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "The Lord is good to those that wait on him; and his compassions are over all his works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "Let all thy works, O Lord, give thanks to thee; and let thy saints bless thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 11,
      "referenceLabel": "Psalms 145:11",
      "text": "They shall speak of the glory of thy kingdom, and talk of thy dominion;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 12,
      "referenceLabel": "Psalms 145:12",
      "text": "to make known to the sons of men thy power, and the glorious majesty of thy kingdom.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 13,
      "referenceLabel": "Psalms 145:13",
      "text": "Thy kingdom is an everlasting kingdom, and thy dominion endures through all generations. The Lord is faithful in his words, and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 14,
      "referenceLabel": "Psalms 145:14",
      "text": "The Lord supports all that are falling, and sets up all that are broken down.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 15,
      "referenceLabel": "Psalms 145:15",
      "text": "The eyes of all wait upon thee; and thou givest them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 16,
      "referenceLabel": "Psalms 145:16",
      "text": "Thou openest thine hands, and fillest every living thing with pleasure.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 17,
      "referenceLabel": "Psalms 145:17",
      "text": "The Lord is righteous in all his ways, and holy in all his works.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 18,
      "referenceLabel": "Psalms 145:18",
      "text": "The Lord is near to all that call upon him, to all that call upon him in truth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 19,
      "referenceLabel": "Psalms 145:19",
      "text": "He will perform the desire of them that fear him: and he will hear their supplication, and save them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 20,
      "referenceLabel": "Psalms 145:20",
      "text": "The Lord preserves all that love him: but all sinners he will utterly destroy.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.145.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 21,
      "referenceLabel": "Psalms 145:21",
      "text": "My mouth shall speak the praise of the Lord: and let all flesh bless his holy name for ever and ever.",
      "paragraphStart": false
    }
  ]
}
