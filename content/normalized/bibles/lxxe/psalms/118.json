{
  "chapter": {
    "id": "lxxe:psalms.118",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 118,
    "referenceLabel": "Psalms 118",
    "summary": "Source text for Psalms 118 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.118.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 1,
      "referenceLabel": "Psalms 118:1",
      "text": "Alleluia. - Give thanks to the Lord; for he is good: for his mercy endures for ever.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.118.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 2,
      "referenceLabel": "Psalms 118:2",
      "text": "Let now the house of Israel say, that he is good: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 3,
      "referenceLabel": "Psalms 118:3",
      "text": "Let now the house of Aaron say, that he is good: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 4,
      "referenceLabel": "Psalms 118:4",
      "text": "Let now all that fear the Lord say, that he is good: for his mercy endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 5,
      "referenceLabel": "Psalms 118:5",
      "text": "I called on the Lord out of affliction: and he hearkened to me, so as to bring me into a wide place.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 6,
      "referenceLabel": "Psalms 118:6",
      "text": "The Lord is my helper; and I will not fear what man shall do to me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 7,
      "referenceLabel": "Psalms 118:7",
      "text": "The Lord is my helper; and I shall see my desire upon mine enemies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 8,
      "referenceLabel": "Psalms 118:8",
      "text": "It is better to trust in the Lord than to trust in man.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 9,
      "referenceLabel": "Psalms 118:9",
      "text": "It is better to hope in the Lord, than to hope in princes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 10,
      "referenceLabel": "Psalms 118:10",
      "text": "All nations compassed me about: but in the name of the Lord I repulsed them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 11,
      "referenceLabel": "Psalms 118:11",
      "text": "They completely compassed me about: but in the name of the Lord I repulsed them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 12,
      "referenceLabel": "Psalms 118:12",
      "text": "They compassed me about as bees do a honeycomb, and they burst into flame as fire among thorns: but in the name of the Lord I repulsed them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 13,
      "referenceLabel": "Psalms 118:13",
      "text": "I was thrust, and sorely shaken, that I might fall: but the Lord helped me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 14,
      "referenceLabel": "Psalms 118:14",
      "text": "The Lord is my strength and my song, and is become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 15,
      "referenceLabel": "Psalms 118:15",
      "text": "The voice of exultation and salvation is in the tabernacles of the righteous: the right hand of the Lord has wrought mightily.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 16,
      "referenceLabel": "Psalms 118:16",
      "text": "The right hand of the Lord has exalted me: the right hand of the Lord has wrought powerfully.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 17,
      "referenceLabel": "Psalms 118:17",
      "text": "I shall not die, but live, and recount the works of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 18,
      "referenceLabel": "Psalms 118:18",
      "text": "The Lord has chastened me sore: but he has not given me up to death.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 19,
      "referenceLabel": "Psalms 118:19",
      "text": "Open to me the gates of righteousness: I will go into them, and give praise to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 20,
      "referenceLabel": "Psalms 118:20",
      "text": "This is the gate of the Lord: the righteous shall enter by it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.21",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 21,
      "referenceLabel": "Psalms 118:21",
      "text": "I will give thanks to thee; because thou hast heard me, and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.22",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 22,
      "referenceLabel": "Psalms 118:22",
      "text": "The stone which the builders rejected, the same is become the head of the corner.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.23",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 23,
      "referenceLabel": "Psalms 118:23",
      "text": "This has been done of the Lord; and it is wonderful in our eyes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.24",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 24,
      "referenceLabel": "Psalms 118:24",
      "text": "This is the day which the Lord has made: let us exult and rejoice in it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.25",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 25,
      "referenceLabel": "Psalms 118:25",
      "text": "O Lord, save now: O Lord, send now prosperity.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.26",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 26,
      "referenceLabel": "Psalms 118:26",
      "text": "Blessed is he that comes in the name of the Lord: we have blessed you out of the house of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.27",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 27,
      "referenceLabel": "Psalms 118:27",
      "text": "God is the Lord, and he has shined upon us: celebrate the feast with thick branches, binding the victims even to the horns of the altar.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.28",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 28,
      "referenceLabel": "Psalms 118:28",
      "text": "Thou art my God, and I will give thee thanks: thou art my God, and I will exalt thee. I will give thanks to thee, for thou hast heard me, and art become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.118.29",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 29,
      "referenceLabel": "Psalms 118:29",
      "text": "Give thanks to the Lord; for he is good: for his mercy endures for ever.",
      "paragraphStart": false
    }
  ]
}
