{
  "chapter": {
    "id": "lxxe:psalms.66",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.66.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "For the end, a Song of Psalm of resurrection. - Shout unto God, all the earth.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.66.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "O sing praises to his name; give glory to his praise.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "Say unto God, How awful are thy works! through the greatness of thy power thine enemies shall lie to thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "Let all the earth worship thee, and sing to thee; let them sing to thy name. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Come and behold the works of God; he is terrible in his counsels beyond the children of men.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "Who turns the sea into dry land; they shall go through the river on foot; there shall we rejoice in him,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "who by his power is Lord over the age, his eyes look upon the nations; let not them that provoke him be exalted in themselves. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "Bless our God, ye Gentiles, and make the voice of his praise to be heard;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 9,
      "referenceLabel": "Psalms 66:9",
      "text": "who quickens my soul in life, and does not suffer my feet to be moved.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.10",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 10,
      "referenceLabel": "Psalms 66:10",
      "text": "For thou, O God, has proved us; thou hast tried us with fire as silver is tried.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.11",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 11,
      "referenceLabel": "Psalms 66:11",
      "text": "Thou broughtest us into the snare; thou laidest afflictions on our back.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.12",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 12,
      "referenceLabel": "Psalms 66:12",
      "text": "Thou didst mount men upon our heads; we went through the fire and water; but thou broughtest us out into a place of refreshment.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.13",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 13,
      "referenceLabel": "Psalms 66:13",
      "text": "I will go into thine house with whole-burnt-offerings; I will pay thee my vows,",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.14",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 14,
      "referenceLabel": "Psalms 66:14",
      "text": "which my lips framed, and my mouth uttered in my affliction.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.15",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 15,
      "referenceLabel": "Psalms 66:15",
      "text": "I will offer to thee whole-burnt-sacrifices full of marrow, with incense and rams; I will sacrifice to thee oxen with goats. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.16",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 16,
      "referenceLabel": "Psalms 66:16",
      "text": "Come, hear, and I will tell, all ye that fear God, how great things he has done for my soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.17",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 17,
      "referenceLabel": "Psalms 66:17",
      "text": "I cried to him with my mouth, and exalted him with my tongue.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.18",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 18,
      "referenceLabel": "Psalms 66:18",
      "text": "If I have regarded iniquity in my heart, let not the Lord hearken to me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.19",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 19,
      "referenceLabel": "Psalms 66:19",
      "text": "Therefore God has hearkened to me; he has attended to the voice of my prayer.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.66.20",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 20,
      "referenceLabel": "Psalms 66:20",
      "text": "Blessed be God, who has not turned away my prayer, nor his mercy from me.",
      "paragraphStart": false
    }
  ]
}
