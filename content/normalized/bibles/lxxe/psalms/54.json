{
  "chapter": {
    "id": "lxxe:psalms.54",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.54.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "For the end, among Hymns of instruction by David, when the Ziphites came and said to Saul, Lo, is not David hid with us? - Save me, O God, by thy name, and judge me by thy might.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.54.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "O God, hear my prayer; hearken to the words of my mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.54.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "For strangers have risen up against me, and mighty men have sought my life: they have not set God before them. Pause.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.54.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "For lo! God assists me; and the Lord is the helper of my soul.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.54.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "He shall return evil to mine enemies; utterly destroy them in thy truth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.54.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "I will willingly sacrifice to thee: I will give thanks to thy name, O Lord; for it is good.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.54.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "For thou hast delivered me out of all affliction, and mine eye has seen my desire upon mine enemies.",
      "paragraphStart": false
    }
  ]
}
