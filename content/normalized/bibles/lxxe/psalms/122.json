{
  "chapter": {
    "id": "lxxe:psalms.122",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 122,
    "referenceLabel": "Psalms 122",
    "summary": "Source text for Psalms 122 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.122.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "A Song of Degrees. - I was glad when they said to me, Let us go into the house of the Lord.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.122.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Our feet stood in thy courts, O Jerusalem.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Jerusalem is built as a city whose fellowship is complete.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "For thither the tribes went up, the tribes of the Lord, as a testimony for Israel, to give thanks unto the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 5,
      "referenceLabel": "Psalms 122:5",
      "text": "For there are set thrones for judgement, even thrones for the house of David.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 6,
      "referenceLabel": "Psalms 122:6",
      "text": "Pray now for the peace of Jerusalem: and let there be prosperity to them that love thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 7,
      "referenceLabel": "Psalms 122:7",
      "text": "Let peace, I pray, be within thine host, and prosperity in thy palaces.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 8,
      "referenceLabel": "Psalms 122:8",
      "text": "For the sake of my brethren and my neighbours, I have indeed spoken peace concerning thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.122.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 9,
      "referenceLabel": "Psalms 122:9",
      "text": "Because of the house of the Lord our God, I have diligently sought thy good.",
      "paragraphStart": false
    }
  ]
}
