{
  "chapter": {
    "id": "lxxe:psalms.149",
    "translationId": "lxxe",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalms.149.1",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Alleluia. Sing to the Lord a new song: his praise is in the assembly of the saints.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalms.149.2",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Let Israel rejoice in him that made him; and let the children of Sion exult in their king.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.3",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Let them praise his name in the dance: let them sings praises to him with timbrel and psaltery.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.4",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "For the Lord takes pleasure in his people; and will exalt the meek with salvation.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.5",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "The saints shall rejoice in glory; and shall exult on their beds.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.6",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "The high praises of God shall be in their throat, and two-edged swords in their hands;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.7",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "to execute vengeance on the nations, and punishments among the peoples;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.8",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "to bind their kings with fetters, and their nobles with manacles of iron;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalms.149.9",
      "translationId": "lxxe",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "to execute on them the judgement written: this honour have all his saints.",
      "paragraphStart": false
    }
  ]
}
