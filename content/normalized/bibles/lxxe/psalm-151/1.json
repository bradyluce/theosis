{
  "chapter": {
    "id": "lxxe:psalm-151.1",
    "translationId": "lxxe",
    "bookSlug": "psalm-151",
    "chapterNumber": 1,
    "referenceLabel": "Psalm 151 1",
    "summary": "Source text for Psalm 151 1 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:psalm-151.1.1",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Psalm 151 1:1",
      "text": "This Psalm is a genuine one of David, though supernumerary, composed when he fought in single combat with Goliad. - I was small among my brethren, and youngest in my father’s house: I tended my father’s sheep.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:psalm-151.1.2",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Psalm 151 1:2",
      "text": "My hands formed a musical instrument, and my fingers tuned a psaltery.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalm-151.1.3",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Psalm 151 1:3",
      "text": "And who shall tell my Lord? the Lord himself, he himself hears.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalm-151.1.4",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Psalm 151 1:4",
      "text": "He sent forth his angel, and took me from my father’s sheep, and he anointed me with the oil of his anointing.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalm-151.1.5",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Psalm 151 1:5",
      "text": "My brothers were handsome and tall; but the Lord did not take pleasure in them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalm-151.1.6",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Psalm 151 1:6",
      "text": "I went forth to meet the Philistine; and he cursed me by his idols.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:psalm-151.1.7",
      "translationId": "lxxe",
      "bookSlug": "psalm-151",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Psalm 151 1:7",
      "text": "But I drew his own sword, and beheaded him, and removed reproach from the children of Israel.",
      "paragraphStart": false
    }
  ]
}
