{
  "chapter": {
    "id": "lxxe:sirach.7",
    "translationId": "lxxe",
    "bookSlug": "sirach",
    "chapterNumber": 7,
    "referenceLabel": "Sirach 7",
    "summary": "Source text for Sirach 7 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:sirach.7.1",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Sirach 7:1",
      "text": "Do no evil, so shall no harm come unto thee.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:sirach.7.2",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Sirach 7:2",
      "text": "Depart from the unjust, and iniquity shall turn away from thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.3",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Sirach 7:3",
      "text": "My son, sow not upon the furrows of unrighteousness, and thou shalt not reap them sevenfold.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.4",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Sirach 7:4",
      "text": "Seek not of the Lord preeminence, neither of the king the seat of honour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.5",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Sirach 7:5",
      "text": "justify not thyself before the Lord; and boast not of thy wisdom before the king.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.6",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Sirach 7:6",
      "text": "Seek not to be judge, being not able to take away iniquity; lest at any time thou fear the person of the mighty, an stumblingblock in the way of thy uprightness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.7",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Sirach 7:7",
      "text": "Offend not against the multitude of a city, and then thou shalt not cast thyself down among the people.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.8",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Sirach 7:8",
      "text": "Bind not one sin upon another; for in one thou shalt not be unpunished.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.9",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Sirach 7:9",
      "text": "Say not, God will look upon the multitude of my oblations, and when I offer to the most high God, he will accept it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.10",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Sirach 7:10",
      "text": "Be not fainthearted when thou makest thy prayer, and neglect not to give alms.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.11",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Sirach 7:11",
      "text": "Laugh no man to scorn in the bitterness of his soul: for there is one which humbleth and exalteth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.12",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Sirach 7:12",
      "text": "Devise not a lie against thy brother; neither do the like to thy friend.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.13",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Sirach 7:13",
      "text": "Use not to make any manner of lie: for the custom thereof is not good.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.14",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Sirach 7:14",
      "text": "Use not many words in a multitude of elders, and make not much babbling when thou prayest.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.15",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Sirach 7:15",
      "text": "Hate not laborious work, neither husbandry, which the most High hath ordained.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.16",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Sirach 7:16",
      "text": "Number not thyself among the multitude of sinners, but remember that wrath will not tarry long.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.17",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Sirach 7:17",
      "text": "Humble thyself greatly: for the vengeance of the ungodly is fire and worms.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.18",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Sirach 7:18",
      "text": "Change not a friend for any good by no means; neither a faithful brother for the gold of Ophir.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.19",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Sirach 7:19",
      "text": "Forego not a wise and good woman: for her grace is above gold.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.20",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Sirach 7:20",
      "text": "Whereas thy servant worketh truly, entreat him not evil. nor the hireling that bestoweth himself wholly for thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.21",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Sirach 7:21",
      "text": "Let thy soul love a good servant, and defraud him not of liberty.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.22",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Sirach 7:22",
      "text": "Hast thou cattle? have an eye to them: and if they be for thy profit, keep them with thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.23",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Sirach 7:23",
      "text": "Hast thou children? instruct them, and bow down their neck from their youth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.24",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Sirach 7:24",
      "text": "Hast thou daughters? have a care of their body, and shew not thyself cheerful toward them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.25",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Sirach 7:25",
      "text": "Marry thy daughter, and so shalt thou have performed a weighty matter: but give her to a man of understanding.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.26",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Sirach 7:26",
      "text": "Hast thou a wife after thy mind? forsake her not: but give not thyself over to a light woman.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.27",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Sirach 7:27",
      "text": "Honour thy father with thy whole heart, and forget not the sorrows of thy mother.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.28",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Sirach 7:28",
      "text": "Remember that thou wast begotten of them; and how canst thou recompense them the things that they have done for thee?",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.29",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Sirach 7:29",
      "text": "Fear the Lord with all thy soul, and reverence his priests.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.30",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Sirach 7:30",
      "text": "Love him that made thee with all thy strength, and forsake not his ministers.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.31",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Sirach 7:31",
      "text": "Fear the Lord, and honour the priest; and give him his portion, as it is commanded thee; the firstfruits, and the trespass offering, and the gift of the shoulders, and the sacrifice of sanctification, and the firstfruits of the holy things.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.32",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Sirach 7:32",
      "text": "And stretch thine hand unto the poor, that thy blessing may be perfected.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.33",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Sirach 7:33",
      "text": "A gift hath grace in the sight of every man living; and for the dead detain it not.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.34",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Sirach 7:34",
      "text": "Fail not to be with them that weep, and mourn with them that mourn.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.35",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Sirach 7:35",
      "text": "Be not slow to visit the sick: fir that shall make thee to be beloved.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.7.36",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Sirach 7:36",
      "text": "Whatsoever thou takest in hand, remember the end, and thou shalt never do amiss.",
      "paragraphStart": false
    }
  ]
}
