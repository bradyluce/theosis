{
  "chapter": {
    "id": "lxxe:sirach.8",
    "translationId": "lxxe",
    "bookSlug": "sirach",
    "chapterNumber": 8,
    "referenceLabel": "Sirach 8",
    "summary": "Source text for Sirach 8 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:sirach.8.1",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Sirach 8:1",
      "text": "Strive not with a mighty man’ lest thou fall into his hands.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:sirach.8.2",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Sirach 8:2",
      "text": "Be not at variance with a rich man, lest he overweigh thee: for gold hath destroyed many, and perverted the hearts of kings.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.3",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Sirach 8:3",
      "text": "Strive not with a man that is full of tongue, and heap not wood upon his fire.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.4",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Sirach 8:4",
      "text": "Jest not with a rude man, lest thy ancestors be disgraced.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.5",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Sirach 8:5",
      "text": "Reproach not a man that turneth from sin, but remember that we are all worthy of punishment.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.6",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Sirach 8:6",
      "text": "Dishonour not a man in his old age: for even some of us wax old.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.7",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Sirach 8:7",
      "text": "Rejoice not over thy greatest enemy being dead, but remember that we die all.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.8",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Sirach 8:8",
      "text": "Despise not the discourse of the wise, but acquaint thyself with their proverbs: for of them thou shalt learn instruction, and how to serve great men with ease.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.9",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Sirach 8:9",
      "text": "Miss not the discourse of the elders: for they also learned of their fathers, and of them thou shalt learn understanding, and to give answer as need requireth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.10",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Sirach 8:10",
      "text": "Kindle not the coals of a sinner, lest thou be burnt with the flame of his fire.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.11",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Sirach 8:11",
      "text": "Rise not up in anger at the presence of an injurious person, lest he lie in wait to entrap thee in thy words",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.12",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Sirach 8:12",
      "text": "Lend not unto him that is mightier than thyself; for if thou lendest him, count it but lost.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.13",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Sirach 8:13",
      "text": "Be not surety above thy power: for if thou be surety, take care to pay it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.14",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Sirach 8:14",
      "text": "Go not to law with a judge; for they will judge for him according to his honour.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.15",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Sirach 8:15",
      "text": "Travel not by the way with a bold fellow, lest he become grievous unto thee: for he will do according to his own will, and thou shalt perish with him through his folly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.16",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Sirach 8:16",
      "text": "Strive not with an angry man, and go not with him into a solitary place: for blood is as nothing in his sight, and where there is no help, he will overthrow thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.17",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Sirach 8:17",
      "text": "Consult not with a fool; for he cannot keep counsel.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.18",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Sirach 8:18",
      "text": "Do no secret thing before a stranger; for thou knowest not what he will bring forth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.8.19",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Sirach 8:19",
      "text": "Open not thine heart to every man, lest he requite thee with a shrewd turn.",
      "paragraphStart": false
    }
  ]
}
