{
  "chapter": {
    "id": "lxxe:sirach.3",
    "translationId": "lxxe",
    "bookSlug": "sirach",
    "chapterNumber": 3,
    "referenceLabel": "Sirach 3",
    "summary": "Source text for Sirach 3 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:sirach.3.1",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Sirach 3:1",
      "text": "Hear me your father, O children, and do thereafter, that ye may be safe.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:sirach.3.2",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Sirach 3:2",
      "text": "For the Lord hath given the father honour over the children, and hath confirmed the authority of the mother over the sons.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.3",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Sirach 3:3",
      "text": "Whoso honoureth his father maketh an atonement for his sins:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.4",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Sirach 3:4",
      "text": "And he that honoureth his mother is as one that layeth up treasure.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.5",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Sirach 3:5",
      "text": "Whoso honoureth his father shall have joy of his own children; and when he maketh his prayer, he shall be heard.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.6",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Sirach 3:6",
      "text": "He that honoureth his father shall have a long life; and he that is obedient unto the Lord shall be a comfort to his mother.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.7",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Sirach 3:7",
      "text": "He that feareth the Lord will honour his father, and will do service unto his parents, as to his masters.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.8",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Sirach 3:8",
      "text": "Honour thy father and mother both in word and deed, that a blessing may come upon thee from them.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.9",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Sirach 3:9",
      "text": "For the blessing of the father establisheth the houses of children; but the curse of the mother rooteth out foundations.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.10",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Sirach 3:10",
      "text": "Glory not in the dishonour of thy father; for thy father’s dishonour is no glory unto thee.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.11",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Sirach 3:11",
      "text": "For the glory of a man is from the honour of his father; and a mother in dishonour is a reproach to the children.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.12",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Sirach 3:12",
      "text": "My son, help thy father in his age, and grieve him not as long as he liveth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.13",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Sirach 3:13",
      "text": "And if his understanding fail, have patience with him; and despise him not when thou art in thy full strength.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.14",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Sirach 3:14",
      "text": "For the relieving of thy father shall not be forgotten: and instead of sins it shall be added to build thee up.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.15",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Sirach 3:15",
      "text": "In the day of thine affliction it shall be remembered; thy sins also shall melt away, as the ice in the fair warm weather.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.16",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Sirach 3:16",
      "text": "He that forsaketh his father is as a blasphemer; and he that angereth his mother is cursed: of God.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.17",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Sirach 3:17",
      "text": "My son, go on with thy business in meekness; so shalt thou be beloved of him that is approved.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.18",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Sirach 3:18",
      "text": "The greater thou art, the more humble thyself, and thou shalt find favour before the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.19",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Sirach 3:19",
      "text": "Many are in high place, and of renown: but mysteries are revealed unto the meek.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.20",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Sirach 3:20",
      "text": "For the power of the Lord is great, and he is honoured of the lowly.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.21",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Sirach 3:21",
      "text": "Seek not out things that are too hard for thee, neither search the things that are above thy strength.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.22",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Sirach 3:22",
      "text": "But what is commanded thee, think thereupon with reverence, for it is not needful for thee to see with thine eyes the things that are in secret.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.23",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Sirach 3:23",
      "text": "Be not curious in unnecessary matters: for more things are shewed unto thee than men understand.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.24",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Sirach 3:24",
      "text": "For many are deceived by their own vain opinion; and an evil suspicion hath overthrown their judgement.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.25",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Sirach 3:25",
      "text": "Without eyes thou shalt want light: profess not the knowledge therefore that thou hast not.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.26",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Sirach 3:26",
      "text": "A stubborn heart shall fare evil at the last; and he that loveth danger shall perish therein.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.27",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Sirach 3:27",
      "text": "An obstinate heart shall be laden with sorrows; and the wicked man shall heap sin upon sin.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.28",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Sirach 3:28",
      "text": "In the punishment of the proud there is no remedy; for the plant of wickedness hath taken root in him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.29",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Sirach 3:29",
      "text": "The heart of the prudent will understand a parable; and an attentive ear is the desire of a wise man.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.30",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Sirach 3:30",
      "text": "Water will quench a flaming fire; and alms maketh an atonement for sins.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.3.31",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Sirach 3:31",
      "text": "And he that requiteth good turns is mindful of that which may come hereafter; and when he falleth, he shall find a stay.",
      "paragraphStart": false
    }
  ]
}
