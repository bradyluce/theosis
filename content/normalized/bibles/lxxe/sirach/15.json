{
  "chapter": {
    "id": "lxxe:sirach.15",
    "translationId": "lxxe",
    "bookSlug": "sirach",
    "chapterNumber": 15,
    "referenceLabel": "Sirach 15",
    "summary": "Source text for Sirach 15 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:sirach.15.1",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Sirach 15:1",
      "text": "He that feareth the Lord will do good, and he that hath the knowledge of the law shall obtain her.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:sirach.15.2",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Sirach 15:2",
      "text": "And as a mother shall she meet him, and receive him as a wife married of a virgin.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.3",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Sirach 15:3",
      "text": "With the bread of understanding shall she feed him, and give him the water of wisdom to drink.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.4",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Sirach 15:4",
      "text": "He shall be stayed upon her, and shall not be moved; and shall rely upon her, and shall not be confounded.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.5",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Sirach 15:5",
      "text": "She shall exalt him above his neighbours, and in the midst of the congregation shall she open his mouth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.6",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Sirach 15:6",
      "text": "He shall find joy and a crown of gladness, and she shall cause him to inherit an everlasting name.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.7",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Sirach 15:7",
      "text": "But foolish men shall not attain unto her, and sinners shall not see her.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.8",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Sirach 15:8",
      "text": "For she is far from pride, and men that are liars cannot remember her.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.9",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Sirach 15:9",
      "text": "Praise is not seemly in the mouth of a sinner, for it was not sent him of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.10",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Sirach 15:10",
      "text": "For praise shall be uttered in wisdom, and the Lord will prosper it.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.11",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Sirach 15:11",
      "text": "Say not thou, It is through the Lord that I fell away: for thou oughtest not to do the things that he hateth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.12",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Sirach 15:12",
      "text": "Say not thou, He hath caused me to err: for he hath no need of the sinful man.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.13",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Sirach 15:13",
      "text": "The Lord hateth all abomination; and they that fear God love it not.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.14",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Sirach 15:14",
      "text": "He himself made man from the beginning, and left him in the hand of his counsel;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.15",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Sirach 15:15",
      "text": "If thou wilt, to keep the commandments, and to perform acceptable faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.16",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Sirach 15:16",
      "text": "He hath set fire and water before thee: stretch forth thy hand unto whether thou wilt.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.17",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Sirach 15:17",
      "text": "Before man is life and death; and whether him liketh shall be given him.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.18",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Sirach 15:18",
      "text": "For the wisdom of the Lord is great, and he is mighty in power, and beholdeth all things:",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.19",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Sirach 15:19",
      "text": "And his eyes are upon them that fear him, and he knoweth every work of man.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:sirach.15.20",
      "translationId": "lxxe",
      "bookSlug": "sirach",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Sirach 15:20",
      "text": "He hath commanded no man to do wickedly, neither hath he given any man licence to sin.",
      "paragraphStart": false
    }
  ]
}
