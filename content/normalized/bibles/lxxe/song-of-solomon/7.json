{
  "chapter": {
    "id": "lxxe:song-of-solomon.7",
    "translationId": "lxxe",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 7,
    "referenceLabel": "Song of Solomon 7",
    "summary": "Source text for Song of Solomon 7 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:song-of-solomon.7.1",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 7:1",
      "text": "Thy steps are beautiful in shoes, O daughter of the prince: the joints of thy thighs are like chains, the work of the craftsman.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:song-of-solomon.7.2",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 7:2",
      "text": "Thy navel is as a turned bowl, not wanting liquor; thy belly is as a heap of wheat set about with lilies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.3",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 7:3",
      "text": "Thy two breasts are as two twin fawns.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.4",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 7:4",
      "text": "Thy neck is as an ivory tower; thine eyes are as pools in Esebon, by the gates of the daughter of many: thy nose is as the tower of Libanus, looking toward Damascus.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.5",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 7:5",
      "text": "Thy head upon thee is as Carmel, and the curls of thy hair like scarlet; the king is bound in the galleries.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.6",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 7:6",
      "text": "How beautiful art thou, and how sweet art thou, my love!",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.7",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 7:7",
      "text": "This is thy greatness in thy delights: thou wast made like a palm tree, and thy breasts to cluster.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.8",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 7:8",
      "text": "I said, I will go up to the palm tree, I will take hold of its high boughs: and now shall thy breasts be as clusters of the vine, and the smell of thy nose of apples;",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.9",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 7:9",
      "text": "and thy throat as good wine, going well with my kinsman, suiting my lips and teeth.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.10",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 7:10",
      "text": "I am my kinsman’s, and his desire is toward me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.11",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 7:11",
      "text": "Come, my kinsman, let us go forth into the field; let us lodge in the villages.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.12",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 7:12",
      "text": "Let us go early into the vineyards; let us see if the vine has flowered, if the blossoms have appeared, if the pomegranates have blossomed; there will I give thee my breasts.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.7.13",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 7:13",
      "text": "The mandrakes have given a smell, and at our doors are all kinds of choice fruits, new and old. O my kinsman, I have kept them for thee.",
      "paragraphStart": false
    }
  ]
}
