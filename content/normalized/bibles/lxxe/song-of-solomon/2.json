{
  "chapter": {
    "id": "lxxe:song-of-solomon.2",
    "translationId": "lxxe",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in Brenton's English Septuagint."
  },
  "verses": [
    {
      "id": "lxxe:song-of-solomon.2.1",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "I am a flower of the plain, a lily of the valleys.",
      "paragraphStart": true
    },
    {
      "id": "lxxe:song-of-solomon.2.2",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "As a lily among thorns, so is my companion among the daughters.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.3",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "As the apple among the trees of the wood, so is my kinsman among the sons. I desired his shadow, and sat down, and his fruit was sweet in my throat.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.4",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "Bring me into the wine house; set love before me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.5",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Strengthen me with perfumes, stay me with apples: for I am wounded with love.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.6",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "His left hand shall be under my head, and his right hand shall embrace me.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.7",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "I have charged you, ye daughters of Jerusalem, by the powers and by the virtues of the field, that ye do not rouse or wake my love, until he please.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.8",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "The voice of my kinsman! behold, he comes leaping over the mountains, bounding over the hills.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.9",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "My kinsman is like a roe or a young hart on the mountains of Baethel: behold, he is behind our wall, looking through the windows, peeping through the lattices.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.10",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "My kinsman answers, and says to me, Rise up, come, my companion, my fair one, my dove.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.11",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "For, behold, the winter is past, the rain is gone, it has departed.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.12",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "The flowers are seen in the land; the time of pruning has arrived; the voice of the turtle-dove has been heard in our land.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.13",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "The fig-tree has put forth its young figs, the vines put forth the tender grape, they yield a smell: arise, come, my companion, my fair one, my dove; yea, come.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.14",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "Thou art my dove, in the shelter of the rock, near the wall: shew me thy face, and cause me to hear thy voice; for thy voice is sweet, and thy countenance is beautiful.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.15",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Take us the little foxes that spoil the vines: for our vines put forth tender grapes.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.16",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "My kinsman is mine, and I am his: he feeds his flock among the lilies.",
      "paragraphStart": false
    },
    {
      "id": "lxxe:song-of-solomon.2.17",
      "translationId": "lxxe",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "Until the day dawn, and the shadows depart, turn, my kinsman, be thou like to a roe or young hart on the mountains of the ravines.",
      "paragraphStart": false
    }
  ]
}
