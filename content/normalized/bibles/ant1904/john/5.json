{
  "chapter": {
    "id": "ant1904:john.5",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 5,
    "referenceLabel": "John 5",
    "summary": "Source text for John 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.5.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "John 5:1",
      "text": "μετα ταυτα ην η εορτη των ιουδαιων και ανεβη ο ιησους εις ιεροσολυμα",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.5.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "John 5:2",
      "text": "εστιν δε εν τοις ιεροσολυμοις επι τη προβατικη κολυμβηθρα η επιλεγομενη εβραιστι βηθεσδα πεντε στοας εχουσα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "John 5:3",
      "text": "εν ταυταις κατεκειτο πληθος πολυ των ασθενουντων τυφλων χωλων ξηρων εκδεχομενων την του υδατος κινησιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "John 5:4",
      "text": "αγγελος γαρ κατα καιρον κατεβαινεν εν τη κολυμβηθρα και εταρασσετο το υδωρ ο ουν πρωτος εμβας μετα την ταραχην του υδατος υγιης εγινετο ω δηποτε κατειχετο νοσηματι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "John 5:5",
      "text": "ην δε τις ανθρωπος εκει τριακοντα και οκτω ετη εχων εν τη ασθενεια αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "John 5:6",
      "text": "τουτον ιδων ο ιησους κατακειμενον και γνους οτι πολυν ηδη χρονον εχει λεγει αυτω θελεις υγιης γενεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "John 5:7",
      "text": "απεκριθη αυτω ο ασθενων κυριε ανθρωπον ουκ εχω ινα οταν ταραχθη το υδωρ βαλη με εις την κολυμβηθραν εν ω δε ερχομαι εγω αλλος προ εμου καταβαινει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "John 5:8",
      "text": "λεγει αυτω ο ιησους εγειρε αρον τον κραβαττον σου και περιπατει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "John 5:9",
      "text": "και ευθεως εγενετο υγιης ο ανθρωπος και ηρεν τον κραβαττον αυτου και περιεπατει ην δε σαββατον εν εκεινη τη ημερα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "John 5:10",
      "text": "ελεγον ουν οι ιουδαιοι τω τεθεραπευμενω σαββατον εστιν ουκ εξεστιν σοι αραι τον κραβαττον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "John 5:11",
      "text": "απεκριθη αυτοις ο ποιησας με υγιη εκεινος μοι ειπεν αρον τον κραβαττον σου και περιπατει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "John 5:12",
      "text": "ηρωτησαν ουν αυτον τις εστιν ο ανθρωπος ο ειπων σοι αρον τον κραβαττον σου και περιπατει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "John 5:13",
      "text": "ο δε ιαθεις ουκ ηδει τις εστιν ο γαρ ιησους εξενευσεν οχλου οντος εν τω τοπω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "John 5:14",
      "text": "μετα ταυτα ευρισκει αυτον ο ιησους εν τω ιερω και ειπεν αυτω ιδε υγιης γεγονας μηκετι αμαρτανε ινα μη χειρον σοι τι γενηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "John 5:15",
      "text": "απηλθεν ο ανθρωπος και ανηγγειλεν τοις ιουδαιοις οτι ιησους εστιν ο ποιησας αυτον υγιη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "John 5:16",
      "text": "και δια τουτο εδιωκον τον ιησουν οι ιουδαιοι και εζητουν αυτον αποκτειναι οτι ταυτα εποιει εν σαββατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "John 5:17",
      "text": "ο δε ιησους απεκρινατο αυτοις ο πατηρ μου εως αρτι εργαζεται καγω εργαζομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "John 5:18",
      "text": "δια τουτο ουν μαλλον εζητουν αυτον οι ιουδαιοι αποκτειναι οτι ου μονον ελυεν το σαββατον αλλα και πατερα ιδιον ελεγεν τον θεον ισον εαυτον ποιων τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "John 5:19",
      "text": "απεκρινατο ουν ο ιησους και ειπεν αυτοις αμην αμην λεγω υμιν ου δυναται ο υιος ποιειν αφ εαυτου ουδεν εαν μη τι βλεπη τον πατερα ποιουντα α γαρ αν εκεινος ποιη ταυτα και ο υιος ομοιως ποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "John 5:20",
      "text": "ο γαρ πατηρ φιλει τον υιον και παντα δεικνυσιν αυτω α αυτος ποιει και μειζονα τουτων δειξει αυτω εργα ινα υμεις θαυμαζητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "John 5:21",
      "text": "ωσπερ γαρ ο πατηρ εγειρει τους νεκρους και ζωοποιει ουτως και ο υιος ους θελει ζωοποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "John 5:22",
      "text": "ουδε γαρ ο πατηρ κρινει ουδενα αλλα την κρισιν πασαν δεδωκεν τω υιω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "John 5:23",
      "text": "ινα παντες τιμωσιν τον υιον καθως τιμωσιν τον πατερα ο μη τιμων τον υιον ου τιμα τον πατερα τον πεμψαντα αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "John 5:24",
      "text": "αμην αμην λεγω υμιν οτι ο τον λογον μου ακουων και πιστευων τω πεμψαντι με εχει ζωην αιωνιον και εις κρισιν ουκ ερχεται αλλα μεταβεβηκεν εκ του θανατου εις την ζωην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "John 5:25",
      "text": "αμην αμην λεγω υμιν οτι ερχεται ωρα και νυν εστιν οτε οι νεκροι ακουσονται της φωνης του υιου του θεου και οι ακουσαντες ζησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "John 5:26",
      "text": "ωσπερ γαρ ο πατηρ εχει ζωην εν εαυτω ουτως εδωκεν και τω υιω ζωην εχειν εν εαυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "John 5:27",
      "text": "και εξουσιαν εδωκεν αυτω και κρισιν ποιειν οτι υιος ανθρωπου εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "John 5:28",
      "text": "μη θαυμαζετε τουτο οτι ερχεται ωρα εν η παντες οι εν τοις μνημειοις ακουσονται της φωνης αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "John 5:29",
      "text": "και εκπορευσονται οι τα αγαθα ποιησαντες εις αναστασιν ζωης οι δε τα φαυλα πραξαντες εις αναστασιν κρισεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "John 5:30",
      "text": "ου δυναμαι εγω ποιειν απ εμαυτου ουδεν καθως ακουω κρινω και η κρισις η εμη δικαια εστιν οτι ου ζητω το θελημα το εμον αλλα το θελημα του πεμψαντος με πατρος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "John 5:31",
      "text": "εαν εγω μαρτυρω περι εμαυτου η μαρτυρια μου ουκ εστιν αληθης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "John 5:32",
      "text": "αλλος εστιν ο μαρτυρων περι εμου και οιδα οτι αληθης εστιν η μαρτυρια ην μαρτυρει περι εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "John 5:33",
      "text": "υμεις απεσταλκατε προς ιωαννην και μεμαρτυρηκεν τη αληθεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "John 5:34",
      "text": "εγω δε ου παρα ανθρωπου την μαρτυριαν λαμβανω αλλα ταυτα λεγω ινα υμεις σωθητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "John 5:35",
      "text": "εκεινος ην ο λυχνος ο καιομενος και φαινων υμεις δε ηθελησατε αγαλλιαθηναι προς ωραν εν τω φωτι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "John 5:36",
      "text": "εγω δε εχω την μαρτυριαν μειζω του ιωαννου τα γαρ εργα α εδωκεν μοι ο πατηρ ινα τελειωσω αυτα αυτα τα εργα α εγω ποιω μαρτυρει περι εμου οτι ο πατηρ με απεσταλκεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.37",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "John 5:37",
      "text": "και ο πεμψας με πατηρ αυτος μεμαρτυρηκεν περι εμου ουτε φωνην αυτου ακηκοατε πωποτε ουτε ειδος αυτου εωρακατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.38",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 38,
      "referenceLabel": "John 5:38",
      "text": "και τον λογον αυτου ουκ εχετε μενοντα εν υμιν οτι ον απεστειλεν εκεινος τουτω υμεις ου πιστευετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.39",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 39,
      "referenceLabel": "John 5:39",
      "text": "ερευνατε τας γραφας οτι υμεις δοκειτε εν αυταις ζωην αιωνιον εχειν και εκειναι εισιν αι μαρτυρουσαι περι εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.40",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 40,
      "referenceLabel": "John 5:40",
      "text": "και ου θελετε ελθειν προς με ινα ζωην εχητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.41",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 41,
      "referenceLabel": "John 5:41",
      "text": "δοξαν παρα ανθρωπων ου λαμβανω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.42",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 42,
      "referenceLabel": "John 5:42",
      "text": "αλλ εγνωκα υμας οτι την αγαπην του θεου ουκ εχετε εν εαυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.43",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 43,
      "referenceLabel": "John 5:43",
      "text": "εγω εληλυθα εν τω ονοματι του πατρος μου και ου λαμβανετε με εαν αλλος ελθη εν τω ονοματι τω ιδιω εκεινον ληψεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.44",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 44,
      "referenceLabel": "John 5:44",
      "text": "πως δυνασθε υμεις πιστευσαι δοξαν παρα αλληλων λαμβανοντες και την δοξαν την παρα του μονου θεου ου ζητειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.45",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 45,
      "referenceLabel": "John 5:45",
      "text": "μη δοκειτε οτι εγω κατηγορησω υμων προς τον πατερα εστιν ο κατηγορων υμων μωυσης εις ον υμεις ηλπικατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.46",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 46,
      "referenceLabel": "John 5:46",
      "text": "ει γαρ επιστευετε μωυσει επιστευετε αν εμοι περι γαρ εμου εκεινος εγραψεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.5.47",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 5,
      "verseNumber": 47,
      "referenceLabel": "John 5:47",
      "text": "ει δε τοις εκεινου γραμμασιν ου πιστευετε πως τοις εμοις ρημασιν πιστευσετε",
      "paragraphStart": false
    }
  ]
}
