{
  "chapter": {
    "id": "ant1904:john.8",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 8,
    "referenceLabel": "John 8",
    "summary": "Source text for John 8 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.8.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "John 8:1",
      "text": "ιησους δε επορευθη εις το ορος των ελαιων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.8.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "John 8:2",
      "text": "ορθρου δε παλιν παρεγενετο εις το ιερον και πας ο λαος ηρχετο προς αυτον και καθισας εδιδασκεν αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "John 8:3",
      "text": "αγουσιν δε οι γραμματεις και οι φαρισαιοι γυναικα επι μοιχεια κατειλημμενην και στησαντες αυτην εν μεσω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "John 8:4",
      "text": "λεγουσιν αυτω διδασκαλε αυτη η γυνη κατειληπται επ αυτοφωρω μοιχευομενη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "John 8:5",
      "text": "και εν τω νομω ημων μωυσης ενετειλατο τας τοιαυτας λιθαζειν συ ουν τι λεγεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "John 8:6",
      "text": "τουτο δε ειπον εκπειραζοντες αυτον ινα σχωσιν κατηγοριαν κατ αυτου ο δε ιησους κατω κυψας τω δακτυλω εγραφεν εις την γην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "John 8:7",
      "text": "ως δε επεμενον ερωτωντες αυτον ανεκυψεν και ειπεν αυτοις ο αναμαρτητος υμων πρωτος βαλετω λιθον επ αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "John 8:8",
      "text": "και παλιν κατω κυψας εγραφεν εις την γην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "John 8:9",
      "text": "οι δε ακουσαντες εξηρχοντο εις καθ εις αρξαμενοι απο των πρεσβυτερων και κατελειφθη ο ιησους και η γυνη εν μεσω ουσα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "John 8:10",
      "text": "ανακυψας δε ο ιησους ειπεν αυτη γυναι που εισιν ουδεις σε κατεκρινεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "John 8:11",
      "text": "η δε ειπεν ουδεις κυριε ειπεν δε ο ιησους ουδε εγω σε κατακρινω πορευου και απο του νυν μηκετι αμαρτανε>>",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "John 8:12",
      "text": "παλιν ουν αυτοις ο ιησους ελαλησεν λεγων εγω ειμι το φως του κοσμου ο ακολουθων εμοι ου μη περιπατηση εν τη σκοτια αλλ εξει το φως της ζωης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "John 8:13",
      "text": "ειπον ουν αυτω οι φαρισαιοι συ περι σεαυτου μαρτυρεις η μαρτυρια σου ουκ εστιν αληθης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "John 8:14",
      "text": "απεκριθη ιησους και ειπεν αυτοις καν εγω μαρτυρω περι εμαυτου αληθης εστιν η μαρτυρια μου οτι οιδα ποθεν ηλθον και που υπαγω υμεις [δε] ουκ οιδατε ποθεν ερχομαι η που υπαγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "John 8:15",
      "text": "υμεις κατα την σαρκα κρινετε εγω ου κρινω ουδενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "John 8:16",
      "text": "και εαν κρινω δε εγω η κρισις η εμη αληθης εστιν οτι μονος ουκ ειμι αλλ εγω και ο πεμψας με πατηρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "John 8:17",
      "text": "και εν τω νομω δε τω υμετερω γεγραπται οτι δυο ανθρωπων η μαρτυρια αληθης εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "John 8:18",
      "text": "εγω ειμι ο μαρτυρων περι εμαυτου και μαρτυρει περι εμου ο πεμψας με πατηρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "John 8:19",
      "text": "ελεγον ουν αυτω που εστιν ο πατηρ σου απεκριθη ιησους ουτε εμε οιδατε ουτε τον πατερα μου ει εμε ηδειτε και τον πατερα μου ηδειτε αν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "John 8:20",
      "text": "ταυτα τα ρηματα ελαλησεν ο ιησους εν τω γαζοφυλακιω διδασκων εν τω ιερω και ουδεις επιασεν αυτον οτι ουπω εληλυθει η ωρα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "John 8:21",
      "text": "ειπεν ουν παλιν αυτοις ο ιησους εγω υπαγω και ζητησετε με και εν τη αμαρτια υμων αποθανεισθε οπου εγω υπαγω υμεις ου δυνασθε ελθειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "John 8:22",
      "text": "ελεγον ουν οι ιουδαιοι μητι αποκτενει εαυτον οτι λεγει οπου εγω υπαγω υμεις ου δυνασθε ελθειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "John 8:23",
      "text": "και ειπεν αυτοις υμεις εκ των κατω εστε εγω εκ των ανω ειμι υμεις εκ του κοσμου τουτου εστε εγω ουκ ειμι εκ του κοσμου τουτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "John 8:24",
      "text": "ειπον ουν υμιν οτι αποθανεισθε εν ταις αμαρτιαις υμων εαν γαρ μη πιστευσητε οτι εγω ειμι αποθανεισθε εν ταις αμαρτιαις υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "John 8:25",
      "text": "ελεγον ουν αυτω συ τις ει και ειπεν αυτοις ο ιησους την αρχην ο τι και λαλω υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "John 8:26",
      "text": "πολλα εχω περι υμων λαλειν και κρινειν αλλ ο πεμψας με αληθης εστιν καγω α ηκουσα παρ αυτου ταυτα λεγω εις τον κοσμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "John 8:27",
      "text": "ουκ εγνωσαν οτι τον πατερα αυτοις ελεγεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "John 8:28",
      "text": "ειπεν ουν αυτοις ο ιησους οταν υψωσητε τον υιον του ανθρωπου τοτε γνωσεσθε οτι εγω ειμι και απ εμαυτου ποιω ουδεν αλλα καθως εδιδαξεν με ο πατηρ μου ταυτα λαλω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "John 8:29",
      "text": "και ο πεμψας με μετ εμου εστιν ουκ αφηκεν με μονον ο πατηρ οτι εγω τα αρεστα αυτω ποιω παντοτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "John 8:30",
      "text": "ταυτα αυτου λαλουντος πολλοι επιστευσαν εις αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "John 8:31",
      "text": "ελεγεν ουν ο ιησους προς τους πεπιστευκοτας αυτω ιουδαιους εαν υμεις μεινητε εν τω λογω τω εμω αληθως μαθηται μου εστε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "John 8:32",
      "text": "και γνωσεσθε την αληθειαν και η αληθεια ελευθερωσει υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "John 8:33",
      "text": "απεκριθησαν αυτω σπερμα αβρααμ εσμεν και ουδενι δεδουλευκαμεν πωποτε πως συ λεγεις οτι ελευθεροι γενησεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "John 8:34",
      "text": "απεκριθη αυτοις ο ιησους αμην αμην λεγω υμιν οτι πας ο ποιων την αμαρτιαν δουλος εστιν της αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "John 8:35",
      "text": "ο δε δουλος ου μενει εν τη οικια εις τον αιωνα ο υιος μενει εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "John 8:36",
      "text": "εαν ουν ο υιος υμας ελευθερωση οντως ελευθεροι εσεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.37",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "John 8:37",
      "text": "οιδα οτι σπερμα αβρααμ εστε αλλα ζητειτε με αποκτειναι οτι ο λογος ο εμος ου χωρει εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.38",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "John 8:38",
      "text": "εγω ο εωρακα παρα τω πατρι μου λαλω και υμεις ουν ο εωρακατε παρα τω πατρι υμων ποιειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.39",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "John 8:39",
      "text": "απεκριθησαν και ειπον αυτω ο πατηρ ημων αβρααμ εστιν λεγει αυτοις ο ιησους ει τεκνα του αβρααμ ητε τα εργα του αβρααμ εποιειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.40",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 40,
      "referenceLabel": "John 8:40",
      "text": "νυν δε ζητειτε με αποκτειναι ανθρωπον ος την αληθειαν υμιν λελαληκα ην ηκουσα παρα του θεου τουτο αβρααμ ουκ εποιησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.41",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 41,
      "referenceLabel": "John 8:41",
      "text": "υμεις ποιειτε τα εργα του πατρος υμων ειπον ουν αυτω ημεις εκ πορνειας ου γεγεννημεθα ενα πατερα εχομεν τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.42",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 42,
      "referenceLabel": "John 8:42",
      "text": "ειπεν ουν αυτοις ο ιησους ει ο θεος πατηρ υμων ην ηγαπατε αν εμε εγω γαρ εκ του θεου εξηλθον και ηκω ουδε γαρ απ εμαυτου εληλυθα αλλ εκεινος με απεστειλεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.43",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 43,
      "referenceLabel": "John 8:43",
      "text": "διατι την λαλιαν την εμην ου γινωσκετε οτι ου δυνασθε ακουειν τον λογον τον εμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.44",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 44,
      "referenceLabel": "John 8:44",
      "text": "υμεις εκ του πατρος του διαβολου εστε και τας επιθυμιας του πατρος υμων θελετε ποιειν εκεινος ανθρωποκτονος ην απ αρχης και εν τη αληθεια ουχ εστηκεν οτι ουκ εστιν αληθεια εν αυτω οταν λαλη το ψευδος εκ των ιδιων λαλει οτι ψευστης εστιν και ο πατηρ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.45",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 45,
      "referenceLabel": "John 8:45",
      "text": "εγω δε οτι την αληθειαν λεγω ου πιστευετε μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.46",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 46,
      "referenceLabel": "John 8:46",
      "text": "τις εξ υμων ελεγχει με περι αμαρτιας ει δε αληθειαν λεγω διατι υμεις ου πιστευετε μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.47",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 47,
      "referenceLabel": "John 8:47",
      "text": "ο ων εκ του θεου τα ρηματα του θεου ακουει δια τουτο υμεις ουκ ακουετε οτι εκ του θεου ουκ εστε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.48",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 48,
      "referenceLabel": "John 8:48",
      "text": "απεκριθησαν ουν οι ιουδαιοι και ειπον αυτω ου καλως λεγομεν ημεις οτι σαμαρειτης ει συ και δαιμονιον εχεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.49",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 49,
      "referenceLabel": "John 8:49",
      "text": "απεκριθη ιησους εγω δαιμονιον ουκ εχω αλλα τιμω τον πατερα μου και υμεις ατιμαζετε με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.50",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 50,
      "referenceLabel": "John 8:50",
      "text": "εγω δε ου ζητω την δοξαν μου εστιν ο ζητων και κρινων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.51",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 51,
      "referenceLabel": "John 8:51",
      "text": "αμην αμην λεγω υμιν εαν τις τον λογον τον εμον τηρηση θανατον ου μη θεωρηση εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.52",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 52,
      "referenceLabel": "John 8:52",
      "text": "ειπον ουν αυτω οι ιουδαιοι νυν εγνωκαμεν οτι δαιμονιον εχεις αβρααμ απεθανεν και οι προφηται και συ λεγεις εαν τις τον λογον μου τηρηση ου μη γευσηται θανατου εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.8.53",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 8,
      "verseNumber": 53,
      "referenceLabel": "John 8:53",
