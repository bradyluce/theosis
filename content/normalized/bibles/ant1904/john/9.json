{
  "chapter": {
    "id": "ant1904:john.9",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 9,
    "referenceLabel": "John 9",
    "summary": "Source text for John 9 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.9.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "John 9:1",
      "text": "και παραγων ειδεν ανθρωπον τυφλον εκ γενετης",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.9.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "John 9:2",
      "text": "και ηρωτησαν αυτον οι μαθηται αυτου λεγοντες ραββι τις ημαρτεν ουτος η οι γονεις αυτου ινα τυφλος γεννηθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "John 9:3",
      "text": "απεκριθη ιησους ουτε ουτος ημαρτεν ουτε οι γονεις αυτου αλλ ινα φανερωθη τα εργα του θεου εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "John 9:4",
      "text": "εμε δει εργαζεσθαι τα εργα του πεμψαντος με εως ημερα εστιν ερχεται νυξ οτε ουδεις δυναται εργαζεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "John 9:5",
      "text": "οταν εν τω κοσμω ω φως ειμι του κοσμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "John 9:6",
      "text": "ταυτα ειπων επτυσεν χαμαι και εποιησεν πηλον εκ του πτυσματος και επεχρισεν τον πηλον επι τους οφθαλμους του τυφλου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "John 9:7",
      "text": "και ειπεν αυτω υπαγε νιψαι εις την κολυμβηθραν του σιλωαμ ο ερμηνευεται απεσταλμενος απηλθεν ουν και ενιψατο και ηλθεν βλεπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "John 9:8",
      "text": "οι ουν γειτονες και οι θεωρουντες αυτον το προτερον οτι τυφλος ην ελεγον ουχ ουτος εστιν ο καθημενος και προσαιτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "John 9:9",
      "text": "αλλοι ελεγον οτι ουτος εστιν αλλοι δε οτι ομοιος αυτω εστιν εκεινος ελεγεν οτι εγω ειμι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "John 9:10",
      "text": "ελεγον ουν αυτω πως ανεωχθησαν σου οι οφθαλμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "John 9:11",
      "text": "απεκριθη εκεινος και ειπεν ανθρωπος λεγομενος ιησους πηλον εποιησεν και επεχρισεν μου τους οφθαλμους και ειπεν μοι υπαγε εις την κολυμβηθραν του σιλωαμ και νιψαι απελθων δε και νιψαμενος ανεβλεψα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "John 9:12",
      "text": "ειπον ουν αυτω που εστιν εκεινος λεγει ουκ οιδα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "John 9:13",
      "text": "αγουσιν αυτον προς τους φαρισαιους τον ποτε τυφλον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "John 9:14",
      "text": "ην δε σαββατον οτε τον πηλον εποιησεν ο ιησους και ανεωξεν αυτου τους οφθαλμους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "John 9:15",
      "text": "παλιν ουν ηρωτων αυτον και οι φαρισαιοι πως ανεβλεψεν ο δε ειπεν αυτοις πηλον επεθηκεν μου επι τους οφθαλμους και ενιψαμην και βλεπω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "John 9:16",
      "text": "ελεγον ουν εκ των φαρισαιων τινες ουτος ο ανθρωπος ουκ εστιν παρα του θεου οτι το σαββατον ου τηρει αλλοι ελεγον πως δυναται ανθρωπος αμαρτωλος τοιαυτα σημεια ποιειν και σχισμα ην εν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "John 9:17",
      "text": "λεγουσιν τω τυφλω παλιν συ τι λεγεις περι αυτου οτι ηνοιξεν σου τους οφθαλμους ο δε ειπεν οτι προφητης εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "John 9:18",
      "text": "ουκ επιστευσαν ουν οι ιουδαιοι περι αυτου οτι τυφλος ην και ανεβλεψεν εως οτου εφωνησαν τους γονεις αυτου του αναβλεψαντος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "John 9:19",
      "text": "και ηρωτησαν αυτους λεγοντες ουτος εστιν ο υιος υμων ον υμεις λεγετε οτι τυφλος εγεννηθη πως ουν αρτι βλεπει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "John 9:20",
      "text": "απεκριθησαν δε αυτοις οι γονεις αυτου και ειπον οιδαμεν οτι ουτος εστιν ο υιος ημων και οτι τυφλος εγεννηθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "John 9:21",
      "text": "πως δε νυν βλεπει ουκ οιδαμεν η τις ηνοιξεν αυτου τους οφθαλμους ημεις ουκ οιδαμεν αυτος ηλικιαν εχει αυτον ερωτησατε αυτος περι εαυτου λαλησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "John 9:22",
      "text": "ταυτα ειπον οι γονεις αυτου οτι εφοβουντο τους ιουδαιους ηδη γαρ συνετεθειντο οι ιουδαιοι ινα εαν τις αυτον ομολογηση χριστον αποσυναγωγος γενηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "John 9:23",
      "text": "δια τουτο οι γονεις αυτου ειπον οτι ηλικιαν εχει αυτον ερωτησατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "John 9:24",
      "text": "εφωνησαν ουν εκ δευτερου τον ανθρωπον ος ην τυφλος και ειπον αυτω δος δοξαν τω θεω ημεις οιδαμεν οτι ο ανθρωπος ουτος αμαρτωλος εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "John 9:25",
      "text": "απεκριθη ουν εκεινος και ειπεν ει αμαρτωλος εστιν ουκ οιδα εν οιδα οτι τυφλος ων αρτι βλεπω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "John 9:26",
      "text": "ειπον δε αυτω παλιν τι εποιησεν σοι πως ηνοιξεν σου τους οφθαλμους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "John 9:27",
      "text": "απεκριθη αυτοις ειπον υμιν ηδη και ουκ ηκουσατε τι παλιν θελετε ακουειν μη και υμεις θελετε αυτου μαθηται γενεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "John 9:28",
      "text": "ελοιδορησαν αυτον και ειπον συ ει μαθητης εκεινου ημεις δε του μωυσεως εσμεν μαθηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "John 9:29",
      "text": "ημεις οιδαμεν οτι μωυσει λελαληκεν ο θεος τουτον δε ουκ οιδαμεν ποθεν εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "John 9:30",
      "text": "απεκριθη ο ανθρωπος και ειπεν αυτοις εν γαρ τουτω θαυμαστον εστιν οτι υμεις ουκ οιδατε ποθεν εστιν και ανεωξεν μου τους οφθαλμους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "John 9:31",
      "text": "οιδαμεν δε οτι αμαρτωλων ο θεος ουκ ακουει αλλ εαν τις θεοσεβης η και το θελημα αυτου ποιη τουτου ακουει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "John 9:32",
      "text": "εκ του αιωνος ουκ ηκουσθη οτι ηνοιξεν τις οφθαλμους τυφλου γεγεννημενου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "John 9:33",
      "text": "ει μη ην ουτος παρα θεου ουκ ηδυνατο ποιειν ουδεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "John 9:34",
      "text": "απεκριθησαν και ειπον αυτω εν αμαρτιαις συ εγεννηθης ολος και συ διδασκεις ημας και εξεβαλον αυτον εξω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "John 9:35",
      "text": "ηκουσεν ο ιησους οτι εξεβαλον αυτον εξω και ευρων αυτον ειπεν αυτω συ πιστευεις εις τον υιον του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "John 9:36",
      "text": "απεκριθη εκεινος και ειπεν και τις εστιν κυριε ινα πιστευσω εις αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.37",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 37,
      "referenceLabel": "John 9:37",
      "text": "ειπεν δε αυτω ο ιησους και εωρακας αυτον και ο λαλων μετα σου εκεινος εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.38",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 38,
      "referenceLabel": "John 9:38",
      "text": "ο δε εφη πιστευω κυριε και προσεκυνησεν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.39",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 39,
      "referenceLabel": "John 9:39",
      "text": "και ειπεν ο ιησους εις κριμα εγω εις τον κοσμον τουτον ηλθον ινα οι μη βλεποντες βλεπωσιν και οι βλεποντες τυφλοι γενωνται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.40",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 40,
      "referenceLabel": "John 9:40",
      "text": "και ηκουσαν εκ των φαρισαιων ταυτα οι οντες μετ αυτου και ειπον αυτω μη και ημεις τυφλοι εσμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.9.41",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 9,
      "verseNumber": 41,
      "referenceLabel": "John 9:41",
      "text": "ειπεν αυτοις ο ιησους ει τυφλοι ητε ουκ αν ειχετε αμαρτιαν νυν δε λεγετε οτι βλεπομεν η ουν αμαρτια υμων μενει",
      "paragraphStart": false
    }
  ]
}
