{
  "chapter": {
    "id": "ant1904:john.1",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 1,
    "referenceLabel": "John 1",
    "summary": "Source text for John 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.1.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "John 1:1",
      "text": "εν αρχη ην ο λογος και ο λογος ην προς τον θεον και θεος ην ο λογος",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.1.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "John 1:2",
      "text": "ουτος ην εν αρχη προς τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "John 1:3",
      "text": "παντα δι αυτου εγενετο και χωρις αυτου εγενετο ουδε εν ο γεγονεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "John 1:4",
      "text": "εν αυτω ζωη ην και η ζωη ην το φως των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "John 1:5",
      "text": "και το φως εν τη σκοτια φαινει και η σκοτια αυτο ου κατελαβεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "John 1:6",
      "text": "εγενετο ανθρωπος απεσταλμενος παρα θεου ονομα αυτω ιωαννης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "John 1:7",
      "text": "ουτος ηλθεν εις μαρτυριαν ινα μαρτυρηση περι του φωτος ινα παντες πιστευσωσιν δι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "John 1:8",
      "text": "ουκ ην εκεινος το φως αλλ ινα μαρτυρηση περι του φωτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "John 1:9",
      "text": "ην το φως το αληθινον ο φωτιζει παντα ανθρωπον ερχομενον εις τον κοσμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "John 1:10",
      "text": "εν τω κοσμω ην και ο κοσμος δι αυτου εγενετο και ο κοσμος αυτον ουκ εγνω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "John 1:11",
      "text": "εις τα ιδια ηλθεν και οι ιδιοι αυτον ου παρελαβον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "John 1:12",
      "text": "οσοι δε ελαβον αυτον εδωκεν αυτοις εξουσιαν τεκνα θεου γενεσθαι τοις πιστευουσιν εις το ονομα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "John 1:13",
      "text": "οι ουκ εξ αιματων ουδε εκ θεληματος σαρκος ουδε εκ θεληματος ανδρος αλλ εκ θεου εγεννηθησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "John 1:14",
      "text": "και ο λογος σαρξ εγενετο και εσκηνωσεν εν ημιν και εθεασαμεθα την δοξαν αυτου δοξαν ως μονογενους παρα πατρος πληρης χαριτος και αληθειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "John 1:15",
      "text": "ιωαννης μαρτυρει περι αυτου και κεκραγεν λεγων ουτος ην ον ειπον ο οπισω μου ερχομενος εμπροσθεν μου γεγονεν οτι πρωτος μου ην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "John 1:16",
      "text": "και εκ του πληρωματος αυτου ημεις παντες ελαβομεν και χαριν αντι χαριτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "John 1:17",
      "text": "οτι ο νομος δια μωυσεως εδοθη η χαρις και η αληθεια δια ιησου χριστου εγενετο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "John 1:18",
      "text": "θεον ουδεις εωρακεν πωποτε ο μονογενης υιος ο ων εις τον κολπον του πατρος εκεινος εξηγησατο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "John 1:19",
      "text": "και αυτη εστιν η μαρτυρια του ιωαννου οτε απεστειλαν οι ιουδαιοι εξ ιεροσολυμων ιερεις και λευιτας ινα ερωτησωσιν αυτον συ τις ει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "John 1:20",
      "text": "και ωμολογησεν και ουκ ηρνησατο και ωμολογησεν οτι ουκ ειμι εγω ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "John 1:21",
      "text": "και ηρωτησαν αυτον τι ουν ηλιας ει συ και λεγει ουκ ειμι ο προφητης ει συ και απεκριθη ου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "John 1:22",
      "text": "ειπον ουν αυτω τις ει ινα αποκρισιν δωμεν τοις πεμψασιν ημας τι λεγεις περι σεαυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "John 1:23",
      "text": "εφη εγω φωνη βοωντος εν τη ερημω ευθυνατε την οδον κυριου καθως ειπεν ησαιας ο προφητης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "John 1:24",
      "text": "και οι απεσταλμενοι ησαν εκ των φαρισαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "John 1:25",
      "text": "και ηρωτησαν αυτον και ειπον αυτω τι ουν βαπτιζεις ει συ ουκ ει ο χριστος ουτε ηλιας ουτε ο προφητης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "John 1:26",
      "text": "απεκριθη αυτοις ο ιωαννης λεγων εγω βαπτιζω εν υδατι μεσος δε υμων εστηκεν ον υμεις ουκ οιδατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "John 1:27",
      "text": "αυτος εστιν ο οπισω μου ερχομενος ος εμπροσθεν μου γεγονεν ου εγω ουκ ειμι αξιος ινα λυσω αυτου τον ιμαντα του υποδηματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "John 1:28",
      "text": "ταυτα εν βηθανια εγενετο περαν του ιορδανου οπου ην ιωαννης βαπτιζων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "John 1:29",
      "text": "τη επαυριον βλεπει [ο ιωαννης] τον ιησουν ερχομενον προς αυτον και λεγει ιδε ο αμνος του θεου ο αιρων την αμαρτιαν του κοσμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "John 1:30",
      "text": "ουτος εστιν περι ου εγω ειπον οπισω μου ερχεται ανηρ ος εμπροσθεν μου γεγονεν οτι πρωτος μου ην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "John 1:31",
      "text": "καγω ουκ ηδειν αυτον αλλ ινα φανερωθη τω ισραηλ δια τουτο ηλθον εγω εν τω υδατι βαπτιζων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "John 1:32",
      "text": "και εμαρτυρησεν ιωαννης λεγων οτι τεθεαμαι το πνευμα καταβαινον ως περιστεραν εξ ουρανου και εμεινεν επ αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "John 1:33",
      "text": "καγω ουκ ηδειν αυτον αλλ ο πεμψας με βαπτιζειν εν υδατι εκεινος μοι ειπεν εφ ον αν ιδης το πνευμα καταβαινον και μενον επ αυτον ουτος εστιν ο βαπτιζων εν πνευματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "John 1:34",
      "text": "καγω εωρακα και μεμαρτυρηκα οτι ουτος εστιν ο υιος του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "John 1:35",
      "text": "τη επαυριον παλιν ειστηκει ο ιωαννης και εκ των μαθητων αυτου δυο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "John 1:36",
      "text": "και εμβλεψας τω ιησου περιπατουντι λεγει ιδε ο αμνος του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.37",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "John 1:37",
      "text": "και ηκουσαν αυτου οι δυο μαθηται λαλουντος και ηκολουθησαν τω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.38",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "John 1:38",
      "text": "στραφεις δε ο ιησους και θεασαμενος αυτους ακολουθουντας λεγει αυτοις τι ζητειτε οι δε ειπον αυτω ραββι ο λεγεται ερμηνευομενον διδασκαλε που μενεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.39",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "John 1:39",
      "text": "λεγει αυτοις ερχεσθε και ιδετε ηλθον [ουν] και ειδον που μενει και παρ αυτω εμειναν την ημεραν εκεινην ωρα ην ως δεκατη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.40",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "John 1:40",
      "text": "ην ανδρεας ο αδελφος σιμωνος πετρου εις εκ των δυο των ακουσαντων παρα ιωαννου και ακολουθησαντων αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.41",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "John 1:41",
      "text": "ευρισκει ουτος πρωτος τον αδελφον τον ιδιον σιμωνα και λεγει αυτω ευρηκαμεν τον μεσσιαν ο εστιν μεθερμηνευομενον χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.42",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "John 1:42",
      "text": "και ηγαγεν αυτον προς τον ιησουν εμβλεψας αυτω ο ιησους ειπεν συ ει σιμων ο υιος ιωνα συ κληθηση κηφας ο ερμηνευεται πετρος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.43",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "John 1:43",
      "text": "τη επαυριον ηθελησεν ο ιησους εξελθειν εις την γαλιλαιαν και ευρισκει φιλιππον και λεγει αυτω ακολουθει μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.44",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "John 1:44",
      "text": "ην δε ο φιλιππος απο βηθσαιδα εκ της πολεως ανδρεου και πετρου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.45",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "John 1:45",
      "text": "ευρισκει φιλιππος τον ναθαναηλ και λεγει αυτω ον εγραψεν μωυσης εν τω νομω και οι προφηται ευρηκαμεν ιησουν τον υιον του ιωσηφ τον απο ναζαρετ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.46",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "John 1:46",
      "text": "και ειπεν αυτω ναθαναηλ εκ ναζαρετ δυναται τι αγαθον ειναι λεγει αυτω φιλιππος ερχου και ιδε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.47",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "John 1:47",
      "text": "ειδεν ο ιησους τον ναθαναηλ ερχομενον προς αυτον και λεγει περι αυτου ιδε αληθως ισραηλιτης εν ω δολος ουκ εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.48",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "John 1:48",
      "text": "λεγει αυτω ναθαναηλ ποθεν με γινωσκεις απεκριθη ιησους και ειπεν αυτω προ του σε φιλιππον φωνησαι οντα υπο την συκην ειδον σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.49",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "John 1:49",
      "text": "απεκριθη ναθαναηλ και λεγει αυτω ραββι συ ει ο υιος του θεου συ ει ο βασιλευς του ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.50",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "John 1:50",
      "text": "απεκριθη ιησους και ειπεν αυτω οτι ειπον σοι ειδον σε υποκατω της συκης πιστευεις μειζω τουτων οψει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.1.51",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "John 1:51",
      "text": "και λεγει αυτω αμην αμην λεγω υμιν απ αρτι οψεσθε τον ουρανον ανεωγοτα και τους αγγελους του θεου αναβαινοντας και καταβαινοντας επι τον υιον του ανθρωπου",
      "paragraphStart": false
    }
  ]
}
