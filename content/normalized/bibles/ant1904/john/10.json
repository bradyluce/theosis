{
  "chapter": {
    "id": "ant1904:john.10",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 10,
    "referenceLabel": "John 10",
    "summary": "Source text for John 10 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.10.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "John 10:1",
      "text": "αμην αμην λεγω υμιν ο μη εισερχομενος δια της θυρας εις την αυλην των προβατων αλλα αναβαινων αλλαχοθεν εκεινος κλεπτης εστιν και ληστης",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.10.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "John 10:2",
      "text": "ο δε εισερχομενος δια της θυρας ποιμην εστιν των προβατων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "John 10:3",
      "text": "τουτω ο θυρωρος ανοιγει και τα προβατα της φωνης αυτου ακουει και τα ιδια προβατα καλει κατ ονομα και εξαγει αυτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "John 10:4",
      "text": "και οταν τα ιδια προβατα εκβαλη εμπροσθεν αυτων πορευεται και τα προβατα αυτω ακολουθει οτι οιδασιν την φωνην αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "John 10:5",
      "text": "αλλοτριω δε ου μη ακολουθησωσιν αλλα φευξονται απ αυτου οτι ουκ οιδασιν των αλλοτριων την φωνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "John 10:6",
      "text": "ταυτην την παροιμιαν ειπεν αυτοις ο ιησους εκεινοι δε ουκ εγνωσαν τινα ην α ελαλει αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "John 10:7",
      "text": "ειπεν ουν παλιν αυτοις ο ιησους αμην αμην λεγω υμιν οτι εγω ειμι η θυρα των προβατων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "John 10:8",
      "text": "παντες οσοι ηλθον προ εμου κλεπται εισιν και λησται αλλ ουκ ηκουσαν αυτων τα προβατα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "John 10:9",
      "text": "εγω ειμι η θυρα δι εμου εαν τις εισελθη σωθησεται και εισελευσεται και εξελευσεται και νομην ευρησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "John 10:10",
      "text": "ο κλεπτης ουκ ερχεται ει μη ινα κλεψη και θυση και απολεση εγω ηλθον ινα ζωην εχωσιν και περισσον εχωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "John 10:11",
      "text": "εγω ειμι ο ποιμην ο καλος ο ποιμην ο καλος την ψυχην αυτου τιθησιν υπερ των προβατων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "John 10:12",
      "text": "ο μισθωτος δε και ουκ ων ποιμην ου ουκ εισιν τα προβατα ιδια θεωρει τον λυκον ερχομενον και αφιησιν τα προβατα και φευγει και ο λυκος αρπαζει αυτα και σκορπιζει τα προβατα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "John 10:13",
      "text": "ο δε μισθωτος φευγει οτι μισθωτος εστιν και ου μελει αυτω περι των προβατων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "John 10:14",
      "text": "εγω ειμι ο ποιμην ο καλος και γινωσκω τα εμα και γινωσκομαι υπο των εμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "John 10:15",
      "text": "καθως γινωσκει με ο πατηρ καγω γινωσκω τον πατερα και την ψυχην μου τιθημι υπερ των προβατων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "John 10:16",
      "text": "και αλλα προβατα εχω α ουκ εστιν εκ της αυλης ταυτης κακεινα με δει αγαγειν και της φωνης μου ακουσουσιν και γενησεται μια ποιμνη εις ποιμην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "John 10:17",
      "text": "δια τουτο ο πατηρ με αγαπα οτι εγω τιθημι την ψυχην μου ινα παλιν λαβω αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "John 10:18",
      "text": "ουδεις αιρει αυτην απ εμου αλλ εγω τιθημι αυτην απ εμαυτου εξουσιαν εχω θειναι αυτην και εξουσιαν εχω παλιν λαβειν αυτην ταυτην την εντολην ελαβον παρα του πατρος μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "John 10:19",
      "text": "σχισμα ουν παλιν εγενετο εν τοις ιουδαιοις δια τους λογους τουτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "John 10:20",
      "text": "ελεγον δε πολλοι εξ αυτων δαιμονιον εχει και μαινεται τι αυτου ακουετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "John 10:21",
      "text": "αλλοι ελεγον ταυτα τα ρηματα ουκ εστιν δαιμονιζομενου μη δαιμονιον δυναται τυφλων οφθαλμους ανοιγειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "John 10:22",
      "text": "εγενετο δε τα εγκαινια εν τοις ιεροσολυμοις και χειμων ην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "John 10:23",
      "text": "και περιεπατει ο ιησους εν τω ιερω εν τη στοα του σολομωνος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "John 10:24",
      "text": "εκυκλωσαν ουν αυτον οι ιουδαιοι και ελεγον αυτω εως ποτε την ψυχην ημων αιρεις ει συ ει ο χριστος ειπε ημιν παρρησια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "John 10:25",
      "text": "απεκριθη αυτοις ο ιησους ειπον υμιν και ου πιστευετε τα εργα α εγω ποιω εν τω ονοματι του πατρος μου ταυτα μαρτυρει περι εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "John 10:26",
      "text": "αλλ υμεις ου πιστευετε ου γαρ εστε εκ των προβατων των εμων καθως ειπον υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "John 10:27",
      "text": "τα προβατα τα εμα της φωνης μου ακουει καγω γινωσκω αυτα και ακολουθουσιν μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "John 10:28",
      "text": "καγω ζωην αιωνιον διδωμι αυτοις και ου μη απολωνται εις τον αιωνα και ουχ αρπασει τις αυτα εκ της χειρος μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "John 10:29",
      "text": "ο πατηρ μου ος δεδωκεν μοι μειζων παντων εστιν και ουδεις δυναται αρπαζειν εκ της χειρος του πατρος μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "John 10:30",
      "text": "εγω και ο πατηρ εν εσμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "John 10:31",
      "text": "εβαστασαν ουν παλιν λιθους οι ιουδαιοι ινα λιθασωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "John 10:32",
      "text": "απεκριθη αυτοις ο ιησους πολλα καλα εργα εδειξα υμιν εκ του πατρος μου δια ποιον αυτων εργον λιθαζετε με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "John 10:33",
      "text": "απεκριθησαν αυτω οι ιουδαιοι λεγοντες περι καλου εργου ου λιθαζομεν σε αλλα περι βλασφημιας και οτι συ ανθρωπος ων ποιεις σεαυτον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "John 10:34",
      "text": "απεκριθη αυτοις ο ιησους ουκ εστιν γεγραμμενον εν τω νομω υμων εγω ειπα θεοι εστε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "John 10:35",
      "text": "ει εκεινους ειπεν θεους προς ους ο λογος του θεου εγενετο και ου δυναται λυθηναι η γραφη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "John 10:36",
      "text": "ον ο πατηρ ηγιασεν και απεστειλεν εις τον κοσμον υμεις λεγετε οτι βλασφημεις οτι ειπον υιος του θεου ειμι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.37",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "John 10:37",
      "text": "ει ου ποιω τα εργα του πατρος μου μη πιστευετε μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.38",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "John 10:38",
      "text": "ει δε ποιω καν εμοι μη πιστευητε τοις εργοις πιστευσατε ινα γνωτε και πιστευσητε οτι εν εμοι ο πατηρ καγω εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.39",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 39,
      "referenceLabel": "John 10:39",
      "text": "εζητουν ουν παλιν πιασαι αυτον και εξηλθεν εκ της χειρος αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.40",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 40,
      "referenceLabel": "John 10:40",
      "text": "και απηλθεν παλιν περαν του ιορδανου εις τον τοπον οπου ην ιωαννης το πρωτον βαπτιζων και εμεινεν εκει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.41",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 41,
      "referenceLabel": "John 10:41",
      "text": "και πολλοι ηλθον προς αυτον και ελεγον οτι ιωαννης μεν σημειον εποιησεν ουδεν παντα δε οσα ειπεν ιωαννης περι τουτου αληθη ην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.10.42",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 10,
      "verseNumber": 42,
      "referenceLabel": "John 10:42",
      "text": "και επιστευσαν πολλοι εκει εις αυτον",
      "paragraphStart": false
    }
  ]
}
