{
  "chapter": {
    "id": "ant1904:john.3",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 3,
    "referenceLabel": "John 3",
    "summary": "Source text for John 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.3.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "John 3:1",
      "text": "ην δε ανθρωπος εκ των φαρισαιων νικοδημος ονομα αυτω αρχων των ιουδαιων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.3.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "John 3:2",
      "text": "ουτος ηλθεν προς αυτον νυκτος και ειπεν αυτω ραββι οιδαμεν οτι απο θεου εληλυθας διδασκαλος ουδεις γαρ ταυτα τα σημεια δυναται ποιειν α συ ποιεις εαν μη η ο θεος μετ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "John 3:3",
      "text": "απεκριθη ιησους και ειπεν αυτω αμην αμην λεγω σοι εαν μη τις γεννηθη ανωθεν ου δυναται ιδειν την βασιλειαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "John 3:4",
      "text": "λεγει προς αυτον ο νικοδημος πως δυναται ανθρωπος γεννηθηναι γερων ων μη δυναται εις την κοιλιαν της μητρος αυτου δευτερον εισελθειν και γεννηθηναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "John 3:5",
      "text": "απεκριθη ιησους αμην αμην λεγω σοι εαν μη τις γεννηθη εξ υδατος και πνευματος ου δυναται εισελθειν εις την βασιλειαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "John 3:6",
      "text": "το γεγεννημενον εκ της σαρκος σαρξ εστιν και το γεγεννημενον εκ του πνευματος πνευμα εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "John 3:7",
      "text": "μη θαυμασης οτι ειπον σοι δει υμας γεννηθηναι ανωθεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "John 3:8",
      "text": "το πνευμα οπου θελει πνει και την φωνην αυτου ακουεις αλλ ουκ οιδας ποθεν ερχεται και που υπαγει ουτως εστιν πας ο γεγεννημενος εκ του πνευματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "John 3:9",
      "text": "απεκριθη νικοδημος και ειπεν αυτω πως δυναται ταυτα γενεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "John 3:10",
      "text": "απεκριθη ιησους και ειπεν αυτω συ ει ο διδασκαλος του ισραηλ και ταυτα ου γινωσκεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "John 3:11",
      "text": "αμην αμην λεγω σοι οτι ο οιδαμεν λαλουμεν και ο εωρακαμεν μαρτυρουμεν και την μαρτυριαν ημων ου λαμβανετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "John 3:12",
      "text": "ει τα επιγεια ειπον υμιν και ου πιστευετε πως εαν ειπω υμιν τα επουρανια πιστευσετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "John 3:13",
      "text": "και ουδεις αναβεβηκεν εις τον ουρανον ει μη ο εκ του ουρανου καταβας ο υιος του ανθρωπου ο ων εν τω ουρανω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "John 3:14",
      "text": "και καθως μωυσης υψωσεν τον οφιν εν τη ερημω ουτως υψωθηναι δει τον υιον του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "John 3:15",
      "text": "ινα πας ο πιστευων εις αυτον μη αποληται αλλ εχη ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "John 3:16",
      "text": "ουτως γαρ ηγαπησεν ο θεος τον κοσμον ωστε τον υιον αυτου τον μονογενη εδωκεν ινα πας ο πιστευων εις αυτον μη αποληται αλλ εχη ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "John 3:17",
      "text": "ου γαρ απεστειλεν ο θεος τον υιον αυτου εις τον κοσμον ινα κρινη τον κοσμον αλλ ινα σωθη ο κοσμος δι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "John 3:18",
      "text": "ο πιστευων εις αυτον ου κρινεται ο δε μη πιστευων ηδη κεκριται οτι μη πεπιστευκεν εις το ονομα του μονογενους υιου του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "John 3:19",
      "text": "αυτη δε εστιν η κρισις οτι το φως εληλυθεν εις τον κοσμον και ηγαπησαν οι ανθρωποι μαλλον το σκοτος η το φως ην γαρ πονηρα αυτων τα εργα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "John 3:20",
      "text": "πας γαρ ο φαυλα πρασσων μισει το φως και ουκ ερχεται προς το φως ινα μη ελεγχθη τα εργα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "John 3:21",
      "text": "ο δε ποιων την αληθειαν ερχεται προς το φως ινα φανερωθη αυτου τα εργα οτι εν θεω εστιν ειργασμενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "John 3:22",
      "text": "μετα ταυτα ηλθεν ο ιησους και οι μαθηται αυτου εις την ιουδαιαν γην και εκει διετριβεν μετ αυτων και εβαπτιζεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "John 3:23",
      "text": "ην δε και ιωαννης βαπτιζων εν αινων εγγυς του σαλειμ οτι υδατα πολλα ην εκει και παρεγινοντο και εβαπτιζοντο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "John 3:24",
      "text": "ουπω γαρ ην βεβλημενος εις την φυλακην ο ιωαννης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "John 3:25",
      "text": "εγενετο ουν ζητησις εκ των μαθητων ιωαννου μετα ιουδαιου περι καθαρισμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "John 3:26",
      "text": "και ηλθον προς τον ιωαννην και ειπον αυτω ραββι ος ην μετα σου περαν του ιορδανου ω συ μεμαρτυρηκας ιδε ουτος βαπτιζει και παντες ερχονται προς αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "John 3:27",
      "text": "απεκριθη ιωαννης και ειπεν ου δυναται ανθρωπος λαμβανειν ουδεν εαν μη η δεδομενον αυτω εκ του ουρανου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "John 3:28",
      "text": "αυτοι υμεις μοι μαρτυρειτε οτι ειπον ουκ ειμι εγω ο χριστος αλλ οτι απεσταλμενος ειμι εμπροσθεν εκεινου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "John 3:29",
      "text": "ο εχων την νυμφην νυμφιος εστιν ο δε φιλος του νυμφιου ο εστηκως και ακουων αυτου χαρα χαιρει δια την φωνην του νυμφιου αυτη ουν η χαρα η εμη πεπληρωται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "John 3:30",
      "text": "εκεινον δει αυξανειν εμε δε ελαττουσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "John 3:31",
      "text": "ο ανωθεν ερχομενος επανω παντων εστιν ο ων εκ της γης εκ της γης εστιν και εκ της γης λαλει ο εκ του ουρανου ερχομενος επανω παντων εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "John 3:32",
      "text": "και ο εωρακεν και ηκουσεν τουτο μαρτυρει και την μαρτυριαν αυτου ουδεις λαμβανει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "John 3:33",
      "text": "ο λαβων αυτου την μαρτυριαν εσφραγισεν οτι ο θεος αληθης εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "John 3:34",
      "text": "ον γαρ απεστειλεν ο θεος τα ρηματα του θεου λαλει ου γαρ εκ μετρου διδωσιν ο θεος το πνευμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "John 3:35",
      "text": "ο πατηρ αγαπα τον υιον και παντα δεδωκεν εν τη χειρι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.3.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "John 3:36",
      "text": "ο πιστευων εις τον υιον εχει ζωην αιωνιον ο δε απειθων τω υιω ουκ οψεται ζωην αλλ η οργη του θεου μενει επ αυτον",
      "paragraphStart": false
    }
  ]
}
