{
  "chapter": {
    "id": "ant1904:john.7",
    "translationId": "ant1904",
    "bookSlug": "john",
    "chapterNumber": 7,
    "referenceLabel": "John 7",
    "summary": "Source text for John 7 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:john.7.1",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "John 7:1",
      "text": "και περιεπατει ο ιησους μετα ταυτα εν τη γαλιλαια ου γαρ ηθελεν εν τη ιουδαια περιπατειν οτι εζητουν αυτον οι ιουδαιοι αποκτειναι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:john.7.2",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "John 7:2",
      "text": "ην δε εγγυς η εορτη των ιουδαιων η σκηνοπηγια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.3",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "John 7:3",
      "text": "ειπον ουν προς αυτον οι αδελφοι αυτου μεταβηθι εντευθεν και υπαγε εις την ιουδαιαν ινα και οι μαθηται σου θεωρησωσιν τα εργα σου α ποιεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.4",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "John 7:4",
      "text": "ουδεις γαρ εν κρυπτω τι ποιει και ζητει αυτος εν παρρησια ειναι ει ταυτα ποιεις φανερωσον σεαυτον τω κοσμω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.5",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "John 7:5",
      "text": "ουδε γαρ οι αδελφοι αυτου επιστευον εις αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.6",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "John 7:6",
      "text": "λεγει ουν αυτοις ο ιησους ο καιρος ο εμος ουπω παρεστιν ο δε καιρος ο υμετερος παντοτε εστιν ετοιμος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.7",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "John 7:7",
      "text": "ου δυναται ο κοσμος μισειν υμας εμε δε μισει οτι εγω μαρτυρω περι αυτου οτι τα εργα αυτου πονηρα εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.8",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "John 7:8",
      "text": "υμεις αναβητε εις την εορτην ταυτην εγω ουπω αναβαινω εις την εορτην ταυτην οτι ο καιρος ο εμος ουπω πεπληρωται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.9",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "John 7:9",
      "text": "ταυτα δε ειπων αυτοις εμεινεν εν τη γαλιλαια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.10",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "John 7:10",
      "text": "ως δε ανεβησαν οι αδελφοι αυτου τοτε και αυτος ανεβη εις την εορτην ου φανερως αλλ ως εν κρυπτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.11",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "John 7:11",
      "text": "οι ουν ιουδαιοι εζητουν αυτον εν τη εορτη και ελεγον που εστιν εκεινος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.12",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "John 7:12",
      "text": "και γογγυσμος πολυς περι αυτου ην εν τοις οχλοις οι μεν ελεγον οτι αγαθος εστιν αλλοι ελεγον ου αλλα πλανα τον οχλον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.13",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "John 7:13",
      "text": "ουδεις μεντοι παρρησια ελαλει περι αυτου δια τον φοβον των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.14",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "John 7:14",
      "text": "ηδη δε της εορτης μεσουσης ανεβη ο ιησους εις το ιερον και εδιδασκεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.15",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "John 7:15",
      "text": "και εθαυμαζον οι ιουδαιοι λεγοντες πως ουτος γραμματα οιδεν μη μεμαθηκως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.16",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "John 7:16",
      "text": "απεκριθη ουν αυτοις ο ιησους και ειπεν η εμη διδαχη ουκ εστιν εμη αλλα του πεμψαντος με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.17",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "John 7:17",
      "text": "εαν τις θελη το θελημα αυτου ποιειν γνωσεται περι της διδαχης ποτερον εκ του θεου εστιν η εγω απ εμαυτου λαλω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.18",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "John 7:18",
      "text": "ο αφ εαυτου λαλων την δοξαν την ιδιαν ζητει ο δε ζητων την δοξαν του πεμψαντος αυτον ουτος αληθης εστιν και αδικια εν αυτω ουκ εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.19",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "John 7:19",
      "text": "ου μωυσης δεδωκεν υμιν τον νομον και ουδεις εξ υμων ποιει τον νομον τι με ζητειτε αποκτειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.20",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "John 7:20",
      "text": "απεκριθη ο οχλος και ειπεν δαιμονιον εχεις τις σε ζητει αποκτειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.21",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "John 7:21",
      "text": "απεκριθη ιησους και ειπεν αυτοις εν εργον εποιησα και παντες θαυμαζετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.22",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "John 7:22",
      "text": "δια τουτο μωυσης δεδωκεν υμιν την περιτομην ουχ οτι εκ του μωυσεως εστιν αλλ εκ των πατερων και εν σαββατω περιτεμνετε ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.23",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "John 7:23",
      "text": "ει περιτομην λαμβανει ανθρωπος εν σαββατω ινα μη λυθη ο νομος μωυσεως εμοι χολατε οτι ολον ανθρωπον υγιη εποιησα εν σαββατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.24",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "John 7:24",
      "text": "μη κρινετε κατ οψιν αλλα την δικαιαν κρισιν κρινατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.25",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "John 7:25",
      "text": "ελεγον ουν τινες εκ των ιεροσολυμιτων ουχ ουτος εστιν ον ζητουσιν αποκτειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.26",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "John 7:26",
      "text": "και ιδε παρρησια λαλει και ουδεν αυτω λεγουσιν μηποτε αληθως εγνωσαν οι αρχοντες οτι ουτος εστιν αληθως ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.27",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "John 7:27",
      "text": "αλλα τουτον οιδαμεν ποθεν εστιν ο δε χριστος οταν ερχηται ουδεις γινωσκει ποθεν εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.28",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "John 7:28",
      "text": "εκραξεν ουν εν τω ιερω διδασκων ο ιησους και λεγων καμε οιδατε και οιδατε ποθεν ειμι και απ εμαυτου ουκ εληλυθα αλλ εστιν αληθινος ο πεμψας με ον υμεις ουκ οιδατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.29",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "John 7:29",
      "text": "εγω οιδα αυτον οτι παρ αυτου ειμι κακεινος με απεστειλεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.30",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "John 7:30",
      "text": "εζητουν ουν αυτον πιασαι και ουδεις επεβαλεν επ αυτον την χειρα οτι ουπω εληλυθει η ωρα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.31",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "John 7:31",
      "text": "πολλοι δε εκ του οχλου επιστευσαν εις αυτον και ελεγον οτι ο χριστος οταν ελθη μητι πλειονα σημεια τουτων ποιησει ων ουτος εποιησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.32",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "John 7:32",
      "text": "ηκουσαν οι φαρισαιοι του οχλου γογγυζοντος περι αυτου ταυτα και απεστειλαν υπηρετας οι φαρισαιοι και οι αρχιερεις ινα πιασωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.33",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "John 7:33",
      "text": "ειπεν ουν ο ιησους ετι μικρον χρονον μεθ υμων ειμι και υπαγω προς τον πεμψαντα με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.34",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "John 7:34",
      "text": "ζητησετε με και ουχ ευρησετε και οπου ειμι εγω υμεις ου δυνασθε ελθειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.35",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "John 7:35",
      "text": "ειπον ουν οι ιουδαιοι προς εαυτους που ουτος μελλει πορευεσθαι οτι ημεις ουχ ευρησομεν αυτον μη εις την διασποραν των ελληνων μελλει πορευεσθαι και διδασκειν τους ελληνας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.36",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "John 7:36",
      "text": "τις εστιν ουτος ο λογος ον ειπεν ζητησετε με και ουχ ευρησετε και οπου ειμι εγω υμεις ου δυνασθε ελθειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.37",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "John 7:37",
      "text": "εν δε τη εσχατη ημερα τη μεγαλη της εορτης ειστηκει ο ιησους και εκραξεν λεγων εαν τις διψα ερχεσθω προς με και πινετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.38",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "John 7:38",
      "text": "ο πιστευων εις εμε καθως ειπεν η γραφη ποταμοι εκ της κοιλιας αυτου ρευσουσιν υδατος ζωντος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.39",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "John 7:39",
      "text": "τουτο δε ειπεν περι του πνευματος ου εμελλον λαμβανειν οι πιστευοντες εις αυτον ουπω γαρ ην πνευμα αγιον οτι ιησους ουδεπω εδοξασθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.40",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "John 7:40",
      "text": "πολλοι ουν εκ του οχλου ακουσαντες τον λογον ελεγον ουτος εστιν αληθως ο προφητης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.41",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 41,
      "referenceLabel": "John 7:41",
      "text": "αλλοι ελεγον ουτος εστιν ο χριστος αλλοι ελεγον μη γαρ εκ της γαλιλαιας ο χριστος ερχεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.42",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 42,
      "referenceLabel": "John 7:42",
      "text": "ουχι η γραφη ειπεν οτι εκ του σπερματος δαυιδ και απο βηθλεεμ της κωμης οπου ην δαυιδ ο χριστος ερχεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.43",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 43,
      "referenceLabel": "John 7:43",
      "text": "σχισμα ουν εν τω οχλω εγενετο δι αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.44",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 44,
      "referenceLabel": "John 7:44",
      "text": "τινες δε ηθελον εξ αυτων πιασαι αυτον αλλ ουδεις επεβαλεν επ αυτον τας χειρας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.45",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 45,
      "referenceLabel": "John 7:45",
      "text": "ηλθον ουν οι υπηρεται προς τους αρχιερεις και φαρισαιους και ειπον αυτοις εκεινοι διατι ουκ ηγαγετε αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.46",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 46,
      "referenceLabel": "John 7:46",
      "text": "απεκριθησαν οι υπηρεται ουδεποτε ουτως ελαλησεν ανθρωπος ως ουτος ο ανθρωπος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.47",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 47,
      "referenceLabel": "John 7:47",
      "text": "απεκριθησαν ουν αυτοις οι φαρισαιοι μη και υμεις πεπλανησθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.48",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 48,
      "referenceLabel": "John 7:48",
      "text": "μη τις εκ των αρχοντων επιστευσεν εις αυτον η εκ των φαρισαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.49",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 49,
      "referenceLabel": "John 7:49",
      "text": "αλλ ο οχλος ουτος ο μη γινωσκων τον νομον επικαταρατοι εισιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.50",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 50,
      "referenceLabel": "John 7:50",
      "text": "λεγει νικοδημος προς αυτους ο ελθων νυκτος προς αυτον εις ων εξ αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.51",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 51,
      "referenceLabel": "John 7:51",
      "text": "μη ο νομος ημων κρινει τον ανθρωπον εαν μη ακουση παρ αυτου προτερον και γνω τι ποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.52",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 52,
      "referenceLabel": "John 7:52",
      "text": "απεκριθησαν και ειπον αυτω μη και συ εκ της γαλιλαιας ει ερευνησον και ιδε οτι προφητης εκ της γαλιλαιας ουκ εγηγερται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:john.7.53",
      "translationId": "ant1904",
      "bookSlug": "john",
      "chapterNumber": 7,
      "verseNumber": 53,
      "referenceLabel": "John 7:53",
      "text": "<<και απηλθεν εκαστος εις τον οικον αυτου",
      "paragraphStart": false
    }
  ]
}
