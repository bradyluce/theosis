{
  "chapter": {
    "id": "ant1904:ephesians.5",
    "translationId": "ant1904",
    "bookSlug": "ephesians",
    "chapterNumber": 5,
    "referenceLabel": "Ephesians 5",
    "summary": "Source text for Ephesians 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:ephesians.5.1",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 5:1",
      "text": "γινεσθε ουν μιμηται του θεου ως τεκνα αγαπητα",
      "paragraphStart": true
    },
    {
      "id": "ant1904:ephesians.5.2",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 5:2",
      "text": "και περιπατειτε εν αγαπη καθως και ο χριστος ηγαπησεν ημας και παρεδωκεν εαυτον υπερ ημων προσφοραν και θυσιαν τω θεω εις οσμην ευωδιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.3",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 5:3",
      "text": "πορνεια δε και πασα ακαθαρσια η πλεονεξια μηδε ονομαζεσθω εν υμιν καθως πρεπει αγιοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.4",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 5:4",
      "text": "και αισχροτης και μωρολογια η ευτραπελια τα ουκ ανηκοντα αλλα μαλλον ευχαριστια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.5",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 5:5",
      "text": "τουτο γαρ εστε γινωσκοντες οτι πας πορνος η ακαθαρτος η πλεονεκτης ος εστιν ειδωλολατρης ουκ εχει κληρονομιαν εν τη βασιλεια του χριστου και θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.6",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 5:6",
      "text": "μηδεις υμας απατατω κενοις λογοις δια ταυτα γαρ ερχεται η οργη του θεου επι τους υιους της απειθειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.7",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 5:7",
      "text": "μη ουν γινεσθε συμμετοχοι αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.8",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 5:8",
      "text": "ητε γαρ ποτε σκοτος νυν δε φως εν κυριω ως τεκνα φωτος περιπατειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.9",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 5:9",
      "text": "ο γαρ καρπος του πνευματος εν παση αγαθωσυνη και δικαιοσυνη και αληθεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.10",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 5:10",
      "text": "δοκιμαζοντες τι εστιν ευαρεστον τω κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.11",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 5:11",
      "text": "και μη συγκοινωνειτε τοις εργοις τοις ακαρποις του σκοτους μαλλον δε και ελεγχετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.12",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 5:12",
      "text": "τα γαρ κρυφη γινομενα υπ αυτων αισχρον εστιν και λεγειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.13",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 5:13",
      "text": "τα δε παντα ελεγχομενα υπο του φωτος φανερουται παν γαρ το φανερουμενον φως εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.14",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 5:14",
      "text": "διο λεγει εγειρε ο καθευδων και αναστα εκ των νεκρων και επιφαυσει σοι ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.15",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 5:15",
      "text": "βλεπετε ουν πως ακριβως περιπατειτε μη ως ασοφοι αλλ ως σοφοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.16",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 5:16",
      "text": "εξαγοραζομενοι τον καιρον οτι αι ημεραι πονηραι εισιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.17",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 5:17",
      "text": "δια τουτο μη γινεσθε αφρονες αλλα συνιεντες τι το θελημα του κυριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.18",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 5:18",
      "text": "και μη μεθυσκεσθε οινω εν ω εστιν ασωτια αλλα πληρουσθε εν πνευματι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.19",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 5:19",
      "text": "λαλουντες εαυτοις ψαλμοις και υμνοις και ωδαις πνευματικαις αδοντες και ψαλλοντες εν τη καρδια υμων τω κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.20",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 5:20",
      "text": "ευχαριστουντες παντοτε υπερ παντων εν ονοματι του κυριου ημων ιησου χριστου τω θεω και πατρι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.21",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 5:21",
      "text": "υποτασσομενοι αλληλοις εν φοβω χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.22",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 5:22",
      "text": "αι γυναικες τοις ιδιοις ανδρασιν υποτασσεσθε ως τω κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.23",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 5:23",
      "text": "οτι [ο] ανηρ εστιν κεφαλη της γυναικος ως και ο χριστος κεφαλη της εκκλησιας και αυτος εστιν σωτηρ του σωματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.24",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 5:24",
      "text": "αλλ ωσπερ η εκκλησια υποτασσεται τω χριστω ουτως και αι γυναικες τοις ιδιοις ανδρασιν εν παντι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.25",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 5:25",
      "text": "οι ανδρες αγαπατε τας γυναικας εαυτων καθως και ο χριστος ηγαπησεν την εκκλησιαν και εαυτον παρεδωκεν υπερ αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.26",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 5:26",
      "text": "ινα αυτην αγιαση καθαρισας τω λουτρω του υδατος εν ρηματι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.27",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 5:27",
      "text": "ινα παραστηση αυτην εαυτω ενδοξον την εκκλησιαν μη εχουσαν σπιλον η ρυτιδα η τι των τοιουτων αλλ ινα η αγια και αμωμος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.28",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 5:28",
      "text": "ουτως οφειλουσιν οι ανδρες αγαπαν τας εαυτων γυναικας ως τα εαυτων σωματα ο αγαπων την εαυτου γυναικα εαυτον αγαπα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.29",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 5:29",
      "text": "ουδεις γαρ ποτε την εαυτου σαρκα εμισησεν αλλ εκτρεφει και θαλπει αυτην καθως και ο κυριος την εκκλησιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.30",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 5:30",
      "text": "οτι μελη εσμεν του σωματος αυτου εκ της σαρκος αυτου και εκ των οστεων αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.31",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 5:31",
      "text": "αντι τουτου καταλειψει ανθρωπος τον πατερα αυτου και την μητερα και προσκολληθησεται προς την γυναικα αυτου και εσονται οι δυο εις σαρκα μιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.32",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 5:32",
      "text": "το μυστηριον τουτο μεγα εστιν εγω δε λεγω εις χριστον και εις την εκκλησιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.5.33",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Ephesians 5:33",
      "text": "πλην και υμεις οι καθ ενα εκαστος την εαυτου γυναικα ουτως αγαπατω ως εαυτον η δε γυνη ινα φοβηται τον ανδρα",
      "paragraphStart": false
    }
  ]
}
