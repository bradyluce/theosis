{
  "chapter": {
    "id": "ant1904:ephesians.1",
    "translationId": "ant1904",
    "bookSlug": "ephesians",
    "chapterNumber": 1,
    "referenceLabel": "Ephesians 1",
    "summary": "Source text for Ephesians 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:ephesians.1.1",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 1:1",
      "text": "παυλος αποστολος ιησου χριστου δια θεληματος θεου τοις αγιοις τοις ουσιν εν εφεσω και πιστοις εν χριστω ιησου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:ephesians.1.2",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 1:2",
      "text": "χαρις υμιν και ειρηνη απο θεου πατρος ημων και κυριου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.3",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 1:3",
      "text": "ευλογητος ο θεος και πατηρ του κυριου ημων ιησου χριστου ο ευλογησας ημας εν παση ευλογια πνευματικη εν τοις επουρανιοις εν χριστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.4",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 1:4",
      "text": "καθως [και] εξελεξατο ημας εν αυτω προ καταβολης κοσμου ειναι ημας αγιους και αμωμους κατενωπιον αυτου εν αγαπη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.5",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 1:5",
      "text": "προορισας ημας εις υιοθεσιαν δια ιησου χριστου εις αυτον κατα την ευδοκιαν του θεληματος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.6",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 1:6",
      "text": "εις επαινον δοξης της χαριτος αυτου εν η εχαριτωσεν ημας εν τω ηγαπημενω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.7",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 1:7",
      "text": "εν ω εχομεν την απολυτρωσιν δια του αιματος αυτου την αφεσιν των παραπτωματων κατα τον πλουτον της χαριτος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.8",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 1:8",
      "text": "ης επερισσευσεν εις ημας εν παση σοφια και φρονησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.9",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 1:9",
      "text": "γνωρισας ημιν το μυστηριον του θεληματος αυτου κατα την ευδοκιαν αυτου ην προεθετο εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.10",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 1:10",
      "text": "εις οικονομιαν του πληρωματος των καιρων ανακεφαλαιωσασθαι τα παντα εν τω χριστω τα επι τοις ουρανοις και τα επι της γης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.11",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 1:11",
      "text": "εν αυτω εν ω και εκληρωθημεν προορισθεντες κατα προθεσιν του τα παντα ενεργουντος κατα την βουλην του θεληματος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.12",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 1:12",
      "text": "εις το ειναι ημας εις επαινον δοξης αυτου τους προηλπικοτας εν τω χριστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.13",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 1:13",
      "text": "εν ω και υμεις ακουσαντες τον λογον της αληθειας το ευαγγελιον της σωτηριας υμων εν ω και πιστευσαντες εσφραγισθητε τω πνευματι της επαγγελιας τω αγιω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.14",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 1:14",
      "text": "ος εστιν αρραβων της κληρονομιας ημων εις απολυτρωσιν της περιποιησεως εις επαινον της δοξης αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.15",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 1:15",
      "text": "δια τουτο καγω ακουσας την καθ υμας πιστιν εν τω κυριω ιησου και την αγαπην την εις παντας τους αγιους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.16",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 1:16",
      "text": "ου παυομαι ευχαριστων υπερ υμων μνειαν υμων ποιουμενος επι των προσευχων μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.17",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 1:17",
      "text": "ινα ο θεος του κυριου ημων ιησου χριστου ο πατηρ της δοξης δωη υμιν πνευμα σοφιας και αποκαλυψεως εν επιγνωσει αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.18",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 1:18",
      "text": "πεφωτισμενους τους οφθαλμους της καρδιας υμων εις το ειδεναι υμας τις εστιν η ελπις της κλησεως αυτου και τις ο πλουτος της δοξης της κληρονομιας αυτου εν τοις αγιοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.19",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 1:19",
      "text": "και τι το υπερβαλλον μεγεθος της δυναμεως αυτου εις ημας τους πιστευοντας κατα την ενεργειαν του κρατους της ισχυος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.20",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 1:20",
      "text": "ην ενηργησεν εν τω χριστω εγειρας αυτον εκ νεκρων και εκαθισεν εν δεξια αυτου εν τοις επουρανιοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.21",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 1:21",
      "text": "υπερανω πασης αρχης και εξουσιας και δυναμεως και κυριοτητος και παντος ονοματος ονομαζομενου ου μονον εν τω αιωνι τουτω αλλα και εν τω μελλοντι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.22",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 1:22",
      "text": "και παντα υπεταξεν υπο τους ποδας αυτου και αυτον εδωκεν κεφαλην υπερ παντα τη εκκλησια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:ephesians.1.23",
      "translationId": "ant1904",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 1:23",
      "text": "ητις εστιν το σωμα αυτου το πληρωμα του τα παντα εν πασιν πληρουμενου",
      "paragraphStart": false
    }
  ]
}
