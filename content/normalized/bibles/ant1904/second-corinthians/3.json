{
  "chapter": {
    "id": "ant1904:second-corinthians.3",
    "translationId": "ant1904",
    "bookSlug": "second-corinthians",
    "chapterNumber": 3,
    "referenceLabel": "2 Corinthians 3",
    "summary": "Source text for 2 Corinthians 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-corinthians.3.1",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 3:1",
      "text": "αρχομεθα παλιν εαυτους συνιστανειν ει μη χρηζομεν ως τινες συστατικων επιστολων προς υμας η εξ υμων συστατικων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-corinthians.3.2",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 3:2",
      "text": "η επιστολη ημων υμεις εστε εγγεγραμμενη εν ταις καρδιαις ημων γινωσκομενη και αναγινωσκομενη υπο παντων ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.3",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 3:3",
      "text": "φανερουμενοι οτι εστε επιστολη χριστου διακονηθεισα υφ ημων εγγεγραμμενη ου μελανι αλλα πνευματι θεου ζωντος ουκ εν πλαξιν λιθιναις αλλα εν πλαξιν καρδιαις σαρκιναις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.4",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 3:4",
      "text": "πεποιθησιν δε τοιαυτην εχομεν δια του χριστου προς τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.5",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 3:5",
      "text": "ουχ οτι ικανοι εσμεν αφ εαυτων λογισασθαι τι ως εξ εαυτων αλλ η ικανοτης ημων εκ του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.6",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 3:6",
      "text": "ος και ικανωσεν ημας διακονους καινης διαθηκης ου γραμματος αλλα πνευματος το γαρ γραμμα αποκτεννει το δε πνευμα ζωοποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.7",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 3:7",
      "text": "ει δε η διακονια του θανατου εν γραμμασιν εντετυπωμενη εν λιθοις εγενηθη εν δοξη ωστε μη δυνασθαι ατενισαι τους υιους ισραηλ εις το προσωπον μωυσεως δια την δοξαν του προσωπου αυτου την καταργουμενην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.8",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 3:8",
      "text": "πως ουχι μαλλον η διακονια του πνευματος εσται εν δοξη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.9",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 3:9",
      "text": "ει γαρ η διακονια της κατακρισεως δοξα πολλω μαλλον περισσευει η διακονια της δικαιοσυνης εν δοξη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.10",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 3:10",
      "text": "και γαρ ουδε δεδοξασται το δεδοξασμενον εν τουτω τω μερει ενεκεν της υπερβαλλουσης δοξης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.11",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 3:11",
      "text": "ει γαρ το καταργουμενον δια δοξης πολλω μαλλον το μενον εν δοξη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.12",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 3:12",
      "text": "εχοντες ουν τοιαυτην ελπιδα πολλη παρρησια χρωμεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.13",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 3:13",
      "text": "και ου καθαπερ μωυσης ετιθει καλυμμα επι το προσωπον εαυτου προς το μη ατενισαι τους υιους ισραηλ εις το τελος του καταργουμενου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.14",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 3:14",
      "text": "αλλ επωρωθη τα νοηματα αυτων αχρι γαρ της σημερον το αυτο καλυμμα επι τη αναγνωσει της παλαιας διαθηκης μενει μη ανακαλυπτομενον οτι εν χριστω καταργειται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.15",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 3:15",
      "text": "αλλ εως σημερον ηνικα αναγινωσκεται μωυσης καλυμμα επι την καρδιαν αυτων κειται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.16",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 3:16",
      "text": "ηνικα δ αν επιστρεψη προς κυριον περιαιρειται το καλυμμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.17",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 3:17",
      "text": "ο δε κυριος το πνευμα εστιν ου δε το πνευμα κυριου εκει ελευθερια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.3.18",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 3:18",
      "text": "ημεις δε παντες ανακεκαλυμμενω προσωπω την δοξαν κυριου κατοπτριζομενοι την αυτην εικονα μεταμορφουμεθα απο δοξης εις δοξαν καθαπερ απο κυριου πνευματος",
      "paragraphStart": false
    }
  ]
}
