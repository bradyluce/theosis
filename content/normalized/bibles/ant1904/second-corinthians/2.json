{
  "chapter": {
    "id": "ant1904:second-corinthians.2",
    "translationId": "ant1904",
    "bookSlug": "second-corinthians",
    "chapterNumber": 2,
    "referenceLabel": "2 Corinthians 2",
    "summary": "Source text for 2 Corinthians 2 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-corinthians.2.1",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 2:1",
      "text": "εκρινα δε εμαυτω τουτο το μη παλιν εν λυπη ελθειν προς υμας",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-corinthians.2.2",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 2:2",
      "text": "ει γαρ εγω λυπω υμας και τις εστιν ο ευφραινων με ει μη ο λυπουμενος εξ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.3",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 2:3",
      "text": "και εγραψα υμιν τουτο αυτο ινα μη ελθων λυπην εχω αφ ων εδει με χαιρειν πεποιθως επι παντας υμας οτι η εμη χαρα παντων υμων εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.4",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 2:4",
      "text": "εκ γαρ πολλης θλιψεως και συνοχης καρδιας εγραψα υμιν δια πολλων δακρυων ουχ ινα λυπηθητε αλλα την αγαπην ινα γνωτε ην εχω περισσοτερως εις υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.5",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 2:5",
      "text": "ει δε τις λελυπηκεν ουκ εμε λελυπηκεν αλλα απο μερους ινα μη επιβαρω παντας υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.6",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 2:6",
      "text": "ικανον τω τοιουτω η επιτιμια αυτη η υπο των πλειονων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.7",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 2:7",
      "text": "ωστε τουναντιον μαλλον υμας χαρισασθαι και παρακαλεσαι μηπως τη περισσοτερα λυπη καταποθη ο τοιουτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.8",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 2:8",
      "text": "διο παρακαλω υμας κυρωσαι εις αυτον αγαπην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.9",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 2:9",
      "text": "εις τουτο γαρ και εγραψα ινα γνω την δοκιμην υμων ει εις παντα υπηκοοι εστε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.10",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 2:10",
      "text": "ω δε τι χαριζεσθε και εγω και γαρ εγω ει τι κεχαρισμαι ω κεχαρισμαι δι υμας εν προσωπω χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.11",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 2:11",
      "text": "ινα μη πλεονεκτηθωμεν υπο του σατανα ου γαρ αυτου τα νοηματα αγνοουμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.12",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 2:12",
      "text": "ελθων δε εις την τρωαδα εις το ευαγγελιον του χριστου και θυρας μοι ανεωγμενης εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.13",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 2:13",
      "text": "ουκ εσχηκα ανεσιν τω πνευματι μου τω μη ευρειν με τιτον τον αδελφον μου αλλα αποταξαμενος αυτοις εξηλθον εις μακεδονιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.14",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 2:14",
      "text": "τω δε θεω χαρις τω παντοτε θριαμβευοντι ημας εν τω χριστω και την οσμην της γνωσεως αυτου φανερουντι δι ημων εν παντι τοπω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.15",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 2:15",
      "text": "οτι χριστου ευωδια εσμεν τω θεω εν τοις σωζομενοις και εν τοις απολλυμενοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.16",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 2:16",
      "text": "οις μεν οσμη θανατου εις θανατον οις δε οσμη ζωης εις ζωην και προς ταυτα τις ικανος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.2.17",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 2:17",
      "text": "ου γαρ εσμεν ως οι λοιποι καπηλευοντες τον λογον του θεου αλλ ως εξ ειλικρινειας αλλ ως εκ θεου κατενωπιον του θεου εν χριστω λαλουμεν",
      "paragraphStart": false
    }
  ]
}
