{
  "chapter": {
    "id": "ant1904:second-corinthians.11",
    "translationId": "ant1904",
    "bookSlug": "second-corinthians",
    "chapterNumber": 11,
    "referenceLabel": "2 Corinthians 11",
    "summary": "Source text for 2 Corinthians 11 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-corinthians.11.1",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 11:1",
      "text": "οφελον ανειχεσθε μου μικρον τη αφροσυνη αλλα και ανεχεσθε μου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-corinthians.11.2",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 11:2",
      "text": "ζηλω γαρ υμας θεου ζηλω ηρμοσαμην γαρ υμας ενι ανδρι παρθενον αγνην παραστησαι τω χριστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.3",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 11:3",
      "text": "φοβουμαι δε μηπως ως ο οφις ευαν εξηπατησεν εν τη πανουργια αυτου ουτως φθαρη τα νοηματα υμων απο της απλοτητος της εις τον χριστον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.4",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 11:4",
      "text": "ει μεν γαρ ο ερχομενος αλλον ιησουν κηρυσσει ον ουκ εκηρυξαμεν η πνευμα ετερον λαμβανετε ο ουκ ελαβετε η ευαγγελιον ετερον ο ουκ εδεξασθε καλως ανειχεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.5",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 11:5",
      "text": "λογιζομαι γαρ μηδεν υστερηκεναι των υπερλιαν αποστολων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.6",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 11:6",
      "text": "ει δε και ιδιωτης τω λογω αλλ ου τη γνωσει αλλ εν παντι φανερωθεντες εν πασιν εις υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.7",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 11:7",
      "text": "η αμαρτιαν εποιησα εμαυτον ταπεινων ινα υμεις υψωθητε οτι δωρεαν το του θεου ευαγγελιον ευηγγελισαμην υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.8",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 11:8",
      "text": "αλλας εκκλησιας εσυλησα λαβων οψωνιον προς την υμων διακονιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.9",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 11:9",
      "text": "και παρων προς υμας και υστερηθεις ου κατεναρκησα ουδενος το γαρ υστερημα μου προσανεπληρωσαν οι αδελφοι ελθοντες απο μακεδονιας και εν παντι αβαρη υμιν εμαυτον ετηρησα και τηρησω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.10",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 11:10",
      "text": "εστιν αληθεια χριστου εν εμοι οτι η καυχησις αυτη ου φραγησεται εις εμε εν τοις κλιμασιν της αχαιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.11",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 11:11",
      "text": "διατι οτι ουκ αγαπω υμας ο θεος οιδεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.12",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 11:12",
      "text": "ο δε ποιω και ποιησω ινα εκκοψω την αφορμην των θελοντων αφορμην ινα εν ω καυχωνται ευρεθωσιν καθως και ημεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.13",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 11:13",
      "text": "οι γαρ τοιουτοι ψευδαποστολοι εργαται δολιοι μετασχηματιζομενοι εις αποστολους χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.14",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 11:14",
      "text": "και ου θαυμαστον αυτος γαρ ο σατανας μετασχηματιζεται εις αγγελον φωτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.15",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 11:15",
      "text": "ου μεγα ουν ει και οι διακονοι αυτου μετασχηματιζονται ως διακονοι δικαιοσυνης ων το τελος εσται κατα τα εργα αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.16",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 11:16",
      "text": "παλιν λεγω μη τις με δοξη αφρονα ειναι ει δε μη γε καν ως αφρονα δεξασθε με ινα καγω μικρον τι καυχησωμαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.17",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 11:17",
      "text": "ο λαλω ου λαλω κατα κυριον αλλ ως εν αφροσυνη εν ταυτη τη υποστασει της καυχησεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.18",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 11:18",
      "text": "επει πολλοι καυχωνται κατα την σαρκα καγω καυχησομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.19",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 11:19",
      "text": "ηδεως γαρ ανεχεσθε των αφρονων φρονιμοι οντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.20",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 11:20",
      "text": "ανεχεσθε γαρ ει τις υμας καταδουλοι ει τις κατεσθιει ει τις λαμβανει ει τις επαιρεται ει τις υμας εις προσωπον δερει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.21",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 11:21",
      "text": "κατα ατιμιαν λεγω ως οτι ημεις ησθενησαμεν εν ω δ αν τις τολμα εν αφροσυνη λεγω τολμω καγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.22",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "2 Corinthians 11:22",
      "text": "εβραιοι εισιν καγω ισραηλιται εισιν καγω σπερμα αβρααμ εισιν καγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.23",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "2 Corinthians 11:23",
      "text": "διακονοι χριστου εισιν παραφρονων λαλω υπερ εγω εν κοποις περισσοτερως εν πληγαις υπερβαλλοντως εν φυλακαις περισσοτερως εν θανατοις πολλακις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.24",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "2 Corinthians 11:24",
      "text": "υπο ιουδαιων πεντακις τεσσαρακοντα παρα μιαν ελαβον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.25",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "2 Corinthians 11:25",
      "text": "τρις ερραβδισθην απαξ ελιθασθην τρις εναυαγησα νυχθημερον εν τω βυθω πεποιηκα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.26",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "2 Corinthians 11:26",
      "text": "οδοιποριαις πολλακις κινδυνοις ποταμων κινδυνοις ληστων κινδυνοις εκ γενους κινδυνοις εξ εθνων κινδυνοις εν πολει κινδυνοις εν ερημια κινδυνοις εν θαλασση κινδυνοις εν ψευδαδελφοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.27",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "2 Corinthians 11:27",
      "text": "εν κοπω και μοχθω εν αγρυπνιαις πολλακις εν λιμω και διψει εν νηστειαις πολλακις εν ψυχει και γυμνοτητι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.28",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "2 Corinthians 11:28",
      "text": "χωρις των παρεκτος η επισυστασις μου η καθ ημεραν η μεριμνα πασων των εκκλησιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.29",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "2 Corinthians 11:29",
      "text": "τις ασθενει και ουκ ασθενω τις σκανδαλιζεται και ουκ εγω πυρουμαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.30",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "2 Corinthians 11:30",
      "text": "ει καυχασθαι δει τα της ασθενειας μου καυχησομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.31",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "2 Corinthians 11:31",
      "text": "ο θεος και πατηρ του κυριου ημων ιησου χριστου οιδεν ο ων ευλογητος εις τους αιωνας οτι ου ψευδομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.32",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "2 Corinthians 11:32",
      "text": "εν δαμασκω ο εθναρχης αρετα του βασιλεως εφρουρει την δαμασκηνων πολιν πιασαι με θελων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.11.33",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "2 Corinthians 11:33",
      "text": "και δια θυριδος εν σαργανη εχαλασθην δια του τειχους και εξεφυγον τας χειρας αυτου",
      "paragraphStart": false
    }
  ]
}
