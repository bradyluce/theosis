{
  "chapter": {
    "id": "ant1904:second-corinthians.5",
    "translationId": "ant1904",
    "bookSlug": "second-corinthians",
    "chapterNumber": 5,
    "referenceLabel": "2 Corinthians 5",
    "summary": "Source text for 2 Corinthians 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-corinthians.5.1",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 5:1",
      "text": "οιδαμεν γαρ οτι εαν η επιγειος ημων οικια του σκηνους καταλυθη οικοδομην εκ θεου εχομεν οικιαν αχειροποιητον αιωνιον εν τοις ουρανοις",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-corinthians.5.2",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 5:2",
      "text": "και γαρ εν τουτω στεναζομεν το οικητηριον ημων το εξ ουρανου επενδυσασθαι επιποθουντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.3",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 5:3",
      "text": "ει γε και ενδυσαμενοι ου γυμνοι ευρεθησομεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.4",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 5:4",
      "text": "και γαρ οι οντες εν τω σκηνει στεναζομεν βαρουμενοι εφ ω ου θελομεν εκδυσασθαι αλλ επενδυσασθαι ινα καταποθη το θνητον υπο της ζωης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.5",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 5:5",
      "text": "ο δε κατεργασαμενος ημας εις αυτο τουτο θεος ο και δους ημιν τον αρραβωνα του πνευματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.6",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 5:6",
      "text": "θαρρουντες ουν παντοτε και ειδοτες οτι ενδημουντες εν τω σωματι εκδημουμεν απο του κυριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.7",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 5:7",
      "text": "δια πιστεως γαρ περιπατουμεν ου δια ειδους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.8",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 5:8",
      "text": "θαρρουμεν δε και ευδοκουμεν μαλλον εκδημησαι εκ του σωματος και ενδημησαι προς τον κυριον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.9",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 5:9",
      "text": "διο και φιλοτιμουμεθα ειτε ενδημουντες ειτε εκδημουντες ευαρεστοι αυτω ειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.10",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 5:10",
      "text": "τους γαρ παντας ημας φανερωθηναι δει εμπροσθεν του βηματος του χριστου ινα κομισηται εκαστος τα δια του σωματος προς α επραξεν ειτε αγαθον ειτε κακον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.11",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 5:11",
      "text": "ειδοτες ουν τον φοβον του κυριου ανθρωπους πειθομεν θεω δε πεφανερωμεθα ελπιζω δε και εν ταις συνειδησεσιν υμων πεφανερωσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.12",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 5:12",
      "text": "ου γαρ παλιν εαυτους συνιστανομεν υμιν αλλα αφορμην διδοντες υμιν καυχηματος υπερ ημων ινα εχητε προς τους εν προσωπω καυχωμενους και ου καρδια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.13",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 5:13",
      "text": "ειτε γαρ εξεστημεν θεω ειτε σωφρονουμεν υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.14",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 5:14",
      "text": "η γαρ αγαπη του χριστου συνεχει ημας κριναντας τουτο οτι [ει] εις υπερ παντων απεθανεν αρα οι παντες απεθανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.15",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 5:15",
      "text": "και υπερ παντων απεθανεν ινα οι ζωντες μηκετι εαυτοις ζωσιν αλλα τω υπερ αυτων αποθανοντι και εγερθεντι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.16",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 5:16",
      "text": "ωστε ημεις απο του νυν ουδενα οιδαμεν κατα σαρκα ει δε και εγνωκαμεν κατα σαρκα χριστον αλλα νυν ουκετι γινωσκομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.17",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 5:17",
      "text": "ωστε ει τις εν χριστω καινη κτισις τα αρχαια παρηλθεν ιδου γεγονεν καινα τα παντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.18",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 5:18",
      "text": "τα δε παντα εκ του θεου του καταλλαξαντος ημας εαυτω δια ιησου χριστου και δοντος ημιν την διακονιαν της καταλλαγης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.19",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 5:19",
      "text": "ως οτι θεος ην εν χριστω κοσμον καταλλασσων εαυτω μη λογιζομενος αυτοις τα παραπτωματα αυτων και θεμενος εν ημιν τον λογον της καταλλαγης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.20",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 5:20",
      "text": "υπερ χριστου ουν πρεσβευομεν ως του θεου παρακαλουντος δι ημων δεομεθα υπερ χριστου καταλλαγητε τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.5.21",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 5:21",
      "text": "τον γαρ μη γνοντα αμαρτιαν υπερ ημων αμαρτιαν εποιησεν ινα ημεις γενωμεθα δικαιοσυνη θεου εν αυτω",
      "paragraphStart": false
    }
  ]
}
