{
  "chapter": {
    "id": "ant1904:second-corinthians.12",
    "translationId": "ant1904",
    "bookSlug": "second-corinthians",
    "chapterNumber": 12,
    "referenceLabel": "2 Corinthians 12",
    "summary": "Source text for 2 Corinthians 12 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-corinthians.12.1",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 12:1",
      "text": "καυχασθαι δη ου συμφερει μοι ελευσομαι γαρ εις οπτασιας και αποκαλυψεις κυριου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-corinthians.12.2",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 12:2",
      "text": "οιδα ανθρωπον εν χριστω προ ετων δεκατεσσαρων ειτε εν σωματι ουκ οιδα ειτε εκτος του σωματος ουκ οιδα ο θεος οιδεν αρπαγεντα τον τοιουτον εως τριτου ουρανου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.3",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 12:3",
      "text": "και οιδα τον τοιουτον ανθρωπον ειτε εν σωματι ειτε εκτος του σωματος ουκ οιδα ο θεος οιδεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.4",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 12:4",
      "text": "οτι ηρπαγη εις τον παραδεισον και ηκουσεν αρρητα ρηματα α ουκ εξον ανθρωπω λαλησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.5",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 12:5",
      "text": "υπερ του τοιουτου καυχησομαι υπερ δε εμαυτου ου καυχησομαι ει μη εν ταις ασθενειαις μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.6",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 12:6",
      "text": "εαν γαρ θελησω καυχησασθαι ουκ εσομαι αφρων αληθειαν γαρ ερω φειδομαι δε μη τις εις εμε λογισηται υπερ ο βλεπει με η ακουει τι εξ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.7",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 12:7",
      "text": "και τη υπερβολη των αποκαλυψεων ινα μη υπεραιρωμαι εδοθη μοι σκολοψ τη σαρκι αγγελος σαταν ινα με κολαφιζη ινα μη υπεραιρωμαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.8",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 12:8",
      "text": "υπερ τουτου τρις τον κυριον παρεκαλεσα ινα αποστη απ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.9",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 12:9",
      "text": "και ειρηκεν μοι αρκει σοι η χαρις μου η γαρ δυναμις μου εν ασθενεια τελειουται ηδιστα ουν μαλλον καυχησομαι εν ταις ασθενειαις μου ινα επισκηνωση επ εμε η δυναμις του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.10",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 12:10",
      "text": "διο ευδοκω εν ασθενειαις εν υβρεσιν εν αναγκαις εν διωγμοις εν στενοχωριαις υπερ χριστου οταν γαρ ασθενω τοτε δυνατος ειμι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.11",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 12:11",
      "text": "γεγονα αφρων καυχωμενος υμεις με ηναγκασατε εγω γαρ ωφειλον υφ υμων συνιστασθαι ουδεν γαρ υστερησα των υπερλιαν αποστολων ει και ουδεν ειμι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.12",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 12:12",
      "text": "τα μεν σημεια του αποστολου κατειργασθη εν υμιν εν παση υπομονη εν σημειοις και τερασιν και δυναμεσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.13",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 12:13",
      "text": "τι γαρ εστιν ο ηττηθητε υπερ τας λοιπας εκκλησιας ει μη οτι αυτος εγω ου κατεναρκησα υμων χαρισασθε μοι την αδικιαν ταυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.14",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 12:14",
      "text": "ιδου τριτον ετοιμως εχω ελθειν προς υμας και ου καταναρκησω υμων ου γαρ ζητω τα υμων αλλα υμας ου γαρ οφειλει τα τεκνα τοις γονευσιν θησαυριζειν αλλ οι γονεις τοις τεκνοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.15",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 12:15",
      "text": "εγω δε ηδιστα δαπανησω και εκδαπανηθησομαι υπερ των ψυχων υμων ει και περισσοτερως υμας αγαπων ηττον αγαπωμαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.16",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 12:16",
      "text": "εστω δε εγω ου κατεβαρησα υμας αλλ υπαρχων πανουργος δολω υμας ελαβον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.17",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 12:17",
      "text": "μη τινα ων απεσταλκα προς υμας δι αυτου επλεονεκτησα υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.18",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 12:18",
      "text": "παρεκαλεσα τιτον και συναπεστειλα τον αδελφον μητι επλεονεκτησεν υμας τιτος ου τω αυτω πνευματι περιεπατησαμεν ου τοις αυτοις ιχνεσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.19",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 12:19",
      "text": "παλιν δοκειτε οτι υμιν απολογουμεθα κατενωπιον του θεου εν χριστω λαλουμεν τα δε παντα αγαπητοι υπερ της υμων οικοδομης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.20",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 12:20",
      "text": "φοβουμαι γαρ μηπως ελθων ουχ οιους θελω ευρω υμας καγω ευρεθω υμιν οιον ου θελετε μηπως ερεις ζηλοι θυμοι εριθειαι καταλαλιαι ψιθυρισμοι φυσιωσεις ακαταστασιαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.12.21",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 12:21",
      "text": "μη παλιν ελθοντα με ταπεινωση ο θεος μου προς υμας και πενθησω πολλους των προημαρτηκοτων και μη μετανοησαντων επι τη ακαθαρσια και πορνεια και ασελγεια η επραξαν",
      "paragraphStart": false
    }
  ]
}
