{
  "chapter": {
    "id": "ant1904:second-corinthians.8",
    "translationId": "ant1904",
    "bookSlug": "second-corinthians",
    "chapterNumber": 8,
    "referenceLabel": "2 Corinthians 8",
    "summary": "Source text for 2 Corinthians 8 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-corinthians.8.1",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "2 Corinthians 8:1",
      "text": "γνωριζω δε υμιν αδελφοι την χαριν του θεου την δεδομενην εν ταις εκκλησιαις της μακεδονιας",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-corinthians.8.2",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "2 Corinthians 8:2",
      "text": "οτι εν πολλη δοκιμη θλιψεως η περισσεια της χαρας αυτων και η κατα βαθους πτωχεια αυτων επερισσευσεν εις τον πλουτον της απλοτητος αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.3",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "2 Corinthians 8:3",
      "text": "οτι κατα δυναμιν μαρτυρω και υπερ δυναμιν αυθαιρετοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.4",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "2 Corinthians 8:4",
      "text": "μετα πολλης παρακλησεως δεομενοι ημων την χαριν και την κοινωνιαν της διακονιας της εις τους αγιους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.5",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "2 Corinthians 8:5",
      "text": "και ου καθως ηλπισαμεν αλλ εαυτους εδωκαν πρωτον τω κυριω και ημιν δια θεληματος θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.6",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "2 Corinthians 8:6",
      "text": "εις το παρακαλεσαι ημας τιτον ινα καθως προενηρξατο ουτως και επιτελεση εις υμας και την χαριν ταυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.7",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "2 Corinthians 8:7",
      "text": "αλλ ωσπερ εν παντι περισσευετε πιστει και λογω και γνωσει και παση σπουδη και τη εξ υμων εν ημιν αγαπη ινα και εν ταυτη τη χαριτι περισσευητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.8",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "2 Corinthians 8:8",
      "text": "ου κατ επιταγην λεγω αλλα δια της ετερων σπουδης και το της υμετερας αγαπης γνησιον δοκιμαζων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.9",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "2 Corinthians 8:9",
      "text": "γινωσκετε γαρ την χαριν του κυριου ημων ιησου χριστου οτι δι υμας επτωχευσεν πλουσιος ων ινα υμεις τη εκεινου πτωχεια πλουτησητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.10",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "2 Corinthians 8:10",
      "text": "και γνωμην εν τουτω διδωμι τουτο γαρ υμιν συμφερει οιτινες ου μονον το ποιησαι αλλα και το θελειν προενηρξασθε απο περυσι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.11",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "2 Corinthians 8:11",
      "text": "νυνι δε και το ποιησαι επιτελεσατε οπως καθαπερ η προθυμια του θελειν ουτως και το επιτελεσαι εκ του εχειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.12",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "2 Corinthians 8:12",
      "text": "ει γαρ η προθυμια προκειται καθο εαν εχη τις ευπροσδεκτος ου καθο ουκ εχει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.13",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "2 Corinthians 8:13",
      "text": "ου γαρ ινα αλλοις ανεσις υμιν δε θλιψις αλλ εξ ισοτητος εν τω νυν καιρω το υμων περισσευμα εις το εκεινων υστερημα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.14",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "2 Corinthians 8:14",
      "text": "ινα και το εκεινων περισσευμα γενηται εις το υμων υστερημα οπως γενηται ισοτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.15",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "2 Corinthians 8:15",
      "text": "καθως γεγραπται ο το πολυ ουκ επλεονασεν και ο το ολιγον ουκ ηλαττονησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.16",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "2 Corinthians 8:16",
      "text": "χαρις δε τω θεω τω διδοντι την αυτην σπουδην υπερ υμων εν τη καρδια τιτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.17",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "2 Corinthians 8:17",
      "text": "οτι την μεν παρακλησιν εδεξατο σπουδαιοτερος δε υπαρχων αυθαιρετος εξηλθεν προς υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.18",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "2 Corinthians 8:18",
      "text": "συνεπεμψαμεν δε μετ αυτου τον αδελφον ου ο επαινος εν τω ευαγγελιω δια πασων των εκκλησιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.19",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "2 Corinthians 8:19",
      "text": "ου μονον δε αλλα και χειροτονηθεις υπο των εκκλησιων συνεκδημος ημων συν τη χαριτι ταυτη τη διακονουμενη υφ ημων προς την αυτου του κυριου δοξαν και προθυμιαν ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.20",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "2 Corinthians 8:20",
      "text": "στελλομενοι τουτο μη τις ημας μωμησηται εν τη αδροτητι ταυτη τη διακονουμενη υφ ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.21",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "2 Corinthians 8:21",
      "text": "προνοουμενοι καλα ου μονον ενωπιον κυριου αλλα και ενωπιον ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.22",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "2 Corinthians 8:22",
      "text": "συνεπεμψαμεν δε αυτοις τον αδελφον ημων ον εδοκιμασαμεν εν πολλοις πολλακις σπουδαιον οντα νυνι δε πολυ σπουδαιοτερον πεποιθησει πολλη τη εις υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.23",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "2 Corinthians 8:23",
      "text": "ειτε υπερ τιτου κοινωνος εμος και εις υμας συνεργος ειτε αδελφοι ημων αποστολοι εκκλησιων δοξα χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-corinthians.8.24",
      "translationId": "ant1904",
      "bookSlug": "second-corinthians",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "2 Corinthians 8:24",
      "text": "την ουν ενδειξιν της αγαπης υμων και ημων καυχησεως υπερ υμων εις αυτους ενδειξασθε εις προσωπον των εκκλησιων",
      "paragraphStart": false
    }
  ]
}
