{
  "chapter": {
    "id": "ant1904:second-timothy.1",
    "translationId": "ant1904",
    "bookSlug": "second-timothy",
    "chapterNumber": 1,
    "referenceLabel": "2 Timothy 1",
    "summary": "Source text for 2 Timothy 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-timothy.1.1",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 1:1",
      "text": "παυλος αποστολος χριστου ιησου δια θεληματος θεου κατ επαγγελιαν ζωης της εν χριστω ιησου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-timothy.1.2",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 1:2",
      "text": "τιμοθεω αγαπητω τεκνω χαρις ελεος ειρηνη απο θεου πατρος και χριστου ιησου του κυριου ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.3",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 1:3",
      "text": "χαριν εχω τω θεω ω λατρευω απο προγονων εν καθαρα συνειδησει ως αδιαλειπτον εχω την περι σου μνειαν εν ταις δεησεσιν μου νυκτος και ημερας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.4",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 1:4",
      "text": "επιποθων σε ιδειν μεμνημενος σου των δακρυων ινα χαρας πληρωθω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.5",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 1:5",
      "text": "υπομνησιν λαμβανων της εν σοι ανυποκριτου πιστεως ητις ενωκησεν πρωτον εν τη μαμμη σου λωιδι και τη μητρι σου ευνικη πεπεισμαι δε οτι και εν σοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.6",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 1:6",
      "text": "δι ην αιτιαν αναμιμνησκω σε αναζωπυρειν το χαρισμα του θεου ο εστιν εν σοι δια της επιθεσεως των χειρων μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.7",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 1:7",
      "text": "ου γαρ εδωκεν ημιν ο θεος πνευμα δειλιας αλλα δυναμεως και αγαπης και σωφρονισμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.8",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 1:8",
      "text": "μη ουν επαισχυνθης το μαρτυριον του κυριου ημων μηδε εμε τον δεσμιον αυτου αλλα συγκακοπαθησον τω ευαγγελιω κατα δυναμιν θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.9",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 1:9",
      "text": "του σωσαντος ημας και καλεσαντος κλησει αγια ου κατα τα εργα ημων αλλα κατ ιδιαν προθεσιν και χαριν την δοθεισαν ημιν εν χριστω ιησου προ χρονων αιωνιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.10",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 1:10",
      "text": "φανερωθεισαν δε νυν δια της επιφανειας του σωτηρος ημων ιησου χριστου καταργησαντος μεν τον θανατον φωτισαντος δε ζωην και αφθαρσιαν δια του ευαγγελιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.11",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 1:11",
      "text": "εις ο ετεθην εγω κηρυξ και αποστολος και διδασκαλος εθνων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.12",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 1:12",
      "text": "δι ην αιτιαν και ταυτα πασχω αλλ ουκ επαισχυνομαι οιδα γαρ ω πεπιστευκα και πεπεισμαι οτι δυνατος εστιν την παραθηκην μου φυλαξαι εις εκεινην την ημεραν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.13",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 1:13",
      "text": "υποτυπωσιν εχε υγιαινοντων λογων ων παρ εμου ηκουσας εν πιστει και αγαπη τη εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.14",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 1:14",
      "text": "την καλην παραθηκην φυλαξον δια πνευματος αγιου του ενοικουντος εν ημιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.15",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 1:15",
      "text": "οιδας τουτο οτι απεστραφησαν με παντες οι εν τη ασια ων εστιν φυγελλος και ερμογενης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.16",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 1:16",
      "text": "δωη ελεος ο κυριος τω ονησιφορου οικω οτι πολλακις με ανεψυξεν και την αλυσιν μου ουκ επαισχυνθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.17",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 1:17",
      "text": "αλλα γενομενος εν ρωμη σπουδαιοτερον εζητησεν με και ευρεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.1.18",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "2 Timothy 1:18",
      "text": "δωη αυτω ο κυριος ευρειν ελεος παρα κυριου εν εκεινη τη ημερα και οσα εν εφεσω διηκονησεν βελτιον συ γινωσκεις",
      "paragraphStart": false
    }
  ]
}
