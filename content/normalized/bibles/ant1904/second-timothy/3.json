{
  "chapter": {
    "id": "ant1904:second-timothy.3",
    "translationId": "ant1904",
    "bookSlug": "second-timothy",
    "chapterNumber": 3,
    "referenceLabel": "2 Timothy 3",
    "summary": "Source text for 2 Timothy 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-timothy.3.1",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Timothy 3:1",
      "text": "τουτο δε γινωσκε οτι εν εσχαταις ημεραις ενστησονται καιροι χαλεποι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-timothy.3.2",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Timothy 3:2",
      "text": "εσονται γαρ οι ανθρωποι φιλαυτοι φιλαργυροι αλαζονες υπερηφανοι βλασφημοι γονευσιν απειθεις αχαριστοι ανοσιοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.3",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Timothy 3:3",
      "text": "αστοργοι ασπονδοι διαβολοι ακρατεις ανημεροι αφιλαγαθοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.4",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Timothy 3:4",
      "text": "προδοται προπετεις τετυφωμενοι φιληδονοι μαλλον η φιλοθεοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.5",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Timothy 3:5",
      "text": "εχοντες μορφωσιν ευσεβειας την δε δυναμιν αυτης ηρνημενοι και τουτους αποτρεπου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.6",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Timothy 3:6",
      "text": "εκ τουτων γαρ εισιν οι ενδυνοντες εις τας οικιας και αιχμαλωτιζοντες γυναικαρια σεσωρευμενα αμαρτιαις αγομενα επιθυμιαις ποικιλαις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.7",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Timothy 3:7",
      "text": "παντοτε μανθανοντα και μηδεποτε εις επιγνωσιν αληθειας ελθειν δυναμενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.8",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Timothy 3:8",
      "text": "ον τροπον δε ιαννης και ιαμβρης αντεστησαν μωυσει ουτως και ουτοι ανθιστανται τη αληθεια ανθρωποι κατεφθαρμενοι τον νουν αδοκιμοι περι την πιστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.9",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Timothy 3:9",
      "text": "αλλ ου προκοψουσιν επι πλειον η γαρ ανοια αυτων εκδηλος εσται πασιν ως και η εκεινων εγενετο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.10",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Timothy 3:10",
      "text": "συ δε παρηκολουθηκας μου τη διδασκαλια τη αγωγη τη προθεσει τη πιστει τη μακροθυμια τη αγαπη τη υπομονη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.11",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Timothy 3:11",
      "text": "τοις διωγμοις τοις παθημασιν οια μοι εγενοντο εν αντιοχεια εν ικονιω εν λυστροις οιους διωγμους υπηνεγκα και εκ παντων με ερρυσατο ο κυριος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.12",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Timothy 3:12",
      "text": "και παντες δε οι θελοντες ευσεβως ζην εν χριστω ιησου διωχθησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.13",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Timothy 3:13",
      "text": "πονηροι δε ανθρωποι και γοητες προκοψουσιν επι το χειρον πλανωντες και πλανωμενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.14",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Timothy 3:14",
      "text": "συ δε μενε εν οις εμαθες και επιστωθης ειδως παρα τινος εμαθες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.15",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Timothy 3:15",
      "text": "και οτι απο βρεφους τα ιερα γραμματα οιδας τα δυναμενα σε σοφισαι εις σωτηριαν δια πιστεως της εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.16",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Timothy 3:16",
      "text": "πασα γραφη θεοπνευστος και ωφελιμος προς διδασκαλιαν προς ελεγχον προς επανορθωσιν προς παιδειαν την εν δικαιοσυνη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-timothy.3.17",
      "translationId": "ant1904",
      "bookSlug": "second-timothy",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Timothy 3:17",
      "text": "ινα αρτιος η ο του θεου ανθρωπος προς παν εργον αγαθον εξηρτισμενος",
      "paragraphStart": false
    }
  ]
}
