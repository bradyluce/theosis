{
  "chapter": {
    "id": "ant1904:colossians.2",
    "translationId": "ant1904",
    "bookSlug": "colossians",
    "chapterNumber": 2,
    "referenceLabel": "Colossians 2",
    "summary": "Source text for Colossians 2 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:colossians.2.1",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Colossians 2:1",
      "text": "θελω γαρ υμας ειδεναι ηλικον αγωνα εχω περι υμων και των εν λαοδικεια και οσοι ουχ εωρακασιν το προσωπον μου εν σαρκι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:colossians.2.2",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Colossians 2:2",
      "text": "ινα παρακληθωσιν αι καρδιαι αυτων συμβιβασθεντων εν αγαπη και εις παντα πλουτον της πληροφοριας της συνεσεως εις επιγνωσιν του μυστηριου του θεου και πατρος και του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.3",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Colossians 2:3",
      "text": "εν ω εισιν παντες οι θησαυροι της σοφιας και της γνωσεως αποκρυφοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.4",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Colossians 2:4",
      "text": "τουτο δε λεγω ινα μη τις υμας παραλογιζηται εν πιθανολογια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.5",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Colossians 2:5",
      "text": "ει γαρ και τη σαρκι απειμι αλλα τω πνευματι συν υμιν ειμι χαιρων και βλεπων υμων την ταξιν και το στερεωμα της εις χριστον πιστεως υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.6",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Colossians 2:6",
      "text": "ως ουν παρελαβετε τον χριστον ιησουν τον κυριον εν αυτω περιπατειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.7",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Colossians 2:7",
      "text": "ερριζωμενοι και εποικοδομουμενοι εν αυτω και βεβαιουμενοι εν τη πιστει καθως εδιδαχθητε περισσευοντες εν αυτη εν ευχαριστια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.8",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Colossians 2:8",
      "text": "βλεπετε μη τις υμας εσται ο συλαγωγων δια της φιλοσοφιας και κενης απατης κατα την παραδοσιν των ανθρωπων κατα τα στοιχεια του κοσμου και ου κατα χριστον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.9",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Colossians 2:9",
      "text": "οτι εν αυτω κατοικει παν το πληρωμα της θεοτητος σωματικως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.10",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Colossians 2:10",
      "text": "και εστε εν αυτω πεπληρωμενοι ος εστιν η κεφαλη πασης αρχης και εξουσιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.11",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Colossians 2:11",
      "text": "εν ω και περιετμηθητε περιτομη αχειροποιητω εν τη απεκδυσει του σωματος των αμαρτιων της σαρκος εν τη περιτομη του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.12",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Colossians 2:12",
      "text": "συνταφεντες αυτω εν τω βαπτισματι εν ω και συνηγερθητε δια της πιστεως της ενεργειας του θεου του εγειραντος αυτον εκ των νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.13",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Colossians 2:13",
      "text": "και υμας νεκρους οντας [εν] τοις παραπτωμασιν και τη ακροβυστια της σαρκος υμων συνεζωοποιησεν υμας συν αυτω χαρισαμενος ημιν παντα τα παραπτωματα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.14",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Colossians 2:14",
      "text": "εξαλειψας το καθ ημων χειρογραφον τοις δογμασιν ο ην υπεναντιον ημιν και αυτο ηρεν εκ του μεσου προσηλωσας αυτο τω σταυρω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.15",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Colossians 2:15",
      "text": "απεκδυσαμενος τας αρχας και τας εξουσιας εδειγματισεν εν παρρησια θριαμβευσας αυτους εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.16",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Colossians 2:16",
      "text": "μη ουν τις υμας κρινετω εν βρωσει η εν ποσει η εν μερει εορτης η νουμηνιας η σαββατων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.17",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Colossians 2:17",
      "text": "α εστιν σκια των μελλοντων το δε σωμα χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.18",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Colossians 2:18",
      "text": "μηδεις υμας καταβραβευετω θελων εν ταπεινοφροσυνη και θρησκεια των αγγελων α μη εωρακεν εμβατευων εικη φυσιουμενος υπο του νοος της σαρκος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.19",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Colossians 2:19",
      "text": "και ου κρατων την κεφαλην εξ ου παν το σωμα δια των αφων και συνδεσμων επιχορηγουμενον και συμβιβαζομενον αυξει την αυξησιν του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.20",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Colossians 2:20",
      "text": "ει ουν απεθανετε συν τω χριστω απο των στοιχειων του κοσμου τι ως ζωντες εν κοσμω δογματιζεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.21",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Colossians 2:21",
      "text": "μη αψη μηδε γευση μηδε θιγης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.22",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Colossians 2:22",
      "text": "α εστιν παντα εις φθοραν τη αποχρησει κατα τα ενταλματα και διδασκαλιας των ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.2.23",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Colossians 2:23",
      "text": "ατινα εστιν λογον μεν εχοντα σοφιας εν εθελοθρησκια και ταπεινοφροσυνη και αφειδια σωματος ουκ εν τιμη τινι προς πλησμονην της σαρκος",
      "paragraphStart": false
    }
  ]
}
