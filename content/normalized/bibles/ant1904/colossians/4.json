{
  "chapter": {
    "id": "ant1904:colossians.4",
    "translationId": "ant1904",
    "bookSlug": "colossians",
    "chapterNumber": 4,
    "referenceLabel": "Colossians 4",
    "summary": "Source text for Colossians 4 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:colossians.4.1",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Colossians 4:1",
      "text": "οι κυριοι το δικαιον και την ισοτητα τοις δουλοις παρεχεσθε ειδοτες οτι και υμεις εχετε κυριον εν ουρανοις",
      "paragraphStart": true
    },
    {
      "id": "ant1904:colossians.4.2",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Colossians 4:2",
      "text": "τη προσευχη προσκαρτερειτε γρηγορουντες εν αυτη εν ευχαριστια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.3",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Colossians 4:3",
      "text": "προσευχομενοι αμα και περι ημων ινα ο θεος ανοιξη ημιν θυραν του λογου λαλησαι το μυστηριον του χριστου δι ο και δεδεμαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.4",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Colossians 4:4",
      "text": "ινα φανερωσω αυτο ως δει με λαλησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.5",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Colossians 4:5",
      "text": "εν σοφια περιπατειτε προς τους εξω τον καιρον εξαγοραζομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.6",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Colossians 4:6",
      "text": "ο λογος υμων παντοτε εν χαριτι αλατι ηρτυμενος ειδεναι πως δει υμας ενι εκαστω αποκρινεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.7",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Colossians 4:7",
      "text": "τα κατ εμε παντα γνωρισει υμιν τυχικος ο αγαπητος αδελφος και πιστος διακονος και συνδουλος εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.8",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Colossians 4:8",
      "text": "ον επεμψα προς υμας εις αυτο τουτο ινα γνω τα περι υμων και παρακαλεση τας καρδιας υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.9",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Colossians 4:9",
      "text": "συν ονησιμω τω πιστω και αγαπητω αδελφω ος εστιν εξ υμων παντα υμιν γνωριουσιν τα ωδε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.10",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Colossians 4:10",
      "text": "ασπαζεται υμας αρισταρχος ο συναιχμαλωτος μου και μαρκος ο ανεψιος βαρναβα περι ου ελαβετε εντολας εαν ελθη προς υμας δεξασθε αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.11",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Colossians 4:11",
      "text": "και ιησους ο λεγομενος ιουστος οι οντες εκ περιτομης ουτοι μονοι συνεργοι εις την βασιλειαν του θεου οιτινες εγενηθησαν μοι παρηγορια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.12",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Colossians 4:12",
      "text": "ασπαζεται υμας επαφρας ο εξ υμων δουλος χριστου παντοτε αγωνιζομενος υπερ υμων εν ταις προσευχαις ινα στητε τελειοι και πεπληρωμενοι εν παντι θεληματι του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.13",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Colossians 4:13",
      "text": "μαρτυρω γαρ αυτω οτι εχει ζηλον πολυν υπερ υμων και των εν λαοδικεια και των εν ιεραπολει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.14",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Colossians 4:14",
      "text": "ασπαζεται υμας λουκας ο ιατρος ο αγαπητος και δημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.15",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Colossians 4:15",
      "text": "ασπασασθε τους εν λαοδικεια αδελφους και νυμφαν και την κατ οικον αυτου εκκλησιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.16",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Colossians 4:16",
      "text": "και οταν αναγνωσθη παρ υμιν η επιστολη ποιησατε ινα και εν τη λαοδικεων εκκλησια αναγνωσθη και την εκ λαοδικειας ινα και υμεις αναγνωτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.17",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Colossians 4:17",
      "text": "και ειπατε αρχιππω βλεπε την διακονιαν ην παρελαβες εν κυριω ινα αυτην πληροις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:colossians.4.18",
      "translationId": "ant1904",
      "bookSlug": "colossians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Colossians 4:18",
      "text": "ο ασπασμος τη εμη χειρι παυλου μνημονευετε μου των δεσμων η χαρις μεθ υμων αμην",
      "paragraphStart": false
    }
  ]
}
