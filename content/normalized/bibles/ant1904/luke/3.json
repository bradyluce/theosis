{
  "chapter": {
    "id": "ant1904:luke.3",
    "translationId": "ant1904",
    "bookSlug": "luke",
    "chapterNumber": 3,
    "referenceLabel": "Luke 3",
    "summary": "Source text for Luke 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:luke.3.1",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Luke 3:1",
      "text": "εν ετει δε πεντεκαιδεκατω της ηγεμονιας τιβεριου καισαρος ηγεμονευοντος ποντιου πιλατου της ιουδαιας και τετραρχουντος της γαλιλαιας ηρωδου φιλιππου δε του αδελφου αυτου τετραρχουντος της ιτουραιας και τραχωνιτιδος χωρας και λυσανιου της αβιληνης τετραρχουντος",
      "paragraphStart": true
    },
    {
      "id": "ant1904:luke.3.2",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Luke 3:2",
      "text": "επ αρχιερεως αννα και καιαφα εγενετο ρημα θεου επι ιωαννην τον ζαχαριου υιον εν τη ερημω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.3",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Luke 3:3",
      "text": "και ηλθεν εις πασαν την περιχωρον του ιορδανου κηρυσσων βαπτισμα μετανοιας εις αφεσιν αμαρτιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.4",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Luke 3:4",
      "text": "ως γεγραπται εν βιβλω λογων ησαιου του προφητου λεγοντος φωνη βοωντος εν τη ερημω ετοιμασατε την οδον κυριου ευθειας ποιειτε τας τριβους αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.5",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Luke 3:5",
      "text": "πασα φαραγξ πληρωθησεται και παν ορος και βουνος ταπεινωθησεται και εσται τα σκολια εις ευθειαν και αι τραχειαι εις οδους λειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.6",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Luke 3:6",
      "text": "και οψεται πασα σαρξ το σωτηριον του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.7",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Luke 3:7",
      "text": "ελεγεν ουν τοις εκπορευομενοις οχλοις βαπτισθηναι υπ αυτου γεννηματα εχιδνων τις υπεδειξεν υμιν φυγειν απο της μελλουσης οργης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.8",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Luke 3:8",
      "text": "ποιησατε ουν καρπους αξιους της μετανοιας και μη αρξησθε λεγειν εν εαυτοις πατερα εχομεν τον αβρααμ λεγω γαρ υμιν οτι δυναται ο θεος εκ των λιθων τουτων εγειραι τεκνα τω αβρααμ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.9",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Luke 3:9",
      "text": "ηδη δε και η αξινη προς την ριζαν των δενδρων κειται παν ουν δενδρον μη ποιουν καρπον καλον εκκοπτεται και εις πυρ βαλλεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.10",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Luke 3:10",
      "text": "και επηρωτων αυτον οι οχλοι λεγοντες τι ουν ποιησομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.11",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Luke 3:11",
      "text": "αποκριθεις δε λεγει αυτοις ο εχων δυο χιτωνας μεταδοτω τω μη εχοντι και ο εχων βρωματα ομοιως ποιειτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.12",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Luke 3:12",
      "text": "ηλθον δε και τελωναι βαπτισθηναι και ειπον προς αυτον διδασκαλε τι ποιησομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.13",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Luke 3:13",
      "text": "ο δε ειπεν προς αυτους μηδεν πλεον παρα το διατεταγμενον υμιν πρασσετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.14",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Luke 3:14",
      "text": "επηρωτων δε αυτον και στρατευομενοι λεγοντες και ημεις τι ποιησομεν και ειπεν προς αυτους μηδενα συκοφαντησητε μηδε διασεισητε και αρκεισθε τοις οψωνιοις υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.15",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Luke 3:15",
      "text": "προσδοκωντος δε του λαου και διαλογιζομενων παντων εν ταις καρδιαις αυτων περι του ιωαννου μηποτε αυτος ειη ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.16",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Luke 3:16",
      "text": "απεκρινατο ο ιωαννης απασιν λεγων εγω μεν υδατι βαπτιζω υμας ερχεται δε ο ισχυροτερος μου ου ουκ ειμι ικανος λυσαι τον ιμαντα των υποδηματων αυτου αυτος υμας βαπτισει εν πνευματι αγιω και πυρι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.17",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Luke 3:17",
      "text": "ου το πτυον εν τη χειρι αυτου και διακαθαριει την αλωνα αυτου και συναξει τον σιτον εις την αποθηκην αυτου το δε αχυρον κατακαυσει πυρι ασβεστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.18",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Luke 3:18",
      "text": "πολλα μεν ουν και ετερα παρακαλων ευηγγελιζετο τον λαον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.19",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Luke 3:19",
      "text": "ο δε ηρωδης ο τετραρχης ελεγχομενος υπ αυτου περι ηρωδιαδος της γυναικος του αδελφου αυτου και περι παντων ων εποιησεν πονηρων ο ηρωδης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.20",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Luke 3:20",
      "text": "προσεθηκεν και τουτο επι πασιν και κατεκλεισεν τον ιωαννην εν τη φυλακη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.21",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Luke 3:21",
      "text": "εγενετο δε εν τω βαπτισθηναι απαντα τον λαον και ιησου βαπτισθεντος και προσευχομενου ανεωχθηναι τον ουρανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.22",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Luke 3:22",
      "text": "και καταβηναι το πνευμα το αγιον σωματικω ειδει ωσει περιστεραν επ αυτον και φωνην εξ ουρανου γενεσθαι λεγουσαν συ ει ο υιος μου ο αγαπητος εν σοι ευδοκησα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.23",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Luke 3:23",
      "text": "και αυτος ην ο ιησους ωσει ετων τριακοντα αρχομενος ων ως ενομιζετο υιος ιωσηφ του ηλι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.24",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Luke 3:24",
      "text": "του ματθαν του λευι του μελχι του ιωαννα του ιωσηφ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.25",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Luke 3:25",
      "text": "του ματταθιου του αμως του ναουμ του εσλιμ του ναγγαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.26",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Luke 3:26",
      "text": "του μααθ του ματταθιου του σεμευ του ιωσηχ του ιωδα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.27",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Luke 3:27",
      "text": "του ιωανναν του ρησα του ζοροβαβελ του σαλαθιηλ του νηρι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.28",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Luke 3:28",
      "text": "του μελχι του αδδι του κωσαμ του ελμωδαμ του ηρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.29",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Luke 3:29",
      "text": "του ιωση του ελιεζερ του ιωρειμ του ματθατ του λευι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.30",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Luke 3:30",
      "text": "του συμεων του ιουδα του ιωσηφ του ιωνα του ελιακειμ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.31",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Luke 3:31",
      "text": "του μελεα του μαιναν του ματταθα του ναθαν του δαυιδ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.32",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Luke 3:32",
      "text": "του ιεσσαι του ωβηδ του βοοζ του σαλμων του ναασσων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.33",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Luke 3:33",
      "text": "του αμιναδαβ του αραμ του ιωραμ του εσρωμ του φαρες του ιουδα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.34",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Luke 3:34",
      "text": "του ιακωβ του ισαακ του αβρααμ του θαρα του ναχωρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.35",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Luke 3:35",
      "text": "του σερουχ του ραγαυ του φαλεκ του εβερ του σαλα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.36",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 36,
      "referenceLabel": "Luke 3:36",
      "text": "του καιναν του αρφαξαδ του σημ του νωε του λαμεχ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.37",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 37,
      "referenceLabel": "Luke 3:37",
      "text": "του μαθουσαλα του ενωχ του ιαρεδ του μαλελεηλ του καιναν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.3.38",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 3,
      "verseNumber": 38,
      "referenceLabel": "Luke 3:38",
      "text": "του ενως του σηθ του αδαμ του θεου",
      "paragraphStart": false
    }
  ]
}
