{
  "chapter": {
    "id": "ant1904:luke.1",
    "translationId": "ant1904",
    "bookSlug": "luke",
    "chapterNumber": 1,
    "referenceLabel": "Luke 1",
    "summary": "Source text for Luke 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:luke.1.1",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Luke 1:1",
      "text": "επειδηπερ πολλοι επεχειρησαν αναταξασθαι διηγησιν περι των πεπληροφορημενων εν ημιν πραγματων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:luke.1.2",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Luke 1:2",
      "text": "καθως παρεδοσαν ημιν οι απ αρχης αυτοπται και υπηρεται γενομενοι του λογου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.3",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Luke 1:3",
      "text": "εδοξεν καμοι παρηκολουθηκοτι ανωθεν πασιν ακριβως καθεξης σοι γραψαι κρατιστε θεοφιλε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.4",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Luke 1:4",
      "text": "ινα επιγνως περι ων κατηχηθης λογων την ασφαλειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.5",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Luke 1:5",
      "text": "εγενετο εν ταις ημεραις ηρωδου του βασιλεως της ιουδαιας ιερευς τις ονοματι ζαχαριας εξ εφημεριας αβια και η γυνη αυτου εκ των θυγατερων ααρων και το ονομα αυτης ελισαβετ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.6",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Luke 1:6",
      "text": "ησαν δε δικαιοι αμφοτεροι ενωπιον του θεου πορευομενοι εν πασαις ταις εντολαις και δικαιωμασιν του κυριου αμεμπτοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.7",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Luke 1:7",
      "text": "και ουκ ην αυτοις τεκνον καθοτι η ελισαβετ ην στειρα και αμφοτεροι προβεβηκοτες εν ταις ημεραις αυτων ησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.8",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Luke 1:8",
      "text": "εγενετο δε εν τω ιερατευειν αυτον εν τη ταξει της εφημεριας αυτου εναντι του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.9",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Luke 1:9",
      "text": "κατα το εθος της ιερατειας ελαχεν του θυμιασαι εισελθων εις τον ναον του κυριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.10",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Luke 1:10",
      "text": "και παν το πληθος ην του λαου προσευχομενον εξω τη ωρα του θυμιαματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.11",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Luke 1:11",
      "text": "ωφθη δε αυτω αγγελος κυριου εστως εκ δεξιων του θυσιαστηριου του θυμιαματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.12",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Luke 1:12",
      "text": "και εταραχθη ζαχαριας ιδων και φοβος επεπεσεν επ αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.13",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Luke 1:13",
      "text": "ειπεν δε προς αυτον ο αγγελος μη φοβου ζαχαρια διοτι εισηκουσθη η δεησις σου και η γυνη σου ελισαβετ γεννησει υιον σοι και καλεσεις το ονομα αυτου ιωαννην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.14",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Luke 1:14",
      "text": "και εσται χαρα σοι και αγαλλιασις και πολλοι επι τη γεννησει αυτου χαρησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.15",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Luke 1:15",
      "text": "εσται γαρ μεγας ενωπιον του κυριου και οινον και σικερα ου μη πιη και πνευματος αγιου πλησθησεται ετι εκ κοιλιας μητρος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.16",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Luke 1:16",
      "text": "και πολλους των υιων ισραηλ επιστρεψει επι κυριον τον θεον αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.17",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Luke 1:17",
      "text": "και αυτος προελευσεται ενωπιον αυτου εν πνευματι και δυναμει ηλιου επιστρεψαι καρδιας πατερων επι τεκνα και απειθεις εν φρονησει δικαιων ετοιμασαι κυριω λαον κατεσκευασμενον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.18",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Luke 1:18",
      "text": "και ειπεν ζαχαριας προς τον αγγελον κατα τι γνωσομαι τουτο εγω γαρ ειμι πρεσβυτης και η γυνη μου προβεβηκυια εν ταις ημεραις αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.19",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Luke 1:19",
      "text": "και αποκριθεις ο αγγελος ειπεν αυτω εγω ειμι γαβριηλ ο παρεστηκως ενωπιον του θεου και απεσταλην λαλησαι προς σε και ευαγγελισασθαι σοι ταυτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.20",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Luke 1:20",
      "text": "και ιδου εση σιωπων και μη δυναμενος λαλησαι αχρι ης ημερας γενηται ταυτα ανθ ων ουκ επιστευσας τοις λογοις μου οιτινες πληρωθησονται εις τον καιρον αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.21",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Luke 1:21",
      "text": "και ην ο λαος προσδοκων τον ζαχαριαν και εθαυμαζον εν τω χρονιζειν αυτον εν τω ναω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.22",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Luke 1:22",
      "text": "εξελθων δε ουκ ηδυνατο λαλησαι αυτοις και επεγνωσαν οτι οπτασιαν εωρακεν εν τω ναω και αυτος ην διανευων αυτοις και διεμενεν κωφος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.23",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Luke 1:23",
      "text": "και εγενετο ως επλησθησαν αι ημεραι της λειτουργιας αυτου απηλθεν εις τον οικον αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.24",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Luke 1:24",
      "text": "μετα δε ταυτας τας ημερας συνελαβεν ελισαβετ η γυνη αυτου και περιεκρυβεν εαυτην μηνας πεντε λεγουσα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.25",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Luke 1:25",
      "text": "οτι ουτως μοι πεποιηκεν ο κυριος εν ημεραις αις επειδεν αφελειν το ονειδος μου εν ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.26",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Luke 1:26",
      "text": "εν δε τω μηνι τω εκτω απεσταλη ο αγγελος γαβριηλ υπο του θεου εις πολιν της γαλιλαιας η ονομα ναζαρετ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.27",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Luke 1:27",
      "text": "προς παρθενον μεμνηστευμενην ανδρι ω ονομα ιωσηφ εξ οικου δαυιδ και το ονομα της παρθενου μαριαμ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.28",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Luke 1:28",
      "text": "και εισελθων ο αγγελος προς αυτην ειπεν χαιρε κεχαριτωμενη ο κυριος μετα σου ευλογημενη συ εν γυναιξιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.29",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Luke 1:29",
      "text": "η δε ιδουσα διεταραχθη επι τω λογω αυτου και διελογιζετο ποταπος ειη ο ασπασμος ουτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.30",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Luke 1:30",
      "text": "και ειπεν ο αγγελος αυτη μη φοβου μαριαμ ευρες γαρ χαριν παρα τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.31",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Luke 1:31",
      "text": "και ιδου συλληψη εν γαστρι και τεξη υιον και καλεσεις το ονομα αυτου ιησουν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.32",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Luke 1:32",
      "text": "ουτος εσται μεγας και υιος υψιστου κληθησεται και δωσει αυτω κυριος ο θεος τον θρονον δαυιδ του πατρος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.33",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Luke 1:33",
      "text": "και βασιλευσει επι τον οικον ιακωβ εις τους αιωνας και της βασιλειας αυτου ουκ εσται τελος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.34",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Luke 1:34",
      "text": "ειπεν δε μαριαμ προς τον αγγελον πως εσται μοι τουτο επει ανδρα ου γινωσκω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.35",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Luke 1:35",
      "text": "και αποκριθεις ο αγγελος ειπεν αυτη πνευμα αγιον επελευσεται επι σε και δυναμις υψιστου επισκιασει σοι διο και το γεννωμενον αγιον κληθησεται υιος θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.36",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Luke 1:36",
      "text": "και ιδου ελισαβετ η συγγενης σου και αυτη συνειληφυια υιον εν γηρει αυτης και ουτος μην εκτος εστιν αυτη τη καλουμενη στειρα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.37",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Luke 1:37",
      "text": "οτι ουκ αδυνατησει παρα τω θεω παν ρημα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.38",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Luke 1:38",
      "text": "ειπεν δε μαριαμ ιδου η δουλη κυριου γενοιτο μοι κατα το ρημα σου και απηλθεν απ αυτης ο αγγελος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.39",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Luke 1:39",
      "text": "αναστασα δε μαριαμ εν ταις ημεραις ταυταις επορευθη εις την ορεινην μετα σπουδης εις πολιν ιουδα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.40",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Luke 1:40",
      "text": "και εισηλθεν εις τον οικον ζαχαριου και ησπασατο την ελισαβετ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.41",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "Luke 1:41",
      "text": "και εγενετο ως ηκουσεν η ελισαβετ τον ασπασμον της μαριας εσκιρτησεν το βρεφος εν τη κοιλια αυτης και επλησθη πνευματος αγιου η ελισαβετ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.42",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "Luke 1:42",
      "text": "και ανεφωνησεν φωνη μεγαλη και ειπεν ευλογημενη συ εν γυναιξιν και ευλογημενος ο καρπος της κοιλιας σου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.43",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "Luke 1:43",
      "text": "και ποθεν μοι τουτο ινα ελθη η μητηρ του κυριου μου προς με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.44",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "Luke 1:44",
      "text": "ιδου γαρ ως εγενετο η φωνη του ασπασμου σου εις τα ωτα μου εσκιρτησεν το βρεφος εν αγαλλιασει εν τη κοιλια μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.45",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "Luke 1:45",
      "text": "και μακαρια η πιστευσασα οτι εσται τελειωσις τοις λελαλημενοις αυτη παρα κυριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.46",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "Luke 1:46",
      "text": "και ειπεν μαριαμ μεγαλυνει η ψυχη μου τον κυριον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.47",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "Luke 1:47",
      "text": "και ηγαλλιασεν το πνευμα μου επι τω θεω τω σωτηρι μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.48",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "Luke 1:48",
      "text": "οτι επεβλεψεν επι την ταπεινωσιν της δουλης αυτου ιδου γαρ απο του νυν μακαριουσιν με πασαι αι γενεαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.49",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "Luke 1:49",
      "text": "οτι εποιησεν μοι μεγαλεια ο δυνατος και αγιον το ονομα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.50",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "Luke 1:50",
      "text": "και το ελεος αυτου εις γενεας γενεων τοις φοβουμενοις αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.51",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "Luke 1:51",
      "text": "εποιησεν κρατος εν βραχιονι αυτου διεσκορπισεν υπερηφανους διανοια καρδιας αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.52",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "Luke 1:52",
      "text": "καθειλεν δυναστας απο θρονων και υψωσεν ταπεινους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.53",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "Luke 1:53",
      "text": "πεινωντας ενεπλησεν αγαθων και πλουτουντας εξαπεστειλεν κενους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.54",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "Luke 1:54",
      "text": "αντελαβετο ισραηλ παιδος αυτου μνησθηναι ελεους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.55",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 55,
      "referenceLabel": "Luke 1:55",
      "text": "καθως ελαλησεν προς τους πατερας ημων τω αβρααμ και τω σπερματι αυτου εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.56",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 56,
      "referenceLabel": "Luke 1:56",
      "text": "εμεινεν δε μαριαμ συν αυτη ωσει μηνας τρεις και υπεστρεψεν εις τον οικον αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.57",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 57,
      "referenceLabel": "Luke 1:57",
      "text": "τη δε ελισαβετ επλησθη ο χρονος του τεκειν αυτην και εγεννησεν υιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.58",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 58,
      "referenceLabel": "Luke 1:58",
      "text": "και ηκουσαν οι περιοικοι και οι συγγενεις αυτης οτι εμεγαλυνεν κυριος το ελεος αυτου μετ αυτης και συνεχαιρον αυτη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.59",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 59,
      "referenceLabel": "Luke 1:59",
      "text": "και εγενετο εν τη ογδοη ημερα ηλθον περιτεμειν το παιδιον και εκαλουν αυτο επι τω ονοματι του πατρος αυτου ζαχαχαριαν σιχ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.60",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 60,
      "referenceLabel": "Luke 1:60",
      "text": "και αποκριθεισα η μητηρ αυτου ειπεν ουχι αλλα κληθησεται ιωαννης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.61",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 61,
      "referenceLabel": "Luke 1:61",
      "text": "και ειπον προς αυτην οτι ουδεις εστιν εν τη συγγενεια σου ος καλειται τω ονοματι τουτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.62",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 62,
      "referenceLabel": "Luke 1:62",
      "text": "ενενευον δε τω πατρι αυτου το τι αν θελοι καλεισθαι αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.63",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 63,
      "referenceLabel": "Luke 1:63",
      "text": "και αιτησας πινακιδιον εγραψεν λεγων ιωαννης εστιν το ονομα αυτου και εθαυμασαν παντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.64",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 64,
      "referenceLabel": "Luke 1:64",
      "text": "ανεωχθη δε το στομα αυτου παραχρημα και η γλωσσα αυτου και ελαλει ευλογων τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.65",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 65,
      "referenceLabel": "Luke 1:65",
      "text": "και εγενετο επι παντας φοβος τους περιοικουντας αυτους και εν ολη τη ορεινη της ιουδαιας διελαλειτο παντα τα ρηματα ταυτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.66",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 66,
      "referenceLabel": "Luke 1:66",
      "text": "και εθεντο παντες οι ακουσαντες εν τη καρδια αυτων λεγοντες τι αρα το παιδιον τουτο εσται και χειρ κυριου ην μετ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.67",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 67,
      "referenceLabel": "Luke 1:67",
      "text": "και ζαχαριας ο πατηρ αυτου επλησθη πνευματος αγιου και προεφητευσεν λεγων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.68",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 68,
      "referenceLabel": "Luke 1:68",
      "text": "ευλογητος κυριος ο θεος του ισραηλ οτι επεσκεψατο και εποιησεν λυτρωσιν τω λαω αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.69",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 69,
      "referenceLabel": "Luke 1:69",
      "text": "και ηγειρεν κερας σωτηριας ημιν εν τω οικω δαυιδ του παιδος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.70",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 70,
      "referenceLabel": "Luke 1:70",
      "text": "καθως ελαλησεν δια στοματος των αγιων των απ αιωνος προφητων αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.71",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 71,
      "referenceLabel": "Luke 1:71",
      "text": "σωτηριαν εξ εχθρων ημων και εκ χειρος παντων των μισουντων ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.72",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 72,
      "referenceLabel": "Luke 1:72",
      "text": "ποιησαι ελεος μετα των πατερων ημων και μνησθηναι διαθηκης αγιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.73",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 73,
      "referenceLabel": "Luke 1:73",
      "text": "ορκον ον ωμοσεν προς αβρααμ τον πατερα ημων του δουναι ημιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.74",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 74,
      "referenceLabel": "Luke 1:74",
      "text": "αφοβως εκ χειρος των εχθρων ημων ρυσθεντας λατρευειν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.75",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 75,
      "referenceLabel": "Luke 1:75",
      "text": "εν οσιοτητι και δικαιοσυνη ενωπιον αυτου πασας τας ημερας της ζωης ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.76",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 76,
      "referenceLabel": "Luke 1:76",
      "text": "και συ παιδιον προφητης υψιστου κληθηση προπορευση γαρ προ προσωπου κυριου ετοιμασαι οδους αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.77",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 77,
      "referenceLabel": "Luke 1:77",
      "text": "του δουναι γνωσιν σωτηριας τω λαω αυτου εν αφεσει αμαρτιων αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.78",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 78,
      "referenceLabel": "Luke 1:78",
      "text": "δια σπλαγχνα ελεους θεου ημων εν οις επεσκεψατο ημας ανατολη εξ υψους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.79",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 79,
      "referenceLabel": "Luke 1:79",
      "text": "επιφαναι τοις εν σκοτει και σκια θανατου καθημενοις του κατευθυναι τους ποδας ημων εις οδον ειρηνης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.1.80",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 1,
      "verseNumber": 80,
      "referenceLabel": "Luke 1:80",
      "text": "το δε παιδιον ηυξανεν και εκραταιουτο πνευματι και ην εν ταις ερημοις εως ημερας αναδειξεως αυτου προς τον ισραηλ",
      "paragraphStart": false
    }
  ]
}
