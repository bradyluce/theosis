{
  "chapter": {
    "id": "ant1904:luke.24",
    "translationId": "ant1904",
    "bookSlug": "luke",
    "chapterNumber": 24,
    "referenceLabel": "Luke 24",
    "summary": "Source text for Luke 24 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:luke.24.1",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Luke 24:1",
      "text": "τη δε μια των σαββατων ορθρου βαθεος ηλθον επι το μνημα φερουσαι α ητοιμασαν αρωματα και τινες συν αυταις",
      "paragraphStart": true
    },
    {
      "id": "ant1904:luke.24.2",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Luke 24:2",
      "text": "ευρον δε τον λιθον αποκεκυλισμενον απο του μνημειου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.3",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Luke 24:3",
      "text": "και εισελθουσαι ουχ ευρον το σωμα του κυριου ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.4",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Luke 24:4",
      "text": "και εγενετο εν τω διαπορεισθαι αυτας περι τουτου και ιδου ανδρες δυο επεστησαν αυταις εν εσθησεσιν αστραπτουσαις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.5",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Luke 24:5",
      "text": "εμφοβων δε γενομενων αυτων και κλινουσων το προσωπον εις την γην ειπον προς αυτας τι ζητειτε τον ζωντα μετα των νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.6",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Luke 24:6",
      "text": "ουκ εστιν ωδε αλλ ηγερθη μνησθητε ως ελαλησεν υμιν ετι ων εν τη γαλιλαια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.7",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Luke 24:7",
      "text": "λεγων οτι δει τον υιον του ανθρωπου παραδοθηναι εις χειρας ανθρωπων αμαρτωλων και σταυρωθηναι και τη τριτη ημερα αναστηναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.8",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Luke 24:8",
      "text": "και εμνησθησαν των ρηματων αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.9",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Luke 24:9",
      "text": "και υποστρεψασαι απο του μνημειου απηγγειλαν ταυτα παντα τοις ενδεκα και πασιν τοις λοιποις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.10",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Luke 24:10",
      "text": "ησαν δε η μαγδαληνη μαρια και ιωαννα και μαρια ιακωβου και αι λοιπαι συν αυταις αι ελεγον προς τους αποστολους ταυτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.11",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 11,
      "referenceLabel": "Luke 24:11",
      "text": "και εφανησαν ενωπιον αυτων ωσει ληρος τα ρηματα αυτων και ηπιστουν αυταις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.12",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 12,
      "referenceLabel": "Luke 24:12",
      "text": "ο δε πετρος αναστας εδραμεν επι το μνημειον και παρακυψας βλεπει τα οθονια κειμενα μονα και απηλθεν προς εαυτον θαυμαζων το γεγονος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.13",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 13,
      "referenceLabel": "Luke 24:13",
      "text": "και ιδου δυο εξ αυτων ησαν πορευομενοι εν αυτη τη ημερα εις κωμην απεχουσαν σταδιους εξηκοντα απο ιερουσαλημ η ονομα εμμαους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.14",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 14,
      "referenceLabel": "Luke 24:14",
      "text": "και αυτοι ωμιλουν προς αλληλους περι παντων των συμβεβηκοτων τουτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.15",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 15,
      "referenceLabel": "Luke 24:15",
      "text": "και εγενετο εν τω ομιλειν αυτους και συζητειν και αυτος ο ιησους εγγισας συνεπορευετο αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.16",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 16,
      "referenceLabel": "Luke 24:16",
      "text": "οι δε οφθαλμοι αυτων εκρατουντο του μη επιγνωναι αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.17",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 17,
      "referenceLabel": "Luke 24:17",
      "text": "ειπεν δε προς αυτους τινες οι λογοι ουτοι ους αντιβαλλετε προς αλληλους περιπατουντες και εστε σκυθρωποι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.18",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 18,
      "referenceLabel": "Luke 24:18",
      "text": "αποκριθεις δε ο εις ω ονομα κλεοπας ειπεν προς αυτον συ μονος παροικεις εν ιερουσαλημ και ουκ εγνως τα γενομενα εν αυτη εν ταις ημεραις ταυταις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.19",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 19,
      "referenceLabel": "Luke 24:19",
      "text": "και ειπεν αυτοις ποια οι δε ειπον αυτω τα περι ιησου του ναζωραιου ος εγενετο ανηρ προφητης δυνατος εν εργω και λογω εναντιον του θεου και παντος του λαου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.20",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 20,
      "referenceLabel": "Luke 24:20",
      "text": "οπως τε παρεδωκαν αυτον οι αρχιερεις και οι αρχοντες ημων εις κριμα θανατου και εσταυρωσαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.21",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 21,
      "referenceLabel": "Luke 24:21",
      "text": "ημεις δε ηλπιζομεν οτι αυτος εστιν ο μελλων λυτρουσθαι τον ισραηλ αλλα γε συν πασιν τουτοις τριτην ταυτην ημεραν αγει σημερον αφ ου ταυτα εγενετο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.22",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 22,
      "referenceLabel": "Luke 24:22",
      "text": "αλλα και γυναικες τινες εξ ημων εξεστησαν ημας γενομεναι ορθριαι επι το μνημειον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.23",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 23,
      "referenceLabel": "Luke 24:23",
      "text": "και μη ευρουσαι το σωμα αυτου ηλθον λεγουσαι και οπτασιαν αγγελων εωρακεναι οι λεγουσιν αυτον ζην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.24",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 24,
      "referenceLabel": "Luke 24:24",
      "text": "και απηλθον τινες των συν ημιν επι το μνημειον και ευρον ουτως καθως και αι γυναικες ειπον αυτον δε ουκ ειδον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.25",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 25,
      "referenceLabel": "Luke 24:25",
      "text": "και αυτος ειπεν προς αυτους ω ανοητοι και βραδεις τη καρδια του πιστευειν επι πασιν οις ελαλησαν οι προφηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.26",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 26,
      "referenceLabel": "Luke 24:26",
      "text": "ουχι ταυτα εδει παθειν τον χριστον και εισελθειν εις την δοξαν αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.27",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 27,
      "referenceLabel": "Luke 24:27",
      "text": "και αρξαμενος απο μωυσεως και απο παντων των προφητων διηρμηνευεν αυτοις εν πασαις ταις γραφαις τα περι εαυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.28",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 28,
      "referenceLabel": "Luke 24:28",
      "text": "και ηγγισαν εις την κωμην ου επορευοντο και αυτος προσεποιειτο πορρωτερω πορευεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.29",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 29,
      "referenceLabel": "Luke 24:29",
      "text": "και παρεβιασαντο αυτον λεγοντες μεινον μεθ ημων οτι προς εσπεραν εστιν και κεκλικεν η ημερα και εισηλθεν του μειναι συν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.30",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 30,
      "referenceLabel": "Luke 24:30",
      "text": "και εγενετο εν τω κατακλιθηναι αυτον μετ αυτων λαβων τον αρτον ευλογησεν και κλασας επεδιδου αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.31",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 31,
      "referenceLabel": "Luke 24:31",
      "text": "αυτων δε διηνοιχθησαν οι οφθαλμοι και επεγνωσαν αυτον και αυτος αφαντος εγενετο απ αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.32",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 32,
      "referenceLabel": "Luke 24:32",
      "text": "και ειπον προς αλληλους ουχι η καρδια ημων καιομενη ην εν ημιν ως ελαλει ημιν εν τη οδω και ως διηνοιγεν ημιν τας γραφας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.33",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 33,
      "referenceLabel": "Luke 24:33",
      "text": "και ανασταντες αυτη τη ωρα υπεστρεψαν εις ιερουσαλημ και ευρον συνηθροισμενους τους ενδεκα και τους συν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.34",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 34,
      "referenceLabel": "Luke 24:34",
      "text": "λεγοντας οτι ηγερθη ο κυριος οντως και ωφθη σιμωνι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.35",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 35,
      "referenceLabel": "Luke 24:35",
      "text": "και αυτοι εξηγουντο τα εν τη οδω και ως εγνωσθη αυτοις εν τη κλασει του αρτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.36",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 36,
      "referenceLabel": "Luke 24:36",
      "text": "ταυτα δε αυτων λαλουντων αυτος ο ιησους εστη εν μεσω αυτων και λεγει αυτοις ειρηνη υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.37",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 37,
      "referenceLabel": "Luke 24:37",
      "text": "πτοηθεντες δε και εμφοβοι γενομενοι εδοκουν πνευμα θεωρειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.38",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 38,
      "referenceLabel": "Luke 24:38",
      "text": "και ειπεν αυτοις τι τεταραγμενοι εστε και διατι διαλογισμοι αναβαινουσιν εν ταις καρδιαις υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.39",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 39,
      "referenceLabel": "Luke 24:39",
      "text": "ιδετε τας χειρας μου και τους ποδας μου οτι αυτος εγω ειμι ψηλαφησατε με και ιδετε οτι πνευμα σαρκα και οστεα ουκ εχει καθως εμε θεωρειτε εχοντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.40",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 40,
      "referenceLabel": "Luke 24:40",
      "text": "και τουτο ειπων επεδειξεν αυτοις τας χειρας και τους ποδας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.41",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 41,
      "referenceLabel": "Luke 24:41",
      "text": "ετι δε απιστουντων αυτων απο της χαρας και θαυμαζοντων ειπεν αυτοις εχετε τι βρωσιμον ενθαδε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.42",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 42,
      "referenceLabel": "Luke 24:42",
      "text": "οι δε επεδωκαν αυτω ιχθυος οπτου μερος και απο μελισσιου κηριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.43",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 43,
      "referenceLabel": "Luke 24:43",
      "text": "και λαβων ενωπιον αυτων εφαγεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.44",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 44,
      "referenceLabel": "Luke 24:44",
      "text": "ειπεν δε αυτοις ουτοι οι λογοι ους ελαλησα προς υμας ετι ων συν υμιν οτι δει πληρωθηναι παντα τα γεγραμμενα εν τω νομω μωυσεως και προφηταις και ψαλμοις περι εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.45",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 45,
      "referenceLabel": "Luke 24:45",
      "text": "τοτε διηνοιξεν αυτων τον νουν του συνιεναι τας γραφας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.46",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 46,
      "referenceLabel": "Luke 24:46",
      "text": "και ειπεν αυτοις οτι ουτως γεγραπται και ουτως εδει παθειν τον χριστον και αναστηναι εκ νεκρων τη τριτη ημερα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.47",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 47,
      "referenceLabel": "Luke 24:47",
      "text": "και κηρυχθηναι επι τω ονοματι αυτου μετανοιαν και αφεσιν αμαρτιων εις παντα τα εθνη αρξαμενον απο ιερουσαλημ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.48",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 48,
      "referenceLabel": "Luke 24:48",
      "text": "υμεις δε εστε μαρτυρες τουτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.49",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 49,
      "referenceLabel": "Luke 24:49",
      "text": "και ιδου εγω αποστελλω την επαγγελιαν του πατρος μου εφ υμας υμεις δε καθισατε εν τη πολει ιερουσαλημ εως ου ενδυσησθε δυναμιν εξ υψους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.50",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 50,
      "referenceLabel": "Luke 24:50",
      "text": "εξηγαγεν δε αυτους εξω εως εις βηθανιαν και επαρας τας χειρας αυτου ευλογησεν αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.51",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 51,
      "referenceLabel": "Luke 24:51",
      "text": "και εγενετο εν τω ευλογειν αυτον αυτους διεστη απ αυτων και ανεφερετο εις τον ουρανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.52",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 52,
      "referenceLabel": "Luke 24:52",
      "text": "και αυτοι προσκυνησαντες αυτον υπεστρεψαν εις ιερουσαλημ μετα χαρας μεγαλης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.24.53",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 24,
      "verseNumber": 53,
      "referenceLabel": "Luke 24:53",
      "text": "και ησαν δια παντος εν τω ιερω αινουντες και ευλογουντες τον θεον αμην",
      "paragraphStart": false
    }
  ]
}
