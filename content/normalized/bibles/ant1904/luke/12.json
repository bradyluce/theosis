{
  "chapter": {
    "id": "ant1904:luke.12",
    "translationId": "ant1904",
    "bookSlug": "luke",
    "chapterNumber": 12,
    "referenceLabel": "Luke 12",
    "summary": "Source text for Luke 12 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:luke.12.1",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Luke 12:1",
      "text": "εν οις επισυναχθεισων των μυριαδων του οχλου ως καταπατειν αλληλους ηρξατο λεγειν προς τους μαθητας αυτου πρωτον προσεχετε εαυτοις απο της ζυμης των φαρισαιων ητις εστιν υποκρισις",
      "paragraphStart": true
    },
    {
      "id": "ant1904:luke.12.2",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Luke 12:2",
      "text": "ουδεν δε συγκεκαλυμμενον εστιν ο ουκ αποκαλυφθησεται και κρυπτον ο ου γνωσθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.3",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Luke 12:3",
      "text": "ανθ ων οσα εν τη σκοτια ειπατε εν τω φωτι ακουσθησεται και ο προς το ους ελαλησατε εν τοις ταμειοις κηρυχθησεται επι των δωματων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.4",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Luke 12:4",
      "text": "λεγω δε υμιν τοις φιλοις μου μη φοβηθητε απο των αποκτεννοντων το σωμα και μετα ταυτα μη εχοντων περισσοτερον τι ποιησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.5",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Luke 12:5",
      "text": "υποδειξω δε υμιν τινα φοβηθητε φοβηθητε τον μετα το αποκτειναι εχοντα εξουσιαν εμβαλειν εις την γεενναν ναι λεγω υμιν τουτον φοβηθητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.6",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Luke 12:6",
      "text": "ουχι πεντε στρουθια πωλειται ασσαριων δυο και εν εξ αυτων ουκ εστιν επιλελησμενον ενωπιον του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.7",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Luke 12:7",
      "text": "αλλα και αι τριχες της κεφαλης υμων πασαι ηριθμηνται μη ουν φοβεισθε πολλων στρουθιων διαφερετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.8",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Luke 12:8",
      "text": "λεγω δε υμιν πας ος αν ομολογηση εν εμοι εμπροσθεν των ανθρωπων και ο υιος του ανθρωπου ομολογησει εν αυτω εμπροσθεν των αγγελων του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.9",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Luke 12:9",
      "text": "ο δε αρνησαμενος με ενωπιον των ανθρωπων απαρνηθησεται ενωπιον των αγγελων του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.10",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Luke 12:10",
      "text": "και πας ος ερει λογον εις τον υιον του ανθρωπου αφεθησεται αυτω τω δε εις το αγιον πνευμα βλασφημησαντι ουκ αφεθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.11",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Luke 12:11",
      "text": "οταν δε προσφερωσιν υμας επι τας συναγωγας και τας αρχας και τας εξουσιας μη μεριμνατε πως η τι απολογησησθε η τι ειπητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.12",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Luke 12:12",
      "text": "το γαρ αγιον πνευμα διδαξει υμας εν αυτη τη ωρα α δει ειπειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.13",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Luke 12:13",
      "text": "ειπεν δε τις αυτω εκ του οχλου διδασκαλε ειπε τω αδελφω μου μερισασθαι την κληρονομιαν μετ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.14",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Luke 12:14",
      "text": "ο δε ειπεν αυτω ανθρωπε τις με κατεστησεν δικαστην η μεριστην εφ υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.15",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Luke 12:15",
      "text": "ειπεν δε προς αυτους ορατε και φυλασσεσθε απο πασης πλεονεξιας οτι ουκ εν τω περισσευειν τινι η ζωη αυτου εστιν εκ των υπαρχοντων αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.16",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Luke 12:16",
      "text": "ειπεν δε παραβολην προς αυτους λεγων ανθρωπου τινος πλουσιου ευφορησεν η χωρα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.17",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Luke 12:17",
      "text": "και διελογιζετο εν εαυτω λεγων τι ποιησω οτι ουκ εχω που συναξω τους καρπους μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.18",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Luke 12:18",
      "text": "και ειπεν τουτο ποιησω καθελω μου τας αποθηκας και μειζονας οικοδομησω και συναξω εκει παντα τα γενηματα μου και τα αγαθα μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.19",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Luke 12:19",
      "text": "και ερω τη ψυχη μου ψυχη εχεις πολλα αγαθα κειμενα εις ετη πολλα αναπαυου φαγε πιε ευφραινου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.20",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Luke 12:20",
      "text": "ειπεν δε αυτω ο θεος αφρον ταυτη τη νυκτι την ψυχην σου απαιτουσιν απο σου α δε ητοιμασας τινι εσται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.21",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Luke 12:21",
      "text": "ουτως ο θησαυριζων εαυτω και μη εις θεον πλουτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.22",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Luke 12:22",
      "text": "ειπεν δε προς τους μαθητας αυτου δια τουτο λεγω υμιν μη μεριμνατε τη ψυχη υμων τι φαγητε μηδε τω σωματι υμων τι ενδυσησθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.23",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Luke 12:23",
      "text": "ουχι η ψυχη πλειον εστιν της τροφης και το σωμα του ενδυματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.24",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Luke 12:24",
      "text": "κατανοησατε τους κορακας οτι ου σπειρουσιν ουδε θεριζουσιν οις ουκ εστιν ταμειον ουδε αποθηκη και ο θεος τρεφει αυτους ποσω μαλλον υμεις διαφερετε των πετεινων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.25",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Luke 12:25",
      "text": "τις δε εξ υμων μεριμνων δυναται προσθειναι επι την ηλικιαν αυτου πηχυν ενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.26",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Luke 12:26",
      "text": "ει ουν ουτε ελαχιστον δυνασθε τι περι των λοιπων μεριμνατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.27",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Luke 12:27",
      "text": "κατανοησατε τα κρινα πως αυξανει ου κοπια ουδε νηθει λεγω δε υμιν ουδε σολομων εν παση τη δοξη αυτου περιεβαλετο ως εν τουτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.28",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Luke 12:28",
      "text": "ει δε τον χορτον του αγρου σημερον οντα και αυριον εις κλιβανον βαλλομενον ο θεος ουτως αμφιεννυσιν ποσω μαλλον υμας ολιγοπιστοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.29",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Luke 12:29",
      "text": "και υμεις μη ζητειτε τι φαγητε και τι πιητε και μη μετεωριζεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.30",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "Luke 12:30",
      "text": "ταυτα γαρ παντα τα εθνη του κοσμου επιζητει υμων δε ο πατηρ οιδεν οτι χρηζετε τουτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.31",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "Luke 12:31",
      "text": "πλην ζητειτε την βασιλειαν του θεου και ταυτα [παντα] προστεθησεται υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.32",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "Luke 12:32",
      "text": "μη φοβου το μικρον ποιμνιον οτι ευδοκησεν ο πατηρ υμων δουναι υμιν την βασιλειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.33",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "Luke 12:33",
      "text": "πωλησατε τα υπαρχοντα υμων και δοτε ελεημοσυνην ποιησατε εαυτοις βαλλαντια μη παλαιουμενα θησαυρον ανεκλειπτον εν τοις ουρανοις οπου κλεπτης ουκ εγγιζει ουδε σης διαφθειρει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.34",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "Luke 12:34",
      "text": "οπου γαρ εστιν ο θησαυρος υμων εκει και η καρδια υμων εσται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.35",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "Luke 12:35",
      "text": "εστωσαν υμων αι οσφυες περιεζωσμεναι και οι λυχνοι καιομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.36",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "Luke 12:36",
      "text": "και υμεις ομοιοι ανθρωποις προσδεχομενοις τον κυριον εαυτων ποτε αναλυσει εκ των γαμων ινα ελθοντος και κρουσαντος ευθεως ανοιξωσιν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.37",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 37,
      "referenceLabel": "Luke 12:37",
      "text": "μακαριοι οι δουλοι εκεινοι ους ελθων ο κυριος ευρησει γρηγορουντας αμην λεγω υμιν οτι περιζωσεται και ανακλινει αυτους και παρελθων διακονησει αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.38",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 38,
      "referenceLabel": "Luke 12:38",
      "text": "και εαν ελθη εν τη δευτερα φυλακη και εν τη τριτη φυλακη ελθη και ευρη ουτως μακαριοι εισιν οι δουλοι εκεινοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.39",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 39,
      "referenceLabel": "Luke 12:39",
      "text": "τουτο δε γινωσκετε οτι ει ηδει ο οικοδεσποτης ποια ωρα ο κλεπτης ερχεται εγρηγορησεν αν και ουκ αν αφηκεν διορυγηναι τον οικον αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.40",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 40,
      "referenceLabel": "Luke 12:40",
      "text": "και υμεις ουν γινεσθε ετοιμοι οτι η ωρα ου δοκειτε ο υιος του ανθρωπου ερχεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.41",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 41,
      "referenceLabel": "Luke 12:41",
      "text": "ειπεν δε αυτω ο πετρος κυριε προς ημας την παραβολην ταυτην λεγεις η και προς παντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.42",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 42,
      "referenceLabel": "Luke 12:42",
      "text": "ειπεν δε ο κυριος τις αρα εστιν ο πιστος οικονομος και φρονιμος ον καταστησει ο κυριος επι της θεραπειας αυτου του διδοναι εν καιρω το σιτομετριον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.43",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 43,
      "referenceLabel": "Luke 12:43",
      "text": "μακαριος ο δουλος εκεινος ον ελθων ο κυριος αυτου ευρησει ουτως ποιουντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.44",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 44,
      "referenceLabel": "Luke 12:44",
      "text": "αληθως λεγω υμιν οτι επι πασιν τοις υπαρχουσιν αυτου καταστησει αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.45",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 45,
      "referenceLabel": "Luke 12:45",
      "text": "εαν δε ειπη ο δουλος εκεινος εν τη καρδια αυτου χρονιζει ο κυριος μου ερχεσθαι και αρξηται τυπτειν τους παιδας και τας παιδισκας εσθιειν τε και πινειν και μεθυσκεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.46",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 46,
      "referenceLabel": "Luke 12:46",
      "text": "ηξει ο κυριος του δουλου εκεινου εν ημερα η ου προσδοκα και εν ωρα η ου γινωσκει και διχοτομησει αυτον και το μερος αυτου μετα των απιστων θησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.47",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 47,
      "referenceLabel": "Luke 12:47",
      "text": "εκεινος δε ο δουλος ο γνους το θελημα του κυριου εαυτου και μη ετοιμασας μηδε ποιησας προς το θελημα αυτου δαρησεται πολλας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.48",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 48,
      "referenceLabel": "Luke 12:48",
      "text": "ο δε μη γνους ποιησας δε αξια πληγων δαρησεται ολιγας παντι δε ω εδοθη πολυ πολυ ζητηθησεται παρ αυτου και ω παρεθεντο πολυ περισσοτερον αιτησουσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.49",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 49,
      "referenceLabel": "Luke 12:49",
      "text": "πυρ ηλθον βαλειν επι την γην και τι θελω ει ηδη ανηφθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.50",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 50,
      "referenceLabel": "Luke 12:50",
      "text": "βαπτισμα δε εχω βαπτισθηναι και πως συνεχομαι εως ου τελεσθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.51",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 51,
      "referenceLabel": "Luke 12:51",
      "text": "δοκειτε οτι ειρηνην παρεγενομην δουναι εν τη γη ουχι λεγω υμιν αλλ η διαμερισμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.12.52",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 12,
      "verseNumber": 52,
      "referenceLabel": "Luke 12:52",
      "text": "εσονται γαρ απο του νυν πεντε εν οικω ενι διαμεμερισμενοι τρεις επι δυσιν και δυο επι τρισιν",
