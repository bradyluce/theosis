{
  "chapter": {
    "id": "ant1904:luke.17",
    "translationId": "ant1904",
    "bookSlug": "luke",
    "chapterNumber": 17,
    "referenceLabel": "Luke 17",
    "summary": "Source text for Luke 17 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:luke.17.1",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Luke 17:1",
      "text": "ελεγεν δε και προς τους μαθητας αυτου ανενδεκτον εστιν του μη ελθειν τα σκανδαλα ουαι δε δι ου ερχεται",
      "paragraphStart": true
    },
    {
      "id": "ant1904:luke.17.2",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Luke 17:2",
      "text": "λυσιτελει αυτω ει λιθος μυλικος περικειται περι τον τραχηλον αυτου και ερριπται εις την θαλασσαν η ινα σκανδαλιση ενα των μικρων τουτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.3",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Luke 17:3",
      "text": "προσεχετε εαυτοις εαν δε αμαρτη εις σε ο αδελφος σου επιτιμησον αυτω και εαν μετανοηση αφες αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.4",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Luke 17:4",
      "text": "και εαν επτακις της ημερας αμαρτη εις σε και επτακις της ημερας επιστρεψη [προς σε] λεγων μετανοω αφησεις αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.5",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Luke 17:5",
      "text": "και ειπον οι αποστολοι τω κυριω προσθες ημιν πιστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.6",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Luke 17:6",
      "text": "ειπεν δε ο κυριος ει εχετε πιστιν ως κοκκον σιναπεως ελεγετε αν τη συκαμινω ταυτη εκριζωθητι και φυτευθητι εν τη θαλασση και υπηκουσεν αν υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.7",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Luke 17:7",
      "text": "τις δε εξ υμων δουλον εχων αροτριωντα η ποιμαινοντα ος εισελθοντι εκ του αγρου ερει ευθεως παρελθων αναπεσε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.8",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Luke 17:8",
      "text": "αλλ ουχι ερει αυτω ετοιμασον τι δειπνησω και περιζωσαμενος διακονει μοι εως φαγω και πιω και μετα ταυτα φαγεσαι και πιεσαι συ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.9",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Luke 17:9",
      "text": "μη χαριν εχει τω δουλω εκεινω οτι εποιησεν τα διαταχθεντα ου δοκω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.10",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Luke 17:10",
      "text": "ουτως και υμεις οταν ποιησητε παντα τα διαταχθεντα υμιν λεγετε οτι δουλοι αχρειοι εσμεν οτι ο ωφειλομεν ποιησαι πεποιηκαμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.11",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Luke 17:11",
      "text": "και εγενετο εν τω πορευεσθαι αυτον εις ιερουσαλημ και αυτος διηρχετο δια μεσου σαμαρειας και γαλιλαιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.12",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Luke 17:12",
      "text": "και εισερχομενου αυτου εις τινα κωμην απηντησαν αυτω δεκα λεπροι ανδρες οι εστησαν πορρωθεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.13",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Luke 17:13",
      "text": "και αυτοι ηραν φωνην λεγοντες ιησου επιστατα ελεησον ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.14",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Luke 17:14",
      "text": "και ιδων ειπεν αυτοις πορευθεντες επιδειξατε εαυτους τοις ιερευσιν και εγενετο εν τω υπαγειν αυτους εκαθαρισθησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.15",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Luke 17:15",
      "text": "εις δε εξ αυτων ιδων οτι ιαθη υπεστρεψεν μετα φωνης μεγαλης δοξαζων τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.16",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Luke 17:16",
      "text": "και επεσεν επι προσωπον παρα τους ποδας αυτου ευχαριστων αυτω και αυτος ην σαμαρειτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.17",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Luke 17:17",
      "text": "αποκριθεις δε ο ιησους ειπεν ουχι οι δεκα εκαθαρισθησαν οι δε εννεα που",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.18",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Luke 17:18",
      "text": "ουχ ευρεθησαν υποστρεψαντες δουναι δοξαν τω θεω ει μη ο αλλογενης ουτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.19",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Luke 17:19",
      "text": "και ειπεν αυτω αναστας πορευου η πιστις σου σεσωκεν σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.20",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Luke 17:20",
      "text": "επερωτηθεις δε υπο των φαρισαιων ποτε ερχεται η βασιλεια του θεου απεκριθη αυτοις και ειπεν ουκ ερχεται η βασιλεια του θεου μετα παρατηρησεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.21",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Luke 17:21",
      "text": "ουδε ερουσιν ιδου ωδε η ιδου εκει ιδου γαρ η βασιλεια του θεου εντος υμων εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.22",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Luke 17:22",
      "text": "ειπεν δε προς τους μαθητας ελευσονται ημεραι οτε επιθυμησετε μιαν των ημερων του υιου του ανθρωπου ιδειν και ουκ οψεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.23",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Luke 17:23",
      "text": "και ερουσιν υμιν ιδου ωδε ιδου εκει μη απελθητε μηδε διωξητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.24",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Luke 17:24",
      "text": "ωσπερ γαρ η αστραπη αστραπτουσα εκ της υπ ουρανον εις την υπ ουρανον λαμπει ουτως εσται και ο υιος του ανθρωπου εν τη ημερα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.25",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Luke 17:25",
      "text": "πρωτον δε δει αυτον πολλα παθειν και αποδοκιμασθηναι απο της γενεας ταυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.26",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Luke 17:26",
      "text": "και καθως εγενετο εν ταις ημεραις νωε ουτως εσται και εν ταις ημεραις του υιου του ανθρωπου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.27",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Luke 17:27",
      "text": "ησθιον επινον εγαμουν εξεγαμιζοντο αχρι ης ημερας εισηλθεν νωε εις την κιβωτον και ηλθεν ο κατακλυσμος και απωλεσεν απαντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.28",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Luke 17:28",
      "text": "ομοιως και ως εγενετο εν ταις ημεραις λωτ ησθιον επινον ηγοραζον επωλουν εφυτευον ωκοδομουν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.29",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 29,
      "referenceLabel": "Luke 17:29",
      "text": "η δε ημερα εξηλθεν λωτ απο σοδομων εβρεξεν πυρ και θειον απ ουρανου και απωλεσεν απαντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.30",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 30,
      "referenceLabel": "Luke 17:30",
      "text": "κατα τα αυτα εσται η ημερα ο υιος του ανθρωπου αποκαλυπτεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.31",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 31,
      "referenceLabel": "Luke 17:31",
      "text": "εν εκεινη τη ημερα ος εσται επι του δωματος και τα σκευη αυτου εν τη οικια μη καταβατω αραι αυτα και ο εν τω αγρω ομοιως μη επιστρεψατω εις τα οπισω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.32",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 32,
      "referenceLabel": "Luke 17:32",
      "text": "μνημονευετε της γυναικος λωτ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.33",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 33,
      "referenceLabel": "Luke 17:33",
      "text": "ος εαν ζητηση την ψυχην αυτου σωσαι απολεσει αυτην και ος εαν απολεση αυτην ζωογονησει αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.34",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 34,
      "referenceLabel": "Luke 17:34",
      "text": "λεγω υμιν ταυτη τη νυκτι δυο εσονται επι κλινης μιας εις παραληφθησεται και ο ετερος αφεθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.35",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 35,
      "referenceLabel": "Luke 17:35",
      "text": "δυο εσονται αληθουσαι επι το αυτο μια παραληφθησεται και η ετερα αφεθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.36",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 36,
      "referenceLabel": "Luke 17:36",
      "text": "δυο εν τω αγρω εις παραληφθησεται και ο ετερος αφεθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:luke.17.37",
      "translationId": "ant1904",
      "bookSlug": "luke",
      "chapterNumber": 17,
      "verseNumber": 37,
      "referenceLabel": "Luke 17:37",
      "text": "και αποκριθεντες λεγουσιν αυτω που κυριε ο δε ειπεν αυτοις οπου το σωμα εκει επισυναχθησονται [και] οι αετοι",
      "paragraphStart": false
    }
  ]
}
