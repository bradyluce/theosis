{
  "chapter": {
    "id": "ant1904:first-corinthians.5",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 5,
    "referenceLabel": "1 Corinthians 5",
    "summary": "Source text for 1 Corinthians 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.5.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 5:1",
      "text": "ολως ακουεται εν υμιν πορνεια και τοιαυτη πορνεια ητις ουδε εν τοις εθνεσιν ονομαζεται ωστε γυναικα τινα του πατρος εχειν",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.5.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 5:2",
      "text": "και υμεις πεφυσιωμενοι εστε και ουχι μαλλον επενθησατε ινα εξαρθη εκ μεσου υμων ο το εργον τουτο ποιησας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 5:3",
      "text": "εγω μεν γαρ ως απων τω σωματι παρων δε τω πνευματι ηδη κεκρικα ως παρων τον ουτως τουτο κατεργασαμενον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 5:4",
      "text": "εν τω ονοματι του κυριου ημων ιησου χριστου συναχθεντων υμων και του εμου πνευματος συν τη δυναμει του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 5:5",
      "text": "παραδουναι τον τοιουτον τω σατανα εις ολεθρον της σαρκος ινα το πνευμα σωθη εν τη ημερα του κυριου ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 5:6",
      "text": "ου καλον το καυχημα υμων ουκ οιδατε οτι μικρα ζυμη ολον το φυραμα ζυμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 5:7",
      "text": "εκκαθαρατε [ουν] την παλαιαν ζυμην ινα ητε νεον φυραμα καθως εστε αζυμοι και γαρ το πασχα ημων υπερ ημων ετυθη χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 5:8",
      "text": "ωστε εορταζωμεν μη εν ζυμη παλαια μηδε εν ζυμη κακιας και πονηριας αλλ εν αζυμοις ειλικρινειας και αληθειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 5:9",
      "text": "εγραψα υμιν εν τη επιστολη μη συναναμιγνυσθαι πορνοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 5:10",
      "text": "και ου παντως τοις πορνοις του κοσμου τουτου η τοις πλεονεκταις η αρπαξιν η ειδωλολατραις επει οφειλετε αρα εκ του κοσμου εξελθειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 5:11",
      "text": "νυν δε εγραψα υμιν μη συναναμιγνυσθαι εαν τις αδελφος ονομαζομενος η πορνος η πλεονεκτης η ειδωλολατρης η λοιδορος η μεθυσος η αρπαξ τω τοιουτω μηδε συνεσθιειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 5:12",
      "text": "τι γαρ μοι και τους εξω κρινειν ουχι τους εσω υμεις κρινετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.5.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 5:13",
      "text": "τους δε εξω ο θεος κρινει και εξαρειτε τον πονηρον εξ υμων αυτων",
      "paragraphStart": false
    }
  ]
}
