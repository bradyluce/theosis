{
  "chapter": {
    "id": "ant1904:first-corinthians.6",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 6,
    "referenceLabel": "1 Corinthians 6",
    "summary": "Source text for 1 Corinthians 6 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.6.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 6:1",
      "text": "τολμα τις υμων πραγμα εχων προς τον ετερον κρινεσθαι επι των αδικων και ουχι επι των αγιων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.6.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 6:2",
      "text": "ουκ οιδατε οτι οι αγιοι τον κοσμον κρινουσιν και ει εν υμιν κρινεται ο κοσμος αναξιοι εστε κριτηριων ελαχιστων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 6:3",
      "text": "ουκ οιδατε οτι αγγελους κρινουμεν μητι γε βιωτικα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 6:4",
      "text": "βιωτικα μεν ουν κριτηρια εαν εχητε τους εξουθενημενους εν τη εκκλησια τουτους καθιζετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 6:5",
      "text": "προς εντροπην υμιν λεγω ουτως ουκ ενι εν υμιν σοφος ουδε εις ος δυνησεται διακριναι ανα μεσον του αδελφου αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 6:6",
      "text": "αλλα αδελφος μετα αδελφου κρινεται και τουτο επι απιστων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 6:7",
      "text": "ηδη μεν ουν ολως ηττημα υμιν εστιν οτι κριματα εχετε μεθ εαυτων διατι ουχι μαλλον αδικεισθε διατι ουχι μαλλον αποστερεισθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 6:8",
      "text": "αλλα υμεις αδικειτε και αποστερειτε και ταυτα αδελφους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 6:9",
      "text": "η ουκ οιδατε οτι αδικοι βασιλειαν θεου ου κληρονομησουσιν μη πλανασθε ουτε πορνοι ουτε ειδωλολατραι ουτε μοιχοι ουτε μαλακοι ουτε αρσενοκοιται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 6:10",
      "text": "ουτε πλεονεκται ουτε κλεπται ουτε μεθυσοι ου λοιδοροι ουχ αρπαγες βασιλειαν θεου ου κληρονομησουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 6:11",
      "text": "και ταυτα τινες ητε αλλα απελουσασθε αλλα ηγιασθητε αλλα εδικαιωθητε εν τω ονοματι του κυριου ιησου και εν τω πνευματι του θεου ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 6:12",
      "text": "παντα μοι εξεστιν αλλ ου παντα συμφερει παντα μοι εξεστιν αλλ ουκ εγω εξουσιασθησομαι υπο τινος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 6:13",
      "text": "τα βρωματα τη κοιλια και η κοιλια τοις βρωμασιν ο δε θεος και ταυτην και ταυτα καταργησει το δε σωμα ου τη πορνεια αλλα τω κυριω και ο κυριος τω σωματι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.14",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 6:14",
      "text": "ο δε θεος και τον κυριον ηγειρεν και ημας εξεγερει δια της δυναμεως αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.15",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 6:15",
      "text": "ουκ οιδατε οτι τα σωματα υμων μελη χριστου εστιν αρας ουν τα μελη του χριστου ποιησω πορνης μελη μη γενοιτο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.16",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 6:16",
      "text": "[η] ουκ οιδατε οτι ο κολλωμενος τη πορνη εν σωμα εστιν εσονται γαρ φησιν οι δυο εις σαρκα μιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.17",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 6:17",
      "text": "ο δε κολλωμενος τω κυριω εν πνευμα εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.18",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 6:18",
      "text": "φευγετε την πορνειαν παν αμαρτημα ο εαν ποιηση ανθρωπος εκτος του σωματος εστιν ο δε πορνευων εις το ιδιον σωμα αμαρτανει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.19",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 6:19",
      "text": "η ουκ οιδατε οτι το σωμα υμων ναος του εν υμιν αγιου πνευματος εστιν ου εχετε απο θεου και ουκ εστε εαυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.6.20",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 6:20",
      "text": "ηγορασθητε γαρ τιμης δοξασατε δη τον θεον εν τω σωματι υμων και εν τω πνευματι υμων ατινα εστιν του θεου",
      "paragraphStart": false
    }
  ]
}
