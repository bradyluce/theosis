{
  "chapter": {
    "id": "ant1904:first-corinthians.15",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 15,
    "referenceLabel": "1 Corinthians 15",
    "summary": "Source text for 1 Corinthians 15 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.15.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 15:1",
      "text": "γνωριζω δε υμιν αδελφοι το ευαγγελιον ο ευηγγελισαμην υμιν ο και παρελαβετε εν ω και εστηκατε",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.15.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 15:2",
      "text": "δι ου και σωζεσθε τινι λογω ευηγγελισαμην υμιν ει κατεχετε εκτος ει μη εικη επιστευσατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 15:3",
      "text": "παρεδωκα γαρ υμιν εν πρωτοις ο και παρελαβον οτι χριστος απεθανεν υπερ των αμαρτιων ημων κατα τας γραφας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 15:4",
      "text": "και οτι εταφη και οτι εγηγερται τη τριτη ημερα κατα τας γραφας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 15:5",
      "text": "και οτι ωφθη κηφα ειτα τοις δωδεκα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 15:6",
      "text": "επειτα ωφθη επανω πεντακοσιοις αδελφοις εφαπαξ εξ ων οι πλειους μενουσιν εως αρτι τινες δε και εκοιμηθησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 15:7",
      "text": "επειτα ωφθη ιακωβω ειτα τοις αποστολοις πασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 15:8",
      "text": "εσχατον δε παντων ωσπερει τω εκτρωματι ωφθη καμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 15:9",
      "text": "εγω γαρ ειμι ο ελαχιστος των αποστολων ος ουκ ειμι ικανος καλεισθαι αποστολος διοτι εδιωξα την εκκλησιαν του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 15:10",
      "text": "χαριτι δε θεου ειμι ο ειμι και η χαρις αυτου η εις εμε ου κενη εγενηθη αλλα περισσοτερον αυτων παντων εκοπιασα ουκ εγω δε αλλ η χαρις του θεου η συν εμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 15:11",
      "text": "ειτε ουν εγω ειτε εκεινοι ουτως κηρυσσομεν και ουτως επιστευσατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 15:12",
      "text": "ει δε χριστος κηρυσσεται οτι εκ νεκρων εγηγερται πως λεγουσιν τινες εν υμιν οτι αναστασις νεκρων ουκ εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 15:13",
      "text": "ει δε αναστασις νεκρων ουκ εστιν ουδε χριστος εγηγερται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.14",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 15:14",
      "text": "ει δε χριστος ουκ εγηγερται κενον αρα το κηρυγμα ημων κενη δε και η πιστις υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.15",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 15:15",
      "text": "ευρισκομεθα δε και ψευδομαρτυρες του θεου οτι εμαρτυρησαμεν κατα του θεου οτι ηγειρεν τον χριστον ον ουκ ηγειρεν ειπερ αρα νεκροι ουκ εγειρονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.16",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 15:16",
      "text": "ει γαρ νεκροι ουκ εγειρονται ουδε χριστος εγηγερται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.17",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 15:17",
      "text": "ει δε χριστος ουκ εγηγερται ματαια η πιστις υμων ετι εστε εν ταις αμαρτιαις υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.18",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 15:18",
      "text": "αρα και οι κοιμηθεντες εν χριστω απωλοντο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.19",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 15:19",
      "text": "ει εν τη ζωη ταυτη ηλπικοτες εσμεν εν χριστω μονον ελεεινοτεροι παντων ανθρωπων εσμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.20",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 15:20",
      "text": "νυνι δε χριστος εγηγερται εκ νεκρων απαρχη των κεκοιμημενων εγενετο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.21",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 15:21",
      "text": "επειδη γαρ δι ανθρωπου ο θανατος και δι ανθρωπου αναστασις νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.22",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 15:22",
      "text": "ωσπερ γαρ εν τω αδαμ παντες αποθνησκουσιν ουτως και εν τω χριστω παντες ζωοποιηθησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.23",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 15:23",
      "text": "εκαστος δε εν τω ιδιω ταγματι απαρχη χριστος επειτα οι χριστου εν τη παρουσια αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.24",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 15:24",
      "text": "ειτα το τελος οταν παραδω την βασιλειαν τω θεω και πατρι οταν καταργηση πασαν αρχην και πασαν εξουσιαν και δυναμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.25",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 15:25",
      "text": "δει γαρ αυτον βασιλευειν αχρι ου αν θη παντας τους εχθρους υπο τους ποδας αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.26",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 15:26",
      "text": "εσχατος εχθρος καταργειται ο θανατος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.27",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 15:27",
      "text": "παντα γαρ υπεταξεν υπο τους ποδας αυτου οταν δε ειπη οτι παντα υποτετακται δηλον οτι εκτος του υποταξαντος αυτω τα παντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.28",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 15:28",
      "text": "οταν δε υποταγη αυτω τα παντα τοτε και αυτος ο υιος υποταγησεται τω υποταξαντι αυτω τα παντα ινα η ο θεος τα παντα εν πασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.29",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 15:29",
      "text": "επει τι ποιησουσιν οι βαπτιζομενοι υπερ των νεκρων ει ολως νεκροι ουκ εγειρονται τι και βαπτιζονται υπερ των νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.30",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 15:30",
      "text": "τι και ημεις κινδυνευομεν πασαν ωραν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.31",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 15:31",
      "text": "καθ ημεραν αποθνησκω νη την υμετεραν καυχησιν ην εχω εν χριστω ιησου τω κυριω ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.32",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 15:32",
      "text": "ει κατα ανθρωπον εθηριομαχησα εν εφεσω τι μοι το οφελος ει νεκροι ουκ εγειρονται φαγωμεν και πιωμεν αυριον γαρ αποθνησκομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.33",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 15:33",
      "text": "μη πλανασθε φθειρουσιν ηθη χρηστα ομιλιαι κακαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.34",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 15:34",
      "text": "εκνηψατε δικαιως και μη αμαρτανετε αγνωσιαν γαρ θεου τινες εχουσιν προς εντροπην υμιν λεγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.35",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "1 Corinthians 15:35",
      "text": "αλλ ερει τις πως εγειρονται οι νεκροι ποιω δε σωματι ερχονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.36",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "1 Corinthians 15:36",
      "text": "αφρον συ ο σπειρεις ου ζωοποιειται εαν μη αποθανη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.37",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "1 Corinthians 15:37",
      "text": "και ο σπειρεις ου το σωμα το γενησομενον σπειρεις αλλα γυμνον κοκκον ει τυχοι σιτου η τινος των λοιπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.38",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "1 Corinthians 15:38",
      "text": "ο δε θεος αυτω διδωσιν σωμα καθως ηθελησεν και εκαστω των σπερματων το ιδιον σωμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.39",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "1 Corinthians 15:39",
      "text": "ου πασα σαρξ η αυτη σαρξ αλλα αλλη μεν ανθρωπων αλλη δε σαρξ κτηνων αλλη δε ιχθυων αλλη δε πετεινων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.40",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "1 Corinthians 15:40",
      "text": "και σωματα επουρανια και σωματα επιγεια αλλ ετερα μεν η των επουρανιων δοξα ετερα δε η των επιγειων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.41",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 41,
      "referenceLabel": "1 Corinthians 15:41",
      "text": "αλλη δοξα ηλιου και αλλη δοξα σεληνης και αλλη δοξα αστερων αστηρ γαρ αστερος διαφερει εν δοξη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.42",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 42,
      "referenceLabel": "1 Corinthians 15:42",
      "text": "ουτως και η αναστασις των νεκρων σπειρεται εν φθορα εγειρεται εν αφθαρσια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.43",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 43,
      "referenceLabel": "1 Corinthians 15:43",
      "text": "σπειρεται εν ατιμια εγειρεται εν δοξη σπειρεται εν ασθενεια εγειρεται εν δυναμει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.44",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 44,
      "referenceLabel": "1 Corinthians 15:44",
      "text": "σπειρεται σωμα ψυχικον εγειρεται σωμα πνευματικον εστιν σωμα ψυχικον και εστιν σωμα πνευματικον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.45",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 45,
      "referenceLabel": "1 Corinthians 15:45",
      "text": "ουτως και γεγραπται εγενετο ο πρωτος ανθρωπος αδαμ εις ψυχην ζωσαν ο εσχατος αδαμ εις πνευμα ζωοποιουν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.46",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 46,
      "referenceLabel": "1 Corinthians 15:46",
      "text": "αλλ ου πρωτον το πνευματικον αλλα το ψυχικον επειτα το πνευματικον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.47",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 47,
      "referenceLabel": "1 Corinthians 15:47",
      "text": "ο πρωτος ανθρωπος εκ γης χοικος ο δευτερος ανθρωπος ο κυριος εξ ουρανου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.48",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 48,
      "referenceLabel": "1 Corinthians 15:48",
      "text": "οιος ο χοικος τοιουτοι και οι χοικοι και οιος ο επουρανιος τοιουτοι και οι επουρανιοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.49",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 49,
      "referenceLabel": "1 Corinthians 15:49",
      "text": "και καθως εφορεσαμεν την εικονα του χοικου φορεσομεν και την εικονα του επουρανιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.50",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 50,
      "referenceLabel": "1 Corinthians 15:50",
      "text": "τουτο δε φημι αδελφοι οτι σαρξ και αιμα βασιλειαν θεου κληρονομησαι ου δυνανται ουδε η φθορα την αφθαρσιαν κληρονομει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.51",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 51,
      "referenceLabel": "1 Corinthians 15:51",
      "text": "ιδου μυστηριον υμιν λεγω παντες μεν ου κοιμηθησομεθα παντες δε αλλαγησομεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.15.52",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 15,
      "verseNumber": 52,
      "referenceLabel": "1 Corinthians 15:52",
      "text": "εν ατομω εν ριπη οφθαλμου εν τη εσχατη σαλπιγγι σαλπισει γαρ και οι νεκροι εγερθησονται αφθαρτοι και ημεις αλλαγησομεθα",
      "paragraphStart": false
    },
