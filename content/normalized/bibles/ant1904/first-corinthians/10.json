{
  "chapter": {
    "id": "ant1904:first-corinthians.10",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 10,
    "referenceLabel": "1 Corinthians 10",
    "summary": "Source text for 1 Corinthians 10 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.10.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 10:1",
      "text": "ου θελω δε υμας αγνοειν αδελφοι οτι οι πατερες ημων παντες υπο την νεφελην ησαν και παντες δια της θαλασσης διηλθον",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.10.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 10:2",
      "text": "και παντες εις τον μωυσην εβαπτισαντο εν τη νεφελη και εν τη θαλασση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 10:3",
      "text": "και παντες το αυτο βρωμα πνευματικον εφαγον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 10:4",
      "text": "και παντες το αυτο πομα πνευματικον επιον επινον γαρ εκ πνευματικης ακολουθουσης πετρας η δε πετρα ην ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 10:5",
      "text": "αλλ ουκ εν τοις πλειοσιν αυτων ευδοκησεν ο θεος κατεστρωθησαν γαρ εν τη ερημω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 10:6",
      "text": "ταυτα δε τυποι ημων εγενηθησαν εις το μη ειναι ημας επιθυμητας κακων καθως κακεινοι επεθυμησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 10:7",
      "text": "μηδε ειδωλολατραι γινεσθε καθως τινες αυτων ως γεγραπται εκαθισεν ο λαος φαγειν και πιειν και ανεστησαν παιζειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 10:8",
      "text": "μηδε πορνευωμεν καθως τινες αυτων επορνευσαν και επεσον εν μια ημερα εικοσιτρεις χιλιαδες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 10:9",
      "text": "μηδε εκπειραζωμεν τον χριστον καθως και τινες αυτων επειρασαν και υπο των οφεων απωλοντο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 10:10",
      "text": "μηδε γογγυζετε καθως και τινες αυτων εγογγυσαν και απωλοντο υπο του ολοθρευτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 10:11",
      "text": "ταυτα δε παντα τυποι συνεβαινον εκεινοις εγραφη δε προς νουθεσιαν ημων εις ους τα τελη των αιωνων κατηντησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 10:12",
      "text": "ωστε ο δοκων εσταναι βλεπετω μη πεση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 10:13",
      "text": "πειρασμος υμας ουκ ειληφεν ει μη ανθρωπινος πιστος δε ο θεος ος ουκ εασει υμας πειρασθηναι υπερ ο δυνασθε αλλα ποιησει συν τω πειρασμω και την εκβασιν του δυνασθαι [υμας] υπενεγκειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.14",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 10:14",
      "text": "διοπερ αγαπητοι μου φευγετε απο της ειδωλολατριας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.15",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 10:15",
      "text": "ως φρονιμοις λεγω κρινατε υμεις ο φημι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.16",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 10:16",
      "text": "το ποτηριον της ευλογιας ο ευλογουμεν ουχι κοινωνια του αιματος του χριστου εστιν τον αρτον ον κλωμεν ουχι κοινωνια του σωματος του χριστου εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.17",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 10:17",
      "text": "οτι εις αρτος εν σωμα οι πολλοι εσμεν οι γαρ παντες εκ του ενος αρτου μετεχομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.18",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 10:18",
      "text": "βλεπετε τον ισραηλ κατα σαρκα ουχι οι εσθιοντες τας θυσιας κοινωνοι του θυσιαστηριου εισιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.19",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 10:19",
      "text": "τι ουν φημι οτι ειδωλον τι εστιν η οτι ειδωλοθυτον τι εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.20",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 10:20",
      "text": "αλλ οτι α θυει τα εθνη δαιμονιοις θυει και ου θεω ου θελω δε υμας κοινωνους των δαιμονιων γινεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.21",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 10:21",
      "text": "ου δυνασθε ποτηριον κυριου πινειν και ποτηριον δαιμονιων ου δυνασθε τραπεζης κυριου μετεχειν και τραπεζης δαιμονιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.22",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 10:22",
      "text": "η παραζηλουμεν τον κυριον μη ισχυροτεροι αυτου εσμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.23",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 10:23",
      "text": "παντα μοι εξεστιν αλλ ου παντα συμφερει παντα μοι εξεστιν αλλ ου παντα οικοδομει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.24",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 10:24",
      "text": "μηδεις το εαυτου ζητειτω αλλα το του ετερου εκαστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.25",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 10:25",
      "text": "παν το εν μακελλω πωλουμενον εσθιετε μηδεν ανακρινοντες δια την συνειδησιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.26",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 10:26",
      "text": "του γαρ κυριου η γη και το πληρωμα αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.27",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 10:27",
      "text": "ει δε τις καλει υμας των απιστων και θελετε πορευεσθαι παν το παρατιθεμενον υμιν εσθιετε μηδεν ανακρινοντες δια την συνειδησιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.28",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 10:28",
      "text": "εαν δε τις υμιν ειπη τουτο ειδωλοθυτον εστιν μη εσθιετε δι εκεινον τον μηνυσαντα και την συνειδησιν του γαρ κυριου η γη και το πληρωμα αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.29",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 10:29",
      "text": "συνειδησιν δε λεγω ουχι την εαυτου αλλα την του ετερου ινατι γαρ η ελευθερια μου κρινεται υπο αλλης συνειδησεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.30",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 10:30",
      "text": "ει εγω χαριτι μετεχω τι βλασφημουμαι υπερ ου εγω ευχαριστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.31",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 10:31",
      "text": "ειτε ουν εσθιετε ειτε πινετε ειτε τι ποιειτε παντα εις δοξαν θεου ποιειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.32",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 10:32",
      "text": "απροσκοποι γινεσθε και ιουδαιοις και ελλησιν και τη εκκλησια του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.10.33",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 10:33",
      "text": "καθως καγω παντα πασιν αρεσκω μη ζητων το εμαυτου συμφερον αλλα το των πολλων ινα σωθωσιν",
      "paragraphStart": false
    }
  ]
}
