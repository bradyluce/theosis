{
  "chapter": {
    "id": "ant1904:first-corinthians.7",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 7,
    "referenceLabel": "1 Corinthians 7",
    "summary": "Source text for 1 Corinthians 7 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.7.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 7:1",
      "text": "περι δε ων εγραψατε μοι καλον ανθρωπω γυναικος μη απτεσθαι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.7.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 7:2",
      "text": "δια δε τας πορνειας εκαστος την εαυτου γυναικα εχετω και εκαστη τον ιδιον ανδρα εχετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 7:3",
      "text": "τη γυναικι ο ανηρ την οφειλομενην ευνοιαν αποδιδοτω ομοιως δε και η γυνη τω ανδρι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 7:4",
      "text": "η γυνη του ιδιου σωματος ουκ εξουσιαζει αλλ ο ανηρ ομοιως δε και ο ανηρ του ιδιου σωματος ουκ εξουσιαζει αλλ η γυνη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 7:5",
      "text": "μη αποστερειτε αλληλους ει μη τι αν εκ συμφωνου προς καιρον ινα σχολαζητε τη νηστεια και τη προσευχη και παλιν επι το αυτο συνερχησθε ινα μη πειραζη υμας ο σατανας δια την ακρασιαν υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 7:6",
      "text": "τουτο δε λεγω κατα συγγνωμην ου κατ επιταγην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 7:7",
      "text": "θελω γαρ παντας ανθρωπους ειναι ως και εμαυτον αλλ εκαστος ιδιον χαρισμα εχει εκ θεου ος μεν ουτως ος δε ουτως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 7:8",
      "text": "λεγω δε τοις αγαμοις και ταις χηραις καλον αυτοις εστιν εαν μεινωσιν ως καγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 7:9",
      "text": "ει δε ουκ εγκρατευονται γαμησατωσαν κρεισσον γαρ εστιν γαμησαι η πυρουσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 7:10",
      "text": "τοις δε γεγαμηκοσιν παραγγελλω ουκ εγω αλλ ο κυριος γυναικα απο ανδρος μη χωρισθηναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 7:11",
      "text": "εαν δε και χωρισθη μενετω αγαμος η τω ανδρι καταλλαγητω και ανδρα γυναικα μη αφιεναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 7:12",
      "text": "τοις δε λοιποις εγω λεγω ουχ ο κυριος ει τις αδελφος γυναικα εχει απιστον και αυτη συνευδοκει οικειν μετ αυτου μη αφιετω αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 7:13",
      "text": "και γυνη ει τις εχει ανδρα απιστον και αυτος συνευδοκει οικειν μετ αυτης μη αφιετω αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.14",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 7:14",
      "text": "ηγιασται γαρ ο ανηρ ο απιστος εν τη γυναικι και ηγιασται η γυνη η απιστος εν τω ανδρι επει αρα τα τεκνα υμων ακαθαρτα εστιν νυν δε αγια εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.15",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 7:15",
      "text": "ει δε ο απιστος χωριζεται χωριζεσθω ου δεδουλωται ο αδελφος η η αδελφη εν τοις τοιουτοις εν δε ειρηνη κεκληκεν ημας ο θεος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.16",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 7:16",
      "text": "τι γαρ οιδας γυναι ει τον ανδρα σωσεις η τι οιδας ανερ ει την γυναικα σωσεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.17",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 7:17",
      "text": "ει μη εκαστω ως εμερισεν ο θεος εκαστον ως κεκληκεν ο κυριος ουτως περιπατειτω και ουτως εν ταις εκκλησιαις πασαις διατασσομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.18",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 7:18",
      "text": "περιτετμημενος τις εκληθη μη επισπασθω εν ακροβυστια τις εκληθη μη περιτεμνεσθω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.19",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 7:19",
      "text": "η περιτομη ουδεν εστιν και η ακροβυστια ουδεν εστιν αλλα τηρησις εντολων θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.20",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 7:20",
      "text": "εκαστος εν τη κλησει η εκληθη εν ταυτη μενετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.21",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 7:21",
      "text": "δουλος εκληθης μη σοι μελετω αλλ ει και δυνασαι ελευθερος γενεσθαι μαλλον χρησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.22",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 7:22",
      "text": "ο γαρ εν κυριω κληθεις δουλος απελευθερος κυριου εστιν ομοιως και ο ελευθερος κληθεις δουλος εστιν χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.23",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 7:23",
      "text": "τιμης ηγορασθητε μη γινεσθε δουλοι ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.24",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 7:24",
      "text": "εκαστος εν ω εκληθη αδελφοι εν τουτω μενετω παρα τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.25",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 7:25",
      "text": "περι δε των παρθενων επιταγην κυριου ουκ εχω γνωμην δε διδωμι ως ηλεημενος υπο κυριου πιστος ειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.26",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 7:26",
      "text": "νομιζω ουν τουτο καλον υπαρχειν δια την ενεστωσαν αναγκην οτι καλον ανθρωπω το ουτως ειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.27",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 7:27",
      "text": "δεδεσαι γυναικι μη ζητει λυσιν λελυσαι απο γυναικος μη ζητει γυναικα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.28",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 7:28",
      "text": "εαν δε και γημης ουχ ημαρτες και εαν γημη η παρθενος ουχ ημαρτεν θλιψιν δε τη σαρκι εξουσιν οι τοιουτοι εγω δε υμων φειδομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.29",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 7:29",
      "text": "τουτο δε φημι αδελφοι ο καιρος συνεσταλμενος το λοιπον εστιν ινα και οι εχοντες γυναικας ως μη εχοντες ωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.30",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 7:30",
      "text": "και οι κλαιοντες ως μη κλαιοντες και οι χαιροντες ως μη χαιροντες και οι αγοραζοντες ως μη κατεχοντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.31",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 7:31",
      "text": "και οι χρωμενοι τω κοσμω τουτω ως μη καταχρωμενοι παραγει γαρ το σχημα του κοσμου τουτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.32",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 7:32",
      "text": "θελω δε υμας αμεριμνους ειναι ο αγαμος μεριμνα τα του κυριου πως αρεσει τω κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.33",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 7:33",
      "text": "ο δε γαμησας μεριμνα τα του κοσμου πως αρεσει τη γυναικι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.34",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 7:34",
      "text": "μεμερισται [και] η γυνη και η παρθενος η αγαμος μεριμνα τα του κυριου ινα η αγια και σωματι και πνευματι η δε γαμησασα μεριμνα τα του κοσμου πως αρεσει τω ανδρι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.35",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "1 Corinthians 7:35",
      "text": "τουτο δε προς το υμων αυτων συμφερον λεγω ουχ ινα βροχον υμιν επιβαλω αλλα προς το ευσχημον και ευπαρεδρον τω κυριω απερισπαστως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.36",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "1 Corinthians 7:36",
      "text": "ει δε τις ασχημονειν επι την παρθενον αυτου νομιζει εαν η υπερακμος και ουτως οφειλει γινεσθαι ο θελει ποιειτω ουχ αμαρτανει γαμειτωσαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.37",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "1 Corinthians 7:37",
      "text": "ος δε εστηκεν εδραιος εν τη καρδια μη εχων αναγκην εξουσιαν δε εχει περι του ιδιου θεληματος και τουτο κεκρικεν εν τη καρδια αυτου του τηρειν την εαυτου παρθενον καλως ποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.38",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 38,
      "referenceLabel": "1 Corinthians 7:38",
      "text": "ωστε και ο εκγαμιζων καλως ποιει ο δε μη εκγαμιζων κρεισσον ποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.39",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 39,
      "referenceLabel": "1 Corinthians 7:39",
      "text": "γυνη δεδεται νομω εφ οσον χρονον ζη ο ανηρ αυτης εαν δε κοιμηθη ο ανηρ αυτης ελευθερα εστιν ω θελει γαμηθηναι μονον εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.7.40",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 7,
      "verseNumber": 40,
      "referenceLabel": "1 Corinthians 7:40",
      "text": "μακαριωτερα δε εστιν εαν ουτως μεινη κατα την εμην γνωμην δοκω δε καγω πνευμα θεου εχειν",
      "paragraphStart": false
    }
  ]
}
