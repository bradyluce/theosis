{
  "chapter": {
    "id": "ant1904:first-corinthians.8",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 8,
    "referenceLabel": "1 Corinthians 8",
    "summary": "Source text for 1 Corinthians 8 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.8.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 8:1",
      "text": "περι δε των ειδωλοθυτων οιδαμεν οτι παντες γνωσιν εχομεν η γνωσις φυσιοι η δε αγαπη οικοδομει",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.8.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 8:2",
      "text": "ει δε τις δοκει ειδεναι τι ουδεπω ουδεν εγνωκεν καθως δει γνωναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 8:3",
      "text": "ει δε τις αγαπα τον θεον ουτος εγνωσται υπ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 8:4",
      "text": "περι της βρωσεως ουν των ειδωλοθυτων οιδαμεν οτι ουδεν ειδωλον εν κοσμω και οτι ουδεις θεος ετερος ει μη εις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 8:5",
      "text": "και γαρ ειπερ εισιν λεγομενοι θεοι ειτε εν ουρανω ειτε επι της γης ωσπερ εισιν θεοι πολλοι και κυριοι πολλοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 8:6",
      "text": "αλλ ημιν εις θεος ο πατηρ εξ ου τα παντα και ημεις εις αυτον και εις κυριος ιησους χριστος δι ου τα παντα και ημεις δι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 8:7",
      "text": "αλλ ουκ εν πασιν η γνωσις τινες δε τη συνειδησει του ειδωλου εως αρτι ως ειδωλοθυτον εσθιουσιν και η συνειδησις αυτων ασθενης ουσα μολυνεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 8:8",
      "text": "βρωμα δε ημας ου παριστησιν τω θεω ουτε γαρ εαν φαγωμεν περισσευομεν ουτε εαν μη φαγωμεν υστερουμεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 8:9",
      "text": "βλεπετε δε μηπως η εξουσια υμων αυτη προσκομμα γενηται τοις ασθενουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 8:10",
      "text": "εαν γαρ τις ιδη σε τον εχοντα γνωσιν εν ειδωλειω κατακειμενον ουχι η συνειδησις αυτου ασθενους οντος οικοδομηθησεται εις το τα ειδωλοθυτα εσθιειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 8:11",
      "text": "και απολειται ο ασθενων αδελφος επι τη ση γνωσει δι ον χριστος απεθανεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 8:12",
      "text": "ουτως δε αμαρτανοντες εις τους αδελφους και τυπτοντες αυτων την συνειδησιν ασθενουσαν εις χριστον αμαρτανετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.8.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 8:13",
      "text": "διοπερ ει βρωμα σκανδαλιζει τον αδελφον μου ου μη φαγω κρεα εις τον αιωνα ινα μη τον αδελφον μου σκανδαλισω",
      "paragraphStart": false
    }
  ]
}
