{
  "chapter": {
    "id": "ant1904:first-corinthians.14",
    "translationId": "ant1904",
    "bookSlug": "first-corinthians",
    "chapterNumber": 14,
    "referenceLabel": "1 Corinthians 14",
    "summary": "Source text for 1 Corinthians 14 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-corinthians.14.1",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 14:1",
      "text": "διωκετε την αγαπην ζηλουτε δε τα πνευματικα μαλλον δε ινα προφητευητε",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-corinthians.14.2",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 14:2",
      "text": "ο γαρ λαλων γλωσση ουκ ανθρωποις λαλει αλλα τω θεω ουδεις γαρ ακουει πνευματι δε λαλει μυστηρια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.3",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 14:3",
      "text": "ο δε προφητευων ανθρωποις λαλει οικοδομην και παρακλησιν και παραμυθιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.4",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 14:4",
      "text": "ο λαλων γλωσση εαυτον οικοδομει ο δε προφητευων εκκλησιαν οικοδομει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.5",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 14:5",
      "text": "θελω δε παντας υμας λαλειν γλωσσαις μαλλον δε ινα προφητευητε μειζων γαρ ο προφητευων η ο λαλων γλωσσαις εκτος ει μη διερμηνευει ινα η εκκλησια οικοδομην λαβη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.6",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 14:6",
      "text": "νυνι δε αδελφοι εαν ελθω προς υμας γλωσσαις λαλων τι υμας ωφελησω εαν μη υμιν λαλησω η εν αποκαλυψει η εν γνωσει η εν προφητεια η εν διδαχη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.7",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 14:7",
      "text": "ομως τα αψυχα φωνην διδοντα ειτε αυλος ειτε κιθαρα εαν διαστολην τοις φθογγοις μη διδω πως γνωσθησεται το αυλουμενον η το κιθαριζομενον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.8",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 14:8",
      "text": "και γαρ εαν αδηλον φωνην σαλπιγξ δω τις παρασκευασεται εις πολεμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.9",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 14:9",
      "text": "ουτως και υμεις δια της γλωσσης εαν μη ευσημον λογον δωτε πως γνωσθησεται το λαλουμενον εσεσθε γαρ εις αερα λαλουντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.10",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 14:10",
      "text": "τοσαυτα ει τυχοι γενη φωνων εστιν εν κοσμω και ουδεν αυτων αφωνον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.11",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 14:11",
      "text": "εαν ουν μη ειδω την δυναμιν της φωνης εσομαι τω λαλουντι βαρβαρος και ο λαλων εν εμοι βαρβαρος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.12",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 14:12",
      "text": "ουτως και υμεις επει ζηλωται εστε πνευματων προς την οικοδομην της εκκλησιας ζητειτε ινα περισσευητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.13",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 14:13",
      "text": "διοπερ ο λαλων γλωσση προσευχεσθω ινα διερμηνευη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.14",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 14:14",
      "text": "εαν γαρ προσευχωμαι γλωσση το πνευμα μου προσευχεται ο δε νους μου ακαρπος εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.15",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 14:15",
      "text": "τι ουν εστιν προσευξομαι τω πνευματι προσευξομαι δε και τω νοι ψαλω τω πνευματι ψαλω δε και τω νοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.16",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 14:16",
      "text": "επει εαν ευλογησης τω πνευματι ο αναπληρων τον τοπον του ιδιωτου πως ερει το αμην επι τη ση ευχαριστια επειδη τι λεγεις ουκ οιδεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.17",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 14:17",
      "text": "συ μεν γαρ καλως ευχαριστεις αλλ ο ετερος ουκ οικοδομειται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.18",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 14:18",
      "text": "ευχαριστω τω θεω μου παντων υμων μαλλον γλωσσαις λαλων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.19",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 14:19",
      "text": "αλλ εν εκκλησια θελω πεντε λογους δια του νοος μου λαλησαι ινα και αλλους κατηχησω η μυριους λογους εν γλωσση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.20",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 14:20",
      "text": "αδελφοι μη παιδια γινεσθε ταις φρεσιν αλλα τη κακια νηπιαζετε ταις δε φρεσιν τελειοι γινεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.21",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 14:21",
      "text": "εν τω νομω γεγραπται οτι εν ετερογλωσσοις και εν χειλεσιν ετεροις λαλησω τω λαω τουτω και ουδ ουτως εισακουσονται μου λεγει κυριος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.22",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 14:22",
      "text": "ωστε αι γλωσσαι εις σημειον εισιν ου τοις πιστευουσιν αλλα τοις απιστοις η δε προφητεια ου τοις απιστοις αλλα τοις πιστευουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.23",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 14:23",
      "text": "εαν ουν συνελθη η εκκλησια ολη επι το αυτο και παντες γλωσσαις λαλωσιν εισελθωσιν δε ιδιωται η απιστοι ουκ ερουσιν οτι μαινεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.24",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 14:24",
      "text": "εαν δε παντες προφητευωσιν εισελθη δε τις απιστος η ιδιωτης ελεγχεται υπο παντων ανακρινεται υπο παντων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.25",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 14:25",
      "text": "και ουτως τα κρυπτα της καρδιας αυτου φανερα γινεται και ουτως πεσων επι προσωπον προσκυνησει τω θεω απαγγελλων οτι ο θεος οντως εν υμιν εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.26",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 14:26",
      "text": "τι ουν εστιν αδελφοι οταν συνερχησθε εκαστος υμων ψαλμον εχει διδαχην εχει γλωσσαν εχει αποκαλυψιν εχει ερμηνειαν εχει παντα προς οικοδομην γινεσθω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.27",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 14:27",
      "text": "ειτε γλωσση τις λαλει κατα δυο η το πλειστον τρεις και ανα μερος και εις διερμηνευετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.28",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "1 Corinthians 14:28",
      "text": "εαν δε μη η διερμηνευτης σιγατω εν εκκλησια εαυτω δε λαλειτω και τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.29",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "1 Corinthians 14:29",
      "text": "προφηται δε δυο η τρεις λαλειτωσαν και οι αλλοι διακρινετωσαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.30",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "1 Corinthians 14:30",
      "text": "εαν δε αλλω αποκακαλυφθη σιχ καθημενω ο πρωτος σιγατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.31",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "1 Corinthians 14:31",
      "text": "δυνασθε γαρ καθ ενα παντες προφητευειν ινα παντες μανθανωσιν και παντες παρακαλωνται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.32",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "1 Corinthians 14:32",
      "text": "και πνευματα προφητων προφηταις υποτασσεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.33",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "1 Corinthians 14:33",
      "text": "ου γαρ εστιν ακαταστασιας ο θεος αλλα ειρηνης ως εν πασαις ταις εκκλησιαις των αγιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.34",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "1 Corinthians 14:34",
      "text": "αι γυναικες υμων εν ταις εκκλησιαις σιγατωσαν ου γαρ επιτετραπται αυταις λαλειν αλλ υποτασσεσθαι καθως και ο νομος λεγει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.35",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "1 Corinthians 14:35",
      "text": "ει δε τι μαθειν θελουσιν εν οικω τους ιδιους ανδρας επερωτατωσαν αισχρον γαρ εστιν γυναιξιν εν εκκλησια λαλειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.36",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "1 Corinthians 14:36",
      "text": "η αφ υμων ο λογος του θεου εξηλθεν η εις υμας μονους κατηντησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.37",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 37,
      "referenceLabel": "1 Corinthians 14:37",
      "text": "ει τις δοκει προφητης ειναι η πνευματικος επιγινωσκετω α γραφω υμιν οτι του κυριου εισιν εντολαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.38",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 38,
      "referenceLabel": "1 Corinthians 14:38",
      "text": "ει δε τις αγνοει αγνοειτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.39",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 39,
      "referenceLabel": "1 Corinthians 14:39",
      "text": "ωστε αδελφοι ζηλουτε το προφητευειν και το λαλειν γλωσσαις μη κωλυετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-corinthians.14.40",
      "translationId": "ant1904",
      "bookSlug": "first-corinthians",
      "chapterNumber": 14,
      "verseNumber": 40,
      "referenceLabel": "1 Corinthians 14:40",
      "text": "παντα ευσχημονως και κατα ταξιν γινεσθω",
      "paragraphStart": false
    }
  ]
}
