{
  "chapter": {
    "id": "ant1904:titus.2",
    "translationId": "ant1904",
    "bookSlug": "titus",
    "chapterNumber": 2,
    "referenceLabel": "Titus 2",
    "summary": "Source text for Titus 2 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:titus.2.1",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Titus 2:1",
      "text": "συ δε λαλει α πρεπει τη υγιαινουση διδασκαλια",
      "paragraphStart": true
    },
    {
      "id": "ant1904:titus.2.2",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Titus 2:2",
      "text": "πρεσβυτας νηφαλιους ειναι σεμνους σωφρονας υγιαινοντας τη πιστει τη αγαπη τη υπομονη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.3",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Titus 2:3",
      "text": "πρεσβυτιδας ωσαυτως εν καταστηματι ιεροπρεπεις μη διαβολους μη οινω πολλω δεδουλωμενας καλοδιδασκαλους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.4",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Titus 2:4",
      "text": "ινα σωφρονιζωσιν τας νεας φιλανδρους ειναι φιλοτεκνους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.5",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Titus 2:5",
      "text": "σωφρονας αγνας οικουρους αγαθας υποτασσομενας τοις ιδιοις ανδρασιν ινα μη ο λογος του θεου βλασφημηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.6",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Titus 2:6",
      "text": "τους νεωτερους ωσαυτως παρακαλει σωφρονειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.7",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Titus 2:7",
      "text": "περι παντα σεαυτον παρεχομενος τυπον καλων εργων εν τη διδασκαλια αδιαφθοριαν σεμνοτητα αφθαρσιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.8",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Titus 2:8",
      "text": "λογον υγιη ακαταγνωστον ινα ο εξ εναντιας εντραπη μηδεν εχων περι ημων λεγειν φαυλον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.9",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Titus 2:9",
      "text": "δουλους ιδιοις δεσποταις υποτασσεσθαι εν πασιν ευαρεστους ειναι μη αντιλεγοντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.10",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Titus 2:10",
      "text": "μη νοσφιζομενους αλλα πιστιν πασαν ενδεικνυμενους αγαθην ινα την διδασκαλιαν του σωτηρος ημων θεου κοσμωσιν εν πασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.11",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Titus 2:11",
      "text": "επεφανη γαρ η χαρις του θεου η σωτηριος πασιν ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.12",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Titus 2:12",
      "text": "παιδευουσα ημας ινα αρνησαμενοι την ασεβειαν και τας κοσμικας επιθυμιας σωφρονως και δικαιως και ευσεβως ζησωμεν εν τω νυν αιωνι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.13",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Titus 2:13",
      "text": "προσδεχομενοι την μακαριαν ελπιδα και επιφανειαν της δοξης του μεγαλου θεου και σωτηρος ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.14",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Titus 2:14",
      "text": "ος εδωκεν εαυτον υπερ ημων ινα λυτρωσηται ημας απο πασης ανομιας και καθαριση εαυτω λαον περιουσιον ζηλωτην καλων εργων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.2.15",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Titus 2:15",
      "text": "ταυτα λαλει και παρακαλει και ελεγχε μετα πασης επιταγης μηδεις σου περιφρονειτω",
      "paragraphStart": false
    }
  ]
}
