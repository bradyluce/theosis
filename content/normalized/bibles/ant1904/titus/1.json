{
  "chapter": {
    "id": "ant1904:titus.1",
    "translationId": "ant1904",
    "bookSlug": "titus",
    "chapterNumber": 1,
    "referenceLabel": "Titus 1",
    "summary": "Source text for Titus 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:titus.1.1",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Titus 1:1",
      "text": "παυλος δουλος θεου αποστολος δε ιησου χριστου κατα πιστιν εκλεκτων θεου και επιγνωσιν αληθειας της κατ ευσεβειαν",
      "paragraphStart": true
    },
    {
      "id": "ant1904:titus.1.2",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Titus 1:2",
      "text": "επ ελπιδι ζωης αιωνιου ην επηγγειλατο ο αψευδης θεος προ χρονων αιωνιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.3",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Titus 1:3",
      "text": "εφανερωσεν δε καιροις ιδιοις τον λογον αυτου εν κηρυγματι ο επιστευθην εγω κατ επιταγην του σωτηρος ημων θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.4",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Titus 1:4",
      "text": "τιτω γνησιω τεκνω κατα κοινην πιστιν χαρις ελεος ειρηνη απο θεου πατρος και κυριου ιησου χριστου του σωτηρος ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.5",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Titus 1:5",
      "text": "τουτου χαριν κατελιπον σε εν κρητη ινα τα λειποντα επιδιορθωση και καταστησης κατα πολιν πρεσβυτερους ως εγω σοι διεταξαμην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.6",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Titus 1:6",
      "text": "ει τις εστιν ανεγκλητος μιας γυναικος ανηρ τεκνα εχων πιστα μη εν κατηγορια ασωτιας η ανυποτακτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.7",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Titus 1:7",
      "text": "δει γαρ τον επισκοπον ανεγκλητον ειναι ως θεου οικονομον μη αυθαδη μη οργιλον μη παροινον μη πληκτην μη αισχροκερδη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.8",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Titus 1:8",
      "text": "αλλα φιλοξενον φιλαγαθον σωφρονα δικαιον οσιον εγκρατη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.9",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Titus 1:9",
      "text": "αντεχομενον του κατα την διδαχην πιστου λογου ινα δυνατος η και παρακαλειν εν τη διδασκαλια τη υγιαινουση και τους αντιλεγοντας ελεγχειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.10",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Titus 1:10",
      "text": "εισιν γαρ πολλοι [και] ανυποτακτοι ματαιολογοι και φρεναπαται μαλιστα οι εκ περιτομης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.11",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Titus 1:11",
      "text": "ους δει επιστομιζειν οιτινες ολους οικους ανατρεπουσιν διδασκοντες α μη δει αισχρου κερδους χαριν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.12",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Titus 1:12",
      "text": "ειπεν τις εξ αυτων ιδιος αυτων προφητης κρητες αει ψευσται κακα θηρια γαστερες αργαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.13",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Titus 1:13",
      "text": "η μαρτυρια αυτη εστιν αληθης δι ην αιτιαν ελεγχε αυτους αποτομως ινα υγιαινωσιν εν τη πιστει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.14",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Titus 1:14",
      "text": "μη προσεχοντες ιουδαικοις μυθοις και εντολαις ανθρωπων αποστρεφομενων την αληθειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.15",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Titus 1:15",
      "text": "παντα [μεν] καθαρα τοις καθαροις τοις δε μεμιαμμενοις και απιστοις ουδεν καθαρον αλλα μεμιανται αυτων και ο νους και η συνειδησις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:titus.1.16",
      "translationId": "ant1904",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Titus 1:16",
      "text": "θεον ομολογουσιν ειδεναι τοις δε εργοις αρνουνται βδελυκτοι οντες και απειθεις και προς παν εργον αγαθον αδοκιμοι",
      "paragraphStart": false
    }
  ]
}
