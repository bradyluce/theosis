{
  "chapter": {
    "id": "ant1904:matthew.23",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 23,
    "referenceLabel": "Matthew 23",
    "summary": "Source text for Matthew 23 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.23.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Matthew 23:1",
      "text": "τοτε ο ιησους ελαλησεν τοις οχλοις και τοις μαθηταις αυτου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.23.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Matthew 23:2",
      "text": "λεγων επι της μωσεως καθεδρας εκαθισαν οι γραμματεις και οι φαρισαιοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Matthew 23:3",
      "text": "παντα ουν οσα εαν ειπωσιν υμιν τηρειν τηρειτε και ποιειτε κατα δε τα εργα αυτων μη ποιειτε λεγουσιν γαρ και ου ποιουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Matthew 23:4",
      "text": "δεσμευουσιν γαρ φορτια βαρεα και δυσβαστακτα και επιτιθεασιν επι τους ωμους των ανθρωπων τω δε δακτυλω αυτων ου θελουσιν κινησαι αυτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Matthew 23:5",
      "text": "παντα δε τα εργα αυτων ποιουσιν προς το θεαθηναι τοις ανθρωποις πλατυνουσιν γαρ τα φυλακτηρια αυτων και μεγαλυνουσιν τα κρασπεδα των ιματιων αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Matthew 23:6",
      "text": "φιλουσιν δε την πρωτοκλισιαν εν τοις δειπνοις και τας πρωτοκαθεδριας εν ταις συναγωγαις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 7,
      "referenceLabel": "Matthew 23:7",
      "text": "και τους ασπασμους εν ταις αγοραις και καλεισθαι υπο των ανθρωπων ραββι ραββι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 8,
      "referenceLabel": "Matthew 23:8",
      "text": "υμεις δε μη κληθητε ραββι εις γαρ υμων εστιν [ο] διδασκαλος ο χριστος παντες δε υμεις αδελφοι εστε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 9,
      "referenceLabel": "Matthew 23:9",
      "text": "και πατερα μη καλεσητε υμων επι της γης εις γαρ εστιν ο πατηρ υμων ο εν τοις ουρανοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 10,
      "referenceLabel": "Matthew 23:10",
      "text": "μηδε κληθητε καθηγηται εις γαρ υμων εστιν [ο] καθηγητης ο χριστος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 11,
      "referenceLabel": "Matthew 23:11",
      "text": "ο δε μειζων υμων εσται υμων διακονος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 12,
      "referenceLabel": "Matthew 23:12",
      "text": "οστις δε υψωσει εαυτον ταπεινωθησεται και οστις ταπεινωσει εαυτον υψωθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 13,
      "referenceLabel": "Matthew 23:13",
      "text": "(:) ουαι δε υμιν γραμματεις και φαρισαιοι υποκριται οτι κατεσθιετε τας οικιας των χηρων και προφασει μακρα προσευχομενοι δια τουτο ληψεσθε περισσοτερον κριμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 14,
      "referenceLabel": "Matthew 23:14",
      "text": "(:) ουαι υμιν γραμματεις και φαρισαιοι υποκριται οτι κλειετε την βασιλειαν των ουρανων εμπροσθεν των ανθρωπων υμεις γαρ ουκ εισερχεσθε ουδε τους εισερχομενους αφιετε εισελθειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 15,
      "referenceLabel": "Matthew 23:15",
      "text": "ουαι υμιν γραμματεις και φαρισαιοι υποκριται οτι περιαγετε την θαλασσαν και την ξηραν ποιησαι ενα προσηλυτον και οταν γενηται ποιειτε αυτον υιον γεεννης διπλοτερον υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 16,
      "referenceLabel": "Matthew 23:16",
      "text": "ουαι υμιν οδηγοι τυφλοι οι λεγοντες ος αν ομοση εν τω ναω ουδεν εστιν ος δ αν ομοση εν τω χρυσω του ναου οφειλει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 17,
      "referenceLabel": "Matthew 23:17",
      "text": "μωροι και τυφλοι τις γαρ μειζων εστιν ο χρυσος η ο ναος ο αγιαζων τον χρυσον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 18,
      "referenceLabel": "Matthew 23:18",
      "text": "και ος αν ομοση εν τω θυσιαστηριω ουδεν εστιν ος δ αν ομοση εν τω δωρω τω επανω αυτου οφειλει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 19,
      "referenceLabel": "Matthew 23:19",
      "text": "μωροι και τυφλοι τι γαρ μειζον το δωρον η το θυσιαστηριον το αγιαζον το δωρον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 20,
      "referenceLabel": "Matthew 23:20",
      "text": "ο ουν ομοσας εν τω θυσιαστηριω ομνυει εν αυτω και εν πασιν τοις επανω αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.21",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 21,
      "referenceLabel": "Matthew 23:21",
      "text": "και ο ομοσας εν τω ναω ομνυει εν αυτω και εν τω κατοικησαντι αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.22",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 22,
      "referenceLabel": "Matthew 23:22",
      "text": "και ο ομοσας εν τω ουρανω ομνυει εν τω θρονω του θεου και εν τω καθημενω επανω αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.23",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 23,
      "referenceLabel": "Matthew 23:23",
      "text": "ουαι υμιν γραμματεις και φαρισαιοι υποκριται οτι αποδεκατουτε το ηδυοσμον και το ανηθον και το κυμινον και αφηκατε τα βαρυτερα του νομου την κρισιν και τον ελεον και την πιστιν ταυτα δε εδει ποιησαι κακεινα μη αφιεναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.24",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 24,
      "referenceLabel": "Matthew 23:24",
      "text": "οδηγοι τυφλοι οι διυλιζοντες τον κωνωπα την δε καμηλον καταπινοντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.25",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 25,
      "referenceLabel": "Matthew 23:25",
      "text": "ουαι υμιν γραμματεις και φαρισαιοι υποκριται οτι καθαριζετε το εξωθεν του ποτηριου και της παροψιδος εσωθεν δε γεμουσιν εξ αρπαγης και αδικιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.26",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 26,
      "referenceLabel": "Matthew 23:26",
      "text": "φαρισαιε τυφλε καθαρισον πρωτον το εντος του ποτηριου και της παροψιδος ινα γενηται και το εκτος αυτων καθαρον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.27",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 27,
      "referenceLabel": "Matthew 23:27",
      "text": "ουαι υμιν γραμματεις και φαρισαιοι υποκριται οτι παρομοιαζετε ταφοις κεκονιαμενοις οιτινες εξωθεν μεν φαινονται ωραιοι εσωθεν δε γεμουσιν οστεων νεκρων και πασης ακαθαρσιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.28",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 28,
      "referenceLabel": "Matthew 23:28",
      "text": "ουτως και υμεις εξωθεν μεν φαινεσθε τοις ανθρωποις δικαιοι εσωθεν δε μεστοι εστε υποκρισεως και ανομιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.29",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 29,
      "referenceLabel": "Matthew 23:29",
      "text": "ουαι υμιν γραμματεις και φαρισαιοι υποκριται οτι οικοδομειτε τους ταφους των προφητων και κοσμειτε τα μνημεια των δικαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.30",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 30,
      "referenceLabel": "Matthew 23:30",
      "text": "και λεγετε ει ημεν εν ταις ημεραις των πατερων ημων ουκ αν ημεν κοινωνοι αυτων εν τω αιματι των προφητων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.31",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 31,
      "referenceLabel": "Matthew 23:31",
      "text": "ωστε μαρτυρειτε εαυτοις οτι υιοι εστε των φονευσαντων τους προφητας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.32",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 32,
      "referenceLabel": "Matthew 23:32",
      "text": "και υμεις πληρωσατε το μετρον των πατερων υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.33",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 33,
      "referenceLabel": "Matthew 23:33",
      "text": "οφεις γεννηματα εχιδνων πως φυγητε απο της κρισεως της γεεννης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.34",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 34,
      "referenceLabel": "Matthew 23:34",
      "text": "δια τουτο ιδου εγω αποστελλω προς υμας προφητας και σοφους και γραμματεις και εξ αυτων αποκτενειτε και σταυρωσετε και εξ αυτων μαστιγωσετε εν ταις συναγωγαις υμων και διωξετε απο πολεως εις πολιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.35",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 35,
      "referenceLabel": "Matthew 23:35",
      "text": "οπως ελθη εφ υμας παν αιμα δικαιον εκχυνομενον επι της γης απο του αιματος αβελ του δικαιου εως του αιματος ζαχαριου υιου βαραχιου ον εφονευσατε μεταξυ του ναου και του θυσιαστηριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.36",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 36,
      "referenceLabel": "Matthew 23:36",
      "text": "αμην λεγω υμιν οτι ηξει ταυτα παντα επι την γενεαν ταυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.37",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 37,
      "referenceLabel": "Matthew 23:37",
      "text": "ιερουσαλημ ιερουσαλημ η αποκτεννουσα τους προφητας και λιθοβολουσα τους απεσταλμενους προς αυτην ποσακις ηθελησα επισυναγαγειν τα τεκνα σου ον τροπον επισυναγει ορνις τα νοσσια εαυτης υπο τας πτερυγας και ουκ ηθελησατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.38",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 38,
      "referenceLabel": "Matthew 23:38",
      "text": "ιδου αφιεται υμιν ο οικος υμων ερημος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.23.39",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 23,
      "verseNumber": 39,
      "referenceLabel": "Matthew 23:39",
      "text": "λεγω γαρ υμιν ου μη με ιδετε απ αρτι εως αν ειπητε ευλογημενος ο ερχομενος εν ονοματι κυριου",
      "paragraphStart": false
    }
  ]
}
