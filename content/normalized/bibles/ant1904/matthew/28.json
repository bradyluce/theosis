{
  "chapter": {
    "id": "ant1904:matthew.28",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 28,
    "referenceLabel": "Matthew 28",
    "summary": "Source text for Matthew 28 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.28.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Matthew 28:1",
      "text": "οψε δε σαββατων τη επιφωσκουση εις μιαν σαββατων ηλθεν μαρια η μαγδαληνη και η αλλη μαρια θεωρησαι τον ταφον",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.28.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Matthew 28:2",
      "text": "και ιδου σεισμος εγενετο μεγας αγγελος γαρ κυριου καταβας εξ ουρανου προσελθων απεκυλισεν τον λιθον απο της θυρας και εκαθητο επανω αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Matthew 28:3",
      "text": "ην δε η ιδεα αυτου ως αστραπη και το ενδυμα αυτου λευκον ωσει χιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Matthew 28:4",
      "text": "απο δε του φοβου αυτου εσεισθησαν οι τηρουντες και εγενοντο ωσει νεκροι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Matthew 28:5",
      "text": "αποκριθεις δε ο αγγελος ειπεν ταις γυναιξιν μη φοβεισθε υμεις οιδα γαρ οτι ιησουν τον εσταυρωμενον ζητειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Matthew 28:6",
      "text": "ουκ εστιν ωδε ηγερθη γαρ καθως ειπεν δευτε ιδετε τον τοπον οπου εκειτο ο κυριος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Matthew 28:7",
      "text": "και ταχυ πορευθεισαι ειπατε τοις μαθηταις αυτου οτι ηγερθη απο των νεκρων και ιδου προαγει υμας εις την γαλιλαιαν εκει αυτον οψεσθε ιδου ειπον υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Matthew 28:8",
      "text": "και εξελθουσαι ταχυ απο του μνημειου μετα φοβου και χαρας μεγαλης εδραμον απαγγειλαι τοις μαθηταις αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Matthew 28:9",
      "text": "[ως δε επορευοντο απαγγειλαι τοις μαθηταις αυτου] και ιδου ιησους απηντησεν αυταις λεγων χαιρετε αι δε προσελθουσαι εκρατησαν αυτου τους ποδας και προσεκυνησαν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Matthew 28:10",
      "text": "τοτε λεγει αυταις ο ιησους μη φοβεισθε υπαγετε απαγγειλατε τοις αδελφοις μου ινα απελθωσιν εις την γαλιλαιαν κακει με οψονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Matthew 28:11",
      "text": "πορευομενων δε αυτων ιδου τινες της κουστωδιας ελθοντες εις την πολιν απηγγειλαν τοις αρχιερευσιν απαντα τα γενομενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Matthew 28:12",
      "text": "και συναχθεντες μετα των πρεσβυτερων συμβουλιον τε λαβοντες αργυρια ικανα εδωκαν τοις στρατιωταις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Matthew 28:13",
      "text": "λεγοντες ειπατε οτι οι μαθηται αυτου νυκτος ελθοντες εκλεψαν αυτον ημων κοιμωμενων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Matthew 28:14",
      "text": "και εαν ακουσθη τουτο επι του ηγεμονος ημεις πεισομεν αυτον και υμας αμεριμνους ποιησομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Matthew 28:15",
      "text": "οι δε λαβοντες τα αργυρια εποιησαν ως εδιδαχθησαν και διεφημισθη ο λογος ουτος παρα ιουδαιοις μεχρι της σημερον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Matthew 28:16",
      "text": "οι δε ενδεκα μαθηται επορευθησαν εις την γαλιλαιαν εις το ορος ου εταξατο αυτοις ο ιησους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Matthew 28:17",
      "text": "και ιδοντες αυτον προσεκυνησαν αυτω οι δε εδιστασαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Matthew 28:18",
      "text": "και προσελθων ο ιησους ελαλησεν αυτοις λεγων εδοθη μοι πασα εξουσια εν ουρανω και επι γης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Matthew 28:19",
      "text": "πορευθεντες μαθητευσατε παντα τα εθνη βαπτιζοντες αυτους εις το ονομα του πατρος και του υιου και του αγιου πνευματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.28.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Matthew 28:20",
      "text": "διδασκοντες αυτους τηρειν παντα οσα ενετειλαμην υμιν και ιδου εγω μεθ υμων ειμι πασας τας ημερας εως της συντελειας του αιωνος αμην",
      "paragraphStart": false
    }
  ]
}
