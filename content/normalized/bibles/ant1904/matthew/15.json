{
  "chapter": {
    "id": "ant1904:matthew.15",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 15,
    "referenceLabel": "Matthew 15",
    "summary": "Source text for Matthew 15 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.15.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Matthew 15:1",
      "text": "τοτε προσερχονται τω ιησου οι απο ιεροσολυμων γραμματεις και φαρισαιοι λεγοντες",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.15.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Matthew 15:2",
      "text": "διατι οι μαθηται σου παραβαινουσιν την παραδοσιν των πρεσβυτερων ου γαρ νιπτονται τας χειρας αυτων οταν αρτον εσθιωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Matthew 15:3",
      "text": "ο δε αποκριθεις ειπεν αυτοις διατι και υμεις παραβαινετε την εντολην του θεου δια την παραδοσιν υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Matthew 15:4",
      "text": "ο γαρ θεος ενετειλατο λεγων τιμα τον πατερα και την μητερα και ο κακολογων πατερα η μητερα θανατω τελευτατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Matthew 15:5",
      "text": "υμεις δε λεγετε ος αν ειπη τω πατρι η τη μητρι δωρον ο εαν εξ εμου ωφεληθης και ου μη τιμηση τον πατερα αυτου η την μητερα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Matthew 15:6",
      "text": "και ηκυρωσατε την εντολην του θεου δια την παραδοσιν υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Matthew 15:7",
      "text": "υποκριται καλως προεφητευσεν περι υμων ησαιας λεγων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Matthew 15:8",
      "text": "εγγιζει μοι ο λαος ουτος τω στοματι αυτων και τοις χειλεσιν με τιμα η δε καρδια αυτων πορρω απεχει απ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Matthew 15:9",
      "text": "ματην δε σεβονται με διδασκοντες διδασκαλιας ενταλματα ανθρωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Matthew 15:10",
      "text": "και προσκαλεσαμενος τον οχλον ειπεν αυτοις ακουετε και συνιετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Matthew 15:11",
      "text": "ου το εισερχομενον εις το στομα κοινοι τον ανθρωπον αλλα το εκπορευομενον εκ του στοματος τουτο κοινοι τον ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Matthew 15:12",
      "text": "τοτε προσελθοντες οι μαθηται αυτου ειπον αυτω οιδας οτι οι φαρισαιοι εσκανδαλισθησαν ακουσαντες τον λογον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Matthew 15:13",
      "text": "ο δε αποκριθεις ειπεν πασα φυτεια ην ουκ εφυτευσεν ο πατηρ μου ο ουρανιος εκριζωθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Matthew 15:14",
      "text": "αφετε αυτους οδηγοι εισιν τυφλοι τυφλων τυφλος δε τυφλον εαν οδηγη αμφοτεροι εις βοθυνον πεσουνται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Matthew 15:15",
      "text": "αποκριθεις δε ο πετρος ειπεν αυτω φρασον ημιν την παραβολην ταυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Matthew 15:16",
      "text": "ο δε ιησους ειπεν ακμην και υμεις ασυνετοι εστε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Matthew 15:17",
      "text": "ουπω νοειτε οτι παν το εισπορευομενον εις το στομα εις την κοιλιαν χωρει και εις αφεδρωνα εκβαλλεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Matthew 15:18",
      "text": "τα δε εκπορευομενα εκ του στοματος εκ της καρδιας εξερχεται κακεινα κοινοι τον ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Matthew 15:19",
      "text": "εκ γαρ της καρδιας εξερχονται διαλογισμοι πονηροι φονοι μοιχειαι πορνειαι κλοπαι ψευδομαρτυριαι βλασφημιαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Matthew 15:20",
      "text": "ταυτα εστιν τα κοινουντα τον ανθρωπον το δε ανιπτοις χερσιν φαγειν ου κοινοι τον ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.21",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Matthew 15:21",
      "text": "και εξελθων εκειθεν ο ιησους ανεχωρησεν εις τα μερη τυρου και σιδωνος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.22",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Matthew 15:22",
      "text": "και ιδου γυνη χαναναια απο των οριων εκεινων εξελθουσα εκραυγασεν αυτω λεγουσα ελεησον με κυριε υιε δαυιδ η θυγατηρ μου κακως δαιμονιζεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.23",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Matthew 15:23",
      "text": "ο δε ουκ απεκριθη αυτη λογον και προσελθοντες οι μαθηται αυτου ηρωτων αυτον λεγοντες απολυσον αυτην οτι κραζει οπισθεν ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.24",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Matthew 15:24",
      "text": "ο δε αποκριθεις ειπεν ουκ απεσταλην ει μη εις τα προβατα τα απολωλοτα οικου ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.25",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Matthew 15:25",
      "text": "η δε ελθουσα προσεκυνησεν αυτω λεγουσα κυριε βοηθει μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.26",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Matthew 15:26",
      "text": "ο δε αποκριθεις ειπεν ουκ εστιν καλον λαβειν τον αρτον των τεκνων και βαλειν τοις κυναριοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.27",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Matthew 15:27",
      "text": "η δε ειπεν ναι κυριε και γαρ τα κυναρια εσθιει απο των ψιχιων των πιπτοντων απο της τραπεζης των κυριων αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.28",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Matthew 15:28",
      "text": "τοτε αποκριθεις ο ιησους ειπεν αυτη ω γυναι μεγαλη σου η πιστις γενηθητω σοι ως θελεις και ιαθη η θυγατηρ αυτης απο της ωρας εκεινης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.29",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Matthew 15:29",
      "text": "και μεταβας εκειθεν ο ιησους ηλθεν παρα την θαλασσαν της γαλιλαιας και αναβας εις το ορος εκαθητο εκει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.30",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Matthew 15:30",
      "text": "και προσηλθον αυτω οχλοι πολλοι εχοντες μεθ εαυτων χωλους τυφλους κωφους κυλλους και ετερους πολλους και ερριψαν αυτους παρα τους ποδας του ιησου και εθεραπευσεν αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.31",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Matthew 15:31",
      "text": "ωστε τους οχλους θαυμασαι βλεποντας κωφους [ακουοντας αλαλους] λαλουντας κυλλους υγιεις χωλους περιπατουντας και τυφλους βλεποντας και εδοξασαν τον θεον ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.32",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Matthew 15:32",
      "text": "ο δε ιησους προσκαλεσαμενος τους μαθητας αυτου ειπεν σπλαγχνιζομαι επι τον οχλον οτι ηδη ημεραι τρεις προσμενουσιν μοι και ουκ εχουσιν τι φαγωσιν και απολυσαι αυτους νηστεις ου θελω μηποτε εκλυθωσιν εν τη οδω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.33",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Matthew 15:33",
      "text": "και λεγουσιν αυτω οι μαθηται αυτου ποθεν ημιν εν ερημια αρτοι τοσουτοι ωστε χορτασαι οχλον τοσουτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.34",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Matthew 15:34",
      "text": "και λεγει αυτοις ο ιησους ποσους αρτους εχετε οι δε ειπον επτα και ολιγα ιχθυδια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.35",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Matthew 15:35",
      "text": "και εκελευσεν τοις οχλοις αναπεσειν επι την γην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.36",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Matthew 15:36",
      "text": "και λαβων τους επτα αρτους και τους ιχθυας ευχαριστησας εκλασεν και εδωκεν τοις μαθηταις αυτου οι δε μαθηται τοις οχλοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.37",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Matthew 15:37",
      "text": "και εφαγον παντες και εχορτασθησαν και ηραν το περισσευον των κλασματων επτα σπυριδας πληρεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.38",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Matthew 15:38",
      "text": "οι δε εσθιοντες ησαν τετρακισχιλιοι ανδρες χωρις γυναικων και παιδιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.15.39",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Matthew 15:39",
      "text": "και απολυσας τους οχλους ενεβη εις το πλοιον και ηλθεν εις τα ορια μαγδαλα",
      "paragraphStart": false
    }
  ]
}
