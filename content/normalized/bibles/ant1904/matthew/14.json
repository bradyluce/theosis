{
  "chapter": {
    "id": "ant1904:matthew.14",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 14,
    "referenceLabel": "Matthew 14",
    "summary": "Source text for Matthew 14 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.14.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Matthew 14:1",
      "text": "εν εκεινω τω καιρω ηκουσεν ηρωδης ο τετραρχης την ακοην ιησου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.14.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Matthew 14:2",
      "text": "και ειπεν τοις παισιν αυτου ουτος εστιν ιωαννης ο βαπτιστης αυτος ηγερθη απο των νεκρων και δια τουτο αι δυναμεις ενεργουσιν εν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Matthew 14:3",
      "text": "ο γαρ ηρωδης κρατησας τον ιωαννην εδησεν αυτον και εθετο εν φυλακη δια ηρωδιαδα την γυναικα φιλιππου του αδελφου αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Matthew 14:4",
      "text": "ελεγεν γαρ αυτω ο ιωαννης ουκ εξεστιν σοι εχειν αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Matthew 14:5",
      "text": "και θελων αυτον αποκτειναι εφοβηθη τον οχλον οτι ως προφητην αυτον ειχον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Matthew 14:6",
      "text": "γενεσιων δε αγομενων του ηρωδου ωρχησατο η θυγατηρ της ηρωδιαδος εν τω μεσω και ηρεσεν τω ηρωδη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Matthew 14:7",
      "text": "οθεν μεθ ορκου ωμολογησεν αυτη δουναι ο εαν αιτησηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Matthew 14:8",
      "text": "η δε προβιβασθεισα υπο της μητρος αυτης δος μοι φησιν ωδε επι πινακι την κεφαλην ιωαννου του βαπτιστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Matthew 14:9",
      "text": "και ελυπηθη ο βασιλευς δια δε τους ορκους και τους συνανακειμενους εκελευσεν δοθηναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Matthew 14:10",
      "text": "και πεμψας απεκεφαλισεν τον ιωαννην εν τη φυλακη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Matthew 14:11",
      "text": "και ηνεχθη η κεφαλη αυτου επι πινακι και εδοθη τω κορασιω και ηνεγκεν τη μητρι αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Matthew 14:12",
      "text": "και προσελθοντες οι μαθηται αυτου ηραν το σωμα και εθαψαν αυτο και ελθοντες απηγγειλαν τω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Matthew 14:13",
      "text": "ακουσας δε ο ιησους ανεχωρησεν εκειθεν εν πλοιω εις ερημον τοπον κατ ιδιαν και ακουσαντες οι οχλοι ηκολουθησαν αυτω πεζη απο των πολεων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Matthew 14:14",
      "text": "και εξελθων ο ιησους ειδεν πολυν οχλον και εσπλαγχνισθη επ αυτοις και εθεραπευσεν τους αρρωστους αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Matthew 14:15",
      "text": "οψιας δε γενομενης προσηλθον αυτω οι μαθηται αυτου λεγοντες ερημος εστιν ο τοπος και η ωρα ηδη παρηλθεν απολυσον τους οχλους ινα απελθοντες εις τας κωμας αγορασωσιν εαυτοις βρωματα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Matthew 14:16",
      "text": "ο δε ιησους ειπεν αυτοις ου χρειαν εχουσιν απελθειν δοτε αυτοις υμεις φαγειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Matthew 14:17",
      "text": "οι δε λεγουσιν αυτω ουκ εχομεν ωδε ει μη πεντε αρτους και δυο ιχθυας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Matthew 14:18",
      "text": "ο δε ειπεν φερετε μοι αυτους ωδε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Matthew 14:19",
      "text": "και κελευσας τους οχλους ανακλιθηναι επι τους χορτους λαβων τους πεντε αρτους και τους δυο ιχθυας αναβλεψας εις τον ουρανον ευλογησεν και κλασας εδωκεν τοις μαθηταις τους αρτους οι δε μαθηται τοις οχλοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Matthew 14:20",
      "text": "και εφαγον παντες και εχορτασθησαν και ηραν το περισσευον των κλασματων δωδεκα κοφινους πληρεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.21",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Matthew 14:21",
      "text": "οι δε εσθιοντες ησαν ανδρες ωσει πεντακισχιλιοι χωρις γυναικων και παιδιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.22",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Matthew 14:22",
      "text": "και ευθεως ηναγκασεν ο ιησους τους μαθητας αυτου εμβηναι εις το πλοιον και προαγειν αυτον εις το περαν εως ου απολυση τους οχλους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.23",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Matthew 14:23",
      "text": "και απολυσας τους οχλους ανεβη εις το ορος κατ ιδιαν προσευξασθαι οψιας δε γενομενης μονος ην εκει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.24",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Matthew 14:24",
      "text": "το δε πλοιον ηδη μεσον της θαλασσης ην βασανιζομενον υπο των κυματων ην γαρ εναντιος ο ανεμος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.25",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Matthew 14:25",
      "text": "τεταρτη δε φυλακη της νυκτος απηλθεν προς αυτους ο ιησους περιπατων επι της θαλασσης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.26",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Matthew 14:26",
      "text": "και ιδοντες αυτον οι μαθηται επι την θαλασσαν περιπατουντα εταραχθησαν λεγοντες οτι φαντασμα εστιν και απο του φοβου εκραξαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.27",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Matthew 14:27",
      "text": "ευθεως δε ελαλησεν αυτοις ο ιησους λεγων θαρσειτε εγω ειμι μη φοβεισθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.28",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Matthew 14:28",
      "text": "αποκριθεις δε αυτω ο πετρος ειπεν κυριε ει συ ει κελευσον με προς σε ελθειν επι τα υδατα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.29",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Matthew 14:29",
      "text": "ο δε ειπεν ελθε και καταβας απο του πλοιου ο πετρος περιεπατησεν επι τα υδατα ελθειν προς τον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.30",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Matthew 14:30",
      "text": "βλεπων δε τον ανεμον ισχυρον εφοβηθη και αρξαμενος καταποντιζεσθαι εκραξεν λεγων κυριε σωσον με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.31",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Matthew 14:31",
      "text": "ευθεως δε ο ιησους εκτεινας την χειρα επελαβετο αυτου και λεγει αυτω ολιγοπιστε εις τι εδιστασας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.32",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Matthew 14:32",
      "text": "και εμβαντων αυτων εις το πλοιον εκοπασεν ο ανεμος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.33",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Matthew 14:33",
      "text": "οι δε εν τω πλοιω ελθοντες προσεκυνησαν αυτω λεγοντες αληθως θεου υιος ει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.34",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Matthew 14:34",
      "text": "και διαπερασαντες ηλθον εις την γην γεννησαρετ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.35",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Matthew 14:35",
      "text": "και επιγνοντες αυτον οι ανδρες του τοπου εκεινου απεστειλαν εις ολην την περιχωρον εκεινην και προσηνεγκαν αυτω παντας τους κακως εχοντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.14.36",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Matthew 14:36",
      "text": "και παρεκαλουν αυτον ινα καν μονον αψωνται του κρασπεδου του ιματιου αυτου και οσοι ηψαντο διεσωθησαν",
      "paragraphStart": false
    }
  ]
}
