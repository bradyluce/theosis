{
  "chapter": {
    "id": "ant1904:matthew.26",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 26,
    "referenceLabel": "Matthew 26",
    "summary": "Source text for Matthew 26 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.26.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Matthew 26:1",
      "text": "και εγενετο οτε ετελεσεν ο ιησους παντας τους λογους τουτους ειπεν τοις μαθηταις αυτου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.26.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Matthew 26:2",
      "text": "οιδατε οτι μετα δυο ημερας το πασχα γινεται και ο υιος του ανθρωπου παραδιδοται εις το σταυρωθηναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Matthew 26:3",
      "text": "τοτε συνηχθησαν οι αρχιερεις και οι γραμματεις και οι πρεσβυτεροι του λαου εις την αυλην του αρχιερεως του λεγομενου καιαφα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Matthew 26:4",
      "text": "και συνεβουλευσαντο ινα τον ιησουν δολω κρατησωσιν και αποκτεινωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Matthew 26:5",
      "text": "ελεγον δε μη εν τη εορτη ινα μη θορυβος γενηται εν τω λαω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Matthew 26:6",
      "text": "του δε ιησου γενομενου εν βηθανια εν οικια σιμωνος του λεπρου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Matthew 26:7",
      "text": "προσηλθεν αυτω γυνη αλαβαστρον μυρου εχουσα βαρυτιμου και κατεχεεν επι την κεφαλην αυτου ανακειμενου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Matthew 26:8",
      "text": "ιδοντες δε οι μαθηται αυτου ηγανακτησαν λεγοντες εις τι η απωλεια αυτη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Matthew 26:9",
      "text": "ηδυνατο γαρ τουτο το μυρον πραθηναι πολλου και δοθηναι [τοις] πτωχοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Matthew 26:10",
      "text": "γνους δε ο ιησους ειπεν αυτοις τι κοπους παρεχετε τη γυναικι εργον γαρ καλον ειργασατο εις εμε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Matthew 26:11",
      "text": "τους πτωχους γαρ παντοτε εχετε μεθ εαυτων εμε δε ου παντοτε εχετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Matthew 26:12",
      "text": "βαλουσα γαρ αυτη το μυρον τουτο επι του σωματος μου προς το ενταφιασαι με εποιησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Matthew 26:13",
      "text": "αμην λεγω υμιν οπου εαν κηρυχθη το ευαγγελιον τουτο εν ολω τω κοσμω λαληθησεται και ο εποιησεν αυτη εις μνημοσυνον αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Matthew 26:14",
      "text": "τοτε πορευθεις εις των δωδεκα ο λεγομενος ιουδας ισκαριωτης προς τους αρχιερεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Matthew 26:15",
      "text": "ειπεν τι θελετε μοι δουναι και εγω υμιν παραδωσω αυτον οι δε εστησαν αυτω τριακοντα αργυρια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Matthew 26:16",
      "text": "και απο τοτε εζητει ευκαιριαν ινα αυτον παραδω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Matthew 26:17",
      "text": "τη δε πρωτη των αζυμων προσηλθον οι μαθηται τω ιησου λεγοντες αυτω που θελεις ετοιμασωμεν σοι φαγειν το πασχα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Matthew 26:18",
      "text": "ο δε ειπεν υπαγετε εις την πολιν προς τον δεινα και ειπατε αυτω ο διδασκαλος λεγει ο καιρος μου εγγυς εστιν προς σε ποιω το πασχα μετα των μαθητων μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Matthew 26:19",
      "text": "και εποιησαν οι μαθηται ως συνεταξεν αυτοις ο ιησους και ητοιμασαν το πασχα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Matthew 26:20",
      "text": "οψιας δε γενομενης ανεκειτο μετα των δωδεκα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.21",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Matthew 26:21",
      "text": "και εσθιοντων αυτων ειπεν αμην λεγω υμιν οτι εις εξ υμων παραδωσει με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.22",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Matthew 26:22",
      "text": "και λυπουμενοι σφοδρα ηρξαντο λεγειν αυτω εκαστος αυτων μητι εγω ειμι κυριε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.23",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Matthew 26:23",
      "text": "ο δε αποκριθεις ειπεν ο εμβαψας μετ εμου εν τω τρυβλιω την χειρα ουτος με παραδωσει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.24",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Matthew 26:24",
      "text": "ο μεν υιος του ανθρωπου υπαγει καθως γεγραπται περι αυτου ουαι δε τω ανθρωπω εκεινω δι ου ο υιος του ανθρωπου παραδιδοται καλον ην αυτω ει ουκ εγεννηθη ο ανθρωπος εκεινος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.25",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Matthew 26:25",
      "text": "αποκριθεις δε ιουδας ο παραδιδους αυτον ειπεν μητι εγω ειμι ραββι λεγει αυτω συ ειπας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.26",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Matthew 26:26",
      "text": "εσθιοντων δε αυτων λαβων ο ιησους τον αρτον και ευχαριστησας εκλασεν και εδιδου τοις μαθηταις και ειπεν λαβετε φαγετε τουτο εστιν το σωμα μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.27",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Matthew 26:27",
      "text": "και λαβων το ποτηριον και ευχαριστησας εδωκεν αυτοις λεγων πιετε εξ αυτου παντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.28",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Matthew 26:28",
      "text": "τουτο γαρ εστιν το αιμα μου το της καινης διαθηκης το περι πολλων εκχυνομενον εις αφεσιν αμαρτιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.29",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 29,
      "referenceLabel": "Matthew 26:29",
      "text": "λεγω δε υμιν οτι ου μη πιω απ αρτι εκ τουτου του γενηματος της αμπελου εως της ημερας εκεινης οταν αυτο πινω μεθ υμων καινον εν τη βασιλεια του πατρος μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.30",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 30,
      "referenceLabel": "Matthew 26:30",
      "text": "και υμνησαντες εξηλθον εις το ορος των ελαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.31",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 31,
      "referenceLabel": "Matthew 26:31",
      "text": "τοτε λεγει αυτοις ο ιησους παντες υμεις σκανδαλισθησεσθε εν εμοι εν τη νυκτι ταυτη γεγραπται γαρ παταξω τον ποιμενα και διασκορπισθησονται τα προβατα της ποιμνης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.32",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 32,
      "referenceLabel": "Matthew 26:32",
      "text": "μετα δε το εγερθηναι με προαξω υμας εις την γαλιλαιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.33",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 33,
      "referenceLabel": "Matthew 26:33",
      "text": "αποκριθεις δε ο πετρος ειπεν αυτω ει παντες σκανδαλισθησονται εν σοι εγω δε ουδεποτε σκανδαλισθησομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.34",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 34,
      "referenceLabel": "Matthew 26:34",
      "text": "εφη αυτω ο ιησους αμην λεγω σοι οτι εν ταυτη τη νυκτι πριν αλεκτορα φωνησαι τρις απαρνηση με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.35",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 35,
      "referenceLabel": "Matthew 26:35",
      "text": "λεγει αυτω ο πετρος καν δεη με συν σοι αποθανειν ου μη σε απαρνησομαι ομοιως δε και παντες οι μαθηται ειπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.36",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 36,
      "referenceLabel": "Matthew 26:36",
      "text": "τοτε ερχεται μετ αυτων ο ιησους εις χωριον λεγομενον γεθσημανη και λεγει τοις μαθηταις καθισατε αυτου εως ου απελθων προσευξωμαι εκει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.37",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 37,
      "referenceLabel": "Matthew 26:37",
      "text": "και παραλαβων τον πετρον και τους δυο υιους ζεβεδαιου ηρξατο λυπεισθαι και αδημονειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.38",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 38,
      "referenceLabel": "Matthew 26:38",
      "text": "τοτε λεγει αυτοις ο ιησους περιλυπος εστιν η ψυχη μου εως θανατου μεινατε ωδε και γρηγορειτε μετ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.39",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 39,
      "referenceLabel": "Matthew 26:39",
      "text": "και προελθων μικρον επεσεν επι προσωπον αυτου προσευχομενος και λεγων πατερ μου ει δυνατον εστιν παρελθετω απ εμου το ποτηριον τουτο πλην ουχ ως εγω θελω αλλ ως συ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.40",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 40,
      "referenceLabel": "Matthew 26:40",
      "text": "και ερχεται προς τους μαθητας και ευρισκει αυτους καθευδοντας και λεγει τω πετρω ουτως ουκ ισχυσατε μιαν ωραν γρηγορησαι μετ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.41",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 41,
      "referenceLabel": "Matthew 26:41",
      "text": "γρηγορειτε και προσευχεσθε ινα μη εισελθητε εις πειρασμον το μεν πνευμα προθυμον η δε σαρξ ασθενης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.42",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 42,
      "referenceLabel": "Matthew 26:42",
      "text": "παλιν εκ δευτερου απελθων προσηυξατο λεγων πατερ μου ει ου δυναται τουτο το ποτηριον παρελθειν απ εμου εαν μη αυτο πιω γενηθητω το θελημα σου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.43",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 43,
      "referenceLabel": "Matthew 26:43",
      "text": "και ελθων ευρισκει αυτους παλιν καθευδοντας ησαν γαρ αυτων οι οφθαλμοι βεβαρημενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.44",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 44,
      "referenceLabel": "Matthew 26:44",
      "text": "και αφεις αυτους απελθων παλιν προσηυξατο εκ τριτου τον αυτον λογον ειπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.45",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 45,
      "referenceLabel": "Matthew 26:45",
      "text": "τοτε ερχεται προς τους μαθητας αυτου και λεγει αυτοις καθευδετε το λοιπον και αναπαυεσθε ιδου ηγγικεν η ωρα και ο υιος του ανθρωπου παραδιδοται εις χειρας αμαρτωλων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.46",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 46,
      "referenceLabel": "Matthew 26:46",
      "text": "εγειρεσθε αγωμεν ιδου ηγγικεν ο παραδιδους με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.47",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 47,
      "referenceLabel": "Matthew 26:47",
      "text": "και ετι αυτου λαλουντος ιδου ιουδας εις των δωδεκα ηλθεν και μετ αυτου οχλος πολυς μετα μαχαιρων και ξυλων απο των αρχιερεων και πρεσβυτερων του λαου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.48",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 48,
      "referenceLabel": "Matthew 26:48",
      "text": "ο δε παραδιδους αυτον εδωκεν αυτοις σημειον λεγων ον αν φιλησω αυτος εστιν κρατησατε αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.49",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 49,
      "referenceLabel": "Matthew 26:49",
      "text": "και ευθεως προσελθων τω ιησου ειπεν χαιρε ραββι και κατεφιλησεν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.50",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 50,
      "referenceLabel": "Matthew 26:50",
      "text": "ο δε ιησους ειπεν αυτω εταιρε εφ ω παρει τοτε προσελθοντες επεβαλον τας χειρας επι τον ιησουν και εκρατησαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.51",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 51,
      "referenceLabel": "Matthew 26:51",
      "text": "και ιδου εις των μετα ιησου εκτεινας την χειρα απεσπασεν την μαχαιραν αυτου και παταξας τον δουλον του αρχιερεως αφειλεν αυτου το ωτιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.52",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 52,
      "referenceLabel": "Matthew 26:52",
      "text": "τοτε λεγει αυτω ο ιησους αποστρεψον σου την μαχαιραν εις τον τοπον αυτης παντες γαρ οι λαβοντες μαχαιραν εν μαχαιρα αποθανουνται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.53",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 53,
      "referenceLabel": "Matthew 26:53",
      "text": "η δοκεις οτι ου δυναμαι αρτι παρακαλεσαι τον πατερα μου και παραστησει μοι πλειους η δωδεκα λεγεωνας αγγελων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.54",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 54,
      "referenceLabel": "Matthew 26:54",
      "text": "πως ουν πληρωθωσιν αι γραφαι οτι ουτως δει γενεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.55",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 55,
      "referenceLabel": "Matthew 26:55",
      "text": "εν εκεινη τη ωρα ειπεν ο ιησους τοις οχλοις ως επι ληστην εξηλθετε μετα μαχαιρων και ξυλων συλλαβειν με καθ ημεραν προς υμας εκαθεζομην διδασκων εν τω ιερω και ουκ εκρατησατε με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.56",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 56,
      "referenceLabel": "Matthew 26:56",
      "text": "τουτο δε ολον γεγονεν ινα πληρωθωσιν αι γραφαι των προφητων τοτε οι μαθηται παντες αφεντες αυτον εφυγον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.57",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 57,
      "referenceLabel": "Matthew 26:57",
      "text": "οι δε κρατησαντες τον ιησουν απηγαγον προς καιαφαν τον αρχιερεα οπου οι γραμματεις και οι πρεσβυτεροι συνηχθησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.58",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 58,
      "referenceLabel": "Matthew 26:58",
      "text": "ο δε πετρος ηκολουθει αυτω απο μακροθεν εως της αυλης του αρχιερεως και εισελθων εσω εκαθητο μετα των υπηρετων ιδειν το τελος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.59",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 59,
      "referenceLabel": "Matthew 26:59",
      "text": "οι δε αρχιερεις και οι πρεσβυτεροι και το συνεδριον ολον εζητουν ψευδομαρτυριαν κατα του ιησου οπως θανατωσωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.60",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 60,
      "referenceLabel": "Matthew 26:60",
      "text": "και ουχ ευρον και πολλων ψευδομαρτυρων προσελθοντων ουχ ευρον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.61",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 61,
      "referenceLabel": "Matthew 26:61",
      "text": "υστερον δε προσελθοντες δυο ψευδομαρτυρες ειπον ουτος εφη δυναμαι καταλυσαι τον ναον του θεου και δια τριων ημερων οικοδομησαι αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.62",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 62,
      "referenceLabel": "Matthew 26:62",
      "text": "και αναστας ο αρχιερευς ειπεν αυτω ουδεν αποκρινη τι ουτοι σου καταμαρτυρουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.63",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 63,
      "referenceLabel": "Matthew 26:63",
      "text": "ο δε ιησους εσιωπα και αποκριθεις ο αρχιερευς ειπεν αυτω εξορκιζω σε κατα του θεου του ζωντος ινα ημιν ειπης ει συ ει ο χριστος ο υιος του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.64",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 64,
      "referenceLabel": "Matthew 26:64",
      "text": "λεγει αυτω ο ιησους συ ειπας πλην λεγω υμιν απ αρτι οψεσθε τον υιον του ανθρωπου καθημενον εκ δεξιων της δυναμεως και ερχομενον επι των νεφελων του ουρανου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.65",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 65,
      "referenceLabel": "Matthew 26:65",
      "text": "τοτε ο αρχιερευς διερρηξεν τα ιματια αυτου λεγων οτι εβλασφημησεν τι ετι χρειαν εχομεν μαρτυρων ιδε νυν ηκουσατε την βλασφημιαν αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.66",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 66,
      "referenceLabel": "Matthew 26:66",
      "text": "τι υμιν δοκει οι δε αποκριθεντες ειπον ενοχος θανατου εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.67",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 67,
      "referenceLabel": "Matthew 26:67",
      "text": "τοτε ενεπτυσαν εις το προσωπον αυτου και εκολαφισαν αυτον οι δε ερραπισαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.68",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 68,
      "referenceLabel": "Matthew 26:68",
      "text": "λεγοντες προφητευσον ημιν χριστε τις εστιν ο παισας σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.69",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 69,
      "referenceLabel": "Matthew 26:69",
      "text": "ο δε πετρος εξω εκαθητο εν τη αυλη και προσηλθεν αυτω μια παιδισκη λεγουσα και συ ησθα μετα ιησου του γαλιλαιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.70",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 70,
      "referenceLabel": "Matthew 26:70",
      "text": "ο δε ηρνησατο εμπροσθεν αυτων παντων λεγων ουκ οιδα τι λεγεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.71",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 71,
      "referenceLabel": "Matthew 26:71",
      "text": "εξελθοντα δε αυτον εις τον πυλωνα ειδεν αυτον αλλη και λεγει αυτοις εκει και ουτος ην μετα ιησου του ναζωραιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.72",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 72,
      "referenceLabel": "Matthew 26:72",
      "text": "και παλιν ηρνησατο μεθ ορκου οτι ουκ οιδα τον ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.73",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 73,
      "referenceLabel": "Matthew 26:73",
      "text": "μετα μικρον δε προσελθοντες οι εστωτες ειπον τω πετρω αληθως και συ εξ αυτων ει και γαρ η λαλια σου δηλον σε ποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.74",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 74,
      "referenceLabel": "Matthew 26:74",
      "text": "τοτε ηρξατο καταθεματιζειν και ομνυειν οτι ουκ οιδα τον ανθρωπον και ευθεως αλεκτωρ εφωνησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.26.75",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 26,
      "verseNumber": 75,
      "referenceLabel": "Matthew 26:75",
      "text": "και εμνησθη ο πετρος του ρηματος ιησου ειρηκοτος αυτω οτι πριν αλεκτορα φωνησαι τρις απαρνηση με και εξελθων εξω εκλαυσεν πικρως",
      "paragraphStart": false
    }
  ]
}
