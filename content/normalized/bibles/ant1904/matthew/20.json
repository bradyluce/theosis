{
  "chapter": {
    "id": "ant1904:matthew.20",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 20,
    "referenceLabel": "Matthew 20",
    "summary": "Source text for Matthew 20 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.20.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Matthew 20:1",
      "text": "ομοια γαρ εστιν η βασιλεια των ουρανων ανθρωπω οικοδεσποτη οστις εξηλθεν αμα πρωι μισθωσασθαι εργατας εις τον αμπελωνα αυτου",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.20.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Matthew 20:2",
      "text": "και συμφωνησας μετα των εργατων εκ δηναριου την ημεραν απεστειλεν αυτους εις τον αμπελωνα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Matthew 20:3",
      "text": "και εξελθων περι τριτην ωραν ειδεν αλλους εστωτας εν τη αγορα αργους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Matthew 20:4",
      "text": "και εκεινοις ειπεν υπαγετε και υμεις εις τον αμπελωνα και ο εαν η δικαιον δωσω υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Matthew 20:5",
      "text": "οι δε απηλθον παλιν εξελθων περι εκτην και ενατην ωραν εποιησεν ωσαυτως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Matthew 20:6",
      "text": "περι δε την ενδεκατην ωραν εξελθων ευρεν αλλους εστωτας αργους και λεγει αυτοις τι ωδε εστηκατε ολην την ημεραν αργοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Matthew 20:7",
      "text": "λεγουσιν αυτω οτι ουδεις ημας εμισθωσατο λεγει αυτοις υπαγετε και υμεις εις τον αμπελωνα και ο εαν η δικαιον ληψεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Matthew 20:8",
      "text": "οψιας δε γενομενης λεγει ο κυριος του αμπελωνος τω επιτροπω αυτου καλεσον τους εργατας και αποδος αυτοις τον μισθον αρξαμενος απο των εσχατων εως των πρωτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Matthew 20:9",
      "text": "και ελθοντες οι περι την ενδεκατην ωραν ελαβον ανα δηναριον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Matthew 20:10",
      "text": "ελθοντες δε οι πρωτοι ενομισαν οτι πλειονα ληψονται και ελαβον και αυτοι ανα δηναριον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Matthew 20:11",
      "text": "λαβοντες δε εγογγυζον κατα του οικοδεσποτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Matthew 20:12",
      "text": "λεγοντες οτι ουτοι οι εσχατοι μιαν ωραν εποιησαν και ισους ημιν αυτους εποιησας τοις βαστασασιν το βαρος της ημερας και τον καυσωνα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Matthew 20:13",
      "text": "ο δε αποκριθεις ειπεν ενι αυτων εταιρε ουκ αδικω σε ουχι δηναριου συνεφωνησας μοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Matthew 20:14",
      "text": "αρον το σον και υπαγε θελω δε τουτω τω εσχατω δουναι ως και σοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Matthew 20:15",
      "text": "η ουκ εξεστιν μοι ποιησαι ο θελω εν τοις εμοις ει ο οφθαλμος σου πονηρος εστιν οτι εγω αγαθος ειμι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 16,
      "referenceLabel": "Matthew 20:16",
      "text": "ουτως εσονται οι εσχατοι πρωτοι και οι πρωτοι εσχατοι πολλοι γαρ εισιν κλητοι ολιγοι δε εκλεκτοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 17,
      "referenceLabel": "Matthew 20:17",
      "text": "και αναβαινων ο ιησους εις ιεροσολυμα παρελαβεν τους δωδεκα μαθητας κατ ιδιαν εν τη οδω και ειπεν αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 18,
      "referenceLabel": "Matthew 20:18",
      "text": "ιδου αναβαινομεν εις ιεροσολυμα και ο υιος του ανθρωπου παραδοθησεται τοις αρχιερευσιν και γραμματευσιν και κατακρινουσιν αυτον θανατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 19,
      "referenceLabel": "Matthew 20:19",
      "text": "και παραδωσουσιν αυτον τοις εθνεσιν εις το εμπαιξαι και μαστιγωσαι και σταυρωσαι και τη τριτη ημερα αναστησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 20,
      "referenceLabel": "Matthew 20:20",
      "text": "τοτε προσηλθεν αυτω η μητηρ των υιων ζεβεδαιου μετα των υιων αυτης προσκυνουσα και αιτουσα τι παρ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.21",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 21,
      "referenceLabel": "Matthew 20:21",
      "text": "ο δε ειπεν αυτη τι θελεις λεγει αυτω ειπε ινα καθισωσιν ουτοι οι δυο υιοι μου εις εκ δεξιων σου και εις εξ ευωνυμων σου εν τη βασιλεια σου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.22",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 22,
      "referenceLabel": "Matthew 20:22",
      "text": "αποκριθεις δε ο ιησους ειπεν ουκ οιδατε τι αιτεισθε δυνασθε πιειν το ποτηριον ο εγω μελλω πινειν η το βαπτισμα ο εγω βαπτιζομαι βαπτισθηναι λεγουσιν αυτω δυναμεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.23",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 23,
      "referenceLabel": "Matthew 20:23",
      "text": "και λεγει αυτοις το μεν ποτηριον μου πιεσθε και το βαπτισμα ο εγω βαπτιζομαι βαπτισθησεσθε το δε καθισαι εκ δεξιων μου και εξ ευωνυμων μου ουκ εστιν εμον δουναι αλλ οις ητοιμασται [υπο του πατρος μου]",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.24",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 24,
      "referenceLabel": "Matthew 20:24",
      "text": "και ακουσαντες οι δεκα ηγανακτησαν περι των δυο αδελφων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.25",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 25,
      "referenceLabel": "Matthew 20:25",
      "text": "ο δε ιησους προσκαλεσαμενος αυτους ειπεν οιδατε οτι οι αρχοντες των εθνων κατακυριευουσιν αυτων και οι μεγαλοι κατεξουσιαζουσιν αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.26",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 26,
      "referenceLabel": "Matthew 20:26",
      "text": "ουχ ουτως εσται εν υμιν αλλ ος εαν θελη εν υμιν μεγας γενεσθαι εσται υμων διακονος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.27",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 27,
      "referenceLabel": "Matthew 20:27",
      "text": "και ος εαν θελη εν υμιν ειναι πρωτος εσται υμων δουλος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.28",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 28,
      "referenceLabel": "Matthew 20:28",
      "text": "ωσπερ ο υιος του ανθρωπου ουκ ηλθεν διακονηθηναι αλλα διακονησαι και δουναι την ψυχην αυτου λυτρον αντι πολλων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.29",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 29,
      "referenceLabel": "Matthew 20:29",
      "text": "και εκπορευομενων αυτων απο ιεριχω ηκολουθησεν αυτω οχλος πολυς",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.30",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 30,
      "referenceLabel": "Matthew 20:30",
      "text": "και ιδου δυο τυφλοι καθημενοι παρα την οδον ακουσαντες οτι ιησους παραγει εκραξαν λεγοντες ελεησον ημας κυριε υιος δαυιδ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.31",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 31,
      "referenceLabel": "Matthew 20:31",
      "text": "ο δε οχλος επετιμησεν αυτοις ινα σιωπησωσιν οι δε μειζον εκραζον λεγοντες ελεησον ημας κυριε υιος δαυιδ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.32",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 32,
      "referenceLabel": "Matthew 20:32",
      "text": "και στας ο ιησους εφωνησεν αυτους και ειπεν τι θελετε ποιησω υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.33",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 33,
      "referenceLabel": "Matthew 20:33",
      "text": "λεγουσιν αυτω κυριε ινα ανοιχθωσιν ημων οι οφθαλμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.20.34",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 34,
      "referenceLabel": "Matthew 20:34",
      "text": "σπλαγχνισθεις δε ο ιησους ηψατο των οφθαλμων αυτων και ευθεως ανεβλεψαν αυτων οι οφθαλμοι και ηκολουθησαν αυτω",
      "paragraphStart": false
    }
  ]
}
