{
  "chapter": {
    "id": "ant1904:matthew.8",
    "translationId": "ant1904",
    "bookSlug": "matthew",
    "chapterNumber": 8,
    "referenceLabel": "Matthew 8",
    "summary": "Source text for Matthew 8 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:matthew.8.1",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Matthew 8:1",
      "text": "καταβαντι δε αυτω απο του ορους ηκολουθησαν αυτω οχλοι πολλοι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:matthew.8.2",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Matthew 8:2",
      "text": "και ιδου λεπρος ελθων προσεκυνει αυτω λεγων κυριε εαν θελης δυνασαι με καθαρισαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.3",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Matthew 8:3",
      "text": "και εκτεινας την χειρα ηψατο αυτου ο ιησους λεγων θελω καθαρισθητι και ευθεως εκαθαρισθη αυτου η λεπρα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.4",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Matthew 8:4",
      "text": "και λεγει αυτω ο ιησους ορα μηδενι ειπης αλλα υπαγε σεαυτον δειξον τω ιερει και προσενεγκε το δωρον ο προσεταξεν μωσης εις μαρτυριον αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.5",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Matthew 8:5",
      "text": "εισελθοντι δε αυτω εις καπερναουμ προσηλθεν αυτω εκατονταρχος παρακαλων αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.6",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Matthew 8:6",
      "text": "και λεγων κυριε ο παις μου βεβληται εν τη οικια παραλυτικος δεινως βασανιζομενος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.7",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Matthew 8:7",
      "text": "και λεγει αυτω ο ιησους εγω ελθων θεραπευσω αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.8",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Matthew 8:8",
      "text": "και αποκριθεις ο εκατονταρχος εφη κυριε ουκ ειμι ικανος ινα μου υπο την στεγην εισελθης αλλα μονον ειπε λογω και ιαθησεται ο παις μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.9",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Matthew 8:9",
      "text": "και γαρ εγω ανθρωπος ειμι υπο εξουσιαν εχων υπ εμαυτον στρατιωτας και λεγω τουτω πορευθητι και πορευεται και αλλω ερχου και ερχεται και τω δουλω μου ποιησον τουτο και ποιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.10",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Matthew 8:10",
      "text": "ακουσας δε ο ιησους εθαυμασεν και ειπεν τοις ακολουθουσιν αμην λεγω υμιν ουδε εν τω ισραηλ τοσαυτην πιστιν ευρον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.11",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Matthew 8:11",
      "text": "λεγω δε υμιν οτι πολλοι απο ανατολων και δυσμων ηξουσιν και ανακλιθησονται μετα αβρααμ και ισαακ και ιακωβ εν τη βασιλεια των ουρανων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.12",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Matthew 8:12",
      "text": "οι δε υιοι της βασιλειας εκβληθησονται εις το σκοτος το εξωτερον εκει εσται ο κλαυθμος και ο βρυγμος των οδοντων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.13",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Matthew 8:13",
      "text": "και ειπεν ο ιησους τω εκατονταρχω υπαγε και ως επιστευσας γενηθητω σοι και ιαθη ο παις αυτου εν τη ωρα εκεινη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.14",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Matthew 8:14",
      "text": "και ελθων ο ιησους εις την οικιαν πετρου ειδεν την πενθεραν αυτου βεβλημενην και πυρεσσουσαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.15",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Matthew 8:15",
      "text": "και ηψατο της χειρος αυτης και αφηκεν αυτην ο πυρετος και ηγερθη και διηκονει αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.16",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Matthew 8:16",
      "text": "οψιας δε γενομενης προσηνεγκαν αυτω δαιμονιζομενους πολλους και εξεβαλεν τα πνευματα λογω και παντας τους κακως εχοντας εθεραπευσεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.17",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Matthew 8:17",
      "text": "οπως πληρωθη το ρηθεν δια ησαιου του προφητου λεγοντος αυτος τας ασθενειας ημων ελαβεν και τας νοσους εβαστασεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.18",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Matthew 8:18",
      "text": "ιδων δε ο ιησους πολλους οχλους περι αυτον εκελευσεν απελθειν εις το περαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.19",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Matthew 8:19",
      "text": "και προσελθων εις γραμματευς ειπεν αυτω διδασκαλε ακολουθησω σοι οπου εαν απερχη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.20",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Matthew 8:20",
      "text": "και λεγει αυτω ο ιησους αι αλωπεκες φωλεους εχουσιν και τα πετεινα του ουρανου κατασκηνωσεις ο δε υιος του ανθρωπου ουκ εχει που την κεφαλην κλινη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.21",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Matthew 8:21",
      "text": "ετερος δε των μαθητων αυτου ειπεν αυτω κυριε επιτρεψον μοι πρωτον απελθειν και θαψαι τον πατερα μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.22",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Matthew 8:22",
      "text": "ο δε ιησους ειπεν αυτω ακολουθει μοι και αφες τους νεκρους θαψαι τους εαυτων νεκρους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.23",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Matthew 8:23",
      "text": "και εμβαντι αυτω εις [το] πλοιον ηκολουθησαν αυτω οι μαθηται αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.24",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Matthew 8:24",
      "text": "και ιδου σεισμος μεγας εγενετο εν τη θαλασση ωστε το πλοιον καλυπτεσθαι υπο των κυματων αυτος δε εκαθευδεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.25",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Matthew 8:25",
      "text": "και προσελθοντες οι μαθηται αυτου ηγειραν αυτον λεγοντες κυριε σωσον ημας απολλυμεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.26",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Matthew 8:26",
      "text": "και λεγει αυτοις τι δειλοι εστε ολιγοπιστοι τοτε εγερθεις επετιμησεν τοις ανεμοις και τη θαλασση και εγενετο γαληνη μεγαλη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.27",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Matthew 8:27",
      "text": "οι δε ανθρωποι εθαυμασαν λεγοντες ποταπος εστιν ουτος οτι και οι ανεμοι και η θαλασσα υπακουουσιν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.28",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Matthew 8:28",
      "text": "και ελθοντι αυτω εις το περαν εις την χωραν των γεργεσηνων υπηντησαν αυτω δυο δαιμονιζομενοι εκ των μνημειων εξερχομενοι χαλεποι λιαν ωστε μη ισχυειν τινα παρελθειν δια της οδου εκεινης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.29",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Matthew 8:29",
      "text": "και ιδου εκραξαν λεγοντες τι ημιν και σοι ιησου υιε του θεου ηλθες ωδε προ καιρου βασανισαι ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.30",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Matthew 8:30",
      "text": "ην δε μακραν απ αυτων αγελη χοιρων πολλων βοσκομενη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.31",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Matthew 8:31",
      "text": "οι δε δαιμονες παρεκαλουν αυτον λεγοντες ει εκβαλλεις ημας επιτρεψον ημιν απελθειν εις την αγελην των χοιρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.32",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Matthew 8:32",
      "text": "και ειπεν αυτοις υπαγετε οι δε εξελθοντες απηλθον εις την αγελην των χοιρων και ιδου ωρμησεν πασα η αγελη των χοιρων κατα του κρημνου εις την θαλασσαν και απεθανον εν τοις υδασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.33",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Matthew 8:33",
      "text": "οι δε βοσκοντες εφυγον και απελθοντες εις την πολιν απηγγειλαν παντα και τα των δαιμονιζομενων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:matthew.8.34",
      "translationId": "ant1904",
      "bookSlug": "matthew",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Matthew 8:34",
      "text": "και ιδου πασα η πολις εξηλθεν εις συναντησιν τω ιησου και ιδοντες αυτον παρεκαλεσαν οπως μεταβη απο των οριων αυτων",
      "paragraphStart": false
    }
  ]
}
