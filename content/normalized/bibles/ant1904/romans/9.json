{
  "chapter": {
    "id": "ant1904:romans.9",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 9,
    "referenceLabel": "Romans 9",
    "summary": "Source text for Romans 9 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.9.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Romans 9:1",
      "text": "αληθειαν λεγω εν χριστω ου ψευδομαι συμμαρτυρουσης μοι της συνειδησεως μου εν πνευματι αγιω",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.9.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Romans 9:2",
      "text": "οτι λυπη μοι εστιν μεγαλη και αδιαλειπτος οδυνη τη καρδια μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Romans 9:3",
      "text": "ηυχομην γαρ αυτος εγω αναθεμα ειναι απο του χριστου υπερ των αδελφων μου των συγγενων μου κατα σαρκα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Romans 9:4",
      "text": "οιτινες εισιν ισραηλιται ων η υιοθεσια και η δοξα και αι διαθηκαι και η νομοθεσια και η λατρεια και αι επαγγελιαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Romans 9:5",
      "text": "ων οι πατερες και εξ ων ο χριστος το κατα σαρκα ο ων επι παντων θεος ευλογητος εις τους αιωνας αμην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Romans 9:6",
      "text": "ουχ οιον δε οτι εκπεπτωκεν ο λογος του θεου ου γαρ παντες οι εξ ισραηλ ουτοι ισραηλ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Romans 9:7",
      "text": "ουδ οτι εισιν σπερμα αβρααμ παντες τεκνα αλλ εν ισαακ κληθησεται σοι σπερμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Romans 9:8",
      "text": "τουτ εστιν ου τα τεκνα της σαρκος ταυτα τεκνα του θεου αλλα τα τεκνα της επαγγελιας λογιζεται εις σπερμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Romans 9:9",
      "text": "επαγγελιας γαρ ο λογος ουτος κατα τον καιρον τουτον ελευσομαι και εσται τη σαρρα υιος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Romans 9:10",
      "text": "ου μονον δε αλλα και ρεβεκκα εξ ενος κοιτην εχουσα ισαακ του πατρος ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Romans 9:11",
      "text": "μηπω γαρ γεννηθεντων μηδε πραξαντων τι αγαθον η κακον ινα η κατ εκλογην του θεου προθεσις μενη ουκ εξ εργων αλλ εκ του καλουντος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Romans 9:12",
      "text": "ερρεθη αυτη οτι ο μειζων δουλευσει τω ελασσονι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Romans 9:13",
      "text": "καθως γεγραπται τον ιακωβ ηγαπησα τον δε ησαυ εμισησα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Romans 9:14",
      "text": "τι ουν ερουμεν μη αδικια παρα τω θεω μη γενοιτο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Romans 9:15",
      "text": "τω γαρ μωυση λεγει ελεησω ον αν ελεω και οικτειρησω ον αν οικτειρω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Romans 9:16",
      "text": "αρα ουν ου του θελοντος ουδε του τρεχοντος αλλα του ελεουντος θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Romans 9:17",
      "text": "λεγει γαρ η γραφη τω φαραω οτι εις αυτο τουτο εξηγειρα σε οπως ενδειξωμαι εν σοι την δυναμιν μου και οπως διαγγελη το ονομα μου εν παση τη γη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Romans 9:18",
      "text": "αρα ουν ον θελει ελεει ον δε θελει σκληρυνει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Romans 9:19",
      "text": "ερεις ουν μοι τι ετι μεμφεται τω γαρ βουληματι αυτου τις ανθεστηκεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Romans 9:20",
      "text": "μενουνγε ω ανθρωπε συ τις ει ο ανταποκρινομενος τω θεω μη ερει το πλασμα τω πλασαντι τι με εποιησας ουτως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Romans 9:21",
      "text": "η ουκ εχει εξουσιαν ο κεραμευς του πηλου εκ του αυτου φυραματος ποιησαι ο μεν εις τιμην σκευος ο δε εις ατιμιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Romans 9:22",
      "text": "ει δε θελων ο θεος ενδειξασθαι την οργην και γνωρισαι το δυνατον αυτου ηνεγκεν εν πολλη μακροθυμια σκευη οργης κατηρτισμενα εις απωλειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Romans 9:23",
      "text": "και ινα γνωριση τον πλουτον της δοξης αυτου επι σκευη ελεους α προητοιμασεν εις δοξαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Romans 9:24",
      "text": "ους και εκαλεσεν ημας ου μονον εξ ιουδαιων αλλα και εξ εθνων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Romans 9:25",
      "text": "ως και εν τω ωσηε λεγει καλεσω τον ου λαον μου λαον μου και την ουκ ηγαπημενην ηγαπημενην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.26",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Romans 9:26",
      "text": "και εσται εν τω τοπω ου ερρεθη αυτοις ου λαος μου υμεις εκει κληθησονται υιοι θεου ζωντος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.27",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Romans 9:27",
      "text": "ησαιας δε κραζει υπερ του ισραηλ εαν η ο αριθμος των υιων ισραηλ ως η αμμος της θαλασσης το καταλειμμα σωθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.28",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Romans 9:28",
      "text": "λογον γαρ συντελων και συντεμνων εν δικαιοσυνη οτι λογον συντετμημενον ποιησει κυριος επι της γης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.29",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Romans 9:29",
      "text": "και καθως προειρηκεν ησαιας ει μη κυριος σαβαωθ εγκατελιπεν ημιν σπερμα ως σοδομα αν εγενηθημεν και ως γομορρα αν ωμοιωθημεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.30",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Romans 9:30",
      "text": "τι ουν ερουμεν οτι εθνη τα μη διωκοντα δικαιοσυνην κατελαβεν δικαιοσυνην δικαιοσυνην δε την εκ πιστεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.31",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Romans 9:31",
      "text": "ισραηλ δε διωκων νομον δικαιοσυνης εις νομον δικαιοσυνης ουκ εφθασεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.32",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Romans 9:32",
      "text": "διατι οτι ουκ εκ πιστεως αλλ ως εξ εργων νομου προσεκοψαν γαρ τω λιθω του προσκομματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.9.33",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Romans 9:33",
      "text": "καθως γεγραπται ιδου τιθημι εν σιων λιθον προσκομματος και πετραν σκανδαλου και πας ο πιστευων επ αυτω ου καταισχυνθησεται",
      "paragraphStart": false
    }
  ]
}
