{
  "chapter": {
    "id": "ant1904:romans.7",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 7,
    "referenceLabel": "Romans 7",
    "summary": "Source text for Romans 7 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.7.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Romans 7:1",
      "text": "η αγνοειτε αδελφοι γινωσκουσιν γαρ νομον λαλω οτι ο νομος κυριευει του ανθρωπου εφ οσον χρονον ζη",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.7.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Romans 7:2",
      "text": "η γαρ υπανδρος γυνη τω ζωντι ανδρι δεδεται νομω εαν δε αποθανη ο ανηρ κατηργηται απο του νομου του ανδρος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Romans 7:3",
      "text": "αρα ουν ζωντος του ανδρος μοιχαλις χρηματισει εαν γενηται ανδρι ετερω εαν δε αποθανη ο ανηρ ελευθερα εστιν απο του νομου του μη ειναι αυτην μοιχαλιδα γενομενην ανδρι ετερω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Romans 7:4",
      "text": "ωστε αδελφοι μου και υμεις εθανατωθητε τω νομω δια του σωματος του χριστου εις το γενεσθαι υμας ετερω τω εκ νεκρων εγερθεντι ινα καρποφορησωμεν τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Romans 7:5",
      "text": "οτε γαρ ημεν εν τη σαρκι τα παθηματα των αμαρτιων τα δια του νομου ενηργειτο εν τοις μελεσιν ημων εις το καρποφορησαι τω θανατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Romans 7:6",
      "text": "νυνι δε κατηργηθημεν απο του νομου αποθανοντες εν ω κατειχομεθα ωστε δουλευειν ημας εν καινοτητι πνευματος και ου παλαιοτητι γραμματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Romans 7:7",
      "text": "τι ουν ερουμεν ο νομος αμαρτια μη γενοιτο αλλα την αμαρτιαν ουκ εγνων ει μη δια νομου την τε γαρ επιθυμιαν ουκ ηδειν ει μη ο νομος ελεγεν ουκ επιθυμησεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Romans 7:8",
      "text": "αφορμην δε λαβουσα η αμαρτια δια της εντολης κατειργασατο εν εμοι πασαν επιθυμιαν χωρις γαρ νομου αμαρτια νεκρα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Romans 7:9",
      "text": "εγω δε εζων χωρις νομου ποτε ελθουσης δε της εντολης η αμαρτια ανεζησεν εγω δε απεθανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Romans 7:10",
      "text": "και ευρεθη μοι η εντολη η εις ζωην αυτη εις θανατον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Romans 7:11",
      "text": "η γαρ αμαρτια αφορμην λαβουσα δια της εντολης εξηπατησεν με και δια αυτης απεκτεινεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Romans 7:12",
      "text": "ωστε ο μεν νομος αγιος και η εντολη αγια και δικαια και αγαθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Romans 7:13",
      "text": "το ουν αγαθον εμοι γεγονεν θανατος μη γενοιτο αλλα η αμαρτια ινα φανη αμαρτια δια του αγαθου μοι κατεργαζομενη θανατον ινα γενηται καθ υπερβολην αμαρτωλος η αμαρτια δια της εντολης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Romans 7:14",
      "text": "οιδαμεν γαρ οτι ο νομος πνευματικος εστιν εγω δε σαρκικος ειμι πεπραμενος υπο την αμαρτιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Romans 7:15",
      "text": "ο γαρ κατεργαζομαι ου γινωσκω ου γαρ ο θελω τουτο πρασσω αλλ ο μισω τουτο ποιω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Romans 7:16",
      "text": "ει δε ο ου θελω τουτο ποιω συμφημι τω νομω οτι καλος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Romans 7:17",
      "text": "νυνι δε ουκετι εγω κατεργαζομαι αυτο αλλ η οικουσα εν εμοι αμαρτια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Romans 7:18",
      "text": "οιδα γαρ οτι ουκ οικει εν εμοι τουτ εστιν εν τη σαρκι μου αγαθον το γαρ θελειν παρακειται μοι το δε κατεργαζεσθαι το καλον ουχ ευρισκω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Romans 7:19",
      "text": "ου γαρ ο θελω ποιω αγαθον αλλ ο ου θελω κακον τουτο πρασσω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Romans 7:20",
      "text": "ει δε ο ου θελω εγω τουτο ποιω ουκετι εγω κατεργαζομαι αυτο αλλ η οικουσα εν εμοι αμαρτια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Romans 7:21",
      "text": "ευρισκω αρα τον νομον τω θελοντι εμοι ποιειν το καλον οτι εμοι το κακον παρακειται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Romans 7:22",
      "text": "συνηδομαι γαρ τω νομω του θεου κατα τον εσω ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Romans 7:23",
      "text": "βλεπω δε ετερον νομον εν τοις μελεσιν μου αντιστρατευομενον τω νομω του νοος μου και αιχμαλωτιζοντα με [εν] τω νομω της αμαρτιας τω οντι εν τοις μελεσιν μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Romans 7:24",
      "text": "ταλαιπωρος εγω ανθρωπος τις με ρυσεται εκ του σωματος του θανατου τουτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.7.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Romans 7:25",
      "text": "ευχαριστω τω θεω δια ιησου χριστου του κυριου ημων αρα ουν αυτος εγω τω μεν νοι δουλευω νομω θεου τη δε σαρκι νομω αμαρτιας",
      "paragraphStart": false
    }
  ]
}
