{
  "chapter": {
    "id": "ant1904:romans.4",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 4,
    "referenceLabel": "Romans 4",
    "summary": "Source text for Romans 4 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.4.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Romans 4:1",
      "text": "τι ουν ερουμεν αβρααμ τον πατερα ημων ευρηκεναι κατα σαρκα",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.4.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Romans 4:2",
      "text": "ει γαρ αβρααμ εξ εργων εδικαιωθη εχει καυχημα αλλ ου προς τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Romans 4:3",
      "text": "τι γαρ η γραφη λεγει επιστευσεν δε αβρααμ τω θεω και ελογισθη αυτω εις δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Romans 4:4",
      "text": "τω δε εργαζομενω ο μισθος ου λογιζεται κατα χαριν αλλα κατα οφειλημα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Romans 4:5",
      "text": "τω δε μη εργαζομενω πιστευοντι δε επι τον δικαιουντα τον ασεβη λογιζεται η πιστις αυτου εις δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Romans 4:6",
      "text": "καθαπερ και δαυιδ λεγει τον μακαρισμον του ανθρωπου ω ο θεος λογιζεται δικαιοσυνην χωρις εργων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Romans 4:7",
      "text": "μακαριοι ων αφεθησαν αι ανομιαι και ων επεκαλυφθησαν αι αμαρτιαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Romans 4:8",
      "text": "μακαριος ανηρ ω ου μη λογισηται κυριος αμαρτιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Romans 4:9",
      "text": "ο μακαρισμος ουν ουτος επι την περιτομην η και επι την ακροβυστιαν λεγομεν γαρ οτι ελογισθη τω αβρααμ η πιστις εις δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Romans 4:10",
      "text": "πως ουν ελογισθη εν περιτομη οντι η εν ακροβυστια ουκ εν περιτομη αλλ εν ακροβυστια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Romans 4:11",
      "text": "και σημειον ελαβεν περιτομης σφραγιδα της δικαιοσυνης της πιστεως της εν τη ακροβυστια εις το ειναι αυτον πατερα παντων των πιστευοντων δι ακροβυστιας εις το λογισθηναι και αυτοις την δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Romans 4:12",
      "text": "και πατερα περιτομης τοις ουκ εκ περιτομης μονον αλλα και τοις στοιχουσιν τοις ιχνεσιν της εν [τη] ακροβυστια πιστεως του πατρος ημων αβρααμ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Romans 4:13",
      "text": "ου γαρ δια νομου η επαγγελια τω αβρααμ η τω σπερματι αυτου το κληρονομον αυτον ειναι του κοσμου αλλα δια δικαιοσυνης πιστεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Romans 4:14",
      "text": "ει γαρ οι εκ νομου κληρονομοι κεκενωται η πιστις και κατηργηται η επαγγελια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Romans 4:15",
      "text": "ο γαρ νομος οργην κατεργαζεται ου γαρ ουκ εστιν νομος ουδε παραβασις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Romans 4:16",
      "text": "δια τουτο εκ πιστεως ινα κατα χαριν εις το ειναι βεβαιαν την επαγγελιαν παντι τω σπερματι ου τω εκ [του] νομου μονον αλλα και τω εκ πιστεως αβρααμ ος εστιν πατηρ παντων ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Romans 4:17",
      "text": "καθως γεγραπται οτι πατερα πολλων εθνων τεθεικα σε κατεναντι ου επιστευσεν θεου του ζωοποιουντος τους νεκρους και καλουντος τα μη οντα ως οντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Romans 4:18",
      "text": "ος παρ ελπιδα επ ελπιδι επιστευσεν εις το γενεσθαι αυτον πατερα πολλων εθνων κατα το ειρημενον ουτως εσται το σπερμα σου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Romans 4:19",
      "text": "και μη ασθενησας τη πιστει ου κατενοησεν το εαυτου σωμα ηδη νενεκρωμενον εκατονταετης που υπαρχων και την νεκρωσιν μητρας σαρρας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Romans 4:20",
      "text": "εις δε την επαγγελιαν του θεου ου διεκριθη τη απιστια αλλ ενεδυναμωθη τη πιστει δους δοξαν τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Romans 4:21",
      "text": "και πληροφορηθεις οτι ο επηγγελται δυνατος εστιν και ποιησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Romans 4:22",
      "text": "διο και ελογισθη αυτω εις δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Romans 4:23",
      "text": "ουκ εγραφη δε δι αυτον μονον οτι ελογισθη αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Romans 4:24",
      "text": "αλλα και δι ημας οις μελλει λογιζεσθαι τοις πιστευουσιν επι τον εγειραντα ιησουν τον κυριον ημων εκ νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.4.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Romans 4:25",
      "text": "ος παρεδοθη δια τα παραπτωματα ημων και ηγερθη δια την δικαιωσιν ημων",
      "paragraphStart": false
    }
  ]
}
