{
  "chapter": {
    "id": "ant1904:romans.2",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 2,
    "referenceLabel": "Romans 2",
    "summary": "Source text for Romans 2 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.2.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Romans 2:1",
      "text": "διο αναπολογητος ει ω ανθρωπε πας ο κρινων εν ω γαρ κρινεις τον ετερον σεαυτον κατακρινεις τα γαρ αυτα πρασσεις ο κρινων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.2.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Romans 2:2",
      "text": "οιδαμεν δε οτι το κριμα του θεου εστιν κατα αληθειαν επι τους τα τοιαυτα πρασσοντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Romans 2:3",
      "text": "λογιζη δε τουτο ω ανθρωπε ο κρινων τους τα τοιαυτα πρασσοντας και ποιων αυτα οτι συ εκφευξη το κριμα του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Romans 2:4",
      "text": "η του πλουτου της χρηστοτητος αυτου και της ανοχης και της μακροθυμιας καταφρονεις αγνοων οτι το χρηστον του θεου εις μετανοιαν σε αγει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Romans 2:5",
      "text": "κατα δε την σκληροτητα σου και αμετανοητον καρδιαν θησαυριζεις σεαυτω οργην εν ημερα οργης και αποκαλυψεως [και] δικαιοκρισιας του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Romans 2:6",
      "text": "ος αποδωσει εκαστω κατα τα εργα αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Romans 2:7",
      "text": "τοις μεν καθ υπομονην εργου αγαθου δοξαν και τιμην και αφθαρσιαν ζητουσιν ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Romans 2:8",
      "text": "τοις δε εξ εριθειας και απειθουσιν μεν τη αληθεια πειθομενοις δε τη αδικια θυμος και οργη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Romans 2:9",
      "text": "θλιψις και στενοχωρια επι πασαν ψυχην ανθρωπου του κατεργαζομενου το κακον ιουδαιου τε πρωτον και ελληνος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Romans 2:10",
      "text": "δοξα δε και τιμη και ειρηνη παντι τω εργαζομενω το αγαθον ιουδαιω τε πρωτον και ελληνι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Romans 2:11",
      "text": "ου γαρ εστιν προσωποληψια παρα τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Romans 2:12",
      "text": "οσοι γαρ ανομως ημαρτον ανομως και απολουνται και οσοι εν νομω ημαρτον δια νομου κριθησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Romans 2:13",
      "text": "ου γαρ οι ακροαται του νομου δικαιοι παρα τω θεω αλλ οι ποιηται του νομου δικαιωθησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Romans 2:14",
      "text": "οταν γαρ εθνη τα μη νομον εχοντα φυσει τα του νομου ποιη ουτοι νομον μη εχοντες εαυτοις εισιν νομος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Romans 2:15",
      "text": "οιτινες ενδεικνυνται το εργον του νομου γραπτον εν ταις καρδιαις αυτων συμμαρτυρουσης αυτων της συνειδησεως και μεταξυ αλληλων των λογισμων κατηγορουντων η και απολογουμενων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Romans 2:16",
      "text": "εν ημερα οτε κρινει ο θεος τα κρυπτα των ανθρωπων κατα το ευαγγελιον μου δια ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Romans 2:17",
      "text": "ιδε συ ιουδαιος επονομαζη και επαναπαυη τω νομω και καυχασαι εν θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Romans 2:18",
      "text": "και γινωσκεις το θελημα και δοκιμαζεις τα διαφεροντα κατηχουμενος εκ του νομου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Romans 2:19",
      "text": "πεποιθας τε σεαυτον οδηγον ειναι τυφλων φως των εν σκοτει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Romans 2:20",
      "text": "παιδευτην αφρονων διδασκαλον νηπιων εχοντα την μορφωσιν της γνωσεως και της αληθειας εν τω νομω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Romans 2:21",
      "text": "ο ουν διδασκων ετερον σεαυτον ου διδασκεις ο κηρυσσων μη κλεπτειν κλεπτεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Romans 2:22",
      "text": "ο λεγων μη μοιχευειν μοιχευεις ο βδελυσσομενος τα ειδωλα ιεροσυλεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Romans 2:23",
      "text": "ος εν νομω καυχασαι δια της παραβασεως του νομου τον θεον ατιμαζεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Romans 2:24",
      "text": "το γαρ ονομα του θεου δι υμας βλασφημειται εν τοις εθνεσιν καθως γεγραπται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Romans 2:25",
      "text": "περιτομη μεν γαρ ωφελει εαν νομον πρασσης εαν δε παραβατης νομου ης η περιτομη σου ακροβυστια γεγονεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.26",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Romans 2:26",
      "text": "εαν ουν η ακροβυστια τα δικαιωματα του νομου φυλασση ουχι η ακροβυστια αυτου εις περιτομην λογισθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.27",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Romans 2:27",
      "text": "και κρινει η εκ φυσεως ακροβυστια τον νομον τελουσα σε τον δια γραμματος και περιτομης παραβατην νομου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.28",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Romans 2:28",
      "text": "ου γαρ ο εν τω φανερω ιουδαιος εστιν ουδε η εν τω φανερω εν σαρκι περιτομη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.2.29",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Romans 2:29",
      "text": "αλλ ο εν τω κρυπτω ιουδαιος και περιτομη καρδιας εν πνευματι ου γραμματι ου ο επαινος ουκ εξ ανθρωπων αλλ εκ του θεου",
      "paragraphStart": false
    }
  ]
}
