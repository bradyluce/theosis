{
  "chapter": {
    "id": "ant1904:romans.11",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 11,
    "referenceLabel": "Romans 11",
    "summary": "Source text for Romans 11 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.11.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Romans 11:1",
      "text": "λεγω ουν μη απωσατο ο θεος τον λαον αυτου μη γενοιτο και γαρ εγω ισραηλιτης ειμι εκ σπερματος αβρααμ φυλης βενιαμιν",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.11.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Romans 11:2",
      "text": "ουκ απωσατο ο θεος τον λαον αυτου ον προεγνω η ουκ οιδατε εν ηλια τι λεγει η γραφη ως εντυγχανει τω θεω κατα του ισραηλ λεγων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Romans 11:3",
      "text": "κυριε τους προφητας σου απεκτειναν και τα θυσιαστηρια σου κατεσκαψαν καγω υπελειφθην μονος και ζητουσιν την ψυχην μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Romans 11:4",
      "text": "αλλα τι λεγει αυτω ο χρηματισμος κατελιπον εμαυτω επτακισχιλιους ανδρας οιτινες ουκ εκαμψαν γονυ τη βααλ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Romans 11:5",
      "text": "ουτως ουν και εν τω νυν καιρω λειμμα κατ εκλογην χαριτος γεγονεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Romans 11:6",
      "text": "ει δε χαριτι ουκετι εξ εργων επει η χαρις ουκετι γινεται χαρις ει δε εξ εργων ουκετι εστιν χαρις επει το εργον ουκετι εστιν εργον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Romans 11:7",
      "text": "τι ουν ο επιζητει ισραηλ τουτο ουκ επετυχεν η δε εκλογη επετυχεν οι δε λοιποι επωρωθησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Romans 11:8",
      "text": "καθως γεγραπται εδωκεν αυτοις ο θεος πνευμα κατανυξεως οφθαλμους του μη βλεπειν και ωτα του μη ακουειν εως της σημερον ημερας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Romans 11:9",
      "text": "και δαυιδ λεγει γενηθητω η τραπεζα αυτων εις παγιδα και εις θηραν και εις σκανδαλον και εις ανταποδομα αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Romans 11:10",
      "text": "σκοτισθητωσαν οι οφθαλμοι αυτων του μη βλεπειν και τον νωτον αυτων δια παντος συγκαμψον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Romans 11:11",
      "text": "λεγω ουν μη επταισαν ινα πεσωσιν μη γενοιτο αλλα τω αυτων παραπτωματι η σωτηρια τοις εθνεσιν εις το παραζηλωσαι αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Romans 11:12",
      "text": "ει δε το παραπτωμα αυτων πλουτος κοσμου και το ηττημα αυτων πλουτος εθνων ποσω μαλλον το πληρωμα αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Romans 11:13",
      "text": "υμιν γαρ λεγω τοις εθνεσιν εφ οσον μεν ειμι εγω εθνων αποστολος την διακονιαν μου δοξαζω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Romans 11:14",
      "text": "ει πως παραζηλωσω μου την σαρκα και σωσω τινας εξ αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Romans 11:15",
      "text": "ει γαρ η αποβολη αυτων καταλλαγη κοσμου τις η προσληψις ει μη ζωη εκ νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Romans 11:16",
      "text": "ει δε η απαρχη αγια και το φυραμα και ει η ριζα αγια και οι κλαδοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Romans 11:17",
      "text": "ει δε τινες των κλαδων εξεκλασθησαν συ δε αγριελαιος ων ενεκεντρισθης εν αυτοις και συγκοινωνος της ριζης και της πιοτητος της ελαιας εγενου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Romans 11:18",
      "text": "μη κατακαυχω των κλαδων ει δε κατακαυχασαι ου συ την ριζαν βασταζεις αλλ η ριζα σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Romans 11:19",
      "text": "ερεις ουν εξεκλασθησαν [οι] κλαδοι ινα εγω εγκεντρισθω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Romans 11:20",
      "text": "καλως τη απιστια εξεκλασθησαν συ δε τη πιστει εστηκας μη υψηλοφρονει αλλα φοβου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Romans 11:21",
      "text": "ει γαρ ο θεος των κατα φυσιν κλαδων ουκ εφεισατο μη πως ουδε σου φεισεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Romans 11:22",
      "text": "ιδε ουν χρηστοτητα και αποτομιαν θεου επι μεν τους πεσοντας αποτομιαν επι δε σε χρηστοτητα εαν επιμεινης τη χρηστοτητι επει και συ εκκοπηση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Romans 11:23",
      "text": "και εκεινοι δε εαν μη επιμεινωσιν τη απιστια εγκεντρισθησονται δυνατος γαρ ο θεος εστιν παλιν εγκεντρισαι αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Romans 11:24",
      "text": "ει γαρ συ εκ της κατα φυσιν εξεκοπης αγριελαιου και παρα φυσιν ενεκεντρισθης εις καλλιελαιον ποσω μαλλον ουτοι οι κατα φυσιν εγκεντρισθησονται τη ιδια ελαια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Romans 11:25",
      "text": "ου γαρ θελω υμας αγνοειν αδελφοι το μυστηριον τουτο ινα μη ητε παρ εαυτοις φρονιμοι οτι πωρωσις απο μερους τω ισραηλ γεγονεν αχρι ου το πληρωμα των εθνων εισελθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.26",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Romans 11:26",
      "text": "και ουτως πας ισραηλ σωθησεται καθως γεγραπται ηξει εκ σιων ο ρυομενος και αποστρεψει ασεβειας απο ιακωβ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.27",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Romans 11:27",
      "text": "και αυτη αυτοις η παρ εμου διαθηκη οταν αφελωμαι τας αμαρτιας αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.28",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Romans 11:28",
      "text": "κατα μεν το ευαγγελιον εχθροι δι υμας κατα δε την εκλογην αγαπητοι δια τους πατερας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.29",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Romans 11:29",
      "text": "αμεταμελητα γαρ τα χαρισματα και η κλησις του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.30",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Romans 11:30",
      "text": "ωσπερ γαρ και υμεις ποτε ηπειθησατε τω θεω νυν δε ηλεηθητε τη τουτων απειθεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.31",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Romans 11:31",
      "text": "ουτως και ουτοι νυν ηπειθησαν τω υμετερω ελεει ινα και αυτοι ελεηθωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.32",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Romans 11:32",
      "text": "συνεκλεισεν γαρ ο θεος τους παντας εις απειθειαν ινα τους παντας ελεηση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.33",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Romans 11:33",
      "text": "ω βαθος πλουτου και σοφιας και γνωσεως θεου ως ανεξερευνητα τα κριματα αυτου και ανεξιχνιαστοι αι οδοι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.34",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 34,
      "referenceLabel": "Romans 11:34",
      "text": "τις γαρ εγνω νουν κυριου η τις συμβουλος αυτου εγενετο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.35",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 35,
      "referenceLabel": "Romans 11:35",
      "text": "η τις προεδωκεν αυτω και ανταποδοθησεται αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.11.36",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 11,
      "verseNumber": 36,
      "referenceLabel": "Romans 11:36",
      "text": "οτι εξ αυτου και δι αυτου και εις αυτον τα παντα αυτω η δοξα εις τους αιωνας αμην",
      "paragraphStart": false
    }
  ]
}
