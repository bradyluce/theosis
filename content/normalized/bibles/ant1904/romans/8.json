{
  "chapter": {
    "id": "ant1904:romans.8",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 8,
    "referenceLabel": "Romans 8",
    "summary": "Source text for Romans 8 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.8.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Romans 8:1",
      "text": "ουδεν αρα νυν κατακριμα τοις εν χριστω ιησου μη κατα σαρκα περιπατουσιν αλλα κατα πνευμα",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.8.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Romans 8:2",
      "text": "ο γαρ νομος του πνευματος της ζωης εν χριστω ιησου ηλευθερωσεν με απο του νομου της αμαρτιας και του θανατου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Romans 8:3",
      "text": "το γαρ αδυνατον του νομου εν ω ησθενει δια της σαρκος ο θεος τον εαυτου υιον πεμψας εν ομοιωματι σαρκος αμαρτιας και περι αμαρτιας κατεκρινεν την αμαρτιαν εν τη σαρκι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Romans 8:4",
      "text": "ινα το δικαιωμα του νομου πληρωθη εν ημιν τοις μη κατα σαρκα περιπατουσιν αλλα κατα πνευμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Romans 8:5",
      "text": "οι γαρ κατα σαρκα οντες τα της σαρκος φρονουσιν οι δε κατα πνευμα τα του πνευματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Romans 8:6",
      "text": "το γαρ φρονημα της σαρκος θανατος το δε φρονημα του πνευματος ζωη και ειρηνη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Romans 8:7",
      "text": "διοτι το φρονημα της σαρκος εχθρα εις θεον τω γαρ νομω του θεου ουχ υποτασσεται ουδε γαρ δυναται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Romans 8:8",
      "text": "οι δε εν σαρκι οντες θεω αρεσαι ου δυνανται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Romans 8:9",
      "text": "υμεις δε ουκ εστε εν σαρκι αλλ εν πνευματι ειπερ πνευμα θεου οικει εν υμιν ει δε τις πνευμα χριστου ουκ εχει ουτος ουκ εστιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Romans 8:10",
      "text": "ει δε χριστος εν υμιν το μεν σωμα νεκρον δι αμαρτιαν το δε πνευμα ζωη δια δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Romans 8:11",
      "text": "ει δε το πνευμα του εγειραντος ιησουν εκ νεκρων οικει εν υμιν ο εγειρας τον χριστον εκ νεκρων ζωοποιησει και τα θνητα σωματα υμων δια το ενοικουν αυτου πνευμα εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Romans 8:12",
      "text": "αρα ουν αδελφοι οφειλεται εσμεν ου τη σαρκι του κατα σαρκα ζην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Romans 8:13",
      "text": "ει γαρ κατα σαρκα ζητε μελλετε αποθνησκειν ει δε πνευματι τας πραξεις του σωματος θανατουτε ζησεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Romans 8:14",
      "text": "οσοι γαρ πνευματι θεου αγονται ουτοι εισιν υιοι θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Romans 8:15",
      "text": "ου γαρ ελαβετε πνευμα δουλειας παλιν εις φοβον αλλ ελαβετε πνευμα υιοθεσιας εν ω κραζομεν αββα ο πατηρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Romans 8:16",
      "text": "αυτο το πνευμα συμμαρτυρει τω πνευματι ημων οτι εσμεν τεκνα θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Romans 8:17",
      "text": "ει δε τεκνα και κληρονομοι κληρονομοι μεν θεου συγκληρονομοι δε χριστου ειπερ συμπασχομεν ινα και συνδοξασθωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Romans 8:18",
      "text": "λογιζομαι γαρ οτι ουκ αξια τα παθηματα του νυν καιρου προς την μελλουσαν δοξαν αποκαλυφθηναι εις ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Romans 8:19",
      "text": "η γαρ αποκαραδοκια της κτισεως την αποκαλυψιν των υιων του θεου απεκδεχεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Romans 8:20",
      "text": "τη γαρ ματαιοτητι η κτισις υπεταγη ουχ εκουσα αλλα δια τον υποταξαντα επ ελπιδι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Romans 8:21",
      "text": "οτι και αυτη η κτισις ελευθερωθησεται απο της δουλειας της φθορας εις την ελευθεριαν της δοξης των τεκνων του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Romans 8:22",
      "text": "οιδαμεν γαρ οτι πασα η κτισις συστεναζει και συνωδινει αχρι του νυν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Romans 8:23",
      "text": "ου μονον δε αλλα και αυτοι την απαρχην του πνευματος εχοντες και ημεις αυτοι εν εαυτοις στεναζομεν υιοθεσιαν απεκδεχομενοι την απολυτρωσιν του σωματος ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Romans 8:24",
      "text": "τη γαρ ελπιδι εσωθημεν ελπις δε βλεπομενη ουκ εστιν ελπις ο γαρ βλεπει τις τι και ελπιζει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Romans 8:25",
      "text": "ει δε ο ου βλεπομεν ελπιζομεν δι υπομονης απεκδεχομεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.26",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Romans 8:26",
      "text": "ωσαυτως δε και το πνευμα συναντιλαμβανεται ταις ασθενειαις ημων το γαρ τι προσευξομεθα καθο δει ουκ οιδαμεν αλλ αυτο το πνευμα υπερεντυγχανει υπερ ημων στεναγμοις αλαλητοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.27",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Romans 8:27",
      "text": "ο δε ερευνων τας καρδιας οιδεν τι το φρονημα του πνευματος οτι κατα θεον εντυγχανει υπερ αγιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.28",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Romans 8:28",
      "text": "οιδαμεν δε οτι τοις αγαπωσιν τον θεον παντα συνεργει εις αγαθον τοις κατα προθεσιν κλητοις ουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.29",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Romans 8:29",
      "text": "οτι ους προεγνω και προωρισεν συμμορφους της εικονος του υιου αυτου εις το ειναι αυτον πρωτοτοκον εν πολλοις αδελφοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.30",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Romans 8:30",
      "text": "ους δε προωρισεν τουτους και εκαλεσεν και ους εκαλεσεν τουτους και εδικαιωσεν ους δε εδικαιωσεν τουτους και εδοξασεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.31",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Romans 8:31",
      "text": "τι ουν ερουμεν προς ταυτα ει ο θεος υπερ ημων τις καθ ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.32",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Romans 8:32",
      "text": "ος γε του ιδιου υιου ουκ εφεισατο αλλ υπερ ημων παντων παρεδωκεν αυτον πως ουχι και συν αυτω τα παντα ημιν χαρισεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.33",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Romans 8:33",
      "text": "τις εγκαλεσει κατα εκλεκτων θεου θεος ο δικαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.34",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Romans 8:34",
      "text": "τις ο κατακρινων χριστος ο αποθανων μαλλον δε και εγερθεις ος και εστιν εν δεξια του θεου ος και εντυγχανει υπερ ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.35",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Romans 8:35",
      "text": "τις ημας χωρισει απο της αγαπης του χριστου θλιψις η στενοχωρια η διωγμος η λιμος η γυμνοτης η κινδυνος η μαχαιρα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.36",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Romans 8:36",
      "text": "καθως γεγραπται οτι ενεκα σου θανατουμεθα ολην την ημεραν ελογισθημεν ως προβατα σφαγης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.37",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "Romans 8:37",
      "text": "αλλ εν τουτοις πασιν υπερνικωμεν δια του αγαπησαντος ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.38",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 38,
      "referenceLabel": "Romans 8:38",
      "text": "πεπεισμαι γαρ οτι ουτε θανατος ουτε ζωη ουτε αγγελοι ουτε αρχαι ουτε δυναμεις ουτε ενεστωτα ουτε μελλοντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.8.39",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 8,
      "verseNumber": 39,
      "referenceLabel": "Romans 8:39",
      "text": "ουτε υψωμα ουτε βαθος ουτε τις κτισις ετερα δυνησεται ημας χωρισαι απο της αγαπης του θεου της εν χριστω ιησου τω κυριω ημων",
      "paragraphStart": false
    }
  ]
}
