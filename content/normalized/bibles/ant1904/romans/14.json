{
  "chapter": {
    "id": "ant1904:romans.14",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 14,
    "referenceLabel": "Romans 14",
    "summary": "Source text for Romans 14 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.14.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Romans 14:1",
      "text": "τον δε ασθενουντα τη πιστει προσλαμβανεσθε μη εις διακρισεις διαλογισμων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.14.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Romans 14:2",
      "text": "ος μεν πιστευει φαγειν παντα ο δε ασθενων λαχανα εσθιει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Romans 14:3",
      "text": "ο εσθιων τον μη εσθιοντα μη εξουθενειτω και ο μη εσθιων τον εσθιοντα μη κρινετω ο θεος γαρ αυτον προσελαβετο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Romans 14:4",
      "text": "συ τις ει ο κρινων αλλοτριον οικετην τω ιδιω κυριω στηκει η πιπτει σταθησεται δε δυνατος γαρ εστιν ο θεος στησαι αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Romans 14:5",
      "text": "ος μεν κρινει ημεραν παρ ημεραν ος δε κρινει πασαν ημεραν εκαστος εν τω ιδιω νοι πληροφορεισθω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Romans 14:6",
      "text": "ο φρονων την ημεραν κυριω φρονει και ο μη φρονων την ημεραν κυριω ου φρονει και ο εσθιων κυριω εσθιει ευχαριστει γαρ τω θεω και ο μη εσθιων κυριω ουκ εσθιει και ευχαριστει τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Romans 14:7",
      "text": "ουδεις γαρ ημων εαυτω ζη και ουδεις εαυτω αποθνησκει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Romans 14:8",
      "text": "εαν τε γαρ ζωμεν τω κυριω ζωμεν εαν τε αποθνησκωμεν τω κυριω αποθνησκομεν εαν τε ουν ζωμεν εαν τε αποθνησκωμεν του κυριου εσμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Romans 14:9",
      "text": "εις τουτο γαρ χριστος και απεθανεν και ανεστη και εζησεν ινα και νεκρων και ζωντων κυριευση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Romans 14:10",
      "text": "συ δε τι κρινεις τον αδελφον σου η και συ τι εξουθενεις τον αδελφον σου παντες γαρ παραστησομεθα τω βηματι του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Romans 14:11",
      "text": "γεγραπται γαρ ζω εγω λεγει κυριος οτι εμοι καμψει παν γονυ και πασα γλωσσα εξομολογησεται τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Romans 14:12",
      "text": "αρα ουν εκαστος ημων περι εαυτου λογον δωσει τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Romans 14:13",
      "text": "μηκετι ουν αλληλους κρινωμεν αλλα τουτο κρινατε μαλλον το μη τιθεναι προσκομμα τω αδελφω η σκανδαλον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Romans 14:14",
      "text": "οιδα και πεπεισμαι εν κυριω ιησου οτι ουδεν κοινον δι αυτου ει μη τω λογιζομενω τι κοινον ειναι εκεινω κοινον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Romans 14:15",
      "text": "ει δε δια βρωμα ο αδελφος σου λυπειται ουκετι κατα αγαπην περιπατεις μη τω βρωματι σου εκεινον απολλυε υπερ ου χριστος απεθανεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Romans 14:16",
      "text": "μη βλασφημεισθω ουν υμων το αγαθον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Romans 14:17",
      "text": "ου γαρ εστιν η βασιλεια του θεου βρωσις και ποσις αλλα δικαιοσυνη και ειρηνη και χαρα εν πνευματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Romans 14:18",
      "text": "ο γαρ εν τουτοις δουλευων τω χριστω ευαρεστος τω θεω και δοκιμος τοις ανθρωποις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Romans 14:19",
      "text": "αρα ουν τα της ειρηνης διωκωμεν και τα της οικοδομης της εις αλληλους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Romans 14:20",
      "text": "μη ενεκεν βρωματος καταλυε το εργον του θεου παντα μεν καθαρα αλλα κακον τω ανθρωπω τω δια προσκομματος εσθιοντι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Romans 14:21",
      "text": "καλον το μη φαγειν κρεα μηδε πιειν οινον μηδε εν ω ο αδελφος σου προσκοπτει η σκανδαλιζεται η ασθενει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Romans 14:22",
      "text": "συ πιστιν εχεις κατα σεαυτον εχε ενωπιον του θεου μακαριος ο μη κρινων εαυτον εν ω δοκιμαζει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Romans 14:23",
      "text": "ο δε διακρινομενος εαν φαγη κατακεκριται οτι ουκ εκ πιστεως παν δε ο ουκ εκ πιστεως αμαρτια εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Romans 14:24",
      "text": "(:) τω δε δυναμενω υμας στηριξαι κατα το ευαγγελιον μου και το κηρυγμα ιησου χριστου κατα αποκαλυψιν μυστηριου χρονοις αιωνιοις σεσιγημενου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Romans 14:25",
      "text": "(:) φανερωθεντος δε νυν δια τε γραφων προφητικων κατ επιταγην του αιωνιου θεου εις υπακοην πιστεως εις παντα τα εθνη γνωρισθεντος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.14.26",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Romans 14:26",
      "text": "(:) μονω σοφω θεω δια ιησου χριστου ω η δοξα εις τους αιωνας αμην",
      "paragraphStart": false
    }
  ]
}
