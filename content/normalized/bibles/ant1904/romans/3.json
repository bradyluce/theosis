{
  "chapter": {
    "id": "ant1904:romans.3",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 3,
    "referenceLabel": "Romans 3",
    "summary": "Source text for Romans 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.3.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Romans 3:1",
      "text": "τι ουν το περισσον του ιουδαιου η τις η ωφελεια της περιτομης",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.3.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Romans 3:2",
      "text": "πολυ κατα παντα τροπον πρωτον μεν γαρ οτι επιστευθησαν τα λογια του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Romans 3:3",
      "text": "τι γαρ ει ηπιστησαν τινες μη η απιστια αυτων την πιστιν του θεου καταργησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Romans 3:4",
      "text": "μη γενοιτο γινεσθω δε ο θεος αληθης πας δε ανθρωπος ψευστης καθως γεγραπται οπως αν δικαιωθης εν τοις λογοις σου και νικησεις εν τω κρινεσθαι σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Romans 3:5",
      "text": "ει δε η αδικια ημων θεου δικαιοσυνην συνιστησιν τι ερουμεν μη αδικος ο θεος ο επιφερων την οργην κατα ανθρωπον λεγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Romans 3:6",
      "text": "μη γενοιτο επει πως κρινει ο θεος τον κοσμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Romans 3:7",
      "text": "ει γαρ η αληθεια του θεου εν τω εμω ψευσματι επερισσευσεν εις την δοξαν αυτου τι ετι καγω ως αμαρτωλος κρινομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Romans 3:8",
      "text": "και μη καθως βλασφημουμεθα και καθως φασιν τινες ημας λεγειν οτι ποιησωμεν τα κακα ινα ελθη τα αγαθα ων το κριμα ενδικον εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Romans 3:9",
      "text": "τι ουν προεχομεθα ου παντως προητιασαμεθα γαρ ιουδαιους τε και ελληνας παντας υφ αμαρτιαν ειναι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Romans 3:10",
      "text": "καθως γεγραπται οτι ουκ εστιν δικαιος ουδε εις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Romans 3:11",
      "text": "ουκ εστιν ο συνιων ουκ εστιν ο εκζητων τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Romans 3:12",
      "text": "παντες εξεκλιναν αμα ηχρειωθησαν ουκ εστιν ποιων χρηστοτητα ουκ εστιν εως ενος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Romans 3:13",
      "text": "ταφος ανεωγμενος ο λαρυγξ αυτων ταις γλωσσαις αυτων εδολιουσαν ιος ασπιδων υπο τα χειλη αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Romans 3:14",
      "text": "ων το στομα αρας και πικριας γεμει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Romans 3:15",
      "text": "οξεις οι ποδες αυτων εκχεαι αιμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Romans 3:16",
      "text": "συντριμμα και ταλαιπωρια εν ταις οδοις αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Romans 3:17",
      "text": "και οδον ειρηνης ουκ εγνωσαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Romans 3:18",
      "text": "ουκ εστιν φοβος θεου απεναντι των οφθαλμων αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Romans 3:19",
      "text": "οιδαμεν δε οτι οσα ο νομος λεγει τοις εν τω νομω λαλει ινα παν στομα φραγη και υποδικος γενηται πας ο κοσμος τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Romans 3:20",
      "text": "διοτι εξ εργων νομου ου δικαιωθησεται πασα σαρξ ενωπιον αυτου δια γαρ νομου επιγνωσις αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Romans 3:21",
      "text": "νυνι δε χωρις νομου δικαιοσυνη θεου πεφανερωται μαρτυρουμενη υπο του νομου και των προφητων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Romans 3:22",
      "text": "δικαιοσυνη δε θεου δια πιστεως ιησου χριστου εις παντας και επι παντας τους πιστευοντας ου γαρ εστιν διαστολη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Romans 3:23",
      "text": "παντες γαρ ημαρτον και υστερουνται της δοξης του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.24",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Romans 3:24",
      "text": "δικαιουμενοι δωρεαν τη αυτου χαριτι δια της απολυτρωσεως της εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.25",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Romans 3:25",
      "text": "ον προεθετο ο θεος ιλαστηριον δια της πιστεως εν τω αυτου αιματι εις ενδειξιν της δικαιοσυνης αυτου δια την παρεσιν των προγεγονοτων αμαρτηματων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.26",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Romans 3:26",
      "text": "εν τη ανοχη του θεου προς ενδειξιν της δικαιοσυνης αυτου εν τω νυν καιρω εις το ειναι αυτον δικαιον και δικαιουντα τον εκ πιστεως ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.27",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Romans 3:27",
      "text": "που ουν η καυχησις εξεκλεισθη δια ποιου νομου των εργων ουχι αλλα δια νομου πιστεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.28",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Romans 3:28",
      "text": "λογιζομεθα ουν πιστει δικαιουσθαι ανθρωπον χωρις εργων νομου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.29",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Romans 3:29",
      "text": "η ιουδαιων ο θεος μονον ουχι δε και εθνων ναι και εθνων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.30",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Romans 3:30",
      "text": "επειπερ εις ο θεος ος δικαιωσει περιτομην εκ πιστεως και ακροβυστιαν δια της πιστεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.3.31",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Romans 3:31",
      "text": "νομον ουν καταργουμεν δια της πιστεως μη γενοιτο αλλα νομον ιστωμεν",
      "paragraphStart": false
    }
  ]
}
