{
  "chapter": {
    "id": "ant1904:romans.6",
    "translationId": "ant1904",
    "bookSlug": "romans",
    "chapterNumber": 6,
    "referenceLabel": "Romans 6",
    "summary": "Source text for Romans 6 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:romans.6.1",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Romans 6:1",
      "text": "τι ουν ερουμεν επιμενουμεν τη αμαρτια ινα η χαρις πλεοναση",
      "paragraphStart": true
    },
    {
      "id": "ant1904:romans.6.2",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Romans 6:2",
      "text": "μη γενοιτο οιτινες απεθανομεν τη αμαρτια πως ετι ζησομεν εν αυτη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.3",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Romans 6:3",
      "text": "η αγνοειτε οτι οσοι εβαπτισθημεν εις χριστον ιησουν εις τον θανατον αυτου εβαπτισθημεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.4",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Romans 6:4",
      "text": "συνεταφημεν ουν αυτω δια του βαπτισματος εις τον θανατον ινα ωσπερ ηγερθη χριστος εκ νεκρων δια της δοξης του πατρος ουτως και ημεις εν καινοτητι ζωης περιπατησωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.5",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Romans 6:5",
      "text": "ει γαρ συμφυτοι γεγοναμεν τω ομοιωματι του θανατου αυτου αλλα και της αναστασεως εσομεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.6",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Romans 6:6",
      "text": "τουτο γινωσκοντες οτι ο παλαιος ημων ανθρωπος συνεσταυρωθη ινα καταργηθη το σωμα της αμαρτιας του μηκετι δουλευειν ημας τη αμαρτια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.7",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Romans 6:7",
      "text": "ο γαρ αποθανων δεδικαιωται απο της αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.8",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Romans 6:8",
      "text": "ει δε απεθανομεν συν χριστω πιστευομεν οτι και συζησομεν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.9",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Romans 6:9",
      "text": "ειδοτες οτι χριστος εγερθεις εκ νεκρων ουκετι αποθνησκει θανατος αυτου ουκετι κυριευει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.10",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Romans 6:10",
      "text": "ο γαρ απεθανεν τη αμαρτια απεθανεν εφαπαξ ο δε ζη ζη τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.11",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Romans 6:11",
      "text": "ουτως και υμεις λογιζεσθε εαυτους νεκρους μεν ειναι τη αμαρτια ζωντας δε τω θεω εν χριστω ιησου τω κυριω ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.12",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Romans 6:12",
      "text": "μη ουν βασιλευετω η αμαρτια εν τω θνητω υμων σωματι εις το υπακουειν αυτη εν ταις επιθυμιαις αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.13",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Romans 6:13",
      "text": "μηδε παριστανετε τα μελη υμων οπλα αδικιας τη αμαρτια αλλα παραστησατε εαυτους τω θεω ως εκ νεκρων ζωντας και τα μελη υμων οπλα δικαιοσυνης τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.14",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Romans 6:14",
      "text": "αμαρτια γαρ υμων ου κυριευσει ου γαρ εστε υπο νομον αλλ υπο χαριν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.15",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Romans 6:15",
      "text": "τι ουν αμαρτησομεν οτι ουκ εσμεν υπο νομον αλλ υπο χαριν μη γενοιτο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.16",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Romans 6:16",
      "text": "ουκ οιδατε οτι ω παριστανετε εαυτους δουλους εις υπακοην δουλοι εστε ω υπακουετε ητοι αμαρτιας εις θανατον η υπακοης εις δικαιοσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.17",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Romans 6:17",
      "text": "χαρις δε τω θεω οτι ητε δουλοι της αμαρτιας υπηκουσατε δε εκ καρδιας εις ον παρεδοθητε τυπον διδαχης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.18",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Romans 6:18",
      "text": "ελευθερωθεντες δε απο της αμαρτιας εδουλωθητε τη δικαιοσυνη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.19",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Romans 6:19",
      "text": "ανθρωπινον λεγω δια την ασθενειαν της σαρκος υμων ωσπερ γαρ παρεστησατε τα μελη υμων δουλα τη ακαθαρσια και τη ανομια εις την ανομιαν ουτως νυν παραστησατε τα μελη υμων δουλα τη δικαιοσυνη εις αγιασμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.20",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Romans 6:20",
      "text": "οτε γαρ δουλοι ητε της αμαρτιας ελευθεροι ητε τη δικαιοσυνη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.21",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Romans 6:21",
      "text": "τινα ουν καρπον ειχετε τοτε εφ οις νυν επαισχυνεσθε το γαρ τελος εκεινων θανατος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.22",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Romans 6:22",
      "text": "νυνι δε ελευθερωθεντες απο της αμαρτιας δουλωθεντες δε τω θεω εχετε τον καρπον υμων εις αγιασμον το δε τελος ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:romans.6.23",
      "translationId": "ant1904",
      "bookSlug": "romans",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Romans 6:23",
      "text": "τα γαρ οψωνια της αμαρτιας θανατος το δε χαρισμα του θεου ζωη αιωνιος εν χριστω ιησου τω κυριω ημων",
      "paragraphStart": false
    }
  ]
}
