{
  "chapter": {
    "id": "ant1904:first-peter.2",
    "translationId": "ant1904",
    "bookSlug": "first-peter",
    "chapterNumber": 2,
    "referenceLabel": "1 Peter 2",
    "summary": "Source text for 1 Peter 2 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-peter.2.1",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 2:1",
      "text": "αποθεμενοι ουν πασαν κακιαν και παντα δολον και υποκρισεις και φθονους και πασας καταλαλιας",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-peter.2.2",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 2:2",
      "text": "ως αρτιγεννητα βρεφη το λογικον αδολον γαλα επιποθησατε ινα εν αυτω αυξηθητε [εις σωτηριαν]",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.3",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 2:3",
      "text": "ειπερ εγευσασθε οτι χρηστος ο κυριος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.4",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 2:4",
      "text": "προς ον προσερχομενοι λιθον ζωντα υπο ανθρωπων μεν αποδεδοκιμασμενον παρα δε θεω εκλεκτον εντιμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.5",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 2:5",
      "text": "και αυτοι ως λιθοι ζωντες οικοδομεισθε οικος πνευματικος ιερατευμα αγιον ανενεγκαι πνευματικας θυσιας ευπροσδεκτους τω θεω δια ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.6",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 2:6",
      "text": "διοτι περιεχει εν τη γραφη ιδου τιθημι εν σιων λιθον ακρογωνιαιον εκλεκτον εντιμον και ο πιστευων επ αυτω ου μη καταισχυνθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.7",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 2:7",
      "text": "υμιν ουν η τιμη τοις πιστευουσιν απειθουσιν δε λιθον ον απεδοκιμασαν οι οικοδομουντες ουτος εγενηθη εις κεφαλην γωνιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.8",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 2:8",
      "text": "και λιθος προσκομματος και πετρα σκανδαλου οι προσκοπτουσιν τω λογω απειθουντες εις ο και ετεθησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.9",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 2:9",
      "text": "υμεις δε γενος εκλεκτον βασιλειον ιερατευμα εθνος αγιον λαος εις περιποιησιν οπως τας αρετας εξαγγειλητε του εκ σκοτους υμας καλεσαντος εις το θαυμαστον αυτου φως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.10",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 2:10",
      "text": "οι ποτε ου λαος νυν δε λαος θεου οι ουκ ηλεημενοι νυν δε ελεηθεντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.11",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 2:11",
      "text": "αγαπητοι παρακαλω ως παροικους και παρεπιδημους απεχεσθε των σαρκικων επιθυμιων αιτινες στρατευονται κατα της ψυχης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.12",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 2:12",
      "text": "την αναστροφην υμων εχοντες καλην εν τοις εθνεσιν ινα εν ω καταλαλουσιν υμων ως κακοποιων εκ των καλων εργων εποπτευσαντες δοξασωσιν τον θεον εν ημερα επισκοπης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.13",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 2:13",
      "text": "υποταγητε ουν παση ανθρωπινη κτισει δια τον κυριον ειτε βασιλει ως υπερεχοντι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.14",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 2:14",
      "text": "ειτε ηγεμοσιν ως δι αυτου πεμπομενοις εις εκδικησιν [μεν] κακοποιων επαινον δε αγαθοποιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.15",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 2:15",
      "text": "οτι ουτως εστιν το θελημα του θεου αγαθοποιουντας φιμουν την των αφρονων ανθρωπων αγνωσιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.16",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 2:16",
      "text": "ως ελευθεροι και μη ως επικαλυμμα εχοντες της κακιας την ελευθεριαν αλλ ως δουλοι θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.17",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 2:17",
      "text": "παντας τιμησατε την αδελφοτητα αγαπατε τον θεον φοβεισθε τον βασιλεα τιματε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.18",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 2:18",
      "text": "οι οικεται υποτασσομενοι εν παντι φοβω τοις δεσποταις ου μονον τοις αγαθοις και επιεικεσιν αλλα και τοις σκολιοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.19",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 2:19",
      "text": "τουτο γαρ χαρις ει δια συνειδησιν θεου υποφερει τις λυπας πασχων αδικως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.20",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 Peter 2:20",
      "text": "ποιον γαρ κλεος ει αμαρτανοντες και κολαφιζομενοι υπομενειτε αλλ ει αγαθοποιουντες και πασχοντες υπομενειτε τουτο χαρις παρα θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.21",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "1 Peter 2:21",
      "text": "εις τουτο γαρ εκληθητε οτι και χριστος επαθεν υπερ ημων υμιν υπολιμπανων υπογραμμον ινα επακολουθησητε τοις ιχνεσιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.22",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "1 Peter 2:22",
      "text": "ος αμαρτιαν ουκ εποιησεν ουδε ευρεθη δολος εν τω στοματι αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.23",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "1 Peter 2:23",
      "text": "ος λοιδορουμενος ουκ αντελοιδορει πασχων ουκ ηπειλει παρεδιδου δε τω κρινοντι δικαιως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.24",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "1 Peter 2:24",
      "text": "ος τας αμαρτιας ημων αυτος ανηνεγκεν εν τω σωματι αυτου επι το ξυλον ινα ταις αμαρτιαις απογενομενοι τη δικαιοσυνη ζησωμεν ου τω μωλωπι [αυτου] ιαθητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.2.25",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "1 Peter 2:25",
      "text": "ητε γαρ ως προβατα πλανωμενα αλλ επεστραφητε νυν επι τον ποιμενα και επισκοπον των ψυχων υμων",
      "paragraphStart": false
    }
  ]
}
