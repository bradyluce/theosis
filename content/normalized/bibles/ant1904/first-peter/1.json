{
  "chapter": {
    "id": "ant1904:first-peter.1",
    "translationId": "ant1904",
    "bookSlug": "first-peter",
    "chapterNumber": 1,
    "referenceLabel": "1 Peter 1",
    "summary": "Source text for 1 Peter 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-peter.1.1",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 1:1",
      "text": "πετρος αποστολος ιησου χριστου εκλεκτοις παρεπιδημοις διασπορας ποντου γαλατιας καππαδοκιας ασιας και βιθυνιας",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-peter.1.2",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 1:2",
      "text": "κατα προγνωσιν θεου πατρος εν αγιασμω πνευματος εις υπακοην και ραντισμον αιματος ιησου χριστου χαρις υμιν και ειρηνη πληθυνθειη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.3",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 1:3",
      "text": "ευλογητος ο θεος και πατηρ του κυριου ημων ιησου χριστου ο κατα το πολυ αυτου ελεος αναγεννησας ημας εις ελπιδα ζωσαν δι αναστασεως ιησου χριστου εκ νεκρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.4",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 1:4",
      "text": "εις κληρονομιαν αφθαρτον και αμιαντον και αμαραντον τετηρημενην εν ουρανοις εις υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.5",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 1:5",
      "text": "τους εν δυναμει θεου φρουρουμενους δια πιστεως εις σωτηριαν ετοιμην αποκαλυφθηναι εν καιρω εσχατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.6",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 1:6",
      "text": "εν ω αγαλλιασθε ολιγον αρτι ει δεον εστιν λυπηθεντες εν ποικιλοις πειρασμοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.7",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 1:7",
      "text": "ινα το δοκιμιον υμων της πιστεως πολυτιμοτερον χρυσιου του απολλυμενου δια πυρος δε δοκιμαζομενου ευρεθη εις επαινον και τιμην και δοξαν εν αποκαλυψει ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.8",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 1:8",
      "text": "ον ουκ ειδοτες αγαπατε εις ον αρτι μη ορωντες πιστευοντες δε αγαλλιασθε χαρα ανεκλαλητω και δεδοξασμενη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.9",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 1:9",
      "text": "κομιζομενοι το τελος της πιστεως υμων σωτηριαν ψυχων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.10",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 1:10",
      "text": "περι ης σωτηριας εξεζητησαν και εξηρευνησαν προφηται οι περι της εις υμας χαριτος προφητευσαντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.11",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 1:11",
      "text": "ερευνωντες εις τινα η ποιον καιρον εδηλου το εν αυτοις πνευμα χριστου προμαρτυρομενον τα εις χριστον παθηματα και τας μετα ταυτα δοξας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.12",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 1:12",
      "text": "οις απεκαλυφθη οτι ουχ εαυτοις υμιν δε διηκονουν αυτα α νυν ανηγγελη υμιν δια των ευαγγελισαμενων υμας εν πνευματι αγιω αποσταλεντι απ ουρανου εις α επιθυμουσιν αγγελοι παρακυψαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.13",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 1:13",
      "text": "διο αναζωσαμενοι τας οσφυας της διανοιας υμων νηφοντες τελειως ελπισατε επι την φερομενην υμιν χαριν εν αποκαλυψει ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.14",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 1:14",
      "text": "ως τεκνα υπακοης μη συσχηματιζομενοι ταις προτερον εν τη αγνοια υμων επιθυμιαις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.15",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Peter 1:15",
      "text": "αλλα κατα τον καλεσαντα υμας αγιον και αυτοι αγιοι εν παση αναστροφη γενηθητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.16",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Peter 1:16",
      "text": "διοτι γεγραπται αγιοι γινεσθε οτι εγω αγιος ειμι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.17",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Peter 1:17",
      "text": "και ει πατερα επικαλεισθε τον απροσωποληπτως κρινοντα κατα το εκαστου εργον εν φοβω τον της παροικιας υμων χρονον αναστραφητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.18",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Peter 1:18",
      "text": "ειδοτες οτι ου φθαρτοις αργυριω η χρυσιω ελυτρωθητε εκ της ματαιας υμων αναστροφης πατροπαραδοτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.19",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Peter 1:19",
      "text": "αλλα τιμιω αιματι ως αμνου αμωμου και ασπιλου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.20",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Peter 1:20",
      "text": "προεγνωσμενου μεν προ καταβολης κοσμου φανερωθεντος δε επ εσχατων των χρονων δι υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.21",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Peter 1:21",
      "text": "τους δι αυτου πιστευοντας εις θεον τον εγειραντα αυτον εκ νεκρων και δοξαν αυτω δοντα ωστε την πιστιν υμων και ελπιδα ειναι εις θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.22",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Peter 1:22",
      "text": "τας ψυχας υμων ηγνικοτες εν τη υπακοη της αληθειας δια πνευματος εις φιλαδελφιαν ανυποκριτον εκ καθαρας καρδιας αλληλους αγαπησατε εκτενως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.23",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Peter 1:23",
      "text": "αναγεγεννημενοι ουκ εκ σπορας φθαρτης αλλα αφθαρτου δια λογου ζωντος θεου και μενοντος εις τον αιωνα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.24",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Peter 1:24",
      "text": "διοτι πασα σαρξ ως χορτος και πασα δοξα ανθρωπου ως ανθος χορτου εξηρανθη ο χορτος και το ανθος αυτου εξεπεσεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.1.25",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Peter 1:25",
      "text": "το δε ρημα κυριου μενει εις τον αιωνα τουτο δε εστιν το ρημα το ευαγγελισθεν εις υμας",
      "paragraphStart": false
    }
  ]
}
