{
  "chapter": {
    "id": "ant1904:first-peter.5",
    "translationId": "ant1904",
    "bookSlug": "first-peter",
    "chapterNumber": 5,
    "referenceLabel": "1 Peter 5",
    "summary": "Source text for 1 Peter 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-peter.5.1",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Peter 5:1",
      "text": "πρεσβυτερους τους εν υμιν παρακαλω ο συμπρεσβυτερος και μαρτυς των του χριστου παθηματων ο και της μελλουσης αποκαλυπτεσθαι δοξης κοινωνος",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-peter.5.2",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Peter 5:2",
      "text": "ποιμανατε το εν υμιν ποιμνιον του θεου επισκοπουντες μη αναγκαστως αλλ εκουσιως μηδε αισχροκερδως αλλα προθυμως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.3",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Peter 5:3",
      "text": "μηδ ως κατακυριευοντες των κληρων αλλα τυποι γινομενοι του ποιμνιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.4",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Peter 5:4",
      "text": "και φανερωθεντος του αρχιποιμενος κομιεισθε τον αμαραντινον της δοξης στεφανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.5",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Peter 5:5",
      "text": "ομοιως νεωτεροι υποταγητε πρεσβυτεροις παντες δε αλληλοις υποτασσομενοι την ταπεινοφροσυνην εγκομβωσασθε οτι ο θεος υπερηφανοις αντιτασσεται ταπεινοις δε διδωσιν χαριν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.6",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Peter 5:6",
      "text": "ταπεινωθητε ουν υπο την κραταιαν χειρα του θεου ινα υμας υψωση εν καιρω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.7",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Peter 5:7",
      "text": "πασαν την μεριμναν υμων επιρριψαντες επ αυτον οτι αυτω μελει περι υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.8",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Peter 5:8",
      "text": "νηψατε γρηγορησατε ο αντιδικος υμων διαβολος ως λεων ωρυομενος περιπατει ζητων τινα καταπιη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.9",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Peter 5:9",
      "text": "ω αντιστητε στερεοι τη πιστει ειδοτες τα αυτα των παθηματων τη εν κοσμω υμων αδελφοτητι επιτελεισθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.10",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Peter 5:10",
      "text": "ο δε θεος πασης χαριτος ο καλεσας υμας εις την αιωνιον αυτου δοξαν εν χριστω ιησου ολιγον παθοντας αυτος καταρτισει υμας στηριξει σθενωσει θεμελιωσει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.11",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Peter 5:11",
      "text": "αυτω η δοξα και το κρατος εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.12",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Peter 5:12",
      "text": "δια σιλουανου υμιν του πιστου αδελφου ως λογιζομαι δι ολιγων εγραψα παρακαλων και επιμαρτυρων ταυτην ειναι αληθη χαριν του θεου εις ην εστηκατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.13",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Peter 5:13",
      "text": "ασπαζεται υμας η εν βαβυλωνι συνεκλεκτη και μαρκος ο υιος μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-peter.5.14",
      "translationId": "ant1904",
      "bookSlug": "first-peter",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Peter 5:14",
      "text": "ασπασασθε αλληλους εν φιληματι αγαπης ειρηνη υμιν πασιν τοις εν χριστω ιησου αμην",
      "paragraphStart": false
    }
  ]
}
