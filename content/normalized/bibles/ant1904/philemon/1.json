{
  "chapter": {
    "id": "ant1904:philemon.1",
    "translationId": "ant1904",
    "bookSlug": "philemon",
    "chapterNumber": 1,
    "referenceLabel": "Philemon 1",
    "summary": "Source text for Philemon 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:philemon.1.1",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Philemon 1:1",
      "text": "παυλος δεσμιος χριστου ιησου και τιμοθεος ο αδελφος φιλημονι τω αγαπητω και συνεργω ημων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:philemon.1.2",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Philemon 1:2",
      "text": "και απφια τη αγαπητη και αρχιππω τω συστρατιωτη ημων και τη κατ οικον σου εκκλησια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.3",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Philemon 1:3",
      "text": "χαρις υμιν και ειρηνη απο θεου πατρος ημων και κυριου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.4",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Philemon 1:4",
      "text": "ευχαριστω τω θεω μου παντοτε μνειαν σου ποιουμενος επι των προσευχων μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.5",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Philemon 1:5",
      "text": "ακουων σου την αγαπην και την πιστιν ην εχεις προς τον κυριον ιησουν και εις παντας τους αγιους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.6",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Philemon 1:6",
      "text": "οπως η κοινωνια της πιστεως σου ενεργης γενηται εν επιγνωσει παντος αγαθου του εν ημιν εις χριστον ιησουν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.7",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Philemon 1:7",
      "text": "χαριν γαρ εχομεν πολλην και παρακλησιν επι τη αγαπη σου οτι τα σπλαγχνα των αγιων αναπεπαυται δια σου αδελφε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.8",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Philemon 1:8",
      "text": "διο πολλην εν χριστω παρρησιαν εχων επιτασσειν σοι το ανηκον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.9",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Philemon 1:9",
      "text": "δια την αγαπην μαλλον παρακαλω τοιουτος ων ως παυλος πρεσβυτης νυνι δε και δεσμιος ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.10",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Philemon 1:10",
      "text": "παρακαλω σε περι του εμου τεκνου ον εγεννησα εν τοις δεσμοις μου ονησιμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.11",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Philemon 1:11",
      "text": "τον ποτε σοι αχρηστον νυνι δε σοι και εμοι ευχρηστον ον ανεπεμψα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.12",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Philemon 1:12",
      "text": "συ δε αυτον τουτ εστιν τα εμα σπλαγχνα προσλαβου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.13",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Philemon 1:13",
      "text": "ον εγω εβουλομην προς εμαυτον κατεχειν ινα υπερ σου διακονη μοι εν τοις δεσμοις του ευαγγελιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.14",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Philemon 1:14",
      "text": "χωρις δε της σης γνωμης ουδεν ηθελησα ποιησαι ινα μη ως κατα αναγκην το αγαθον σου η αλλα κατα εκουσιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.15",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Philemon 1:15",
      "text": "ταχα γαρ δια τουτο εχωρισθη προς ωραν ινα αιωνιον αυτον απεχης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.16",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Philemon 1:16",
      "text": "ουκετι ως δουλον αλλ υπερ δουλον αδελφον αγαπητον μαλιστα εμοι ποσω δε μαλλον σοι και εν σαρκι και εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.17",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Philemon 1:17",
      "text": "ει ουν με εχεις κοινωνον προσλαβου αυτον ως εμε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.18",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Philemon 1:18",
      "text": "ει δε τι ηδικησεν σε η οφειλει τουτο εμοι ελλογει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.19",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Philemon 1:19",
      "text": "εγω παυλος εγραψα τη εμη χειρι εγω αποτισω ινα μη λεγω σοι οτι και σεαυτον μοι προσοφειλεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.20",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Philemon 1:20",
      "text": "ναι αδελφε εγω σου οναιμην εν κυριω αναπαυσον μου τα σπλαγχνα εν κυριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.21",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Philemon 1:21",
      "text": "πεποιθως τη υπακοη σου εγραψα σοι ειδως οτι και υπερ ο λεγω ποιησεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.22",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Philemon 1:22",
      "text": "αμα δε και ετοιμαζε μοι ξενιαν ελπιζω γαρ οτι δια των προσευχων υμων χαρισθησομαι υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.23",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Philemon 1:23",
      "text": "ασπαζεται σε επαφρας ο συναιχμαλωτος μου εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.24",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Philemon 1:24",
      "text": "μαρκος αρισταρχος δημας λουκας οι συνεργοι μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:philemon.1.25",
      "translationId": "ant1904",
      "bookSlug": "philemon",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Philemon 1:25",
      "text": "η χαρις του κυριου ημων ιησου χριστου μετα του πνευματος υμων αμην",
      "paragraphStart": false
    }
  ]
}
