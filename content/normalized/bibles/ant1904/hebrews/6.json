{
  "chapter": {
    "id": "ant1904:hebrews.6",
    "translationId": "ant1904",
    "bookSlug": "hebrews",
    "chapterNumber": 6,
    "referenceLabel": "Hebrews 6",
    "summary": "Source text for Hebrews 6 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:hebrews.6.1",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 6:1",
      "text": "διο αφεντες τον της αρχης του χριστου λογον επι την τελειοτητα φερωμεθα μη παλιν θεμελιον καταβαλλομενοι μετανοιας απο νεκρων εργων και πιστεως επι θεον",
      "paragraphStart": true
    },
    {
      "id": "ant1904:hebrews.6.2",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 6:2",
      "text": "βαπτισμων διδαχης επιθεσεως τε χειρων αναστασεως τε νεκρων και κριματος αιωνιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.3",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 6:3",
      "text": "και τουτο ποιησομεν εανπερ επιτρεπη ο θεος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.4",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 6:4",
      "text": "αδυνατον γαρ τους απαξ φωτισθεντας γευσαμενους τε της δωρεας της επουρανιου και μετοχους γενηθεντας πνευματος αγιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.5",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 6:5",
      "text": "και καλον γευσαμενους θεου ρημα δυναμεις τε μελλοντος αιωνος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.6",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 6:6",
      "text": "και παραπεσοντας παλιν ανακαινιζειν εις μετανοιαν ανασταυρουντας εαυτοις τον υιον του θεου και παραδειγματιζοντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.7",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 6:7",
      "text": "γη γαρ η πιουσα τον επ αυτης πολλακις ερχομενον υετον και τικτουσα βοτανην ευθετον εκεινοις δι ους και γεωργειται μεταλαμβανει ευλογιας απο του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.8",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 6:8",
      "text": "εκφερουσα δε ακανθας και τριβολους αδοκιμος και καταρας εγγυς ης το τελος εις καυσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.9",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 6:9",
      "text": "πεπεισμεθα δε περι υμων αγαπητοι τα κρειττονα και εχομενα σωτηριας ει και ουτως λαλουμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.10",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 6:10",
      "text": "ου γαρ αδικος ο θεος επιλαθεσθαι του εργου υμων και του κοπου της αγαπης ης ενεδειξασθε εις το ονομα αυτου διακονησαντες τοις αγιοις και διακονουντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.11",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 6:11",
      "text": "επιθυμουμεν δε εκαστον υμων την αυτην ενδεικνυσθαι σπουδην προς την πληροφοριαν της ελπιδος αχρι τελους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.12",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 6:12",
      "text": "ινα μη νωθροι γενησθε μιμηται δε των δια πιστεως και μακροθυμιας κληρονομουντων τας επαγγελιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.13",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 6:13",
      "text": "τω γαρ αβρααμ επαγγειλαμενος ο θεος επει κατ ουδενος ειχεν μειζονος ομοσαι ωμοσεν καθ εαυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.14",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 6:14",
      "text": "λεγων η μην ευλογων ευλογησω σε και πληθυνων πληθυνω σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.15",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 6:15",
      "text": "και ουτως μακροθυμησας επετυχεν της επαγγελιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.16",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 6:16",
      "text": "ανθρωποι μεν γαρ κατα του μειζονος ομνυουσιν και πασης αυτοις αντιλογιας περας εις βεβαιωσιν ο ορκος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.17",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 6:17",
      "text": "εν ω περισσοτερον βουλομενος ο θεος επιδειξαι τοις κληρονομοις της επαγγελιας το αμεταθετον της βουλης αυτου εμεσιτευσεν ορκω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.18",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 6:18",
      "text": "ινα δια δυο πραγματων αμεταθετων εν οις αδυνατον ψευσασθαι θεον ισχυραν παρακλησιν εχωμεν οι καταφυγοντες κρατησαι της προκειμενης ελπιδος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.19",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 6:19",
      "text": "ην ως αγκυραν εχομεν της ψυχης ασφαλη τε και βεβαιαν και εισερχομενην εις το εσωτερον του καταπετασματος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.6.20",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 6:20",
      "text": "οπου προδρομος υπερ ημων εισηλθεν ιησους κατα την ταξιν μελχισεδεκ αρχιερευς γενομενος εις τον αιωνα",
      "paragraphStart": false
    }
  ]
}
