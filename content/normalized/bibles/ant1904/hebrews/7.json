{
  "chapter": {
    "id": "ant1904:hebrews.7",
    "translationId": "ant1904",
    "bookSlug": "hebrews",
    "chapterNumber": 7,
    "referenceLabel": "Hebrews 7",
    "summary": "Source text for Hebrews 7 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:hebrews.7.1",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 7:1",
      "text": "ουτος γαρ ο μελχισεδεκ βασιλευς σαλημ ιερευς του θεου του υψιστου ο συναντησας αβρααμ υποστρεφοντι απο της κοπης των βασιλεων και ευλογησας αυτον",
      "paragraphStart": true
    },
    {
      "id": "ant1904:hebrews.7.2",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 7:2",
      "text": "ω και δεκατην απο παντων εμερισεν αβρααμ πρωτον μεν ερμηνευομενος βασιλευς δικαιοσυνης επειτα δε και βασιλευς σαλημ ο εστιν βασιλευς ειρηνης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.3",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 7:3",
      "text": "απατωρ αμητωρ αγενεαλογητος μητε αρχην ημερων μητε ζωης τελος εχων αφωμοιωμενος δε τω υιω του θεου μενει ιερευς εις το διηνεκες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.4",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 7:4",
      "text": "θεωρειτε δε πηλικος ουτος ω και δεκατην αβρααμ εδωκεν εκ των ακροθινιων ο πατριαρχης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.5",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 7:5",
      "text": "και οι μεν εκ των υιων λευι την ιερατειαν λαμβανοντες εντολην εχουσιν αποδεκατουν τον λαον κατα τον νομον τουτ εστιν τους αδελφους αυτων καιπερ εξεληλυθοτας εκ της οσφυος αβρααμ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.6",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 7:6",
      "text": "ο δε μη γενεαλογουμενος εξ αυτων δεδεκατωκεν τον αβρααμ και τον εχοντα τας επαγγελιας ευλογηκεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.7",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 7:7",
      "text": "χωρις δε πασης αντιλογιας το ελαττον υπο του κρειττονος ευλογειται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.8",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 7:8",
      "text": "και ωδε μεν δεκατας αποθνησκοντες ανθρωποι λαμβανουσιν εκει δε μαρτυρουμενος οτι ζη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.9",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 7:9",
      "text": "και ως επος ειπειν δια αβρααμ και λευι ο δεκατας λαμβανων δεδεκατωται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.10",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 7:10",
      "text": "ετι γαρ εν τη οσφυι του πατρος ην οτε συνηντησεν αυτω ο μελχισεδεκ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.11",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 7:11",
      "text": "ει μεν ουν τελειωσις δια της λευιτικης ιερωσυνης ην ο λαος γαρ επ αυτη νενομοθετητο τις ετι χρεια κατα την ταξιν μελχισεδεκ ετερον ανιστασθαι ιερεα και ου κατα την ταξιν ααρων λεγεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.12",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 7:12",
      "text": "μετατιθεμενης γαρ της ιερωσυνης εξ αναγκης και νομου μεταθεσις γινεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.13",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 7:13",
      "text": "εφ ον γαρ λεγεται ταυτα φυλης ετερας μετεσχηκεν αφ ης ουδεις προσεσχηκεν τω θυσιαστηριω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.14",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 7:14",
      "text": "προδηλον γαρ οτι εξ ιουδα ανατεταλκεν ο κυριος ημων εις ην φυλην ουδεν περι ιερωσυνης μωυσης ελαλησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.15",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 7:15",
      "text": "και περισσοτερον ετι καταδηλον εστιν ει κατα την ομοιοτητα μελχισεδεκ ανισταται ιερευς ετερος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.16",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 7:16",
      "text": "ος ου κατα νομον εντολης σαρκικης γεγονεν αλλα κατα δυναμιν ζωης ακαταλυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.17",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 7:17",
      "text": "μαρτυρει γαρ οτι συ ιερευς εις τον αιωνα κατα την ταξιν μελχισεδεκ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.18",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 7:18",
      "text": "αθετησις μεν γαρ γινεται προαγουσης εντολης δια το αυτης ασθενες και ανωφελες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.19",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 7:19",
      "text": "ουδεν γαρ ετελειωσεν ο νομος επεισαγωγη δε κρειττονος ελπιδος δι ης εγγιζομεν τω θεω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.20",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 7:20",
      "text": "και καθ οσον ου χωρις ορκωμοσιας οι μεν γαρ χωρις ορκωμοσιας εισιν ιερεις γεγονοτες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.21",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 7:21",
      "text": "ο δε μετα ορκωμοσιας δια του λεγοντος προς αυτον ωμοσεν κυριος και ου μεταμεληθησεται συ ιερευς εις τον αιωνα κατα την ταξιν μελχισεδεκ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.22",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 7:22",
      "text": "κατα τοσουτον κρειττονος διαθηκης γεγονεν εγγυος ιησους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.23",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 7:23",
      "text": "και οι μεν πλειονες εισιν γεγονοτες ιερεις δια το θανατω κωλυεσθαι παραμενειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.24",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 7:24",
      "text": "ο δε δια το μενειν αυτον εις τον αιωνα απαραβατον εχει την ιερωσυνην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.25",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 7:25",
      "text": "οθεν και σωζειν εις το παντελες δυναται τους προσερχομενους δι αυτου τω θεω παντοτε ζων εις το εντυγχανειν υπερ αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.26",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 7:26",
      "text": "τοιουτος γαρ ημιν επρεπεν αρχιερευς οσιος ακακος αμιαντος κεχωρισμενος απο των αμαρτωλων και υψηλοτερος των ουρανων γενομενος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.27",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 7:27",
      "text": "ος ουκ εχει καθ ημεραν αναγκην ωσπερ οι αρχιερεις προτερον υπερ των ιδιων αμαρτιων θυσιας αναφερειν επειτα των του λαου τουτο γαρ εποιησεν εφαπαξ εαυτον ανενεγκας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.7.28",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 7:28",
      "text": "ο νομος γαρ ανθρωπους καθιστησιν αρχιερεις εχοντας ασθενειαν ο λογος δε της ορκωμοσιας της μετα τον νομον υιον εις τον αιωνα τετελειωμενον",
      "paragraphStart": false
    }
  ]
}
