{
  "chapter": {
    "id": "ant1904:hebrews.5",
    "translationId": "ant1904",
    "bookSlug": "hebrews",
    "chapterNumber": 5,
    "referenceLabel": "Hebrews 5",
    "summary": "Source text for Hebrews 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:hebrews.5.1",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 5:1",
      "text": "πας γαρ αρχιερευς εξ ανθρωπων λαμβανομενος υπερ ανθρωπων καθισταται τα προς τον θεον ινα προσφερη δωρα τε και θυσιας υπερ αμαρτιων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:hebrews.5.2",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 5:2",
      "text": "μετριοπαθειν δυναμενος τοις αγνοουσιν και πλανωμενοις επει και αυτος περικειται ασθενειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.3",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 5:3",
      "text": "και δια ταυτην οφειλει καθως περι του λαου ουτως και περι εαυτου προσφερειν υπερ αμαρτιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.4",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 5:4",
      "text": "και ουχ εαυτω τις λαμβανει την τιμην αλλα καλουμενος υπο του θεου καθαπερ και ααρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.5",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 5:5",
      "text": "ουτως και ο χριστος ουχ εαυτον εδοξασεν γενηθηναι αρχιερεα αλλ ο λαλησας προς αυτον υιος μου ει συ εγω σημερον γεγεννηκα σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.6",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 5:6",
      "text": "καθως και εν ετερω λεγει συ ιερευς εις τον αιωνα κατα την ταξιν μελχισεδεκ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.7",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 5:7",
      "text": "ος εν ταις ημεραις της σαρκος αυτου δεησεις τε και ικετηριας προς τον δυναμενον σωζειν αυτον εκ θανατου μετα κραυγης ισχυρας και δακρυων προσενεγκας και εισακουσθεις απο της ευλαβειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.8",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 5:8",
      "text": "καιπερ ων υιος εμαθεν αφ ων επαθεν την υπακοην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.9",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 5:9",
      "text": "και τελειωθεις εγενετο τοις υπακουουσιν αυτω πασιν αιτιος σωτηριας αιωνιου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.10",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 5:10",
      "text": "προσαγορευθεις υπο του θεου αρχιερευς κατα την ταξιν μελχισεδεκ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.11",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 5:11",
      "text": "περι ου πολυς ημιν ο λογος και δυσερμηνευτος λεγειν επει νωθροι γεγονατε ταις ακοαις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.12",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 5:12",
      "text": "και γαρ οφειλοντες ειναι διδασκαλοι δια τον χρονον παλιν χρειαν εχετε του διδασκειν υμας τινα τα στοιχεια της αρχης των λογιων του θεου και γεγονατε χρειαν εχοντες γαλακτος και ου στερεας τροφης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.13",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 5:13",
      "text": "πας γαρ ο μετεχων γαλακτος απειρος λογου δικαιοσυνης νηπιος γαρ εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.5.14",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 5:14",
      "text": "τελειων δε εστιν η στερεα τροφη των δια την εξιν τα αισθητηρια γεγυμνασμενα εχοντων προς διακρισιν καλου τε και κακου",
      "paragraphStart": false
    }
  ]
}
