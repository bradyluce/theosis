{
  "chapter": {
    "id": "ant1904:hebrews.12",
    "translationId": "ant1904",
    "bookSlug": "hebrews",
    "chapterNumber": 12,
    "referenceLabel": "Hebrews 12",
    "summary": "Source text for Hebrews 12 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:hebrews.12.1",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 12:1",
      "text": "τοιγαρουν και ημεις τοσουτον εχοντες περικειμενον ημιν νεφος μαρτυρων ογκον αποθεμενοι παντα και την ευπεριστατον αμαρτιαν δι υπομονης τρεχωμεν τον προκειμενον ημιν αγωνα",
      "paragraphStart": true
    },
    {
      "id": "ant1904:hebrews.12.2",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 12:2",
      "text": "αφορωντες εις τον της πιστεως αρχηγον και τελειωτην ιησουν ος αντι της προκειμενης αυτω χαρας υπεμεινεν σταυρον αισχυνης καταφρονησας εν δεξια τε του θρονου του θεου κεκαθικεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.3",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 12:3",
      "text": "αναλογισασθε γαρ τον τοιαυτην υπομεμενηκοτα υπο των αμαρτωλων εις αυτον αντιλογιαν ινα μη καμητε ταις ψυχαις υμων εκλυομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.4",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 12:4",
      "text": "ουπω μεχρι αιματος αντικατεστητε προς την αμαρτιαν ανταγωνιζομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.5",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 12:5",
      "text": "και εκλελησθε της παρακλησεως ητις υμιν ως υιοις διαλεγεται υιε μου μη ολιγωρει παιδειας κυριου μηδε εκλυου υπ αυτου ελεγχομενος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.6",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 12:6",
      "text": "ον γαρ αγαπα κυριος παιδευει μαστιγοι δε παντα υιον ον παραδεχεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.7",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 12:7",
      "text": "ει παιδειαν υπομενετε ως υιοις υμιν προσφερεται ο θεος τις γαρ εστιν υιος ον ου παιδευει πατηρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.8",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 12:8",
      "text": "ει δε χωρις εστε παιδειας ης μετοχοι γεγονασιν παντες αρα νοθοι εστε και ουχ υιοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.9",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 12:9",
      "text": "ειτα τους μεν της σαρκος ημων πατερας ειχομεν παιδευτας και ενετρεπομεθα ου πολλω μαλλον υποταγησομεθα τω πατρι των πνευματων και ζησομεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.10",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 12:10",
      "text": "οι μεν γαρ προς ολιγας ημερας κατα το δοκουν αυτοις επαιδευον ο δε επι το συμφερον εις το μεταλαβειν της αγιοτητος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.11",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 12:11",
      "text": "πασα δε παιδεια προς μεν το παρον ου δοκει χαρας ειναι αλλα λυπης υστερον δε καρπον ειρηνικον τοις δι αυτης γεγυμνασμενοις αποδιδωσιν δικαιοσυνης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.12",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 12:12",
      "text": "διο τας παρειμενας χειρας και τα παραλελυμενα γονατα ανορθωσατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.13",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 12:13",
      "text": "και τροχιας ορθας ποιησατε τοις ποσιν υμων ινα μη το χωλον εκτραπη ιαθη δε μαλλον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.14",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 12:14",
      "text": "ειρηνην διωκετε μετα παντων και τον αγιασμον ου χωρις ουδεις οψεται τον κυριον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.15",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 12:15",
      "text": "επισκοπουντες μη τις υστερων απο της χαριτος του θεου μη τις ριζα πικριας ανω φυουσα ενοχλη και δια ταυτης μιανθωσιν πολλοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.16",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 12:16",
      "text": "μη τις πορνος η βεβηλος ως ησαυ ος αντι βρωσεως μιας απεδοτο τα πρωτοτοκια αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.17",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 12:17",
      "text": "ιστε γαρ οτι και μετεπειτα θελων κληρονομησαι την ευλογιαν απεδοκιμασθη μετανοιας γαρ τοπον ουχ ευρεν καιπερ μετα δακρυων εκζητησας αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.18",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 12:18",
      "text": "ου γαρ προσεληλυθατε ψηλαφωμενω ορει και κεκαυμενω πυρι και γνοφω και σκοτω και θυελλη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.19",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 12:19",
      "text": "και σαλπιγγος ηχω και φωνη ρηματων ης οι ακουσαντες παρητησαντο μη προστεθηναι αυτοις λογον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.20",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Hebrews 12:20",
      "text": "ουκ εφερον γαρ το διαστελλομενον καν θηριον θιγη του ορους λιθοβοληθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.21",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Hebrews 12:21",
      "text": "και ουτως φοβερον ην το φανταζομενον μωυσης ειπεν εκφοβος ειμι και εντρομος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.22",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Hebrews 12:22",
      "text": "αλλα προσεληλυθατε σιων ορει και πολει θεου ζωντος ιερουσαλημ επουρανιω και μυριασιν αγγελων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.23",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Hebrews 12:23",
      "text": "πανηγυρει και εκκλησια πρωτοτοκων εν ουρανοις απογεγραμμενων και κριτη θεω παντων και πνευμασιν δικαιων τετελειωμενων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.24",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Hebrews 12:24",
      "text": "και διαθηκης νεας μεσιτη ιησου και αιματι ραντισμου κρειττον λαλουντι παρα τον αβελ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.25",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Hebrews 12:25",
      "text": "βλεπετε μη παραιτησησθε τον λαλουντα ει γαρ εκεινοι ουκ εφυγον τον επι της γης παραιτησαμενοι χρηματιζοντα πολλω μαλλον ημεις οι τον απ ουρανων αποστρεφομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.26",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Hebrews 12:26",
      "text": "ου η φωνη την γην εσαλευσεν τοτε νυν δε επηγγελται λεγων ετι απαξ εγω σειω ου μονον την γην αλλα και τον ουρανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.27",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Hebrews 12:27",
      "text": "το δε ετι απαξ δηλοι των σαλευομενων την μεταθεσιν ως πεποιημενων ινα μεινη τα μη σαλευομενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.28",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Hebrews 12:28",
      "text": "διο βασιλειαν ασαλευτον παραλαμβανοντες εχωμεν χαριν δι ης λατρευωμεν ευαρεστως τω θεω μετα αιδους και ευλαβειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.12.29",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Hebrews 12:29",
      "text": "και γαρ ο θεος ημων πυρ καταναλισκον",
      "paragraphStart": false
    }
  ]
}
