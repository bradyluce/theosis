{
  "chapter": {
    "id": "ant1904:hebrews.3",
    "translationId": "ant1904",
    "bookSlug": "hebrews",
    "chapterNumber": 3,
    "referenceLabel": "Hebrews 3",
    "summary": "Source text for Hebrews 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:hebrews.3.1",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Hebrews 3:1",
      "text": "οθεν αδελφοι αγιοι κλησεως επουρανιου μετοχοι κατανοησατε τον αποστολον και αρχιερεα της ομολογιας ημων ιησουν χριστον",
      "paragraphStart": true
    },
    {
      "id": "ant1904:hebrews.3.2",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Hebrews 3:2",
      "text": "πιστον οντα τω ποιησαντι αυτον ως και μωυσης εν ολω τω οικω αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.3",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Hebrews 3:3",
      "text": "πλειονος γαρ δοξης ουτος παρα μωυσην ηξιωται καθ οσον πλειονα τιμην εχει του οικου ο κατασκευασας αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.4",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Hebrews 3:4",
      "text": "πας γαρ οικος κατασκευαζεται υπο τινος ο δε τα παντα κατασκευασας θεος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.5",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Hebrews 3:5",
      "text": "και μωυσης μεν πιστος εν ολω τω οικω αυτου ως θεραπων εις μαρτυριον των λαληθησομενων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.6",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Hebrews 3:6",
      "text": "χριστος δε ως υιος επι τον οικον αυτου ου οικος εσμεν ημεις εανπερ την παρρησιαν και το καυχημα της ελπιδος μεχρι τελους βεβαιαν κατασχωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.7",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Hebrews 3:7",
      "text": "διο καθως λεγει το πνευμα το αγιον σημερον εαν της φωνης αυτου ακουσητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.8",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Hebrews 3:8",
      "text": "μη σκληρυνητε τας καρδιας υμων ως εν τω παραπικρασμω κατα την ημεραν του πειρασμου εν τη ερημω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.9",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Hebrews 3:9",
      "text": "ου επειρασαν με οι πατερες υμων εδοκιμασαν με και ειδον τα εργα μου τεσσαρακοντα ετη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.10",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Hebrews 3:10",
      "text": "διο προσωχθισα τη γενεα εκεινη και ειπον αει πλανωνται τη καρδια αυτοι δε ουκ εγνωσαν τας οδους μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.11",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Hebrews 3:11",
      "text": "ως ωμοσα εν τη οργη μου ει εισελευσονται εις την καταπαυσιν μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.12",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Hebrews 3:12",
      "text": "βλεπετε αδελφοι μη ποτε εσται εν τινι υμων καρδια πονηρα απιστιας εν τω αποστηναι απο θεου ζωντος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.13",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Hebrews 3:13",
      "text": "αλλα παρακαλειτε εαυτους καθ εκαστην ημεραν αχρι ου το σημερον καλειται ινα μη σκληρυνθη εξ υμων τις απατη της αμαρτιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.14",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Hebrews 3:14",
      "text": "μετοχοι γαρ γεγοναμεν του χριστου εανπερ την αρχην της υποστασεως μεχρι τελους βεβαιαν κατασχωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.15",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Hebrews 3:15",
      "text": "εν τω λεγεσθαι σημερον εαν της φωνης αυτου ακουσητε μη σκληρυνητε τας καρδιας υμων ως εν τω παραπικρασμω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.16",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Hebrews 3:16",
      "text": "τινες γαρ ακουσαντες παρεπικραναν αλλ ου παντες οι εξελθοντες εξ αιγυπτου δια μωυσεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.17",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Hebrews 3:17",
      "text": "τισιν δε προσωχθισεν τεσσαρακοντα ετη ουχι τοις αμαρτησασιν ων τα κωλα επεσεν εν τη ερημω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.18",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Hebrews 3:18",
      "text": "τισιν δε ωμοσεν μη εισελευσεσθαι εις την καταπαυσιν αυτου ει μη τοις απειθησασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:hebrews.3.19",
      "translationId": "ant1904",
      "bookSlug": "hebrews",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Hebrews 3:19",
      "text": "και βλεπομεν οτι ουκ ηδυνηθησαν εισελθειν δι απιστιαν",
      "paragraphStart": false
    }
  ]
}
