{
  "chapter": {
    "id": "ant1904:second-thessalonians.2",
    "translationId": "ant1904",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 2,
    "referenceLabel": "2 Thessalonians 2",
    "summary": "Source text for 2 Thessalonians 2 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-thessalonians.2.1",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 2:1",
      "text": "ερωτωμεν δε υμας αδελφοι υπερ της παρουσιας του κυριου ημων ιησου χριστου και ημων επισυναγωγης επ αυτον",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-thessalonians.2.2",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 2:2",
      "text": "εις το μη ταχεως σαλευθηναι υμας απο του νοος μητε θροεισθαι μητε δια του πνευματος μητε δια λογου μητε δι επιστολης ως δι ημων ως οτι ενεστηκεν η ημερα του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.3",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 2:3",
      "text": "μη τις υμας εξαπατηση κατα μηδενα τροπον οτι εαν μη ελθη η αποστασια πρωτον και αποκαλυφθη ο ανθρωπος της αμαρτιας ο υιος της απωλειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.4",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 2:4",
      "text": "ο αντικειμενος και υπεραιρομενος επι παντα λεγομενον θεον η σεβασμα ωστε αυτον εις τον ναον του θεου ως θεον καθισαι αποδεικνυντα εαυτον οτι εστιν θεος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.5",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 2:5",
      "text": "ου μνημονευετε οτι ετι ων προς υμας ταυτα ελεγον υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.6",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 2:6",
      "text": "και νυν το κατεχον οιδατε εις το αποκαλυφθηναι αυτον εν τω εαυτου καιρω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.7",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 2:7",
      "text": "το γαρ μυστηριον ηδη ενεργειται της ανομιας μονον ο κατεχων αρτι εως εκ μεσου γενηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.8",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 2:8",
      "text": "και τοτε αποκαλυφθησεται ο ανομος ον ο κυριος αναλωσει τω πνευματι του στοματος αυτου και καταργησει τη επιφανεια της παρουσιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.9",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 2:9",
      "text": "ου εστιν η παρουσια κατ ενεργειαν του σατανα εν παση δυναμει και σημειοις και τερασιν ψευδους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.10",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 2:10",
      "text": "και εν παση απατη της αδικιας εν τοις απολλυμενοις ανθ ων την αγαπην της αληθειας ουκ εδεξαντο εις το σωθηναι αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.11",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 2:11",
      "text": "και δια τουτο πεμψει αυτοις ο θεος ενεργειαν πλανης εις το πιστευσαι αυτους τω ψευδει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.12",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 2:12",
      "text": "ινα κριθωσιν παντες οι μη πιστευσαντες τη αληθεια αλλ ευδοκησαντες εν τη αδικια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.13",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 2:13",
      "text": "ημεις δε οφειλομεν ευχαριστειν τω θεω παντοτε περι υμων αδελφοι ηγαπημενοι υπο κυριου οτι ειλετο υμας ο θεος απ αρχης εις σωτηριαν εν αγιασμω πνευματος και πιστει αληθειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.14",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 2:14",
      "text": "εις ο εκαλεσεν υμας δια του ευαγγελιου ημων εις περιποιησιν δοξης του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.15",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 2:15",
      "text": "αρα ουν αδελφοι στηκετε και κρατειτε τας παραδοσεις ας εδιδαχθητε ειτε δια λογου ειτε δι επιστολης ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.16",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 2:16",
      "text": "αυτος δε ο κυριος ημων ιησους χριστος και ο θεος και πατηρ ημων ο αγαπησας ημας και δους παρακλησιν αιωνιαν και ελπιδα αγαθην εν χαριτι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.2.17",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 2:17",
      "text": "παρακαλεσαι υμων τας καρδιας και στηριξαι υμας εν παντι λογω και εργω αγαθω",
      "paragraphStart": false
    }
  ]
}
