{
  "chapter": {
    "id": "ant1904:second-thessalonians.3",
    "translationId": "ant1904",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 3,
    "referenceLabel": "2 Thessalonians 3",
    "summary": "Source text for 2 Thessalonians 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-thessalonians.3.1",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 3:1",
      "text": "το λοιπον προσευχεσθε αδελφοι περι ημων ινα ο λογος του κυριου τρεχη και δοξαζηται καθως και προς υμας",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-thessalonians.3.2",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 3:2",
      "text": "και ινα ρυσθωμεν απο των ατοπων και πονηρων ανθρωπων ου γαρ παντων η πιστις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.3",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 3:3",
      "text": "πιστος δε εστιν ο κυριος ος στηριξει υμας και φυλαξει απο του πονηρου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.4",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 3:4",
      "text": "πεποιθαμεν δε εν κυριω εφ υμας οτι α παραγγελλομεν υμιν και ποιειτε και ποιησετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.5",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 3:5",
      "text": "ο δε κυριος κατευθυναι υμων τας καρδιας εις την αγαπην του θεου και εις την υπομονην του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.6",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 3:6",
      "text": "παραγγελλομεν δε υμιν αδελφοι εν ονοματι του κυριου ημων ιησου χριστου στελλεσθαι υμας απο παντος αδελφου ατακτως περιπατουντος και μη κατα την παραδοσιν ην παρελαβον παρ ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.7",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 3:7",
      "text": "αυτοι γαρ οιδατε πως δει μιμεισθαι ημας οτι ουκ ητακτησαμεν εν υμιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.8",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 3:8",
      "text": "ουδε δωρεαν αρτον εφαγομεν παρα τινος αλλ εν κοπω και μοχθω νυκτα και ημεραν εργαζομενοι προς το μη επιβαρησαι τινα υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.9",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 3:9",
      "text": "ουχ οτι ουκ εχομεν εξουσιαν αλλ ινα εαυτους τυπον δωμεν υμιν εις το μιμεισθαι ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.10",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 3:10",
      "text": "και γαρ οτε ημεν προς υμας τουτο παρηγγελλομεν υμιν οτι ει τις ου θελει εργαζεσθαι μηδε εσθιετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.11",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 3:11",
      "text": "ακουομεν γαρ τινας περιπατουντας εν υμιν ατακτως μηδεν εργαζομενους αλλα περιεργαζομενους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.12",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 3:12",
      "text": "τοις δε τοιουτοις παραγγελλομεν και παρακαλουμεν δια του κυριου ημων ιησου χριστου ινα μετα ησυχιας εργαζομενοι τον εαυτων αρτον εσθιωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.13",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 3:13",
      "text": "υμεις δε αδελφοι μη εκκακησητε καλοποιουντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.14",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 3:14",
      "text": "ει δε τις ουχ υπακουει τω λογω ημων δια της επιστολης τουτον σημειουσθε και μη συναναμιγνυσθε αυτω ινα εντραπη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.15",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 3:15",
      "text": "και μη ως εχθρον ηγεισθε αλλα νουθετειτε ως αδελφον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.16",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 3:16",
      "text": "αυτος δε ο κυριος της ειρηνης δωη υμιν την ειρηνην δια παντος εν παντι τροπω ο κυριος μετα παντων υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.17",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 3:17",
      "text": "ο ασπασμος τη εμη χειρι παυλου ο εστιν σημειον εν παση επιστολη ουτως γραφω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.3.18",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Thessalonians 3:18",
      "text": "η χαρις του κυριου ημων ιησου χριστου μετα παντων υμων αμην",
      "paragraphStart": false
    }
  ]
}
