{
  "chapter": {
    "id": "ant1904:second-thessalonians.1",
    "translationId": "ant1904",
    "bookSlug": "second-thessalonians",
    "chapterNumber": 1,
    "referenceLabel": "2 Thessalonians 1",
    "summary": "Source text for 2 Thessalonians 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:second-thessalonians.1.1",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 1:1",
      "text": "παυλος και σιλουανος και τιμοθεος τη εκκλησια θεσσαλονικεων εν θεω πατρι ημων και κυριω ιησου χριστω",
      "paragraphStart": true
    },
    {
      "id": "ant1904:second-thessalonians.1.2",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 1:2",
      "text": "χαρις υμιν και ειρηνη απο θεου πατρος ημων και κυριου ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.3",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 1:3",
      "text": "ευχαριστειν οφειλομεν τω θεω παντοτε περι υμων αδελφοι καθως αξιον εστιν οτι υπεραυξανει η πιστις υμων και πλεοναζει η αγαπη ενος εκαστου παντων υμων εις αλληλους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.4",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 1:4",
      "text": "ωστε ημας αυτους εν υμιν καυχασθαι εν ταις εκκλησιαις του θεου υπερ της υπομονης υμων και πιστεως εν πασιν τοις διωγμοις υμων και ταις θλιψεσιν αις ανεχεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.5",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 1:5",
      "text": "ενδειγμα της δικαιας κρισεως του θεου εις το καταξιωθηναι υμας της βασιλειας του θεου υπερ ης και πασχετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.6",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 1:6",
      "text": "ειπερ δικαιον παρα θεω ανταποδουναι τοις θλιβουσιν υμας θλιψιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.7",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 1:7",
      "text": "και υμιν τοις θλιβομενοις ανεσιν μεθ ημων εν τη αποκαλυψει του κυριου ιησου απ ουρανου μετ αγγελων δυναμεως αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.8",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 1:8",
      "text": "εν πυρι φλογος διδοντος εκδικησιν τοις μη ειδοσιν θεον και τοις μη υπακουουσιν τω ευαγγελιω του κυριου ημων ιησου [χριστου]",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.9",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 1:9",
      "text": "οιτινες δικην τισουσιν ολεθρον αιωνιον απο προσωπου του κυριου και απο της δοξης της ισχυος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.10",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 1:10",
      "text": "οταν ελθη ενδοξασθηναι εν τοις αγιοις αυτου και θαυμασθηναι εν πασιν τοις πιστευσασιν οτι επιστευθη το μαρτυριον ημων εφ υμας εν τη ημερα εκεινη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.11",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 1:11",
      "text": "εις ο και προσευχομεθα παντοτε περι υμων ινα υμας αξιωση της κλησεως ο θεος ημων και πληρωση πασαν ευδοκιαν αγαθωσυνης και εργον πιστεως εν δυναμει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:second-thessalonians.1.12",
      "translationId": "ant1904",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 1:12",
      "text": "οπως ενδοξασθη το ονομα του κυριου ημων ιησου [χριστου] εν υμιν και υμεις εν αυτω κατα την χαριν του θεου ημων και κυριου ιησου χριστου",
      "paragraphStart": false
    }
  ]
}
