{
  "chapter": {
    "id": "ant1904:mark.14",
    "translationId": "ant1904",
    "bookSlug": "mark",
    "chapterNumber": 14,
    "referenceLabel": "Mark 14",
    "summary": "Source text for Mark 14 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:mark.14.1",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Mark 14:1",
      "text": "ην δε το πασχα και τα αζυμα μετα δυο ημερας και εζητουν οι αρχιερεις και οι γραμματεις πως αυτον εν δολω κρατησαντες αποκτεινωσιν",
      "paragraphStart": true
    },
    {
      "id": "ant1904:mark.14.2",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Mark 14:2",
      "text": "ελεγον δε μη εν τη εορτη μηποτε θορυβος εσται του λαου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.3",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Mark 14:3",
      "text": "και οντος αυτου εν βηθανια εν τη οικια σιμωνος του λεπρου κατακειμενου αυτου ηλθεν γυνη εχουσα αλαβαστρον μυρου ναρδου πιστικης πολυτελους και συντριψασα το αλαβαστρον κατεχεεν αυτου κατα της κεφαλης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.4",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Mark 14:4",
      "text": "ησαν δε τινες αγανακτουντες προς εαυτους λεγοντες εις τι η απωλεια αυτη του μυρου γεγονεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.5",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Mark 14:5",
      "text": "ηδυνατο γαρ τουτο το μυρον πραθηναι επανω τριακοσιων δηναριων και δοθηναι τοις πτωχοις και ενεβριμωντο αυτη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.6",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Mark 14:6",
      "text": "ο δε ιησους ειπεν αφετε αυτην τι αυτη κοπους παρεχετε καλον εργον ειργασατο εν εμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.7",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Mark 14:7",
      "text": "παντοτε γαρ τους πτωχους εχετε μεθ εαυτων και οταν θελητε δυνασθε αυτους ευ ποιησαι εμε δε ου παντοτε εχετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.8",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Mark 14:8",
      "text": "ο εσχεν αυτη εποιησεν προελαβεν μυρισαι μου το σωμα εις τον ενταφιασμον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.9",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Mark 14:9",
      "text": "αμην λεγω υμιν οπου εαν κηρυχθη το ευαγγελιον τουτο εις ολον τον κοσμον και ο εποιησεν αυτη λαληθησεται εις μνημοσυνον αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.10",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Mark 14:10",
      "text": "και ιουδας ο ισκαριωτης εις των δωδεκα απηλθεν προς τους αρχιερεις ινα παραδω αυτον αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.11",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Mark 14:11",
      "text": "οι δε ακουσαντες εχαρησαν και επηγγειλαντο αυτω αργυρια δουναι και εζητει πως ευκαιρως αυτον παραδω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.12",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Mark 14:12",
      "text": "και τη πρωτη ημερα των αζυμων οτε το πασχα εθυον λεγουσιν αυτω οι μαθηται αυτου που θελεις απελθοντες ετοιμασωμεν ινα φαγης το πασχα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.13",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Mark 14:13",
      "text": "και αποστελλει δυο των μαθητων αυτου και λεγει αυτοις υπαγετε εις την πολιν και απαντησει υμιν ανθρωπος κεραμιον υδατος βασταζων ακολουθησατε αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.14",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Mark 14:14",
      "text": "και οπου εαν εισελθη ειπατε τω οικοδεσποτη οτι ο διδασκαλος λεγει που εστιν το καταλυμα μου οπου το πασχα μετα των μαθητων μου φαγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.15",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Mark 14:15",
      "text": "και αυτος υμιν δειξει ανωγαιον μεγα εστρωμενον ετοιμον εκει ετοιμασατε ημιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.16",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Mark 14:16",
      "text": "και εξηλθον οι μαθηται αυτου και ηλθον εις την πολιν και ευρον καθως ειπεν αυτοις και ητοιμασαν το πασχα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.17",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Mark 14:17",
      "text": "και οψιας γενομενης ερχεται μετα των δωδεκα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.18",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Mark 14:18",
      "text": "και ανακειμενων αυτων και εσθιοντων ειπεν ο ιησους αμην λεγω υμιν οτι εις εξ υμων παραδωσει με ο εσθιων μετ εμου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.19",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Mark 14:19",
      "text": "οι δε ηρξαντο λυπεισθαι και λεγειν αυτω εις καθ εις μητι εγω και αλλος μητι εγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.20",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Mark 14:20",
      "text": "ο δε αποκριθεις ειπεν αυτοις εις εκ των δωδεκα ο εμβαπτομενος μετ εμου εις το τρυβλιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.21",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Mark 14:21",
      "text": "ο μεν υιος του ανθρωπου υπαγει καθως γεγραπται περι αυτου ουαι δε τω ανθρωπω εκεινω δι ου ο υιος του ανθρωπου παραδιδοται καλον ην αυτω ει ουκ εγεννηθη ο ανθρωπος εκεινος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.22",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Mark 14:22",
      "text": "και εσθιοντων αυτων λαβων ο ιησους αρτον ευλογησας εκλασεν και εδωκεν αυτοις και ειπεν λαβετε [φαγετε] τουτο εστιν το σωμα μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.23",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Mark 14:23",
      "text": "και λαβων [το] ποτηριον ευχαριστησας εδωκεν αυτοις και επιον εξ αυτου παντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.24",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Mark 14:24",
      "text": "και ειπεν αυτοις τουτο εστιν το αιμα μου το της καινης διαθηκης το περι πολλων εκχυνομενον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.25",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Mark 14:25",
      "text": "αμην λεγω υμιν οτι ουκετι ου μη πιω εκ του γενηματος της αμπελου εως της ημερας εκεινης οταν αυτο πινω καινον εν τη βασιλεια του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.26",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Mark 14:26",
      "text": "και υμνησαντες εξηλθον εις το ορος των ελαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.27",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Mark 14:27",
      "text": "και λεγει αυτοις ο ιησους οτι παντες σκανδαλισθησεσθε εν εμοι εν τη νυκτι ταυτη οτι γεγραπται παταξω τον ποιμενα και διασκορπισθησονται τα προβατα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.28",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Mark 14:28",
      "text": "αλλα μετα το εγερθηναι με προαξω υμας εις την γαλιλαιαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.29",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Mark 14:29",
      "text": "ο δε πετρος εφη αυτω και ει παντες σκανδαλισθησονται αλλ ουκ εγω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.30",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Mark 14:30",
      "text": "και λεγει αυτω ο ιησους αμην λεγω σοι οτι συ σημερον εν τη νυκτι ταυτη πριν η δις αλεκτορα φωνησαι τρις απαρνηση με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.31",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Mark 14:31",
      "text": "ο δε πετρος εκ περισσου ελεγεν μαλλον εαν με δεη συναποθανειν σοι ου μη σε απαρνησομαι ωσαυτως δε και παντες ελεγον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.32",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Mark 14:32",
      "text": "και ερχονται εις χωριον ου το ονομα γεθσημανη και λεγει τοις μαθηταις αυτου καθισατε ωδε εως προσευξωμαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.33",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Mark 14:33",
      "text": "και παραλαμβανει τον πετρον και ιακωβον και ιωαννην μεθ εαυτου και ηρξατο εκθαμβεισθαι και αδημονειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.34",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Mark 14:34",
      "text": "και λεγειν αυτοις περιλυπος εστιν η ψυχη μου εως θανατου μεινατε ωδε και γρηγορειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.35",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Mark 14:35",
      "text": "και προελθων μικρον επεσεν επι προσωπον επι της γης και προσηυχετο ινα ει δυνατον εστιν παρελθη απ αυτου η ωρα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.36",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Mark 14:36",
      "text": "και ελεγεν αββα ο πατηρ παντα δυνατα σοι παρενεγκε το ποτηριον απ εμου τουτο αλλ ου τι εγω θελω αλλ ει τι συ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.37",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 37,
      "referenceLabel": "Mark 14:37",
      "text": "και ερχεται και ευρισκει αυτους καθευδοντας και λεγει τω πετρω σιμων καθευδεις ουκ ισχυσατε μιαν ωραν γρηγορησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.38",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 38,
      "referenceLabel": "Mark 14:38",
      "text": "γρηγορειτε και προσευχεσθε ινα μη εισελθητε εις πειρασμον το μεν πνευμα προθυμον η δε σαρξ ασθενης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.39",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 39,
      "referenceLabel": "Mark 14:39",
      "text": "και παλιν απελθων προσηυξατο τον αυτον λογον ειπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.40",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 40,
      "referenceLabel": "Mark 14:40",
      "text": "και υποστρεψας ευρεν αυτους παλιν καθευδοντας ησαν γαρ οι οφθαλμοι αυτων καταβαρυνομενοι και ουκ ηδεισαν τι αποκριθωσιν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.41",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 41,
      "referenceLabel": "Mark 14:41",
      "text": "και ερχεται το τριτον και λεγει αυτοις καθευδετε λοιπον και αναπαυεσθε απεχει ηλθεν η ωρα ιδου παραδιδοται ο υιος του ανθρωπου εις τας χειρας των αμαρτωλων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.42",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 42,
      "referenceLabel": "Mark 14:42",
      "text": "εγειρεσθε αγωμεν ιδου ο παραδιδους με ηγγικεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.43",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 43,
      "referenceLabel": "Mark 14:43",
      "text": "και ευθεως ετι αυτου λαλουντος παραγινεται ιουδας ο ισκαριωτης εις των δωδεκα και μετ αυτου οχλος πολυς μετα μαχαιρων και ξυλων απεσταλμενοι παρα των αρχιερεων και γραμματεων και των πρεσβυτερων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.44",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 44,
      "referenceLabel": "Mark 14:44",
      "text": "δεδωκει δε ο παραδιδους αυτον συσσημον αυτοις λεγων ον αν φιλησω αυτος εστιν κρατησατε αυτον και απαγαγετε ασφαλως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.45",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 45,
      "referenceLabel": "Mark 14:45",
      "text": "και ελθων ευθεως προσελθων αυτω λεγει χαιρε ραββι και κατεφιλησεν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.46",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 46,
      "referenceLabel": "Mark 14:46",
      "text": "οι δε επεβαλον επ αυτον τας χειρας αυτων και εκρατησαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.47",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 47,
      "referenceLabel": "Mark 14:47",
      "text": "εις δε τις των παρεστηκοτων σπασαμενος την μαχαιραν επαισεν τον δουλον του αρχιερεως και αφειλεν αυτου το ωτιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.48",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 48,
      "referenceLabel": "Mark 14:48",
      "text": "και αποκριθεις ο ιησους ειπεν αυτοις ως επι ληστην εξηλθετε μετα μαχαιρων και ξυλων συλλαβειν με",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.49",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 49,
      "referenceLabel": "Mark 14:49",
      "text": "καθ ημεραν προς υμας ημην εν τω ιερω διδασκων και ουκ εκρατησατε με αλλ ινα πληρωθωσιν αι γραφαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.50",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 50,
      "referenceLabel": "Mark 14:50",
      "text": "και αφεντες αυτον εφυγον παντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.51",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 51,
      "referenceLabel": "Mark 14:51",
      "text": "και εις τις νεανισκος ηκολουθησεν αυτω περιβεβλημενος σινδονα επι γυμνου και κρατουσιν αυτον οι νεανισκοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.52",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 52,
      "referenceLabel": "Mark 14:52",
      "text": "ο δε καταλιπων την σινδονα γυμνος εφυγεν απ αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.53",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 53,
      "referenceLabel": "Mark 14:53",
      "text": "και απηγαγον τον ιησουν προς τον αρχιερεα και συνερχονται αυτω παντες οι αρχιερεις και οι πρεσβυτεροι και οι γραμματεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.54",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 54,
      "referenceLabel": "Mark 14:54",
      "text": "και ο πετρος απο μακροθεν ηκολουθησεν αυτω εως εσω εις την αυλην του αρχιερεως και ην συγκαθημενος μετα των υπηρετων και θερμαινομενος προς το φως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.55",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 55,
      "referenceLabel": "Mark 14:55",
      "text": "οι δε αρχιερεις και ολον το συνεδριον εζητουν κατα του ιησου μαρτυριαν εις το θανατωσαι αυτον και ουχ ευρισκον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.56",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 56,
      "referenceLabel": "Mark 14:56",
      "text": "πολλοι γαρ εψευδομαρτυρουν κατ αυτου και ισαι αι μαρτυριαι ουκ ησαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.57",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 57,
      "referenceLabel": "Mark 14:57",
      "text": "και τινες ανασταντες εψευδομαρτυρουν κατ αυτου λεγοντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.58",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 58,
      "referenceLabel": "Mark 14:58",
      "text": "οτι ημεις ηκουσαμεν αυτου λεγοντος οτι εγω καταλυσω τον ναον τουτον τον χειροποιητον και δια τριων ημερων αλλον αχειροποιητον οικοδομησω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.59",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 59,
      "referenceLabel": "Mark 14:59",
      "text": "και ουδε ουτως ιση ην η μαρτυρια αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.60",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 60,
      "referenceLabel": "Mark 14:60",
      "text": "και αναστας ο αρχιερευς εις το μεσον επηρωτα τον ιησουν λεγων ουκ αποκρινη ουδεν τι ουτοι σου καταμαρτυρουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.61",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 61,
      "referenceLabel": "Mark 14:61",
      "text": "ο δε εσιωπα και ουδεν απεκρινατο παλιν ο αρχιερευς επηρωτα αυτον και λεγει αυτω συ ει ο χριστος ο υιος του ευλογητου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.62",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 62,
      "referenceLabel": "Mark 14:62",
      "text": "ο δε ιησους ειπεν εγω ειμι και οψεσθε τον υιον του ανθρωπου εκ δεξιων καθημενον της δυναμεως και ερχομενον επι των νεφελων του ουρανου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.63",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 63,
      "referenceLabel": "Mark 14:63",
      "text": "ο δε αρχιερευς διαρρηξας τους χιτωνας αυτου λεγει τι ετι χρειαν εχομεν μαρτυρων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.64",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 64,
      "referenceLabel": "Mark 14:64",
      "text": "ηκουσατε παντως της βλασφημιας τι υμιν φαινεται οι δε παντες κατεκριναν αυτον ειναι ενοχον θανατου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.65",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 65,
      "referenceLabel": "Mark 14:65",
      "text": "και ηρξαντο τινες εμπτυειν αυτω και περικαλυπτειν το προσωπον αυτου και κολαφιζειν αυτον και λεγειν αυτω προφητευσον ημιν τις εστιν ο παισας σε και οι υπηρεται ραπισμασιν αυτον εβαλον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.66",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 66,
      "referenceLabel": "Mark 14:66",
      "text": "και οντος του πετρου κατω εν τη αυλη ερχεται μια των παιδισκων του αρχιερεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.67",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 67,
      "referenceLabel": "Mark 14:67",
      "text": "και ιδουσα τον πετρον θερμαινομενον εμβλεψασα αυτω λεγει και συ μετα του ιησου του ναζαρηνου ησθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.68",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 68,
      "referenceLabel": "Mark 14:68",
      "text": "ο δε ηρνησατο λεγων ουκ οιδα ουδε επισταμαι τι συ λεγεις και εξηλθεν εξω εις το προαυλιον και αλεκτωρ εφωνησεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.69",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 69,
      "referenceLabel": "Mark 14:69",
      "text": "και η παιδισκη ιδουσα αυτον παλιν ηρξατο λεγειν τοις παρεστηκοσιν οτι ουτος εξ αυτων εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.70",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 70,
      "referenceLabel": "Mark 14:70",
      "text": "ο δε παλιν ηρνειτο και μετα μικρον παλιν οι παρεστωτες ελεγον τω πετρω αληθως εξ αυτων ει και γαρ γαλιλαιος ει και η λαλια σου ομοιαζει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.71",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 71,
      "referenceLabel": "Mark 14:71",
      "text": "ο δε ηρξατο αναθεματιζειν και ομνυναι οτι ουκ οιδα τον ανθρωπον τουτον ον λεγετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.14.72",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 72,
      "referenceLabel": "Mark 14:72",
      "text": "και εκ δευτερου αλεκτωρ εφωνησεν και ανεμνησθη ο πετρος το ρημα ο ειπεν αυτω ο ιησους οτι πριν αλεκτορα φωνησαι δις απαρνηση με τρις και επιβαλων εκλαιεν",
      "paragraphStart": false
    }
  ]
}
