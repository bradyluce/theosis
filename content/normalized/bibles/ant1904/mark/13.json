{
  "chapter": {
    "id": "ant1904:mark.13",
    "translationId": "ant1904",
    "bookSlug": "mark",
    "chapterNumber": 13,
    "referenceLabel": "Mark 13",
    "summary": "Source text for Mark 13 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:mark.13.1",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Mark 13:1",
      "text": "και εκπορευομενου αυτου εκ του ιερου λεγει αυτω εις των μαθητων αυτου διδασκαλε ιδε ποταποι λιθοι και ποταπαι οικοδομαι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:mark.13.2",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Mark 13:2",
      "text": "και ο ιησους αποκριθεις ειπεν αυτω βλεπεις ταυτας τας μεγαλας οικοδομας ου μη αφεθη ωδε λιθος επι λιθον ος ου μη καταλυθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.3",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Mark 13:3",
      "text": "και καθημενου αυτου εις το ορος των ελαιων κατεναντι του ιερου επηρωτων αυτον κατ ιδιαν πετρος και ιακωβος και ιωαννης και ανδρεας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.4",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Mark 13:4",
      "text": "ειπε ημιν ποτε ταυτα εσται και τι το σημειον οταν μελλη παντα ταυτα συντελεισθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.5",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Mark 13:5",
      "text": "ο δε ιησους αποκριθεις ηρξατο λεγειν αυτοις βλεπετε μη τις υμας πλανηση",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.6",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Mark 13:6",
      "text": "πολλοι γαρ ελευσονται επι τω ονοματι μου λεγοντες οτι εγω ειμι και πολλους πλανησουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.7",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Mark 13:7",
      "text": "οταν δε ακουσητε πολεμους και ακοας πολεμων μη θροεισθε δει γαρ γενεσθαι αλλ ουπω το τελος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.8",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Mark 13:8",
      "text": "εγερθησεται γαρ εθνος επι εθνος και βασιλεια επι βασιλειαν και εσονται σεισμοι κατα τοπους και εσονται λιμοι και ταραχαι αρχαι ωδινων ταυτα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.9",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Mark 13:9",
      "text": "βλεπετε δε υμεις εαυτους παραδωσουσιν γαρ υμας εις συνεδρια και εν ταις συναγωγαις αυτων δαρησεσθε και επι ηγεμονων και βασιλεων σταθησεσθε ενεκεν εμου εις μαρτυριον αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.10",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Mark 13:10",
      "text": "και εις παντα τα εθνη δει πρωτον κηρυχθηναι το ευαγγελιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.11",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Mark 13:11",
      "text": "οταν δε αγαγωσιν υμας παραδιδοντες μη προμεριμνατε τι λαλησητε μηδε μελετατε αλλ ο εαν δοθη υμιν εν εκεινη τη ωρα τουτο λαλειτε ου γαρ υμεις εστε οι λαλουντες αλλα το πνευμα το αγιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.12",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Mark 13:12",
      "text": "παραδωσει δε αδελφος αδελφον εις θανατον και πατηρ τεκνον και επαναστησονται τεκνα επι γονεις και θανατωσουσιν αυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.13",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Mark 13:13",
      "text": "και εσεσθε μισουμενοι υπο παντων δια το ονομα μου ο δε υπομεινας εις τελος ουτος σωθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.14",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Mark 13:14",
      "text": "οταν δε ιδητε το βδελυγμα της ερημωσεως το ρηθεν υπο δανιηλ του προφητου εστως οπου ου δει ο αναγινωσκων νοειτω τοτε οι εν τη ιουδαια φευγετωσαν εις τα ορη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.15",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Mark 13:15",
      "text": "ο δε επι του δωματος μη καταβατω εις την οικιαν μηδε εισελθετω αραι τι εκ της οικιας αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.16",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Mark 13:16",
      "text": "και ο εις τον αγρον ων μη επιστρεψατω εις τα οπισω αραι το ιματιον αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.17",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Mark 13:17",
      "text": "ουαι δε ταις εν γαστρι εχουσαις και ταις θηλαζουσαις εν εκειναις ταις ημεραις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.18",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Mark 13:18",
      "text": "προσευχεσθε δε ινα μη γενηται η φυγη υμων χειμωνος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.19",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Mark 13:19",
      "text": "εσονται γαρ αι ημεραι εκειναι θλιψις οια ου γεγονεν τοιαυτη απ αρχης κτισεως ης εκτισεν ο θεος εως του νυν και ου μη γενηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.20",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Mark 13:20",
      "text": "και ει μη εκολοβωσεν κυριος τας ημερας ουκ αν εσωθη πασα σαρξ αλλα δια τους εκλεκτους ους εξελεξατο εκολοβωσεν τας ημερας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.21",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Mark 13:21",
      "text": "και τοτε εαν τις υμιν ειπη ιδου ωδε ο χριστος ιδου εκει μη πιστευετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.22",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Mark 13:22",
      "text": "εγερθησονται γαρ ψευδοχριστοι και ψευδοπροφηται και δωσουσιν σημεια και τερατα προς το αποπλαναν ει δυνατον και τους εκλεκτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.23",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Mark 13:23",
      "text": "υμεις δε βλεπετε ιδου προειρηκα υμιν απαντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.24",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Mark 13:24",
      "text": "αλλ εν εκειναις ταις ημεραις μετα την θλιψιν εκεινην ο ηλιος σκοτισθησεται και η σεληνη ου δωσει το φεγγος αυτης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.25",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Mark 13:25",
      "text": "και οι αστερες εσονται εκ του ουρανου πιπτοντες και αι δυναμεις αι εν τοις ουρανοις σαλευθησονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.26",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Mark 13:26",
      "text": "και τοτε οψονται τον υιον του ανθρωπου ερχομενον εν νεφελαις μετα δυναμεως πολλης και δοξης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.27",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Mark 13:27",
      "text": "και τοτε αποστελει τους αγγελους αυτου και επισυναξει τους εκλεκτους αυτου εκ των τεσσαρων ανεμων απ ακρου της γης εως ακρου του ουρανου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.28",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Mark 13:28",
      "text": "απο δε της συκης μαθετε την παραβολην οταν αυτης ο κλαδος ηδη γενηται απαλος και εκφυη τα φυλλα γινωσκετε οτι εγγυς το θερος εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.29",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Mark 13:29",
      "text": "ουτως και υμεις οταν ιδητε ταυτα γινομενα γινωσκετε οτι εγγυς εστιν επι θυραις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.30",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Mark 13:30",
      "text": "αμην λεγω υμιν οτι ου μη παρελθη η γενεα αυτη μεχρι ου παντα ταυτα γενηται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.31",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Mark 13:31",
      "text": "ο ουρανος και η γη παρελευσονται οι δε εμοι λογοι ου μη παρελευσονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.32",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Mark 13:32",
      "text": "περι δε της ημερας εκεινης η της ωρας ουδεις οιδεν ουδε οι αγγελοι εν ουρανω ουδε ο υιος ει μη ο πατηρ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.33",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Mark 13:33",
      "text": "βλεπετε αγρυπνειτε και προσευχεσθε ουκ οιδατε γαρ ποτε ο καιρος εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.34",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Mark 13:34",
      "text": "ως ανθρωπος αποδημος αφεις την οικιαν αυτου και δους τοις δουλοις αυτου την εξουσιαν και εκαστω το εργον αυτου και τω θυρωρω ενετειλατο ινα γρηγορη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.35",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "Mark 13:35",
      "text": "γρηγορειτε ουν ουκ οιδατε γαρ ποτε ο κυριος της οικιας ερχεται οψε η μεσονυκτιου η αλεκτοροφωνιας η πρωι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.36",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "Mark 13:36",
      "text": "μη ελθων εξαιφνης ευρη υμας καθευδοντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.13.37",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 37,
      "referenceLabel": "Mark 13:37",
      "text": "α δε υμιν λεγω πασιν λεγω γρηγορειτε",
      "paragraphStart": false
    }
  ]
}
