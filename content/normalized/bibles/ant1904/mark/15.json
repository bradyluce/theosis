{
  "chapter": {
    "id": "ant1904:mark.15",
    "translationId": "ant1904",
    "bookSlug": "mark",
    "chapterNumber": 15,
    "referenceLabel": "Mark 15",
    "summary": "Source text for Mark 15 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:mark.15.1",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Mark 15:1",
      "text": "και ευθεως επι το πρωι συμβουλιον ποιησαντες οι αρχιερεις μετα των πρεσβυτερων και γραμματεων και ολον το συνεδριον δησαντες τον ιησουν απηνεγκαν και παρεδωκαν τω πιλατω",
      "paragraphStart": true
    },
    {
      "id": "ant1904:mark.15.2",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Mark 15:2",
      "text": "και επηρωτησεν αυτον ο πιλατος συ ει ο βασιλευς των ιουδαιων ο δε αποκριθεις ειπεν αυτω συ λεγεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.3",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Mark 15:3",
      "text": "και κατηγορουν αυτου οι αρχιερεις πολλα αυτος δε ουδεν απεκρινατο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.4",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Mark 15:4",
      "text": "ο δε πιλατος παλιν επηρωτα αυτον λεγων ουκ αποκρινη ουδεν ιδε ποσα σου καταμαρτυρουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.5",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Mark 15:5",
      "text": "ο δε ιησους ουκετι ουδεν απεκριθη ωστε θαυμαζειν τον πιλατον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.6",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Mark 15:6",
      "text": "κατα δε εορτην απελυεν αυτοις ενα δεσμιον ονπερ ητουντο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.7",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Mark 15:7",
      "text": "ην δε ο λεγομενος βαραββας μετα των συστασιαστων δεδεμενος οιτινες εν τη στασει φονον πεποιηκεισαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.8",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Mark 15:8",
      "text": "και αναβοησας ο οχλος ηρξατο αιτεισθαι καθως αει εποιει αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.9",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Mark 15:9",
      "text": "ο δε πιλατος απεκριθη αυτοις λεγων θελετε απολυσω υμιν τον βασιλεα των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.10",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Mark 15:10",
      "text": "εγινωσκεν γαρ οτι δια φθονον παραδεδωκεισαν αυτον οι αρχιερεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.11",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Mark 15:11",
      "text": "οι δε αρχιερεις ανεσεισαν τον οχλον ινα μαλλον τον βαραββαν απολυση αυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.12",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Mark 15:12",
      "text": "ο δε πιλατος αποκριθεις παλιν ειπεν αυτοις τι ουν θελετε ποιησω ον λεγετε τον βασιλεα των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.13",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Mark 15:13",
      "text": "οι δε παλιν εκραξαν σταυρωσον αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.14",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Mark 15:14",
      "text": "ο δε πιλατος ελεγεν αυτοις τι γαρ εποιησεν κακον οι δε περισσοτερως εκραξαν σταυρωσον αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.15",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Mark 15:15",
      "text": "ο δε πιλατος βουλομενος τω οχλω το ικανον ποιησαι απελυσεν αυτοις τον βαραββαν και παρεδωκεν τον ιησουν φραγελλωσας ινα σταυρωθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.16",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Mark 15:16",
      "text": "οι δε στρατιωται απηγαγον αυτον εσω της αυλης ο εστιν πραιτωριον και συγκαλουσιν ολην την σπειραν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.17",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Mark 15:17",
      "text": "και ενδυουσιν αυτον πορφυραν και περιτιθεασιν αυτω πλεξαντες ακανθινον στεφανον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.18",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Mark 15:18",
      "text": "και ηρξαντο ασπαζεσθαι αυτον χαιρε ο βασιλευς των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.19",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Mark 15:19",
      "text": "και ετυπτον αυτου την κεφαλην καλαμω και ενεπτυον αυτω και τιθεντες τα γονατα προσεκυνουν αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.20",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Mark 15:20",
      "text": "και οτε ενεπαιξαν αυτω εξεδυσαν αυτον την πορφυραν και ενεδυσαν αυτον τα ιματια τα ιδια και εξαγουσιν αυτον ινα σταυρωσωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.21",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Mark 15:21",
      "text": "και αγγαρευουσιν παραγοντα τινα σιμωνα κυρηναιον ερχομενον απ αγρου τον πατερα αλεξανδρου και ρουφου ινα αρη τον σταυρον αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.22",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Mark 15:22",
      "text": "και φερουσιν αυτον επι γολγοθα τοπον ο εστιν μεθερμηνευομενον κρανιου τοπος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.23",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Mark 15:23",
      "text": "και εδιδουν αυτω πιειν εσμυρνισμενον οινον ο δε ουκ ελαβεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.24",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Mark 15:24",
      "text": "και σταυρωσαντες αυτον διαμεριζονται τα ιματια αυτου βαλλοντες κληρον επ αυτα τις τι αρη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.25",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Mark 15:25",
      "text": "ην δε ωρα τριτη και εσταυρωσαν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.26",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Mark 15:26",
      "text": "και ην η επιγραφη της αιτιας αυτου επιγεγραμμενη ο βασιλευς των ιουδαιων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.27",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Mark 15:27",
      "text": "και συν αυτω σταυρουσιν δυο ληστας ενα εκ δεξιων και ενα εξ ευωνυμων αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.28",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Mark 15:28",
      "text": "[και επληρωθη η γραφη η λεγουσα και μετα ανομων ελογισθη]",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.29",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Mark 15:29",
      "text": "και οι παραπορευομενοι εβλασφημουν αυτον κινουντες τας κεφαλας αυτων και λεγοντες ουα ο καταλυων τον ναον και εν τρισιν ημεραις οικοδομων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.30",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Mark 15:30",
      "text": "σωσον σεαυτον και καταβα απο του σταυρου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.31",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Mark 15:31",
      "text": "ομοιως δε και οι αρχιερεις εμπαιζοντες προς αλληλους μετα των γραμματεων ελεγον αλλους εσωσεν εαυτον ου δυναται σωσαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.32",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Mark 15:32",
      "text": "ο χριστος ο βασιλευς του ισραηλ καταβατω νυν απο του σταυρου ινα ιδωμεν και πιστευσωμεν αυτω και οι συνεσταυρωμενοι αυτω ωνειδιζον αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.33",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Mark 15:33",
      "text": "γενομενης δε ωρας εκτης σκοτος εγενετο εφ ολην την γην εως ωρας ενατης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.34",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Mark 15:34",
      "text": "και τη ωρα τη ενατη εβοησεν ο ιησους φωνη μεγαλη λεγων ελωι ελωι λιμα σαβαχθανι ο εστιν μεθερμηνευομενον ο θεος μου ο θεος μου εις τι με εγκατελιπες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.35",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Mark 15:35",
      "text": "και τινες των παρεστηκοτων ακουσαντες ελεγον ιδε ηλιαν φωνει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.36",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Mark 15:36",
      "text": "δραμων δε εις και γεμισας σπογγον οξους περιθεις τε καλαμω εποτιζεν αυτον λεγων αφετε ιδωμεν ει ερχεται ηλιας καθελειν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.37",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Mark 15:37",
      "text": "ο δε ιησους αφεις φωνην μεγαλην εξεπνευσεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.38",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Mark 15:38",
      "text": "και το καταπετασμα του ναου εσχισθη εις δυο απο ανωθεν εως κατω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.39",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Mark 15:39",
      "text": "ιδων δε ο κεντυριων ο παρεστηκως εξ εναντιας αυτου οτι ουτως κραξας εξεπνευσεν ειπεν αληθως ο ανθρωπος ουτος υιος ην θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.40",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "Mark 15:40",
      "text": "ησαν δε και γυναικες απο μακροθεν θεωρουσαι εν αις ην και μαρια η μαγδαληνη και μαρια η του ιακωβου του μικρου και ιωση μητηρ και σαλωμη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.41",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 41,
      "referenceLabel": "Mark 15:41",
      "text": "αι και οτε ην εν τη γαλιλαια ηκολουθουν αυτω και διηκονουν αυτω και αλλαι πολλαι αι συναναβασαι αυτω εις ιεροσολυμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.42",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 42,
      "referenceLabel": "Mark 15:42",
      "text": "και ηδη οψιας γενομενης επει ην παρασκευη ο εστιν προσαββατον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.43",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 43,
      "referenceLabel": "Mark 15:43",
      "text": "ελθων ιωσηφ ο απο αριμαθαιας ευσχημων βουλευτης ος και αυτος ην προσδεχομενος την βασιλειαν του θεου τολμησας εισηλθεν προς πιλατον και ητησατο το σωμα του ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.44",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 44,
      "referenceLabel": "Mark 15:44",
      "text": "ο δε πιλατος εθαυμασεν ει ηδη τεθνηκεν και προσκαλεσαμενος τον κεντυριωνα επηρωτησεν αυτον ει παλαι απεθανεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.45",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 45,
      "referenceLabel": "Mark 15:45",
      "text": "και γνους απο του κεντυριωνος εδωρησατο το σωμα τω ιωσηφ",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.46",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 46,
      "referenceLabel": "Mark 15:46",
      "text": "και αγορασας σινδονα και καθελων αυτον ενειλησεν τη σινδονι και κατεθηκεν αυτον εν μνημειω ο ην λελατομημενον εκ πετρας και προσεκυλισεν λιθον επι την θυραν του μνημειου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.15.47",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 47,
      "referenceLabel": "Mark 15:47",
      "text": "η δε μαρια η μαγδαληνη και μαρια ιωση εθεωρουν που τιθεται",
      "paragraphStart": false
    }
  ]
}
