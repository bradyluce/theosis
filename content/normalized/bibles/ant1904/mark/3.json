{
  "chapter": {
    "id": "ant1904:mark.3",
    "translationId": "ant1904",
    "bookSlug": "mark",
    "chapterNumber": 3,
    "referenceLabel": "Mark 3",
    "summary": "Source text for Mark 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:mark.3.1",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Mark 3:1",
      "text": "και εισηλθεν παλιν εις την συναγωγην και ην εκει ανθρωπος εξηραμμενην εχων την χειρα",
      "paragraphStart": true
    },
    {
      "id": "ant1904:mark.3.2",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Mark 3:2",
      "text": "και παρετητηρουν σιχ αυτον ει τοις σαββασιν θεραπευσει αυτον ινα κατηγορησωσιν αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.3",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Mark 3:3",
      "text": "και λεγει τω ανθρωπω τω εξηραμμενην εχοντι την χειρα εγειρε εις το μεσον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.4",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Mark 3:4",
      "text": "και λεγει αυτοις εξεστιν τοις σαββασιν αγαθοποιησαι η κακοποιησαι ψυχην σωσαι η αποκτειναι οι δε εσιωπων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.5",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Mark 3:5",
      "text": "και περιβλεψαμενος αυτους μετ οργης συλλυπουμενος επι τη πωρωσει της καρδιας αυτων λεγει τω ανθρωπω εκτεινον την χειρα σου και εξετεινεν και αποκατεσταθη η χειρ αυτου υγιης ως η αλλη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.6",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Mark 3:6",
      "text": "και εξελθοντες οι φαρισαιοι ευθεως μετα των ηρωδιανων συμβουλιον εποιουν κατ αυτου οπως αυτον απολεσωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.7",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Mark 3:7",
      "text": "και ο ιησους ανεχωρησεν μετα των μαθητων αυτου προς την θαλασσαν και πολυ πληθος απο της γαλιλαιας ηκολουθησαν αυτω και απο της ιουδαιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.8",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Mark 3:8",
      "text": "και απο ιεροσολυμων και απο της ιδουμαιας και περαν του ιορδανου και οι περι τυρον και σιδωνα πληθος πολυ ακουσαντες οσα εποιει ηλθον προς αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.9",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Mark 3:9",
      "text": "και ειπεν τοις μαθηταις αυτου ινα πλοιαριον προσκαρτερη αυτω δια τον οχλον ινα μη θλιβωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.10",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Mark 3:10",
      "text": "πολλους γαρ εθεραπευσεν ωστε επιπιπτειν αυτω ινα αυτου αψωνται οσοι ειχον μαστιγας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.11",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Mark 3:11",
      "text": "και τα πνευματα τα ακαθαρτα οταν αυτον εθεωρουν προσεπιπτον αυτω και εκραζον λεγοντα οτι συ ει ο υιος του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.12",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Mark 3:12",
      "text": "και πολλα επετιμα αυτοις ινα μη φανερον αυτον ποιησωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.13",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Mark 3:13",
      "text": "και αναβαινει εις το ορος και προσκαλειται ους ηθελεν αυτος και απηλθον προς αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.14",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Mark 3:14",
      "text": "και εποιησεν δωδεκα ινα ωσιν μετ αυτου και ινα αποστελλη αυτους κηρυσσειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.15",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Mark 3:15",
      "text": "και εχειν εξουσιαν θεραπευειν τας νοσους και εκβαλλειν τα δαιμονια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.16",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Mark 3:16",
      "text": "και επεθηκεν ονομα τω σιμωνι πετρον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.17",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Mark 3:17",
      "text": "και ιακωβον τον του ζεβεδαιου και ιωαννην τον αδελφον του ιακωβου και επεθηκεν αυτοις ονοματα βοανεργες ο εστιν υιοι βροντης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.18",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Mark 3:18",
      "text": "και ανδρεαν και φιλιππον και βαρθολομαιον και ματθαιον και θωμαν και ιακωβον τον του αλφαιου και θαδδαιον και σιμωνα τον κανανιτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.19",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Mark 3:19",
      "text": "και ιουδαν ισκαριωτην ος και παρεδωκεν αυτον και ερχονται εις οικον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.20",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Mark 3:20",
      "text": "και συνερχεται παλιν οχλος ωστε μη δυνασθαι αυτους μηδε αρτον φαγειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.21",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Mark 3:21",
      "text": "και ακουσαντες οι παρ αυτου εξηλθον κρατησαι αυτον ελεγον γαρ οτι εξεστη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.22",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Mark 3:22",
      "text": "και οι γραμματεις οι απο ιεροσολυμων καταβαντες ελεγον οτι βεελζεβουλ εχει και οτι εν τω αρχοντι των δαιμονιων εκβαλλει τα δαιμονια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.23",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Mark 3:23",
      "text": "και προσκαλεσαμενος αυτους εν παραβολαις ελεγεν αυτοις πως δυναται σατανας σαταναν εκβαλλειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.24",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Mark 3:24",
      "text": "και εαν βασιλεια εφ εαυτην μερισθη ου δυναται σταθηναι η βασιλεια εκεινη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.25",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Mark 3:25",
      "text": "και εαν οικια εφ εαυτην μερισθη ου δυναται σταθηναι η οικια εκεινη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.26",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Mark 3:26",
      "text": "και ει ο σατανας ανεστη εφ εαυτον και μεμερισται ου δυναται σταθηναι αλλα τελος εχει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.27",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Mark 3:27",
      "text": "ουδεις δυναται τα σκευη του ισχυρου εισελθων εις την οικιαν αυτου διαρπασαι εαν μη πρωτον τον ισχυρον δηση και τοτε την οικιαν αυτου διαρπασει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.28",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Mark 3:28",
      "text": "αμην λεγω υμιν οτι παντα αφεθησεται τοις υιοις των ανθρωπων τα αμαρτηματα και αι βλασφημιαι οσας εαν βλασφημησωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.29",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Mark 3:29",
      "text": "ος δ αν βλασφημηση εις το πνευμα το αγιον ουκ εχει αφεσιν εις τον αιωνα αλλ ενοχος εστιν αιωνιου κρισεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.30",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Mark 3:30",
      "text": "οτι ελεγον πνευμα ακαθαρτον εχει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.31",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Mark 3:31",
      "text": "ερχονται ουν η μητηρ αυτου και οι αδελφοι αυτου και εξω εστωτες απεστειλαν προς αυτον φωνουντες αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.32",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Mark 3:32",
      "text": "και εκαθητο περι αυτον οχλος ειπον δε αυτω ιδου η μητηρ σου και οι αδελφοι σου εξω ζητουσιν σε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.33",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Mark 3:33",
      "text": "και απεκριθη αυτοις λεγων τις εστιν η μητηρ μου η οι αδελφοι μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.34",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Mark 3:34",
      "text": "και περιβλεψαμενος κυκλω τους περι αυτον καθημενους λεγει ιδε η μητηρ μου και οι αδελφοι μου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.3.35",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Mark 3:35",
      "text": "ος γαρ αν ποιηση το θελημα του θεου ουτος αδελφος μου και αδελφη μου και μητηρ εστιν",
      "paragraphStart": false
    }
  ]
}
