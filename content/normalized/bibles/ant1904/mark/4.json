{
  "chapter": {
    "id": "ant1904:mark.4",
    "translationId": "ant1904",
    "bookSlug": "mark",
    "chapterNumber": 4,
    "referenceLabel": "Mark 4",
    "summary": "Source text for Mark 4 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:mark.4.1",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Mark 4:1",
      "text": "και παλιν ηρξατο διδασκειν παρα την θαλασσαν και συνηχθη προς αυτον οχλος πολυς ωστε αυτον εμβαντα εις το πλοιον καθησθαι εν τη θαλασση και πας ο οχλος προς την θαλασσαν επι της γης ησαν",
      "paragraphStart": true
    },
    {
      "id": "ant1904:mark.4.2",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Mark 4:2",
      "text": "και εδιδασκεν αυτους εν παραβολαις πολλα και ελεγεν αυτοις εν τη διδαχη αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.3",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Mark 4:3",
      "text": "ακουετε ιδου εξηλθεν ο σπειρων του σπειραι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.4",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Mark 4:4",
      "text": "και εγενετο εν τω σπειρειν ο μεν επεσεν επι την οδον και ηλθον τα πετεινα και κατεφαγεν αυτο",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.5",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Mark 4:5",
      "text": "και αλλο επεσεν επι το πετρωδες οπου ουκ ειχεν γην πολλην και ευθεως εξανετειλεν δια το μη εχειν βαθος γης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.6",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Mark 4:6",
      "text": "ηλιου δε ανατειλαντος εκαυματισθη και δια το μη εχειν ριζαν εξηρανθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.7",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Mark 4:7",
      "text": "και αλλο επεσεν εις τας ακανθας και ανεβησαν αι ακανθαι και συνεπνιξαν αυτο και καρπον ουκ εδωκεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.8",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Mark 4:8",
      "text": "και αλλο επεσεν εις την γην την καλην και εδιδου καρπον αναβαινοντα και αυξανοντα και εφερεν εν τριακοντα και εν εξηκοντα και εν εκατον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.9",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Mark 4:9",
      "text": "και ελεγεν αυτοις ο εχων ωτα ακουειν ακουετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.10",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Mark 4:10",
      "text": "οτε δε εγενετο κατα μονας ηρωτησαν αυτον οι περι αυτον συν τοις δωδεκα την παραβολην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.11",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Mark 4:11",
      "text": "και ελεγεν αυτοις υμιν δεδοται γνωναι τα μυστηρια της βασιλειας του θεου εκεινοις δε τοις εξω εν παραβολαις τα παντα γινεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.12",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Mark 4:12",
      "text": "ινα βλεποντες βλεπωσιν και μη ιδωσιν και ακουοντες ακουωσιν και μη συνιωσιν μηποτε επιστρεψωσιν και αφεθη αυτοις τα αμαρτηματα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.13",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Mark 4:13",
      "text": "και λεγει αυτοις ουκ οιδατε την παραβολην ταυτην και πως πασας τας παραβολας γνωσεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.14",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Mark 4:14",
      "text": "ο σπειρων τον λογον σπειρει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.15",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Mark 4:15",
      "text": "ουτοι δε εισιν οι παρα την οδον οπου σπειρεται ο λογος και οταν ακουσωσιν ευθυς ερχεται ο σατανας και αιρει τον λογον τον εσπαρμενον εν ταις καρδιαις αυτων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.16",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Mark 4:16",
      "text": "και ουτοι ομοιως εισιν οι επι τα πετρωδη σπειρομενοι οι οταν ακουσωσιν τον λογον ευθυς μετα χαρας λαμβανουσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.17",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Mark 4:17",
      "text": "και ουκ εχουσιν ριζαν εν εαυτοις αλλα προσκαιροι εισιν ειτα γενομενης θλιψεως η διωγμου δια τον λογον ευθυς σκανδαλιζονται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.18",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Mark 4:18",
      "text": "και ουτοι εισιν οι εις τας ακανθας σπειρομενοι οι τον λογον ακουοντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.19",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Mark 4:19",
      "text": "και αι μεριμναι του αιωνος τουτου και η απατη του πλουτου και αι περι τα λοιπα επιθυμιαι εισπορευομεναι συμπνιγουσιν τον λογον και ακαρπος γινεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.20",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Mark 4:20",
      "text": "και ουτοι εισιν οι επι την γην την καλην σπαρεντες οιτινες ακουουσιν τον λογον και παραδεχονται και καρποφορουσιν εν τριακοντα και εν εξηκοντα και εν εκατον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.21",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Mark 4:21",
      "text": "και ελεγεν αυτοις μητι ερχεται ο λυχνος ινα υπο τον μοδιον τεθη η υπο την κλινην ουχ ινα επι την λυχνιαν επιτεθη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.22",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Mark 4:22",
      "text": "ου γαρ εστιν κρυπτον ο εαν μη φανερωθη ουδε εγενετο αποκρυφον αλλ ινα ελθη εις φανερον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.23",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Mark 4:23",
      "text": "ει τις εχει ωτα ακουειν ακουετω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.24",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Mark 4:24",
      "text": "και ελεγεν αυτοις βλεπετε τι ακουετε εν ω μετρω μετρειτε μετρηθησεται υμιν και προστεθησεται υμιν τοις ακουουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.25",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Mark 4:25",
      "text": "ος γαρ αν εχη δοθησεται αυτω και ος ουκ εχει και ο εχει αρθησεται απ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.26",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Mark 4:26",
      "text": "και ελεγεν ουτως εστιν η βασιλεια του θεου ως αν ανθρωπος βαλη τον σπορον επι της γης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.27",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Mark 4:27",
      "text": "και καθευδη και εγειρηται νυκτα και ημεραν και ο σπορος βλαστανη και μηκυνηται ως ουκ οιδεν αυτος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.28",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Mark 4:28",
      "text": "αυτοματη γαρ η γη καρποφορει πρωτον χορτον ειτα σταχυν ειτα πληρη σιτον εν τω σταχυι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.29",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Mark 4:29",
      "text": "οταν δε παραδω ο καρπος ευθεως αποστελλει το δρεπανον οτι παρεστηκεν ο θερισμος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.30",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Mark 4:30",
      "text": "και ελεγεν πως ομοιωσωμεν την βασιλειαν του θεου η εν τινι παραβολη παραβαλωμεν αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.31",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Mark 4:31",
      "text": "ως κοκκον σιναπεως ος οταν σπαρη επι της γης μικροτερος παντων των σπερματων εστιν των επι της γης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.32",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Mark 4:32",
      "text": "και οταν σπαρη αναβαινει και γινεται μειζων παντων των λαχανων και ποιει κλαδους μεγαλους ωστε δυνασθαι υπο την σκιαν αυτου τα πετεινα του ουρανου κατασκηνουν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.33",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Mark 4:33",
      "text": "και τοιαυταις παραβολαις πολλαις ελαλει αυτοις τον λογον καθως ηδυναντο ακουειν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.34",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "Mark 4:34",
      "text": "χωρις δε παραβολης ουκ ελαλει αυτοις τον λογον κατ ιδιαν δε τοις μαθηταις αυτου επελυεν παντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.35",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "Mark 4:35",
      "text": "και λεγει αυτοις εν εκεινη τη ημερα οψιας γενομενης διελθωμεν εις το περαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.36",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "Mark 4:36",
      "text": "και αφεντες τον οχλον παραλαμβανουσιν αυτον ως ην εν τω πλοιω και αλλα δε πλοια ην μετ αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.37",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "Mark 4:37",
      "text": "και γινεται λαιλαψ ανεμου μεγαλη τα δε κυματα επεβαλλεν εις το πλοιον ωστε ηδη αυτο βυθιζεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.38",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "Mark 4:38",
      "text": "και ην αυτος επι τη πρυμνη επι το προσκεφαλαιον καθευδων και διεγειρουσιν αυτον και λεγουσιν αυτω διδασκαλε ου μελει σοι οτι απολλυμεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.39",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 39,
      "referenceLabel": "Mark 4:39",
      "text": "και διεγερθεις επετιμησεν τω ανεμω και ειπεν τη θαλασση σιωπα πεφιμωσο και εκοπασεν ο ανεμος και εγενετο γαληνη μεγαλη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.40",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 40,
      "referenceLabel": "Mark 4:40",
      "text": "και ειπεν αυτοις τι δειλοι εστε ουτως πως ουκ εχετε πιστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:mark.4.41",
      "translationId": "ant1904",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 41,
      "referenceLabel": "Mark 4:41",
      "text": "και εφοβηθησαν φοβον μεγαν και ελεγον προς αλληλους τις αρα ουτος εστιν οτι και ο ανεμος και η θαλασσα υπακουουσιν αυτω",
      "paragraphStart": false
    }
  ]
}
