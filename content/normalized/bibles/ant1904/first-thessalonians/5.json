{
  "chapter": {
    "id": "ant1904:first-thessalonians.5",
    "translationId": "ant1904",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-thessalonians.5.1",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "περι δε των χρονων και των καιρων αδελφοι ου χρειαν εχετε υμιν γραφεσθαι",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-thessalonians.5.2",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "αυτοι γαρ ακριβως οιδατε οτι η ημερα κυριου ως κλεπτης εν νυκτι ουτως ερχεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.3",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "οταν γαρ λεγωσιν ειρηνη και ασφαλεια τοτε αιφνιδιος αυτοις εφισταται ολεθρος ωσπερ η ωδιν τη εν γαστρι εχουση και ου μη εκφυγωσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.4",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "υμεις δε αδελφοι ουκ εστε εν σκοτει ινα η ημερα υμας ως κλεπτης καταλαβη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.5",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "παντες υμεις υιοι φωτος εστε και υιοι ημερας ουκ εσμεν νυκτος ουδε σκοτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.6",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "αρα ουν μη καθευδωμεν ως και οι λοιποι αλλα γρηγορωμεν και νηφωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.7",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "οι γαρ καθευδοντες νυκτος καθευδουσιν και οι μεθυσκομενοι νυκτος μεθυουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.8",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "υμεις δε ημερας οντες νηφωμεν ενδυσαμενοι θωρακα πιστεως και αγαπης και περικεφαλαιαν ελπιδα σωτηριας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.9",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "οτι ουκ εθετο ημας ο θεος εις οργην αλλ εις περιποιησιν σωτηριας δια του κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.10",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "του αποθανοντος υπερ ημων ινα ειτε γρηγορωμεν ειτε καθευδωμεν αμα συν αυτω ζησωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.11",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "διο παρακαλειτε αλληλους και οικοδομειτε εις τον ενα καθως και ποιειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.12",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "ερωτωμεν δε υμας αδελφοι ειδεναι τους κοπιωντας εν υμιν και προισταμενους υμων εν κυριω και νουθετουντας υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.13",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "και ηγεισθαι αυτους υπερεκπερισσου εν αγαπη δια το εργον αυτων ειρηνευετε εν εαυτοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.14",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "παρακαλουμεν δε υμας αδελφοι νουθετειτε τους ατακτους παραμυθεισθε τους ολιγοψυχους αντεχεσθε των ασθενων μακροθυμειτε προς παντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.15",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "ορατε μη τις κακον αντι κακου τινι αποδω αλλα παντοτε το αγαθον διωκετε και εις αλληλους και εις παντας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.16",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "παντοτε χαιρετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.17",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "αδιαλειπτως προσευχεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.18",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "εν παντι ευχαριστειτε τουτο γαρ θελημα θεου εν χριστω ιησου εις υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.19",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "το πνευμα μη σβεννυτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.20",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "προφητειας μη εξουθενειτε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.21",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "παντα [δε] δοκιμαζετε το καλον κατεχετε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.22",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "απο παντος ειδους πονηρου απεχεσθε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.23",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "αυτος δε ο θεος της ειρηνης αγιασαι υμας ολοτελεις και ολοκληρον υμων το πνευμα και η ψυχη και το σωμα αμεμπτως εν τη παρουσια του κυριου ημων ιησου χριστου τηρηθειη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.24",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "πιστος ο καλων υμας ος και ποιησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.25",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "αδελφοι προσευχεσθε περι ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.26",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "ασπασασθε τους αδελφους παντας εν φιληματι αγιω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.27",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "ορκιζω υμας τον κυριον αναγνωσθηναι την επιστολην πασιν τοις αγιοις αδελφοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-thessalonians.5.28",
      "translationId": "ant1904",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "η χαρις του κυριου ημων ιησου χριστου μεθ υμων αμην",
      "paragraphStart": false
    }
  ]
}
