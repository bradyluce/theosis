{
  "chapter": {
    "id": "ant1904:galatians.5",
    "translationId": "ant1904",
    "bookSlug": "galatians",
    "chapterNumber": 5,
    "referenceLabel": "Galatians 5",
    "summary": "Source text for Galatians 5 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:galatians.5.1",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Galatians 5:1",
      "text": "τη ελευθερια ουν η χριστος ημας ηλευθερωσεν στηκετε και μη παλιν ζυγω δουλειας ενεχεσθε",
      "paragraphStart": true
    },
    {
      "id": "ant1904:galatians.5.2",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Galatians 5:2",
      "text": "ιδε εγω παυλος λεγω υμιν οτι εαν περιτεμνησθε χριστος υμας ουδεν ωφελησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.3",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Galatians 5:3",
      "text": "μαρτυρομαι δε παλιν παντι ανθρωπω περιτεμνομενω οτι οφειλετης εστιν ολον τον νομον ποιησαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.4",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Galatians 5:4",
      "text": "κατηργηθητε απο του χριστου οιτινες εν νομω δικαιουσθε της χαριτος εξεπεσατε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.5",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Galatians 5:5",
      "text": "ημεις γαρ πνευματι εκ πιστεως ελπιδα δικαιοσυνης απεκδεχομεθα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.6",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Galatians 5:6",
      "text": "εν γαρ χριστω ιησου ουτε περιτομη τι ισχυει ουτε ακροβυστια αλλα πιστις δι αγαπης ενεργουμενη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.7",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Galatians 5:7",
      "text": "ετρεχετε καλως τις υμας ενεκοψεν τη αληθεια μη πειθεσθαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.8",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Galatians 5:8",
      "text": "η πεισμονη ουκ εκ του καλουντος υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.9",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Galatians 5:9",
      "text": "μικρα ζυμη ολον το φυραμα ζυμοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.10",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Galatians 5:10",
      "text": "εγω πεποιθα εις υμας εν κυριω οτι ουδεν αλλο φρονησετε ο δε ταρασσων υμας βαστασει το κριμα οστις αν η",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.11",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Galatians 5:11",
      "text": "εγω δε αδελφοι ει περιτομην ετι κηρυσσω τι ετι διωκομαι αρα κατηργηται το σκανδαλον του σταυρου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.12",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Galatians 5:12",
      "text": "οφελον και αποκοψονται οι αναστατουντες υμας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.13",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Galatians 5:13",
      "text": "υμεις γαρ επ ελευθερια εκληθητε αδελφοι μονον μη την ελευθεριαν εις αφορμην τη σαρκι αλλα δια της αγαπης δουλευετε αλληλοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.14",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Galatians 5:14",
      "text": "ο γαρ πας νομος εν ενι λογω πληρουται εν τω αγαπησεις τον πλησιον σου ως σεαυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.15",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Galatians 5:15",
      "text": "ει δε αλληλους δακνετε και κατεσθιετε βλεπετε μη υπ αλληλων αναλωθητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.16",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Galatians 5:16",
      "text": "λεγω δε πνευματι περιπατειτε και επιθυμιαν σαρκος ου μη τελεσητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.17",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Galatians 5:17",
      "text": "η γαρ σαρξ επιθυμει κατα του πνευματος το δε πνευμα κατα της σαρκος ταυτα δε αντικειται αλληλοις ινα μη α αν θελητε ταυτα ποιητε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.18",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Galatians 5:18",
      "text": "ει δε πνευματι αγεσθε ουκ εστε υπο νομον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.19",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Galatians 5:19",
      "text": "φανερα δε εστιν τα εργα της σαρκος ατινα εστιν μοιχεια πορνεια ακαθαρσια ασελγεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.20",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Galatians 5:20",
      "text": "ειδωλολατρια φαρμακεια εχθραι ερεις ζηλοι θυμοι εριθειαι διχοστασιαι αιρεσεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.21",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Galatians 5:21",
      "text": "φθονοι φονοι μεθαι κωμοι και τα ομοια τουτοις α προλεγω υμιν καθως και προειπον οτι οι τα τοιαυτα πρασσοντες βασιλειαν θεου ου κληρονομησουσιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.22",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Galatians 5:22",
      "text": "ο δε καρπος του πνευματος εστιν αγαπη χαρα ειρηνη μακροθυμια χρηστοτης αγαθωσυνη πιστις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.23",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Galatians 5:23",
      "text": "πραοτης εγκρατεια κατα των τοιουτων ουκ εστιν νομος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.24",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Galatians 5:24",
      "text": "οι δε του χριστου την σαρκα εσταυρωσαν συν τοις παθημασιν και ταις επιθυμιαις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.25",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Galatians 5:25",
      "text": "ει ζωμεν πνευματι πνευματι και στοιχωμεν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.5.26",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Galatians 5:26",
      "text": "μη γινωμεθα κενοδοξοι αλληλους προκαλουμενοι αλληλοις φθονουντες",
      "paragraphStart": false
    }
  ]
}
