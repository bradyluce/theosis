{
  "chapter": {
    "id": "ant1904:galatians.6",
    "translationId": "ant1904",
    "bookSlug": "galatians",
    "chapterNumber": 6,
    "referenceLabel": "Galatians 6",
    "summary": "Source text for Galatians 6 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:galatians.6.1",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Galatians 6:1",
      "text": "αδελφοι εαν και προληφθη ανθρωπος εν τινι παραπτωματι υμεις οι πνευματικοι καταρτιζετε τον τοιουτον εν πνευματι πραοτητος σκοπων σεαυτον μη και συ πειρασθης",
      "paragraphStart": true
    },
    {
      "id": "ant1904:galatians.6.2",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Galatians 6:2",
      "text": "αλληλων τα βαρη βασταζετε και ουτως αναπληρωσατε τον νομον του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.3",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Galatians 6:3",
      "text": "ει γαρ δοκει τις ειναι τι μηδεν ων εαυτον φρεναπατα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.4",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Galatians 6:4",
      "text": "το δε εργον εαυτου δοκιμαζετω εκαστος και τοτε εις εαυτον μονον το καυχημα εξει και ουκ εις τον ετερον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.5",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Galatians 6:5",
      "text": "εκαστος γαρ το ιδιον φορτιον βαστασει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.6",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Galatians 6:6",
      "text": "κοινωνειτω δε ο κατηχουμενος τον λογον τω κατηχουντι εν πασιν αγαθοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.7",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Galatians 6:7",
      "text": "μη πλανασθε θεος ου μυκτηριζεται ο γαρ εαν σπειρη ανθρωπος τουτο και θερισει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.8",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Galatians 6:8",
      "text": "οτι ο σπειρων εις την σαρκα εαυτου εκ της σαρκος θερισει φθοραν ο δε σπειρων εις το πνευμα εκ του πνευματος θερισει ζωην αιωνιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.9",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Galatians 6:9",
      "text": "το δε καλον ποιουντες μη εκκακωμεν καιρω γαρ ιδιω θερισομεν μη εκλυομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.10",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Galatians 6:10",
      "text": "αρα ουν ως καιρον εχομεν εργαζωμεθα το αγαθον προς παντας μαλιστα δε προς τους οικειους της πιστεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.11",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Galatians 6:11",
      "text": "ιδετε πηλικοις υμιν γραμμασιν εγραψα τη εμη χειρι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.12",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Galatians 6:12",
      "text": "οσοι θελουσιν ευπροσωπησαι εν σαρκι ουτοι αναγκαζουσιν υμας περιτεμνεσθαι μονον ινα μη τω σταυρω του χριστου διωκωνται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.13",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Galatians 6:13",
      "text": "ουδε γαρ οι περιτετμημενοι αυτοι νομον φυλασσουσιν αλλα θελουσιν υμας περιτεμνεσθαι ινα εν τη υμετερα σαρκι καυχησωνται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.14",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Galatians 6:14",
      "text": "εμοι δε μη γενοιτο καυχασθαι ει μη εν τω σταυρω του κυριου ημων ιησου χριστου δι ου εμοι κοσμος εσταυρωται καγω τω κοσμω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.15",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Galatians 6:15",
      "text": "εν γαρ χριστω ιησου ουτε περιτομη τι ισχυει ουτε ακροβυστια αλλα καινη κτισις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.16",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Galatians 6:16",
      "text": "και οσοι τω κανονι τουτω στοιχησουσιν ειρηνη επ αυτους και ελεος και επι τον ισραηλ του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.17",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Galatians 6:17",
      "text": "του λοιπου κοπους μοι μηδεις παρεχετω εγω γαρ τα στιγματα του κυριου ιησου εν τω σωματι μου βασταζω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.6.18",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Galatians 6:18",
      "text": "η χαρις του κυριου ημων ιησου χριστου μετα του πνευματος υμων αδελφοι αμην",
      "paragraphStart": false
    }
  ]
}
