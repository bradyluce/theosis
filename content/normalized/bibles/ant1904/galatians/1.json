{
  "chapter": {
    "id": "ant1904:galatians.1",
    "translationId": "ant1904",
    "bookSlug": "galatians",
    "chapterNumber": 1,
    "referenceLabel": "Galatians 1",
    "summary": "Source text for Galatians 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:galatians.1.1",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Galatians 1:1",
      "text": "παυλος αποστολος ουκ απ ανθρωπων ουδε δι ανθρωπου αλλα δια ιησου χριστου και θεου πατρος του εγειραντος αυτον εκ νεκρων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:galatians.1.2",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Galatians 1:2",
      "text": "και οι συν εμοι παντες αδελφοι ταις εκκλησιαις της γαλατιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.3",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Galatians 1:3",
      "text": "χαρις υμιν και ειρηνη απο θεου πατρος και κυριου ημων ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.4",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Galatians 1:4",
      "text": "του δοντος εαυτον υπερ των αμαρτιων ημων οπως εξεληται ημας εκ του ενεστωτος αιωνος πονηρου κατα το θελημα του θεου και πατρος ημων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.5",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Galatians 1:5",
      "text": "ω η δοξα εις τους αιωνας των αιωνων αμην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.6",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Galatians 1:6",
      "text": "θαυμαζω οτι ουτως ταχεως μετατιθεσθε απο του καλεσαντος υμας εν χαριτι χριστου εις ετερον ευαγγελιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.7",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Galatians 1:7",
      "text": "ο ουκ εστιν αλλο ει μη τινες εισιν οι ταρασσοντες υμας και θελοντες μεταστρεψαι το ευαγγελιον του χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.8",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Galatians 1:8",
      "text": "αλλα και εαν ημεις η αγγελος εξ ουρανου ευαγγελιζηται υμιν παρ ο ευηγγελισαμεθα υμιν αναθεμα εστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.9",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Galatians 1:9",
      "text": "ως προειρηκαμεν και αρτι παλιν λεγω ει τις υμας ευαγγελιζεται παρ ο παρελαβετε αναθεμα εστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.10",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Galatians 1:10",
      "text": "αρτι γαρ ανθρωπους πειθω η τον θεον η ζητω ανθρωποις αρεσκειν ει γαρ ετι ανθρωποις ηρεσκον χριστου δουλος ουκ αν ημην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.11",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Galatians 1:11",
      "text": "γνωριζω δε υμιν αδελφοι το ευαγγελιον το ευαγγελισθεν υπ εμου οτι ουκ εστιν κατα ανθρωπον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.12",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Galatians 1:12",
      "text": "ουδε γαρ εγω παρα ανθρωπου παρελαβον αυτο ουτε εδιδαχθην αλλα δι αποκαλυψεως ιησου χριστου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.13",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Galatians 1:13",
      "text": "ηκουσατε γαρ την εμην αναστροφην ποτε εν τω ιουδαισμω οτι καθ υπερβολην εδιωκον την εκκλησιαν του θεου και επορθουν αυτην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.14",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Galatians 1:14",
      "text": "και προεκοπτον εν τω ιουδαισμω υπερ πολλους συνηλικιωτας εν τω γενει μου περισσοτερως ζηλωτης υπαρχων των πατρικων μου παραδοσεων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.15",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Galatians 1:15",
      "text": "οτε δε ευδοκησεν ο θεος ο αφορισας με εκ κοιλιας μητρος μου και καλεσας δια της χαριτος αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.16",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Galatians 1:16",
      "text": "αποκαλυψαι τον υιον αυτου εν εμοι ινα ευαγγελιζωμαι αυτον εν τοις εθνεσιν ευθεως ου προσανεθεμην σαρκι και αιματι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.17",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Galatians 1:17",
      "text": "ουδε ανηλθον εις ιεροσολυμα προς τους προ εμου αποστολους αλλα απηλθον εις αραβιαν και παλιν υπεστρεψα εις δαμασκον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.18",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Galatians 1:18",
      "text": "επειτα μετα ετη τρια ανηλθον εις ιεροσολυμα ιστορησαι πετρον και επεμεινα προς αυτον ημερας δεκαπεντε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.19",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Galatians 1:19",
      "text": "ετερον δε των αποστολων ουκ ειδον ει μη ιακωβον τον αδελφον του κυριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.20",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Galatians 1:20",
      "text": "α δε γραφω υμιν ιδου ενωπιον του θεου οτι ου ψευδομαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.21",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Galatians 1:21",
      "text": "επειτα ηλθον εις τα κλιματα της συριας και της κιλικιας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.22",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Galatians 1:22",
      "text": "ημην δε αγνοουμενος τω προσωπω ταις εκκλησιαις της ιουδαιας ταις εν χριστω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.23",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Galatians 1:23",
      "text": "μονον δε ακουοντες ησαν οτι ο διωκων ημας ποτε νυν ευαγγελιζεται την πιστιν ην ποτε επορθει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:galatians.1.24",
      "translationId": "ant1904",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Galatians 1:24",
      "text": "και εδοξαζον εν εμοι τον θεον",
      "paragraphStart": false
    }
  ]
}
