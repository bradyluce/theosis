{
  "chapter": {
    "id": "ant1904:third-john.1",
    "translationId": "ant1904",
    "bookSlug": "third-john",
    "chapterNumber": 1,
    "referenceLabel": "3 John 1",
    "summary": "Source text for 3 John 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:third-john.1.1",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "3 John 1:1",
      "text": "ο πρεσβυτερος γαιω τω αγαπητω ον εγω αγαπω εν αληθεια",
      "paragraphStart": true
    },
    {
      "id": "ant1904:third-john.1.2",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "3 John 1:2",
      "text": "αγαπητε περι παντων ευχομαι σε ευοδουσθαι και υγιαινειν καθως ευοδουται σου η ψυχη",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.3",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "3 John 1:3",
      "text": "εχαρην γαρ λιαν ερχομενων αδελφων και μαρτυρουντων σου τη αληθεια καθως συ εν αληθεια περιπατεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.4",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "3 John 1:4",
      "text": "μειζοτεραν τουτων ουκ εχω χαραν ινα ακουω τα εμα τεκνα εν αληθεια περιπατουντα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.5",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "3 John 1:5",
      "text": "αγαπητε πιστον ποιεις ο εαν εργαση εις τους αδελφους και εις τους ξενους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.6",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "3 John 1:6",
      "text": "οι εμαρτυρησαν σου τη αγαπη ενωπιον εκκλησιας ους καλως ποιησεις προπεμψας αξιως του θεου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.7",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "3 John 1:7",
      "text": "υπερ γαρ του ονοματος εξηλθον μηδεν λαμβανοντες απο των εθνικων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.8",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "3 John 1:8",
      "text": "ημεις ουν οφειλομεν απολαμβανειν τους τοιουτους ινα συνεργοι γινωμεθα τη αληθεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.9",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "3 John 1:9",
      "text": "εγραψα τη εκκλησια αλλ ο φιλοπρωτευων αυτων διοτρεφης ουκ επιδεχεται ημας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.10",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "3 John 1:10",
      "text": "δια τουτο εαν ελθω υπομνησω αυτου τα εργα α ποιει λογοις πονηροις φλυαρων ημας και μη αρκουμενος επι τουτοις ουτε αυτος επιδεχεται τους αδελφους και τους βουλομενους κωλυει και [εκ] της εκκλησιας εκβαλλει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.11",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "3 John 1:11",
      "text": "αγαπητε μη μιμου το κακον αλλα το αγαθον ο αγαθοποιων εκ του θεου εστιν ο κακοποιων ουχ εωρακεν τον θεον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.12",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "3 John 1:12",
      "text": "δημητριω μεμαρτυρηται υπο παντων και υπ αυτης της αληθειας και ημεις δε μαρτυρουμεν και οιδατε οτι η μαρτυρια ημων αληθης εστιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.13",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "3 John 1:13",
      "text": "πολλα ειχον γραφειν αλλ ου θελω δια μελανος και καλαμου σοι γραψαι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:third-john.1.14",
      "translationId": "ant1904",
      "bookSlug": "third-john",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "3 John 1:14",
      "text": "ελπιζω δε ευθεως ιδειν σε και στομα προς στομα λαλησομεν ειρηνη σοι ασπαζονται σε οι φιλοι ασπαζου τους φιλους κατ ονομα",
      "paragraphStart": false
    }
  ]
}
