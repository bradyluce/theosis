{
  "chapter": {
    "id": "ant1904:james.1",
    "translationId": "ant1904",
    "bookSlug": "james",
    "chapterNumber": 1,
    "referenceLabel": "James 1",
    "summary": "Source text for James 1 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:james.1.1",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "James 1:1",
      "text": "ιακωβος θεου και κυριου ιησου χριστου δουλος ταις δωδεκα φυλαις ταις εν τη διασπορα χαιρειν",
      "paragraphStart": true
    },
    {
      "id": "ant1904:james.1.2",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "James 1:2",
      "text": "πασαν χαραν ηγησασθε αδελφοι μου οταν πειρασμοις περιπεσητε ποικιλοις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.3",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "James 1:3",
      "text": "γινωσκοντες οτι το δοκιμιον υμων της πιστεως κατεργαζεται υπομονην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.4",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "James 1:4",
      "text": "η δε υπομονη εργον τελειον εχετω ινα ητε τελειοι και ολοκληροι εν μηδενι λειπομενοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.5",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "James 1:5",
      "text": "ει δε τις υμων λειπεται σοφιας αιτειτω παρα του διδοντος θεου πασιν απλως και ουκ ονειδιζοντος και δοθησεται αυτω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.6",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "James 1:6",
      "text": "αιτειτω δε εν πιστει μηδεν διακρινομενος ο γαρ διακρινομενος εοικεν κλυδωνι θαλασσης ανεμιζομενω και ριπιζομενω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.7",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "James 1:7",
      "text": "μη γαρ οιεσθω ο ανθρωπος εκεινος οτι ληψεται τι παρα του κυριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.8",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "James 1:8",
      "text": "ανηρ διψυχος ακαταστατος εν πασαις ταις οδοις αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.9",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "James 1:9",
      "text": "καυχασθω δε ο αδελφος ο ταπεινος εν τω υψει αυτου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.10",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "James 1:10",
      "text": "ο δε πλουσιος εν τη ταπεινωσει αυτου οτι ως ανθος χορτου παρελευσεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.11",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "James 1:11",
      "text": "ανετειλεν γαρ ο ηλιος συν τω καυσωνι και εξηρανεν τον χορτον και το ανθος αυτου εξεπεσεν και η ευπρεπεια του προσωπου αυτου απωλετο ουτως και ο πλουσιος εν ταις πορειαις αυτου μαρανθησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.12",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "James 1:12",
      "text": "μακαριος ανηρ ος υπομενει πειρασμον οτι δοκιμος γενομενος ληψεται τον στεφανον της ζωης ον επηγγειλατο ο κυριος τοις αγαπωσιν αυτον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.13",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "James 1:13",
      "text": "μηδεις πειραζομενος λεγετω οτι απο θεου πειραζομαι ο γαρ θεος απειραστος εστιν κακων πειραζει δε αυτος ουδενα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.14",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "James 1:14",
      "text": "εκαστος δε πειραζεται υπο της ιδιας επιθυμιας εξελκομενος και δελεαζομενος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.15",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "James 1:15",
      "text": "ειτα η επιθυμια συλλαβουσα τικτει αμαρτιαν η δε αμαρτια αποτελεσθεισα αποκυει θανατον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.16",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "James 1:16",
      "text": "μη πλανασθε αδελφοι μου αγαπητοι",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.17",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "James 1:17",
      "text": "πασα δοσις αγαθη και παν δωρημα τελειον ανωθεν εστιν καταβαινον απο του πατρος των φωτων παρ ω ουκ ενι παραλλαγη η τροπης αποσκιασμα",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.18",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "James 1:18",
      "text": "βουληθεις απεκυησεν ημας λογω αληθειας εις το ειναι ημας απαρχην τινα των αυτου κτισματων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.19",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "James 1:19",
      "text": "ωστε αδελφοι μου αγαπητοι εστω πας ανθρωπος ταχυς εις το ακουσαι βραδυς εις το λαλησαι βραδυς εις οργην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.20",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "James 1:20",
      "text": "οργη γαρ ανδρος δικαιοσυνην θεου ου κατεργαζεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.21",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "James 1:21",
      "text": "διο αποθεμενοι πασαν ρυπαριαν και περισσειαν κακιας εν πραυτητι δεξασθε τον εμφυτον λογον τον δυναμενον σωσαι τας ψυχας υμων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.22",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "James 1:22",
      "text": "γινεσθε δε ποιηται λογου και μη μονον ακροαται παραλογιζομενοι εαυτους",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.23",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "James 1:23",
      "text": "οτι ει τις ακροατης λογου εστιν και ου ποιητης ουτος εοικεν ανδρι κατανοουντι το προσωπον της γενεσεως αυτου εν εσοπτρω",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.24",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "James 1:24",
      "text": "κατενοησεν γαρ εαυτον και απεληλυθεν και ευθεως επελαθετο οποιος ην",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.25",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "James 1:25",
      "text": "ο δε παρακυψας εις νομον τελειον τον της ελευθεριας και παραμεινας ουτος ουκ ακροατης επιλησμονης γενομενος αλλα ποιητης εργου ουτος μακαριος εν τη ποιησει αυτου εσται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.26",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "James 1:26",
      "text": "ει τις δοκει θρησκος ειναι εν υμιν μη χαλιναγωγων γλωσσαν αυτου αλλ απατων καρδιαν αυτου τουτου ματαιος η θρησκεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:james.1.27",
      "translationId": "ant1904",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "James 1:27",
      "text": "θρησκεια καθαρα και αμιαντος παρα [τω] θεω και πατρι αυτη εστιν επισκεπτεσθαι ορφανους και χηρας εν τη θλιψει αυτων ασπιλον εαυτον τηρειν απο του κοσμου",
      "paragraphStart": false
    }
  ]
}
