{
  "chapter": {
    "id": "ant1904:first-timothy.3",
    "translationId": "ant1904",
    "bookSlug": "first-timothy",
    "chapterNumber": 3,
    "referenceLabel": "1 Timothy 3",
    "summary": "Source text for 1 Timothy 3 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-timothy.3.1",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 3:1",
      "text": "πιστος ο λογος ει τις επισκοπης ορεγεται καλου εργου επιθυμει",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-timothy.3.2",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 3:2",
      "text": "δει ουν τον επισκοπον ανεπιληπτον ειναι μιας γυναικος ανδρα νηφαλιον σωφρονα κοσμιον φιλοξενον διδακτικον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.3",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 3:3",
      "text": "μη παροινον μη πληκτην μη αισχροκερδη αλλ επιεικη αμαχον αφιλαργυρον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.4",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 3:4",
      "text": "του ιδιου οικου καλως προισταμενον τεκνα εχοντα εν υποταγη μετα πασης σεμνοτητος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.5",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 3:5",
      "text": "ει δε τις του ιδιου οικου προστηναι ουκ οιδεν πως εκκλησιας θεου επιμελησεται",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.6",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 3:6",
      "text": "μη νεοφυτον ινα μη τυφωθεις εις κριμα εμπεση του διαβολου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.7",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 3:7",
      "text": "δει δε αυτον και μαρτυριαν καλην εχειν απο των εξωθεν ινα μη εις ονειδισμον εμπεση και παγιδα του διαβολου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.8",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 3:8",
      "text": "διακονους ωσαυτως σεμνους μη διλογους μη οινω πολλω προσεχοντας μη αισχροκερδεις",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.9",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 3:9",
      "text": "εχοντας το μυστηριον της πιστεως εν καθαρα συνειδησει",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.10",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 3:10",
      "text": "και ουτοι δε δοκιμαζεσθωσαν πρωτον ειτα διακονειτωσαν ανεγκλητοι οντες",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.11",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 3:11",
      "text": "γυναικας ωσαυτως σεμνας μη διαβολους νηφαλιους πιστας εν πασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.12",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 3:12",
      "text": "διακονοι εστωσαν μιας γυναικος ανδρες τεκνων καλως προισταμενοι και των ιδιων οικων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.13",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 3:13",
      "text": "οι γαρ καλως διακονησαντες βαθμον εαυτοις καλον περιποιουνται και πολλην παρρησιαν εν πιστει τη εν χριστω ιησου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.14",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 3:14",
      "text": "ταυτα σοι γραφω ελπιζων ελθειν προς σε ταχιον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.15",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 3:15",
      "text": "εαν δε βραδυνω ινα ειδης πως δει εν οικω θεου αναστρεφεσθαι ητις εστιν εκκλησια θεου ζωντος στυλος και εδραιωμα της αληθειας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.3.16",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 3:16",
      "text": "και ομολογουμενως μεγα εστιν το της ευσεβειας μυστηριον θεος εφανερωθη εν σαρκι εδικαιωθη εν πνευματι ωφθη αγγελοις εκηρυχθη εν εθνεσιν επιστευθη εν κοσμω ανεληφθη εν δοξη",
      "paragraphStart": false
    }
  ]
}
