{
  "chapter": {
    "id": "ant1904:first-timothy.4",
    "translationId": "ant1904",
    "bookSlug": "first-timothy",
    "chapterNumber": 4,
    "referenceLabel": "1 Timothy 4",
    "summary": "Source text for 1 Timothy 4 in Antoniades 1904 Patriarchal Text."
  },
  "verses": [
    {
      "id": "ant1904:first-timothy.4.1",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Timothy 4:1",
      "text": "το δε πνευμα ρητως λεγει οτι εν υστεροις καιροις αποστησονται τινες της πιστεως προσεχοντες πνευμασιν πλανοις και διδασκαλιαις δαιμονιων",
      "paragraphStart": true
    },
    {
      "id": "ant1904:first-timothy.4.2",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Timothy 4:2",
      "text": "εν υποκρισει ψευδολογων κεκαυστηριασμενων την ιδιαν συνειδησιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.3",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Timothy 4:3",
      "text": "κωλυοντων γαμειν απεχεσθαι βρωματων α ο θεος εκτισεν εις μεταληψιν μετα ευχαριστιας τοις πιστοις και επεγνωκοσιν την αληθειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.4",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Timothy 4:4",
      "text": "οτι παν κτισμα θεου καλον και ουδεν αποβλητον μετα ευχαριστιας λαμβανομενον",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.5",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Timothy 4:5",
      "text": "αγιαζεται γαρ δια λογου θεου και εντευξεως",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.6",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Timothy 4:6",
      "text": "ταυτα υποτιθεμενος τοις αδελφοις καλος εση διακονος ιησου χριστου εντρεφομενος τοις λογοις της πιστεως και της καλης διδασκαλιας η παρηκολουθηκας",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.7",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Timothy 4:7",
      "text": "τους δε βεβηλους και γραωδεις μυθους παραιτου γυμναζε δε σεαυτον προς ευσεβειαν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.8",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Timothy 4:8",
      "text": "η γαρ σωματικη γυμνασια προς ολιγον εστιν ωφελιμος η δε ευσεβεια προς παντα ωφελιμος εστιν επαγγελιας εχουσα ζωης της νυν και της μελλουσης",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.9",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Timothy 4:9",
      "text": "πιστος ο λογος και πασης αποδοχης αξιος",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.10",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Timothy 4:10",
      "text": "εις τουτο γαρ και κοπιωμεν και ονειδιζομεθα οτι ηλπικαμεν επι θεω ζωντι ος εστιν σωτηρ παντων ανθρωπων μαλιστα πιστων",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.11",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Timothy 4:11",
      "text": "παραγγελλε ταυτα και διδασκε",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.12",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Timothy 4:12",
      "text": "μηδεις σου της νεοτητος καταφρονειτω αλλα τυπος γινου των πιστων εν λογω εν αναστροφη εν αγαπη εν πνευματι εν πιστει εν αγνεια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.13",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Timothy 4:13",
      "text": "εως ερχομαι προσεχε τη αναγνωσει τη παρακλησει τη διδασκαλια",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.14",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Timothy 4:14",
      "text": "μη αμελει του εν σοι χαρισματος ο εδοθη σοι δια προφητειας μετα επιθεσεως των χειρων του πρεσβυτεριου",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.15",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Timothy 4:15",
      "text": "ταυτα μελετα εν τουτοις ισθι ινα σου η προκοπη φανερα η εν πασιν",
      "paragraphStart": false
    },
    {
      "id": "ant1904:first-timothy.4.16",
      "translationId": "ant1904",
      "bookSlug": "first-timothy",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Timothy 4:16",
      "text": "επεχε σεαυτω και τη διδασκαλια επιμενε αυτοις τουτο γαρ ποιων και σεαυτον σωσεις και τους ακουοντας σου",
      "paragraphStart": false
    }
  ]
}
