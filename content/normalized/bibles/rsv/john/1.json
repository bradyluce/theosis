{
  "chapter": {
    "id": "rsv:john.1",
    "translationId": "rsv",
    "bookSlug": "john",
    "chapterNumber": 1,
    "referenceLabel": "John 1",
    "summary": "Source text for John 1 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:john.1.1",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "John 1:1",
      "text": "In the beginning was the Word, and the Word was with God, and the Word was God.",
      "paragraphStart": true
    },
    {
      "id": "rsv:john.1.2",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "John 1:2",
      "text": "He was in the beginning with God;",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.3",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "John 1:3",
      "text": "all things were made through him, and without him was not anything made that was made.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.4",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "John 1:4",
      "text": "In him was life, and the life was the light of men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.5",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "John 1:5",
      "text": "The light shines in the darkness, and the darkness has not overcome it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.6",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "John 1:6",
      "text": "There was a man sent from God, whose name was John.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.7",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "John 1:7",
      "text": "He came for testimony, to bear witness to the light, that all might believe through him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.8",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "John 1:8",
      "text": "He was not the light, but came to bear witness to the light.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.9",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "John 1:9",
      "text": "The true light that enlightens every man was coming into the world.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.10",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "John 1:10",
      "text": "He was in the world, and the world was made through him, yet the world knew him not.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.11",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "John 1:11",
      "text": "He came to his own home, and his own people received him not.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.12",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "John 1:12",
      "text": "But to all who received him, who believed in his name, he gave power to become children of God;",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.13",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "John 1:13",
      "text": "who were born, not of blood nor of the will of the flesh nor of the will of man, but of God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.14",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "John 1:14",
      "text": "And the Word became flesh and dwelt among us, full of grace and truth; we have beheld his glory, glory as of the only Son from the Father.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.15",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "John 1:15",
      "text": "(John bore witness to him, and cried, “This was he of whom I said, ‘He who comes after me ranks before me, for he was before me.’ ”)",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.16",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "John 1:16",
      "text": "And from his fulness have we all received, grace upon grace.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.17",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "John 1:17",
      "text": "For the law was given through Moses; grace and truth came through Jesus Christ.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.18",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "John 1:18",
      "text": "No one has ever seen God; the only Son, who is in the bosom of the Father, he has made him known.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.19",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "John 1:19",
      "text": "And this is the testimony of John, when the Jews sent priests and Levites from Jerusalem to ask him, “Who are you?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.20",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "John 1:20",
      "text": "He confessed, he did not deny, but confessed, “I am not the Christ.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.21",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "John 1:21",
      "text": "And they asked him, “What then? Are you Elijah?” He said, “I am not.” “Are you the prophet?” And he answered, “No.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.22",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "John 1:22",
      "text": "They said to him then, “Who are you? Let us have an answer for those who sent us. What do you say about yourself?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.23",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "John 1:23",
      "text": "He said, “I am the voice of one crying in the wilderness, ‘Make straight the way of the Lord,’ as the prophet Isaiah said.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.24",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "John 1:24",
      "text": "Now they had been sent from the Pharisees.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.25",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "John 1:25",
      "text": "They asked him, “Then why are you baptizing, if you are neither the Christ, nor Elijah, nor the prophet?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.26",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "John 1:26",
      "text": "John answered them, “I baptize with water; but among you stands one whom you do not know,",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.27",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "John 1:27",
      "text": "even he who comes after me, the thong of whose sandal I am not worthy to untie.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.28",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "John 1:28",
      "text": "This took place in Bethany beyond the Jordan, where John was baptizing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.29",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "John 1:29",
      "text": "The next day he saw Jesus coming toward him, and said, “Behold, the Lamb of God, who takes away the sin of the world!",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.30",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "John 1:30",
      "text": "This is he of whom I said, ‘After me comes a man who ranks before me, for he was before me.’",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.31",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "John 1:31",
      "text": "I myself did not know him; but for this I came baptizing with water, that he might be revealed to Israel.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.32",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "John 1:32",
      "text": "And John bore witness, “I saw the Spirit descend as a dove from heaven, and it remained on him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.33",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "John 1:33",
      "text": "I myself did not know him; but he who sent me to baptize with water said to me, ‘He on whom you see the Spirit descend and remain, this is he who baptizes with the Holy Spirit.’",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.34",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "John 1:34",
      "text": "And I have seen and have borne witness that this is the Son of God.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.35",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "John 1:35",
      "text": "The next day again John was standing with two of his disciples;",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.36",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "John 1:36",
      "text": "and he looked at Jesus as he walked, and said, “Behold, the Lamb of God!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.37",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "John 1:37",
      "text": "The two disciples heard him say this, and they followed Jesus.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.38",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "John 1:38",
      "text": "Jesus turned, and saw them following, and said to them, “What do you seek?” And they said to him, “Rabbi” (which means Teacher), “where are you staying?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.39",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "John 1:39",
      "text": "He said to them, “Come and see.” They came and saw where he was staying; and they stayed with him that day, for it was about the tenth hour.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.40",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "John 1:40",
      "text": "One of the two who heard John speak, and followed him, was Andrew, Simon Peter's brother.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.41",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "John 1:41",
      "text": "He first found his brother Simon, and said to him, “We have found the Messiah” (which means Christ).",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.42",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "John 1:42",
      "text": "He brought him to Jesus. Jesus looked at him, and said, “So you are Simon the son of John? You shall be called Cephas” (which means Peter).",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.43",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "John 1:43",
      "text": "The next day Jesus decided to go to Galilee. And he found Philip and said to him, “Follow me.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.44",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "John 1:44",
      "text": "Now Philip was from Beth-saida, the city of Andrew and Peter.",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.45",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "John 1:45",
      "text": "Philip found Nathana-el, and said to him, “We have found him of whom Moses in the law and also the prophets wrote, Jesus of Nazareth, the son of Joseph.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.46",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "John 1:46",
      "text": "Nathana-el said to him, “Can anything good come out of Nazareth?” Philip said to him, “Come and see.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.47",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "John 1:47",
      "text": "Jesus saw Nathana-el coming to him, and said of him, “Behold, an Israelite indeed, in whom is no guile!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.48",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "John 1:48",
      "text": "Nathana-el said to him, “How do you know me?” Jesus answered him, “Before Philip called you, when you were under the fig tree, I saw you.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.49",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "John 1:49",
      "text": "Nathana-el answered him, “Rabbi, you are the Son of God! You are the King of Israel!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.50",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "John 1:50",
      "text": "Jesus answered him, “Because I said to you, I saw you under the fig tree, do you believe? You shall see greater things than these.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:john.1.51",
      "translationId": "rsv",
      "bookSlug": "john",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "John 1:51",
      "text": "And he said to him, “Truly, truly, I say to you, you will see heaven opened, and the angels of God ascending and descending upon the Son of man.”",
      "paragraphStart": false
    }
  ]
}
