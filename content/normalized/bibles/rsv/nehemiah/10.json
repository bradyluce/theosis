      "translationId": "rsv",
      "bookSlug": "nehemiah",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Nehemiah 10:9",
      "text": "And the Levites: Jeshua the son of Azaniah, Binnui of the sons of Henadad, Kadmi-el;",
      "paragraphStart": false
    },
    {
