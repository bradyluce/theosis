{
  "chapter": {
    "id": "rsv:psalms.54",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 54,
    "referenceLabel": "Psalms 54",
    "summary": "Source text for Psalms 54 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.54.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 1,
      "referenceLabel": "Psalms 54:1",
      "text": "Save me, O God, by thy name, and vindicate me by thy might.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.54.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 2,
      "referenceLabel": "Psalms 54:2",
      "text": "Hear my prayer, O God; give ear to the words of my mouth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.54.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 3,
      "referenceLabel": "Psalms 54:3",
      "text": "For insolent men have risen against me, ruthless men seek my life; they do not set God before them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.54.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 4,
      "referenceLabel": "Psalms 54:4",
      "text": "Behold, God is my helper; the Lord is the upholder of my life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.54.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 5,
      "referenceLabel": "Psalms 54:5",
      "text": "He will requite my enemies with evil; in thy faithfulness put an end to them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.54.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 6,
      "referenceLabel": "Psalms 54:6",
      "text": "With a freewill offering I will sacrifice to thee; I will give thanks to thy name, O Lord, for it is good.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.54.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 54,
      "verseNumber": 7,
      "referenceLabel": "Psalms 54:7",
      "text": "For thou hast delivered me from every trouble, and my eye has looked in triumph on my enemies.",
      "paragraphStart": false
    }
  ]
}
