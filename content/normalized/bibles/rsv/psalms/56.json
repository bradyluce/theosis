{
  "chapter": {
    "id": "rsv:psalms.56",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 56,
    "referenceLabel": "Psalms 56",
    "summary": "Source text for Psalms 56 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.56.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 1,
      "referenceLabel": "Psalms 56:1",
      "text": "Be gracious to me, O God, for men trample upon me; all day long foemen oppress me;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.56.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 2,
      "referenceLabel": "Psalms 56:2",
      "text": "my enemies trample upon me all day long, for many fight against me proudly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 3,
      "referenceLabel": "Psalms 56:3",
      "text": "When I am afraid, I put my trust in thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 4,
      "referenceLabel": "Psalms 56:4",
      "text": "In God, whose word I praise, in God I trust without a fear. What can flesh do to me?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 5,
      "referenceLabel": "Psalms 56:5",
      "text": "All day long they seek to injure my cause; all their thoughts are against me for evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 6,
      "referenceLabel": "Psalms 56:6",
      "text": "They band themselves together, they lurk, they watch my steps. As they have waited for my life,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 7,
      "referenceLabel": "Psalms 56:7",
      "text": "so recompense them for their crime; in wrath cast down the peoples, O God!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 8,
      "referenceLabel": "Psalms 56:8",
      "text": "Thou hast kept count of my tossings; put thou my tears in thy bottle! Are they not in thy book?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 9,
      "referenceLabel": "Psalms 56:9",
      "text": "Then my enemies will be turned back in the day when I call. This I know, that God is for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 10,
      "referenceLabel": "Psalms 56:10",
      "text": "In God, whose word I praise, in the Lord, whose word I praise,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 11,
      "referenceLabel": "Psalms 56:11",
      "text": "in God I trust without a fear. What can man do to me?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 12,
      "referenceLabel": "Psalms 56:12",
      "text": "My vows to thee I must perform, O God; I will render thank offerings to thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.56.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 56,
      "verseNumber": 13,
      "referenceLabel": "Psalms 56:13",
      "text": "For thou hast delivered my soul from death, yea, my feet from falling, that I may walk before God in the light of life.",
      "paragraphStart": false
    }
  ]
}
