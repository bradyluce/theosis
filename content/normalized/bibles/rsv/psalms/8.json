{
  "chapter": {
    "id": "rsv:psalms.8",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 8,
    "referenceLabel": "Psalms 8",
    "summary": "Source text for Psalms 8 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.8.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Psalms 8:1",
      "text": "O Lord, our Lord, how majestic is thy name in all the earth! Thou whose glory above the heavens is chanted",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.8.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Psalms 8:2",
      "text": "by the mouth of babes and infants, thou hast founded a bulwark because of thy foes, to still the enemy and the avenger.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Psalms 8:3",
      "text": "When I look at thy heavens, the work of thy fingers, the moon and the stars which thou hast established;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Psalms 8:4",
      "text": "what is man that thou art mindful of him, and the son of man that thou dost care for him?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Psalms 8:5",
      "text": "Yet thou hast made him little less than God, and dost crown him with glory and honor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Psalms 8:6",
      "text": "Thou hast given him dominion over the works of thy hands; thou hast put all things under his feet,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Psalms 8:7",
      "text": "all sheep and oxen, and also the beasts of the field,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Psalms 8:8",
      "text": "the birds of the air, and the fish of the sea, whatever passes along the paths of the sea.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.8.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Psalms 8:9",
      "text": "O Lord, our Lord, how majestic is thy name in all the earth!",
      "paragraphStart": false
    }
  ]
}
