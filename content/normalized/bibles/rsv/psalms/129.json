{
  "chapter": {
    "id": "rsv:psalms.129",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 129,
    "referenceLabel": "Psalms 129",
    "summary": "Source text for Psalms 129 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.129.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 1,
      "referenceLabel": "Psalms 129:1",
      "text": "“Sorely have they afflicted me from my youth,” let Israel now say—",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.129.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 2,
      "referenceLabel": "Psalms 129:2",
      "text": "“Sorely have they afflicted me from my youth, yet they have not prevailed against me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.129.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 3,
      "referenceLabel": "Psalms 129:3",
      "text": "The plowers plowed upon my back; they made long their furrows.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.129.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 4,
      "referenceLabel": "Psalms 129:4",
      "text": "The Lord is righteous; he has cut the cords of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.129.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 5,
      "referenceLabel": "Psalms 129:5",
      "text": "May all who hate Zion be put to shame and turned backward!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.129.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 6,
      "referenceLabel": "Psalms 129:6",
      "text": "Let them be like the grass on the housetops, which withers before it grows up,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.129.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 7,
      "referenceLabel": "Psalms 129:7",
      "text": "with which the reaper does not fill his hand or the binder of sheaves his bosom,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.129.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 129,
      "verseNumber": 8,
      "referenceLabel": "Psalms 129:8",
      "text": "while those who pass by do not say, “The blessing of the Lord be upon you! We bless you in the name of the Lord!”",
      "paragraphStart": false
    }
  ]
}
