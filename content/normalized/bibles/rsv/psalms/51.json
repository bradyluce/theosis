{
  "chapter": {
    "id": "rsv:psalms.51",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 51,
    "referenceLabel": "Psalms 51",
    "summary": "Source text for Psalms 51 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.51.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 1,
      "referenceLabel": "Psalms 51:1",
      "text": "Have mercy on me, O God, according to thy steadfast love; according to thy abundant mercy blot out my transgressions.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.51.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 2,
      "referenceLabel": "Psalms 51:2",
      "text": "Wash me thoroughly from my iniquity, and cleanse me from my sin!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 3,
      "referenceLabel": "Psalms 51:3",
      "text": "For I know my transgressions, and my sin is ever before me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 4,
      "referenceLabel": "Psalms 51:4",
      "text": "Against thee, thee only, have I sinned, and done that which is evil in thy sight, so that thou art justified in thy sentence and blameless in thy judgment.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 5,
      "referenceLabel": "Psalms 51:5",
      "text": "Behold, I was brought forth in iniquity, and in sin did my mother conceive me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 6,
      "referenceLabel": "Psalms 51:6",
      "text": "Behold, thou desirest truth in the inward being; therefore teach me wisdom in my secret heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 7,
      "referenceLabel": "Psalms 51:7",
      "text": "Purge me with hyssop, and I shall be clean; wash me, and I shall be whiter than snow.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 8,
      "referenceLabel": "Psalms 51:8",
      "text": "Fill me with joy and gladness; let the bones which thou hast broken rejoice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 9,
      "referenceLabel": "Psalms 51:9",
      "text": "Hide thy face from my sins, and blot out all my iniquities.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 10,
      "referenceLabel": "Psalms 51:10",
      "text": "Create in me a clean heart, O God, and put a new and right spirit within me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 11,
      "referenceLabel": "Psalms 51:11",
      "text": "Cast me not away from thy presence, and take not thy holy Spirit from me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 12,
      "referenceLabel": "Psalms 51:12",
      "text": "Restore to me the joy of thy salvation, and uphold me with a willing spirit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 13,
      "referenceLabel": "Psalms 51:13",
      "text": "Then I will teach transgressors thy ways, and sinners will return to thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 14,
      "referenceLabel": "Psalms 51:14",
      "text": "Deliver me from bloodguiltiness, O God, thou God of my salvation, and my tongue will sing aloud of thy deliverance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 15,
      "referenceLabel": "Psalms 51:15",
      "text": "O Lord, open thou my lips, and my mouth shall show forth thy praise.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 16,
      "referenceLabel": "Psalms 51:16",
      "text": "For thou hast no delight in sacrifice; were I to give a burnt offering, thou wouldst not be pleased.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 17,
      "referenceLabel": "Psalms 51:17",
      "text": "The sacrifice acceptable to God is a broken spirit; a broken and contrite heart, O God, thou wilt not despise.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 18,
      "referenceLabel": "Psalms 51:18",
      "text": "Do good to Zion in thy good pleasure; rebuild the walls of Jerusalem,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.51.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 51,
      "verseNumber": 19,
      "referenceLabel": "Psalms 51:19",
      "text": "then wilt thou delight in right sacrifices, in burnt offerings and whole burnt offerings; then bulls will be offered on thy altar.",
      "paragraphStart": false
    }
  ]
}
