{
  "chapter": {
    "id": "rsv:psalms.104",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 104,
    "referenceLabel": "Psalms 104",
    "summary": "Source text for Psalms 104 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.104.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 1,
      "referenceLabel": "Psalms 104:1",
      "text": "Bless the Lord, O my soul! O Lord my God, thou art very great! Thou art clothed with honor and majesty,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.104.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 2,
      "referenceLabel": "Psalms 104:2",
      "text": "who coverest thyself with light as with a garment, who hast stretched out the heavens like a tent,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 3,
      "referenceLabel": "Psalms 104:3",
      "text": "who hast laid the beams of thy chambers on the waters, who makest the clouds thy chariot, who ridest on the wings of the wind,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 4,
      "referenceLabel": "Psalms 104:4",
      "text": "who makest the winds thy messengers, fire and flame thy ministers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 5,
      "referenceLabel": "Psalms 104:5",
      "text": "Thou didst set the earth on its foundations, so that it should never be shaken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 6,
      "referenceLabel": "Psalms 104:6",
      "text": "Thou didst cover it with the deep as with a garment; the waters stood above the mountains.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 7,
      "referenceLabel": "Psalms 104:7",
      "text": "At thy rebuke they fled; at the sound of thy thunder they took to flight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 8,
      "referenceLabel": "Psalms 104:8",
      "text": "The mountains rose, the valleys sank down to the place which thou didst appoint for them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 9,
      "referenceLabel": "Psalms 104:9",
      "text": "Thou didst set a bound which they should not pass, so that they might not again cover the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 10,
      "referenceLabel": "Psalms 104:10",
      "text": "Thou makest springs gush forth in the valleys; they flow between the hills,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 11,
      "referenceLabel": "Psalms 104:11",
      "text": "they give drink to every beast of the field; the wild asses quench their thirst.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 12,
      "referenceLabel": "Psalms 104:12",
      "text": "By them the birds of the air have their habitation; they sing among the branches.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 13,
      "referenceLabel": "Psalms 104:13",
      "text": "From thy lofty abode thou waterest the mountains; the earth is satisfied with the fruit of thy work.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 14,
      "referenceLabel": "Psalms 104:14",
      "text": "Thou dost cause the grass to grow for the cattle, and plants for man to cultivate, that he may bring forth food from the earth,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 15,
      "referenceLabel": "Psalms 104:15",
      "text": "and wine to gladden the heart of man, oil to make his face shine, and bread to strengthen man's heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 16,
      "referenceLabel": "Psalms 104:16",
      "text": "The trees of the Lord are watered abundantly, the cedars of Lebanon which he planted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 17,
      "referenceLabel": "Psalms 104:17",
      "text": "In them the birds build their nests; the stork has her home in the fir trees.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 18,
      "referenceLabel": "Psalms 104:18",
      "text": "The high mountains are for the wild goats; the rocks are a refuge for the badgers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 19,
      "referenceLabel": "Psalms 104:19",
      "text": "Thou hast made the moon to mark the seasons; the sun knows its time for setting.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 20,
      "referenceLabel": "Psalms 104:20",
      "text": "Thou makest darkness, and it is night, when all the beasts of the forest creep forth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 21,
      "referenceLabel": "Psalms 104:21",
      "text": "The young lions roar for their prey, seeking their food from God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 22,
      "referenceLabel": "Psalms 104:22",
      "text": "When the sun rises, they get them away and lie down in their dens.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 23,
      "referenceLabel": "Psalms 104:23",
      "text": "Man goes forth to his work and to his labor until the evening.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 24,
      "referenceLabel": "Psalms 104:24",
      "text": "O Lord, how manifold are thy works! In wisdom hast thou made them all; the earth is full of thy creatures.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 25,
      "referenceLabel": "Psalms 104:25",
      "text": "Yonder is the sea, great and wide, which teems with things innumerable, living things both small and great.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 26,
      "referenceLabel": "Psalms 104:26",
      "text": "There go the ships, and Leviathan which thou didst form to sport in it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 27,
      "referenceLabel": "Psalms 104:27",
      "text": "These all look to thee, to give them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 28,
      "referenceLabel": "Psalms 104:28",
      "text": "When thou givest to them, they gather it up; when thou openest thy hand, they are filled with good things.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 29,
      "referenceLabel": "Psalms 104:29",
      "text": "When thou hidest thy face, they are dismayed; when thou takest away their breath, they die and return to their dust.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.30",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 30,
      "referenceLabel": "Psalms 104:30",
      "text": "When thou sendest forth thy Spirit, they are created; and thou renewest the face of the ground.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.31",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 31,
      "referenceLabel": "Psalms 104:31",
      "text": "May the glory of the Lord endure for ever, may the Lord rejoice in his works,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.32",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 32,
      "referenceLabel": "Psalms 104:32",
      "text": "who looks on the earth and it trembles, who touches the mountains and they smoke!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.33",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 33,
      "referenceLabel": "Psalms 104:33",
      "text": "I will sing to the Lord as long as I live; I will sing praise to my God while I have being.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.34",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 34,
      "referenceLabel": "Psalms 104:34",
      "text": "May my meditation be pleasing to him, for I rejoice in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.104.35",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 104,
      "verseNumber": 35,
      "referenceLabel": "Psalms 104:35",
      "text": "Let sinners be consumed from the earth, and let the wicked be no more! Bless the Lord, O my soul! Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
