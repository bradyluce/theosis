{
  "chapter": {
    "id": "rsv:psalms.63",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 63,
    "referenceLabel": "Psalms 63",
    "summary": "Source text for Psalms 63 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.63.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 1,
      "referenceLabel": "Psalms 63:1",
      "text": "O God, thou art my God, I seek thee, my soul thirsts for thee; my flesh faints for thee, as in a dry and weary land where no water is.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.63.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 2,
      "referenceLabel": "Psalms 63:2",
      "text": "So I have looked upon thee in the sanctuary, beholding thy power and glory.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 3,
      "referenceLabel": "Psalms 63:3",
      "text": "Because thy steadfast love is better than life, my lips will praise thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 4,
      "referenceLabel": "Psalms 63:4",
      "text": "So I will bless thee as long as I live; I will lift up my hands and call on thy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 5,
      "referenceLabel": "Psalms 63:5",
      "text": "My soul is feasted as with marrow and fat, and my mouth praises thee with joyful lips,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 6,
      "referenceLabel": "Psalms 63:6",
      "text": "when I think of thee upon my bed, and meditate on thee in the watches of the night;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 7,
      "referenceLabel": "Psalms 63:7",
      "text": "for thou hast been my help, and in the shadow of thy wings I sing for joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 8,
      "referenceLabel": "Psalms 63:8",
      "text": "My soul clings to thee; thy right hand upholds me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 9,
      "referenceLabel": "Psalms 63:9",
      "text": "But those who seek to destroy my life shall go down into the depths of the earth;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 10,
      "referenceLabel": "Psalms 63:10",
      "text": "they shall be given over to the power of the sword, they shall be prey for jackals.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.63.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 63,
      "verseNumber": 11,
      "referenceLabel": "Psalms 63:11",
      "text": "But the king shall rejoice in God; all who swear by him shall glory; for the mouths of liars will be stopped.",
      "paragraphStart": false
    }
  ]
}
