{
  "chapter": {
    "id": "rsv:psalms.89",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 89,
    "referenceLabel": "Psalms 89",
    "summary": "Source text for Psalms 89 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.89.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 1,
      "referenceLabel": "Psalms 89:1",
      "text": "I will sing of thy steadfast love, O Lord, for ever; with my mouth I will proclaim thy faithfulness to all generations.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.89.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 2,
      "referenceLabel": "Psalms 89:2",
      "text": "For thy steadfast love was established for ever, thy faithfulness is firm as the heavens.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 3,
      "referenceLabel": "Psalms 89:3",
      "text": "Thou hast said, “I have made a covenant with my chosen one, I have sworn to David my servant:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 4,
      "referenceLabel": "Psalms 89:4",
      "text": "‘I will establish your descendants for ever, and build your throne for all generations.’ ”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 5,
      "referenceLabel": "Psalms 89:5",
      "text": "Let the heavens praise thy wonders, O Lord, thy faithfulness in the assembly of the holy ones!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 6,
      "referenceLabel": "Psalms 89:6",
      "text": "For who in the skies can be compared to the Lord? Who among the heavenly beings is like the Lord,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 7,
      "referenceLabel": "Psalms 89:7",
      "text": "a God feared in the council of the holy ones, great and terrible above all that are round about him?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 8,
      "referenceLabel": "Psalms 89:8",
      "text": "O Lord God of hosts, who is mighty as thou art, O Lord, with thy faithfulness round about thee?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 9,
      "referenceLabel": "Psalms 89:9",
      "text": "Thou dost rule the raging of the sea; when its waves rise, thou stillest them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 10,
      "referenceLabel": "Psalms 89:10",
      "text": "Thou didst crush Rahab like a carcass, thou didst scatter thy enemies with thy mighty arm.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 11,
      "referenceLabel": "Psalms 89:11",
      "text": "The heavens are thine, the earth also is thine; the world and all that is in it, thou hast founded them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 12,
      "referenceLabel": "Psalms 89:12",
      "text": "The north and the south, thou hast created them; Tabor and Hermon joyously praise thy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 13,
      "referenceLabel": "Psalms 89:13",
      "text": "Thou hast a mighty arm; strong is thy hand, high thy right hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 14,
      "referenceLabel": "Psalms 89:14",
      "text": "Righteousness and justice are the foundation of thy throne; steadfast love and faithfulness go before thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 15,
      "referenceLabel": "Psalms 89:15",
      "text": "Blessed are the people who know the festal shout, who walk, O Lord, in the light of thy countenance,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 16,
      "referenceLabel": "Psalms 89:16",
      "text": "who exult in thy name all the day, and extol thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 17,
      "referenceLabel": "Psalms 89:17",
      "text": "For thou art the glory of their strength; by thy favor our horn is exalted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 18,
      "referenceLabel": "Psalms 89:18",
      "text": "For our shield belongs to the Lord, our king to the Holy One of Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 19,
      "referenceLabel": "Psalms 89:19",
      "text": "Of old thou didst speak in a vision to thy faithful one, and say: “I have set the crown upon one who is mighty, I have exalted one chosen from the people.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 20,
      "referenceLabel": "Psalms 89:20",
      "text": "I have found David, my servant; with my holy oil I have anointed him;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 21,
      "referenceLabel": "Psalms 89:21",
      "text": "so that my hand shall ever abide with him, my arm also shall strengthen him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 22,
      "referenceLabel": "Psalms 89:22",
      "text": "The enemy shall not outwit him, the wicked shall not humble him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 23,
      "referenceLabel": "Psalms 89:23",
      "text": "I will crush his foes before him and strike down those who hate him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 24,
      "referenceLabel": "Psalms 89:24",
      "text": "My faithfulness and my steadfast love shall be with him, and in my name shall his horn be exalted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 25,
      "referenceLabel": "Psalms 89:25",
      "text": "I will set his hand on the sea and his right hand on the rivers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 26,
      "referenceLabel": "Psalms 89:26",
      "text": "He shall cry to me, ‘Thou art my Father, my God, and the Rock of my salvation.’",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 27,
      "referenceLabel": "Psalms 89:27",
      "text": "And I will make him the first-born, the highest of the kings of the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 28,
      "referenceLabel": "Psalms 89:28",
      "text": "My steadfast love I will keep for him for ever, and my covenant will stand firm for him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 29,
      "referenceLabel": "Psalms 89:29",
      "text": "I will establish his line for ever and his throne as the days of the heavens.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.30",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 30,
      "referenceLabel": "Psalms 89:30",
      "text": "If his children forsake my law and do not walk according to my ordinances,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.31",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 31,
      "referenceLabel": "Psalms 89:31",
      "text": "if they violate my statutes and do not keep my commandments,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.32",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 32,
      "referenceLabel": "Psalms 89:32",
      "text": "then I will punish their transgression with the rod and their iniquity with scourges;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.33",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 33,
      "referenceLabel": "Psalms 89:33",
      "text": "but I will not remove from him my steadfast love, or be false to my faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.34",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 34,
      "referenceLabel": "Psalms 89:34",
      "text": "I will not violate my covenant, or alter the word that went forth from my lips.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.35",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 35,
      "referenceLabel": "Psalms 89:35",
      "text": "Once for all I have sworn by my holiness; I will not lie to David.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.36",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 36,
      "referenceLabel": "Psalms 89:36",
      "text": "His line shall endure for ever, his throne as long as the sun before me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.37",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 37,
      "referenceLabel": "Psalms 89:37",
      "text": "Like the moon it shall be established for ever; it shall stand firm while the skies endure.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.38",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 38,
      "referenceLabel": "Psalms 89:38",
      "text": "But now thou hast cast off and rejected, thou art full of wrath against thy anointed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.39",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 39,
      "referenceLabel": "Psalms 89:39",
      "text": "Thou hast renounced the covenant with thy servant; thou hast defiled his crown in the dust.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.40",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 40,
      "referenceLabel": "Psalms 89:40",
      "text": "Thou hast breached all his walls; thou hast laid his strongholds in ruins.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.41",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 41,
      "referenceLabel": "Psalms 89:41",
      "text": "All that pass by despoil him; he has become the scorn of his neighbors.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.42",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 42,
      "referenceLabel": "Psalms 89:42",
      "text": "Thou hast exalted the right hand of his foes; thou hast made all his enemies rejoice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.43",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 43,
      "referenceLabel": "Psalms 89:43",
      "text": "Yea, thou hast turned back the edge of his sword, and thou hast not made him stand in battle.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.44",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 44,
      "referenceLabel": "Psalms 89:44",
      "text": "Thou hast removed the scepter from his hand, and cast his throne to the ground.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.45",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 45,
      "referenceLabel": "Psalms 89:45",
      "text": "Thou hast cut short the days of his youth; thou hast covered him with shame.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.46",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 46,
      "referenceLabel": "Psalms 89:46",
      "text": "How long, O Lord? Wilt thou hide thyself for ever? How long will thy wrath burn like fire?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.47",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 47,
      "referenceLabel": "Psalms 89:47",
      "text": "Remember, O Lord, what the measure of life is, for what vanity thou hast created all the sons of men!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.48",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 48,
      "referenceLabel": "Psalms 89:48",
      "text": "What man can live and never see death? Who can deliver his soul from the power of Sheol?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.49",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 49,
      "referenceLabel": "Psalms 89:49",
      "text": "Lord, where is thy steadfast love of old, which by thy faithfulness thou didst swear to David?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.50",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 50,
      "referenceLabel": "Psalms 89:50",
      "text": "Remember, O Lord, how thy servant is scorned; how I bear in my bosom the insults of the peoples,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.51",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 51,
      "referenceLabel": "Psalms 89:51",
      "text": "with which thy enemies taunt, O Lord, with which they mock the footsteps of thy anointed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.89.52",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 89,
      "verseNumber": 52,
      "referenceLabel": "Psalms 89:52",
      "text": "Blessed be the Lord for ever! Amen and Amen.",
      "paragraphStart": false
    }
  ]
}
