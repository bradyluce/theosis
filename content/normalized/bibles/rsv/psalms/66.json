{
  "chapter": {
    "id": "rsv:psalms.66",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 66,
    "referenceLabel": "Psalms 66",
    "summary": "Source text for Psalms 66 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.66.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 1,
      "referenceLabel": "Psalms 66:1",
      "text": "Make a joyful noise to God, all the earth;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.66.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 2,
      "referenceLabel": "Psalms 66:2",
      "text": "sing the glory of his name; give to him glorious praise!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 3,
      "referenceLabel": "Psalms 66:3",
      "text": "Say to God, “How terrible are thy deeds! So great is thy power that thy enemies cringe before thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 4,
      "referenceLabel": "Psalms 66:4",
      "text": "All the earth worships thee; they sing praises to thee, sing praises to thy name.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 5,
      "referenceLabel": "Psalms 66:5",
      "text": "Come and see what God has done: he is terrible in his deeds among men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 6,
      "referenceLabel": "Psalms 66:6",
      "text": "He turned the sea into dry land; men passed through the river on foot. There did we rejoice in him,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 7,
      "referenceLabel": "Psalms 66:7",
      "text": "who rules by his might for ever, whose eyes keep watch on the nations— let not the rebellious exalt themselves.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 8,
      "referenceLabel": "Psalms 66:8",
      "text": "Bless our God, O peoples, let the sound of his praise be heard,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 9,
      "referenceLabel": "Psalms 66:9",
      "text": "who has kept us among the living, and has not let our feet slip.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 10,
      "referenceLabel": "Psalms 66:10",
      "text": "For thou, O God, hast tested us; thou hast tried us as silver is tried.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 11,
      "referenceLabel": "Psalms 66:11",
      "text": "Thou didst bring us into the net; thou didst lay affliction on our loins;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 12,
      "referenceLabel": "Psalms 66:12",
      "text": "thou didst let men ride over our heads; we went through fire and through water; yet thou hast brought us forth to a spacious place.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 13,
      "referenceLabel": "Psalms 66:13",
      "text": "I will come into thy house with burnt offerings; I will pay thee my vows,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 14,
      "referenceLabel": "Psalms 66:14",
      "text": "that which my lips uttered and my mouth promised when I was in trouble.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 15,
      "referenceLabel": "Psalms 66:15",
      "text": "I will offer to thee burnt offerings of fatlings, with the smoke of the sacrifice of rams; I will make an offering of bulls and goats.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 16,
      "referenceLabel": "Psalms 66:16",
      "text": "Come and hear, all you who fear God, and I will tell what he has done for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 17,
      "referenceLabel": "Psalms 66:17",
      "text": "I cried aloud to him, and he was extolled with my tongue.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 18,
      "referenceLabel": "Psalms 66:18",
      "text": "If I had cherished iniquity in my heart, the Lord would not have listened.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 19,
      "referenceLabel": "Psalms 66:19",
      "text": "But truly God has listened; he has given heed to the voice of my prayer.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.66.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 66,
      "verseNumber": 20,
      "referenceLabel": "Psalms 66:20",
      "text": "Blessed be God, because he has not rejected my prayer or removed his steadfast love from me!",
      "paragraphStart": false
    }
  ]
}
