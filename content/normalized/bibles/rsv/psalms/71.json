{
  "chapter": {
    "id": "rsv:psalms.71",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 71,
    "referenceLabel": "Psalms 71",
    "summary": "Source text for Psalms 71 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.71.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 1,
      "referenceLabel": "Psalms 71:1",
      "text": "In thee, O Lord, do I take refuge; let me never be put to shame!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.71.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 2,
      "referenceLabel": "Psalms 71:2",
      "text": "In thy righteousness deliver me and rescue me; incline thy ear to me, and save me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 3,
      "referenceLabel": "Psalms 71:3",
      "text": "Be thou to me a rock of refuge, a strong fortress, to save me, for thou art my rock and my fortress.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 4,
      "referenceLabel": "Psalms 71:4",
      "text": "Rescue me, O my God, from the hand of the wicked, from the grasp of the unjust and cruel man.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 5,
      "referenceLabel": "Psalms 71:5",
      "text": "For thou, O Lord, art my hope, my trust, O Lord, from my youth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 6,
      "referenceLabel": "Psalms 71:6",
      "text": "Upon thee I have leaned from my birth; thou art he who took me from my mother's womb. My praise is continually of thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 7,
      "referenceLabel": "Psalms 71:7",
      "text": "I have been as a portent to many; but thou art my strong refuge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 8,
      "referenceLabel": "Psalms 71:8",
      "text": "My mouth is filled with thy praise, and with thy glory all the day.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 9,
      "referenceLabel": "Psalms 71:9",
      "text": "Do not cast me off in the time of old age; forsake me not when my strength is spent.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 10,
      "referenceLabel": "Psalms 71:10",
      "text": "For my enemies speak concerning me, those who watch for my life consult together,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 11,
      "referenceLabel": "Psalms 71:11",
      "text": "and say, “God has forsaken him; pursue and seize him, for there is none to deliver him.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 12,
      "referenceLabel": "Psalms 71:12",
      "text": "O God, be not far from me; O my God, make haste to help me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 13,
      "referenceLabel": "Psalms 71:13",
      "text": "May my accusers be put to shame and consumed; with scorn and disgrace may they be covered who seek my hurt.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 14,
      "referenceLabel": "Psalms 71:14",
      "text": "But I will hope continually, and will praise thee yet more and more.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 15,
      "referenceLabel": "Psalms 71:15",
      "text": "My mouth will tell of thy righteous acts, of thy deeds of salvation all the day, for their number is past my knowledge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 16,
      "referenceLabel": "Psalms 71:16",
      "text": "With the mighty deeds of the Lord God I will come, I will praise thy righteousness, thine alone.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 17,
      "referenceLabel": "Psalms 71:17",
      "text": "O God, from my youth thou hast taught me, and I still proclaim thy wondrous deeds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 18,
      "referenceLabel": "Psalms 71:18",
      "text": "So even to old age and gray hairs, O God, do not forsake me, till I proclaim thy might to all the generations to come. Thy power",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 19,
      "referenceLabel": "Psalms 71:19",
      "text": "and thy righteousness, O God, reach the high heavens. Thou who hast done great things, O God, who is like thee?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 20,
      "referenceLabel": "Psalms 71:20",
      "text": "Thou who hast made me see many sore troubles wilt revive me again; from the depths of the earth thou wilt bring me up again.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 21,
      "referenceLabel": "Psalms 71:21",
      "text": "Thou wilt increase my honor, and comfort me again.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 22,
      "referenceLabel": "Psalms 71:22",
      "text": "I will also praise thee with the harp for thy faithfulness, O my God; I will sing praises to thee with the lyre, O Holy One of Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 23,
      "referenceLabel": "Psalms 71:23",
      "text": "My lips will shout for joy, when I sing praises to thee; my soul also, which thou hast rescued.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.71.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 71,
      "verseNumber": 24,
      "referenceLabel": "Psalms 71:24",
      "text": "And my tongue will talk of thy righteous help all the day long, for they have been put to shame and disgraced who sought to do me hurt.",
      "paragraphStart": false
    }
  ]
}
