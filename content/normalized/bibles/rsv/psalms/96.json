{
  "chapter": {
    "id": "rsv:psalms.96",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 96,
    "referenceLabel": "Psalms 96",
    "summary": "Source text for Psalms 96 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.96.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 1,
      "referenceLabel": "Psalms 96:1",
      "text": "O sing to the Lord a new song; sing to the Lord, all the earth!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.96.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 2,
      "referenceLabel": "Psalms 96:2",
      "text": "Sing to the Lord, bless his name; tell of his salvation from day to day.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 3,
      "referenceLabel": "Psalms 96:3",
      "text": "Declare his glory among the nations, his marvelous works among all the peoples!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 4,
      "referenceLabel": "Psalms 96:4",
      "text": "For great is the Lord, and greatly to be praised; he is to be feared above all gods.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 5,
      "referenceLabel": "Psalms 96:5",
      "text": "For all the gods of the peoples are idols; but the Lord made the heavens.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 6,
      "referenceLabel": "Psalms 96:6",
      "text": "Honor and majesty are before him; strength and beauty are in his sanctuary.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 7,
      "referenceLabel": "Psalms 96:7",
      "text": "Ascribe to the Lord, O families of the peoples, ascribe to the Lord glory and strength!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 8,
      "referenceLabel": "Psalms 96:8",
      "text": "Ascribe to the Lord the glory due his name; bring an offering, and come into his courts!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 9,
      "referenceLabel": "Psalms 96:9",
      "text": "Worship the Lord in holy array; tremble before him, all the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 10,
      "referenceLabel": "Psalms 96:10",
      "text": "Say among the nations, “The Lord reigns! Yea, the world is established, it shall never be moved; he will judge the peoples with equity.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 11,
      "referenceLabel": "Psalms 96:11",
      "text": "Let the heavens be glad, and let the earth rejoice; let the sea roar, and all that fills it;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 12,
      "referenceLabel": "Psalms 96:12",
      "text": "let the field exult, and everything in it! Then shall all the trees of the wood sing for joy",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.96.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 96,
      "verseNumber": 13,
      "referenceLabel": "Psalms 96:13",
      "text": "before the Lord, for he comes, for he comes to judge the earth. He will judge the world with righteousness, and the peoples with his truth.",
      "paragraphStart": false
    }
  ]
}
