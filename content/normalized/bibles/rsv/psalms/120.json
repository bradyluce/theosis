{
  "chapter": {
    "id": "rsv:psalms.120",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 120,
    "referenceLabel": "Psalms 120",
    "summary": "Source text for Psalms 120 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.120.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 1,
      "referenceLabel": "Psalms 120:1",
      "text": "In my distress I cry to the Lord, that he may answer me:",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.120.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 2,
      "referenceLabel": "Psalms 120:2",
      "text": "“Deliver me, O Lord, from lying lips, from a deceitful tongue.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.120.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 3,
      "referenceLabel": "Psalms 120:3",
      "text": "What shall be given to you? And what more shall be done to you, you deceitful tongue?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.120.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 4,
      "referenceLabel": "Psalms 120:4",
      "text": "A warrior's sharp arrows, with glowing coals of the broom tree!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.120.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 5,
      "referenceLabel": "Psalms 120:5",
      "text": "Woe is me, that I sojourn in Meshech, that I dwell among the tents of Kedar!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.120.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 6,
      "referenceLabel": "Psalms 120:6",
      "text": "Too long have I had my dwelling among those who hate peace.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.120.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 120,
      "verseNumber": 7,
      "referenceLabel": "Psalms 120:7",
      "text": "I am for peace; but when I speak, they are for war!",
      "paragraphStart": false
    }
  ]
}
