{
  "chapter": {
    "id": "rsv:psalms.97",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 97,
    "referenceLabel": "Psalms 97",
    "summary": "Source text for Psalms 97 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.97.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 1,
      "referenceLabel": "Psalms 97:1",
      "text": "The Lord reigns; let the earth rejoice; let the many coastlands be glad!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.97.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 2,
      "referenceLabel": "Psalms 97:2",
      "text": "Clouds and thick darkness are round about him; righteousness and justice are the foundation of his throne.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 3,
      "referenceLabel": "Psalms 97:3",
      "text": "Fire goes before him, and burns up his adversaries round about.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 4,
      "referenceLabel": "Psalms 97:4",
      "text": "His lightnings lighten the world; the earth sees and trembles.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 5,
      "referenceLabel": "Psalms 97:5",
      "text": "The mountains melt like wax before the Lord, before the Lord of all the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 6,
      "referenceLabel": "Psalms 97:6",
      "text": "The heavens proclaim his righteousness; and all the peoples behold his glory.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 7,
      "referenceLabel": "Psalms 97:7",
      "text": "All worshipers of images are put to shame, who make their boast in worthless idols; all gods bow down before him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 8,
      "referenceLabel": "Psalms 97:8",
      "text": "Zion hears and is glad, and the daughters of Judah rejoice, because of thy judgments, O God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 9,
      "referenceLabel": "Psalms 97:9",
      "text": "For thou, O Lord, art most high over all the earth; thou art exalted far above all gods.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 10,
      "referenceLabel": "Psalms 97:10",
      "text": "The Lord loves those who hate evil; he preserves the lives of his saints; he delivers them from the hand of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 11,
      "referenceLabel": "Psalms 97:11",
      "text": "Light dawns for the righteous, and joy for the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.97.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 97,
      "verseNumber": 12,
      "referenceLabel": "Psalms 97:12",
      "text": "Rejoice in the Lord, O you righteous, and give thanks to his holy name!",
      "paragraphStart": false
    }
  ]
}
