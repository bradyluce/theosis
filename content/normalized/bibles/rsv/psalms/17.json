{
  "chapter": {
    "id": "rsv:psalms.17",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 17,
    "referenceLabel": "Psalms 17",
    "summary": "Source text for Psalms 17 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.17.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Psalms 17:1",
      "text": "Hear a just cause, O Lord; attend to my cry! Give ear to my prayer from lips free of deceit!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.17.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Psalms 17:2",
      "text": "From thee let my vindication come! Let thy eyes see the right!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Psalms 17:3",
      "text": "If thou triest my heart, if thou visitest me by night, if thou testest me, thou wilt find no wickedness in me; my mouth does not transgress.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Psalms 17:4",
      "text": "With regard to the works of men, by the word of thy lips I have avoided the ways of the violent.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Psalms 17:5",
      "text": "My steps have held fast to thy paths, my feet have not slipped.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Psalms 17:6",
      "text": "I call upon thee, for thou wilt answer me, O God; incline thy ear to me, hear my words.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Psalms 17:7",
      "text": "Wondrously show thy steadfast love, O savior of those who seek refuge from their adversaries at thy right hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Psalms 17:8",
      "text": "Keep me as the apple of the eye; hide me in the shadow of thy wings,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Psalms 17:9",
      "text": "from the wicked who despoil me, my deadly enemies who surround me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Psalms 17:10",
      "text": "They close their hearts to pity; with their mouths they speak arrogantly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Psalms 17:11",
      "text": "They track me down; now they surround me; they set their eyes to cast me to the ground.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Psalms 17:12",
      "text": "They are like a lion eager to tear, as a young lion lurking in ambush.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Psalms 17:13",
      "text": "Arise, O Lord! confront them, overthrow them! Deliver my life from the wicked by thy sword,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Psalms 17:14",
      "text": "from men by thy hand, O Lord, from men whose portion in life is of the world. May their belly be filled with what thou hast stored up for them; may their children have more than enough; may they leave something over to their babes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.17.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Psalms 17:15",
      "text": "As for me, I shall behold thy face in righteousness; when I awake, I shall be satisfied with beholding thy form.",
      "paragraphStart": false
    }
  ]
}
