{
  "chapter": {
    "id": "rsv:psalms.149",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 149,
    "referenceLabel": "Psalms 149",
    "summary": "Source text for Psalms 149 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.149.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 1,
      "referenceLabel": "Psalms 149:1",
      "text": "Praise the Lord! Sing to the Lord a new song, his praise in the assembly of the faithful!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.149.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 2,
      "referenceLabel": "Psalms 149:2",
      "text": "Let Israel be glad in his Maker, let the sons of Zion rejoice in their King!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 3,
      "referenceLabel": "Psalms 149:3",
      "text": "Let them praise his name with dancing, making melody to him with timbrel and lyre!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 4,
      "referenceLabel": "Psalms 149:4",
      "text": "For the Lord takes pleasure in his people; he adorns the humble with victory.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 5,
      "referenceLabel": "Psalms 149:5",
      "text": "Let the faithful exult in glory; let them sing for joy on their couches.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 6,
      "referenceLabel": "Psalms 149:6",
      "text": "Let the high praises of God be in their throats and two-edged swords in their hands,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 7,
      "referenceLabel": "Psalms 149:7",
      "text": "to wreak vengeance on the nations and chastisement on the peoples,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 8,
      "referenceLabel": "Psalms 149:8",
      "text": "to bind their kings with chains and their nobles with fetters of iron,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.149.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 149,
      "verseNumber": 9,
      "referenceLabel": "Psalms 149:9",
      "text": "to execute on them the judgment written! This is glory for all his faithful ones. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
