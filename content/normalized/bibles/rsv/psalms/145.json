{
  "chapter": {
    "id": "rsv:psalms.145",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 145,
    "referenceLabel": "Psalms 145",
    "summary": "Source text for Psalms 145 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.145.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 1,
      "referenceLabel": "Psalms 145:1",
      "text": "I will extol thee, my God and King, and bless thy name for ever and ever.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.145.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 2,
      "referenceLabel": "Psalms 145:2",
      "text": "Every day I will bless thee, and praise thy name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 3,
      "referenceLabel": "Psalms 145:3",
      "text": "Great is the Lord, and greatly to be praised, and his greatness is unsearchable.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 4,
      "referenceLabel": "Psalms 145:4",
      "text": "One generation shall laud thy works to another, and shall declare thy mighty acts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 5,
      "referenceLabel": "Psalms 145:5",
      "text": "On the glorious splendor of thy majesty, and on thy wondrous works, I will meditate.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 6,
      "referenceLabel": "Psalms 145:6",
      "text": "Men shall proclaim the might of thy terrible acts, and I will declare thy greatness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 7,
      "referenceLabel": "Psalms 145:7",
      "text": "They shall pour forth the fame of thy abundant goodness, and shall sing aloud of thy righteousness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 8,
      "referenceLabel": "Psalms 145:8",
      "text": "The Lord is gracious and merciful, slow to anger and abounding in steadfast love.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 9,
      "referenceLabel": "Psalms 145:9",
      "text": "The Lord is good to all, and his compassion is over all that he has made.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 10,
      "referenceLabel": "Psalms 145:10",
      "text": "All thy works shall give thanks to thee, O Lord, and all thy saints shall bless thee!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 11,
      "referenceLabel": "Psalms 145:11",
      "text": "They shall speak of the glory of thy kingdom, and tell of thy power,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 12,
      "referenceLabel": "Psalms 145:12",
      "text": "to make known to the sons of men thy mighty deeds, and the glorious splendor of thy kingdom.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 13,
      "referenceLabel": "Psalms 145:13",
      "text": "Thy kingdom is an everlasting kingdom, and thy dominion endures throughout all generations. The Lord is faithful in all his words, and gracious in all his deeds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 14,
      "referenceLabel": "Psalms 145:14",
      "text": "The Lord upholds all who are falling, and raises up all who are bowed down.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 15,
      "referenceLabel": "Psalms 145:15",
      "text": "The eyes of all look to thee, and thou givest them their food in due season.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 16,
      "referenceLabel": "Psalms 145:16",
      "text": "Thou openest thy hand, thou satisfiest the desire of every living thing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 17,
      "referenceLabel": "Psalms 145:17",
      "text": "The Lord is just in all his ways, and kind in all his doings.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 18,
      "referenceLabel": "Psalms 145:18",
      "text": "The Lord is near to all who call upon him, to all who call upon him in truth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 19,
      "referenceLabel": "Psalms 145:19",
      "text": "He fulfils the desire of all who fear him, he also hears their cry, and saves them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 20,
      "referenceLabel": "Psalms 145:20",
      "text": "The Lord preserves all who love him; but all the wicked he will destroy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.145.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 145,
      "verseNumber": 21,
      "referenceLabel": "Psalms 145:21",
      "text": "My mouth will speak the praise of the Lord, and let all flesh bless his holy name for ever and ever.",
      "paragraphStart": false
    }
  ]
}
