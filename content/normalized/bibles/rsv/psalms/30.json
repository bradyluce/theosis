{
  "chapter": {
    "id": "rsv:psalms.30",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 30,
    "referenceLabel": "Psalms 30",
    "summary": "Source text for Psalms 30 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.30.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 1,
      "referenceLabel": "Psalms 30:1",
      "text": "I will extol thee, O Lord, for thou hast drawn me up, and hast not let my foes rejoice over me.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.30.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 2,
      "referenceLabel": "Psalms 30:2",
      "text": "O Lord my God, I cried to thee for help, and thou hast healed me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 3,
      "referenceLabel": "Psalms 30:3",
      "text": "O Lord, thou hast brought up my soul from Sheol, restored me to life from among those gone down to the Pit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 4,
      "referenceLabel": "Psalms 30:4",
      "text": "Sing praises to the Lord, O you his saints, and give thanks to his holy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 5,
      "referenceLabel": "Psalms 30:5",
      "text": "For his anger is but for a moment, and his favor is for a lifetime. Weeping may tarry for the night, but joy comes with the morning.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 6,
      "referenceLabel": "Psalms 30:6",
      "text": "As for me, I said in my prosperity, “I shall never be moved.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 7,
      "referenceLabel": "Psalms 30:7",
      "text": "By thy favor, O Lord, thou hadst established me as a strong mountain; thou didst hide thy face, I was dismayed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 8,
      "referenceLabel": "Psalms 30:8",
      "text": "To thee, O Lord, I cried; and to the Lord I made supplication:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 9,
      "referenceLabel": "Psalms 30:9",
      "text": "“What profit is there in my death, if I go down to the Pit? Will the dust praise thee? Will it tell of thy faithfulness?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 10,
      "referenceLabel": "Psalms 30:10",
      "text": "Hear, O Lord, and be gracious to me! O Lord, be thou my helper!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 11,
      "referenceLabel": "Psalms 30:11",
      "text": "Thou hast turned for me my mourning into dancing; thou hast loosed my sackcloth and girded me with gladness,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.30.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 30,
      "verseNumber": 12,
      "referenceLabel": "Psalms 30:12",
      "text": "that my soul may praise thee and not be silent. O Lord my God, I will give thanks to thee for ever.",
      "paragraphStart": false
    }
  ]
}
