{
  "chapter": {
    "id": "rsv:psalms.115",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 115,
    "referenceLabel": "Psalms 115",
    "summary": "Source text for Psalms 115 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.115.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 1,
      "referenceLabel": "Psalms 115:1",
      "text": "Not to us, O Lord, not to us, but to thy name give glory, for the sake of thy steadfast love and thy faithfulness!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.115.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 2,
      "referenceLabel": "Psalms 115:2",
      "text": "Why should the nations say, “Where is their God?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 3,
      "referenceLabel": "Psalms 115:3",
      "text": "Our God is in the heavens; he does whatever he pleases.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 4,
      "referenceLabel": "Psalms 115:4",
      "text": "Their idols are silver and gold, the work of men's hands.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 5,
      "referenceLabel": "Psalms 115:5",
      "text": "They have mouths, but do not speak; eyes, but do not see.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 6,
      "referenceLabel": "Psalms 115:6",
      "text": "They have ears, but do not hear; noses, but do not smell.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 7,
      "referenceLabel": "Psalms 115:7",
      "text": "They have hands, but do not feel; feet, but do not walk; and they do not make a sound in their throat.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 8,
      "referenceLabel": "Psalms 115:8",
      "text": "Those who make them are like them; so are all who trust in them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 9,
      "referenceLabel": "Psalms 115:9",
      "text": "O Israel, trust in the Lord! He is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 10,
      "referenceLabel": "Psalms 115:10",
      "text": "O house of Aaron, put your trust in the Lord! He is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 11,
      "referenceLabel": "Psalms 115:11",
      "text": "You who fear the Lord, trust in the Lord! He is their help and their shield.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 12,
      "referenceLabel": "Psalms 115:12",
      "text": "The Lord has been mindful of us; he will bless us; he will bless the house of Israel; he will bless the house of Aaron;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 13,
      "referenceLabel": "Psalms 115:13",
      "text": "he will bless those who fear the Lord, both small and great.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 14,
      "referenceLabel": "Psalms 115:14",
      "text": "May the Lord give you increase, you and your children!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 15,
      "referenceLabel": "Psalms 115:15",
      "text": "May you be blessed by the Lord, who made heaven and earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 16,
      "referenceLabel": "Psalms 115:16",
      "text": "The heavens are the Lord 's heavens, but the earth he has given to the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 17,
      "referenceLabel": "Psalms 115:17",
      "text": "The dead do not praise the Lord, nor do any that go down into silence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.115.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 115,
      "verseNumber": 18,
      "referenceLabel": "Psalms 115:18",
      "text": "But we will bless the Lord from this time forth and for evermore. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
