{
  "chapter": {
    "id": "rsv:psalms.7",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 7,
    "referenceLabel": "Psalms 7",
    "summary": "Source text for Psalms 7 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.7.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Psalms 7:1",
      "text": "O Lord my God, in thee do I take refuge; save me from all my pursuers, and deliver me,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.7.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Psalms 7:2",
      "text": "lest like a lion they rend me, dragging me away, with none to rescue.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Psalms 7:3",
      "text": "O Lord my God, if I have done this, if there is wrong in my hands,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Psalms 7:4",
      "text": "if I have requited my friend with evil or plundered my enemy without cause,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Psalms 7:5",
      "text": "let the enemy pursue me and overtake me, and let him trample my life to the ground, and lay my soul in the dust.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Psalms 7:6",
      "text": "Arise, O Lord, in thy anger, lift thyself up against the fury of my enemies; awake, O my God; thou hast appointed a judgment.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Psalms 7:7",
      "text": "Let the assembly of the peoples be gathered about thee; and over it take thy seat on high.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Psalms 7:8",
      "text": "The Lord judges the peoples; judge me, O Lord, according to my righteousness and according to the integrity that is in me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Psalms 7:9",
      "text": "O let the evil of the wicked come to an end, but establish thou the righteous, thou who triest the minds and hearts, thou righteous God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Psalms 7:10",
      "text": "My shield is with God, who saves the upright in heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Psalms 7:11",
      "text": "God is a righteous judge, and a God who has indignation every day.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Psalms 7:12",
      "text": "If a man does not repent, God will whet his sword; he has bent and strung his bow;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Psalms 7:13",
      "text": "he has prepared his deadly weapons, making his arrows fiery shafts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Psalms 7:14",
      "text": "Behold, the wicked man conceives evil, and is pregnant with mischief, and brings forth lies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Psalms 7:15",
      "text": "He makes a pit, digging it out, and falls into the hole which he has made.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Psalms 7:16",
      "text": "His mischief returns upon his own head, and on his own pate his violence descends.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.7.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Psalms 7:17",
      "text": "I will give to the Lord the thanks due to his righteousness, and I will sing praise to the name of the Lord, the Most High.",
      "paragraphStart": false
    }
  ]
}
