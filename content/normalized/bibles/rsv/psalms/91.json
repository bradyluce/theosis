{
  "chapter": {
    "id": "rsv:psalms.91",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 91,
    "referenceLabel": "Psalms 91",
    "summary": "Source text for Psalms 91 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.91.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 1,
      "referenceLabel": "Psalms 91:1",
      "text": "He who dwells in the shelter of the Most High, who abides in the shadow of the Almighty,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.91.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 2,
      "referenceLabel": "Psalms 91:2",
      "text": "will say to the Lord, “My refuge and my fortress; my God, in whom I trust.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 3,
      "referenceLabel": "Psalms 91:3",
      "text": "For he will deliver you from the snare of the fowler and from the deadly pestilence;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 4,
      "referenceLabel": "Psalms 91:4",
      "text": "he will cover you with his pinions, and under his wings you will find refuge; his faithfulness is a shield and buckler.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 5,
      "referenceLabel": "Psalms 91:5",
      "text": "You will not fear the terror of the night, nor the arrow that flies by day,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 6,
      "referenceLabel": "Psalms 91:6",
      "text": "nor the pestilence that stalks in darkness, nor the destruction that wastes at noonday.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 7,
      "referenceLabel": "Psalms 91:7",
      "text": "A thousand may fall at your side, ten thousand at your right hand; but it will not come near you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 8,
      "referenceLabel": "Psalms 91:8",
      "text": "You will only look with your eyes and see the recompense of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 9,
      "referenceLabel": "Psalms 91:9",
      "text": "Because you have made the Lord your refuge, the Most High your habitation,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 10,
      "referenceLabel": "Psalms 91:10",
      "text": "no evil shall befall you, no scourge come near your tent.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 11,
      "referenceLabel": "Psalms 91:11",
      "text": "For he will give his angels charge of you to guard you in all your ways.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 12,
      "referenceLabel": "Psalms 91:12",
      "text": "On their hands they will bear you up, lest you dash your foot against a stone.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 13,
      "referenceLabel": "Psalms 91:13",
      "text": "You will tread on the lion and the adder, the young lion and the serpent you will trample under foot.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 14,
      "referenceLabel": "Psalms 91:14",
      "text": "Because he cleaves to me in love, I will deliver him; I will protect him, because he knows my name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 15,
      "referenceLabel": "Psalms 91:15",
      "text": "When he calls to me, I will answer him; I will be with him in trouble, I will rescue him and honor him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.91.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 91,
      "verseNumber": 16,
      "referenceLabel": "Psalms 91:16",
      "text": "With long life I will satisfy him, and show him my salvation.",
      "paragraphStart": false
    }
  ]
}
