{
  "chapter": {
    "id": "rsv:psalms.88",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 88,
    "referenceLabel": "Psalms 88",
    "summary": "Source text for Psalms 88 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.88.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 1,
      "referenceLabel": "Psalms 88:1",
      "text": "O Lord, my God, I call for help by day; I cry out in the night before thee.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.88.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 2,
      "referenceLabel": "Psalms 88:2",
      "text": "Let my prayer come before thee, incline thy ear to my cry!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 3,
      "referenceLabel": "Psalms 88:3",
      "text": "For my soul is full of troubles, and my life draws near to Sheol.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 4,
      "referenceLabel": "Psalms 88:4",
      "text": "I am reckoned among those who go down to the Pit; I am a man who has no strength,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 5,
      "referenceLabel": "Psalms 88:5",
      "text": "like one forsaken among the dead, like the slain that lie in the grave, like those whom thou dost remember no more, for they are cut off from thy hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 6,
      "referenceLabel": "Psalms 88:6",
      "text": "Thou hast put me in the depths of the Pit, in the regions dark and deep.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 7,
      "referenceLabel": "Psalms 88:7",
      "text": "Thy wrath lies heavy upon me, and thou dost overwhelm me with all thy waves.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 8,
      "referenceLabel": "Psalms 88:8",
      "text": "Thou hast caused my companions to shun me; thou hast made me a thing of horror to them. I am shut in so that I cannot escape;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 9,
      "referenceLabel": "Psalms 88:9",
      "text": "my eye grows dim through sorrow. Every day I call upon thee, O Lord; I spread out my hands to thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 10,
      "referenceLabel": "Psalms 88:10",
      "text": "Dost thou work wonders for the dead? Do the shades rise up to praise thee?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 11,
      "referenceLabel": "Psalms 88:11",
      "text": "Is thy steadfast love declared in the grave, or thy faithfulness in Abaddon?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 12,
      "referenceLabel": "Psalms 88:12",
      "text": "Are thy wonders known in the darkness, or thy saving help in the land of forgetfulness?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 13,
      "referenceLabel": "Psalms 88:13",
      "text": "But I, O Lord, cry to thee; in the morning my prayer comes before thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 14,
      "referenceLabel": "Psalms 88:14",
      "text": "O Lord, why dost thou cast me off? Why dost thou hide thy face from me?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 15,
      "referenceLabel": "Psalms 88:15",
      "text": "Afflicted and close to death from my youth up, I suffer thy terrors; I am helpless.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 16,
      "referenceLabel": "Psalms 88:16",
      "text": "Thy wrath has swept over me; thy dread assaults destroy me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 17,
      "referenceLabel": "Psalms 88:17",
      "text": "They surround me like a flood all day long; they close in upon me together.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.88.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 88,
      "verseNumber": 18,
      "referenceLabel": "Psalms 88:18",
      "text": "Thou hast caused lover and friend to shun me; my companions are in darkness.",
      "paragraphStart": false
    }
  ]
}
