{
  "chapter": {
    "id": "rsv:psalms.121",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 121,
    "referenceLabel": "Psalms 121",
    "summary": "Source text for Psalms 121 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.121.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 1,
      "referenceLabel": "Psalms 121:1",
      "text": "I lift up my eyes to the hills. From whence does my help come?",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.121.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 2,
      "referenceLabel": "Psalms 121:2",
      "text": "My help comes from the Lord, who made heaven and earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.121.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 3,
      "referenceLabel": "Psalms 121:3",
      "text": "He will not let your foot be moved, he who keeps you will not slumber.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.121.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 4,
      "referenceLabel": "Psalms 121:4",
      "text": "Behold, he who keeps Israel will neither slumber nor sleep.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.121.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 5,
      "referenceLabel": "Psalms 121:5",
      "text": "The Lord is your keeper; the Lord is your shade on your right hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.121.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 6,
      "referenceLabel": "Psalms 121:6",
      "text": "The sun shall not smite you by day, nor the moon by night.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.121.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 7,
      "referenceLabel": "Psalms 121:7",
      "text": "The Lord will keep you from all evil; he will keep your life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.121.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 121,
      "verseNumber": 8,
      "referenceLabel": "Psalms 121:8",
      "text": "The Lord will keep your going out and your coming in from this time forth and for evermore.",
      "paragraphStart": false
    }
  ]
}
