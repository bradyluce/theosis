{
  "chapter": {
    "id": "rsv:psalms.132",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 132,
    "referenceLabel": "Psalms 132",
    "summary": "Source text for Psalms 132 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.132.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 1,
      "referenceLabel": "Psalms 132:1",
      "text": "Remember, O Lord, in David's favor, all the hardships he endured;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.132.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 2,
      "referenceLabel": "Psalms 132:2",
      "text": "how he swore to the Lord and vowed to the Mighty One of Jacob,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 3,
      "referenceLabel": "Psalms 132:3",
      "text": "“I will not enter my house or get into my bed;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 4,
      "referenceLabel": "Psalms 132:4",
      "text": "I will not give sleep to my eyes or slumber to my eyelids,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 5,
      "referenceLabel": "Psalms 132:5",
      "text": "until I find a place for the Lord, a dwelling place for the Mighty One of Jacob.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 6,
      "referenceLabel": "Psalms 132:6",
      "text": "Lo, we heard of it in Ephrathah, we found it in the fields of Jaar.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 7,
      "referenceLabel": "Psalms 132:7",
      "text": "“Let us go to his dwelling place; let us worship at his footstool!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 8,
      "referenceLabel": "Psalms 132:8",
      "text": "Arise, O Lord, and go to thy resting place, thou and the ark of thy might.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 9,
      "referenceLabel": "Psalms 132:9",
      "text": "Let thy priests be clothed with righteousness, and let thy saints shout for joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 10,
      "referenceLabel": "Psalms 132:10",
      "text": "For thy servant David's sake do not turn away the face of thy anointed one.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 11,
      "referenceLabel": "Psalms 132:11",
      "text": "The Lord swore to David a sure oath from which he will not turn back: “One of the sons of your body I will set on your throne.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 12,
      "referenceLabel": "Psalms 132:12",
      "text": "If your sons keep my covenant and my testimonies which I shall teach them, their sons also for ever shall sit upon your throne.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 13,
      "referenceLabel": "Psalms 132:13",
      "text": "For the Lord has chosen Zion; he has desired it for his habitation:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 14,
      "referenceLabel": "Psalms 132:14",
      "text": "“This is my resting place for ever; here I will dwell, for I have desired it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 15,
      "referenceLabel": "Psalms 132:15",
      "text": "I will abundantly bless her provisions; I will satisfy her poor with bread.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 16,
      "referenceLabel": "Psalms 132:16",
      "text": "Her priests I will clothe with salvation, and her saints will shout for joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 17,
      "referenceLabel": "Psalms 132:17",
      "text": "There I will make a horn to sprout for David; I have prepared a lamp for my anointed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.132.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 132,
      "verseNumber": 18,
      "referenceLabel": "Psalms 132:18",
      "text": "His enemies I will clothe with shame, but upon himself his crown will shed its luster.”",
      "paragraphStart": false
    }
  ]
}
