{
  "chapter": {
    "id": "rsv:psalms.21",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 21,
    "referenceLabel": "Psalms 21",
    "summary": "Source text for Psalms 21 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.21.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Psalms 21:1",
      "text": "In thy strength the king rejoices, O Lord; and in thy help how greatly he exults!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.21.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Psalms 21:2",
      "text": "Thou hast given him his heart's desire, and hast not withheld the request of his lips.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Psalms 21:3",
      "text": "For thou dost meet him with goodly blessings; thou dost set a crown of fine gold upon his head.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Psalms 21:4",
      "text": "He asked life of thee; thou gavest it to him, length of days for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Psalms 21:5",
      "text": "His glory is great through thy help; splendor and majesty thou dost bestow upon him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Psalms 21:6",
      "text": "Yea, thou dost make him most blessed for ever; thou dost make him glad with the joy of thy presence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Psalms 21:7",
      "text": "For the king trusts in the Lord; and through the steadfast love of the Most High he shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Psalms 21:8",
      "text": "Your hand will find out all your enemies; your right hand will find out those who hate you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Psalms 21:9",
      "text": "You will make them as a blazing oven when you appear. The Lord will swallow them up in his wrath; and fire will consume them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Psalms 21:10",
      "text": "You will destroy their offspring from the earth, and their children from among the sons of men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Psalms 21:11",
      "text": "If they plan evil against you, if they devise mischief, they will not succeed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Psalms 21:12",
      "text": "For you will put them to flight; you will aim at their faces with your bows.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.21.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Psalms 21:13",
      "text": "Be exalted, O Lord, in thy strength! We will sing and praise thy power.",
      "paragraphStart": false
    }
  ]
}
