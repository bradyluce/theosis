{
  "chapter": {
    "id": "rsv:psalms.143",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 143,
    "referenceLabel": "Psalms 143",
    "summary": "Source text for Psalms 143 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.143.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 1,
      "referenceLabel": "Psalms 143:1",
      "text": "Hear my prayer, O Lord; give ear to my supplications! In thy faithfulness answer me, in thy righteousness!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.143.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 2,
      "referenceLabel": "Psalms 143:2",
      "text": "Enter not into judgment with thy servant; for no man living is righteous before thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 3,
      "referenceLabel": "Psalms 143:3",
      "text": "For the enemy has pursued me; he has crushed my life to the ground; he has made me sit in darkness like those long dead.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 4,
      "referenceLabel": "Psalms 143:4",
      "text": "Therefore my spirit faints within me; my heart within me is appalled.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 5,
      "referenceLabel": "Psalms 143:5",
      "text": "I remember the days of old, I meditate on all that thou hast done; I muse on what thy hands have wrought.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 6,
      "referenceLabel": "Psalms 143:6",
      "text": "I stretch out my hands to thee; my soul thirsts for thee like a parched land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 7,
      "referenceLabel": "Psalms 143:7",
      "text": "Make haste to answer me, O Lord! My spirit fails! Hide not thy face from me, lest I be like those who go down to the Pit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 8,
      "referenceLabel": "Psalms 143:8",
      "text": "Let me hear in the morning of thy steadfast love, for in thee I put my trust. Teach me the way I should go, for to thee I lift up my soul.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 9,
      "referenceLabel": "Psalms 143:9",
      "text": "Deliver me, O Lord, from my enemies! I have fled to thee for refuge!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 10,
      "referenceLabel": "Psalms 143:10",
      "text": "Teach me to do thy will, for thou art my God! Let thy good spirit lead me on a level path!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 11,
      "referenceLabel": "Psalms 143:11",
      "text": "For thy name's sake, O Lord, preserve my life! In thy righteousness bring me out of trouble!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.143.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 143,
      "verseNumber": 12,
      "referenceLabel": "Psalms 143:12",
      "text": "And in thy steadfast love cut off my enemies, and destroy all my adversaries, for I am thy servant.",
      "paragraphStart": false
    }
  ]
}
