{
  "chapter": {
    "id": "rsv:psalms.69",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 69,
    "referenceLabel": "Psalms 69",
    "summary": "Source text for Psalms 69 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.69.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 1,
      "referenceLabel": "Psalms 69:1",
      "text": "Save me, O God! For the waters have come up to my neck.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.69.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 2,
      "referenceLabel": "Psalms 69:2",
      "text": "I sink in deep mire, where there is no foothold; I have come into deep waters, and the flood sweeps over me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 3,
      "referenceLabel": "Psalms 69:3",
      "text": "I am weary with my crying; my throat is parched. My eyes grow dim with waiting for my God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 4,
      "referenceLabel": "Psalms 69:4",
      "text": "More in number than the hairs of my head are those who hate me without cause; mighty are those who would destroy me, those who attack me with lies. What I did not steal must I now restore?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 5,
      "referenceLabel": "Psalms 69:5",
      "text": "O God, thou knowest my folly; the wrongs I have done are not hidden from thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 6,
      "referenceLabel": "Psalms 69:6",
      "text": "Let not those who hope in thee be put to shame through me, O Lord God of hosts; let not those who seek thee be brought to dishonor through me, O God of Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 7,
      "referenceLabel": "Psalms 69:7",
      "text": "For it is for thy sake that I have borne reproach, that shame has covered my face.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 8,
      "referenceLabel": "Psalms 69:8",
      "text": "I have become a stranger to my brethren, an alien to my mother's sons.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 9,
      "referenceLabel": "Psalms 69:9",
      "text": "For zeal for thy house has consumed me, and the insults of those who insult thee have fallen on me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 10,
      "referenceLabel": "Psalms 69:10",
      "text": "When I humbled my soul with fasting, it became my reproach.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 11,
      "referenceLabel": "Psalms 69:11",
      "text": "When I made sackcloth my clothing, I became a byword to them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 12,
      "referenceLabel": "Psalms 69:12",
      "text": "I am the talk of those who sit in the gate, and the drunkards make songs about me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 13,
      "referenceLabel": "Psalms 69:13",
      "text": "But as for me, my prayer is to thee, O Lord. At an acceptable time, O God, in the abundance of thy steadfast love answer me. With thy faithful help",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 14,
      "referenceLabel": "Psalms 69:14",
      "text": "rescue me from sinking in the mire; let me be delivered from my enemies and from the deep waters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 15,
      "referenceLabel": "Psalms 69:15",
      "text": "Let not the flood sweep over me, or the deep swallow me up, or the pit close its mouth over me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 16,
      "referenceLabel": "Psalms 69:16",
      "text": "Answer me, O Lord, for thy steadfast love is good; according to thy abundant mercy, turn to me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 17,
      "referenceLabel": "Psalms 69:17",
      "text": "Hide not thy face from thy servant; for I am in distress, make haste to answer me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 18,
      "referenceLabel": "Psalms 69:18",
      "text": "Draw near to me, redeem me, set me free because of my enemies!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 19,
      "referenceLabel": "Psalms 69:19",
      "text": "Thou knowest my reproach, and my shame and my dishonor; my foes are all known to thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 20,
      "referenceLabel": "Psalms 69:20",
      "text": "Insults have broken my heart, so that I am in despair. I looked for pity, but there was none; and for comforters, but I found none.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 21,
      "referenceLabel": "Psalms 69:21",
      "text": "They gave me poison for food, and for my thirst they gave me vinegar to drink.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 22,
      "referenceLabel": "Psalms 69:22",
      "text": "Let their own table before them become a snare; let their sacrificial feasts be a trap.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 23,
      "referenceLabel": "Psalms 69:23",
      "text": "Let their eyes be darkened, so that they cannot see; and make their loins tremble continually.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 24,
      "referenceLabel": "Psalms 69:24",
      "text": "Pour out thy indignation upon them, and let thy burning anger overtake them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 25,
      "referenceLabel": "Psalms 69:25",
      "text": "May their camp be a desolation, let no one dwell in their tents.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 26,
      "referenceLabel": "Psalms 69:26",
      "text": "For they persecute him whom thou hast smitten, and him whom thou hast wounded, they afflict still more.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 27,
      "referenceLabel": "Psalms 69:27",
      "text": "Add to them punishment upon punishment; may they have no acquittal from thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 28,
      "referenceLabel": "Psalms 69:28",
      "text": "Let them be blotted out of the book of the living; let them not be enrolled among the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 29,
      "referenceLabel": "Psalms 69:29",
      "text": "But I am afflicted and in pain; let thy salvation, O God, set me on high!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.30",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 30,
      "referenceLabel": "Psalms 69:30",
      "text": "I will praise the name of God with a song; I will magnify him with thanksgiving.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.31",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 31,
      "referenceLabel": "Psalms 69:31",
      "text": "This will please the Lord more than an ox or a bull with horns and hoofs.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.32",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 32,
      "referenceLabel": "Psalms 69:32",
      "text": "Let the oppressed see it and be glad; you who seek God, let your hearts revive.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.33",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 33,
      "referenceLabel": "Psalms 69:33",
      "text": "For the Lord hears the needy, and does not despise his own that are in bonds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.34",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 34,
      "referenceLabel": "Psalms 69:34",
      "text": "Let heaven and earth praise him, the seas and everything that moves therein.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.35",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 35,
      "referenceLabel": "Psalms 69:35",
      "text": "For God will save Zion and rebuild the cities of Judah; and his servants shall dwell there and possess it;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.69.36",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 69,
      "verseNumber": 36,
      "referenceLabel": "Psalms 69:36",
      "text": "the children of his servants shall inherit it, and those who love his name shall dwell in it.",
      "paragraphStart": false
    }
  ]
}
