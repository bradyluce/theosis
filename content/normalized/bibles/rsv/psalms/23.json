{
  "chapter": {
    "id": "rsv:psalms.23",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 23,
    "referenceLabel": "Psalms 23",
    "summary": "Source text for Psalms 23 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.23.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 1,
      "referenceLabel": "Psalms 23:1",
      "text": "The Lord is my shepherd, I shall not want;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.23.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 2,
      "referenceLabel": "Psalms 23:2",
      "text": "he makes me lie down in green pastures. He leads me beside still waters;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.23.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 3,
      "referenceLabel": "Psalms 23:3",
      "text": "he restores my soul. He leads me in paths of righteousness for his name's sake.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.23.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 4,
      "referenceLabel": "Psalms 23:4",
      "text": "Even though I walk through the valley of the shadow of death, I fear no evil; for thou art with me; thy rod and thy staff, they comfort me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.23.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 5,
      "referenceLabel": "Psalms 23:5",
      "text": "Thou preparest a table before me in the presence of my enemies; thou anointest my head with oil, my cup overflows.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.23.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 23,
      "verseNumber": 6,
      "referenceLabel": "Psalms 23:6",
      "text": "Surely goodness and mercy shall follow me all the days of my life; and I shall dwell in the house of the Lord for ever.",
      "paragraphStart": false
    }
  ]
}
