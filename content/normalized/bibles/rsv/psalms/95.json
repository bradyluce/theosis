{
  "chapter": {
    "id": "rsv:psalms.95",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 95,
    "referenceLabel": "Psalms 95",
    "summary": "Source text for Psalms 95 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.95.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 1,
      "referenceLabel": "Psalms 95:1",
      "text": "O come, let us sing to the Lord; let us make a joyful noise to the rock of our salvation!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.95.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 2,
      "referenceLabel": "Psalms 95:2",
      "text": "Let us come into his presence with thanksgiving; let us make a joyful noise to him with songs of praise!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 3,
      "referenceLabel": "Psalms 95:3",
      "text": "For the Lord is a great God, and a great King above all gods.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 4,
      "referenceLabel": "Psalms 95:4",
      "text": "In his hand are the depths of the earth; the heights of the mountains are his also.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 5,
      "referenceLabel": "Psalms 95:5",
      "text": "The sea is his, for he made it; for his hands formed the dry land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 6,
      "referenceLabel": "Psalms 95:6",
      "text": "O come, let us worship and bow down, let us kneel before the Lord, our Maker!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 7,
      "referenceLabel": "Psalms 95:7",
      "text": "For he is our God, and we are the people of his pasture, and the sheep of his hand. O that today you would hearken to his voice!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 8,
      "referenceLabel": "Psalms 95:8",
      "text": "Harden not your hearts, as at Meribah, as on the day at Massah in the wilderness,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 9,
      "referenceLabel": "Psalms 95:9",
      "text": "when your fathers tested me, and put me to the proof, though they had seen my work.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 10,
      "referenceLabel": "Psalms 95:10",
      "text": "For forty years I loathed that generation and said, “They are a people who err in heart, and they do not regard my ways.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.95.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 95,
      "verseNumber": 11,
      "referenceLabel": "Psalms 95:11",
      "text": "Therefore I swore in my anger that they should not enter my rest.",
      "paragraphStart": false
    }
  ]
}
