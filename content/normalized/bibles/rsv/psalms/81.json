{
  "chapter": {
    "id": "rsv:psalms.81",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 81,
    "referenceLabel": "Psalms 81",
    "summary": "Source text for Psalms 81 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.81.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 1,
      "referenceLabel": "Psalms 81:1",
      "text": "Sing aloud to God our strength; shout for joy to the God of Jacob!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.81.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 2,
      "referenceLabel": "Psalms 81:2",
      "text": "Raise a song, sound the timbrel, the sweet lyre with the harp.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 3,
      "referenceLabel": "Psalms 81:3",
      "text": "Blow the trumpet at the new moon, at the full moon, on our feast day.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 4,
      "referenceLabel": "Psalms 81:4",
      "text": "For it is a statute for Israel, an ordinance of the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 5,
      "referenceLabel": "Psalms 81:5",
      "text": "He made it a decree in Joseph, when he went out over the land of Egypt. I hear a voice I had not known:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 6,
      "referenceLabel": "Psalms 81:6",
      "text": "“I relieved your shoulder of the burden; your hands were freed from the basket.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 7,
      "referenceLabel": "Psalms 81:7",
      "text": "In distress you called, and I delivered you; I answered you in the secret place of thunder; I tested you at the waters of Meribah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 8,
      "referenceLabel": "Psalms 81:8",
      "text": "Hear, O my people, while I admonish you! O Israel, if you would but listen to me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 9,
      "referenceLabel": "Psalms 81:9",
      "text": "There shall be no strange god among you; you shall not bow down to a foreign god.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 10,
      "referenceLabel": "Psalms 81:10",
      "text": "I am the Lord your God, who brought you up out of the land of Egypt. Open your mouth wide, and I will fill it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 11,
      "referenceLabel": "Psalms 81:11",
      "text": "“But my people did not listen to my voice; Israel would have none of me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 12,
      "referenceLabel": "Psalms 81:12",
      "text": "So I gave them over to their stubborn hearts, to follow their own counsels.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 13,
      "referenceLabel": "Psalms 81:13",
      "text": "O that my people would listen to me, that Israel would walk in my ways!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 14,
      "referenceLabel": "Psalms 81:14",
      "text": "I would soon subdue their enemies, and turn my hand against their foes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 15,
      "referenceLabel": "Psalms 81:15",
      "text": "Those who hate the Lord would cringe toward him, and their fate would last for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.81.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 81,
      "verseNumber": 16,
      "referenceLabel": "Psalms 81:16",
      "text": "I would feed you with the finest of the wheat, and with honey from the rock I would satisfy you.”",
      "paragraphStart": false
    }
  ]
}
