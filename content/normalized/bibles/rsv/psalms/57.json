{
  "chapter": {
    "id": "rsv:psalms.57",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 57,
    "referenceLabel": "Psalms 57",
    "summary": "Source text for Psalms 57 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.57.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 1,
      "referenceLabel": "Psalms 57:1",
      "text": "Be merciful to me, O God, be merciful to me, for in thee my soul takes refuge; in the shadow of thy wings I will take refuge, till the storms of destruction pass by.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.57.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 2,
      "referenceLabel": "Psalms 57:2",
      "text": "I cry to God Most High, to God who fulfils his purpose for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 3,
      "referenceLabel": "Psalms 57:3",
      "text": "He will send from heaven and save me, he will put to shame those who trample upon me. God will send forth his steadfast love and his faithfulness!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 4,
      "referenceLabel": "Psalms 57:4",
      "text": "I lie in the midst of lions that greedily devour the sons of men; their teeth are spears and arrows, their tongues sharp swords.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 5,
      "referenceLabel": "Psalms 57:5",
      "text": "Be exalted, O God, above the heavens! Let thy glory be over all the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 6,
      "referenceLabel": "Psalms 57:6",
      "text": "They set a net for my steps; my soul was bowed down. They dug a pit in my way, but they have fallen into it themselves.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 7,
      "referenceLabel": "Psalms 57:7",
      "text": "My heart is steadfast, O God, my heart is steadfast! I will sing and make melody!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 8,
      "referenceLabel": "Psalms 57:8",
      "text": "Awake, my soul! Awake, O harp and lyre! I will awake the dawn!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 9,
      "referenceLabel": "Psalms 57:9",
      "text": "I will give thanks to thee, O Lord, among the peoples; I will sing praises to thee among the nations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 10,
      "referenceLabel": "Psalms 57:10",
      "text": "For thy steadfast love is great to the heavens, thy faithfulness to the clouds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.57.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 57,
      "verseNumber": 11,
      "referenceLabel": "Psalms 57:11",
      "text": "Be exalted, O God, above the heavens! Let thy glory be over all the earth!",
      "paragraphStart": false
    }
  ]
}
