{
  "chapter": {
    "id": "rsv:psalms.41",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 41,
    "referenceLabel": "Psalms 41",
    "summary": "Source text for Psalms 41 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.41.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 1,
      "referenceLabel": "Psalms 41:1",
      "text": "Blessed is he who considers the poor! The Lord delivers him in the day of trouble;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.41.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 2,
      "referenceLabel": "Psalms 41:2",
      "text": "the Lord protects him and keeps him alive; he is called blessed in the land; thou dost not give him up to the will of his enemies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 3,
      "referenceLabel": "Psalms 41:3",
      "text": "The Lord sustains him on his sickbed; in his illness thou healest all his infirmities.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 4,
      "referenceLabel": "Psalms 41:4",
      "text": "As for me, I said, “O Lord, be gracious to me; heal me, for I have sinned against thee!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 5,
      "referenceLabel": "Psalms 41:5",
      "text": "My enemies say of me in malice: “When will he die, and his name perish?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 6,
      "referenceLabel": "Psalms 41:6",
      "text": "And when one comes to see me, he utters empty words, while his heart gathers mischief; when he goes out, he tells it abroad.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 7,
      "referenceLabel": "Psalms 41:7",
      "text": "All who hate me whisper together about me; they imagine the worst for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 8,
      "referenceLabel": "Psalms 41:8",
      "text": "They say, “A deadly thing has fastened upon him; he will not rise again from where he lies.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 9,
      "referenceLabel": "Psalms 41:9",
      "text": "Even my bosom friend in whom I trusted, who ate of my bread, has lifted his heel against me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 10,
      "referenceLabel": "Psalms 41:10",
      "text": "But do thou, O Lord, be gracious to me, and raise me up, that I may requite them!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 11,
      "referenceLabel": "Psalms 41:11",
      "text": "By this I know that thou art pleased with me, in that my enemy has not triumphed over me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 12,
      "referenceLabel": "Psalms 41:12",
      "text": "But thou hast upheld me because of my integrity, and set me in thy presence for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.41.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 41,
      "verseNumber": 13,
      "referenceLabel": "Psalms 41:13",
      "text": "Blessed be the Lord, the God of Israel, from everlasting to everlasting! Amen and Amen.",
      "paragraphStart": false
    }
  ]
}
