{
  "chapter": {
    "id": "rsv:psalms.90",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 90,
    "referenceLabel": "Psalms 90",
    "summary": "Source text for Psalms 90 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.90.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 1,
      "referenceLabel": "Psalms 90:1",
      "text": "Lord, thou hast been our dwelling place in all generations.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.90.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 2,
      "referenceLabel": "Psalms 90:2",
      "text": "Before the mountains were brought forth, or ever thou hadst formed the earth and the world, from everlasting to everlasting thou art God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 3,
      "referenceLabel": "Psalms 90:3",
      "text": "Thou turnest man back to the dust, and sayest, “Turn back, O children of men!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 4,
      "referenceLabel": "Psalms 90:4",
      "text": "For a thousand years in thy sight are but as yesterday when it is past, or as a watch in the night.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 5,
      "referenceLabel": "Psalms 90:5",
      "text": "Thou dost sweep men away; they are like a dream, like grass which is renewed in the morning:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 6,
      "referenceLabel": "Psalms 90:6",
      "text": "in the morning it flourishes and is renewed; in the evening it fades and withers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 7,
      "referenceLabel": "Psalms 90:7",
      "text": "For we are consumed by thy anger; by thy wrath we are overwhelmed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 8,
      "referenceLabel": "Psalms 90:8",
      "text": "Thou hast set our iniquities before thee, our secret sins in the light of thy countenance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 9,
      "referenceLabel": "Psalms 90:9",
      "text": "For all our days pass away under thy wrath, our years come to an end like a sigh.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 10,
      "referenceLabel": "Psalms 90:10",
      "text": "The years of our life are threescore and ten, or even by reason of strength fourscore; yet their span is but toil and trouble; they are soon gone, and we fly away.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 11,
      "referenceLabel": "Psalms 90:11",
      "text": "Who considers the power of thy anger, and thy wrath according to the fear of thee?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 12,
      "referenceLabel": "Psalms 90:12",
      "text": "So teach us to number our days that we may get a heart of wisdom.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 13,
      "referenceLabel": "Psalms 90:13",
      "text": "Return, O Lord! How long? Have pity on thy servants!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 14,
      "referenceLabel": "Psalms 90:14",
      "text": "Satisfy us in the morning with thy steadfast love, that we may rejoice and be glad all our days.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 15,
      "referenceLabel": "Psalms 90:15",
      "text": "Make us glad as many days as thou hast afflicted us, and as many years as we have seen evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 16,
      "referenceLabel": "Psalms 90:16",
      "text": "Let thy work be manifest to thy servants, and thy glorious power to their children.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.90.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 90,
      "verseNumber": 17,
      "referenceLabel": "Psalms 90:17",
      "text": "Let the favor of the Lord our God be upon us, and establish thou the work of our hands upon us, yea, the work of our hands establish thou it.",
      "paragraphStart": false
    }
  ]
}
