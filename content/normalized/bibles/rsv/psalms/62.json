{
  "chapter": {
    "id": "rsv:psalms.62",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 62,
    "referenceLabel": "Psalms 62",
    "summary": "Source text for Psalms 62 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.62.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 1,
      "referenceLabel": "Psalms 62:1",
      "text": "For God alone my soul waits in silence; from him comes my salvation.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.62.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 2,
      "referenceLabel": "Psalms 62:2",
      "text": "He only is my rock and my salvation, my fortress; I shall not be greatly moved.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 3,
      "referenceLabel": "Psalms 62:3",
      "text": "How long will you set upon a man to shatter him, all of you, like a leaning wall, a tottering fence?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 4,
      "referenceLabel": "Psalms 62:4",
      "text": "They only plan to thrust him down from his eminence. They take pleasure in falsehood. They bless with their mouths, but inwardly they curse.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 5,
      "referenceLabel": "Psalms 62:5",
      "text": "For God alone my soul waits in silence, for my hope is from him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 6,
      "referenceLabel": "Psalms 62:6",
      "text": "He only is my rock and my salvation, my fortress; I shall not be shaken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 7,
      "referenceLabel": "Psalms 62:7",
      "text": "On God rests my deliverance and my honor; my mighty rock, my refuge is God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 8,
      "referenceLabel": "Psalms 62:8",
      "text": "Trust in him at all times, O people; pour out your heart before him; God is a refuge for us.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 9,
      "referenceLabel": "Psalms 62:9",
      "text": "Men of low estate are but a breath, men of high estate are a delusion; in the balances they go up; they are together lighter than a breath.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 10,
      "referenceLabel": "Psalms 62:10",
      "text": "Put no confidence in extortion, set no vain hopes on robbery; if riches increase, set not your heart on them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 11,
      "referenceLabel": "Psalms 62:11",
      "text": "Once God has spoken; twice have I heard this: that power belongs to God;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.62.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 62,
      "verseNumber": 12,
      "referenceLabel": "Psalms 62:12",
      "text": "and that to thee, O Lord, belongs steadfast love. For thou dost requite a man according to his work.",
      "paragraphStart": false
    }
  ]
}
