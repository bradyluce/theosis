{
  "chapter": {
    "id": "rsv:psalms.35",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 35,
    "referenceLabel": "Psalms 35",
    "summary": "Source text for Psalms 35 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.35.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 1,
      "referenceLabel": "Psalms 35:1",
      "text": "Contend, O Lord, with those who contend with me; fight against those who fight against me!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.35.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 2,
      "referenceLabel": "Psalms 35:2",
      "text": "Take hold of shield and buckler, and rise for my help!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 3,
      "referenceLabel": "Psalms 35:3",
      "text": "Draw the spear and javelin against my pursuers! Say to my soul, “I am your deliverance!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 4,
      "referenceLabel": "Psalms 35:4",
      "text": "Let them be put to shame and dishonor who seek after my life! Let them be turned back and confounded who devise evil against me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 5,
      "referenceLabel": "Psalms 35:5",
      "text": "Let them be like chaff before the wind, with the angel of the Lord driving them on!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 6,
      "referenceLabel": "Psalms 35:6",
      "text": "Let their way be dark and slippery, with the angel of the Lord pursuing them!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 7,
      "referenceLabel": "Psalms 35:7",
      "text": "For without cause they hid their net for me; without cause they dug a pit for my life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 8,
      "referenceLabel": "Psalms 35:8",
      "text": "Let ruin come upon them unawares! And let the net which they hid ensnare them; let them fall therein to ruin!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 9,
      "referenceLabel": "Psalms 35:9",
      "text": "Then my soul shall rejoice in the Lord, exulting in his deliverance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 10,
      "referenceLabel": "Psalms 35:10",
      "text": "All my bones shall say, “O Lord, who is like thee, thou who deliverest the weak from him who is too strong for him, the weak and needy from him who despoils him?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 11,
      "referenceLabel": "Psalms 35:11",
      "text": "Malicious witnesses rise up; they ask me of things that I know not.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 12,
      "referenceLabel": "Psalms 35:12",
      "text": "They requite me evil for good; my soul is forlorn.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 13,
      "referenceLabel": "Psalms 35:13",
      "text": "But I, when they were sick— I wore sackcloth, I afflicted myself with fasting. I prayed with head bowed on my bosom,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 14,
      "referenceLabel": "Psalms 35:14",
      "text": "as though I grieved for my friend or my brother; I went about as one who laments his mother, bowed down and in mourning.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 15,
      "referenceLabel": "Psalms 35:15",
      "text": "But at my stumbling they gathered in glee, they gathered together against me; cripples whom I knew not slandered me without ceasing;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 16,
      "referenceLabel": "Psalms 35:16",
      "text": "they impiously mocked more and more, gnashing at me with their teeth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 17,
      "referenceLabel": "Psalms 35:17",
      "text": "How long, O Lord, wilt thou look on? Rescue me from their ravages, my life from the lions!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 18,
      "referenceLabel": "Psalms 35:18",
      "text": "Then I will thank thee in the great congregation; in the mighty throng I will praise thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 19,
      "referenceLabel": "Psalms 35:19",
      "text": "Let not those rejoice over me who are wrongfully my foes, and let not those wink the eye who hate me without cause.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 20,
      "referenceLabel": "Psalms 35:20",
      "text": "For they do not speak peace, but against those who are quiet in the land they conceive words of deceit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 21,
      "referenceLabel": "Psalms 35:21",
      "text": "They open wide their mouths against me; they say, “Aha, Aha! our eyes have seen it!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 22,
      "referenceLabel": "Psalms 35:22",
      "text": "Thou hast seen, O Lord; be not silent! O Lord, be not far from me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 23,
      "referenceLabel": "Psalms 35:23",
      "text": "Bestir thyself, and awake for my right, for my cause, my God and my Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 24,
      "referenceLabel": "Psalms 35:24",
      "text": "Vindicate me, O Lord, my God, according to thy righteousness; and let them not rejoice over me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 25,
      "referenceLabel": "Psalms 35:25",
      "text": "Let them not say to themselves, “Aha, we have our heart's desire!” Let them not say, “We have swallowed him up.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 26,
      "referenceLabel": "Psalms 35:26",
      "text": "Let them be put to shame and confusion altogether who rejoice at my calamity! Let them be clothed with shame and dishonor who magnify themselves against me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 27,
      "referenceLabel": "Psalms 35:27",
      "text": "Let those who desire my vindication shout for joy and be glad, and say evermore, “Great is the Lord, who delights in the welfare of his servant!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.35.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 35,
      "verseNumber": 28,
      "referenceLabel": "Psalms 35:28",
      "text": "Then my tongue shall tell of thy righteousness and of thy praise all the day long.",
      "paragraphStart": false
    }
  ]
}
