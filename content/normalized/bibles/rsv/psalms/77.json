{
  "chapter": {
    "id": "rsv:psalms.77",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 77,
    "referenceLabel": "Psalms 77",
    "summary": "Source text for Psalms 77 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.77.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 1,
      "referenceLabel": "Psalms 77:1",
      "text": "I cry aloud to God, aloud to God, that he may hear me.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.77.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 2,
      "referenceLabel": "Psalms 77:2",
      "text": "In the day of my trouble I seek the Lord; in the night my hand is stretched out without wearying; my soul refuses to be comforted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 3,
      "referenceLabel": "Psalms 77:3",
      "text": "I think of God, and I moan; I meditate, and my spirit faints.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 4,
      "referenceLabel": "Psalms 77:4",
      "text": "Thou dost hold my eyelids from closing; I am so troubled that I cannot speak.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 5,
      "referenceLabel": "Psalms 77:5",
      "text": "I consider the days of old, I remember the years long ago.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 6,
      "referenceLabel": "Psalms 77:6",
      "text": "I commune with my heart in the night; I meditate and search my spirit:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 7,
      "referenceLabel": "Psalms 77:7",
      "text": "“Will the Lord spurn for ever, and never again be favorable?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 8,
      "referenceLabel": "Psalms 77:8",
      "text": "Has his steadfast love for ever ceased? Are his promises at an end for all time?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 9,
      "referenceLabel": "Psalms 77:9",
      "text": "Has God forgotten to be gracious? Has he in anger shut up his compassion?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 10,
      "referenceLabel": "Psalms 77:10",
      "text": "And I say, “It is my grief that the right hand of the Most High has changed.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 11,
      "referenceLabel": "Psalms 77:11",
      "text": "I will call to mind the deeds of the Lord; yea, I will remember thy wonders of old.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 12,
      "referenceLabel": "Psalms 77:12",
      "text": "I will meditate on all thy work, and muse on thy mighty deeds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 13,
      "referenceLabel": "Psalms 77:13",
      "text": "Thy way, O God, is holy. What god is great like our God?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 14,
      "referenceLabel": "Psalms 77:14",
      "text": "Thou art the God who workest wonders, who hast manifested thy might among the peoples.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 15,
      "referenceLabel": "Psalms 77:15",
      "text": "Thou didst with thy arm redeem thy people, the sons of Jacob and Joseph.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 16,
      "referenceLabel": "Psalms 77:16",
      "text": "When the waters saw thee, O God, when the waters saw thee, they were afraid, yea, the deep trembled.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 17,
      "referenceLabel": "Psalms 77:17",
      "text": "The clouds poured out water; the skies gave forth thunder; thy arrows flashed on every side.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 18,
      "referenceLabel": "Psalms 77:18",
      "text": "The crash of thy thunder was in the whirlwind; thy lightnings lighted up the world; the earth trembled and shook.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 19,
      "referenceLabel": "Psalms 77:19",
      "text": "Thy way was through the sea, thy path through the great waters; yet thy footprints were unseen.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.77.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 77,
      "verseNumber": 20,
      "referenceLabel": "Psalms 77:20",
      "text": "Thou didst lead thy people like a flock by the hand of Moses and Aaron.",
      "paragraphStart": false
    }
  ]
}
