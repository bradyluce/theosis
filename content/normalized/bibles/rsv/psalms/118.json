{
  "chapter": {
    "id": "rsv:psalms.118",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 118,
    "referenceLabel": "Psalms 118",
    "summary": "Source text for Psalms 118 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.118.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 1,
      "referenceLabel": "Psalms 118:1",
      "text": "O give thanks to the Lord, for he is good; his steadfast love endures for ever!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.118.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 2,
      "referenceLabel": "Psalms 118:2",
      "text": "Let Israel say, “His steadfast love endures for ever.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 3,
      "referenceLabel": "Psalms 118:3",
      "text": "Let the house of Aaron say, “His steadfast love endures for ever.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 4,
      "referenceLabel": "Psalms 118:4",
      "text": "Let those who fear the Lord say, “His steadfast love endures for ever.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 5,
      "referenceLabel": "Psalms 118:5",
      "text": "Out of my distress I called on the Lord; the Lord answered me and set me free.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 6,
      "referenceLabel": "Psalms 118:6",
      "text": "With the Lord on my side I do not fear. What can man do to me?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 7,
      "referenceLabel": "Psalms 118:7",
      "text": "The Lord is on my side to help me; I shall look in triumph on those who hate me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 8,
      "referenceLabel": "Psalms 118:8",
      "text": "It is better to take refuge in the Lord than to put confidence in man.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 9,
      "referenceLabel": "Psalms 118:9",
      "text": "It is better to take refuge in the Lord than to put confidence in princes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 10,
      "referenceLabel": "Psalms 118:10",
      "text": "All nations surrounded me; in the name of the Lord I cut them off!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 11,
      "referenceLabel": "Psalms 118:11",
      "text": "They surrounded me, surrounded me on every side; in the name of the Lord I cut them off!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 12,
      "referenceLabel": "Psalms 118:12",
      "text": "They surrounded me like bees, they blazed like a fire of thorns; in the name of the Lord I cut them off!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 13,
      "referenceLabel": "Psalms 118:13",
      "text": "I was pushed hard, so that I was falling, but the Lord helped me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 14,
      "referenceLabel": "Psalms 118:14",
      "text": "The Lord is my strength and my song; he has become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 15,
      "referenceLabel": "Psalms 118:15",
      "text": "Hark, glad songs of victory in the tents of the righteous: “The right hand of the Lord does valiantly,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 16,
      "referenceLabel": "Psalms 118:16",
      "text": "the right hand of the Lord is exalted, the right hand of the Lord does valiantly!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 17,
      "referenceLabel": "Psalms 118:17",
      "text": "I shall not die, but I shall live, and recount the deeds of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 18,
      "referenceLabel": "Psalms 118:18",
      "text": "The Lord has chastened me sorely, but he has not given me over to death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 19,
      "referenceLabel": "Psalms 118:19",
      "text": "Open to me the gates of righteousness, that I may enter through them and give thanks to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 20,
      "referenceLabel": "Psalms 118:20",
      "text": "This is the gate of the Lord; the righteous shall enter through it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 21,
      "referenceLabel": "Psalms 118:21",
      "text": "I thank thee that thou hast answered me and hast become my salvation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 22,
      "referenceLabel": "Psalms 118:22",
      "text": "The stone which the builders rejected has become the head of the corner.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 23,
      "referenceLabel": "Psalms 118:23",
      "text": "This is the Lord 's doing; it is marvelous in our eyes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 24,
      "referenceLabel": "Psalms 118:24",
      "text": "This is the day which the Lord has made; let us rejoice and be glad in it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 25,
      "referenceLabel": "Psalms 118:25",
      "text": "Save us, we beseech thee, O Lord! O Lord, we beseech thee, give us success!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 26,
      "referenceLabel": "Psalms 118:26",
      "text": "Blessed be he who enters in the name of the Lord! We bless you from the house of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 27,
      "referenceLabel": "Psalms 118:27",
      "text": "The Lord is God, and he has given us light. Bind the festal procession with branches, up to the horns of the altar!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 28,
      "referenceLabel": "Psalms 118:28",
      "text": "Thou art my God, and I will give thanks to thee; thou art my God, I will extol thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.118.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 118,
      "verseNumber": 29,
      "referenceLabel": "Psalms 118:29",
      "text": "O give thanks to the Lord, for he is good; for his steadfast love endures for ever!",
      "paragraphStart": false
    }
  ]
}
