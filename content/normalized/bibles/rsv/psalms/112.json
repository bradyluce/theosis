{
  "chapter": {
    "id": "rsv:psalms.112",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 112,
    "referenceLabel": "Psalms 112",
    "summary": "Source text for Psalms 112 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.112.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 1,
      "referenceLabel": "Psalms 112:1",
      "text": "Praise the Lord! Blessed is the man who fears the Lord, who greatly delights in his commandments!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.112.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 2,
      "referenceLabel": "Psalms 112:2",
      "text": "His descendants will be mighty in the land; the generation of the upright will be blessed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 3,
      "referenceLabel": "Psalms 112:3",
      "text": "Wealth and riches are in his house; and his righteousness endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 4,
      "referenceLabel": "Psalms 112:4",
      "text": "Light rises in the darkness for the upright; the Lord is gracious, merciful, and righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 5,
      "referenceLabel": "Psalms 112:5",
      "text": "It is well with the man who deals generously and lends, who conducts his affairs with justice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 6,
      "referenceLabel": "Psalms 112:6",
      "text": "For the righteous will never be moved; he will be remembered for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 7,
      "referenceLabel": "Psalms 112:7",
      "text": "He is not afraid of evil tidings; his heart is firm, trusting in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 8,
      "referenceLabel": "Psalms 112:8",
      "text": "His heart is steady, he will not be afraid, until he sees his desire on his adversaries.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 9,
      "referenceLabel": "Psalms 112:9",
      "text": "He has distributed freely, he has given to the poor; his righteousness endures for ever; his horn is exalted in honor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.112.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 112,
      "verseNumber": 10,
      "referenceLabel": "Psalms 112:10",
      "text": "The wicked man sees it and is angry; he gnashes his teeth and melts away; the desire of the wicked man comes to naught.",
      "paragraphStart": false
    }
  ]
}
