{
  "chapter": {
    "id": "rsv:psalms.29",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 29,
    "referenceLabel": "Psalms 29",
    "summary": "Source text for Psalms 29 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.29.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Psalms 29:1",
      "text": "Ascribe to the Lord, O heavenly beings, ascribe to the Lord glory and strength.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.29.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Psalms 29:2",
      "text": "Ascribe to the Lord the glory of his name; worship the Lord in holy array.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Psalms 29:3",
      "text": "The voice of the Lord is upon the waters; the God of glory thunders, the Lord, upon many waters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Psalms 29:4",
      "text": "The voice of the Lord is powerful, the voice of the Lord is full of majesty.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Psalms 29:5",
      "text": "The voice of the Lord breaks the cedars, the Lord breaks the cedars of Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Psalms 29:6",
      "text": "He makes Lebanon to skip like a calf, and Sirion like a young wild ox.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Psalms 29:7",
      "text": "The voice of the Lord flashes forth flames of fire.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Psalms 29:8",
      "text": "The voice of the Lord shakes the wilderness, the Lord shakes the wilderness of Kadesh.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Psalms 29:9",
      "text": "The voice of the Lord makes the oaks to whirl, and strips the forests bare; and in his temple all cry, “Glory!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Psalms 29:10",
      "text": "The Lord sits enthroned over the flood; the Lord sits enthroned as king for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.29.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Psalms 29:11",
      "text": "May the Lord give strength to his people! May the Lord bless his people with peace!",
      "paragraphStart": false
    }
  ]
}
