{
  "chapter": {
    "id": "rsv:psalms.86",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 86,
    "referenceLabel": "Psalms 86",
    "summary": "Source text for Psalms 86 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.86.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 1,
      "referenceLabel": "Psalms 86:1",
      "text": "Incline thy ear, O Lord, and answer me, for I am poor and needy.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.86.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 2,
      "referenceLabel": "Psalms 86:2",
      "text": "Preserve my life, for I am godly; save thy servant who trusts in thee. Thou art my God;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 3,
      "referenceLabel": "Psalms 86:3",
      "text": "be gracious to me, O Lord, for to thee do I cry all the day.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 4,
      "referenceLabel": "Psalms 86:4",
      "text": "Gladden the soul of thy servant, for to thee, O Lord, do I lift up my soul.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 5,
      "referenceLabel": "Psalms 86:5",
      "text": "For thou, O Lord, art good and forgiving, abounding in steadfast love to all who call on thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 6,
      "referenceLabel": "Psalms 86:6",
      "text": "Give ear, O Lord, to my prayer; hearken to my cry of supplication.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 7,
      "referenceLabel": "Psalms 86:7",
      "text": "In the day of my trouble I call on thee, for thou dost answer me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 8,
      "referenceLabel": "Psalms 86:8",
      "text": "There is none like thee among the gods, O Lord, nor are there any works like thine.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 9,
      "referenceLabel": "Psalms 86:9",
      "text": "All the nations thou hast made shall come and bow down before thee, O Lord, and shall glorify thy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 10,
      "referenceLabel": "Psalms 86:10",
      "text": "For thou art great and doest wondrous things, thou alone art God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 11,
      "referenceLabel": "Psalms 86:11",
      "text": "Teach me thy way, O Lord, that I may walk in thy truth; unite my heart to fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 12,
      "referenceLabel": "Psalms 86:12",
      "text": "I give thanks to thee, O Lord my God, with my whole heart, and I will glorify thy name for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 13,
      "referenceLabel": "Psalms 86:13",
      "text": "For great is thy steadfast love toward me; thou hast delivered my soul from the depths of Sheol.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 14,
      "referenceLabel": "Psalms 86:14",
      "text": "O God, insolent men have risen up against me; a band of ruthless men seek my life, and they do not set thee before them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 15,
      "referenceLabel": "Psalms 86:15",
      "text": "But thou, O Lord, art a God merciful and gracious, slow to anger and abounding in steadfast love and faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 16,
      "referenceLabel": "Psalms 86:16",
      "text": "Turn to me and take pity on me; give thy strength to thy servant, and save the son of thy handmaid.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.86.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 86,
      "verseNumber": 17,
      "referenceLabel": "Psalms 86:17",
      "text": "Show me a sign of thy favor, that those who hate me may see and be put to shame because thou, Lord, hast helped me and comforted me.",
      "paragraphStart": false
    }
  ]
}
