{
  "chapter": {
    "id": "rsv:psalms.137",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 137,
    "referenceLabel": "Psalms 137",
    "summary": "Source text for Psalms 137 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.137.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 1,
      "referenceLabel": "Psalms 137:1",
      "text": "By the waters of Babylon, there we sat down and wept, when we remembered Zion.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.137.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 2,
      "referenceLabel": "Psalms 137:2",
      "text": "On the willows there we hung up our lyres.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 3,
      "referenceLabel": "Psalms 137:3",
      "text": "For there our captors required of us songs, and our tormentors, mirth, saying, “Sing us one of the songs of Zion!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 4,
      "referenceLabel": "Psalms 137:4",
      "text": "How shall we sing the Lord 's song in a foreign land?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 5,
      "referenceLabel": "Psalms 137:5",
      "text": "If I forget you, O Jerusalem, let my right hand wither!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 6,
      "referenceLabel": "Psalms 137:6",
      "text": "Let my tongue cleave to the roof of my mouth, if I do not remember you, if I do not set Jerusalem above my highest joy!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 7,
      "referenceLabel": "Psalms 137:7",
      "text": "Remember, O Lord, against the Edomites the day of Jerusalem, how they said, “Raze it, raze it! Down to its foundations!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 8,
      "referenceLabel": "Psalms 137:8",
      "text": "O daughter of Babylon, you devastator! Happy shall he be who requites you with what you have done to us!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.137.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 137,
      "verseNumber": 9,
      "referenceLabel": "Psalms 137:9",
      "text": "Happy shall he be who takes your little ones and dashes them against the rock!",
      "paragraphStart": false
    }
  ]
}
