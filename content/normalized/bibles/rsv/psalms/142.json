{
  "chapter": {
    "id": "rsv:psalms.142",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 142,
    "referenceLabel": "Psalms 142",
    "summary": "Source text for Psalms 142 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.142.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 1,
      "referenceLabel": "Psalms 142:1",
      "text": "I cry with my voice to the Lord, with my voice I make supplication to the Lord,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.142.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 2,
      "referenceLabel": "Psalms 142:2",
      "text": "I pour out my complaint before him, I tell my trouble before him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.142.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 3,
      "referenceLabel": "Psalms 142:3",
      "text": "When my spirit is faint, thou knowest my way! In the path where I walk they have hidden a trap for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.142.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 4,
      "referenceLabel": "Psalms 142:4",
      "text": "I look to the right and watch, but there is none who takes notice of me; no refuge remains to me, no man cares for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.142.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 5,
      "referenceLabel": "Psalms 142:5",
      "text": "I cry to thee, O Lord; I say, Thou art my refuge, my portion in the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.142.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 6,
      "referenceLabel": "Psalms 142:6",
      "text": "Give heed to my cry; for I am brought very low! Deliver me from my persecutors; for they are too strong for me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.142.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 142,
      "verseNumber": 7,
      "referenceLabel": "Psalms 142:7",
      "text": "Bring me out of prison, that I may give thanks to thy name! The righteous will surround me; for thou wilt deal bountifully with me.",
      "paragraphStart": false
    }
  ]
}
