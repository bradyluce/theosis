{
  "chapter": {
    "id": "rsv:psalms.102",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 102,
    "referenceLabel": "Psalms 102",
    "summary": "Source text for Psalms 102 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.102.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 1,
      "referenceLabel": "Psalms 102:1",
      "text": "Hear my prayer, O Lord; let my cry come to thee!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.102.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 2,
      "referenceLabel": "Psalms 102:2",
      "text": "Do not hide thy face from me in the day of my distress! Incline thy ear to me; answer me speedily in the day when I call!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 3,
      "referenceLabel": "Psalms 102:3",
      "text": "For my days pass away like smoke, and my bones burn like a furnace.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 4,
      "referenceLabel": "Psalms 102:4",
      "text": "My heart is smitten like grass, and withered; I forget to eat my bread.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 5,
      "referenceLabel": "Psalms 102:5",
      "text": "Because of my loud groaning my bones cleave to my flesh.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 6,
      "referenceLabel": "Psalms 102:6",
      "text": "I am like a vulture of the wilderness, like an owl of the waste places;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 7,
      "referenceLabel": "Psalms 102:7",
      "text": "I lie awake, I am like a lonely bird on the housetop.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 8,
      "referenceLabel": "Psalms 102:8",
      "text": "All the day my enemies taunt me, those who deride me use my name for a curse.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 9,
      "referenceLabel": "Psalms 102:9",
      "text": "For I eat ashes like bread, and mingle tears with my drink,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 10,
      "referenceLabel": "Psalms 102:10",
      "text": "because of thy indignation and anger; for thou hast taken me up and thrown me away.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 11,
      "referenceLabel": "Psalms 102:11",
      "text": "My days are like an evening shadow; I wither away like grass.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 12,
      "referenceLabel": "Psalms 102:12",
      "text": "But thou, O Lord, art enthroned for ever; thy name endures to all generations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 13,
      "referenceLabel": "Psalms 102:13",
      "text": "Thou wilt arise and have pity on Zion; it is the time to favor her; the appointed time has come.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 14,
      "referenceLabel": "Psalms 102:14",
      "text": "For thy servants hold her stones dear, and have pity on her dust.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 15,
      "referenceLabel": "Psalms 102:15",
      "text": "The nations will fear the name of the Lord, and all the kings of the earth thy glory.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 16,
      "referenceLabel": "Psalms 102:16",
      "text": "For the Lord will build up Zion, he will appear in his glory;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 17,
      "referenceLabel": "Psalms 102:17",
      "text": "he will regard the prayer of the destitute, and will not despise their supplication.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 18,
      "referenceLabel": "Psalms 102:18",
      "text": "Let this be recorded for a generation to come, so that a people yet unborn may praise the Lord:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 19,
      "referenceLabel": "Psalms 102:19",
      "text": "that he looked down from his holy height, from heaven the Lord looked at the earth,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 20,
      "referenceLabel": "Psalms 102:20",
      "text": "to hear the groans of the prisoners, to set free those who were doomed to die;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 21,
      "referenceLabel": "Psalms 102:21",
      "text": "that men may declare in Zion the name of the Lord, and in Jerusalem his praise,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 22,
      "referenceLabel": "Psalms 102:22",
      "text": "when peoples gather together, and kingdoms, to worship the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 23,
      "referenceLabel": "Psalms 102:23",
      "text": "He has broken my strength in midcourse; he has shortened my days.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 24,
      "referenceLabel": "Psalms 102:24",
      "text": "“O my God,” I say, “take me not hence in the midst of my days, thou whose years endure throughout all generations!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 25,
      "referenceLabel": "Psalms 102:25",
      "text": "Of old thou didst lay the foundation of the earth, and the heavens are the work of thy hands.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 26,
      "referenceLabel": "Psalms 102:26",
      "text": "They will perish, but thou dost endure; they will all wear out like a garment. Thou changest them like raiment, and they pass away;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 27,
      "referenceLabel": "Psalms 102:27",
      "text": "but thou art the same, and thy years have no end.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.102.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 102,
      "verseNumber": 28,
      "referenceLabel": "Psalms 102:28",
      "text": "The children of thy servants shall dwell secure; their posterity shall be established before thee.",
      "paragraphStart": false
    }
  ]
}
