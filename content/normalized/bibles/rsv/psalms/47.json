{
  "chapter": {
    "id": "rsv:psalms.47",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 47,
    "referenceLabel": "Psalms 47",
    "summary": "Source text for Psalms 47 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.47.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 1,
      "referenceLabel": "Psalms 47:1",
      "text": "Clap your hands, all peoples! Shout to God with loud songs of joy!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.47.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 2,
      "referenceLabel": "Psalms 47:2",
      "text": "For the Lord, the Most High, is terrible, a great king over all the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 3,
      "referenceLabel": "Psalms 47:3",
      "text": "He subdued peoples under us, and nations under our feet.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 4,
      "referenceLabel": "Psalms 47:4",
      "text": "He chose our heritage for us, the pride of Jacob whom he loves.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 5,
      "referenceLabel": "Psalms 47:5",
      "text": "God has gone up with a shout, the Lord with the sound of a trumpet.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 6,
      "referenceLabel": "Psalms 47:6",
      "text": "Sing praises to God, sing praises! Sing praises to our King, sing praises!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 7,
      "referenceLabel": "Psalms 47:7",
      "text": "For God is the king of all the earth; sing praises with a psalm!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 8,
      "referenceLabel": "Psalms 47:8",
      "text": "God reigns over the nations; God sits on his holy throne.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.47.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 47,
      "verseNumber": 9,
      "referenceLabel": "Psalms 47:9",
      "text": "The princes of the peoples gather as the people of the God of Abraham. For the shields of the earth belong to God; he is highly exalted!",
      "paragraphStart": false
    }
  ]
}
