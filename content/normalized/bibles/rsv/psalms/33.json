{
  "chapter": {
    "id": "rsv:psalms.33",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 33,
    "referenceLabel": "Psalms 33",
    "summary": "Source text for Psalms 33 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.33.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 1,
      "referenceLabel": "Psalms 33:1",
      "text": "Rejoice in the Lord, O you righteous! Praise befits the upright.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.33.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 2,
      "referenceLabel": "Psalms 33:2",
      "text": "Praise the Lord with the lyre, make melody to him with the harp of ten strings!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 3,
      "referenceLabel": "Psalms 33:3",
      "text": "Sing to him a new song, play skilfully on the strings, with loud shouts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 4,
      "referenceLabel": "Psalms 33:4",
      "text": "For the word of the Lord is upright; and all his work is done in faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 5,
      "referenceLabel": "Psalms 33:5",
      "text": "He loves righteousness and justice; the earth is full of the steadfast love of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 6,
      "referenceLabel": "Psalms 33:6",
      "text": "By the word of the Lord the heavens were made, and all their host by the breath of his mouth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 7,
      "referenceLabel": "Psalms 33:7",
      "text": "He gathered the waters of the sea as in a bottle; he put the deeps in storehouses.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 8,
      "referenceLabel": "Psalms 33:8",
      "text": "Let all the earth fear the Lord, let all the inhabitants of the world stand in awe of him!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 9,
      "referenceLabel": "Psalms 33:9",
      "text": "For he spoke, and it came to be; he commanded, and it stood forth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 10,
      "referenceLabel": "Psalms 33:10",
      "text": "The Lord brings the counsel of the nations to naught; he frustrates the plans of the peoples.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 11,
      "referenceLabel": "Psalms 33:11",
      "text": "The counsel of the Lord stands for ever, the thoughts of his heart to all generations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 12,
      "referenceLabel": "Psalms 33:12",
      "text": "Blessed is the nation whose God is the Lord, the people whom he has chosen as his heritage!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 13,
      "referenceLabel": "Psalms 33:13",
      "text": "The Lord looks down from heaven, he sees all the sons of men;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 14,
      "referenceLabel": "Psalms 33:14",
      "text": "from where he sits enthroned he looks forth on all the inhabitants of the earth,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 15,
      "referenceLabel": "Psalms 33:15",
      "text": "he who fashions the hearts of them all, and observes all their deeds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 16,
      "referenceLabel": "Psalms 33:16",
      "text": "A king is not saved by his great army; a warrior is not delivered by his great strength.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 17,
      "referenceLabel": "Psalms 33:17",
      "text": "The war horse is a vain hope for victory, and by its great might it cannot save.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 18,
      "referenceLabel": "Psalms 33:18",
      "text": "Behold, the eye of the Lord is on those who fear him, on those who hope in his steadfast love,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 19,
      "referenceLabel": "Psalms 33:19",
      "text": "that he may deliver their soul from death, and keep them alive in famine.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 20,
      "referenceLabel": "Psalms 33:20",
      "text": "Our soul waits for the Lord; he is our help and shield.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 21,
      "referenceLabel": "Psalms 33:21",
      "text": "Yea, our heart is glad in him, because we trust in his holy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.33.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 33,
      "verseNumber": 22,
      "referenceLabel": "Psalms 33:22",
      "text": "Let thy steadfast love, O Lord, be upon us, even as we hope in thee.",
      "paragraphStart": false
    }
  ]
}
