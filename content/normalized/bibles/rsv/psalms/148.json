{
  "chapter": {
    "id": "rsv:psalms.148",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 148,
    "referenceLabel": "Psalms 148",
    "summary": "Source text for Psalms 148 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.148.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 1,
      "referenceLabel": "Psalms 148:1",
      "text": "Praise the Lord! Praise the Lord from the heavens, praise him in the heights!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.148.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 2,
      "referenceLabel": "Psalms 148:2",
      "text": "Praise him, all his angels, praise him, all his host!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 3,
      "referenceLabel": "Psalms 148:3",
      "text": "Praise him, sun and moon, praise him, all you shining stars!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 4,
      "referenceLabel": "Psalms 148:4",
      "text": "Praise him, you highest heavens, and you waters above the heavens!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 5,
      "referenceLabel": "Psalms 148:5",
      "text": "Let them praise the name of the Lord! For he commanded and they were created.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 6,
      "referenceLabel": "Psalms 148:6",
      "text": "And he established them for ever and ever; he fixed their bounds which cannot be passed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 7,
      "referenceLabel": "Psalms 148:7",
      "text": "Praise the Lord from the earth, you sea monsters and all deeps,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 8,
      "referenceLabel": "Psalms 148:8",
      "text": "fire and hail, snow and frost, stormy wind fulfilling his command!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 9,
      "referenceLabel": "Psalms 148:9",
      "text": "Mountains and all hills, fruit trees and all cedars!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 10,
      "referenceLabel": "Psalms 148:10",
      "text": "Beasts and all cattle, creeping things and flying birds!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 11,
      "referenceLabel": "Psalms 148:11",
      "text": "Kings of the earth and all peoples, princes and all rulers of the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 12,
      "referenceLabel": "Psalms 148:12",
      "text": "Young men and maidens together, old men and children!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 13,
      "referenceLabel": "Psalms 148:13",
      "text": "Let them praise the name of the Lord, for his name alone is exalted; his glory is above earth and heaven.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.148.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 148,
      "verseNumber": 14,
      "referenceLabel": "Psalms 148:14",
      "text": "He has raised up a horn for his people, praise for all his saints, for the people of Israel who are near to him. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
