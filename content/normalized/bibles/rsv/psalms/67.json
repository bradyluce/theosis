  "verses": [
    {
      "id": "rsv:psalms.67.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 1,
      "referenceLabel": "Psalms 67:1",
      "text": "May God be gracious to us and bless us and make his face to shine upon us,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.67.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 2,
      "referenceLabel": "Psalms 67:2",
      "text": "that thy way may be known upon earth, thy saving power among all nations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.67.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 3,
      "referenceLabel": "Psalms 67:3",
      "text": "Let the peoples praise thee, O God; let all the peoples praise thee!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.67.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 4,
      "referenceLabel": "Psalms 67:4",
      "text": "Let the nations be glad and sing for joy, for thou dost judge the peoples with equity and guide the nations upon earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.67.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 5,
      "referenceLabel": "Psalms 67:5",
      "text": "Let the peoples praise thee, O God; let all the peoples praise thee!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.67.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 6,
      "referenceLabel": "Psalms 67:6",
      "text": "The earth has yielded its increase; God, our God, has blessed us.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.67.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 67,
      "verseNumber": 7,
      "referenceLabel": "Psalms 67:7",
      "text": "God has blessed us; let all the ends of the earth fear him!",
      "paragraphStart": false
    }
  ]
