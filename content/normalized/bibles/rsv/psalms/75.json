{
  "chapter": {
    "id": "rsv:psalms.75",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 75,
    "referenceLabel": "Psalms 75",
    "summary": "Source text for Psalms 75 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.75.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 1,
      "referenceLabel": "Psalms 75:1",
      "text": "We give thanks to thee, O God; we give thanks; we call on thy name and recount thy wondrous deeds.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.75.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 2,
      "referenceLabel": "Psalms 75:2",
      "text": "At the set time which I appoint I will judge with equity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 3,
      "referenceLabel": "Psalms 75:3",
      "text": "When the earth totters, and all its inhabitants, it is I who keep steady its pillars.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 4,
      "referenceLabel": "Psalms 75:4",
      "text": "I say to the boastful, “Do not boast,” and to the wicked, “Do not lift up your horn;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 5,
      "referenceLabel": "Psalms 75:5",
      "text": "do not lift up your horn on high, or speak with insolent neck.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 6,
      "referenceLabel": "Psalms 75:6",
      "text": "For not from the east or from the west and not from the wilderness comes lifting up;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 7,
      "referenceLabel": "Psalms 75:7",
      "text": "but it is God who executes judgment, putting down one and lifting up another.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 8,
      "referenceLabel": "Psalms 75:8",
      "text": "For in the hand of the Lord there is a cup, with foaming wine, well mixed; and he will pour a draught from it, and all the wicked of the earth shall drain it down to the dregs.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 9,
      "referenceLabel": "Psalms 75:9",
      "text": "But I will rejoice for ever, I will sing praises to the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.75.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 75,
      "verseNumber": 10,
      "referenceLabel": "Psalms 75:10",
      "text": "All the horns of the wicked he will cut off, but the horns of the righteous shall be exalted.",
      "paragraphStart": false
    }
  ]
}
