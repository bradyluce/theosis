{
  "chapter": {
    "id": "rsv:psalms.140",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 140,
    "referenceLabel": "Psalms 140",
    "summary": "Source text for Psalms 140 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.140.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 1,
      "referenceLabel": "Psalms 140:1",
      "text": "Deliver me, O Lord, from evil men; preserve me from violent men,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.140.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 2,
      "referenceLabel": "Psalms 140:2",
      "text": "who plan evil things in their heart, and stir up wars continually.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 3,
      "referenceLabel": "Psalms 140:3",
      "text": "They make their tongue sharp as a serpent's, and under their lips is the poison of vipers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 4,
      "referenceLabel": "Psalms 140:4",
      "text": "Guard me, O Lord, from the hands of the wicked; preserve me from violent men, who have planned to trip up my feet.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 5,
      "referenceLabel": "Psalms 140:5",
      "text": "Arrogant men have hidden a trap for me, and with cords they have spread a net, by the wayside they have set snares for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 6,
      "referenceLabel": "Psalms 140:6",
      "text": "I say to the Lord, Thou art my God; give ear to the voice of my supplications, O Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 7,
      "referenceLabel": "Psalms 140:7",
      "text": "O Lord, my Lord, my strong deliverer, thou hast covered my head in the day of battle.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 8,
      "referenceLabel": "Psalms 140:8",
      "text": "Grant not, O Lord, the desires of the wicked; do not further his evil plot!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 9,
      "referenceLabel": "Psalms 140:9",
      "text": "Those who surround me lift up their head, let the mischief of their lips overwhelm them!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 10,
      "referenceLabel": "Psalms 140:10",
      "text": "Let burning coals fall upon them! Let them be cast into pits, no more to rise!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 11,
      "referenceLabel": "Psalms 140:11",
      "text": "Let not the slanderer be established in the land; let evil hunt down the violent man speedily!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 12,
      "referenceLabel": "Psalms 140:12",
      "text": "I know that the Lord maintains the cause of the afflicted, and executes justice for the needy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.140.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 140,
      "verseNumber": 13,
      "referenceLabel": "Psalms 140:13",
      "text": "Surely the righteous shall give thanks to thy name; the upright shall dwell in thy presence.",
      "paragraphStart": false
    }
  ]
}
