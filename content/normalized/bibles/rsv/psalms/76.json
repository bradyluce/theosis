{
  "chapter": {
    "id": "rsv:psalms.76",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 76,
    "referenceLabel": "Psalms 76",
    "summary": "Source text for Psalms 76 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.76.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 1,
      "referenceLabel": "Psalms 76:1",
      "text": "In Judah God is known, his name is great in Israel.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.76.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 2,
      "referenceLabel": "Psalms 76:2",
      "text": "His abode has been established in Salem, his dwelling place in Zion.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 3,
      "referenceLabel": "Psalms 76:3",
      "text": "There he broke the flashing arrows, the shield, the sword, and the weapons of war.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 4,
      "referenceLabel": "Psalms 76:4",
      "text": "Glorious art thou, more majestic than the everlasting mountains.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 5,
      "referenceLabel": "Psalms 76:5",
      "text": "The stouthearted were stripped of their spoil; they sank into sleep; all the men of war were unable to use their hands.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 6,
      "referenceLabel": "Psalms 76:6",
      "text": "At thy rebuke, O God of Jacob, both rider and horse lay stunned.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 7,
      "referenceLabel": "Psalms 76:7",
      "text": "But thou, terrible art thou! Who can stand before thee when once thy anger is roused?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 8,
      "referenceLabel": "Psalms 76:8",
      "text": "From the heavens thou didst utter judgment; the earth feared and was still,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 9,
      "referenceLabel": "Psalms 76:9",
      "text": "when God arose to establish judgment to save all the oppressed of the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 10,
      "referenceLabel": "Psalms 76:10",
      "text": "Surely the wrath of men shall praise thee; the residue of wrath thou wilt gird upon thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 11,
      "referenceLabel": "Psalms 76:11",
      "text": "Make your vows to the Lord your God, and perform them; let all around him bring gifts to him who is to be feared,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.76.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 76,
      "verseNumber": 12,
      "referenceLabel": "Psalms 76:12",
      "text": "who cuts off the spirit of princes, who is terrible to the kings of the earth.",
      "paragraphStart": false
    }
  ]
}
