{
  "chapter": {
    "id": "rsv:psalms.64",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 64,
    "referenceLabel": "Psalms 64",
    "summary": "Source text for Psalms 64 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.64.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 1,
      "referenceLabel": "Psalms 64:1",
      "text": "Hear my voice, O God, in my complaint; preserve my life from dread of the enemy,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.64.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 2,
      "referenceLabel": "Psalms 64:2",
      "text": "hide me from the secret plots of the wicked, from the scheming of evildoers,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 3,
      "referenceLabel": "Psalms 64:3",
      "text": "who whet their tongues like swords, who aim bitter words like arrows,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 4,
      "referenceLabel": "Psalms 64:4",
      "text": "shooting from ambush at the blameless, shooting at him suddenly and without fear.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 5,
      "referenceLabel": "Psalms 64:5",
      "text": "They hold fast to their evil purpose; they talk of laying snares secretly, thinking, “Who can see us?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 6,
      "referenceLabel": "Psalms 64:6",
      "text": "Who can search out our crimes? We have thought out a cunningly conceived plot.” For the inward mind and heart of a man are deep!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 7,
      "referenceLabel": "Psalms 64:7",
      "text": "But God will shoot his arrow at them; they will be wounded suddenly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 8,
      "referenceLabel": "Psalms 64:8",
      "text": "Because of their tongue he will bring them to ruin; all who see them will wag their heads.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 9,
      "referenceLabel": "Psalms 64:9",
      "text": "Then all men will fear; they will tell what God has wrought, and ponder what he has done.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.64.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 64,
      "verseNumber": 10,
      "referenceLabel": "Psalms 64:10",
      "text": "Let the righteous rejoice in the Lord, and take refuge in him! Let all the upright in heart glory!",
      "paragraphStart": false
    }
  ]
}
