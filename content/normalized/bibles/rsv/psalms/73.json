{
  "chapter": {
    "id": "rsv:psalms.73",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 73,
    "referenceLabel": "Psalms 73",
    "summary": "Source text for Psalms 73 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.73.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 1,
      "referenceLabel": "Psalms 73:1",
      "text": "Truly God is good to the upright, to those who are pure in heart.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.73.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 2,
      "referenceLabel": "Psalms 73:2",
      "text": "But as for me, my feet had almost stumbled, my steps had well nigh slipped.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 3,
      "referenceLabel": "Psalms 73:3",
      "text": "For I was envious of the arrogant, when I saw the prosperity of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 4,
      "referenceLabel": "Psalms 73:4",
      "text": "For they have no pangs; their bodies are sound and sleek.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 5,
      "referenceLabel": "Psalms 73:5",
      "text": "They are not in trouble as other men are; they are not stricken like other men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 6,
      "referenceLabel": "Psalms 73:6",
      "text": "Therefore pride is their necklace; violence covers them as a garment.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 7,
      "referenceLabel": "Psalms 73:7",
      "text": "Their eyes swell out with fatness, their hearts overflow with follies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 8,
      "referenceLabel": "Psalms 73:8",
      "text": "They scoff and speak with malice; loftily they threaten oppression.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 9,
      "referenceLabel": "Psalms 73:9",
      "text": "They set their mouths against the heavens, and their tongue struts through the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 10,
      "referenceLabel": "Psalms 73:10",
      "text": "Therefore the people turn and praise them; and find no fault in them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 11,
      "referenceLabel": "Psalms 73:11",
      "text": "And they say, “How can God know? Is there knowledge in the Most High?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 12,
      "referenceLabel": "Psalms 73:12",
      "text": "Behold, these are the wicked; always at ease, they increase in riches.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 13,
      "referenceLabel": "Psalms 73:13",
      "text": "All in vain have I kept my heart clean and washed my hands in innocence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 14,
      "referenceLabel": "Psalms 73:14",
      "text": "For all the day long I have been stricken, and chastened every morning.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 15,
      "referenceLabel": "Psalms 73:15",
      "text": "If I had said, “I will speak thus,” I would have been untrue to the generation of thy children.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 16,
      "referenceLabel": "Psalms 73:16",
      "text": "But when I thought how to understand this, it seemed to me a wearisome task,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 17,
      "referenceLabel": "Psalms 73:17",
      "text": "until I went into the sanctuary of God; then I perceived their end.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 18,
      "referenceLabel": "Psalms 73:18",
      "text": "Truly thou dost set them in slippery places; thou dost make them fall to ruin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 19,
      "referenceLabel": "Psalms 73:19",
      "text": "How they are destroyed in a moment, swept away utterly by terrors!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 20,
      "referenceLabel": "Psalms 73:20",
      "text": "They are like a dream when one awakes, on awaking you despise their phantoms.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 21,
      "referenceLabel": "Psalms 73:21",
      "text": "When my soul was embittered, when I was pricked in heart,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 22,
      "referenceLabel": "Psalms 73:22",
      "text": "I was stupid and ignorant, I was like a beast toward thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 23,
      "referenceLabel": "Psalms 73:23",
      "text": "Nevertheless I am continually with thee; thou dost hold my right hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 24,
      "referenceLabel": "Psalms 73:24",
      "text": "Thou dost guide me with thy counsel, and afterward thou wilt receive me to glory.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 25,
      "referenceLabel": "Psalms 73:25",
      "text": "Whom have I in heaven but thee? And there is nothing upon earth that I desire besides thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 26,
      "referenceLabel": "Psalms 73:26",
      "text": "My flesh and my heart may fail, but God is the strength of my heart and my portion for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 27,
      "referenceLabel": "Psalms 73:27",
      "text": "For lo, those who are far from thee shall perish; thou dost put an end to those who are false to thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.73.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 73,
      "verseNumber": 28,
      "referenceLabel": "Psalms 73:28",
      "text": "But for me it is good to be near God; I have made the Lord God my refuge, that I may tell of all thy works.",
      "paragraphStart": false
    }
  ]
}
