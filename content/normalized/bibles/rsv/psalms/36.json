{
  "chapter": {
    "id": "rsv:psalms.36",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 36,
    "referenceLabel": "Psalms 36",
    "summary": "Source text for Psalms 36 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.36.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 1,
      "referenceLabel": "Psalms 36:1",
      "text": "Transgression speaks to the wicked deep in his heart; there is no fear of God before his eyes.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.36.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 2,
      "referenceLabel": "Psalms 36:2",
      "text": "For he flatters himself in his own eyes that his iniquity cannot be found out and hated.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 3,
      "referenceLabel": "Psalms 36:3",
      "text": "The words of his mouth are mischief and deceit; he has ceased to act wisely and do good.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 4,
      "referenceLabel": "Psalms 36:4",
      "text": "He plots mischief while on his bed; he sets himself in a way that is not good; he spurns not evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 5,
      "referenceLabel": "Psalms 36:5",
      "text": "Thy steadfast love, O Lord, extends to the heavens, thy faithfulness to the clouds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 6,
      "referenceLabel": "Psalms 36:6",
      "text": "Thy righteousness is like the mountains of God, thy judgments are like the great deep; man and beast thou savest, O Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 7,
      "referenceLabel": "Psalms 36:7",
      "text": "How precious is thy steadfast love, O God! The children of men take refuge in the shadow of thy wings.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 8,
      "referenceLabel": "Psalms 36:8",
      "text": "They feast on the abundance of thy house, and thou givest them drink from the river of thy delights.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 9,
      "referenceLabel": "Psalms 36:9",
      "text": "For with thee is the fountain of life; in thy light do we see light.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 10,
      "referenceLabel": "Psalms 36:10",
      "text": "O continue thy steadfast love to those who know thee, and thy salvation to the upright of heart!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 11,
      "referenceLabel": "Psalms 36:11",
      "text": "Let not the foot of arrogance come upon me, nor the hand of the wicked drive me away.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.36.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 36,
      "verseNumber": 12,
      "referenceLabel": "Psalms 36:12",
      "text": "There the evildoers lie prostrate, they are thrust down, unable to rise.",
      "paragraphStart": false
    }
  ]
}
