{
  "chapter": {
    "id": "rsv:psalms.20",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 20,
    "referenceLabel": "Psalms 20",
    "summary": "Source text for Psalms 20 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.20.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Psalms 20:1",
      "text": "The Lord answer you in the day of trouble! The name of the God of Jacob protect you!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.20.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Psalms 20:2",
      "text": "May he send you help from the sanctuary, and give you support from Zion!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Psalms 20:3",
      "text": "May he remember all your offerings, and regard with favor your burnt sacrifices!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Psalms 20:4",
      "text": "May he grant you your heart's desire, and fulfil all your plans!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Psalms 20:5",
      "text": "May we shout for joy over your victory, and in the name of our God set up our banners! May the Lord fulfil all your petitions!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Psalms 20:6",
      "text": "Now I know that the Lord will help his anointed; he will answer him from his holy heaven with mighty victories by his right hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Psalms 20:7",
      "text": "Some boast of chariots, and some of horses; but we boast of the name of the Lord our God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Psalms 20:8",
      "text": "They will collapse and fall; but we shall rise and stand upright.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.20.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Psalms 20:9",
      "text": "Give victory to the king, O Lord; answer us when we call.",
      "paragraphStart": false
    }
  ]
}
