{
  "chapter": {
    "id": "rsv:psalms.22",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 22,
    "referenceLabel": "Psalms 22",
    "summary": "Source text for Psalms 22 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.22.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Psalms 22:1",
      "text": "My God, my God, why hast thou forsaken me? Why art thou so far from helping me, from the words of my groaning?",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.22.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Psalms 22:2",
      "text": "O my God, I cry by day, but thou dost not answer; and by night, but find no rest.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Psalms 22:3",
      "text": "Yet thou art holy, enthroned on the praises of Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Psalms 22:4",
      "text": "In thee our fathers trusted; they trusted, and thou didst deliver them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Psalms 22:5",
      "text": "To thee they cried, and were saved; in thee they trusted, and were not disappointed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Psalms 22:6",
      "text": "But I am a worm, and no man; scorned by men, and despised by the people.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Psalms 22:7",
      "text": "All who see me mock at me, they make mouths at me, they wag their heads;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Psalms 22:8",
      "text": "“He committed his cause to the Lord; let him deliver him, let him rescue him, for he delights in him!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Psalms 22:9",
      "text": "Yet thou art he who took me from the womb; thou didst keep me safe upon my mother's breasts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Psalms 22:10",
      "text": "Upon thee was I cast from my birth, and since my mother bore me thou hast been my God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Psalms 22:11",
      "text": "Be not far from me, for trouble is near and there is none to help.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Psalms 22:12",
      "text": "Many bulls encompass me, strong bulls of Bashan surround me;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Psalms 22:13",
      "text": "they open wide their mouths at me, like a ravening and roaring lion.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Psalms 22:14",
      "text": "I am poured out like water, and all my bones are out of joint; my heart is like wax, it is melted within my breast;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Psalms 22:15",
      "text": "my strength is dried up like a potsherd, and my tongue cleaves to my jaws; thou dost lay me in the dust of death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Psalms 22:16",
      "text": "Yea, dogs are round about me; a company of evildoers encircle me; they have pierced my hands and feet—",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Psalms 22:17",
      "text": "I can count all my bones— they stare and gloat over me;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Psalms 22:18",
      "text": "they divide my garments among them, and for my raiment they cast lots.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Psalms 22:19",
      "text": "But thou, O Lord, be not far off! O thou my help, hasten to my aid!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Psalms 22:20",
      "text": "Deliver my soul from the sword, my life from the power of the dog!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Psalms 22:21",
      "text": "Save me from the mouth of the lion, my afflicted soul from the horns of the wild oxen!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Psalms 22:22",
      "text": "I will tell of thy name to my brethren; in the midst of the congregation I will praise thee:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Psalms 22:23",
      "text": "You who fear the Lord, praise him! all you sons of Jacob, glorify him, and stand in awe of him, all you sons of Israel!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Psalms 22:24",
      "text": "For he has not despised or abhorred the affliction of the afflicted; and he has not hid his face from him, but has heard, when he cried to him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Psalms 22:25",
      "text": "From thee comes my praise in the great congregation; my vows I will pay before those who fear him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Psalms 22:26",
      "text": "The afflicted shall eat and be satisfied; those who seek him shall praise the Lord! May your hearts live for ever!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Psalms 22:27",
      "text": "All the ends of the earth shall remember and turn to the Lord; and all the families of the nations shall worship before him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Psalms 22:28",
      "text": "For dominion belongs to the Lord, and he rules over the nations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Psalms 22:29",
      "text": "Yea, to him shall all the proud of the earth bow down; before him shall bow all who go down to the dust, and he who cannot keep himself alive.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.30",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 30,
      "referenceLabel": "Psalms 22:30",
      "text": "Posterity shall serve him; men shall tell of the Lord to the coming generation,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.22.31",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 22,
      "verseNumber": 31,
      "referenceLabel": "Psalms 22:31",
      "text": "and proclaim his deliverance to a people yet unborn, that he has wrought it.",
      "paragraphStart": false
    }
  ]
}
