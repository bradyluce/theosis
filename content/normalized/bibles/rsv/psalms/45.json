{
  "chapter": {
    "id": "rsv:psalms.45",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 45,
    "referenceLabel": "Psalms 45",
    "summary": "Source text for Psalms 45 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.45.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 1,
      "referenceLabel": "Psalms 45:1",
      "text": "My heart overflows with a goodly theme; I address my verses to the king; my tongue is like the pen of a ready scribe.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.45.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 2,
      "referenceLabel": "Psalms 45:2",
      "text": "You are the fairest of the sons of men; grace is poured upon your lips; therefore God has blessed you for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 3,
      "referenceLabel": "Psalms 45:3",
      "text": "Gird your sword upon your thigh, O mighty one, in your glory and majesty!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 4,
      "referenceLabel": "Psalms 45:4",
      "text": "In your majesty ride forth victoriously for the cause of truth and to defend the right; let your right hand teach you dread deeds!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 5,
      "referenceLabel": "Psalms 45:5",
      "text": "Your arrows are sharp in the heart of the king's enemies; the peoples fall under you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 6,
      "referenceLabel": "Psalms 45:6",
      "text": "Your divine throne endures for ever and ever. Your royal scepter is a scepter of equity;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 7,
      "referenceLabel": "Psalms 45:7",
      "text": "you love righteousness and hate wickedness. Therefore God, your God, has anointed you with the oil of gladness above your fellows;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 8,
      "referenceLabel": "Psalms 45:8",
      "text": "your robes are all fragrant with myrrh and aloes and cassia. From ivory palaces stringed instruments make you glad;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 9,
      "referenceLabel": "Psalms 45:9",
      "text": "daughters of kings are among your ladies of honor; at your right hand stands the queen in gold of Ophir.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 10,
      "referenceLabel": "Psalms 45:10",
      "text": "Hear, O daughter, consider, and incline your ear; forget your people and your father's house;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 11,
      "referenceLabel": "Psalms 45:11",
      "text": "and the king will desire your beauty. Since he is your lord, bow to him;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 12,
      "referenceLabel": "Psalms 45:12",
      "text": "the people of Tyre will sue your favor with gifts, the richest of the people",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 13,
      "referenceLabel": "Psalms 45:13",
      "text": "with all kinds of wealth. The princess is decked in her chamber with gold-woven robes;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 14,
      "referenceLabel": "Psalms 45:14",
      "text": "in many-colored robes she is led to the king, with her virgin companions, her escort, in her train.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 15,
      "referenceLabel": "Psalms 45:15",
      "text": "With joy and gladness they are led along as they enter the palace of the king.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 16,
      "referenceLabel": "Psalms 45:16",
      "text": "Instead of your fathers shall be your sons; you will make them princes in all the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.45.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 45,
      "verseNumber": 17,
      "referenceLabel": "Psalms 45:17",
      "text": "I will cause your name to be celebrated in all generations; therefore the peoples will praise you for ever and ever.",
      "paragraphStart": false
    }
  ]
}
