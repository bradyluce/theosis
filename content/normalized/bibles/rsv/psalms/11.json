  "verses": [
    {
      "id": "rsv:psalms.11.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Psalms 11:1",
      "text": "In the Lord I take refuge; how can you say to me, “Flee like a bird to the mountains;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.11.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Psalms 11:2",
      "text": "for lo, the wicked bend the bow, they have fitted their arrow to the string, to shoot in the dark at the upright in heart;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.11.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Psalms 11:3",
      "text": "if the foundations are destroyed, what can the righteous do”?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.11.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Psalms 11:4",
      "text": "The Lord is in his holy temple, the Lord 's throne is in heaven; his eyes behold, his eyelids test, the children of men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.11.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Psalms 11:5",
      "text": "The Lord tests the righteous and the wicked, and his soul hates him that loves violence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.11.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Psalms 11:6",
      "text": "On the wicked he will rain coals of fire and brimstone; a scorching wind shall be the portion of their cup.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.11.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Psalms 11:7",
      "text": "For the Lord is righteous, he loves righteous deeds; the upright shall behold his face.",
      "paragraphStart": false
    }
  ]
}
