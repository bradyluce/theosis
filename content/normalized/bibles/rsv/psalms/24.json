{
  "chapter": {
    "id": "rsv:psalms.24",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 24,
    "referenceLabel": "Psalms 24",
    "summary": "Source text for Psalms 24 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.24.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 1,
      "referenceLabel": "Psalms 24:1",
      "text": "The earth is the Lord 's and the fulness thereof, the world and those who dwell therein;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.24.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 2,
      "referenceLabel": "Psalms 24:2",
      "text": "for he has founded it upon the seas, and established it upon the rivers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 3,
      "referenceLabel": "Psalms 24:3",
      "text": "Who shall ascend the hill of the Lord? And who shall stand in his holy place?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 4,
      "referenceLabel": "Psalms 24:4",
      "text": "He who has clean hands and a pure heart, who does not lift up his soul to what is false, and does not swear deceitfully.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 5,
      "referenceLabel": "Psalms 24:5",
      "text": "He will receive blessing from the Lord, and vindication from the God of his salvation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 6,
      "referenceLabel": "Psalms 24:6",
      "text": "Such is the generation of those who seek him, who seek the face of the God of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 7,
      "referenceLabel": "Psalms 24:7",
      "text": "Lift up your heads, O gates! and be lifted up, O ancient doors! that the King of glory may come in.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 8,
      "referenceLabel": "Psalms 24:8",
      "text": "Who is the King of glory? The Lord, strong and mighty, the Lord, mighty in battle!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 9,
      "referenceLabel": "Psalms 24:9",
      "text": "Lift up your heads, O gates! and be lifted up, O ancient doors! that the King of glory may come in.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.24.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 24,
      "verseNumber": 10,
      "referenceLabel": "Psalms 24:10",
      "text": "Who is this King of glory? The Lord of hosts, he is the King of glory!",
      "paragraphStart": false
    }
  ]
}
