{
  "chapter": {
    "id": "rsv:psalms.147",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 147,
    "referenceLabel": "Psalms 147",
    "summary": "Source text for Psalms 147 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.147.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 1,
      "referenceLabel": "Psalms 147:1",
      "text": "Praise the Lord! For it is good to sing praises to our God; for he is gracious, and a song of praise is seemly.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.147.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 2,
      "referenceLabel": "Psalms 147:2",
      "text": "The Lord builds up Jerusalem; he gathers the outcasts of Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 3,
      "referenceLabel": "Psalms 147:3",
      "text": "He heals the brokenhearted, and binds up their wounds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 4,
      "referenceLabel": "Psalms 147:4",
      "text": "He determines the number of the stars, he gives to all of them their names.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 5,
      "referenceLabel": "Psalms 147:5",
      "text": "Great is our Lord, and abundant in power; his understanding is beyond measure.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 6,
      "referenceLabel": "Psalms 147:6",
      "text": "The Lord lifts up the downtrodden, he casts the wicked to the ground.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 7,
      "referenceLabel": "Psalms 147:7",
      "text": "Sing to the Lord with thanksgiving; make melody to our God upon the lyre!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 8,
      "referenceLabel": "Psalms 147:8",
      "text": "He covers the heavens with clouds, he prepares rain for the earth, he makes grass grow upon the hills.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 9,
      "referenceLabel": "Psalms 147:9",
      "text": "He gives to the beasts their food, and to the young ravens which cry.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 10,
      "referenceLabel": "Psalms 147:10",
      "text": "His delight is not in the strength of the horse, nor his pleasure in the legs of a man;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 11,
      "referenceLabel": "Psalms 147:11",
      "text": "but the Lord takes pleasure in those who fear him, in those who hope in his steadfast love.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 12,
      "referenceLabel": "Psalms 147:12",
      "text": "Praise the Lord, O Jerusalem! Praise your God, O Zion!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 13,
      "referenceLabel": "Psalms 147:13",
      "text": "For he strengthens the bars of your gates; he blesses your sons within you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 14,
      "referenceLabel": "Psalms 147:14",
      "text": "He makes peace in your borders; he fills you with the finest of the wheat.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 15,
      "referenceLabel": "Psalms 147:15",
      "text": "He sends forth his command to the earth; his word runs swiftly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 16,
      "referenceLabel": "Psalms 147:16",
      "text": "He gives snow like wool; he scatters hoarfrost like ashes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 17,
      "referenceLabel": "Psalms 147:17",
      "text": "He casts forth his ice like morsels; who can stand before his cold?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 18,
      "referenceLabel": "Psalms 147:18",
      "text": "He sends forth his word, and melts them; he makes his wind blow, and the waters flow.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 19,
      "referenceLabel": "Psalms 147:19",
      "text": "He declares his word to Jacob, his statutes and ordinances to Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.147.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 147,
      "verseNumber": 20,
      "referenceLabel": "Psalms 147:20",
      "text": "He has not dealt thus with any other nation; they do not know his ordinances. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
