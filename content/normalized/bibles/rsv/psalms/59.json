{
  "chapter": {
    "id": "rsv:psalms.59",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 59,
    "referenceLabel": "Psalms 59",
    "summary": "Source text for Psalms 59 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.59.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 1,
      "referenceLabel": "Psalms 59:1",
      "text": "Deliver me from my enemies, O my God, protect me from those who rise up against me,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.59.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 2,
      "referenceLabel": "Psalms 59:2",
      "text": "deliver me from those who work evil, and save me from bloodthirsty men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 3,
      "referenceLabel": "Psalms 59:3",
      "text": "For lo, they lie in wait for my life; fierce men band themselves against me. For no transgression or sin of mine, O Lord,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 4,
      "referenceLabel": "Psalms 59:4",
      "text": "for no fault of mine, they run and make ready. Rouse thyself, come to my help, and see!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 5,
      "referenceLabel": "Psalms 59:5",
      "text": "Thou, Lord God of hosts, art God of Israel. Awake to punish all the nations; spare none of those who treacherously plot evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 6,
      "referenceLabel": "Psalms 59:6",
      "text": "Each evening they come back, howling like dogs and prowling about the city.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 7,
      "referenceLabel": "Psalms 59:7",
      "text": "There they are, bellowing with their mouths, and snarling with their lips— for “Who,” they think, “will hear us?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 8,
      "referenceLabel": "Psalms 59:8",
      "text": "But thou, O Lord, dost laugh at them; thou dost hold all the nations in derision.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 9,
      "referenceLabel": "Psalms 59:9",
      "text": "O my Strength, I will sing praises to thee; for thou, O God, art my fortress.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 10,
      "referenceLabel": "Psalms 59:10",
      "text": "My God in his steadfast love will meet me; my God will let me look in triumph on my enemies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 11,
      "referenceLabel": "Psalms 59:11",
      "text": "Slay them not, lest my people forget; make them totter by thy power, and bring them down, O Lord, our shield!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 12,
      "referenceLabel": "Psalms 59:12",
      "text": "For the sin of their mouths, the words of their lips, let them be trapped in their pride. For the cursing and lies which they utter,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 13,
      "referenceLabel": "Psalms 59:13",
      "text": "consume them in wrath, consume them till they are no more, that men may know that God rules over Jacob to the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 14,
      "referenceLabel": "Psalms 59:14",
      "text": "Each evening they come back, howling like dogs and prowling about the city.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 15,
      "referenceLabel": "Psalms 59:15",
      "text": "They roam about for food, and growl if they do not get their fill.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 16,
      "referenceLabel": "Psalms 59:16",
      "text": "But I will sing of thy might; I will sing aloud of thy steadfast love in the morning. For thou hast been to me a fortress and a refuge in the day of my distress.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.59.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 59,
      "verseNumber": 17,
      "referenceLabel": "Psalms 59:17",
      "text": "O my Strength, I will sing praises to thee, for thou, O God, art my fortress, the God who shows me steadfast love.",
      "paragraphStart": false
    }
  ]
}
