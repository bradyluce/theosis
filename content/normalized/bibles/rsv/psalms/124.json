{
  "chapter": {
    "id": "rsv:psalms.124",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 124,
    "referenceLabel": "Psalms 124",
    "summary": "Source text for Psalms 124 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.124.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 1,
      "referenceLabel": "Psalms 124:1",
      "text": "If it had not been the Lord who was on our side, let Israel now say—",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.124.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 2,
      "referenceLabel": "Psalms 124:2",
      "text": "if it had not been the Lord who was on our side, when men rose up against us,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.124.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 3,
      "referenceLabel": "Psalms 124:3",
      "text": "then they would have swallowed us up alive, when their anger was kindled against us;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.124.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 4,
      "referenceLabel": "Psalms 124:4",
      "text": "then the flood would have swept us away, the torrent would have gone over us;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.124.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 5,
      "referenceLabel": "Psalms 124:5",
      "text": "then over us would have gone the raging waters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.124.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 6,
      "referenceLabel": "Psalms 124:6",
      "text": "Blessed be the Lord, who has not given us as prey to their teeth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.124.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 7,
      "referenceLabel": "Psalms 124:7",
      "text": "We have escaped as a bird from the snare of the fowlers; the snare is broken, and we have escaped!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.124.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 124,
      "verseNumber": 8,
      "referenceLabel": "Psalms 124:8",
      "text": "Our help is in the name of the Lord, who made heaven and earth.",
      "paragraphStart": false
    }
  ]
}
