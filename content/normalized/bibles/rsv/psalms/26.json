{
  "chapter": {
    "id": "rsv:psalms.26",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 26,
    "referenceLabel": "Psalms 26",
    "summary": "Source text for Psalms 26 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.26.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Psalms 26:1",
      "text": "Vindicate me, O Lord, for I have walked in my integrity, and I have trusted in the Lord without wavering.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.26.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Psalms 26:2",
      "text": "Prove me, O Lord, and try me; test my heart and my mind.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Psalms 26:3",
      "text": "For thy steadfast love is before my eyes, and I walk in faithfulness to thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Psalms 26:4",
      "text": "I do not sit with false men, nor do I consort with dissemblers;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Psalms 26:5",
      "text": "I hate the company of evildoers, and I will not sit with the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Psalms 26:6",
      "text": "I wash my hands in innocence, and go about thy altar, O Lord,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Psalms 26:7",
      "text": "singing aloud a song of thanksgiving, and telling all thy wondrous deeds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Psalms 26:8",
      "text": "O Lord, I love the habitation of thy house, and the place where thy glory dwells.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Psalms 26:9",
      "text": "Sweep me not away with sinners, nor my life with bloodthirsty men,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Psalms 26:10",
      "text": "men in whose hands are evil devices, and whose right hands are full of bribes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Psalms 26:11",
      "text": "But as for me, I walk in my integrity; redeem me, and be gracious to me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.26.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Psalms 26:12",
      "text": "My foot stands on level ground; in the great congregation I will bless the Lord.",
      "paragraphStart": false
    }
  ]
}
