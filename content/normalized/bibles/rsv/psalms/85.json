{
  "chapter": {
    "id": "rsv:psalms.85",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 85,
    "referenceLabel": "Psalms 85",
    "summary": "Source text for Psalms 85 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.85.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 1,
      "referenceLabel": "Psalms 85:1",
      "text": "Lord, thou wast favorable to thy land; thou didst restore the fortunes of Jacob.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.85.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 2,
      "referenceLabel": "Psalms 85:2",
      "text": "Thou didst forgive the iniquity of thy people; thou didst pardon all their sin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 3,
      "referenceLabel": "Psalms 85:3",
      "text": "Thou didst withdraw all thy wrath; thou didst turn from thy hot anger.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 4,
      "referenceLabel": "Psalms 85:4",
      "text": "Restore us again, O God of our salvation, and put away thy indignation toward us!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 5,
      "referenceLabel": "Psalms 85:5",
      "text": "Wilt thou be angry with us for ever? Wilt thou prolong thy anger to all generations?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 6,
      "referenceLabel": "Psalms 85:6",
      "text": "Wilt thou not revive us again, that thy people may rejoice in thee?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 7,
      "referenceLabel": "Psalms 85:7",
      "text": "Show us thy steadfast love, O Lord, and grant us thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 8,
      "referenceLabel": "Psalms 85:8",
      "text": "Let me hear what God the Lord will speak, for he will speak peace to his people, to his saints, to those who turn to him in their hearts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 9,
      "referenceLabel": "Psalms 85:9",
      "text": "Surely his salvation is at hand for those who fear him, that glory may dwell in our land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 10,
      "referenceLabel": "Psalms 85:10",
      "text": "Steadfast love and faithfulness will meet; righteousness and peace will kiss each other.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 11,
      "referenceLabel": "Psalms 85:11",
      "text": "Faithfulness will spring up from the ground, and righteousness will look down from the sky.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 12,
      "referenceLabel": "Psalms 85:12",
      "text": "Yea, the Lord will give what is good, and our land will yield its increase.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.85.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 85,
      "verseNumber": 13,
      "referenceLabel": "Psalms 85:13",
      "text": "Righteousness will go before him, and make his footsteps a way.",
      "paragraphStart": false
    }
  ]
}
