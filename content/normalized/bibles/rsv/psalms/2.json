{
  "chapter": {
    "id": "rsv:psalms.2",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 2,
    "referenceLabel": "Psalms 2",
    "summary": "Source text for Psalms 2 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.2.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Psalms 2:1",
      "text": "Why do the nations conspire, and the peoples plot in vain?",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.2.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Psalms 2:2",
      "text": "The kings of the earth set themselves, and the rulers take counsel together, against the Lord and his anointed, saying,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Psalms 2:3",
      "text": "“Let us burst their bonds asunder, and cast their cords from us.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Psalms 2:4",
      "text": "He who sits in the heavens laughs; the Lord has them in derision.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Psalms 2:5",
      "text": "Then he will speak to them in his wrath, and terrify them in his fury, saying,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Psalms 2:6",
      "text": "“I have set my king on Zion, my holy hill.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Psalms 2:7",
      "text": "I will tell of the decree of the Lord: He said to me, “You are my son, today I have begotten you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Psalms 2:8",
      "text": "Ask of me, and I will make the nations your heritage, and the ends of the earth your possession.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Psalms 2:9",
      "text": "You shall break them with a rod of iron, and dash them in pieces like a potter's vessel.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Psalms 2:10",
      "text": "Now therefore, O kings, be wise; be warned, O rulers of the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Psalms 2:11",
      "text": "Serve the Lord with fear, with trembling",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.2.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Psalms 2:12",
      "text": "kiss his feet, lest he be angry, and you perish in the way; for his wrath is quickly kindled. Blessed are all who take refuge in him.",
      "paragraphStart": false
    }
  ]
}
