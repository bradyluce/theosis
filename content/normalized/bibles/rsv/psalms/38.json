{
  "chapter": {
    "id": "rsv:psalms.38",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 38,
    "referenceLabel": "Psalms 38",
    "summary": "Source text for Psalms 38 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.38.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 1,
      "referenceLabel": "Psalms 38:1",
      "text": "O Lord, rebuke me not in thy anger, nor chasten me in thy wrath!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.38.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 2,
      "referenceLabel": "Psalms 38:2",
      "text": "For thy arrows have sunk into me, and thy hand has come down on me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 3,
      "referenceLabel": "Psalms 38:3",
      "text": "There is no soundness in my flesh because of thy indignation; there is no health in my bones because of my sin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 4,
      "referenceLabel": "Psalms 38:4",
      "text": "For my iniquities have gone over my head; they weigh like a burden too heavy for me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 5,
      "referenceLabel": "Psalms 38:5",
      "text": "My wounds grow foul and fester because of my foolishness,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 6,
      "referenceLabel": "Psalms 38:6",
      "text": "I am utterly bowed down and prostrate; all the day I go about mourning.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 7,
      "referenceLabel": "Psalms 38:7",
      "text": "For my loins are filled with burning, and there is no soundness in my flesh.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 8,
      "referenceLabel": "Psalms 38:8",
      "text": "I am utterly spent and crushed; I groan because of the tumult of my heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 9,
      "referenceLabel": "Psalms 38:9",
      "text": "Lord, all my longing is known to thee, my sighing is not hidden from thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 10,
      "referenceLabel": "Psalms 38:10",
      "text": "My heart throbs, my strength fails me; and the light of my eyes—it also has gone from me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 11,
      "referenceLabel": "Psalms 38:11",
      "text": "My friends and companions stand aloof from my plague, and my kinsmen stand afar off.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 12,
      "referenceLabel": "Psalms 38:12",
      "text": "Those who seek my life lay their snares, those who seek my hurt speak of ruin, and meditate treachery all the day long.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 13,
      "referenceLabel": "Psalms 38:13",
      "text": "But I am like a deaf man, I do not hear, Like a dumb man who does not open his mouth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 14,
      "referenceLabel": "Psalms 38:14",
      "text": "Yea, I am like a man who does not hear, and in whose mouth are no rebukes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 15,
      "referenceLabel": "Psalms 38:15",
      "text": "But for thee, O Lord, do I wait; it is thou, O Lord my God, who wilt answer.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 16,
      "referenceLabel": "Psalms 38:16",
      "text": "For I pray, “Only let them not rejoice over me, who boast against me when my foot slips!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 17,
      "referenceLabel": "Psalms 38:17",
      "text": "For I am ready to fall, and my pain is ever with me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 18,
      "referenceLabel": "Psalms 38:18",
      "text": "I confess my iniquity, I am sorry for my sin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 19,
      "referenceLabel": "Psalms 38:19",
      "text": "Those who are my foes without cause are mighty, and many are those who hate me wrongfully.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 20,
      "referenceLabel": "Psalms 38:20",
      "text": "Those who render me evil for good are my adversaries because I follow after good.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 21,
      "referenceLabel": "Psalms 38:21",
      "text": "Do not forsake me, O Lord! O my God, be not far from me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.38.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 38,
      "verseNumber": 22,
      "referenceLabel": "Psalms 38:22",
      "text": "Make haste to help me, O Lord, my salvation!",
      "paragraphStart": false
    }
  ]
}
