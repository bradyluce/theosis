{
  "chapter": {
    "id": "rsv:psalms.6",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 6,
    "referenceLabel": "Psalms 6",
    "summary": "Source text for Psalms 6 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.6.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Psalms 6:1",
      "text": "O Lord, rebuke me not in thy anger, nor chasten me in thy wrath.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.6.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Psalms 6:2",
      "text": "Be gracious to me, O Lord, for I am languishing; O Lord, heal me, for my bones are troubled.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Psalms 6:3",
      "text": "My soul also is sorely troubled. But thou, O Lord —how long?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Psalms 6:4",
      "text": "Turn, O Lord, save my life; deliver me for the sake of thy steadfast love.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Psalms 6:5",
      "text": "For in death there is no remembrance of thee; in Sheol who can give thee praise?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Psalms 6:6",
      "text": "I am weary with my moaning; every night I flood my bed with tears; I drench my couch with my weeping.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Psalms 6:7",
      "text": "My eye wastes away because of grief, it grows weak because of all my foes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Psalms 6:8",
      "text": "Depart from me, all you workers of evil; for the Lord has heard the sound of my weeping.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Psalms 6:9",
      "text": "The Lord has heard my supplication; the Lord accepts my prayer.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.6.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Psalms 6:10",
      "text": "All my enemies shall be ashamed and sorely troubled; they shall turn back, and be put to shame in a moment.",
      "paragraphStart": false
    }
  ]
}
