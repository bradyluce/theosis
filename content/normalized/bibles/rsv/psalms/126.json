{
  "chapter": {
    "id": "rsv:psalms.126",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 126,
    "referenceLabel": "Psalms 126",
    "summary": "Source text for Psalms 126 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.126.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 1,
      "referenceLabel": "Psalms 126:1",
      "text": "When the Lord restored the fortunes of Zion, we were like those who dream.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.126.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 2,
      "referenceLabel": "Psalms 126:2",
      "text": "Then our mouth was filled with laughter, and our tongue with shouts of joy; then they said among the nations, “The Lord has done great things for them.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.126.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 3,
      "referenceLabel": "Psalms 126:3",
      "text": "The Lord has done great things for us; we are glad.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.126.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 4,
      "referenceLabel": "Psalms 126:4",
      "text": "Restore our fortunes, O Lord, like the watercourses in the Negeb!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.126.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 5,
      "referenceLabel": "Psalms 126:5",
      "text": "May those who sow in tears reap with shouts of joy!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.126.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 126,
      "verseNumber": 6,
      "referenceLabel": "Psalms 126:6",
      "text": "He that goes forth weeping, bearing the seed for sowing, shall come home with shouts of joy, bringing his sheaves with him.",
      "paragraphStart": false
    }
  ]
}
