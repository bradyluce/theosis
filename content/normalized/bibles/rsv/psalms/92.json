{
  "chapter": {
    "id": "rsv:psalms.92",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 92,
    "referenceLabel": "Psalms 92",
    "summary": "Source text for Psalms 92 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.92.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 1,
      "referenceLabel": "Psalms 92:1",
      "text": "It is good to give thanks to the Lord, to sing praises to thy name, O Most High;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.92.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 2,
      "referenceLabel": "Psalms 92:2",
      "text": "to declare thy steadfast love in the morning, and thy faithfulness by night,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 3,
      "referenceLabel": "Psalms 92:3",
      "text": "to the music of the lute and the harp, to the melody of the lyre.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 4,
      "referenceLabel": "Psalms 92:4",
      "text": "For thou, O Lord, hast made me glad by thy work; at the works of thy hands I sing for joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 5,
      "referenceLabel": "Psalms 92:5",
      "text": "How great are thy works, O Lord! Thy thoughts are very deep!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 6,
      "referenceLabel": "Psalms 92:6",
      "text": "The dull man cannot know, the stupid cannot understand this:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 7,
      "referenceLabel": "Psalms 92:7",
      "text": "that, though the wicked sprout like grass and all evildoers flourish, they are doomed to destruction for ever,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 8,
      "referenceLabel": "Psalms 92:8",
      "text": "but thou, O Lord, art on high for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 9,
      "referenceLabel": "Psalms 92:9",
      "text": "For lo, thy enemies, O Lord, for lo, thy enemies shall perish; all evildoers shall be scattered.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 10,
      "referenceLabel": "Psalms 92:10",
      "text": "But thou hast exalted my horn like that of the wild ox; thou hast poured over me fresh oil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 11,
      "referenceLabel": "Psalms 92:11",
      "text": "My eyes have seen the downfall of my enemies, my ears have heard the doom of my evil assailants.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 12,
      "referenceLabel": "Psalms 92:12",
      "text": "The righteous flourish like the palm tree, and grow like a cedar in Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 13,
      "referenceLabel": "Psalms 92:13",
      "text": "They are planted in the house of the Lord, they flourish in the courts of our God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 14,
      "referenceLabel": "Psalms 92:14",
      "text": "They still bring forth fruit in old age, they are ever full of sap and green,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.92.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 92,
      "verseNumber": 15,
      "referenceLabel": "Psalms 92:15",
      "text": "to show that the Lord is upright; he is my rock, and there is no unrighteousness in him.",
      "paragraphStart": false
    }
  ]
}
