{
  "chapter": {
    "id": "rsv:psalms.113",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 113,
    "referenceLabel": "Psalms 113",
    "summary": "Source text for Psalms 113 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.113.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 1,
      "referenceLabel": "Psalms 113:1",
      "text": "Praise the Lord! Praise, O servants of the Lord, praise the name of the Lord!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.113.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 2,
      "referenceLabel": "Psalms 113:2",
      "text": "Blessed be the name of the Lord from this time forth and for evermore!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 3,
      "referenceLabel": "Psalms 113:3",
      "text": "From the rising of the sun to its setting the name of the Lord is to be praised!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 4,
      "referenceLabel": "Psalms 113:4",
      "text": "The Lord is high above all nations, and his glory above the heavens!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 5,
      "referenceLabel": "Psalms 113:5",
      "text": "Who is like the Lord our God, who is seated on high,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 6,
      "referenceLabel": "Psalms 113:6",
      "text": "who looks far down upon the heavens and the earth?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 7,
      "referenceLabel": "Psalms 113:7",
      "text": "He raises the poor from the dust, and lifts the needy from the ash heap,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 8,
      "referenceLabel": "Psalms 113:8",
      "text": "to make them sit with princes, with the princes of his people.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.113.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 113,
      "verseNumber": 9,
      "referenceLabel": "Psalms 113:9",
      "text": "He gives the barren woman a home, making her the joyous mother of children. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
