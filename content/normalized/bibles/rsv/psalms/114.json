{
  "chapter": {
    "id": "rsv:psalms.114",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 114,
    "referenceLabel": "Psalms 114",
    "summary": "Source text for Psalms 114 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.114.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 1,
      "referenceLabel": "Psalms 114:1",
      "text": "When Israel went forth from Egypt, the house of Jacob from a people of strange language,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.114.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 2,
      "referenceLabel": "Psalms 114:2",
      "text": "Judah became his sanctuary, Israel his dominion.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.114.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 3,
      "referenceLabel": "Psalms 114:3",
      "text": "The sea looked and fled, Jordan turned back.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.114.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 4,
      "referenceLabel": "Psalms 114:4",
      "text": "The mountains skipped like rams, the hills like lambs.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.114.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 5,
      "referenceLabel": "Psalms 114:5",
      "text": "What ails you, O sea, that you flee? O Jordan, that you turn back?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.114.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 6,
      "referenceLabel": "Psalms 114:6",
      "text": "O mountains, that you skip like rams? O hills, like lambs?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.114.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 7,
      "referenceLabel": "Psalms 114:7",
      "text": "Tremble, O earth, at the presence of the Lord, at the presence of the God of Jacob,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.114.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 114,
      "verseNumber": 8,
      "referenceLabel": "Psalms 114:8",
      "text": "who turns the rock into a pool of water, the flint into a spring of water.",
      "paragraphStart": false
    }
  ]
}
