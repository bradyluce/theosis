{
  "chapter": {
    "id": "rsv:psalms.50",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 50,
    "referenceLabel": "Psalms 50",
    "summary": "Source text for Psalms 50 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.50.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 1,
      "referenceLabel": "Psalms 50:1",
      "text": "The Mighty One, God the Lord, speaks and summons the earth from the rising of the sun to its setting.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.50.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 2,
      "referenceLabel": "Psalms 50:2",
      "text": "Out of Zion, the perfection of beauty, God shines forth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 3,
      "referenceLabel": "Psalms 50:3",
      "text": "Our God comes, he does not keep silence, before him is a devouring fire, round about him a mighty tempest.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 4,
      "referenceLabel": "Psalms 50:4",
      "text": "He calls to the heavens above and to the earth, that he may judge his people:",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 5,
      "referenceLabel": "Psalms 50:5",
      "text": "“Gather to me my faithful ones, who made a covenant with me by sacrifice!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 6,
      "referenceLabel": "Psalms 50:6",
      "text": "The heavens declare his righteousness, for God himself is judge!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 7,
      "referenceLabel": "Psalms 50:7",
      "text": "“Hear, O my people, and I will speak, O Israel, I will testify against you. I am God, your God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 8,
      "referenceLabel": "Psalms 50:8",
      "text": "I do not reprove you for your sacrifices; your burnt offerings are continually before me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 9,
      "referenceLabel": "Psalms 50:9",
      "text": "I will accept no bull from your house, nor he-goat from your folds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 10,
      "referenceLabel": "Psalms 50:10",
      "text": "For every beast of the forest is mine, the cattle on a thousand hills.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 11,
      "referenceLabel": "Psalms 50:11",
      "text": "I know all the birds of the air, and all that moves in the field is mine.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 12,
      "referenceLabel": "Psalms 50:12",
      "text": "“If I were hungry, I would not tell you; for the world and all that is in it is mine.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 13,
      "referenceLabel": "Psalms 50:13",
      "text": "Do I eat the flesh of bulls, or drink the blood of goats?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 14,
      "referenceLabel": "Psalms 50:14",
      "text": "Offer to God a sacrifice of thanksgiving, and pay your vows to the Most High;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 15,
      "referenceLabel": "Psalms 50:15",
      "text": "and call upon me in the day of trouble; I will deliver you, and you shall glorify me.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 16,
      "referenceLabel": "Psalms 50:16",
      "text": "But to the wicked God says: “What right have you to recite my statutes, or take my covenant on your lips?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 17,
      "referenceLabel": "Psalms 50:17",
      "text": "For you hate discipline, and you cast my words behind you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 18,
      "referenceLabel": "Psalms 50:18",
      "text": "If you see a thief, you are a friend of his; and you keep company with adulterers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 19,
      "referenceLabel": "Psalms 50:19",
      "text": "“You give your mouth free rein for evil, and your tongue frames deceit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 20,
      "referenceLabel": "Psalms 50:20",
      "text": "You sit and speak against your brother; you slander your own mother's son.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 21,
      "referenceLabel": "Psalms 50:21",
      "text": "These things you have done and I have been silent; you thought that I was one like yourself. But now I rebuke you, and lay the charge before you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 22,
      "referenceLabel": "Psalms 50:22",
      "text": "“Mark this, then, you who forget God, lest I rend, and there be none to deliver!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.50.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 50,
      "verseNumber": 23,
      "referenceLabel": "Psalms 50:23",
      "text": "He who brings thanksgiving as his sacrifice honors me; to him who orders his way aright I will show the salvation of God!”",
      "paragraphStart": false
    }
  ]
}
