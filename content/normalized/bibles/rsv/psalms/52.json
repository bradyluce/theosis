{
  "chapter": {
    "id": "rsv:psalms.52",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 52,
    "referenceLabel": "Psalms 52",
    "summary": "Source text for Psalms 52 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.52.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 1,
      "referenceLabel": "Psalms 52:1",
      "text": "Why do you boast, O mighty man, of mischief done against the godly? All the day",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.52.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 2,
      "referenceLabel": "Psalms 52:2",
      "text": "you are plotting destruction. Your tongue is like a sharp razor, you worker of treachery.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 3,
      "referenceLabel": "Psalms 52:3",
      "text": "You love evil more than good, and lying more than speaking the truth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 4,
      "referenceLabel": "Psalms 52:4",
      "text": "You love all words that devour, O deceitful tongue.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 5,
      "referenceLabel": "Psalms 52:5",
      "text": "But God will break you down for ever; he will snatch and tear you from your tent; he will uproot you from the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 6,
      "referenceLabel": "Psalms 52:6",
      "text": "The righteous shall see, and fear, and shall laugh at him, saying,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 7,
      "referenceLabel": "Psalms 52:7",
      "text": "“See the man who would not make God his refuge, but trusted in the abundance of his riches, and sought refuge in his wealth!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 8,
      "referenceLabel": "Psalms 52:8",
      "text": "But I am like a green olive tree in the house of God. I trust in the steadfast love of God for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.52.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 52,
      "verseNumber": 9,
      "referenceLabel": "Psalms 52:9",
      "text": "I will thank thee for ever, because thou hast done it. I will proclaim thy name, for it is good, in the presence of the godly.",
      "paragraphStart": false
    }
  ]
}
