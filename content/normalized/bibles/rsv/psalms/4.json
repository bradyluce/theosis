{
  "chapter": {
    "id": "rsv:psalms.4",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 4,
    "referenceLabel": "Psalms 4",
    "summary": "Source text for Psalms 4 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.4.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Psalms 4:1",
      "text": "Answer me when I call, O God of my right! Thou hast given me room when I was in distress. Be gracious to me, and hear my prayer.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.4.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Psalms 4:2",
      "text": "O men, how long shall my honor suffer shame? How long will you love vain words, and seek after lies?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.4.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Psalms 4:3",
      "text": "But know that the Lord has set apart the godly for himself; the Lord hears when I call to him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.4.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Psalms 4:4",
      "text": "Be angry, but sin not; commune with your own hearts on your beds, and be silent.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.4.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Psalms 4:5",
      "text": "Offer right sacrifices, and put your trust in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.4.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Psalms 4:6",
      "text": "There are many who say, “O that we might see some good! Lift up the light of thy countenance upon us, O Lord!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.4.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Psalms 4:7",
      "text": "Thou hast put more joy in my heart than they have when their grain and wine abound.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.4.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Psalms 4:8",
      "text": "In peace I will both lie down and sleep; for thou alone, O Lord, makest me dwell in safety.",
      "paragraphStart": false
    }
  ]
}
