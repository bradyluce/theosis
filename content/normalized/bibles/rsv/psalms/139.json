{
  "chapter": {
    "id": "rsv:psalms.139",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 139,
    "referenceLabel": "Psalms 139",
    "summary": "Source text for Psalms 139 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.139.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 1,
      "referenceLabel": "Psalms 139:1",
      "text": "O Lord, thou hast searched me and known me!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.139.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 2,
      "referenceLabel": "Psalms 139:2",
      "text": "Thou knowest when I sit down and when I rise up; thou discernest my thoughts from afar.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 3,
      "referenceLabel": "Psalms 139:3",
      "text": "Thou searchest out my path and my lying down, and art acquainted with all my ways.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 4,
      "referenceLabel": "Psalms 139:4",
      "text": "Even before a word is on my tongue, lo, O Lord, thou knowest it altogether.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 5,
      "referenceLabel": "Psalms 139:5",
      "text": "Thou dost beset me behind and before, and layest thy hand upon me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 6,
      "referenceLabel": "Psalms 139:6",
      "text": "Such knowledge is too wonderful for me; it is high, I cannot attain it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 7,
      "referenceLabel": "Psalms 139:7",
      "text": "Whither shall I go from thy Spirit? Or whither shall I flee from thy presence?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 8,
      "referenceLabel": "Psalms 139:8",
      "text": "If I ascend to heaven, thou art there! If I make my bed in Sheol, thou art there!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 9,
      "referenceLabel": "Psalms 139:9",
      "text": "If I take the wings of the morning and dwell in the uttermost parts of the sea,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 10,
      "referenceLabel": "Psalms 139:10",
      "text": "even there thy hand shall lead me, and thy right hand shall hold me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 11,
      "referenceLabel": "Psalms 139:11",
      "text": "If I say, “Let only darkness cover me, and the light about me be night,”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 12,
      "referenceLabel": "Psalms 139:12",
      "text": "even the darkness is not dark to thee, the night is bright as the day; for darkness is as light with thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 13,
      "referenceLabel": "Psalms 139:13",
      "text": "For thou didst form my inward parts, thou didst knit me together in my mother's womb.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 14,
      "referenceLabel": "Psalms 139:14",
      "text": "I praise thee, for thou art fearful and wonderful. Wonderful are thy works! Thou knowest me right well;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 15,
      "referenceLabel": "Psalms 139:15",
      "text": "my frame was not hidden from thee, when I was being made in secret, intricately wrought in the depths of the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 16,
      "referenceLabel": "Psalms 139:16",
      "text": "Thy eyes beheld my unformed substance; in thy book were written, every one of them, the days that were formed for me, when as yet there was none of them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 17,
      "referenceLabel": "Psalms 139:17",
      "text": "How precious to me are thy thoughts, O God! How vast is the sum of them!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 18,
      "referenceLabel": "Psalms 139:18",
      "text": "If I would count them, they are more than the sand. When I awake, I am still with thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 19,
      "referenceLabel": "Psalms 139:19",
      "text": "O that thou wouldst slay the wicked, O God, and that men of blood would depart from me,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 20,
      "referenceLabel": "Psalms 139:20",
      "text": "men who maliciously defy thee, who lift themselves up against thee for evil!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 21,
      "referenceLabel": "Psalms 139:21",
      "text": "Do I not hate them that hate thee, O Lord? And do I not loathe them that rise up against thee?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 22,
      "referenceLabel": "Psalms 139:22",
      "text": "I hate them with perfect hatred; I count them my enemies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 23,
      "referenceLabel": "Psalms 139:23",
      "text": "Search me, O God, and know my heart! Try me and know my thoughts!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.139.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 139,
      "verseNumber": 24,
      "referenceLabel": "Psalms 139:24",
      "text": "And see if there be any wicked way in me, and lead me in the way everlasting!",
      "paragraphStart": false
    }
  ]
}
