{
  "chapter": {
    "id": "rsv:psalms.128",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 128,
    "referenceLabel": "Psalms 128",
    "summary": "Source text for Psalms 128 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.128.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 1,
      "referenceLabel": "Psalms 128:1",
      "text": "Blessed is every one who fears the Lord, who walks in his ways!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.128.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 2,
      "referenceLabel": "Psalms 128:2",
      "text": "You shall eat the fruit of the labor of your hands; you shall be happy, and it shall be well with you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.128.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 3,
      "referenceLabel": "Psalms 128:3",
      "text": "Your wife will be like a fruitful vine within your house; your children will be like olive shoots around your table.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.128.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 4,
      "referenceLabel": "Psalms 128:4",
      "text": "Lo, thus shall the man be blessed who fears the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.128.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 5,
      "referenceLabel": "Psalms 128:5",
      "text": "The Lord bless you from Zion! May you see the prosperity of Jerusalem all the days of your life!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.128.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 128,
      "verseNumber": 6,
      "referenceLabel": "Psalms 128:6",
      "text": "May you see your children's children! Peace be upon Israel!",
      "paragraphStart": false
    }
  ]
}
