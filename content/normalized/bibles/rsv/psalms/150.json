{
  "chapter": {
    "id": "rsv:psalms.150",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 150,
    "referenceLabel": "Psalms 150",
    "summary": "Source text for Psalms 150 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.150.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 1,
      "referenceLabel": "Psalms 150:1",
      "text": "Praise the Lord! Praise God in his sanctuary; praise him in his mighty firmament!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.150.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 2,
      "referenceLabel": "Psalms 150:2",
      "text": "Praise him for his mighty deeds; praise him according to his exceeding greatness!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.150.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 3,
      "referenceLabel": "Psalms 150:3",
      "text": "Praise him with trumpet sound; praise him with lute and harp!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.150.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 4,
      "referenceLabel": "Psalms 150:4",
      "text": "Praise him with timbrel and dance; praise him with strings and pipe!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.150.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 5,
      "referenceLabel": "Psalms 150:5",
      "text": "Praise him with sounding cymbals; praise him with loud clashing cymbals!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.150.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 150,
      "verseNumber": 6,
      "referenceLabel": "Psalms 150:6",
      "text": "Let everything that breathes praise the Lord! Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
