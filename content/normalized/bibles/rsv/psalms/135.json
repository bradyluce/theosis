{
  "chapter": {
    "id": "rsv:psalms.135",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 135,
    "referenceLabel": "Psalms 135",
    "summary": "Source text for Psalms 135 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.135.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 1,
      "referenceLabel": "Psalms 135:1",
      "text": "Praise the Lord! Praise the name of the Lord, give praise, O servants of the Lord,",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.135.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 2,
      "referenceLabel": "Psalms 135:2",
      "text": "you that stand in the house of the Lord, in the courts of the house of our God!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 3,
      "referenceLabel": "Psalms 135:3",
      "text": "Praise the Lord, for the Lord is good; sing to his name, for he is gracious!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 4,
      "referenceLabel": "Psalms 135:4",
      "text": "For the Lord has chosen Jacob for himself, Israel as his own possession.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 5,
      "referenceLabel": "Psalms 135:5",
      "text": "For I know that the Lord is great, and that our Lord is above all gods.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 6,
      "referenceLabel": "Psalms 135:6",
      "text": "Whatever the Lord pleases he does, in heaven and on earth, in the seas and all deeps.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 7,
      "referenceLabel": "Psalms 135:7",
      "text": "He it is who makes the clouds rise at the end of the earth, who makes lightnings for the rain and brings forth the wind from his storehouses.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 8,
      "referenceLabel": "Psalms 135:8",
      "text": "He it was who smote the first-born of Egypt, both of man and of beast;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 9,
      "referenceLabel": "Psalms 135:9",
      "text": "who in thy midst, O Egypt, sent signs and wonders against Pharaoh and all his servants;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 10,
      "referenceLabel": "Psalms 135:10",
      "text": "who smote many nations and slew mighty kings,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 11,
      "referenceLabel": "Psalms 135:11",
      "text": "Sihon, king of the Amorites, and Og, king of Bashan, and all the kingdoms of Canaan,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 12,
      "referenceLabel": "Psalms 135:12",
      "text": "and gave their land as a heritage, a heritage to his people Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 13,
      "referenceLabel": "Psalms 135:13",
      "text": "Thy name, O Lord, endures for ever, thy renown, O Lord, throughout all ages.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 14,
      "referenceLabel": "Psalms 135:14",
      "text": "For the Lord will vindicate his people, and have compassion on his servants.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 15,
      "referenceLabel": "Psalms 135:15",
      "text": "The idols of the nations are silver and gold, the work of men's hands.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 16,
      "referenceLabel": "Psalms 135:16",
      "text": "They have mouths, but they speak not, they have eyes, but they see not,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 17,
      "referenceLabel": "Psalms 135:17",
      "text": "they have ears, but they hear not, nor is there any breath in their mouths.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 18,
      "referenceLabel": "Psalms 135:18",
      "text": "Like them be those who make them!— yea, every one who trusts in them!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 19,
      "referenceLabel": "Psalms 135:19",
      "text": "O house of Israel, bless the Lord! O house of Aaron, bless the Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 20,
      "referenceLabel": "Psalms 135:20",
      "text": "O house of Levi, bless the Lord! You that fear the Lord, bless the Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.135.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 135,
      "verseNumber": 21,
      "referenceLabel": "Psalms 135:21",
      "text": "Blessed be the Lord from Zion, he who dwells in Jerusalem! Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
