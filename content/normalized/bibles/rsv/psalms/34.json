{
  "chapter": {
    "id": "rsv:psalms.34",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 34,
    "referenceLabel": "Psalms 34",
    "summary": "Source text for Psalms 34 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.34.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 1,
      "referenceLabel": "Psalms 34:1",
      "text": "I will bless the Lord at all times; his praise shall continually be in my mouth.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.34.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 2,
      "referenceLabel": "Psalms 34:2",
      "text": "My soul makes its boast in the Lord; let the afflicted hear and be glad.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 3,
      "referenceLabel": "Psalms 34:3",
      "text": "O magnify the Lord with me, and let us exalt his name together!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 4,
      "referenceLabel": "Psalms 34:4",
      "text": "I sought the Lord, and he answered me, and delivered me from all my fears.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 5,
      "referenceLabel": "Psalms 34:5",
      "text": "Look to him, and be radiant; so your faces shall never be ashamed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 6,
      "referenceLabel": "Psalms 34:6",
      "text": "This poor man cried, and the Lord heard him, and saved him out of all his troubles.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 7,
      "referenceLabel": "Psalms 34:7",
      "text": "The angel of the Lord encamps around those who fear him, and delivers them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 8,
      "referenceLabel": "Psalms 34:8",
      "text": "O taste and see that the Lord is good! Happy is the man who takes refuge in him!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 9,
      "referenceLabel": "Psalms 34:9",
      "text": "O fear the Lord, you his saints, for those who fear him have no want!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 10,
      "referenceLabel": "Psalms 34:10",
      "text": "The young lions suffer want and hunger; but those who seek the Lord lack no good thing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 11,
      "referenceLabel": "Psalms 34:11",
      "text": "Come, O sons, listen to me, I will teach you the fear of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 12,
      "referenceLabel": "Psalms 34:12",
      "text": "What man is there who desires life, and covets many days, that he may enjoy good?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 13,
      "referenceLabel": "Psalms 34:13",
      "text": "Keep your tongue from evil, and your lips from speaking deceit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 14,
      "referenceLabel": "Psalms 34:14",
      "text": "Depart from evil, and do good; seek peace, and pursue it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 15,
      "referenceLabel": "Psalms 34:15",
      "text": "The eyes of the Lord are toward the righteous, and his ears toward their cry.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 16,
      "referenceLabel": "Psalms 34:16",
      "text": "The face of the Lord is against evildoers, to cut off the remembrance of them from the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 17,
      "referenceLabel": "Psalms 34:17",
      "text": "When the righteous cry for help, the Lord hears, and delivers them out of all their troubles.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 18,
      "referenceLabel": "Psalms 34:18",
      "text": "The Lord is near to the brokenhearted, and saves the crushed in spirit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 19,
      "referenceLabel": "Psalms 34:19",
      "text": "Many are the afflictions of the righteous; but the Lord delivers him out of them all.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 20,
      "referenceLabel": "Psalms 34:20",
      "text": "He keeps all his bones; not one of them is broken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 21,
      "referenceLabel": "Psalms 34:21",
      "text": "Evil shall slay the wicked; and those who hate the righteous will be condemned.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.34.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 34,
      "verseNumber": 22,
      "referenceLabel": "Psalms 34:22",
      "text": "The Lord redeems the life of his servants; none of those who take refuge in him will be condemned.",
      "paragraphStart": false
    }
  ]
}
