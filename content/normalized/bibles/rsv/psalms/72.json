{
  "chapter": {
    "id": "rsv:psalms.72",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 72,
    "referenceLabel": "Psalms 72",
    "summary": "Source text for Psalms 72 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.72.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 1,
      "referenceLabel": "Psalms 72:1",
      "text": "Give the king thy justice, O God, and thy righteousness to the royal son!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.72.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 2,
      "referenceLabel": "Psalms 72:2",
      "text": "May he judge thy people with righteousness, and thy poor with justice!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 3,
      "referenceLabel": "Psalms 72:3",
      "text": "Let the mountains bear prosperity for the people, and the hills, in righteousness!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 4,
      "referenceLabel": "Psalms 72:4",
      "text": "May he defend the cause of the poor of the people, give deliverance to the needy, and crush the oppressor!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 5,
      "referenceLabel": "Psalms 72:5",
      "text": "May he live while the sun endures, and as long as the moon, throughout all generations!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 6,
      "referenceLabel": "Psalms 72:6",
      "text": "May he be like rain that falls on the mown grass, like showers that water the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 7,
      "referenceLabel": "Psalms 72:7",
      "text": "In his days may righteousness flourish, and peace abound, till the moon be no more!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 8,
      "referenceLabel": "Psalms 72:8",
      "text": "May he have dominion from sea to sea, and from the River to the ends of the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 9,
      "referenceLabel": "Psalms 72:9",
      "text": "May his foes bow down before him, and his enemies lick the dust!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 10,
      "referenceLabel": "Psalms 72:10",
      "text": "May the kings of Tarshish and of the isles render him tribute, may the kings of Sheba and Seba bring gifts!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 11,
      "referenceLabel": "Psalms 72:11",
      "text": "May all kings fall down before him, all nations serve him!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 12,
      "referenceLabel": "Psalms 72:12",
      "text": "For he delivers the needy when he calls, the poor and him who has no helper.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 13,
      "referenceLabel": "Psalms 72:13",
      "text": "He has pity on the weak and the needy, and saves the lives of the needy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 14,
      "referenceLabel": "Psalms 72:14",
      "text": "From oppression and violence he redeems their life; and precious is their blood in his sight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 15,
      "referenceLabel": "Psalms 72:15",
      "text": "Long may he live, may gold of Sheba be given to him! May prayer be made for him continually, and blessings invoked for him all the day!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 16,
      "referenceLabel": "Psalms 72:16",
      "text": "May there be abundance of grain in the land; on the tops of the mountains may it wave; may its fruit be like Lebanon; and may men blossom forth from the cities like the grass of the field!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 17,
      "referenceLabel": "Psalms 72:17",
      "text": "May his name endure for ever, his fame continue as long as the sun! May men bless themselves by him, all nations call him blessed!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 18,
      "referenceLabel": "Psalms 72:18",
      "text": "Blessed be the Lord, the God of Israel, who alone does wondrous things.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 19,
      "referenceLabel": "Psalms 72:19",
      "text": "Blessed be his glorious name for ever; may his glory fill the whole earth! Amen and Amen!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.72.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 72,
      "verseNumber": 20,
      "referenceLabel": "Psalms 72:20",
      "text": "The prayers of David, the son of Jesse, are ended.",
      "paragraphStart": false
    }
  ]
}
