{
  "chapter": {
    "id": "rsv:psalms.146",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 146,
    "referenceLabel": "Psalms 146",
    "summary": "Source text for Psalms 146 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.146.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 1,
      "referenceLabel": "Psalms 146:1",
      "text": "Praise the Lord! Praise the Lord, O my soul!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.146.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 2,
      "referenceLabel": "Psalms 146:2",
      "text": "I will praise the Lord as long as I live; I will sing praises to my God while I have being.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 3,
      "referenceLabel": "Psalms 146:3",
      "text": "Put not your trust in princes, in a son of man, in whom there is no help.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 4,
      "referenceLabel": "Psalms 146:4",
      "text": "When his breath departs he returns to his earth; on that very day his plans perish.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 5,
      "referenceLabel": "Psalms 146:5",
      "text": "Happy is he whose help is the God of Jacob, whose hope is in the Lord his God,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 6,
      "referenceLabel": "Psalms 146:6",
      "text": "who made heaven and earth, the sea, and all that is in them; who keeps faith for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 7,
      "referenceLabel": "Psalms 146:7",
      "text": "who executes justice for the oppressed; who gives food to the hungry. The Lord sets the prisoners free;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 8,
      "referenceLabel": "Psalms 146:8",
      "text": "the Lord opens the eyes of the blind. The Lord lifts up those who are bowed down; the Lord loves the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 9,
      "referenceLabel": "Psalms 146:9",
      "text": "The Lord watches over the sojourners, he upholds the widow and the fatherless; but the way of the wicked he brings to ruin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.146.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 146,
      "verseNumber": 10,
      "referenceLabel": "Psalms 146:10",
      "text": "The Lord will reign for ever, thy God, O Zion, to all generations. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
