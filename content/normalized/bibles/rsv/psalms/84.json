{
  "chapter": {
    "id": "rsv:psalms.84",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 84,
    "referenceLabel": "Psalms 84",
    "summary": "Source text for Psalms 84 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.84.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 1,
      "referenceLabel": "Psalms 84:1",
      "text": "How lovely is thy dwelling place, O Lord of hosts!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.84.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 2,
      "referenceLabel": "Psalms 84:2",
      "text": "My soul longs, yea, faints for the courts of the Lord; my heart and flesh sing for joy to the living God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 3,
      "referenceLabel": "Psalms 84:3",
      "text": "Even the sparrow finds a home, and the swallow a nest for herself, where she may lay her young, at thy altars, O Lord of hosts, my King and my God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 4,
      "referenceLabel": "Psalms 84:4",
      "text": "Blessed are those who dwell in thy house, ever singing thy praise!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 5,
      "referenceLabel": "Psalms 84:5",
      "text": "Blessed are the men whose strength is in thee, in whose heart are the highways to Zion.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 6,
      "referenceLabel": "Psalms 84:6",
      "text": "As they go through the valley of Baca they make it a place of springs; the early rain also covers it with pools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 7,
      "referenceLabel": "Psalms 84:7",
      "text": "They go from strength to strength; the God of gods will be seen in Zion.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 8,
      "referenceLabel": "Psalms 84:8",
      "text": "O Lord God of hosts, hear my prayer; give ear, O God of Jacob!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 9,
      "referenceLabel": "Psalms 84:9",
      "text": "Behold our shield, O God; look upon the face of thine anointed!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 10,
      "referenceLabel": "Psalms 84:10",
      "text": "For a day in thy courts is better than a thousand elsewhere. I would rather be a doorkeeper in the house of my God than dwell in the tents of wickedness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 11,
      "referenceLabel": "Psalms 84:11",
      "text": "For the Lord God is a sun and shield; he bestows favor and honor. No good thing does the Lord withhold from those who walk uprightly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.84.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 84,
      "verseNumber": 12,
      "referenceLabel": "Psalms 84:12",
      "text": "O Lord of hosts, blessed is the man who trusts in thee!",
      "paragraphStart": false
    }
  ]
}
