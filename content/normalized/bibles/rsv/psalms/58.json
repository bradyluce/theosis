{
  "chapter": {
    "id": "rsv:psalms.58",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 58,
    "referenceLabel": "Psalms 58",
    "summary": "Source text for Psalms 58 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.58.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 1,
      "referenceLabel": "Psalms 58:1",
      "text": "Do you indeed decree what is right, you gods? Do you judge the sons of men uprightly?",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.58.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 2,
      "referenceLabel": "Psalms 58:2",
      "text": "Nay, in your hearts you devise wrongs; your hands deal out violence on earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 3,
      "referenceLabel": "Psalms 58:3",
      "text": "The wicked go astray from the womb, they err from their birth, speaking lies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 4,
      "referenceLabel": "Psalms 58:4",
      "text": "They have venom like the venom of a serpent, like the deaf adder that stops its ear,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 5,
      "referenceLabel": "Psalms 58:5",
      "text": "so that it does not hear the voice of charmers or of the cunning enchanter.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 6,
      "referenceLabel": "Psalms 58:6",
      "text": "O God, break the teeth in their mouths; tear out the fangs of the young lions, O Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 7,
      "referenceLabel": "Psalms 58:7",
      "text": "Let them vanish like water that runs away; like grass let them be trodden down and wither.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 8,
      "referenceLabel": "Psalms 58:8",
      "text": "Let them be like the snail which dissolves into slime, like the untimely birth that never sees the sun.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 9,
      "referenceLabel": "Psalms 58:9",
      "text": "Sooner than your pots can feel the heat of thorns, whether green or ablaze, may he sweep them away!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 10,
      "referenceLabel": "Psalms 58:10",
      "text": "The righteous will rejoice when he sees the vengeance; he will bathe his feet in the blood of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.58.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 58,
      "verseNumber": 11,
      "referenceLabel": "Psalms 58:11",
      "text": "Men will say, “Surely there is a reward for the righteous; surely there is a God who judges on earth.”",
      "paragraphStart": false
    }
  ]
}
