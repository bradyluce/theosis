{
  "chapter": {
    "id": "rsv:psalms.25",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 25,
    "referenceLabel": "Psalms 25",
    "summary": "Source text for Psalms 25 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.25.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Psalms 25:1",
      "text": "To thee, O Lord, I lift up my soul.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.25.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Psalms 25:2",
      "text": "O my God, in thee I trust, let me not be put to shame; let not my enemies exult over me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Psalms 25:3",
      "text": "Yea, let none that wait for thee be put to shame; let them be ashamed who are wantonly treacherous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Psalms 25:4",
      "text": "Make me to know thy ways, O Lord; teach me thy paths.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Psalms 25:5",
      "text": "Lead me in thy truth, and teach me, for thou art the God of my salvation; for thee I wait all the day long.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Psalms 25:6",
      "text": "Be mindful of thy mercy, O Lord, and of thy steadfast love, for they have been from of old.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 7,
      "referenceLabel": "Psalms 25:7",
      "text": "Remember not the sins of my youth, or my trangressions; according to thy steadfast love remember me, for thy goodness' sake, O Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 8,
      "referenceLabel": "Psalms 25:8",
      "text": "Good and upright is the Lord; therefore he instructs sinners in the way.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 9,
      "referenceLabel": "Psalms 25:9",
      "text": "He leads the humble in what is right, and teaches the humble his way.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 10,
      "referenceLabel": "Psalms 25:10",
      "text": "All the paths of the Lord are steadfast love and faithfulness, for those who keep his covenant and his testimonies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 11,
      "referenceLabel": "Psalms 25:11",
      "text": "For thy name's sake, O Lord, pardon my guilt, for it is great.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 12,
      "referenceLabel": "Psalms 25:12",
      "text": "Who is the man that fears the Lord? Him will he instruct in the way that he should choose.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 13,
      "referenceLabel": "Psalms 25:13",
      "text": "He himself shall abide in prosperity, and his children shall possess the land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 14,
      "referenceLabel": "Psalms 25:14",
      "text": "The friendship of the Lord is for those who fear him, and he makes known to them his covenant.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 15,
      "referenceLabel": "Psalms 25:15",
      "text": "My eyes are ever toward the Lord, for he will pluck my feet out of the net.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 16,
      "referenceLabel": "Psalms 25:16",
      "text": "Turn thou to me, and be gracious to me; for I am lonely and afflicted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 17,
      "referenceLabel": "Psalms 25:17",
      "text": "Relieve the troubles of my heart, and bring me out of my distresses.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 18,
      "referenceLabel": "Psalms 25:18",
      "text": "Consider my affliction and my trouble, and forgive all my sins.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 19,
      "referenceLabel": "Psalms 25:19",
      "text": "Consider how many are my foes, and with what violent hatred they hate me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 20,
      "referenceLabel": "Psalms 25:20",
      "text": "Oh guard my life, and deliver me; let me not be put to shame, for I take refuge in thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 21,
      "referenceLabel": "Psalms 25:21",
      "text": "May integrity and uprightness preserve me, for I wait for thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.25.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 25,
      "verseNumber": 22,
      "referenceLabel": "Psalms 25:22",
      "text": "Redeem Israel, O God, out of all his troubles.",
      "paragraphStart": false
    }
  ]
}
