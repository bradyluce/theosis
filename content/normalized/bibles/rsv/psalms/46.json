{
  "chapter": {
    "id": "rsv:psalms.46",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 46,
    "referenceLabel": "Psalms 46",
    "summary": "Source text for Psalms 46 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.46.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 1,
      "referenceLabel": "Psalms 46:1",
      "text": "God is our refuge and strength, a very present help in trouble.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.46.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 2,
      "referenceLabel": "Psalms 46:2",
      "text": "Therefore we will not fear though the earth should change, though the mountains shake in the heart of the sea;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 3,
      "referenceLabel": "Psalms 46:3",
      "text": "though its waters roar and foam, though the mountains tremble with its tumult.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 4,
      "referenceLabel": "Psalms 46:4",
      "text": "There is a river whose streams make glad the city of God, the holy habitation of the Most High.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 5,
      "referenceLabel": "Psalms 46:5",
      "text": "God is in the midst of her, she shall not be moved; God will help her right early.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 6,
      "referenceLabel": "Psalms 46:6",
      "text": "The nations rage, the kingdoms totter; he utters his voice, the earth melts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 7,
      "referenceLabel": "Psalms 46:7",
      "text": "The Lord of hosts is with us; the God of Jacob is our refuge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 8,
      "referenceLabel": "Psalms 46:8",
      "text": "Come, behold the works of the Lord, how he has wrought desolations in the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 9,
      "referenceLabel": "Psalms 46:9",
      "text": "He makes wars cease to the end of the earth; he breaks the bow, and shatters the spear, he burns the chariots with fire!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 10,
      "referenceLabel": "Psalms 46:10",
      "text": "“Be still, and know that I am God. I am exalted among the nations, I am exalted in the earth!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.46.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 46,
      "verseNumber": 11,
      "referenceLabel": "Psalms 46:11",
      "text": "The Lord of hosts is with us; the God of Jacob is our refuge.",
      "paragraphStart": false
    }
  ]
}
