{
  "chapter": {
    "id": "rsv:psalms.61",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 61,
    "referenceLabel": "Psalms 61",
    "summary": "Source text for Psalms 61 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.61.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 1,
      "referenceLabel": "Psalms 61:1",
      "text": "Hear my cry, O God, listen to my prayer;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.61.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 2,
      "referenceLabel": "Psalms 61:2",
      "text": "from the end of the earth I call to thee, when my heart is faint. Lead thou me to the rock that is higher than I;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.61.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 3,
      "referenceLabel": "Psalms 61:3",
      "text": "for thou art my refuge, a strong tower against the enemy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.61.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 4,
      "referenceLabel": "Psalms 61:4",
      "text": "Let me dwell in thy tent for ever! Oh to be safe under the shelter of thy wings!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.61.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 5,
      "referenceLabel": "Psalms 61:5",
      "text": "For thou, O God, hast heard my vows, thou hast given me the heritage of those who fear thy name.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.61.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 6,
      "referenceLabel": "Psalms 61:6",
      "text": "Prolong the life of the king; may his years endure to all generations!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.61.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 7,
      "referenceLabel": "Psalms 61:7",
      "text": "May he be enthroned for ever before God; bid steadfast love and faithfulness watch over him!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.61.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 61,
      "verseNumber": 8,
      "referenceLabel": "Psalms 61:8",
      "text": "So will I ever sing praises to thy name, as I pay my vows day after day.",
      "paragraphStart": false
    }
  ]
}
