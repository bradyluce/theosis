{
  "chapter": {
    "id": "rsv:psalms.12",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 12,
    "referenceLabel": "Psalms 12",
    "summary": "Source text for Psalms 12 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.12.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Psalms 12:1",
      "text": "Help, Lord; for there is no longer any that is godly; for the faithful have vanished from among the sons of men.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.12.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Psalms 12:2",
      "text": "Every one utters lies to his neighbor; with flattering lips and a double heart they speak.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.12.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Psalms 12:3",
      "text": "May the Lord cut off all flattering lips, the tongue that makes great boasts,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.12.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Psalms 12:4",
      "text": "those who say, “With our tongue we will prevail, our lips are with us; who is our master?”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.12.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Psalms 12:5",
      "text": "“Because the poor are despoiled, because the needy groan, I will now arise,” says the Lord; “I will place him in the safety for which he longs.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.12.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Psalms 12:6",
      "text": "The promises of the Lord are promises that are pure, silver refined in a furnace on the ground, purified seven times.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.12.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Psalms 12:7",
      "text": "Do thou, O Lord, protect us, guard us ever from this generation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.12.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Psalms 12:8",
      "text": "On every side the wicked prowl, as vileness is exalted among the sons of men.",
      "paragraphStart": false
    }
  ]
}
