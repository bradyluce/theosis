{
  "chapter": {
    "id": "rsv:psalms.111",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 111,
    "referenceLabel": "Psalms 111",
    "summary": "Source text for Psalms 111 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.111.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 1,
      "referenceLabel": "Psalms 111:1",
      "text": "Praise the Lord! I will give thanks to the Lord with my whole heart, in the company of the upright, in the congregation.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.111.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 2,
      "referenceLabel": "Psalms 111:2",
      "text": "Great are the works of the Lord, studied by all who have pleasure in them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 3,
      "referenceLabel": "Psalms 111:3",
      "text": "Full of honor and majesty is his work, and his righteousness endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 4,
      "referenceLabel": "Psalms 111:4",
      "text": "He has caused his wonderful works to be remembered; the Lord is gracious and merciful.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 5,
      "referenceLabel": "Psalms 111:5",
      "text": "He provides food for those who fear him; he is ever mindful of his covenant.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 6,
      "referenceLabel": "Psalms 111:6",
      "text": "He has shown his people the power of his works, in giving them the heritage of the nations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 7,
      "referenceLabel": "Psalms 111:7",
      "text": "The works of his hands are faithful and just; all his precepts are trustworthy,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 8,
      "referenceLabel": "Psalms 111:8",
      "text": "they are established for ever and ever, to be performed with faithfulness and uprightness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 9,
      "referenceLabel": "Psalms 111:9",
      "text": "He sent redemption to his people; he has commanded his covenant for ever. Holy and terrible is his name!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.111.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 111,
      "verseNumber": 10,
      "referenceLabel": "Psalms 111:10",
      "text": "The fear of the Lord is the beginning of wisdom; a good understanding have all those who practice it. His praise endures for ever!",
      "paragraphStart": false
    }
  ]
}
