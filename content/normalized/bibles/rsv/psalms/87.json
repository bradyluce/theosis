{
  "chapter": {
    "id": "rsv:psalms.87",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 87,
    "referenceLabel": "Psalms 87",
    "summary": "Source text for Psalms 87 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.87.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 1,
      "referenceLabel": "Psalms 87:1",
      "text": "On the holy mount stands the city he founded;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.87.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 2,
      "referenceLabel": "Psalms 87:2",
      "text": "the Lord loves the gates of Zion more than all the dwelling places of Jacob.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.87.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 3,
      "referenceLabel": "Psalms 87:3",
      "text": "Glorious things are spoken of you, O city of God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.87.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 4,
      "referenceLabel": "Psalms 87:4",
      "text": "Among those who know me I mention Rahab and Babylon; behold, Philistia and Tyre, with Ethiopia— “This one was born there,” they say.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.87.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 5,
      "referenceLabel": "Psalms 87:5",
      "text": "And of Zion it shall be said, “This one and that one were born in her”; for the Most High himself will establish her.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.87.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 6,
      "referenceLabel": "Psalms 87:6",
      "text": "The Lord records as he registers the peoples, “This one was born there.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.87.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 87,
      "verseNumber": 7,
      "referenceLabel": "Psalms 87:7",
      "text": "Singers and dancers alike say, “All my springs are in you.”",
      "paragraphStart": false
    }
  ]
}
