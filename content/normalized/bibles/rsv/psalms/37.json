{
  "chapter": {
    "id": "rsv:psalms.37",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 37,
    "referenceLabel": "Psalms 37",
    "summary": "Source text for Psalms 37 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.37.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 1,
      "referenceLabel": "Psalms 37:1",
      "text": "Fret not yourself because of the wicked, be not envious of wrongdoers!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.37.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 2,
      "referenceLabel": "Psalms 37:2",
      "text": "For they will soon fade like the grass, and wither like the green herb.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 3,
      "referenceLabel": "Psalms 37:3",
      "text": "Trust in the Lord, and do good; so you will dwell in the land, and enjoy security.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 4,
      "referenceLabel": "Psalms 37:4",
      "text": "Take delight in the Lord, and he will give you the desires of your heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 5,
      "referenceLabel": "Psalms 37:5",
      "text": "Commit your way to the Lord; trust in him, and he will act.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 6,
      "referenceLabel": "Psalms 37:6",
      "text": "He will bring forth your vindication as the light, and your right as the noonday.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 7,
      "referenceLabel": "Psalms 37:7",
      "text": "Be still before the Lord, and wait patiently for him; fret not yourself over him who prospers in his way, over the man who carries out evil devices!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 8,
      "referenceLabel": "Psalms 37:8",
      "text": "Refrain from anger, and forsake wrath! Fret not yourself; it tends only to evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 9,
      "referenceLabel": "Psalms 37:9",
      "text": "For the wicked shall be cut off; but those who wait for the Lord shall possess the land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 10,
      "referenceLabel": "Psalms 37:10",
      "text": "Yet a little while, and the wicked will be no more; though you look well at his place, he will not be there.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 11,
      "referenceLabel": "Psalms 37:11",
      "text": "But the meek shall possess the land, and delight themselves in abundant prosperity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 12,
      "referenceLabel": "Psalms 37:12",
      "text": "The wicked plots against the righteous, and gnashes his teeth at him;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 13,
      "referenceLabel": "Psalms 37:13",
      "text": "but the Lord laughs at the wicked, for he sees that his day is coming.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 14,
      "referenceLabel": "Psalms 37:14",
      "text": "The wicked draw the sword and bend their bows, to bring down the poor and needy, to slay those who walk uprightly;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 15,
      "referenceLabel": "Psalms 37:15",
      "text": "their sword shall enter their own heart, and their bows shall be broken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 16,
      "referenceLabel": "Psalms 37:16",
      "text": "Better is a little that the righteous has than the abundance of many wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 17,
      "referenceLabel": "Psalms 37:17",
      "text": "For the arms of the wicked shall be broken; but the Lord upholds the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 18,
      "referenceLabel": "Psalms 37:18",
      "text": "The Lord knows the days of the blameless, and their heritage will abide for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 19,
      "referenceLabel": "Psalms 37:19",
      "text": "they are not put to shame in evil times, in the days of famine they have abundance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 20,
      "referenceLabel": "Psalms 37:20",
      "text": "But the wicked perish; the enemies of the Lord are like the glory of the pastures, they vanish—like smoke they vanish away.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 21,
      "referenceLabel": "Psalms 37:21",
      "text": "The wicked borrows, and cannot pay back, but the righteous is generous and gives;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 22,
      "referenceLabel": "Psalms 37:22",
      "text": "for those blessed by the Lord shall possess the land, but those cursed by him shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 23,
      "referenceLabel": "Psalms 37:23",
      "text": "The steps of a man are from the Lord, and he establishes him in whose way he delights;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 24,
      "referenceLabel": "Psalms 37:24",
      "text": "though he fall, he shall not be cast headlong, for the Lord is the stay of his hand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 25,
      "referenceLabel": "Psalms 37:25",
      "text": "I have been young, and now am old; yet I have not seen the righteous forsaken or his children begging bread.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 26,
      "referenceLabel": "Psalms 37:26",
      "text": "He is ever giving liberally and lending, and his children become a blessing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 27,
      "referenceLabel": "Psalms 37:27",
      "text": "Depart from evil, and do good; so shall you abide for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 28,
      "referenceLabel": "Psalms 37:28",
      "text": "For the Lord loves justice; he will not forsake his saints. The righteous shall be preserved for ever, but the children of the wicked shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 29,
      "referenceLabel": "Psalms 37:29",
      "text": "The righteous shall possess the land, and dwell upon it for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.30",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 30,
      "referenceLabel": "Psalms 37:30",
      "text": "The mouth of the righteous utters wisdom, and his tongue speaks justice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.31",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 31,
      "referenceLabel": "Psalms 37:31",
      "text": "The law of his God is in his heart; his steps do not slip.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.32",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 32,
      "referenceLabel": "Psalms 37:32",
      "text": "The wicked watches the righteous, and seeks to slay him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.33",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 33,
      "referenceLabel": "Psalms 37:33",
      "text": "The Lord will not abandon him to his power, or let him be condemned when he is brought to trial.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.34",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 34,
      "referenceLabel": "Psalms 37:34",
      "text": "Wait for the Lord, and keep to his way, and he will exalt you to possess the land; you will look on the destruction of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.35",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 35,
      "referenceLabel": "Psalms 37:35",
      "text": "I have seen a wicked man overbearing, and towering like a cedar of Lebanon.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.36",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 36,
      "referenceLabel": "Psalms 37:36",
      "text": "Again I passed by, and lo, he was no more; though I sought him, he could not be found.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.37",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 37,
      "referenceLabel": "Psalms 37:37",
      "text": "Mark the blameless man, and behold the upright, for there is posterity for the man of peace.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.38",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 38,
      "referenceLabel": "Psalms 37:38",
      "text": "But transgressors shall be altogether destroyed; the posterity of the wicked shall be cut off.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.39",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 39,
      "referenceLabel": "Psalms 37:39",
      "text": "The salvation of the righteous is from the Lord; he is their refuge in the time of trouble.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.37.40",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 37,
      "verseNumber": 40,
      "referenceLabel": "Psalms 37:40",
      "text": "The Lord helps them and delivers them; he delivers them from the wicked, and saves them, because they take refuge in him.",
      "paragraphStart": false
    }
  ]
}
