{
  "chapter": {
    "id": "rsv:psalms.130",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 130,
    "referenceLabel": "Psalms 130",
    "summary": "Source text for Psalms 130 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.130.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 1,
      "referenceLabel": "Psalms 130:1",
      "text": "Out of the depths I cry to thee, O Lord!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.130.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 2,
      "referenceLabel": "Psalms 130:2",
      "text": "Lord, hear my voice! Let thy ears be attentive to the voice of my supplications!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.130.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 3,
      "referenceLabel": "Psalms 130:3",
      "text": "If thou, O Lord, shouldst mark iniquities, Lord, who could stand?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.130.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 4,
      "referenceLabel": "Psalms 130:4",
      "text": "But there is forgiveness with thee, that thou mayest be feared.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.130.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 5,
      "referenceLabel": "Psalms 130:5",
      "text": "I wait for the Lord, my soul waits, and in his word I hope;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.130.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 6,
      "referenceLabel": "Psalms 130:6",
      "text": "my soul waits for the Lord more than watchmen for the morning, more than watchmen for the morning.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.130.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 7,
      "referenceLabel": "Psalms 130:7",
      "text": "O Israel, hope in the Lord! For with the Lord there is steadfast love, and with him is plenteous redemption.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.130.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 130,
      "verseNumber": 8,
      "referenceLabel": "Psalms 130:8",
      "text": "And he will redeem Israel from all his iniquities.",
      "paragraphStart": false
    }
  ]
}
