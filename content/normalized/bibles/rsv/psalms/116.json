{
  "chapter": {
    "id": "rsv:psalms.116",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 116,
    "referenceLabel": "Psalms 116",
    "summary": "Source text for Psalms 116 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.116.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 1,
      "referenceLabel": "Psalms 116:1",
      "text": "I love the Lord, because he has heard my voice and my supplications.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.116.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 2,
      "referenceLabel": "Psalms 116:2",
      "text": "Because he inclined his ear to me, therefore I will call on him as long as I live.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 3,
      "referenceLabel": "Psalms 116:3",
      "text": "The snares of death encompassed me; the pangs of Sheol laid hold on me; I suffered distress and anguish.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 4,
      "referenceLabel": "Psalms 116:4",
      "text": "Then I called on the name of the Lord: “O Lord, I beseech thee, save my life!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 5,
      "referenceLabel": "Psalms 116:5",
      "text": "Gracious is the Lord, and righteous; our God is merciful.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 6,
      "referenceLabel": "Psalms 116:6",
      "text": "The Lord preserves the simple; when I was brought low, he saved me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 7,
      "referenceLabel": "Psalms 116:7",
      "text": "Return, O my soul, to your rest; for the Lord has dealt bountifully with you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 8,
      "referenceLabel": "Psalms 116:8",
      "text": "For thou hast delivered my soul from death, my eyes from tears, my feet from stumbling;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 9,
      "referenceLabel": "Psalms 116:9",
      "text": "I walk before the Lord in the land of the living.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 10,
      "referenceLabel": "Psalms 116:10",
      "text": "I kept my faith, even when I said, “I am greatly afflicted”;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 11,
      "referenceLabel": "Psalms 116:11",
      "text": "I said in my consternation, “Men are all a vain hope.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 12,
      "referenceLabel": "Psalms 116:12",
      "text": "What shall I render to the Lord for all his bounty to me?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 13,
      "referenceLabel": "Psalms 116:13",
      "text": "I will lift up the cup of salvation and call on the name of the Lord,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 14,
      "referenceLabel": "Psalms 116:14",
      "text": "I will pay my vows to the Lord in the presence of all his people.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 15,
      "referenceLabel": "Psalms 116:15",
      "text": "Precious in the sight of the Lord is the death of his saints.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 16,
      "referenceLabel": "Psalms 116:16",
      "text": "O Lord, I am thy servant; I am thy servant, the son of thy handmaid. Thou hast loosed my bonds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 17,
      "referenceLabel": "Psalms 116:17",
      "text": "I will offer to thee the sacrifice of thanksgiving and call on the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 18,
      "referenceLabel": "Psalms 116:18",
      "text": "I will pay my vows to the Lord in the presence of all his people,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.116.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 116,
      "verseNumber": 19,
      "referenceLabel": "Psalms 116:19",
      "text": "in the courts of the house of the Lord, in your midst, O Jerusalem. Praise the Lord!",
      "paragraphStart": false
    }
  ]
}
