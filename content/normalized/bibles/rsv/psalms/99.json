{
  "chapter": {
    "id": "rsv:psalms.99",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 99,
    "referenceLabel": "Psalms 99",
    "summary": "Source text for Psalms 99 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.99.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 1,
      "referenceLabel": "Psalms 99:1",
      "text": "The Lord reigns; let the peoples tremble! He sits enthroned upon the cherubim; let the earth quake!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.99.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 2,
      "referenceLabel": "Psalms 99:2",
      "text": "The Lord is great in Zion; he is exalted over all the peoples.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 3,
      "referenceLabel": "Psalms 99:3",
      "text": "Let them praise thy great and terrible name! Holy is he!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 4,
      "referenceLabel": "Psalms 99:4",
      "text": "Mighty King, lover of justice, thou hast established equity; thou hast executed justice and righteousness in Jacob.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 5,
      "referenceLabel": "Psalms 99:5",
      "text": "Extol the Lord our God; worship at his footstool! Holy is he!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 6,
      "referenceLabel": "Psalms 99:6",
      "text": "Moses and Aaron were among his priests, Samuel also was among those who called on his name. They cried to the Lord, and he answered them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 7,
      "referenceLabel": "Psalms 99:7",
      "text": "He spoke to them in the pillar of cloud; they kept his testimonies, and the statutes that he gave them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 8,
      "referenceLabel": "Psalms 99:8",
      "text": "O Lord our God, thou didst answer them; thou wast a forgiving God to them, but an avenger of their wrongdoings.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.99.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 99,
      "verseNumber": 9,
      "referenceLabel": "Psalms 99:9",
      "text": "Extol the Lord our God, and worship at his holy mountain; for the Lord our God is holy!",
      "paragraphStart": false
    }
  ]
}
