{
  "chapter": {
    "id": "rsv:psalms.98",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 98,
    "referenceLabel": "Psalms 98",
    "summary": "Source text for Psalms 98 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.98.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 1,
      "referenceLabel": "Psalms 98:1",
      "text": "O sing to the Lord a new song, for he has done marvelous things! His right hand and his holy arm have gotten him victory.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.98.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 2,
      "referenceLabel": "Psalms 98:2",
      "text": "The Lord has made known his victory, he has revealed his vindication in the sight of the nations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 3,
      "referenceLabel": "Psalms 98:3",
      "text": "He has remembered his steadfast love and faithfulness to the house of Israel. All the ends of the earth have seen the victory of our God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 4,
      "referenceLabel": "Psalms 98:4",
      "text": "Make a joyful noise to the Lord, all the earth; break forth into joyous song and sing praises!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 5,
      "referenceLabel": "Psalms 98:5",
      "text": "Sing praises to the Lord with the lyre, with the lyre and the sound of melody!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 6,
      "referenceLabel": "Psalms 98:6",
      "text": "With trumpets and the sound of the horn make a joyful noise before the King, the Lord!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 7,
      "referenceLabel": "Psalms 98:7",
      "text": "Let the sea roar, and all that fills it; the world and those who dwell in it!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 8,
      "referenceLabel": "Psalms 98:8",
      "text": "Let the floods clap their hands; let the hills sing for joy together",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.98.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 98,
      "verseNumber": 9,
      "referenceLabel": "Psalms 98:9",
      "text": "before the Lord, for he comes to judge the earth. He will judge the world with righteousness, and the peoples with equity.",
      "paragraphStart": false
    }
  ]
}
