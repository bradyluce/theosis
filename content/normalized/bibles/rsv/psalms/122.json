{
  "chapter": {
    "id": "rsv:psalms.122",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 122,
    "referenceLabel": "Psalms 122",
    "summary": "Source text for Psalms 122 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.122.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 1,
      "referenceLabel": "Psalms 122:1",
      "text": "I was glad when they said to me, “Let us go to the house of the Lord!”",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.122.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 2,
      "referenceLabel": "Psalms 122:2",
      "text": "Our feet have been standing within your gates, O Jerusalem!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 3,
      "referenceLabel": "Psalms 122:3",
      "text": "Jerusalem, built as a city which is bound firmly together,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 4,
      "referenceLabel": "Psalms 122:4",
      "text": "to which the tribes go up, the tribes of the Lord, as was decreed for Israel, to give thanks to the name of the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 5,
      "referenceLabel": "Psalms 122:5",
      "text": "There thrones for judgment were set, the thrones of the house of David.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 6,
      "referenceLabel": "Psalms 122:6",
      "text": "Pray for the peace of Jerusalem! “May they prosper who love you!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 7,
      "referenceLabel": "Psalms 122:7",
      "text": "Peace be within your walls, and security within your towers!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 8,
      "referenceLabel": "Psalms 122:8",
      "text": "For my brethren and companions' sake I will say, “Peace be within you!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.122.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 122,
      "verseNumber": 9,
      "referenceLabel": "Psalms 122:9",
      "text": "For the sake of the house of the Lord our God, I will seek your good.",
      "paragraphStart": false
    }
  ]
}
