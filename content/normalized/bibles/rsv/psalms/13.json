  "verses": [
    {
      "id": "rsv:psalms.13.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Psalms 13:1",
      "text": "How long, O Lord? Wilt thou forget me for ever? How long wilt thou hide thy face from me?",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.13.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Psalms 13:2",
      "text": "How long must I bear pain in my soul, and have sorrow in my heart all the day? How long shall my enemy be exalted over me?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.13.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Psalms 13:3",
      "text": "Consider and answer me, O Lord my God; lighten my eyes, lest I sleep the sleep of death;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.13.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Psalms 13:4",
      "text": "lest my enemy say, “I have prevailed over him”; lest my foes rejoice because I am shaken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.13.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Psalms 13:5",
      "text": "But I have trusted in thy steadfast love; my heart shall rejoice in thy salvation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.13.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Psalms 13:6",
      "text": "I will sing to the Lord, because he has dealt bountifully with me.",
      "paragraphStart": false
    }
  ]
}
