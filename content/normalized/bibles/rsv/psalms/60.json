{
  "chapter": {
    "id": "rsv:psalms.60",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 60,
    "referenceLabel": "Psalms 60",
    "summary": "Source text for Psalms 60 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.60.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 1,
      "referenceLabel": "Psalms 60:1",
      "text": "O God, thou hast rejected us, broken our defenses; thou hast been angry; oh, restore us.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.60.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 2,
      "referenceLabel": "Psalms 60:2",
      "text": "Thou hast made the land to quake, thou hast rent it open; repair its breaches, for it totters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 3,
      "referenceLabel": "Psalms 60:3",
      "text": "Thou hast made thy people suffer hard things; thou hast given us wine to drink that made us reel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 4,
      "referenceLabel": "Psalms 60:4",
      "text": "Thou hast set up a banner for those who fear thee, to rally to it from the bow.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 5,
      "referenceLabel": "Psalms 60:5",
      "text": "That thy beloved may be delivered, give victory by thy right hand and answer us!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 6,
      "referenceLabel": "Psalms 60:6",
      "text": "God has spoken in his sanctuary: “With exultation I will divide up Shechem and portion out the Vale of Succoth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 7,
      "referenceLabel": "Psalms 60:7",
      "text": "Gilead is mine; Manasseh is mine; Ephraim is my helmet; Judah is my scepter.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 8,
      "referenceLabel": "Psalms 60:8",
      "text": "Moab is my washbasin; upon Edom I cast my shoe; over Philistia I shout in triumph.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 9,
      "referenceLabel": "Psalms 60:9",
      "text": "Who will bring me to the fortified city? Who will lead me to Edom?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 10,
      "referenceLabel": "Psalms 60:10",
      "text": "Hast thou not rejected us, O God? Thou dost not go forth, O God, with our armies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 11,
      "referenceLabel": "Psalms 60:11",
      "text": "O grant us help against the foe, for vain is the help of man!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.60.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 60,
      "verseNumber": 12,
      "referenceLabel": "Psalms 60:12",
      "text": "With God we shall do valiantly; it is he who will tread down our foes.",
      "paragraphStart": false
    }
  ]
}
