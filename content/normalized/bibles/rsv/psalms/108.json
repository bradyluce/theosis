{
  "chapter": {
    "id": "rsv:psalms.108",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 108,
    "referenceLabel": "Psalms 108",
    "summary": "Source text for Psalms 108 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.108.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 1,
      "referenceLabel": "Psalms 108:1",
      "text": "My heart is steadfast, O God, my heart is steadfast! I will sing and make melody! Awake, my soul!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.108.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 2,
      "referenceLabel": "Psalms 108:2",
      "text": "Awake, O harp and lyre! I will awake the dawn!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 3,
      "referenceLabel": "Psalms 108:3",
      "text": "I will give thanks to thee, O Lord, among the peoples, I will sing praises to thee among the nations.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 4,
      "referenceLabel": "Psalms 108:4",
      "text": "For thy steadfast love is great above the heavens, thy faithfulness reaches to the clouds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 5,
      "referenceLabel": "Psalms 108:5",
      "text": "Be exalted, O God, above the heavens! Let thy glory be over all the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 6,
      "referenceLabel": "Psalms 108:6",
      "text": "That thy beloved may be delivered, give help by thy right hand, and answer me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 7,
      "referenceLabel": "Psalms 108:7",
      "text": "God has promised in his sanctuary: “With exultation I will divide up Shechem, and portion out the Vale of Succoth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 8,
      "referenceLabel": "Psalms 108:8",
      "text": "Gilead is mine; Manasseh is mine; Ephraim is my helmet; Judah my scepter.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 9,
      "referenceLabel": "Psalms 108:9",
      "text": "Moab is my washbasin; upon Edom I cast my shoe; over Philistia I shout in triumph.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 10,
      "referenceLabel": "Psalms 108:10",
      "text": "Who will bring me to the fortified city? Who will lead me to Edom?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 11,
      "referenceLabel": "Psalms 108:11",
      "text": "Hast thou not rejected us, O God? Thou dost not go forth, O God, with our armies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 12,
      "referenceLabel": "Psalms 108:12",
      "text": "O grant us help against the foe, for vain is the help of man!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.108.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 108,
      "verseNumber": 13,
      "referenceLabel": "Psalms 108:13",
      "text": "With God we shall do valiantly; it is he who will tread down our foes.",
      "paragraphStart": false
    }
  ]
}
