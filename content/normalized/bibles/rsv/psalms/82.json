{
  "chapter": {
    "id": "rsv:psalms.82",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 82,
    "referenceLabel": "Psalms 82",
    "summary": "Source text for Psalms 82 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.82.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 1,
      "referenceLabel": "Psalms 82:1",
      "text": "God has taken his place in the divine council; in the midst of the gods he holds judgment:",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.82.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 2,
      "referenceLabel": "Psalms 82:2",
      "text": "“How long will you judge unjustly and show partiality to the wicked?",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.82.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 3,
      "referenceLabel": "Psalms 82:3",
      "text": "Give justice to the weak and the fatherless; maintain the right of the afflicted and the destitute.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.82.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 4,
      "referenceLabel": "Psalms 82:4",
      "text": "Rescue the weak and the needy; deliver them from the hand of the wicked.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.82.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 5,
      "referenceLabel": "Psalms 82:5",
      "text": "They have neither knowledge nor understanding, they walk about in darkness; all the foundations of the earth are shaken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.82.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 6,
      "referenceLabel": "Psalms 82:6",
      "text": "I say, “You are gods, sons of the Most High, all of you;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.82.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 7,
      "referenceLabel": "Psalms 82:7",
      "text": "nevertheless, you shall die like men, and fall like any prince.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.82.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 82,
      "verseNumber": 8,
      "referenceLabel": "Psalms 82:8",
      "text": "Arise, O God, judge the earth; for to thee belong all the nations!",
      "paragraphStart": false
    }
  ]
}
