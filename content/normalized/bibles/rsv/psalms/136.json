  "verses": [
    {
      "id": "rsv:psalms.136.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 1,
      "referenceLabel": "Psalms 136:1",
      "text": "O give thanks to the Lord, for he is good, for his steadfast love endures for ever.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.136.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 2,
      "referenceLabel": "Psalms 136:2",
      "text": "O give thanks to the God of gods, for his steadfast love endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 3,
      "referenceLabel": "Psalms 136:3",
      "text": "O give thanks to the Lord of lords, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 4,
      "referenceLabel": "Psalms 136:4",
      "text": "to him who alone does great wonders, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 5,
      "referenceLabel": "Psalms 136:5",
      "text": "to him who by understanding made the heavens, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 6,
      "referenceLabel": "Psalms 136:6",
      "text": "to him who spread out the earth upon the waters, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 7,
      "referenceLabel": "Psalms 136:7",
      "text": "to him who made the great lights, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 8,
      "referenceLabel": "Psalms 136:8",
      "text": "the sun to rule over the day, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 9,
      "referenceLabel": "Psalms 136:9",
      "text": "the moon and stars to rule over the night, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 10,
      "referenceLabel": "Psalms 136:10",
      "text": "to him who smote the first-born of Egypt, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 11,
      "referenceLabel": "Psalms 136:11",
      "text": "and brought Israel out from among them, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 12,
      "referenceLabel": "Psalms 136:12",
      "text": "with a strong hand and an outstretched arm, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 13,
      "referenceLabel": "Psalms 136:13",
      "text": "to him who divided the Red Sea in sunder, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 14,
      "referenceLabel": "Psalms 136:14",
      "text": "and made Israel pass through the midst of it, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 15,
      "referenceLabel": "Psalms 136:15",
      "text": "but overthrew Pharaoh and his host in the Red Sea, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 16,
      "referenceLabel": "Psalms 136:16",
      "text": "to him who led his people through the wilderness, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 17,
      "referenceLabel": "Psalms 136:17",
      "text": "to him who smote great kings, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 18,
      "referenceLabel": "Psalms 136:18",
      "text": "and slew famous kings, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 19,
      "referenceLabel": "Psalms 136:19",
      "text": "Sihon, king of the Amorites, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 20,
      "referenceLabel": "Psalms 136:20",
      "text": "and Og, king of Bashan, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 21,
      "referenceLabel": "Psalms 136:21",
      "text": "and gave their land as a heritage, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 22,
      "referenceLabel": "Psalms 136:22",
      "text": "a heritage to Israel his servant, for his steadfast love endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 23,
      "referenceLabel": "Psalms 136:23",
      "text": "It is he who remembered us in our low estate, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 24,
      "referenceLabel": "Psalms 136:24",
      "text": "and rescued us from our foes, for his steadfast love endures for ever;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 25,
      "referenceLabel": "Psalms 136:25",
      "text": "he who gives food to all flesh, for his steadfast love endures for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.136.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 136,
      "verseNumber": 26,
      "referenceLabel": "Psalms 136:26",
      "text": "O give thanks to the God of heaven, for his steadfast love endures for ever.",
      "paragraphStart": false
    }
  ]
