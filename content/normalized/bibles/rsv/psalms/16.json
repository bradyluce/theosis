{
  "chapter": {
    "id": "rsv:psalms.16",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 16,
    "referenceLabel": "Psalms 16",
    "summary": "Source text for Psalms 16 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.16.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Psalms 16:1",
      "text": "Preserve me, O God, for in thee I take refuge.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.16.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Psalms 16:2",
      "text": "I say to the Lord, “Thou art my Lord; I have no good apart from thee.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Psalms 16:3",
      "text": "As for the saints in the land, they are the noble, in whom is all my delight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Psalms 16:4",
      "text": "Those who choose another god multiply their sorrows; their libations of blood I will not pour out or take their names upon my lips.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Psalms 16:5",
      "text": "The Lord is my chosen portion and my cup; thou holdest my lot.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Psalms 16:6",
      "text": "The lines have fallen for me in pleasant places; yea, I have a goodly heritage.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Psalms 16:7",
      "text": "I bless the Lord who gives me counsel; in the night also my heart instructs me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Psalms 16:8",
      "text": "I keep the Lord always before me; because he is at my right hand, I shall not be moved.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Psalms 16:9",
      "text": "Therefore my heart is glad, and my soul rejoices; my body also dwells secure.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Psalms 16:10",
      "text": "For thou dost not give me up to Sheol, or let thy godly one see the Pit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.16.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Psalms 16:11",
      "text": "Thou dost show me the path of life; in thy presence there is fulness of joy, in thy right hand are pleasures for evermore.",
      "paragraphStart": false
    }
  ]
}
