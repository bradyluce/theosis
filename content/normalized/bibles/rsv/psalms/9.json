{
  "chapter": {
    "id": "rsv:psalms.9",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 9,
    "referenceLabel": "Psalms 9",
    "summary": "Source text for Psalms 9 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.9.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Psalms 9:1",
      "text": "I will give thanks to the Lord with my whole heart; I will tell of all thy wonderful deeds.",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.9.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Psalms 9:2",
      "text": "I will be glad and exult in thee, I will sing praise to thy name, O Most High.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Psalms 9:3",
      "text": "When my enemies turned back, they stumbled and perished before thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Psalms 9:4",
      "text": "For thou hast maintained my just cause; thou hast sat on the throne giving righteous judgment.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Psalms 9:5",
      "text": "Thou hast rebuked the nations, thou hast destroyed the wicked; thou hast blotted out their name for ever and ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Psalms 9:6",
      "text": "The enemy have vanished in everlasting ruins; their cities thou hast rooted out; the very memory of them has perished.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Psalms 9:7",
      "text": "But the Lord sits enthroned for ever, he has established his throne for judgment;",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Psalms 9:8",
      "text": "and he judges the world with righteousness, he judges the peoples with equity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Psalms 9:9",
      "text": "The Lord is a stronghold for the oppressed, a stronghold in times of trouble.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Psalms 9:10",
      "text": "And those who know thy name put their trust in thee, for thou, O Lord, hast not forsaken those who seek thee.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Psalms 9:11",
      "text": "Sing praises to the Lord, who dwells in Zion! Tell among the peoples his deeds!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Psalms 9:12",
      "text": "For he who avenges blood is mindful of them; he does not forget the cry of the afflicted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Psalms 9:13",
      "text": "Be gracious to me, O Lord! Behold what I suffer from those who hate me, O thou who liftest me up from the gates of death,",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Psalms 9:14",
      "text": "that I may recount all thy praises, that in the gates of the daughter of Zion I may rejoice in thy deliverance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Psalms 9:15",
      "text": "The nations have sunk in the pit which they made; in the net which they hid has their own foot been caught.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Psalms 9:16",
      "text": "The Lord has made himself known, he has executed judgment; the wicked are snared in the work of their own hands.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Psalms 9:17",
      "text": "The wicked shall depart to Sheol, all the nations that forget God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Psalms 9:18",
      "text": "For the needy shall not always be forgotten, and the hope of the poor shall not perish for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Psalms 9:19",
      "text": "Arise, O Lord! Let not man prevail; let the nations be judged before thee!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.9.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Psalms 9:20",
      "text": "Put them in fear, O Lord! Let the nations know that they are but men!",
      "paragraphStart": false
    }
  ]
}
