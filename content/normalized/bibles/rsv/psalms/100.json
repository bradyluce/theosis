{
  "chapter": {
    "id": "rsv:psalms.100",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 100,
    "referenceLabel": "Psalms 100",
    "summary": "Source text for Psalms 100 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.100.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 1,
      "referenceLabel": "Psalms 100:1",
      "text": "Make a joyful noise to the Lord, all the lands!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.100.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 2,
      "referenceLabel": "Psalms 100:2",
      "text": "Serve the Lord with gladness! Come into his presence with singing!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.100.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 3,
      "referenceLabel": "Psalms 100:3",
      "text": "Know that the Lord is God! It is he that made us, and we are his; we are his people, and the sheep of his pasture.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.100.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 4,
      "referenceLabel": "Psalms 100:4",
      "text": "Enter his gates with thanksgiving, and his courts with praise! Give thanks to him, bless his name!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.100.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 100,
      "verseNumber": 5,
      "referenceLabel": "Psalms 100:5",
      "text": "For the Lord is good; his steadfast love endures for ever, and his faithfulness to all generations.",
      "paragraphStart": false
    }
  ]
}
