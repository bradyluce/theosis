{
  "chapter": {
    "id": "rsv:psalms.109",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 109,
    "referenceLabel": "Psalms 109",
    "summary": "Source text for Psalms 109 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.109.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 1,
      "referenceLabel": "Psalms 109:1",
      "text": "Be not silent, O God of my praise!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.109.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 2,
      "referenceLabel": "Psalms 109:2",
      "text": "For wicked and deceitful mouths are opened against me, speaking against me with lying tongues.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 3,
      "referenceLabel": "Psalms 109:3",
      "text": "They beset me with words of hate, and attack me without cause.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 4,
      "referenceLabel": "Psalms 109:4",
      "text": "In return for my love they accuse me, even as I make prayer for them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 5,
      "referenceLabel": "Psalms 109:5",
      "text": "So they reward me evil for good, and hatred for my love.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 6,
      "referenceLabel": "Psalms 109:6",
      "text": "Appoint a wicked man against him; let an accuser bring him to trial.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 7,
      "referenceLabel": "Psalms 109:7",
      "text": "When he is tried, let him come forth guilty; let his prayer be counted as sin!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 8,
      "referenceLabel": "Psalms 109:8",
      "text": "May his days be few; may another seize his goods!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.9",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 9,
      "referenceLabel": "Psalms 109:9",
      "text": "May his children be fatherless, and his wife a widow!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.10",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 10,
      "referenceLabel": "Psalms 109:10",
      "text": "May his children wander about and beg; may they be driven out of the ruins they inhabit!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.11",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 11,
      "referenceLabel": "Psalms 109:11",
      "text": "May the creditor seize all that he has; may strangers plunder the fruits of his toil!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.12",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 12,
      "referenceLabel": "Psalms 109:12",
      "text": "Let there be none to extend kindness to him, nor any to pity his fatherless children!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.13",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 13,
      "referenceLabel": "Psalms 109:13",
      "text": "May his posterity be cut off; may his name be blotted out in the second generation!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.14",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 14,
      "referenceLabel": "Psalms 109:14",
      "text": "May the iniquity of his fathers be remembered before the Lord, and let not the sin of his mother be blotted out!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.15",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 15,
      "referenceLabel": "Psalms 109:15",
      "text": "Let them be before the Lord continually; and may his memory be cut off from the earth!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.16",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 16,
      "referenceLabel": "Psalms 109:16",
      "text": "For he did not remember to show kindness, but pursued the poor and needy and the brokenhearted to their death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.17",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 17,
      "referenceLabel": "Psalms 109:17",
      "text": "He loved to curse; let curses come on him! He did not like blessing; may it be far from him!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.18",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 18,
      "referenceLabel": "Psalms 109:18",
      "text": "He clothed himself with cursing as his coat, may it soak into his body like water, like oil into his bones!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.19",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 19,
      "referenceLabel": "Psalms 109:19",
      "text": "May it be like a garment which he wraps round him, like a belt with which he daily girds himself!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.20",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 20,
      "referenceLabel": "Psalms 109:20",
      "text": "May this be the reward of my accusers from the Lord, of those who speak evil against my life!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.21",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 21,
      "referenceLabel": "Psalms 109:21",
      "text": "But thou, O God my Lord, deal on my behalf for thy name's sake; because thy steadfast love is good, deliver me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.22",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 22,
      "referenceLabel": "Psalms 109:22",
      "text": "For I am poor and needy, and my heart is stricken within me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.23",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 23,
      "referenceLabel": "Psalms 109:23",
      "text": "I am gone, like a shadow at evening; I am shaken off like a locust.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.24",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 24,
      "referenceLabel": "Psalms 109:24",
      "text": "My knees are weak through fasting; my body has become gaunt.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.25",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 25,
      "referenceLabel": "Psalms 109:25",
      "text": "I am an object of scorn to my accusers; when they see me, they wag their heads.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.26",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 26,
      "referenceLabel": "Psalms 109:26",
      "text": "Help me, O Lord my God! Save me according to thy steadfast love!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.27",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 27,
      "referenceLabel": "Psalms 109:27",
      "text": "Let them know that this is thy hand; thou, O Lord, hast done it!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.28",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 28,
      "referenceLabel": "Psalms 109:28",
      "text": "Let them curse, but do thou bless! Let my assailants be put to shame; may thy servant be glad!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.29",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 29,
      "referenceLabel": "Psalms 109:29",
      "text": "May my accusers be clothed with dishonor; may they be wrapped in their own shame as in a mantle!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.30",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 30,
      "referenceLabel": "Psalms 109:30",
      "text": "With my mouth I will give great thanks to the Lord; I will praise him in the midst of the throng.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.109.31",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 109,
      "verseNumber": 31,
      "referenceLabel": "Psalms 109:31",
      "text": "For he stands at the right hand of the needy, to save him from those who condemn him to death.",
      "paragraphStart": false
    }
  ]
}
