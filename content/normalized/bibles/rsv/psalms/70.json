{
  "chapter": {
    "id": "rsv:psalms.70",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 70,
    "referenceLabel": "Psalms 70",
    "summary": "Source text for Psalms 70 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.70.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 1,
      "referenceLabel": "Psalms 70:1",
      "text": "Be pleased, O God, to deliver me! O Lord, make haste to help me!",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.70.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 2,
      "referenceLabel": "Psalms 70:2",
      "text": "Let them be put to shame and confusion who seek my life! Let them be turned back and brought to dishonor who desire my hurt!",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.70.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 3,
      "referenceLabel": "Psalms 70:3",
      "text": "Let them be appalled because of their shame who say, “Aha, Aha!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.70.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 4,
      "referenceLabel": "Psalms 70:4",
      "text": "May all who seek thee rejoice and be glad in thee! May those who love thy salvation say evermore, “God is great!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.70.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 70,
      "verseNumber": 5,
      "referenceLabel": "Psalms 70:5",
      "text": "But I am poor and needy; hasten to me, O God! Thou art my help and my deliverer; O Lord, do not tarry!",
      "paragraphStart": false
    }
  ]
}
