{
  "chapter": {
    "id": "rsv:psalms.3",
    "translationId": "rsv",
    "bookSlug": "psalms",
    "chapterNumber": 3,
    "referenceLabel": "Psalms 3",
    "summary": "Source text for Psalms 3 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:psalms.3.1",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Psalms 3:1",
      "text": "O Lord, how many are my foes! Many are rising against me;",
      "paragraphStart": true
    },
    {
      "id": "rsv:psalms.3.2",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Psalms 3:2",
      "text": "many are saying of me, there is no help for him in God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.3.3",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Psalms 3:3",
      "text": "But thou, O Lord, art a shield about me, my glory, and the lifter of my head.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.3.4",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Psalms 3:4",
      "text": "I cry aloud to the Lord, and he answers me from his holy hill.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.3.5",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Psalms 3:5",
      "text": "I lie down and sleep; I wake again, for the Lord sustains me.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.3.6",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Psalms 3:6",
      "text": "I am not afraid of ten thousands of people who have set themselves against me round about.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.3.7",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Psalms 3:7",
      "text": "Arise, O Lord! Deliver me, O my God! For thou dost smite all my enemies on the cheek, thou dost break the teeth of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:psalms.3.8",
      "translationId": "rsv",
      "bookSlug": "psalms",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Psalms 3:8",
      "text": "Deliverance belongs to the Lord; thy blessing be upon thy people!",
      "paragraphStart": false
    }
  ]
}
