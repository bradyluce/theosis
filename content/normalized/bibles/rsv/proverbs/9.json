{
  "chapter": {
    "id": "rsv:proverbs.9",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 9,
    "referenceLabel": "Proverbs 9",
    "summary": "Source text for Proverbs 9 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.9.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 9:1",
      "text": "Wisdom has built her house, she has set up her seven pillars.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.9.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 9:2",
      "text": "She has slaughtered her beasts, she has mixed her wine, she has also set her table.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 9:3",
      "text": "She has sent out her maids to call from the highest places in the town,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 9:4",
      "text": "“Whoever is simple, let him turn in here!” To him who is without sense she says,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 9:5",
      "text": "“Come, eat of my bread and drink of the wine I have mixed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 9:6",
      "text": "Leave simpleness, and live, and walk in the way of insight.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 9:7",
      "text": "He who corrects a scoffer gets himself abuse, and he who reproves a wicked man incurs injury.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 9:8",
      "text": "Do not reprove a scoffer, or he will hate you; reprove a wise man, and he will love you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 9:9",
      "text": "Give instruction to a wise man, and he will be still wiser; teach a righteous man and he will increase in learning.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 9:10",
      "text": "The fear of the Lord is the beginning of wisdom, and the knowledge of the Holy One is insight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 9:11",
      "text": "For by me your days will be multiplied, and years will be added to your life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 9:12",
      "text": "If you are wise, you are wise for yourself; if you scoff, you alone will bear it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 9:13",
      "text": "A foolish woman is noisy; she is wanton and knows no shame.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 9:14",
      "text": "She sits at the door of her house, she takes a seat on the high places of the town,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 9:15",
      "text": "calling to those who pass by, who are going straight on their way,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 9:16",
      "text": "“Whoever is simple, let him turn in here!” And to him who is without sense she says,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 9:17",
      "text": "“Stolen water is sweet, and bread eaten in secret is pleasant.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.9.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 9:18",
      "text": "But he does not know that the dead are there, that her guests are in the depths of Sheol.",
      "paragraphStart": false
    }
  ]
}
