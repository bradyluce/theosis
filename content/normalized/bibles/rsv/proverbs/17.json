{
  "chapter": {
    "id": "rsv:proverbs.17",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 17,
    "referenceLabel": "Proverbs 17",
    "summary": "Source text for Proverbs 17 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.17.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 17:1",
      "text": "Better is a dry morsel with quiet than a house full of feasting with strife.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.17.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 17:2",
      "text": "A slave who deals wisely will rule over a son who acts shamefully, and will share the inheritance as one of the brothers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 17:3",
      "text": "The crucible is for silver, and the furnace is for gold, and the Lord tries hearts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 17:4",
      "text": "An evildoer listens to wicked lips; and a liar gives heed to a mischievous tongue.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 17:5",
      "text": "He who mocks the poor insults his Maker; he who is glad at calamity will not go unpunished.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 17:6",
      "text": "Grandchildren are the crown of the aged, and the glory of sons is their fathers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 17:7",
      "text": "Fine speech is not becoming to a fool; still less is false speech to a prince.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 17:8",
      "text": "A bribe is like a magic stone in the eyes of him who gives it; wherever he turns he prospers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 17:9",
      "text": "He who forgives an offense seeks love, but he who repeats a matter alienates a friend.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 17:10",
      "text": "A rebuke goes deeper into a man of understanding than a hundred blows into a fool.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 17:11",
      "text": "An evil man seeks only rebellion, and a cruel messenger will be sent against him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 17:12",
      "text": "Let a man meet a she-bear robbed of her cubs, rather than a fool in his folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 17:13",
      "text": "If a man returns evil for good, evil will not depart from his house.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 17:14",
      "text": "The beginning of strife is like letting out water; so quit before the quarrel breaks out.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 17:15",
      "text": "He who justifies the wicked and he who condemns the righteous are both alike an abomination to the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 17:16",
      "text": "Why should a fool have a price in his hand to buy wisdom, when he has no mind?",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 17:17",
      "text": "A friend loves at all times, and a brother is born for adversity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 17:18",
      "text": "A man without sense gives a pledge, and becomes surety in the presence of his neighbor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 17:19",
      "text": "He who loves transgression loves strife; he who makes his door high seeks destruction.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 17:20",
      "text": "A man of crooked mind does not prosper, and one with a perverse tongue falls into calamity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 17:21",
      "text": "A stupid son is a grief to a father; and the father of a fool has no joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 17:22",
      "text": "A cheerful heart is a good medicine, but a downcast spirit dries up the bones.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 17:23",
      "text": "A wicked man accepts a bribe from the bosom to pervert the ways of justice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 17:24",
      "text": "A man of understanding sets his face toward wisdom, but the eyes of a fool are on the ends of the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 17:25",
      "text": "A foolish son is a grief to his father and bitterness to her who bore him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 17:26",
      "text": "To impose a fine on a righteous man is not good; to flog noble men is wrong.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 17:27",
      "text": "He who restrains his words has knowledge, and he who has a cool spirit is a man of understanding.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.17.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 17,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 17:28",
      "text": "Even a fool who keeps silent is considered wise; when he closes his lips, he is deemed intelligent.",
      "paragraphStart": false
    }
  ]
}
