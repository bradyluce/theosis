{
  "chapter": {
    "id": "rsv:proverbs.10",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 10,
    "referenceLabel": "Proverbs 10",
    "summary": "Source text for Proverbs 10 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.10.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 10:1",
      "text": "The proverbs of Solomon. A wise son makes a glad father, but a foolish son is a sorrow to his mother.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.10.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 10:2",
      "text": "Treasures gained by wickedness do not profit, but righteousness delivers from death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 10:3",
      "text": "The Lord does not let the righteous go hungry, but he thwarts the craving of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 10:4",
      "text": "A slack hand causes poverty, but the hand of the diligent makes rich.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 10:5",
      "text": "A son who gathers in summer is prudent, but a son who sleeps in harvest brings shame.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 10:6",
      "text": "Blessings are on the head of the righteous, but the mouth of the wicked conceals violence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 10:7",
      "text": "The memory of the righteous is a blessing, but the name of the wicked will rot.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 10:8",
      "text": "The wise of heart will heed commandments, but a prating fool will come to ruin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 10:9",
      "text": "He who walks in integrity walks securely, but he who perverts his ways will be found out.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 10:10",
      "text": "He who winks the eye causes trouble, but he who boldly reproves makes peace.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 10:11",
      "text": "The mouth of the righteous is a fountain of life, but the mouth of the wicked conceals violence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 10:12",
      "text": "Hatred stirs up strife, but love covers all offenses.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 10:13",
      "text": "On the lips of him who has understanding wisdom is found, but a rod is for the back of him who lacks sense.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 10:14",
      "text": "Wise men lay up knowledge, but the babbling of a fool brings ruin near.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 10:15",
      "text": "A rich man's wealth is his strong city; the poverty of the poor is their ruin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 10:16",
      "text": "The wage of the righteous leads to life, the gain of the wicked to sin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 10:17",
      "text": "He who heeds instruction is on the path to life, but he who rejects reproof goes astray.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 10:18",
      "text": "He who conceals hatred has lying lips, and he who utters slander is a fool.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 10:19",
      "text": "When words are many, transgression is not lacking, but he who restrains his lips is prudent.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 10:20",
      "text": "The tongue of the righteous is choice silver; the mind of the wicked is of little worth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 10:21",
      "text": "The lips of the righteous feed many, but fools die for lack of sense.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 10:22",
      "text": "The blessing of the Lord makes rich, and he adds no sorrow with it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 10:23",
      "text": "It is like sport to a fool to do wrong, but wise conduct is pleasure to a man of understanding.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 10:24",
      "text": "What the wicked dreads will come upon him, but the desire of the righteous will be granted.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 10:25",
      "text": "When the tempest passes, the wicked is no more, but the righteous is established for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 10:26",
      "text": "Like vinegar to the teeth, and smoke to the eyes, so is the sluggard to those who send him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 10:27",
      "text": "The fear of the Lord prolongs life, but the years of the wicked will be short.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 10:28",
      "text": "The hope of the righteous ends in gladness, but the expectation of the wicked comes to naught.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.29",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 10:29",
      "text": "The Lord is a stronghold to him whose way is upright, but destruction to evildoers.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.30",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 10:30",
      "text": "The righteous will never be removed, but the wicked will not dwell in the land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.31",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 10:31",
      "text": "The mouth of the righteous brings forth wisdom, but the perverse tongue will be cut off.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.10.32",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 10:32",
      "text": "The lips of the righteous know what is acceptable, but the mouth of the wicked, what is perverse.",
      "paragraphStart": false
    }
  ]
}
