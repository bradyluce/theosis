{
  "chapter": {
    "id": "rsv:proverbs.15",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 15,
    "referenceLabel": "Proverbs 15",
    "summary": "Source text for Proverbs 15 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.15.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 15:1",
      "text": "A soft answer turns away wrath, but a harsh word stirs up anger.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.15.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 15:2",
      "text": "The tongue of the wise dispenses knowledge, but the mouths of fools pour out folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 15:3",
      "text": "The eyes of the Lord are in every place, keeping watch on the evil and the good.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 15:4",
      "text": "A gentle tongue is a tree of life, but perverseness in it breaks the spirit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 15:5",
      "text": "A fool despises his father's instruction, but he who heeds admonition is prudent.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 15:6",
      "text": "In the house of the righteous there is much treasure, but trouble befalls the income of the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 15:7",
      "text": "The lips of the wise spread knowledge; not so the minds of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 15:8",
      "text": "The sacrifice of the wicked is an abomination to the Lord, but the prayer of the upright is his delight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 15:9",
      "text": "The way of the wicked is an abomination to the Lord, but he loves him who pursues righteousness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 15:10",
      "text": "There is severe discipline for him who forsakes the way; he who hates reproof will die.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 15:11",
      "text": "Sheol and Abaddon lie open before the Lord how much more the hearts of men!",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 15:12",
      "text": "A scoffer does not like to be reproved; he will not go to the wise.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 15:13",
      "text": "A glad heart makes a cheerful countenance, but by sorrow of heart the spirit is broken.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 15:14",
      "text": "The mind of him who has understanding seeks knowledge, but the mouths of fools feed on folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 15:15",
      "text": "All the days of the afflicted are evil, but a cheerful heart has a continual feast.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 15:16",
      "text": "Better is a little with the fear of the Lord than great treasure and trouble with it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 15:17",
      "text": "Better is a dinner of herbs where love is than a fatted ox and hatred with it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 15:18",
      "text": "A hot-tempered man stirs up strife, but he who is slow to anger quiets contention.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 15:19",
      "text": "The way of a sluggard is overgrown with thorns, but the path of the upright is a level highway.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 15:20",
      "text": "A wise son makes a glad father, but a foolish man despises his mother.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 15:21",
      "text": "Folly is a joy to him who has no sense, but a man of understanding walks aright.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 15:22",
      "text": "Without counsel plans go wrong, but with many advisers they succeed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 15:23",
      "text": "To make an apt answer is a joy to a man, and a word in season, how good it is!",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 15:24",
      "text": "The wise man's path leads upward to life, that he may avoid Sheol beneath.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 15:25",
      "text": "The Lord tears down the house of the proud, but maintains the widow's boundaries.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 15:26",
      "text": "The thoughts of the wicked are an abomination to the Lord, the words of the pure are pleasing to him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 15:27",
      "text": "He who is greedy for unjust gain makes trouble for his household, but he who hates bribes will live.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 15:28",
      "text": "The mind of the righteous ponders how to answer, but the mouth of the wicked pours out evil things.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.29",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 15:29",
      "text": "The Lord is far from the wicked, but he hears the prayer of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.30",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 15:30",
      "text": "The light of the eyes rejoices the heart, and good news refreshes the bones.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.31",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 15:31",
      "text": "He whose ear heeds wholesome admonition will abide among the wise.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.32",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 15:32",
      "text": "He who ignores instruction despises himself, but he who heeds admonition gains understanding.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.15.33",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 15:33",
      "text": "The fear of the Lord is instruction in wisdom, and humility goes before honor.",
      "paragraphStart": false
    }
  ]
}
