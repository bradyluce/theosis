{
  "chapter": {
    "id": "rsv:proverbs.28",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 28,
    "referenceLabel": "Proverbs 28",
    "summary": "Source text for Proverbs 28 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.28.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 28:1",
      "text": "The wicked flee when no one pursues, but the righteous are bold as a lion.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.28.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 28:2",
      "text": "When a land transgresses it has many rulers; but with men of understanding and knowledge its stability will long continue.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 28:3",
      "text": "A poor man who oppresses the poor is a beating rain that leaves no food.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 28:4",
      "text": "Those who forsake the law praise the wicked, but those who keep the law strive against them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 28:5",
      "text": "Evil men do not understand justice, but those who seek the Lord understand it completely.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 28:6",
      "text": "Better is a poor man who walks in his integrity than a rich man who is perverse in his ways.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 28:7",
      "text": "He who keeps the law is a wise son, but a companion of gluttons shames his father.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 28:8",
      "text": "He who augments his wealth by interest and increase gathers it for him who is kind to the poor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 28:9",
      "text": "If one turns away his ear from hearing the law, even his prayer is an abomination.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 28:10",
      "text": "He who misleads the upright into an evil way will fall into his own pit; but the blameless will have a goodly inheritance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 28:11",
      "text": "A rich man is wise in his own eyes, but a poor man who has understanding will find him out.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 28:12",
      "text": "When the righteous triumph, there is great glory; but when the wicked rise, men hide themselves.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 28:13",
      "text": "He who conceals his transgressions will not prosper, but he who confesses and forsakes them will obtain mercy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 28:14",
      "text": "Blessed is the man who fears the Lord always; but he who hardens his heart will fall into calamity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 28:15",
      "text": "Like a roaring lion or a charging bear is a wicked ruler over a poor people.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 28:16",
      "text": "A ruler who lacks understanding is a cruel oppressor; but he who hates unjust gain will prolong his days.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 28:17",
      "text": "If a man is burdened with the blood of another, let him be a fugitive until death; let no one help him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 28:18",
      "text": "He who walks in integrity will be delivered, but he who is perverse in his ways will fall into a pit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 28:19",
      "text": "He who tills his land will have plenty of bread, but he who follows worthless pursuits will have plenty of poverty.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 28:20",
      "text": "A faithful man will abound with blessings, but he who hastens to be rich will not go unpunished.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 28:21",
      "text": "To show partiality is not good; but for a piece of bread a man will do wrong.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 28:22",
      "text": "A miserly man hastens after wealth, and does not know that want will come upon him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 28:23",
      "text": "He who rebukes a man will afterward find more favor than he who flatters with his tongue.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 28:24",
      "text": "He who robs his father or his mother and says, “That is no transgression,” is the companion of a man who destroys.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 28:25",
      "text": "A greedy man stirs up strife, but he who trusts in the Lord will be enriched.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 28:26",
      "text": "He who trusts in his own mind is a fool; but he who walks in wisdom will be delivered.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 28:27",
      "text": "He who gives to the poor will not want, but he who hides his eyes will get many a curse.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.28.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 28,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 28:28",
      "text": "When the wicked rise, men hide themselves, but when they perish, the righteous increase.",
      "paragraphStart": false
    }
  ]
}
