{
  "chapter": {
    "id": "rsv:proverbs.13",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 13,
    "referenceLabel": "Proverbs 13",
    "summary": "Source text for Proverbs 13 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.13.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 13:1",
      "text": "A wise son hears his father's instruction, but a scoffer does not listen to rebuke.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.13.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 13:2",
      "text": "From the fruit of his mouth a good man eats good, but the desire of the treacherous is for violence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 13:3",
      "text": "He who guards his mouth preserves his life; he who opens wide his lips comes to ruin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 13:4",
      "text": "The soul of the sluggard craves, and gets nothing, while the soul of the diligent is richly supplied.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 13:5",
      "text": "A righteous man hates falsehood, but a wicked man acts shamefully and disgracefully.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 13:6",
      "text": "Righteousness guards him whose way is upright, but sin overthrows the wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 13:7",
      "text": "One man pretends to be rich, yet has nothing; another pretends to be poor, yet has great wealth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 13:8",
      "text": "The ransom of a man's life is his wealth, but a poor man has no means of redemption.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 13:9",
      "text": "The light of the righteous rejoices, but the lamp of the wicked will be put out.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 13:10",
      "text": "By insolence the heedless make strife, but with those who take advice is wisdom.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 13:11",
      "text": "Wealth hastily gotten will dwindle, but he who gathers little by little will increase it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 13:12",
      "text": "Hope deferred makes the heart sick, but a desire fulfilled is a tree of life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 13:13",
      "text": "He who despises the word brings destruction on himself, but he who respects the commandment will be rewarded.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 13:14",
      "text": "The teaching of the wise is a fountain of life, that one may avoid the snares of death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 13:15",
      "text": "Good sense wins favor, but the way of the faithless is their ruin.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 13:16",
      "text": "In everything a prudent man acts with knowledge, but a fool flaunts his folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 13:17",
      "text": "A bad messenger plunges men into trouble, but a faithful envoy brings healing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 13:18",
      "text": "Poverty and disgrace come to him who ignores instruction, but he who heeds reproof is honored.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 13:19",
      "text": "A desire fulfilled is sweet to the soul; but to turn away from evil is an abomination to fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 13:20",
      "text": "He who walks with wise men becomes wise, but the companion of fools will suffer harm.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 13:21",
      "text": "Misfortune pursues sinners, but prosperity rewards the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 13:22",
      "text": "A good man leaves an inheritance to his children's children, but the sinner's wealth is laid up for the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 13:23",
      "text": "The fallow ground of the poor yields much food, but it is swept away through injustice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 13:24",
      "text": "He who spares the rod hates his son, but he who loves him is diligent to discipline him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.13.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 13:25",
      "text": "The righteous has enough to satisfy his appetite, but the belly of the wicked suffers want.",
      "paragraphStart": false
    }
  ]
}
