{
  "chapter": {
    "id": "rsv:proverbs.22",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 22,
    "referenceLabel": "Proverbs 22",
    "summary": "Source text for Proverbs 22 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.22.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 22:1",
      "text": "A good name is to be chosen rather than great riches, and favor is better than silver or gold.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.22.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 22:2",
      "text": "The rich and the poor meet together; the Lord is the maker of them all.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 22:3",
      "text": "A prudent man sees danger and hides himself; but the simple go on, and suffer for it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 22:4",
      "text": "The reward for humility and fear of the Lord is riches and honor and life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 22:5",
      "text": "Thorns and snares are in the way of the perverse; he who guards himself will keep far from them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 22:6",
      "text": "Train up a child in the way he should go, and when he is old he will not depart from it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 22:7",
      "text": "The rich rules over the poor, and the borrower is the slave of the lender.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 22:8",
      "text": "He who sows injustice will reap calamity, and the rod of his fury will fail.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 22:9",
      "text": "He who has a bountiful eye will be blessed, for he shares his bread with the poor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 22:10",
      "text": "Drive out a scoffer, and strife will go out, and quarreling and abuse will cease.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 22:11",
      "text": "He who loves purity of heart, and whose speech is gracious, will have the king as his friend.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 22:12",
      "text": "The eyes of the Lord keep watch over knowledge, but he overthrows the words of the faithless.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 22:13",
      "text": "The sluggard says, “There is a lion outside! I shall be slain in the streets!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 22:14",
      "text": "The mouth of a loose woman is a deep pit; he with whom the Lord is angry will fall into it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 22:15",
      "text": "Folly is bound up in the heart of a child, but the rod of discipline drives it far from him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 22:16",
      "text": "He who oppresses the poor to increase his own wealth, or gives to the rich, will only come to want.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 22:17",
      "text": "Incline your ear, and hear the words of the wise, and apply your mind to my knowledge;",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 22:18",
      "text": "for it will be pleasant if you keep them within you, if all of them are ready on your lips.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 22:19",
      "text": "That your trust may be in the Lord, I have made them known to you today, even to you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 22:20",
      "text": "Have I not written for you thirty sayings of admonition and knowledge,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 22:21",
      "text": "to show you what is right and true, that you may give a true answer to those who sent you?",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 22:22",
      "text": "Do not rob the poor, because he is poor, or crush the afflicted at the gate;",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 22:23",
      "text": "for the Lord will plead their cause and despoil of life those who despoil them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 22:24",
      "text": "Make no friendship with a man given to anger, nor go with a wrathful man,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 22:25",
      "text": "lest you learn his ways and entangle yourself in a snare.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 22:26",
      "text": "Be not one of those who give pledges, who become surety for debts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 22:27",
      "text": "If you have nothing with which to pay, why should your bed be taken from under you?",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 22:28",
      "text": "Remove not the ancient landmark which your fathers have set.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.22.29",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 22,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 22:29",
      "text": "Do you see a man skilful in his work? he will stand before kings; he will not stand before obscure men.",
      "paragraphStart": false
    }
  ]
}
