{
  "chapter": {
    "id": "rsv:proverbs.26",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 26,
    "referenceLabel": "Proverbs 26",
    "summary": "Source text for Proverbs 26 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.26.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 26:1",
      "text": "Like snow in summer or rain in harvest, so honor is not fitting for a fool.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.26.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 26:2",
      "text": "Like a sparrow in its flitting, like a swallow in its flying, a curse that is causeless does not alight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 26:3",
      "text": "A whip for the horse, a bridle for the ass, and a rod for the back of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 26:4",
      "text": "Answer not a fool according to his folly, lest you be like him yourself.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 26:5",
      "text": "Answer a fool according to his folly, lest he be wise in his own eyes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 26:6",
      "text": "He who sends a message by the hand of a fool cuts off his own feet and drinks violence.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 26:7",
      "text": "Like a lame man's legs, which hang useless, is a proverb in the mouth of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 26:8",
      "text": "Like one who binds the stone in the sling is he who gives honor to a fool.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 26:9",
      "text": "Like a thorn that goes up into the hand of a drunkard is a proverb in the mouth of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 26:10",
      "text": "Like an archer who wounds everybody is he who hires a passing fool or drunkard.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 26:11",
      "text": "Like a dog that returns to his vomit is a fool that repeats his folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 26:12",
      "text": "Do you see a man who is wise in his own eyes? There is more hope for a fool than for him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 26:13",
      "text": "The sluggard says, “There is a lion in the road! There is a lion in the streets!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 26:14",
      "text": "As a door turns on its hinges, so does a sluggard on his bed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 26:15",
      "text": "The sluggard buries his hand in the dish; it wears him out to bring it back to his mouth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 26:16",
      "text": "The sluggard is wiser in his own eyes than seven men who can answer discreetly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 26:17",
      "text": "He who meddles in a quarrel not his own is like one who takes a passing dog by the ears.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 26:18",
      "text": "Like a madman who throws firebrands, arrows, and death,",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 26:19",
      "text": "is the man who deceives his neighbor and says, “I am only joking!”",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 26:20",
      "text": "For lack of wood the fire goes out; and where there is no whisperer, quarreling ceases.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 26:21",
      "text": "As charcoal to hot embers and wood to fire, so is a quarrelsome man for kindling strife.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 26:22",
      "text": "The words of a whisperer are like delicious morsels; they go down into the inner parts of the body.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 26:23",
      "text": "Like the glaze covering an earthen vessel are smooth lips with an evil heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 26:24",
      "text": "He who hates, dissembles with his lips and harbors deceit in his heart;",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 26:25",
      "text": "when he speaks graciously, believe him not, for there are seven abominations in his heart;",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 26:26",
      "text": "though his hatred be covered with guile, his wickedness will be exposed in the assembly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 26:27",
      "text": "He who digs a pit will fall into it, and a stone will come back upon him who starts it rolling.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.26.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 26,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 26:28",
      "text": "A lying tongue hates its victims, and a flattering mouth works ruin.",
      "paragraphStart": false
    }
  ]
}
