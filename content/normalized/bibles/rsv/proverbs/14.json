{
  "chapter": {
    "id": "rsv:proverbs.14",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 14,
    "referenceLabel": "Proverbs 14",
    "summary": "Source text for Proverbs 14 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.14.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 14:1",
      "text": "Wisdom builds her house, but folly with her own hands tears it down.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.14.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 14:2",
      "text": "He who walks in uprightness fears the Lord, but he who is devious in his ways despises him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 14:3",
      "text": "The talk of a fool is a rod for his back, but the lips of the wise will preserve them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 14:4",
      "text": "Where there are no oxen, there is no grain; but abundant crops come by the strength of the ox.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 14:5",
      "text": "A faithful witness does not lie, but a false witness breathes out lies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 14:6",
      "text": "A scoffer seeks wisdom in vain, but knowledge is easy for a man of understanding.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 14:7",
      "text": "Leave the presence of a fool, for there you do not meet words of knowledge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 14:8",
      "text": "The wisdom of a prudent man is to discern his way, but the folly of fools is deceiving.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 14:9",
      "text": "God scorns the wicked, but the upright enjoy his favor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 14:10",
      "text": "The heart knows its own bitterness, and no stranger shares its joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 14:11",
      "text": "The house of the wicked will be destroyed, but the tent of the upright will flourish.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 14:12",
      "text": "There is a way which seems right to a man, but its end is the way to death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 14:13",
      "text": "Even in laughter the heart is sad, and the end of joy is grief.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 14:14",
      "text": "A perverse man will be filled with the fruit of his ways, and a good man with the fruit of his deeds.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 14:15",
      "text": "The simple believes everything, but the prudent looks where he is going.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 14:16",
      "text": "A wise man is cautious and turns away from evil, but a fool throws off restraint and is careless.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 14:17",
      "text": "A man of quick temper acts foolishly, but a man of discretion is patient.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 14:18",
      "text": "The simple acquire folly, but the prudent are crowned with knowledge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 14:19",
      "text": "The evil bow down before the good, the wicked at the gates of the righteous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 14:20",
      "text": "The poor is disliked even by his neighbor, but the rich has many friends.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 14:21",
      "text": "He who despises his neighbor is a sinner, but happy is he who is kind to the poor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 14:22",
      "text": "Do they not err that devise evil? Those who devise good meet loyalty and faithfulness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 14:23",
      "text": "In all toil there is profit, but mere talk tends only to want.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 14:24",
      "text": "The crown of the wise is their wisdom, but folly is the garland of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 14:25",
      "text": "A truthful witness saves lives, but one who utters lies is a betrayer.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 14:26",
      "text": "In the fear of the Lord one has strong confidence, and his children will have a refuge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 14:27",
      "text": "The fear of the Lord is a fountain of life, that one may avoid the snares of death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 14:28",
      "text": "In a multitude of people is the glory of a king, but without people a prince is ruined.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.29",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 14:29",
      "text": "He who is slow to anger has great understanding, but he who has a hasty temper exalts folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.30",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 14:30",
      "text": "A tranquil mind gives life to the flesh, but passion makes the bones rot.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.31",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 14:31",
      "text": "He who oppresses a poor man insults his Maker, but he who is kind to the needy honors him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.32",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 14:32",
      "text": "The wicked is overthrown through his evil-doing, but the righteous finds refuge through his integrity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.33",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 14:33",
      "text": "Wisdom abides in the mind of a man of understanding, but it is not known in the heart of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.34",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Proverbs 14:34",
      "text": "Righteousness exalts a nation, but sin is a reproach to any people.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.14.35",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Proverbs 14:35",
      "text": "A servant who deals wisely has the king's favor, but his wrath falls on one who acts shamefully.",
      "paragraphStart": false
    }
  ]
}
