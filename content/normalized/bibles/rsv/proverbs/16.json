{
  "chapter": {
    "id": "rsv:proverbs.16",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 16,
    "referenceLabel": "Proverbs 16",
    "summary": "Source text for Proverbs 16 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.16.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 16:1",
      "text": "The plans of the mind belong to man, but the answer of the tongue is from the Lord.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.16.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 16:2",
      "text": "All the ways of a man are pure in his own eyes, but the Lord weighs the spirit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 16:3",
      "text": "Commit your work to the Lord, and your plans will be established.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 16:4",
      "text": "The Lord has made everything for its purpose, even the wicked for the day of trouble.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 16:5",
      "text": "Every one who is arrogant is an abomination to the Lord; be assured, he will not go unpunished.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 16:6",
      "text": "By loyalty and faithfulness iniquity is atoned for, and by the fear of the Lord a man avoids evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 16:7",
      "text": "When a man's ways please the Lord, he makes even his enemies to be at peace with him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 16:8",
      "text": "Better is a little with righteousness than great revenues with injustice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 16:9",
      "text": "A man's mind plans his way, but the Lord directs his steps.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 16:10",
      "text": "Inspired decisions are on the lips of a king; his mouth does not sin in judgment.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 16:11",
      "text": "A just balance and scales are the Lord 's; all the weights in the bag are his work.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 16:12",
      "text": "It is an abomination to kings to do evil, for the throne is established by righteousness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 16:13",
      "text": "Righteous lips are the delight of a king, and he loves him who speaks what is right.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 16:14",
      "text": "A king's wrath is a messenger of death, and a wise man will appease it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 16:15",
      "text": "In the light of a king's face there is life, and his favor is like the clouds that bring the spring rain.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 16:16",
      "text": "To get wisdom is better than gold; to get understanding is to be chosen rather than silver.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 16:17",
      "text": "The highway of the upright turns aside from evil; he who guards his way preserves his life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 16:18",
      "text": "Pride goes before destruction, and a haughty spirit before a fall.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 16:19",
      "text": "It is better to be of a lowly spirit with the poor than to divide the spoil with the proud.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 16:20",
      "text": "He who gives heed to the word will prosper, and happy is he who trusts in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 16:21",
      "text": "The wise of heart is called a man of discernment, and pleasant speech increases persuasiveness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 16:22",
      "text": "Wisdom is a fountain of life to him who has it, but folly is the chastisement of fools.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 16:23",
      "text": "The mind of the wise makes his speech judicious, and adds persuasiveness to his lips.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 16:24",
      "text": "Pleasant words are like a honeycomb, sweetness to the soul and health to the body.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 16:25",
      "text": "There is a way which seems right to a man, but its end is the way to death.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 16:26",
      "text": "A worker's appetite works for him; his mouth urges him on.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 16:27",
      "text": "A worthless man plots evil, and his speech is like a scorching fire.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 16:28",
      "text": "A perverse man spreads strife, and a whisperer separates close friends.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.29",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 16:29",
      "text": "A man of violence entices his neighbor and leads him in a way that is not good.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.30",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 30,
      "referenceLabel": "Proverbs 16:30",
      "text": "He who winks his eyes plans perverse things, he who compresses his lips brings evil to pass.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.31",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 31,
      "referenceLabel": "Proverbs 16:31",
      "text": "A hoary head is a crown of glory; it is gained in a righteous life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.32",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 32,
      "referenceLabel": "Proverbs 16:32",
      "text": "He who is slow to anger is better than the mighty, and he who rules his spirit than he who takes a city.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.16.33",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 16,
      "verseNumber": 33,
      "referenceLabel": "Proverbs 16:33",
      "text": "The lot is cast into the lap, but the decision is wholly from the Lord.",
      "paragraphStart": false
    }
  ]
}
