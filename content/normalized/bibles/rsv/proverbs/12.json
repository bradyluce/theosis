{
  "chapter": {
    "id": "rsv:proverbs.12",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 12,
    "referenceLabel": "Proverbs 12",
    "summary": "Source text for Proverbs 12 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.12.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 12:1",
      "text": "Whoever loves discipline loves knowledge, but he who hates reproof is stupid.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.12.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 12:2",
      "text": "A good man obtains favor from the Lord, but a man of evil devices he condemns.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 12:3",
      "text": "A man is not established by wickedness, but the root of the righteous will never be moved.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 12:4",
      "text": "A good wife is the crown of her husband, but she who brings shame is like rottenness in his bones.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 12:5",
      "text": "The thoughts of the righteous are just; the counsels of the wicked are treacherous.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 12:6",
      "text": "The words of the wicked lie in wait for blood, but the mouth of the upright delivers men.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 12:7",
      "text": "The wicked are overthrown and are no more, but the house of the righteous will stand.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 12:8",
      "text": "A man is commended according to his good sense, but one of perverse mind is despised.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 12:9",
      "text": "Better is a man of humble standing who works for himself than one who plays the great man but lacks bread.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 12:10",
      "text": "A righteous man has regard for the life of his beast, but the mercy of the wicked is cruel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 12:11",
      "text": "He who tills his land will have plenty of bread, but he who follows worthless pursuits has no sense.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 12:12",
      "text": "The strong tower of the wicked comes to ruin, but the root of the righteous stands firm.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 12:13",
      "text": "An evil man is ensnared by the transgression of his lips, but the righteous escapes from trouble.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 12:14",
      "text": "From the fruit of his words a man is satisfied with good, and the work of a man's hand comes back to him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 12:15",
      "text": "The way of a fool is right in his own eyes, but a wise man listens to advice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 12:16",
      "text": "The vexation of a fool is known at once, but the prudent man ignores an insult.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 12:17",
      "text": "He who speaks the truth gives honest evidence, but a false witness utters deceit.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 12:18",
      "text": "There is one whose rash words are like sword thrusts, but the tongue of the wise brings healing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 12:19",
      "text": "Truthful lips endure for ever, but a lying tongue is but for a moment.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 12:20",
      "text": "Deceit is in the heart of those who devise evil, but those who plan good have joy.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 12:21",
      "text": "No ill befalls the righteous, but the wicked are filled with trouble.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 12:22",
      "text": "Lying lips are an abomination to the Lord, but those who act faithfully are his delight.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 12:23",
      "text": "A prudent man conceals his knowledge, but fools proclaim their folly.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 12:24",
      "text": "The hand of the diligent will rule, while the slothful will be put to forced labor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 12:25",
      "text": "Anxiety in a man's heart weighs him down, but a good word makes him glad.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 12:26",
      "text": "A righteous man turns away from evil, but the way of the wicked leads them astray.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 12:27",
      "text": "A slothful man will not catch his prey, but the diligent man will get precious wealth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.12.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 12:28",
      "text": "In the path of righteousness is life, but the way of error leads to death.",
      "paragraphStart": false
    }
  ]
}
