{
  "chapter": {
    "id": "rsv:proverbs.29",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 29,
    "referenceLabel": "Proverbs 29",
    "summary": "Source text for Proverbs 29 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.29.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 29:1",
      "text": "He who is often reproved, yet stiffens his neck, will suddenly be broken beyond healing.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.29.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 29:2",
      "text": "When the righteous are in authority, the people rejoice; but when the wicked rule, the people groan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 29:3",
      "text": "He who loves wisdom makes his father glad, but one who keeps company with harlots squanders his substance.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 29:4",
      "text": "By justice a king gives stability to the land, but one who exacts gifts ruins it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 29:5",
      "text": "A man who flatters his neighbor spreads a net for his feet.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 29:6",
      "text": "An evil man is ensnared in his transgression, but a righteous man sings and rejoices.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 29:7",
      "text": "A righteous man knows the rights of the poor; a wicked man does not understand such knowledge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 29:8",
      "text": "Scoffers set a city aflame, but wise men turn away wrath.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 29:9",
      "text": "If a wise man has an argument with a fool, the fool only rages and laughs, and there is no quiet.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 29:10",
      "text": "Bloodthirsty men hate one who is blameless, and the wicked seek his life.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 29:11",
      "text": "A fool gives full vent to his anger, but a wise man quietly holds it back.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 29:12",
      "text": "If a ruler listens to falsehood, all his officials will be wicked.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 29:13",
      "text": "The poor man and the oppressor meet together; the Lord gives light to the eyes of both.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 29:14",
      "text": "If a king judges the poor with equity his throne will be established for ever.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 29:15",
      "text": "The rod and reproof give wisdom, but a child left to himself brings shame to his mother.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 29:16",
      "text": "When the wicked are in authority, transgression increases; but the righteous will look upon their downfall.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 29:17",
      "text": "Discipline your son, and he will give you rest; he will give delight to your heart.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 29:18",
      "text": "Where there is no prophecy the people cast off restraint, but blessed is he who keeps the law.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 29:19",
      "text": "By mere words a servant is not disciplined, for though he understands, he will not give heed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 29:20",
      "text": "Do you see a man who is hasty in his words? There is more hope for a fool than for him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 29:21",
      "text": "He who pampers his servant from childhood, will in the end find him his heir.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 29:22",
      "text": "A man of wrath stirs up strife, and a man given to anger causes much transgression.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 29:23",
      "text": "A man's pride will bring him low, but he who is lowly in spirit will obtain honor.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 29:24",
      "text": "The partner of a thief hates his own life; he hears the curse, but discloses nothing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 29:25",
      "text": "The fear of man lays a snare, but he who trusts in the Lord is safe.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 29:26",
      "text": "Many seek the favor of a ruler, but from the Lord a man gets justice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.29.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 29,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 29:27",
      "text": "An unjust man is an abomination to the righteous, but he whose way is straight is an abomination to the wicked.",
      "paragraphStart": false
    }
  ]
}
