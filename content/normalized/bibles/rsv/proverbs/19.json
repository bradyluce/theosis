{
  "chapter": {
    "id": "rsv:proverbs.19",
    "translationId": "rsv",
    "bookSlug": "proverbs",
    "chapterNumber": 19,
    "referenceLabel": "Proverbs 19",
    "summary": "Source text for Proverbs 19 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:proverbs.19.1",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Proverbs 19:1",
      "text": "Better is a poor man who walks in his integrity than a man who is perverse in speech, and is a fool.",
      "paragraphStart": true
    },
    {
      "id": "rsv:proverbs.19.2",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Proverbs 19:2",
      "text": "It is not good for a man to be without knowledge, and he who makes haste with his feet misses his way.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.3",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Proverbs 19:3",
      "text": "When a man's folly brings his way to ruin, his heart rages against the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.4",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Proverbs 19:4",
      "text": "Wealth brings many new friends, but a poor man is deserted by his friend.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.5",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Proverbs 19:5",
      "text": "A false witness will not go unpunished, and he who utters lies will not escape.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.6",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Proverbs 19:6",
      "text": "Many seek the favor of a generous man, and every one is a friend to a man who gives gifts.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.7",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Proverbs 19:7",
      "text": "All a poor man's brothers hate him; how much more do his friends go far from him! He pursues them with words, but does not have them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.8",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Proverbs 19:8",
      "text": "He who gets wisdom loves himself; he who keeps understanding will prosper.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.9",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Proverbs 19:9",
      "text": "A false witness will not go unpunished, and he who utters lies will perish.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.10",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Proverbs 19:10",
      "text": "It is not fitting for a fool to live in luxury, much less for a slave to rule over princes.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.11",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Proverbs 19:11",
      "text": "Good sense makes a man slow to anger, and it is his glory to overlook an offense.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.12",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Proverbs 19:12",
      "text": "A king's wrath is like the growling of a lion, but his favor is like dew upon the grass.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.13",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Proverbs 19:13",
      "text": "A foolish son is ruin to his father, and a wife's quarreling is a continual dripping of rain.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.14",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Proverbs 19:14",
      "text": "House and wealth are inherited from fathers, but a prudent wife is from the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.15",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Proverbs 19:15",
      "text": "Slothfulness casts into a deep sleep, and an idle person will suffer hunger.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.16",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Proverbs 19:16",
      "text": "He who keeps the commandment keeps his life; he who despises the word will die.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.17",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Proverbs 19:17",
      "text": "He who is kind to the poor lends to the Lord, and he will repay him for his deed.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.18",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Proverbs 19:18",
      "text": "Discipline your son while there is hope; do not set your heart on his destruction.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.19",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Proverbs 19:19",
      "text": "A man of great wrath will pay the penalty; for if you deliver him, you will only have to do it again.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.20",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Proverbs 19:20",
      "text": "Listen to advice and accept instruction, that you may gain wisdom for the future.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.21",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Proverbs 19:21",
      "text": "Many are the plans in the mind of a man, but it is the purpose of the Lord that will be established.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.22",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 22,
      "referenceLabel": "Proverbs 19:22",
      "text": "What is desired in a man is loyalty, and a poor man is better than a liar.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.23",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 23,
      "referenceLabel": "Proverbs 19:23",
      "text": "The fear of the Lord leads to life; and he who has it rests satisfied; he will not be visited by harm.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.24",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 24,
      "referenceLabel": "Proverbs 19:24",
      "text": "The sluggard buries his hand in the dish, and will not even bring it back to his mouth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.25",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 25,
      "referenceLabel": "Proverbs 19:25",
      "text": "Strike a scoffer, and the simple will learn prudence; reprove a man of understanding, and he will gain knowledge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.26",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 26,
      "referenceLabel": "Proverbs 19:26",
      "text": "He who does violence to his father and chases away his mother is a son who causes shame and brings reproach.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.27",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 27,
      "referenceLabel": "Proverbs 19:27",
      "text": "Cease, my son, to hear instruction only to stray from the words of knowledge.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.28",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 28,
      "referenceLabel": "Proverbs 19:28",
      "text": "A worthless witness mocks at justice, and the mouth of the wicked devours iniquity.",
      "paragraphStart": false
    },
    {
      "id": "rsv:proverbs.19.29",
      "translationId": "rsv",
      "bookSlug": "proverbs",
      "chapterNumber": 19,
      "verseNumber": 29,
      "referenceLabel": "Proverbs 19:29",
      "text": "Condemnation is ready for scoffers, and flogging for the backs of fools.",
      "paragraphStart": false
    }
  ]
}
