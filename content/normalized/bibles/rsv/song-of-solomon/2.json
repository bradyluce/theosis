{
  "chapter": {
    "id": "rsv:song-of-solomon.2",
    "translationId": "rsv",
    "bookSlug": "song-of-solomon",
    "chapterNumber": 2,
    "referenceLabel": "Song of Solomon 2",
    "summary": "Source text for Song of Solomon 2 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:song-of-solomon.2.1",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Song of Solomon 2:1",
      "text": "I am a rose of Sharon, a lily of the valleys.",
      "paragraphStart": true
    },
    {
      "id": "rsv:song-of-solomon.2.2",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Song of Solomon 2:2",
      "text": "As a lily among brambles, so is my love among maidens.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.3",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Song of Solomon 2:3",
      "text": "As an apple tree among the trees of the wood, so is my beloved among young men. With great delight I sat in his shadow, and his fruit was sweet to my taste,",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.4",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Song of Solomon 2:4",
      "text": "He brought me to the banqueting house, and his banner over me was love.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.5",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Song of Solomon 2:5",
      "text": "Sustain me with raisins, refresh me with apples; for I am sick with love.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.6",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Song of Solomon 2:6",
      "text": "O that his left hand were under my head, and that his right hand embraced me!",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.7",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Song of Solomon 2:7",
      "text": "I adjure you, O daughters of Jerusalem, by the gazelles or the hinds of the field, that you stir not up nor awaken love until it please.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.8",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Song of Solomon 2:8",
      "text": "The voice of my beloved! Behold, he comes, leaping upon the mountains, bounding over the hills.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.9",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Song of Solomon 2:9",
      "text": "My beloved is like a gazelle, or a young stag. Behold, there he stands behind our wall, gazing in at the windows, looking through the lattice.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.10",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Song of Solomon 2:10",
      "text": "My beloved speaks and says to me: “Arise, my love, my fair one, and come away;",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.11",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Song of Solomon 2:11",
      "text": "for lo, the winter is past, the rain is over and gone.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.12",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Song of Solomon 2:12",
      "text": "The flowers appear on the earth, the time of singing has come, and the voice of the turtledove is heard in our land.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.13",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Song of Solomon 2:13",
      "text": "The fig tree puts forth its figs, and the vines are in blossom; they give forth fragrance. Arise, my love, my fair one, and come away.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.14",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Song of Solomon 2:14",
      "text": "O my dove, in the clefts of the rock, in the covert of the cliff, let me see your face, let me hear your voice, for your voice is sweet, and your face is comely.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.15",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Song of Solomon 2:15",
      "text": "Catch us the foxes, the little foxes, that spoil the vineyards, for our vineyards are in blossom.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.16",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Song of Solomon 2:16",
      "text": "My beloved is mine and I am his, he pastures his flock among the lilies.",
      "paragraphStart": false
    },
    {
      "id": "rsv:song-of-solomon.2.17",
      "translationId": "rsv",
      "bookSlug": "song-of-solomon",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Song of Solomon 2:17",
      "text": "Until the day breathe and the shadows flee, turn, my beloved, be like a gazelle, or a young stag upon rugged mountains.",
      "paragraphStart": false
    }
  ]
}
