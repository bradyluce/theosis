{
  "chapter": {
    "id": "rsv:genesis.5",
    "translationId": "rsv",
    "bookSlug": "genesis",
    "chapterNumber": 5,
    "referenceLabel": "Genesis 5",
    "summary": "Source text for Genesis 5 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:genesis.5.1",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Genesis 5:1",
      "text": "This is the book of the generations of Adam. When God created man, he made him in the likeness of God.",
      "paragraphStart": true
    },
    {
      "id": "rsv:genesis.5.2",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Genesis 5:2",
      "text": "Male and female he created them, and he blessed them and named them Man when they were created.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.3",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Genesis 5:3",
      "text": "When Adam had lived a hundred and thirty years, he became the father of a son in his own likeness, after his image, and named him Seth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.4",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Genesis 5:4",
      "text": "The days of Adam after he became the father of Seth were eight hundred years; and he had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.5",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Genesis 5:5",
      "text": "Thus all the days that Adam lived were nine hundred and thirty years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.6",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Genesis 5:6",
      "text": "When Seth had lived a hundred and five years, he became the father of Enosh.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.7",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Genesis 5:7",
      "text": "Seth lived after the birth of Enosh eight hundred and seven years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.8",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Genesis 5:8",
      "text": "Thus all the days of Seth were nine hundred and twelve years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.9",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Genesis 5:9",
      "text": "When Enosh had lived ninety years, he became the father of Kenan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.10",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Genesis 5:10",
      "text": "Enosh lived after the birth of Kenan eight hundred and fifteen years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.11",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Genesis 5:11",
      "text": "Thus all the days of Enosh were nine hundred and five years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.12",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Genesis 5:12",
      "text": "When Kenan had lived seventy years, he became the father of Ma-halalel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.13",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Genesis 5:13",
      "text": "Kenan lived after the birth of Ma-halalel eight hundred and forty years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.14",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Genesis 5:14",
      "text": "Thus all the days of Kenan were nine hundred and ten years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.15",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Genesis 5:15",
      "text": "When Ma-halalel had lived sixty-five years, he became the father of Jared.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.16",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Genesis 5:16",
      "text": "Ma-halalel lived after the birth of Jared eight hundred and thirty years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.17",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Genesis 5:17",
      "text": "Thus all the days of Ma-halalel were eight hundred and ninety-five years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.18",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Genesis 5:18",
      "text": "When Jared had lived a hundred and sixty-two years he became the father of Enoch.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.19",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Genesis 5:19",
      "text": "Jared lived after the birth of Enoch eight hundred years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.20",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Genesis 5:20",
      "text": "Thus all the days of Jared were nine hundred and sixty-two years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.21",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Genesis 5:21",
      "text": "When Enoch had lived sixty-five years, he became the father of Methuselah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.22",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Genesis 5:22",
      "text": "Enoch walked with God after the birth of Methuselah three hundred years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.23",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Genesis 5:23",
      "text": "Thus all the days of Enoch were three hundred and sixty-five years.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.24",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Genesis 5:24",
      "text": "Enoch walked with God; and he was not, for God took him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.25",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Genesis 5:25",
      "text": "When Methuselah had lived a hundred and eighty-seven years, he became the father of Lamech.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.26",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Genesis 5:26",
      "text": "Methuselah lived after the birth of Lamech seven hundred and eighty-two years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.27",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Genesis 5:27",
      "text": "Thus all the days of Methuselah were nine hundred and sixty-nine years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.28",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Genesis 5:28",
      "text": "When Lamech had lived a hundred and eighty-two years, he became the father of a son,",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.29",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Genesis 5:29",
      "text": "and called his name Noah, saying, “Out of the ground which the Lord has cursed this one shall bring us relief from our work and from the toil of our hands.”",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.30",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Genesis 5:30",
      "text": "Lamech lived after the birth of Noah five hundred and ninety-five years, and had other sons and daughters.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.31",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Genesis 5:31",
      "text": "Thus all the days of Lamech were seven hundred and seventy-seven years; and he died.",
      "paragraphStart": false
    },
    {
      "id": "rsv:genesis.5.32",
      "translationId": "rsv",
      "bookSlug": "genesis",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Genesis 5:32",
      "text": "After Noah was five hundred years old, Noah became the father of Shem, Ham, and Japheth.",
      "paragraphStart": false
    }
  ]
}
