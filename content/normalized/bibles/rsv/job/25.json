      "chapterNumber": 25,
      "verseNumber": 1,
      "referenceLabel": "Job 25:1",
      "text": "Then Bildad the Shuhite answered:",
      "paragraphStart": true
    },
    {
      "id": "rsv:job.25.2",
      "translationId": "rsv",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 2,
      "referenceLabel": "Job 25:2",
      "text": "“Dominion and fear are with God; he makes peace in his high heaven.",
      "paragraphStart": false
    },
    {
      "id": "rsv:job.25.3",
      "translationId": "rsv",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 3,
      "referenceLabel": "Job 25:3",
      "text": "Is there any number to his armies? Upon whom does his light not arise?",
      "paragraphStart": false
    },
    {
      "id": "rsv:job.25.4",
      "translationId": "rsv",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 4,
      "referenceLabel": "Job 25:4",
      "text": "How then can man be righteous before God? How can he who is born of woman be clean?",
      "paragraphStart": false
    },
    {
      "id": "rsv:job.25.5",
      "translationId": "rsv",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 5,
      "referenceLabel": "Job 25:5",
      "text": "Behold, even the moon is not bright and the stars are not clean in his sight;",
      "paragraphStart": false
    },
    {
      "id": "rsv:job.25.6",
      "translationId": "rsv",
      "bookSlug": "job",
      "chapterNumber": 25,
      "verseNumber": 6,
      "referenceLabel": "Job 25:6",
      "text": "how much less man, who is a maggot, and the son of man, who is a worm!”",
      "paragraphStart": false
    }
  ]
}
