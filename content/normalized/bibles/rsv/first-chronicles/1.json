{
  "chapter": {
    "id": "rsv:first-chronicles.1",
    "translationId": "rsv",
    "bookSlug": "first-chronicles",
    "chapterNumber": 1,
    "referenceLabel": "1 Chronicles 1",
    "summary": "Source text for 1 Chronicles 1 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:first-chronicles.1.1",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Chronicles 1:1",
      "text": "Adam, Seth, Enosh;",
      "paragraphStart": true
    },
    {
      "id": "rsv:first-chronicles.1.2",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Chronicles 1:2",
      "text": "Kenan, Mahalalel, Jared;",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.3",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Chronicles 1:3",
      "text": "Enoch, Methuselah, Lamech;",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.4",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Chronicles 1:4",
      "text": "Noah, Shem, Ham, and Japheth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.5",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Chronicles 1:5",
      "text": "The sons of Japheth: Gomer, Magog, Madai, Javan, Tubal, Meshech, and Tiras.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.6",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Chronicles 1:6",
      "text": "The sons of Gomer: Ashkenaz, Diphath, and Togarmah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.7",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Chronicles 1:7",
      "text": "The sons of Javan: Elishah, Tarshish, Kittim, and Rodanim.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.8",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Chronicles 1:8",
      "text": "The sons of Ham: Cush, Egypt, Put, and Canaan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.9",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Chronicles 1:9",
      "text": "The sons of Cush: Seba, Havilah, Sabta, Raama, and Sabteca. The sons of Raamah: Sheba and Dedan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.10",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Chronicles 1:10",
      "text": "Cush was the father of Nimrod; he began to be a mighty one in the earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.11",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Chronicles 1:11",
      "text": "Egypt was the father of Ludim, Anamim, Lehabim, Naph-tuhim,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.12",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Chronicles 1:12",
      "text": "Pathrusim, Casluhim (whence came the Philistines), and Caphtorim.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.13",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Chronicles 1:13",
      "text": "Canaan was the father of Sidon his first-born, and Heth,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.14",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Chronicles 1:14",
      "text": "and the Jebusites, the Amorites, the Girgashites,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.15",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Chronicles 1:15",
      "text": "the Hivites, the Arkites, the Sinites,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.16",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Chronicles 1:16",
      "text": "the Arvadites, the Zemarites, and the Hamathites.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.17",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Chronicles 1:17",
      "text": "The sons of Shem: Elam, Asshur, Arpachshad, Lud, Aram, Uz, Hul, Gether, and Meshech.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.18",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Chronicles 1:18",
      "text": "Arpachshad was the father of Shelah; and Shelah was the father of Eber.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.19",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Chronicles 1:19",
      "text": "To Eber were born two sons: the name of the one was Peleg (for in his days the earth was divided), and the name of his brother Joktan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.20",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Chronicles 1:20",
      "text": "Joktan was the father of Almodad, Sheleph, Hazarmaveth, Jerah,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.21",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Chronicles 1:21",
      "text": "Hadoram, Uzal, Diklah,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.22",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Chronicles 1:22",
      "text": "Ebal, Abima-el, Sheba,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.23",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Chronicles 1:23",
      "text": "Ophir, Havilah, and Jobab; all these were the sons of Joktan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.24",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Chronicles 1:24",
      "text": "Shem, Arpachshad, Shelah;",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.25",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Chronicles 1:25",
      "text": "Eber, Peleg, Reu;",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.26",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Chronicles 1:26",
      "text": "Serug, Nahor, Terah;",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.27",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Chronicles 1:27",
      "text": "Abram, that is, Abraham.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.28",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "1 Chronicles 1:28",
      "text": "The sons of Abraham: Isaac and Ishmael.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.29",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "1 Chronicles 1:29",
      "text": "These are their genealogies: the first-born of Ishmael, Nebaioth; and Kedar, Adbeel, Mibsam,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.30",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "1 Chronicles 1:30",
      "text": "Mishma, Dumah, Massa, Hadad, Tema,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.31",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "1 Chronicles 1:31",
      "text": "Jetur, Naphish, and Kedemah. These are the sons of Ishmael.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.32",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "1 Chronicles 1:32",
      "text": "The sons of Keturah, Abraham's concubine: she bore Zimran, Jokshan, Medan, Midian, Ishbak, and Shuah. The sons of Jokshan: Sheba and Dedan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.33",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "1 Chronicles 1:33",
      "text": "The sons of Midian: Ephah, Epher, Hanoch, Abida, and Eldaah. All these were the descendants of Keturah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.34",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "1 Chronicles 1:34",
      "text": "Abraham was the father of Isaac. The sons of Isaac: Esau and Israel.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.35",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "1 Chronicles 1:35",
      "text": "The sons of Esau: Eliphaz, Reuel, Jeush, Jalam, and Korah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.36",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "1 Chronicles 1:36",
      "text": "The sons of Eliphaz: Teman, Omar, Zephi, Gatam, Kenaz, Timna, and Amalek.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.37",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "1 Chronicles 1:37",
      "text": "The sons of Reuel: Nahath, Zerah, Shammah, and Mizzah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.38",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "1 Chronicles 1:38",
      "text": "The sons of Seir: Lotan, Shobal, Zibeon, Anah, Dishon, Ezer, and Dishan.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.39",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "1 Chronicles 1:39",
      "text": "The sons of Lotan: Hori and Homam; and Lotan's sister was Timna.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.40",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "1 Chronicles 1:40",
      "text": "The sons of Shobal: Alian, Manahath, Ebal, Shephi, and Onam. The sons of Zibeon: Aiah and Anah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.41",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 41,
      "referenceLabel": "1 Chronicles 1:41",
      "text": "The sons of Anah: Dishon. The sons of Dishon: Hamran, Eshban, Ithran, and Cheran.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.42",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 42,
      "referenceLabel": "1 Chronicles 1:42",
      "text": "The sons of Ezer: Bilhan, Zaavan, and Jaakan. The sons of Dishan: Uz and Aran.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.43",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 43,
      "referenceLabel": "1 Chronicles 1:43",
      "text": "These are the kings who reigned in the land of Edom before any king reigned over the Israelites: Bela the son of Beor, the name of whose city was Dinhabah.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.44",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 44,
      "referenceLabel": "1 Chronicles 1:44",
      "text": "When Bela died, Jobab the son of Zerah of Bozrah reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.45",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 45,
      "referenceLabel": "1 Chronicles 1:45",
      "text": "When Jobab died, Husham of the land of the Temanites reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.46",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 46,
      "referenceLabel": "1 Chronicles 1:46",
      "text": "When Husham died, Hadad the son of Bedad, who defeated Midian in the country of Moab, reigned in his stead; and the name of his city was Avith.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.47",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 47,
      "referenceLabel": "1 Chronicles 1:47",
      "text": "When Hadad died, Samlah of Masrekah reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.48",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 48,
      "referenceLabel": "1 Chronicles 1:48",
      "text": "When Samlah died, Shaul of Rehoboth on the Euphrates reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.49",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 49,
      "referenceLabel": "1 Chronicles 1:49",
      "text": "When Shaul died, Baal-hanan, the son of Achbor, reigned in his stead.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.50",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 50,
      "referenceLabel": "1 Chronicles 1:50",
      "text": "When Baal-hanan died, Hadad reigned in his stead; and the name of his city was Pai, and his wife's name Mehetabel the daughter of Matred, the daughter of Mezahab.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.51",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 51,
      "referenceLabel": "1 Chronicles 1:51",
      "text": "And Hadad died. The chiefs of Edom were: chiefs Timna, Aliah, Jetheth,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.52",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 52,
      "referenceLabel": "1 Chronicles 1:52",
      "text": "Oholibamah, Elah, Pinon,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.53",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 53,
      "referenceLabel": "1 Chronicles 1:53",
      "text": "Kenaz, Teman, Mibzar,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-chronicles.1.54",
      "translationId": "rsv",
      "bookSlug": "first-chronicles",
      "chapterNumber": 1,
      "verseNumber": 54,
      "referenceLabel": "1 Chronicles 1:54",
      "text": "Magdiel, and Iram; these are the chiefs of Edom.",
      "paragraphStart": false
    }
  ]
}
