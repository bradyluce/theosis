{
  "chapter": {
    "id": "rsv:first-thessalonians.5",
    "translationId": "rsv",
    "bookSlug": "first-thessalonians",
    "chapterNumber": 5,
    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:first-thessalonians.5.1",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "But as to the times and the seasons, brethren, you have no need to have anything written to you.",
      "paragraphStart": true
    },
    {
      "id": "rsv:first-thessalonians.5.2",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "For you yourselves know well that the day of the Lord will come like a thief in the night.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.3",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "When people say, “There is peace and security,” then sudden destruction will come upon them as travail comes upon a woman with child, and there will be no escape.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.4",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "But you are not in darkness, brethren, for that day to surprise you like a thief.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.5",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "For you are all sons of light and sons of the day; we are not of the night or of darkness.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.6",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "So then let us not sleep, as others do, but let us keep awake and be sober.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.7",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "For those who sleep at night, and those who get drunk are drunk at night.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.8",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "But, since we belong to the day, let us be sober, and put on the breastplate of faith and love, and for a helmet the hope of salvation.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.9",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "For God has not destined us for wrath, but to obtain salvation through our Lord Jesus Christ,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.10",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "who died for us so that whether we wake or sleep we might live with him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.11",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "Therefore encourage one another and build one another up, just as you are doing.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.12",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "But we beseech you, brethren, to respect those who labor among you and are over you in the Lord and admonish you,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.13",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "and to esteem them very highly in love because of their work. Be at peace among yourselves.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.14",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "And we exhort you, brethren, admonish the idlers, encourage the fainthearted, help the weak, be patient with them all.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.15",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "See that none of you repays evil for evil, but always seek to do good to one another and to all.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.16",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "Rejoice always,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.17",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "pray constantly,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.18",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "give thanks in all circumstances; for this is the will of God in Christ Jesus for you.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.19",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "Do not quench the Spirit,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.20",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "do not despise prophesying,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.21",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "but test everything; hold fast what is good,",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.22",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "abstain from every form of evil.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.23",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "May the God of peace himself sanctify you wholly; and may your spirit and soul and body be kept sound and blameless at the coming of our Lord Jesus Christ.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.24",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "He who calls you is faithful, and he will do it.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.25",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "Brethren, pray for us.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.26",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "Greet all the brethren with a holy kiss.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.27",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "I adjure you by the Lord that this letter be read to all the brethren.",
      "paragraphStart": false
    },
    {
      "id": "rsv:first-thessalonians.5.28",
      "translationId": "rsv",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "The grace of our Lord Jesus Christ be with you.",
      "paragraphStart": false
    }
  ]
}
