{
  "chapter": {
    "id": "rsv:colossians.3",
    "translationId": "rsv",
    "bookSlug": "colossians",
    "chapterNumber": 3,
    "referenceLabel": "Colossians 3",
    "summary": "Source text for Colossians 3 in Revised Standard Version."
  },
  "verses": [
    {
      "id": "rsv:colossians.3.1",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Colossians 3:1",
      "text": "If then you have been raised with Christ, seek the things that are above, where Christ is, seated at the right hand of God.",
      "paragraphStart": true
    },
    {
      "id": "rsv:colossians.3.2",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Colossians 3:2",
      "text": "Set your minds on things that are above, not on things that are on earth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.3",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Colossians 3:3",
      "text": "For you have died, and your life is hid with Christ in God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.4",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Colossians 3:4",
      "text": "When Christ who is our life appears, then you also will appear with him in glory.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.5",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Colossians 3:5",
      "text": "Put to death therefore what is earthly in you: fornication, impurity, passion, evil desire, and covetousness, which is idolatry.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.6",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Colossians 3:6",
      "text": "On account of these the wrath of God is coming.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.7",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Colossians 3:7",
      "text": "In these you once walked, when you lived in them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.8",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Colossians 3:8",
      "text": "But now put them all away: anger, wrath, malice, slander, and foul talk from your mouth.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.9",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Colossians 3:9",
      "text": "Do not lie to one another, seeing that you have put off the old nature with its practices",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.10",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Colossians 3:10",
      "text": "and have put on the new nature, which is being renewed in knowledge after the image of its creator.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.11",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Colossians 3:11",
      "text": "Here there cannot be Greek and Jew, circumcised and uncircumcised, barbarian, Scythian, slave, free man, but Christ is all, and in all.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.12",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Colossians 3:12",
      "text": "Put on then, as God's chosen ones, holy and beloved, compassion, kindness, lowliness, meekness, and patience,",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.13",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Colossians 3:13",
      "text": "forbearing one another and, if one has a complaint against another, forgiving each other; as the Lord has forgiven you, so you also must forgive.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.14",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Colossians 3:14",
      "text": "And above all these put on love, which binds everything together in perfect harmony.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.15",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Colossians 3:15",
      "text": "And let the peace of Christ rule in your hearts, to which indeed you were called in the one body. And be thankful.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.16",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Colossians 3:16",
      "text": "Let the word of Christ dwell in you richly, teach and admonish one another in all wisdom, and sing psalms and hymns and spiritual songs with thankfulness in your hearts to God.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.17",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Colossians 3:17",
      "text": "And whatever you do, in word or deed, do everything in the name of the Lord Jesus, giving thanks to God the Father through him.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.18",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Colossians 3:18",
      "text": "Wives, be subject to your husbands, as is fitting in the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.19",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Colossians 3:19",
      "text": "Husbands, love your wives, and do not be harsh with them.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.20",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Colossians 3:20",
      "text": "Children, obey your parents in everything, for this pleases the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.21",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Colossians 3:21",
      "text": "Fathers, do not provoke your children, lest they become discouraged.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.22",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Colossians 3:22",
      "text": "Slaves, obey in everything those who are your earthly masters, not with eyeservice, as men-pleasers, but in singleness of heart, fearing the Lord.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.23",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Colossians 3:23",
      "text": "Whatever your task, work heartily, as serving the Lord and not men,",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.24",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Colossians 3:24",
      "text": "knowing that from the Lord you will receive the inheritance as your reward; you are serving the Lord Christ.",
      "paragraphStart": false
    },
    {
      "id": "rsv:colossians.3.25",
      "translationId": "rsv",
      "bookSlug": "colossians",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Colossians 3:25",
      "text": "For the wrongdoer will be paid back for the wrong he has done, and there is no partiality.",
      "paragraphStart": false
    }
  ]
}
