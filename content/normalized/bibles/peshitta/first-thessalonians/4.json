    "summary": "Source text for 1 Thessalonians 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-thessalonians.4.1",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 4:1",
      "text": "ܡܟܝܠ ܐܚܝ ܒܥܝܢܢ ܡܢܟܘܢ ܘܡܬܟܫܦܝܢܢ ܠܟܘܢ ܒܡܪܢ ܝܫܘܥ ܕܐܝܟ ܕܩܒܠܬܘܢ ܡܢܢ ܐܝܟܢ ܘܠܐ ܠܟܘܢ ܕܬܗܠܟܘܢ ܘܬܫܦܪܘܢ ܠܐܠܗܐ ܕܝܬܝܪܐܝܬ ܬܘܤܦܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-thessalonians.4.2",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 4:2",
      "text": "ܝܕܥܝܢ ܐܢܬܘܢ ܓܝܪ ܐܝܠܝܢ ܦܘܩܕܢܐ ܝܗܒܢ ܠܟܘܢ ܒܡܪܢ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.3",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 4:3",
      "text": "ܗܢܘ ܓܝܪ ܨܒܝܢܗ ܕܐܠܗܐ ܩܕܝܫܘܬܟܘܢ ܘܕܬܗܘܘܢ ܦܪܝܩܝܢ ܡܢ ܟܠ ܙܢܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.4",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 4:4",
      "text": "ܘܢܗܘܐ ܝܕܥ ܐܢܫ ܐܢܫ ܡܢܟܘܢ ܠܡܩܢܐ ܡܐܢܗ ܒܩܕܝܫܘܬܐ ܘܒܐܝܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.5",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 4:5",
      "text": "ܘܠܐ ܒܚܫܐ ܕܪܓܬܐ ܐܝܟ ܫܪܟܐ ܕܥܡܡܐ ܗܢܘܢ ܕܠܐ ܝܕܥܝܢ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.6",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 4:6",
      "text": "ܘܠܐ ܬܗܘܘܢ ܡܫܝܚܝܢ ܠܡܥܒܪ ܘܠܡܥܠܒ ܐܢܫ ܠܐܚܘܗܝ ܒܗܕܐ ܨܒܘܬܐ ܡܛܠ ܕܡܪܢ ܗܘ ܬܒܘܥܐ ܥܠ ܗܠܝܢ ܟܠܗܝܢ ܐܝܟܢܐ ܕܐܦ ܡܢ ܩܕܡ ܙܒܢܐ ܐܡܪܢ ܠܟܘܢ ܘܤܗܕܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.7",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 4:7",
      "text": "ܠܐ ܓܝܪ ܩܪܟܘܢ ܐܠܗܐ ܠܛܢܦܘܬܐ ܐܠܐ ܠܩܕܝܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.8",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 4:8",
      "text": "ܡܟܝܠ ܡܢ ܕܛܠܡ ܠܐ ܗܘܐ ܠܒܪܢܫܐ ܛܠܡ ܐܠܐ ܠܐܠܗܐ ܗܘ ܕܝܗܒ ܒܟܘܢ ܪܘܚܗ ܩܕܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.9",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 4:9",
      "text": "ܥܠ ܚܘܒܐ ܕܝܢ ܕܐܚܐ ܠܐ ܤܢܝܩܝܬܘܢ ܠܡܟܬܒ ܠܟܘܢ ܐܢܬܘܢ ܓܝܪ ܩܢܘܡܟܘܢ ܡܠܦܐ ܐܢܬܘܢ ܕܐܠܗܐ ܕܬܚܒܘܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.10",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 4:10",
      "text": "ܐܦ ܥܒܕܝܢ ܐܢܬܘܢ ܗܟܢܐ ܠܟܠܗܘܢ ܐܚܐ ܕܒܟܠܗ ܡܩܕܘܢܝܐ ܒܥܐ ܐܢܐ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܕܬܬܝܬܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.11",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 4:11",
      "text": "ܘܬܬܚܦܛܘܢ ܕܬܗܘܘܢ ܫܠܝܢ ܘܥܢܝܢ ܒܤܘܥܪܢܝܟܘܢ ܘܗܘܝܬܘܢ ܦܠܚܝܢ ܒܐܝܕܝܟܘܢ ܐܝܟܢܐ ܕܦܩܕܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.12",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 4:12",
      "text": "ܕܬܗܘܘܢ ܡܗܠܟܝܢ ܒܐܤܟܡܐ ܠܘܬ ܒܪܝܐ ܘܥܠ ܐܢܫ ܠܐ ܬܤܬܢܩܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.13",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 4:13",
      "text": "ܨܒܐ ܐܢܐ ܕܝܢ ܕܬܕܥܘܢ ܐܚܝ ܕܥܠ ܐܝܠܝܢ ܕܕܡܟܝܢ ܠܐ ܬܗܘܐ ܟܪܝܐ ܠܟܘܢ ܐܝܟ ܫܪܟܐ ܕܐܢܫܐ ܕܤܒܪܐ ܠܝܬ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.14",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 4:14",
      "text": "ܐܢ ܓܝܪ ܡܗܝܡܢܝܢܢ ܕܝܫܘܥ ܡܝܬ ܘܩܡ ܗܟܢܐ ܐܦ ܐܠܗܐ ܠܐܝܠܝܢ ܕܕܡܟܘ ܒܝܫܘܥ ܡܝܬܐ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.15",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 4:15",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪܝܢܢ ܠܟܘܢ ܒܡܠܬܗ ܕܡܪܢ ܕܚܢܢ ܐܝܠܝܢ ܕܡܫܬܚܪܝܢܢ ܒܡܐܬܝܬܗ ܕܡܪܢ ܕܚܝܝܢܢ ܠܐ ܢܕܪܟ ܠܐܝܠܝܢ ܕܕܡܟܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.16",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 4:16",
      "text": "ܡܛܠ ܕܗܘ ܡܪܢ ܒܦܘܩܕܢܐ ܘܒܩܠܐ ܕܪܝܫ ܡܠܐܟܐ ܘܒܩܪܢܐ ܕܐܠܗܐ ܢܚܬ ܡܢ ܫܡܝܐ ܘܡܝܬܐ ܕܒܡܫܝܚܐ ܢܩܘܡܘܢ ܠܘܩܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.17",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 4:17",
      "text": "ܘܗܝܕܝܢ ܚܢܢ ܐܝܠܝܢ ܕܡܫܬܚܪܝܢܢ ܕܚܝܝܢܢ ܢܬܚܛܦ ܥܡܗܘܢ ܐܟܚܕܐ ܒܥܢܢܐ ܠܐܘܪܥܗ ܕܡܪܢ ܒܐܐܪ ܘܗܟܢܐ ܒܟܠܙܒܢ ܥܡ ܡܪܢ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.4.18",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 4:18",
      "text": "ܗܘܘ ܗܟܝܠ ܡܒܝܐܝܢ ܚܕ ܠܚܕ ܒܡܠܐ ܗܠܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
