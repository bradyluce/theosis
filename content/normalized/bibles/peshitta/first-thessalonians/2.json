    "bookSlug": "first-thessalonians",
    "chapterNumber": 2,
    "referenceLabel": "1 Thessalonians 2",
    "summary": "Source text for 1 Thessalonians 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-thessalonians.2.1",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 2:1",
      "text": "ܘܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܐܚܝ ܕܡܥܠܢܢ ܕܠܘܬܟܘܢ ܠܐ ܗܘܐ ܤܪܝܩܐܝܬ ܗܘܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-thessalonians.2.2",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 2:2",
      "text": "ܐܠܐ ܠܘܩܕܡ ܚܫܢܢ ܘܐܨܛܥܪܢܢ ܐܝܟ ܕܝܕܥܝܬܘܢ ܒܦܝܠܝܦܘܤ ܘܗܝܕܝܢ ܒܐܓܘܢܐ ܪܒܐ ܡܠܠܢ ܥܡܟܘܢ ܒܦܪܗܤܝܐ ܕܐܠܗܢ ܤܒܪܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.3",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 2:3",
      "text": "ܒܘܝܐܢ ܓܝܪ ܠܐ ܗܘܐ ܡܢ ܛܥܝܘܬܐ ܐܦܠܐ ܡܢ ܛܢܦܘܬܐ ܐܦܠܐ ܒܢܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.4",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 2:4",
      "text": "ܐܠܐ ܐܝܟ ܡܐ ܕܒܩܝܢܢ ܠܐܠܗܐ ܕܬܬܗܝܡܢ ܤܒܪܬܗ ܗܟܢܐ ܡܡܠܠܝܢܢ ܠܐ ܐܝܟ ܕܠܒܢܝ ܐܢܫܐ ܢܫܦܪ ܐܠܐ ܠܐܠܗܐ ܗܘ ܕܒܩܐ ܠܒܘܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.5",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 2:5",
      "text": "ܐܦܠܐ ܓܝܪ ܡܡܬܘܡ ܐܬܚܫܚܢ ܒܡܡܠܠܐ ܫܕܠܐ ܐܝܟ ܕܝܕܥܝܢ ܐܢܬܘܢ ܘܠܐ ܒܥܠܬܐ ܕܝܥܢܘܬܐ ܐܠܗܐ ܤܗܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.6",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 2:6",
      "text": "ܘܠܐ ܒܥܝܢ ܫܘܒܚܐ ܡܢ ܒܢܝܢܫܐ ܠܐ ܡܢܟܘܢ ܘܠܐ ܡܢ ܐܚܪܢܐ ܟܕ ܡܫܟܚܝܢ ܗܘܝܢ ܝܩܝܪܐ ܠܡܗܘܐ ܐܝܟ ܫܠܝܚܐ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.7",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 2:7",
      "text": "ܐܠܐ ܗܘܝܢ ܒܝܢܬܟܘܢ ܡܟܝܟܐ ܘܐܝܟ ܡܪܒܝܢܝܬܐ ܕܡܚܒܒܐ ܒܢܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.8",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 2:8",
      "text": "ܗܟܢܐ ܐܦ ܚܢܢ ܡܚܒܒܝܢܢ ܘܡܤܘܚܝܢܢ ܠܡܬܠ ܠܟܘܢ ܠܐ ܒܠܚܘܕ ܤܒܪܬܗ ܕܐܠܗܐ ܐܠܐ ܐܦ ܢܦܫܢ ܡܛܠ ܕܚܒܝܒܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.9",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 2:9",
      "text": "ܥܗܕܝܢ ܐܢܬܘܢ ܓܝܪ ܐܚܝܢ ܕܠܐܝܢ ܗܘܝܢ ܘܥܡܠܝܢ ܒܥܒܕ ܐܝܕܝܢ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܕܥܠ ܚܕ ܡܢܟܘܢ ܠܐ ܢܐܩܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.10",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 2:10",
      "text": "ܐܢܬܘܢ ܤܗܕܝܢ ܘܐܠܗܐ ܐܝܟܢܐ ܐܟܪܙܢ ܠܟܘܢ ܤܒܪܬܗ ܕܐܠܗܐ ܕܟܝܐܝܬ ܘܟܐܢܐܝܬ ܘܕܠܐ ܪܫܝܢ ܗܘܝܢ ܠܘܬ ܟܠܗܘܢ ܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.11",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 2:11",
      "text": "ܐܝܟܢܐ ܕܝܕܥܝܢ ܐܢܬܘܢ ܕܡܢ ܚܕ ܚܕ ܡܢܟܘܢ ܐܝܟ ܐܒܐ ܡܢ ܒܢܘܗܝ ܒܥܝܢ ܗܘܝܢ ܘܡܠܝܢ ܗܘܝܢ ܒܠܒܟܘܢ ܘܡܤܗܕܝܢܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.12",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 2:12",
      "text": "ܕܬܗܠܟܘܢ ܐܝܟ ܕܝܐܐ ܠܐܠܗܐ ܗܘ ܕܩܪܟܘܢ ܠܡܠܟܘܬܗ ܘܠܫܘܒܚܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.13",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 2:13",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܚܢܢ ܡܘܕܝܢܢ ܐܡܝܢܐܝܬ ܠܐܠܗܐ ܕܡܠܬܐ ܕܐܠܗܐ ܕܩܒܠܬܘܢ ܡܢܢ ܠܐ ܗܘܐ ܐܝܟ ܡܠܬܐ ܕܒܢܝܢܫܐ ܩܒܠܬܘܢܗ ܐܠܐ ܐܝܟܢܐ ܕܐܝܬܝܗ ܫܪܝܪܐܝܬ ܡܠܬܐ ܕܐܠܗܐ ܘܗܝ ܒܥܒܕܐ ܡܤܬܥܪܐ ܒܟܘܢ ܒܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.14",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 2:14",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܚܝ ܐܬܕܡܝܬܘܢ ܠܥܕܬܐ ܕܐܠܗܐ ܕܒܝܗܘܕ ܗܠܝܢ ܕܒܝܫܘܥ ܡܫܝܚܐ ܕܗܟܢ ܤܝܒܪܬܘܢ ܐܦ ܐܢܬܘܢ ܡܢ ܒܢܝ ܫܪܒܬܟܘܢ ܐܝܟܢܐ ܕܐܦ ܗܢܘܢ ܡܢ ܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.15",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 2:15",
      "text": "ܗܢܘܢ ܕܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܩܛܠܘ ܘܠܢܒܝܐ ܕܡܢܗܘܢ ܘܠܢ ܪܕܦܘ ܘܠܐܠܗܐ ܠܐ ܫܦܪܝܢ ܘܥܒܝܕܝܢ ܤܩܘܒܠܐ ܠܟܠܗܘܢ ܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.16",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 2:16",
      "text": "ܕܟܠܝܢ ܠܢ ܕܢܡܠܠ ܥܡ ܥܡܡܐ ܕܢܚܘܢ ܠܡܫܠܡܘ ܚܛܗܝܗܘܢ ܒܟܠܙܒܢ ܡܛܝ ܕܝܢ ܥܠܝܗܘܢ ܪܘܓܙܐ ܥܕܡܐ ܠܚܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.17",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 2:17",
      "text": "ܚܢܢ ܕܝܢ ܐܚܝܢ ܗܘܝܢ ܝܬܡܐ ܡܢܟܘܢ ܙܒܢܐ ܕܫܥܬܐ ܒܐܦܝܢ ܘܠܐ ܒܠܒܢ ܘܝܬܝܪܐܝܬ ܐܬܚܦܛܢ ܠܡܚܙܐ ܐܦܝܟܘܢ ܒܚܘܒܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.18",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 2:18",
      "text": "ܘܨܒܝܢ ܕܢܐܬܐ ܠܘܬܟܘܢ ܐܢܐ ܦܘܠܘܤ ܚܕܐ ܙܒܢ ܘܬܪܬܝܢ ܘܥܘܟܢܝ ܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.19",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 2:19",
      "text": "ܐܝܢܘ ܓܝܪ ܤܒܪܢ ܘܚܕܘܬܢ ܘܟܠܝܠܐ ܕܫܘܒܗܪܢ ܐܠܐ ܐܢ ܐܢܬܘܢ ܩܕܡ ܡܪܢ ܝܫܘܥ ܒܡܐܬܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.2.20",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 2:20",
      "text": "ܐܢܬܘܢ ܐܢܘܢ ܓܝܪ ܬܫܒܘܚܬܢ ܘܚܕܘܬܢ ܀",
      "paragraphStart": false
    }
  ]
}
