    "referenceLabel": "1 Thessalonians 5",
    "summary": "Source text for 1 Thessalonians 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-thessalonians.5.1",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 5:1",
      "text": "ܥܠ ܙܒܢܐ ܕܝܢ ܘܥܕܢܐ ܐܚܝ ܠܐ ܤܢܝܩܝܬܘܢ ܠܡܟܬܒ ܠܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-thessalonians.5.2",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 5:2",
      "text": "ܐܢܬܘܢ ܓܝܪ ܫܪܝܪܐܝܬ ܝܕܥܝܢ ܐܢܬܘܢ ܕܝܘܡܗ ܕܡܪܢ ܐܝܟ ܓܢܒܐ ܒܠܠܝܐ ܗܟܢܐ ܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.3",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 5:3",
      "text": "ܟܕ ܢܐܡܪܘܢ ܕܫܠܡܐ ܗܘ ܘܫܝܢܐ ܘܗܝܕܝܢ ܡܢܫܠܝܐ ܢܩܘܡ ܥܠܝܗܘܢ ܐܒܕܢܐ ܐܝܟ ܚܒܠܐ ܥܠ ܒܛܢܬܐ ܘܠܐ ܢܡܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.4",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 5:4",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܚܝ ܠܐ ܗܘܝܬܘܢ ܒܚܫܘܟܐ ܕܗܘ ܝܘܡܐ ܐܝܟ ܓܢܒܐ ܢܕܪܟܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.5",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 5:5",
      "text": "ܟܠܟܘܢ ܓܝܪ ܒܢܝ ܢܘܗܪܐ ܐܢܬܘܢ ܘܒܢܝ ܐܝܡܡܐ ܘܠܐ ܗܘܝܬܘܢ ܒܢܝ ܠܠܝܐ ܘܠܐ ܒܢܝ ܚܫܘܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.6",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 5:6",
      "text": "ܠܐ ܢܕܡܟ ܗܟܝܠ ܐܝܟ ܫܪܟܐ ܐܠܐ ܗܘܝܢ ܥܝܪܝܢ ܘܡܗܘܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.7",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 5:7",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܕܡܟܝܢ ܒܠܠܝܐ ܗܘ ܕܡܟܝܢ ܘܐܝܠܝܢ ܕܪܘܝܢ ܒܠܠܝܐ ܗܘ ܪܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.8",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 5:8",
      "text": "ܚܢܢ ܕܝܢ ܕܒܢܝ ܐܝܡܡܐ ܚܢܢ ܗܘܝܢ ܥܝܪܝܢ ܒܪܥܝܢܢ ܘܠܒܝܫܝܢ ܫܪܝܢܐ ܕܗܝܡܢܘܬܐ ܘܕܚܘܒܐ ܘܢܤܝܡ ܤܢܘܪܬܐ ܕܤܒܪܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.9",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 5:9",
      "text": "ܡܛܠ ܕܠܐ ܤܡܢ ܐܠܗܐ ܠܪܘܓܙܐ ܐܠܐ ܠܩܢܝܢܐ ܕܚܝܐ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.10",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 5:10",
      "text": "ܗܘ ܕܡܝܬ ܥܠ ܐܦܝܢ ܕܐܢ ܥܝܪܝܢܢ ܘܐܢ ܕܡܟܝܢܢ ܐܟܚܕܐ ܥܡܗ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.11",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 5:11",
      "text": "ܡܛܠ ܗܢܐ ܒܝܐܘ ܚܕ ܠܚܕ ܘܒܢܘ ܚܕ ܠܚܕ ܐܝܟܢܐ ܕܐܦ ܥܒܕܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.12",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 5:12",
      "text": "ܒܥܝܢܢ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܕܗܘܝܬܘܢ ܝܕܥܝܢ ܠܐܝܠܝܢ ܕܠܐܝܢ ܒܟܘܢ ܘܩܝܡܝܢ ܒܐܦܝܟܘܢ ܒܡܪܢ ܘܡܠܦܝܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.13",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 5:13",
      "text": "ܕܗܘܘ ܚܫܝܒܝܢ ܠܟܘܢ ܒܚܘܒܐ ܝܬܝܪܐ ܘܡܛܠ ܥܒܕܗܘܢ ܐܫܬܝܢܘ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.14",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 Thessalonians 5:14",
      "text": "ܒܥܝܢܢ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܪܕܘ ܠܡܤܟܠܢܐ ܘܠܒܒܘ ܠܙܥܘܪܝ ܢܦܫܐ ܘܤܒܘ ܛܥܢܐ ܕܡܚܝܠܐ ܘܐܓܪܘ ܪܘܚܟܘܢ ܠܘܬ ܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.15",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 Thessalonians 5:15",
      "text": "ܘܐܙܕܗܪܘ ܕܠܡܐ ܐܢܫ ܡܢܟܘܢ ܒܝܫܬܐ ܚܠܦ ܒܝܫܬܐ ܢܦܪܘܥ ܐܠܐ ܒܟܠܙܒܢ ܗܪܛܘ ܒܬܪ ܛܒܬܐ ܠܘܬ ܚܕܕܐ ܘܠܘܬ ܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.16",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 Thessalonians 5:16",
      "text": "ܗܘܘ ܚܕܝܢ ܒܟܠܙܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.17",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 Thessalonians 5:17",
      "text": "ܘܡܨܠܝܢ ܕܠܐ ܫܠܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.18",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 Thessalonians 5:18",
      "text": "ܘܒܟܠ ܡܕܡ ܗܘܘ ܡܘܕܝܢ ܗܢܘ ܓܝܪ ܨܒܝܢܗ ܕܐܠܗܐ ܒܝܫܘܥ ܡܫܝܚܐ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.19",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 Thessalonians 5:19",
      "text": "ܪܘܚܐ ܠܐ ܬܕܥܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.20",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 Thessalonians 5:20",
      "text": "ܢܒܝܘܬܐ ܠܐ ܬܤܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.21",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 Thessalonians 5:21",
      "text": "ܟܠܡܕܡ ܒܩܘ ܘܕܫܦܝܪ ܐܚܘܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.22",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "1 Thessalonians 5:22",
      "text": "ܘܡܢ ܟܠ ܨܒܘ ܒܝܫܐ ܥܪܘܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.23",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "1 Thessalonians 5:23",
      "text": "ܗܘ ܕܝܢ ܐܠܗܐ ܕܫܠܡܐ ܢܩܕܫܟܘܢ ܓܡܝܪܐܝܬ ܠܟܠܟܘܢ ܘܟܠܗ ܪܘܚܟܘܢ ܘܢܦܫܟܘܢ ܘܦܓܪܟܘܢ ܢܢܛܪ ܕܠܐ ܪܫܝܢ ܠܡܐܬܝܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.24",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "1 Thessalonians 5:24",
      "text": "ܡܗܝܡܢ ܗܘ ܡܢ ܕܩܪܟܘܢ ܕܗܘ ܢܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.25",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "1 Thessalonians 5:25",
      "text": "ܐܚܝ ܨܠܘ ܥܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.26",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "1 Thessalonians 5:26",
      "text": "ܫܐܠܘ ܒܫܠܡܐ ܕܐܚܝܢ ܟܠܗܘܢ ܒܢܘܫܩܬܐ ܩܕܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.27",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "1 Thessalonians 5:27",
      "text": "ܡܘܡܐ ܐܢܐ ܠܟܘܢ ܒܡܪܢ ܕܬܬܩܪܐ ܐܓܪܬܐ ܗܕܐ ܠܟܠܗܘܢ ܐܚܐ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.5.28",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "1 Thessalonians 5:28",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
