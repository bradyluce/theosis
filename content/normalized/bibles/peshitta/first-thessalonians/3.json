  "verses": [
    {
      "id": "peshitta:first-thessalonians.3.1",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 3:1",
      "text": "ܘܡܛܠ ܕܠܐ ܚܡܤܢܢ ܨܒܝܢ ܠܡܦܫ ܒܐܬܢܘܤ ܒܠܚܘܕܝܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-thessalonians.3.2",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 3:2",
      "text": "ܘܢܫܕܪ ܠܘܬܟܘܢ ܠܛܝܡܬܐܘܤ ܐܚܘܢ ܘܡܫܡܫܢܐ ܕܐܠܗܐ ܘܡܥܕܪܢܢ ܒܤܒܪܬܗ ܕܡܫܝܚܐ ܕܢܫܪܪܟܘܢ ܘܢܒܥܐ ܡܢܟܘܢ ܥܠ ܗܝܡܢܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.3",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 3:3",
      "text": "ܕܠܐ ܐܢܫ ܡܢܟܘܢ ܬܬܩܛܥ ܠܗ ܒܐܘܠܨܢܐ ܗܠܝܢ ܐܢܬܘܢ ܓܝܪ ܝܕܥܝܢ ܐܢܬܘܢ ܕܠܗܕܐ ܗܘ ܤܝܡܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.4",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 3:4",
      "text": "ܐܦ ܟܕ ܠܘܬܟܘܢ ܗܘܝܢ ܓܝܪ ܩܕܡܢ ܐܡܪܢ ܠܟܘܢ ܕܥܬܝܕܝܢܢ ܠܡܬܐܠܨܘ ܐܝܟܢܐ ܕܝܕܥܝܢ ܐܢܬܘܢ ܕܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.5",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 3:5",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܐܢܐ ܠܐ ܚܡܤܢܬ ܥܕܡܐ ܕܫܕܪܬ ܕܐܕܥ ܗܝܡܢܘܬܟܘܢ ܕܕܠܡܐ ܢܢܤܝܟܘܢ ܡܢܤܝܢܐ ܘܢܗܘܐ ܥܡܠܢ ܤܪܝܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.6",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 3:6",
      "text": "ܗܫܐ ܕܝܢ ܡܢ ܕܐܬܐ ܠܘܬܢ ܛܝܡܬܐܘܤ ܡܢ ܨܐܕܝܟܘܢ ܘܤܒܪܢ ܥܠ ܗܝܡܢܘܬܟܘܢ ܘܥܠ ܚܘܒܟܘܢ ܘܕܐܝܬ ܠܘܬܟܘܢ ܥܘܗܕܢܢ ܛܒܐ ܒܟܠ ܥܕܢ ܘܤܘܝܢ ܐܢܬܘܢ ܠܡܚܙܝܢ ܐܝܟܢܐ ܕܐܦ ܚܢܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.7",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 3:7",
      "text": "ܡܛܠ ܗܢܐ ܐܬܒܝܐܢ ܒܟܘܢ ܐܚܝܢ ܥܠ ܟܠܗܝܢ ܥܩܬܢ ܘܐܘܠܨܢܝܢ ܡܛܠ ܗܝܡܢܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.8",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 3:8",
      "text": "ܘܗܫܐ ܗܘ ܚܝܝܢܢ ܐܢ ܐܢܬܘܢ ܬܬܩܝܡܘܢ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.9",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 3:9",
      "text": "ܐܝܕܐ ܓܝܪ ܬܘܕܝܬܐ ܡܫܟܚܝܢܢ ܠܡܦܪܥ ܚܠܦܝܟܘܢ ܠܐܠܗܐ ܥܠ ܟܠ ܚܕܘܬܐ ܕܚܕܝܢܢ ܡܛܠܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.10",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 3:10",
      "text": "ܐܠܐ ܕܩܕܡ ܐܠܗܐ ܝܬܝܪܐܝܬ ܢܬܟܫܦ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܕܢܚܙܐ ܐܦܝܟܘܢ ܘܢܓܡܘܪ ܡܐ ܕܚܤܝܪܐ ܗܝܡܢܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.11",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Thessalonians 3:11",
      "text": "ܗܘ ܕܝܢ ܐܠܗܐ ܐܒܘܢ ܘܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܢܬܪܘܨ ܐܘܪܚܢ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.12",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Thessalonians 3:12",
      "text": "ܘܢܤܓܐ ܘܢܝܬܪ ܚܘܒܟܘܢ ܕܚܕ ܠܘܬ ܚܕ ܘܕܠܘܬ ܟܠܢܫ ܐܝܟܢܐ ܕܚܢܢ ܡܚܒܝܢܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.3.13",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Thessalonians 3:13",
      "text": "ܘܢܩܝܡ ܠܒܘܬܟܘܢ ܕܠܐ ܪܫܝܢ ܒܩܕܝܫܘܬܐ ܩܕܡ ܐܠܗܐ ܐܒܘܢ ܒܡܐܬܝܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܥܡ ܟܠܗܘܢ ܩܕܝܫܘܗܝ ܀",
      "paragraphStart": false
    }
  ]
}
