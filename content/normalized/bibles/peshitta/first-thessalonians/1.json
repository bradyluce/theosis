  "verses": [
    {
      "id": "peshitta:first-thessalonians.1.1",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Thessalonians 1:1",
      "text": "ܦܘܠܘܤ ܘܤܠܘܢܘܤ ܘܛܝܡܬܐܤ ܠܥܕܬܐ ܕܬܤܠܘܢܝܩܝܐ ܕܒܐܠܗܐ ܐܒܐ ܘܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-thessalonians.1.2",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Thessalonians 1:2",
      "text": "ܡܘܕܝܢܢ ܠܐܠܗܐ ܒܟܠܙܒܢ ܥܠ ܟܠܟܘܢ ܘܡܬܕܟܪܝܢܢ ܠܟܘܢ ܒܨܠܘܬܢ ܐܡܝܢܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.3",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Thessalonians 1:3",
      "text": "ܘܥܗܕܝܢܢ ܩܕܡ ܐܠܗܐ ܐܒܐ ܥܒܕܐ ܕܗܝܡܢܘܬܟܘܢ ܘܥܡܠܐ ܕܚܘܒܟܘܢ ܘܡܤܝܒܪܢܘܬܐ ܕܤܒܪܟܘܢ ܕܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.4",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Thessalonians 1:4",
      "text": "ܝܕܥܝܢܢ ܓܝܪ ܓܒܝܘܬܟܘܢ ܐܚܝ ܚܒܝܒܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.5",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Thessalonians 1:5",
      "text": "ܡܛܠ ܕܡܤܒܪܢܘܬܢ ܠܐ ܗܘܐ ܒܡܠܐ ܒܠܚܘܕ ܗܘܬ ܠܘܬܟܘܢ ܐܠܐ ܐܦ ܒܚܝܠܐ ܘܒܪܘܚܐ ܕܩܘܕܫܐ ܘܒܦܝܤܐ ܫܪܝܪܐ ܐܦ ܐܢܬܘܢ ܝܕܥܝܢ ܐܢܬܘܢ ܐܝܟܢܐ ܗܘܝܢ ܒܝܢܬܟܘܢ ܡܛܠܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.6",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Thessalonians 1:6",
      "text": "ܘܐܢܬܘܢ ܒܢ ܐܬܕܡܝܬܘܢ ܘܒܡܪܢ ܕܩܒܠܬܘܢ ܡܠܬܐ ܒܐܘܠܨܢܐ ܪܒܐ ܘܒܚܕܘܬܐ ܕܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.7",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Thessalonians 1:7",
      "text": "ܘܗܘܝܬܘܢ ܕܡܘܬܐ ܠܟܠܗܘܢ ܡܗܝܡܢܐ ܕܐܝܬ ܒܡܩܕܘܢܝܐ ܘܒܐܟܐܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.8",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Thessalonians 1:8",
      "text": "ܡܢܟܘܢ ܓܝܪ ܐܫܬܡܥܬ ܡܠܬܗ ܕܡܪܢ ܠܐ ܒܠܚܘܕ ܒܡܩܕܘܢܝܐ ܘܒܐܟܐܝܐ ܐܠܐ ܒܟܠ ܐܬܪ ܗܝܡܢܘܬܟܘܢ ܕܒܐܠܗܐ ܐܫܬܡܥܬ ܐܝܟܢܐ ܕܠܐ ܢܤܬܢܩ ܕܢܐܡܪ ܥܠܝܟܘܢ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.9",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Thessalonians 1:9",
      "text": "ܗܢܘܢ ܓܝܪ ܡܫܬܥܝܢ ܐܝܢܐ ܡܥܠܢܐ ܗܘܐ ܠܢ ܠܘܬܟܘܢ ܘܐܝܟܢܐ ܐܬܦܢܝܬܘܢ ܠܘܬ ܐܠܗܐ ܡܢ ܕܚܠܬ ܦܬܟܪܐ ܕܬܦܠܚܘܢ ܠܐܠܗܐ ܚܝܐ ܘܫܪܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-thessalonians.1.10",
      "translationId": "peshitta",
      "bookSlug": "first-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Thessalonians 1:10",
      "text": "ܟܕ ܡܤܟܝܬܘܢ ܠܒܪܗ ܡܢ ܫܡܝܐ ܠܝܫܘܥ ܗܘ ܕܐܩܝܡ ܡܢ ܒܝܬ ܡܝܬܐ ܕܗܘ ܡܦܨܐ ܠܢ ܡܢ ܪܘܓܙܐ ܕܐܬܐ ܀",
      "paragraphStart": false
    }
  ]
