  "verses": [
    {
      "id": "peshitta:first-corinthians.3.1",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 3:1",
      "text": "ܘܐܢܐ ܐܚܝ ܠܐ ܐܫܟܚܬ ܕܐܡܠܠ ܥܡܟܘܢ ܐܝܟ ܕܥܡ ܪܘܚܢܐ ܐܠܐ ܐܝܟ ܕܥܡ ܦܓܪܢܐ ܘܐܝܟ ܕܠܝܠܘܕܐ ܒܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.3.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 3:2",
      "text": "ܚܠܒܐ ܐܫܩܝܬܟܘܢ ܘܠܐ ܝܗܒܬ ܠܟܘܢ ܡܐܟܘܠܬܐ ܠܐ ܓܝܪ ܥܕܟܝܠ ܡܫܟܚܝܢ ܗܘܝܬܘܢ ܐܠܐ ܐܦܠܐ ܗܫܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 3:3",
      "text": "ܥܕܟܝܠ ܓܝܪ ܒܒܤܪ ܐܢܬܘܢ ܐܝܟܐ ܓܝܪ ܕܐܝܬ ܒܟܘܢ ܚܤܡܐ ܘܚܪܝܢܐ ܘܦܠܓܘܬܐ ܠܐ ܗܐ ܦܓܪܢܐ ܐܢܬܘܢ ܘܒܒܤܪ ܡܗܠܟܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 3:4",
      "text": "ܡܐ ܕܐܡܪ ܓܝܪ ܐܢܫ ܐܢܫ ܡܢܟܘܢ ܐܢܐ ܕܦܘܠܘܤ ܐܢܐ ܘܐܚܪܢܐ ܐܡܪ ܐܢܐ ܕܐܦܠܘ ܐܢܐ ܠܐ ܗܐ ܦܓܪܢܐ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 3:5",
      "text": "ܡܢܘ ܓܝܪ ܦܘܠܘܤ ܐܘ ܡܢܘ ܐܦܠܘ ܐܠܐ ܡܫܡܫܢܐ ܕܒܐܝܕܝܗܘܢ ܗܝܡܢܬܘܢ ܘܐܢܫ ܐܢܫ ܐܝܟ ܕܝܗܒ ܠܗ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 3:6",
      "text": "ܐܢܐ ܢܨܒܬ ܘܐܦܠܘ ܐܫܩܝ ܐܠܐ ܐܠܗܐ ܪܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 3:7",
      "text": "ܠܐ ܗܟܝܠ ܗܘ ܕܢܨܒ ܐܝܬܘܗܝ ܡܕܡ ܘܠܐ ܗܘ ܕܡܫܩܐ ܐܠܐ ܐܠܗܐ ܕܡܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 3:8",
      "text": "ܡܢ ܕܢܨܒ ܕܝܢ ܘܡܢ ܕܡܫܩܐ ܚܕ ܐܢܘܢ ܘܐܢܫ ܐܝܟ ܥܡܠܗ ܐܓܪܗ ܡܩܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 3:9",
      "text": "ܥܡ ܐܠܗܐ ܓܝܪ ܦܠܚܝܢܢ ܘܦܘܠܚܢܐ ܕܐܠܗܐ ܘܒܢܝܢܐ ܕܐܠܗܐ ܐܢܬܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 3:10",
      "text": "ܘܐܝܟ ܛܝܒܘܬܐ ܕܐܠܗܐ ܕܐܬܝܗܒܬ ܠܝ ܤܡܬ ܫܬܐܤܬܐ ܐܝܟ ܐܪܕܟܠܐ ܚܟܝܡܐ ܐܚܪܢܐ ܕܝܢ ܥܠܝܗ ܒܢܐ ܟܠܢܫ ܕܝܢ ܢܚܙܐ ܐܝܟܢ ܒܢܐ ܥܠܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 3:11",
      "text": "ܫܬܐܤܬܐ ܓܝܪ ܐܚܪܬܐ ܤܛܪ ܡܢ ܗܕܐ ܕܤܝܡܐ ܐܢܫ ܠܐ ܡܫܟܚ ܠܡܤܡ ܕܐܝܬܝܗ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 3:12",
      "text": "ܘܐܢ ܐܢܫ ܕܝܢ ܒܢܐ ܥܠ ܗܕܐ ܫܬܐܤܬܐ ܕܗܒܐ ܐܘ ܤܐܡܐ ܐܘ ܟܐܦܐ ܝܩܝܪܬܐ ܐܘ ܩܝܤܐ ܐܘ ܥܡܝܪܐ ܐܘ ܚܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 3:13",
      "text": "ܥܒܕܐ ܕܟܠܢܫ ܡܬܓܠܐ ܝܘܡܐ ܓܝܪ ܗܘ ܓܠܐ ܠܗ ܡܛܠ ܕܒܢܘܪܐ ܡܬܓܠܐ ܘܥܒܕܗ ܕܟܠܢܫ ܐܝܟܢܐ ܐܝܬܘܗܝ ܢܘܪܐ ܬܦܪܫܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 3:14",
      "text": "ܘܐܝܢܐ ܕܢܩܘܐ ܥܒܕܗ ܗܘ ܕܒܢܐ ܐܓܪܗ ܢܩܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.3.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 3:15",
      "text": "ܘܐܝܢܐ ܕܥܒܕܗ ܢܐܩܕ ܢܚܤܪ ܗܘ ܕܝܢ ܢܫܬܘܙܒ ܗܟܢܐ ܕܝܢ ܐܝܟ ܕܡܢ ܢܘܪܐ ܀",
