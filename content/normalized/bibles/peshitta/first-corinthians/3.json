    {
      "id": "peshitta:first-corinthians.3.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 3:16",
      "text": "ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܗܝܟܠܗ ܐܢܬܘܢ ܕܐܠܗܐ ܘܪܘܚܗ ܕܐܠܗܐ ܥܡܪܐ ܒܟܘܢ ܀",
      "paragraphStart": false
