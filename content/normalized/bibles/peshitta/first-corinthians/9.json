      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 9:1",
      "text": "ܠܡܐ ܠܐ ܗܘܝܬ ܒܪ ܚܐܪܐ ܐܘ ܠܐ ܗܘܝܬ ܫܠܝܚܐ ܐܘ ܠܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܠܐ ܚܙܝܬ ܐܘ ܠܐ ܗܘܝܬܘܢ ܥܒܕܝ ܒܡܪܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.9.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 9:2",
      "text": "ܘܐܢ ܠܐܚܪܢܐ ܠܐ ܗܘܝܬ ܫܠܝܚܐ ܐܠܐ ܠܟܘܢ ܐܝܬܝ ܘܚܬܡܐ ܕܫܠܝܚܘܬܝ ܐܢܬܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 9:3",
      "text": "ܘܡܦܩ ܒܪܘܚܝ ܠܐܝܠܝܢ ܕܕܝܢܝܢ ܠܝ ܗܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 9:4",
      "text": "ܠܡܐ ܠܐ ܫܠܝܛ ܠܢ ܠܡܐܟܠ ܘܠܡܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 9:5",
      "text": "ܘܠܡܐ ܠܐ ܫܠܝܛ ܠܢ ܚܬܐ ܐܢܬܬܐ ܠܡܟܪܟܘ ܥܡܢ ܐܝܟ ܫܪܟܐ ܕܫܠܝܚܐ ܘܐܝܟ ܐܚܘܗܝ ܕܡܪܢ ܘܐܝܟ ܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 9:6",
      "text": "ܐܘ ܐܢܐ ܒܠܚܘܕ ܘܒܪܢܒܐ ܠܝܬ ܠܢ ܫܘܠܛܢܐ ܕܠܐ ܢܦܠܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 9:7",
      "text": "ܡܢܘ ܕܡܦܠܚ ܒܦܠܚܘܬܐ ܒܢܦܩܬܐ ܕܢܦܫܗ ܐܘ ܡܢܘ ܕܢܨܒ ܟܪܡܐ ܘܡܢ ܦܐܪܘܗܝ ܠܐ ܐܟܠ ܐܘ ܡܢܘ ܕܪܥܐ ܥܢܐ ܘܡܢ ܚܠܒܐ ܕܡܪܥܝܬܗ ܠܐ ܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 9:8",
      "text": "ܕܠܡܐ ܐܝܟ ܒܪܢܫܐ ܗܠܝܢ ܐܡܪ ܐܢܐ ܗܐ ܐܦ ܢܡܘܤܐ ܗܠܝܢ ܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 9:9",
      "text": "ܟܬܝܒ ܓܝܪ ܒܗ ܒܢܡܘܤܐ ܕܡܘܫܐ ܕܠܐ ܬܒܠܘܡ ܬܘܪܐ ܕܡܕܪܟ ܠܡܐ ܥܠ ܬܘܪܐ ܒܛܝܠ ܠܗ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 9:10",
      "text": "ܐܠܐ ܝܕܝܥܐ ܕܡܛܠܬܢ ܗܘ ܐܡܪ ܘܡܛܠܬܢ ܓܝܪ ܐܬܟܬܒܬ ܡܛܠ ܕܥܠ ܤܒܪܐ ܗܘ ܘܠܐ ܠܗ ܠܟܪܘܒܐ ܕܢܟܪܘܒ ܘܐܝܢܐ ܕܡܕܪܟ ܥܠ ܤܒܪܐ ܕܥܠܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 9:11",
      "text": "ܐܢ ܚܢܢ ܕܪܘܚܐ ܙܪܥܢ ܒܟܘܢ ܪܒܐ ܗܝ ܐܢ ܚܢܢ ܡܢܟܘܢ ܕܦܓܪܐ ܢܚܨܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 9:12",
      "text": "ܘܐܢ ܠܐܚܪܢܐ ܐܝܬ ܠܗܘܢ ܫܘܠܛܢܐ ܥܠܝܟܘܢ ܠܐ ܠܢ ܘܠܐ ܝܬܝܪܐܝܬ ܐܠܐ ܠܐ ܐܬܚܫܚܢ ܒܫܘܠܛܢܐ ܗܢܐ ܐܠܐ ܟܠܡܕܡ ܡܤܝܒܪܝܢܢ ܕܒܡܕܡ ܠܐ ܢܬܟܤ ܤܒܪܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 9:13",
      "text": "ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܐܝܠܝܢ ܕܒܝܬ ܩܘܕܫܐ ܦܠܚܝܢ ܡܢ ܒܝܬ ܩܘܕܫܐ ܡܤܬܝܒܪܝܢ ܘܐܝܠܝܢ ܕܠܡܕܒܚܐ ܦܠܚܝܢ ܥܡ ܡܕܒܚܐ ܦܠܓܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 9:14",
      "text": "ܗܟܢܐ ܐܦ ܡܪܢ ܦܩܕ ܕܐܝܠܝܢ ܕܤܒܪܬܗ ܡܟܪܙܝܢ ܡܢ ܤܒܪܬܗ ܢܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 9:15",
      "text": "ܐܢܐ ܕܝܢ ܠܐ ܐܬܚܫܚܬ ܒܚܕܐ ܡܢ ܗܠܝܢ ܘܠܘ ܡܛܠ ܗܕܐ ܟܬܒܬ ܕܗܟܢܐ ܢܗܘܐ ܠܝ ܦܩܚ ܠܝ ܓܝܪ ܕܡܡܬ ܐܡܘܬ ܘܠܐ ܕܐܢܫ ܫܘܒܗܪܝ ܢܤܪܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 9:16",
      "text": "ܐܦ ܕܡܤܒܪ ܐܢܐ ܓܝܪ ܠܝܬ ܠܝ ܫܘܒܗܪܐ ܩܛܝܪܐ ܓܝܪ ܤܝܡ ܥܠܝ ܘܝ ܠܝ ܕܝܢ ܐܠܐ ܐܤܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.17",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 9:17",
      "text": "ܐܢ ܓܝܪ ܒܨܒܝܢܝ ܗܕܐ ܤܥܪ ܐܢܐ ܐܓܪܐ ܐܝܬ ܠܝ ܐܢ ܕܝܢ ܕܠܐ ܒܨܒܝܢܝ ܪܒܬ ܒܝܬܘܬܐ ܗܘ ܡܗܝܡܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.18",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 9:18",
      "text": "ܐܝܢܐ ܗܘ ܗܟܝܠ ܐܓܪܝ ܕܟܕ ܡܤܒܪ ܐܢܐ ܕܠܐ ܢܦܩܬܐ ܐܥܒܕܝܗ ܠܤܒܪܬܗ ܕܡܫܝܚܐ ܘܠܐ ܐܬܚܫܚ ܒܫܘܠܛܢܐ ܕܝܗܒ ܠܝ ܒܐܘܢܓܠܝܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.19",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 9:19",
      "text": "ܟܕ ܡܚܪܪ ܐܢܐ ܓܝܪ ܡܢ ܟܠܗܝܢ ܠܟܠܢܫ ܫܥܒܕܬ ܢܦܫܝ ܕܠܤܓܝܐܐ ܐܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.20",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 9:20",
      "text": "ܘܗܘܝܬ ܥܡ ܝܗܘܕܝܐ ܐܝܟ ܝܗܘܕܝܐ ܕܠܝܗܘܕܝܐ ܐܬܪ ܘܥܡ ܕܬܚܝܬ ܢܡܘܤܐ ܐܢܘܢ ܗܘܝܬ ܐܝܟ ܕܬܚܝܬ ܢܡܘܤܐ ܕܠܐܝܠܝܢ ܕܬܚܝܬ ܢܡܘܤܐ ܐܢܘܢ ܐܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.21",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 9:21",
      "text": "ܘܠܐܝܠܝܢ ܕܢܡܘܤܐ ܠܝܬ ܠܗܘܢ ܗܘܝܬ ܐܝܟ ܕܠܐ ܢܡܘܤ ܟܕ ܠܐ ܐܝܬܝ ܠܐܠܗܐ ܕܠܐ ܢܡܘܤ ܐܠܐ ܒܢܡܘܤܗ ܕܡܫܝܚܐ ܕܐܦ ܠܗܢܘܢ ܕܕܠܐ ܢܡܘܤ ܐܢܘܢ ܐܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.22",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 9:22",
      "text": "ܗܘܝܬ ܥܡ ܟܪܝܗܐ ܐܝܟ ܟܪܝܗܐ ܕܠܟܪܝܗܐ ܐܬܪ ܠܟܠܢܫ ܟܠ ܗܘܝܬ ܕܠܟܠܢܫ ܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.9.23",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 9:23",
      "text": "ܗܕܐ ܕܝܢ ܥܒܕ ܐܢܐ ܡܛܠ ܕܐܗܘܐ ܫܘܬܦܐ ܠܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
