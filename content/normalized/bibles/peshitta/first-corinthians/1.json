  "verses": [
    {
      "id": "peshitta:first-corinthians.1.1",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 1:1",
      "text": "ܦܘܠܘܤ ܩܪܝܐ ܘܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܘܤܘܤܬܢܤ ܐܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.1.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 1:2",
      "text": "ܠܥܕܬܐ ܕܐܠܗܐ ܕܒܩܘܪܢܬܘܤ ܩܪܝܐ ܘܩܕܝܫܐ ܕܒܝܫܘܥ ܡܫܝܚܐ ܡܩܕܫܝܢ ܘܠܟܠܗܘܢ ܐܝܠܝܢ ܕܩܪܝܢ ܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܒܟܠ ܐܬܪ ܕܝܠܗܘܢ ܘܕܝܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 1:3",
      "text": "ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 1:4",
      "text": "ܡܘܕܐ ܐܢܐ ܠܐܠܗܝ ܒܟܠܙܒܢ ܚܠܦܝܟܘܢ ܥܠ ܛܝܒܘܬܐ ܕܐܠܗܐ ܕܐܬܝܗܒܬ ܠܟܘܢ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 1:5",
      "text": "ܕܒܟܠ ܡܕܡ ܥܬܪܬܘܢ ܒܗ ܒܟܠ ܡܠܐ ܘܒܟܠ ܝܕܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 1:6",
      "text": "ܐܝܟ ܕܤܗܕܘܬܗ ܕܡܫܝܚܐ ܐܫܬܪܪܬ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 1:7",
      "text": "ܕܠܐ ܐܬܒܨܪܬܘܢ ܒܚܕܐ ܡܢ ܡܘܗܒܬܗ ܐܠܐ ܡܤܟܝܢ ܐܢܬܘܢ ܠܓܠܝܢܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 1:8",
      "text": "ܕܗܘ ܢܫܪܪܟܘܢ ܥܕܡܐ ܠܐܚܪܝܬܐ ܕܕܠܐ ܪܫܝܢ ܬܗܘܘܢ ܒܝܘܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 1:9",
      "text": "ܡܗܝܡܢ ܗܘ ܐܠܗܐ ܕܒܐܝܕܗ ܐܬܩܪܝܬܘܢ ܠܫܘܬܦܘܬܐ ܕܒܪܗ ܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 1:10",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܬܗܘܐ ܚܕܐ ܡܠܬܐ ܠܟܠܟܘܢ ܘܠܐ ܢܗܘܝܢ ܒܟܘܢ ܦܠܓܘܬܐ ܐܠܐ ܬܗܘܘܢ ܓܡܝܪܝܢ ܒܚܕܐ ܬܪܥܝܬܐ ܘܒܚܕ ܪܥܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 1:11",
      "text": "ܫܠܚܘ ܠܝ ܓܝܪ ܥܠܝܟܘܢ ܐܚܝ ܡܢ ܒܝܬ ܟܠܐܐ ܕܚܪܝܢܐ ܐܝܬ ܒܝܢܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 1:12",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܐܢܐ ܕܐܝܬ ܡܢܟܘܢ ܕܐܡܪ ܐܢܐ ܕܦܘܠܘܤ ܐܢܐ ܘܐܝܬ ܕܐܡܪ ܐܢܐ ܕܐܦܠܘ ܐܢܐ ܘܐܝܬ ܕܐܡܪ ܐܢܐ ܕܟܐܦܐ ܐܢܐ ܘܐܝܬ ܕܐܡܪ ܐܢܐ ܕܡܫܝܚܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 1:13",
      "text": "ܕܠܡܐ ܐܬܦܠܓ ܠܗ ܡܫܝܚܐ ܐܘ ܠܡܐ ܦܘܠܘܤ ܐܙܕܩܦ ܥܠ ܐܦܝܟܘܢ ܐܘ ܒܫܡܗ ܕܦܘܠܘܤ ܥܡܕܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 1:14",
      "text": "ܡܘܕܐ ܐܢܐ ܠܐܠܗܝ ܕܠܐܢܫ ܡܢܟܘܢ ܠܐ ܐܥܡܕܬ ܐܠܐ ܠܟܪܝܤܦܘܤ ܘܠܓܐܝܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 1:15",
      "text": "ܕܠܐ ܐܢܫ ܢܐܡܪ ܕܒܫܡܝ ܐܥܡܕܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 1:16",
      "text": "ܐܥܡܕܬ ܕܝܢ ܐܦ ܠܒܝܬܗ ܕܐܤܛܦܢܐ ܬܘܒ ܕܝܢ ܠܐ ܝܕܥ ܐܢܐ ܐܢ ܠܐܢܫ ܐܚܪܝܢ ܐܥܡܕܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.17",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 1:17",
      "text": "ܠܐ ܓܝܪ ܫܕܪܢܝ ܡܫܝܚܐ ܠܡܥܡܕܘ ܐܠܐ ܠܡܤܒܪܘ ܠܐ ܒܚܟܡܬ ܡܠܐ ܕܠܐ ܢܤܬܪܩ ܙܩܝܦܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.18",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 1:18",
      "text": "ܡܠܬܐ ܓܝܪ ܕܙܩܝܦܐ ܠܐܒܝܕܐ ܫܛܝܘܬܐ ܗܝ ܠܢ ܕܝܢ ܠܐܝܠܝܢ ܕܚܝܝܢܢ ܚܝܠܐ ܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.19",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 1:19",
      "text": "ܟܬܝܒ ܓܝܪ ܕܐܘܒܕ ܚܟܡܬܐ ܕܚܟܝܡܐ ܘܐܓܠܘܙ ܬܪܥܝܬܐ ܕܤܟܘܠܬܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.20",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 1:20",
      "text": "ܐܝܟܐ ܗܘ ܚܟܝܡܐ ܐܘ ܐܝܟܐ ܗܘ ܤܦܪܐ ܐܘ ܐܝܟܐ ܗܘ ܕܪܘܫܐ ܕܥܠܡܐ ܗܢܐ ܠܐ ܗܐ ܐܫܛܝܗ ܐܠܗܐ ܚܟܡܬܗ ܕܥܠܡܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.21",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 1:21",
      "text": "ܡܛܠ ܓܝܪ ܕܒܚܟܡܬܗ ܕܐܠܗܐ ܠܐ ܝܕܥ ܥܠܡܐ ܒܚܟܡܬܐ ܠܐܠܗܐ ܨܒܐ ܐܠܗܐ ܕܒܫܛܝܘܬܐ ܕܟܪܘܙܘܬܐ ܢܚܐ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.22",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 1:22",
      "text": "ܡܛܠ ܕܝܗܘܕܝܐ ܐܬܘܬܐ ܫܐܠܝܢ ܘܐܪܡܝܐ ܚܟܡܬܐ ܒܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.23",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 1:23",
      "text": "ܚܢܢ ܕܝܢ ܡܟܪܙܝܢܢ ܡܫܝܚܐ ܟܕ ܙܩܝܦ ܬܘܩܠܬܐ ܠܝܗܘܕܝܐ ܘܠܐܪܡܝܐ ܫܛܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.24",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "1 Corinthians 1:24",
      "text": "ܠܗܢܘܢ ܕܝܢ ܕܩܪܝܢ ܝܗܘܕܝܐ ܘܐܪܡܝܐ ܡܫܝܚܐ ܚܝܠܐ ܕܐܠܗܐ ܘܚܟܡܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.25",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "1 Corinthians 1:25",
      "text": "ܡܛܠ ܕܫܛܝܘܬܗ ܕܐܠܗܐ ܚܟܝܡܐ ܗܝ ܡܢ ܒܢܝܢܫܐ ܘܟܪܝܗܘܬܗ ܕܐܠܗܐ ܚܝܠܬܢܝܐ ܗܝ ܡܢ ܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.26",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 1:26",
      "text": "ܚܙܘ ܓܝܪ ܐܦ ܩܪܝܬܟܘܢ ܐܚܝ ܕܠܐ ܤܓܝܐܝܢ ܒܟܘܢ ܚܟܝܡܐ ܒܒܤܪ ܘܠܐ ܤܓܝܐܝܢ ܒܟܘܢ ܚܝܠܬܢܐ ܘܠܐ ܤܓܝܐܝܢ ܒܟܘܢ ܒܢܝ ܛܘܗܡܐ ܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.1.27",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "1 Corinthians 1:27",
      "text": "ܐܠܐ ܓܒܐ ܐܠܗܐ ܠܤܟܠܘܗܝ ܕܥܠܡܐ ܕܢܒܗܬ ܠܚܟܝܡܐ ܘܓܒܐ ܟܪܝܗܘܗܝ ܕܥܠܡܐ ܕܢܒܗܬ ܠܚܝܠܬܢܐ ܀",
