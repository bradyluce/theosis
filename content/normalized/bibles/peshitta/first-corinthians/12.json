    {
      "id": "peshitta:first-corinthians.12.26",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "1 Corinthians 12:26",
      "text": "ܕܐܡܬܝ ܕܚܕ ܗܕܡ ܢܗܘܐ ܟܐܒ ܟܠܗܘܢ ܢܗܘܘܢ ܚܫܝܢ ܘܐܢ ܡܫܬܒܚ ܚܕ ܗܕܡ ܟܠܗܘܢ ܗܕܡܐ ܢܗܘܘܢ ܡܫܬܒܚܝܢ ܀",
