      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 12:1",
      "text": "ܥܠ ܪܘܚܢܝܬܐ ܕܝܢ ܐܚܝ ܨܒܐ ܐܢܐ ܕܬܕܥܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.12.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 12:2",
      "text": "ܕܚܢܦܐ ܗܘܝܬܘܢ ܘܠܦܬܟܪܐ ܐܝܠܝܢ ܕܠܝܬ ܠܗܘܢ ܩܠܐ ܕܠܐ ܦܘܪܫܢ ܡܬܕܒܪܝܢ ܗܘܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 12:3",
      "text": "ܡܛܠ ܗܢܐ ܡܘܕܥ ܐܢܐ ܠܟܘܢ ܕܠܝܬ ܐܢܫ ܕܒܪܘܚܐ ܕܐܠܗܐ ܡܡܠܠ ܘܐܡܪ ܕܚܪܡ ܗܘ ܝܫܘܥ ܘܐܦܠܐ ܐܢܫ ܡܫܟܚ ܠܡܐܡܪ ܕܡܪܝܐ ܗܘ ܝܫܘܥ ܐܠܐ ܐܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 12:4",
      "text": "ܦܘܠܓܐ ܕܝܢ ܕܡܘܗܒܬܐ ܐܝܬܝܗܘܢ ܐܠܐ ܚܕܐ ܗܝ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 12:5",
      "text": "ܘܦܘܠܓܐ ܕܬܫܡܫܬܐ ܐܝܬܝܗܘܢ ܐܠܐ ܚܕ ܗܘ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 12:6",
      "text": "ܘܦܘܠܓܐ ܕܚܝܠܘܬܐ ܐܝܬ ܐܠܐ ܚܕ ܗܘ ܐܠܗܐ ܕܡܥܒܕ ܟܠ ܒܟܠܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 12:7",
      "text": "ܠܐܢܫ ܐܢܫ ܕܝܢ ܡܬܝܗܒ ܠܗ ܓܠܝܢܐ ܕܪܘܚܐ ܐܝܟ ܕܥܕܪܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 12:8",
      "text": "ܐܝܬ ܕܝܗܝܒܐ ܠܗ ܒܪܘܚܐ ܡܠܬܐ ܕܚܟܡܬܐ ܠܐܚܪܢܐ ܕܝܢ ܡܠܬܐ ܕܝܕܥܬܐ ܒܗ ܒܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 12:9",
      "text": "ܠܐܚܪܢܐ ܗܝܡܢܘܬܐ ܒܗ ܒܪܘܚܐ ܠܐܚܪܢܐ ܡܘܗܒܬܐ ܕܐܤܝܘܬܐ ܒܗ ܒܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 12:10",
      "text": "ܠܐܚܪܢܐ ܕܝܢ ܚܝܠܐ ܠܐܚܪܢܐ ܕܝܢ ܢܒܝܘܬܐ ܠܐܚܪܢܐ ܕܝܢ ܦܪܘܫܘܬܐ ܕܪܘܚܐ ܠܐܚܪܢܐ ܕܝܢ ܙܢܝܐ ܕܠܫܢܐ ܠܐܚܪܢܐ ܕܝܢ ܦܘܫܩܐ ܕܠܫܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 12:11",
      "text": "ܟܠܗܝܢ ܕܝܢ ܗܠܝܢ ܚܕܐ ܗܝ ܪܘܚܐ ܤܥܪܐ ܘܡܦܠܓܐ ܠܟܠܢܫ ܐܝܟ ܕܗܝ ܨܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 12:12",
      "text": "ܐܟܙܢܐ ܓܝܪ ܕܦܓܪܐ ܚܕ ܗܘ ܘܐܝܬ ܒܗ ܗܕܡܐ ܤܓܝܐܐ ܟܠܗܘܢ ܕܝܢ ܗܕܡܐ ܕܦܓܪܐ ܟܕ ܤܓܝܐܐ ܐܝܬܝܗܘܢ ܚܕ ܐܢܘܢ ܦܓܪ ܗܟܢܐ ܐܦ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 12:13",
      "text": "ܐܦ ܚܢܢ ܓܝܪ ܟܠܢ ܒܚܕܐ ܪܘܚ ܠܚܕ ܦܓܪ ܥܡܕܢ ܐܢ ܝܗܘܕܝܐ ܘܐܢ ܐܪܡܝܐ ܘܐܢ ܥܒܕܐ ܘܐܢ ܒܢܝ ܚܐܪܐ ܘܟܠܢ ܚܕܐ ܪܘܚܐ ܐܫܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 12:14",
      "text": "ܐܦ ܦܓܪܐ ܓܝܪ ܠܐ ܗܘܐ ܚܕ ܗܕܡ ܐܠܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 12:15",
      "text": "ܐܢ ܬܐܡܪ ܓܝܪ ܪܓܠܐ ܕܡܛܠ ܕܠܐ ܗܘܝܬ ܐܝܕܐ ܠܐ ܗܘܝܬ ܡܢܗ ܡܢ ܦܓܪܐ ܠܘ ܡܛܠ ܗܕܐ ܠܝܬܝܗ ܡܢܗ ܡܢ ܦܓܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.12.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 12:16",
      "text": "ܘܐܢ ܬܐܡܪ ܐܕܢܐ ܥܠ ܕܠܐ ܗܘܝܬ ܥܝܢܐ ܠܐ ܗܘܝܬ ܡܢܗ ܡܢ ܦܓܪܐ ܠܘ ܡܛܠ ܗܕܐ ܠܝܬܝܗ ܡܢܗ ܡܢ ܦܓܪܐ ܀",
      "paragraphStart": false
    },
    {
