    "referenceLabel": "1 Corinthians 16",
    "summary": "Source text for 1 Corinthians 16 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-corinthians.16.1",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 16:1",
      "text": "ܥܠ ܡܕܡ ܕܝܢ ܕܡܬܟܢܫ ܠܩܕܝܫܐ ܐܝܟܢܐ ܕܦܩܕܬ ܠܥܕܬܐ ܕܓܠܛܝܐ ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܥܒܕܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.16.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 16:2",
      "text": "ܒܟܠ ܚܕ ܒܫܒܐ ܐܢܫ ܐܢܫ ܡܢܟܘܢ ܒܒܝܬܗ ܢܗܘܐ ܤܐܡ ܘܢܛܪ ܗܘ ܡܕܡ ܕܡܛܐ ܒܐܝܕܘܗܝ ܕܠܐ ܡܐ ܕܐܬܝܬ ܗܝܕܝܢ ܢܗܘܝܢ ܓܒܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 16:3",
      "text": "ܘܡܐ ܕܐܬܝܬ ܠܐܝܠܝܢ ܕܓܒܝܢ ܐܢܬܘܢ ܠܗܘܢ ܐܫܕܪ ܒܐܓܪܬܐ ܕܢܘܒܠܘܢ ܛܝܒܘܬܟܘܢ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 16:4",
      "text": "ܐܢ ܕܝܢ ܫܘܐ ܗܘ ܤܘܥܪܢܐ ܕܐܦ ܐܢܐ ܐܙܠ ܥܡܝ ܢܐܙܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 16:5",
      "text": "ܐܬܐ ܐܢܐ ܕܝܢ ܠܘܬܟܘܢ ܡܐ ܕܥܒܪܬ ܡܢ ܡܩܕܘܢܝܐ ܥܒܪ ܐܢܐ ܠܗ ܓܝܪ ܠܡܩܕܘܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 16:6",
      "text": "ܘܟܒܪ ܐܦ ܠܘܬܟܘܢ ܐܩܘܐ ܐܘ ܐܤܬܐ ܠܘܬܟܘܢ ܕܐܢܬܘܢ ܬܠܘܘܢܢܝ ܠܐܬܪ ܕܐܙܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 16:7",
      "text": "ܠܐ ܓܝܪ ܨܒܐ ܐܢܐ ܕܗܫܐ ܐܝܟ ܥܒܪ ܐܘܪܚܐ ܐܚܙܝܟܘܢ ܡܤܒܪ ܐܢܐ ܓܝܪ ܕܐܘܚܪ ܙܒܢܐ ܠܘܬܟܘܢ ܐܢ ܡܪܝ ܡܦܤ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 16:8",
      "text": "ܡܩܘܐ ܐܢܐ ܕܝܢ ܒܐܦܤܘܤ ܥܕܡܐ ܠܦܢܛܩܘܤܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 16:9",
      "text": "ܬܪܥܐ ܓܝܪ ܪܒܐ ܐܬܦܬܚ ܠܝ ܕܡܠܐ ܤܘܥܪܢܐ ܘܤܩܘܒܠܐ ܤܓܝܐܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 16:10",
      "text": "ܐܢ ܕܝܢ ܢܐܬܐ ܨܐܕܝܟܘܢ ܛܝܡܬܐܘܤ ܚܙܘ ܕܕܠܐ ܕܚܠܐ ܢܗܘܐ ܠܘܬܟܘܢ ܥܒܕܐ ܓܝܪ ܕܡܪܝܐ ܦܠܚ ܐܟܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 16:11",
      "text": "ܠܡܐ ܗܟܝܠ ܐܢܫ ܢܫܘܛܝܘܗܝ ܐܠܐ ܠܘܐܘܗܝ ܒܫܠܡܐ ܕܢܐܬܐ ܠܘܬܝ ܡܩܘܐ ܐܢܐ ܠܗ ܓܝܪ ܥܡ ܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 16:12",
      "text": "ܡܢ ܐܦܠܘ ܕܝܢ ܐܚܝ ܤܓܝ ܒܥܝܬ ܡܢܗ ܕܢܐܬܐ ܠܘܬܟܘܢ ܥܡ ܐܚܐ ܘܟܒܪ ܠܐ ܗܘܐ ܨܒܝܢܐ ܕܢܐܬܐ ܠܘܬܟܘܢ ܐܡܬܝ ܕܝܢ ܕܢܗܘܐ ܠܗ ܐܬܪܐ ܐܬܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 16:13",
      "text": "ܐܬܬܥܝܪܘ ܘܩܘܡܘ ܒܗܝܡܢܘܬܐ ܐܬܓܒܪܘ ܐܬܚܤܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 16:14",
      "text": "ܘܟܠܗܝܢ ܨܒܘܬܟܘܢ ܒܚܘܒܐ ܢܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 16:15",
      "text": "ܒܥܐ ܐܢܐ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܥܠ ܒܝܬܐ ܕܐܤܛܦܢܐ ܡܛܠ ܕܝܕܥܝܢ ܐܢܬܘܢ ܕܗܢܘܢ ܐܢܘܢ ܪܫܝܬܐ ܕܐܟܐܝܐ ܘܤܡܘ ܢܦܫܗܘܢ ܠܬܫܡܫܬܐ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 16:16",
      "text": "ܕܐܦ ܐܢܬܘܢ ܬܗܘܘܢ ܡܫܬܡܥܝܢ ܠܐܝܠܝܢ ܕܗܟܢܐ ܐܢܘܢ ܘܠܟܠܢܫ ܕܠܐܐ ܥܡܢ ܘܡܥܕܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.17",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 16:17",
      "text": "ܚܕܐ ܐܢܐ ܕܝܢ ܒܡܐܬܝܬܗ ܕܐܤܛܦܢܐ ܘܕܦܪܛܘܢܛܘܤ ܘܕܐܟܐܝܩܘܤ ܕܡܕܡ ܕܒܨܪܬܘܢ ܠܘܬܝ ܗܢܘܢ ܡܠܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.18",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 16:18",
      "text": "ܐܢܝܚܘ ܓܝܪ ܪܘܚܝ ܕܝܠܝ ܘܕܝܠܟܘܢ ܗܘܝܬܘܢ ܗܟܝܠ ܡܫܬܘܕܥܝܢ ܠܐܝܠܝܢ ܕܗܟܢܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.19",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 16:19",
      "text": "ܫܐܠܢ ܒܫܠܡܟܘܢ ܥܕܬܐ ܟܠܗܝܢ ܕܒܐܤܝܐ ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܤܓܝ ܒܡܪܢ ܐܩܠܘܤ ܘܦܪܝܤܩܠܐ ܥܡ ܥܕܬܐ ܕܒܒܝܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.20",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 16:20",
      "text": "ܫܐܠܝܢ ܒܫܠܡܟܘܢ ܐܚܝܢ ܟܠܗܘܢ ܫܐܠܘ ܒܫܠܡܐ ܚܕ ܕܚܕ ܒܢܘܫܩܬܐ ܩܕܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.16.21",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 16:21",
      "text": "ܫܠܡܐ ܒܟܬܒܬ ܐܝܕܐ ܕܝܠܝ ܕܦܘܠܘܤ ܀",
