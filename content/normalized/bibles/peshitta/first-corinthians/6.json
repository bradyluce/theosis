  "verses": [
    {
      "id": "peshitta:first-corinthians.6.1",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 6:1",
      "text": "ܡܡܪܚ ܐܢܫ ܡܢܟܘܢ ܟܕ ܐܝܬ ܠܗ ܕܝܢܐ ܥܡ ܐܚܘܗܝ ܕܢܕܘܢ ܩܕܡ ܥܘܠܐ ܘܠܐ ܩܕܡ ܩܕܝܫܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.6.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 6:2",
      "text": "ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܩܕܝܫܐ ܠܥܠܡܐ ܢܕܘܢܘܢ ܘܐܢ ܥܠܡܐ ܒܟܘܢ ܡܬܕܝܢ ܠܐ ܫܘܝܢ ܐܢܬܘܢ ܠܡܕܢ ܕܝܢܐ ܕܩܕܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 6:3",
      "text": "ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܠܡܠܐܟܐ ܕܝܢܝܢܢ ܚܕ ܟܡܐ ܐܝܠܝܢ ܕܕܥܠܡܐ ܐܢܝܢ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 6:4",
      "text": "ܐܠܐ ܐܢ ܐܝܬ ܠܟܘܢ ܕܝܢܐ ܥܠ ܕܥܠܡܐ ܠܐܝܠܝܢ ܕܒܤܝܢ ܒܥܕܬܐ ܐܘܬܒܘ ܠܟܘܢ ܒܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 6:5",
      "text": "ܠܟܘܐܪܐ ܗܘ ܕܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܗܟܢܐ ܠܝܬ ܒܟܘܢ ܐܦܠܐ ܚܕ ܚܟܝܡܐ ܕܢܫܟܚ ܢܫܘܐ ܒܝܬ ܐܚܐ ܠܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 6:6",
      "text": "ܐܠܐ ܐܚܐ ܥܡ ܐܚܘܗܝ ܡܬܕܝܢ ܘܬܘܒ ܩܕܡ ܐܝܠܝܢ ܕܠܐ ܡܗܝܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 6:7",
      "text": "ܡܢ ܟܕܘ ܗܟܝܠ ܩܢܘܡܟܘܢ ܚܒܬܘܢ ܠܟܘܢ ܕܕܝܢܐ ܚܕ ܥܡ ܚܕ ܐܝܬ ܠܟܘܢ ܡܛܠ ܡܢܐ ܓܝܪ ܠܐ ܡܬܥܠܒܝܢ ܐܢܬܘܢ ܘܡܛܠ ܡܢܐ ܠܐ ܡܬܓܠܙܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 6:8",
      "text": "ܐܠܐ ܐܢܬܘܢ ܥܠܒܝܢ ܐܢܬܘܢ ܘܓܠܙܝܢ ܐܢܬܘܢ ܐܦ ܠܐܚܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 6:9",
      "text": "ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܥܘܠܐ ܡܠܟܘܬܗ ܕܐܠܗܐ ܠܐ ܝܪܬܝܢ ܠܐ ܬܛܥܘܢ ܠܐ ܙܢܝܐ ܘܠܐ ܦܠܚܝ ܦܬܟܪܐ ܘܠܐ ܓܝܪܐ ܘܠܐ ܡܚܒܠܐ ܘܠܐ ܫܟܒܝ ܥܡ ܕܟܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 6:10",
      "text": "ܘܠܐ ܥܠܘܒܐ ܘܠܐ ܓܢܒܐ ܘܠܐ ܪܘܝܐ ܘܠܐ ܡܨܥܪܢܐ ܘܠܐ ܚܛܘܦܐ ܗܠܝܢ ܡܠܟܘܬܗ ܕܐܠܗܐ ܠܐ ܝܪܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 6:11",
      "text": "ܘܗܠܝܢ ܐܝܬ ܗܘܝ ܒܐܢܫ ܐܢܫ ܡܢܟܘܢ ܐܠܐ ܤܚܝܬܘܢ ܘܐܬܩܕܫܬܘܢ ܘܐܙܕܕܩܬܘܢ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܒܪܘܚܗ ܕܐܠܗܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 6:12",
      "text": "ܟܠ ܫܠܝܛ ܠܝ ܐܠܐ ܠܐ ܟܠ ܦܩܚ ܠܝ ܟܠ ܫܠܝܛ ܠܝ ܐܠܐ ܥܠܝ ܐܢܫ ܠܐ ܢܫܬܠܛ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 6:13",
      "text": "ܡܐܟܘܠܬܐ ܕܟܪܤܐ ܘܟܪܤܐ ܕܡܐܟܘܠܬܐ ܐܠܗܐ ܕܝܢ ܠܬܪܬܝܗܝܢ ܡܒܛܠ ܦܓܪܐ ܕܝܢ ܠܐ ܠܙܢܝܘܬܐ ܐܠܐ ܠܡܪܢ ܘܡܪܢ ܠܦܓܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 6:14",
      "text": "ܐܠܗܐ ܕܝܢ ܘܠܡܪܢ ܐܩܝܡ ܘܠܢ ܡܩܝܡ ܒܚܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 6:15",
      "text": "ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܦܓܪܝܟܘܢ ܗܕܡܐ ܐܢܘܢ ܕܡܫܝܚܐ ܢܤܒ ܗܕܡܐ ܕܡܫܝܚܐ ܢܥܒܕܝܘܗܝ ܗܕܡܐ ܕܙܢܝܬܐ ܚܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 6:16",
      "text": "ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܡܢ ܕܢܩܦ ܠܙܢܝܬܐ ܚܕ ܗܘ ܦܓܪ ܐܡܝܪ ܓܝܪ ܕܢܗܘܘܢ ܬܪܝܗܘܢ ܚܕ ܦܓܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.17",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 6:17",
      "text": "ܡܢ ܕܢܩܦ ܕܝܢ ܠܡܪܢ ܗܘܐ ܥܡܗ ܚܕܐ ܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.18",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 6:18",
      "text": "ܥܪܘܩܘ ܡܢ ܙܢܝܘܬܐ ܟܠ ܚܛܝܬܐ ܕܢܥܒܕ ܒܪܢܫܐ ܠܒܪ ܡܢ ܦܓܪܗ ܗܝ ܡܢ ܕܡܙܢܐ ܕܝܢ ܒܦܓܪܗ ܗܘ ܚܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.19",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 6:19",
      "text": "ܐܘ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܦܓܪܟܘܢ ܗܝܟܠܐ ܗܘ ܕܪܘܚܐ ܕܩܘܕܫܐ ܕܥܡܪܐ ܒܟܘܢ ܗܝ ܕܩܒܠܬܘܢ ܡܢ ܐܠܗܐ ܘܠܐ ܗܘܝܬܘܢ ܕܢܦܫܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.6.20",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 6:20",
      "text": "ܐܙܕܒܢܬܘܢ ܓܝܪ ܒܕܡܝܐ ܗܘܝܬܘܢ ܗܟܝܠ ܡܫܒܚܝܢ ܠܐܠܗܐ ܒܦܓܪܟܘܢ ܘܒܪܘܚܟܘܢ ܗܢܘܢ ܕܐܝܬܝܗܘܢ ܕܐܠܗܐ ܀",
