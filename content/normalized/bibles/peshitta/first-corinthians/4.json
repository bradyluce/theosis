  "verses": [
    {
      "id": "peshitta:first-corinthians.4.1",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 4:1",
      "text": "ܗܟܢܐ ܗܘܝܢ ܚܫܝܒܝܢ ܠܟܘܢ ܐܝܟ ܡܫܡܫܢܐ ܕܡܫܝܚܐ ܘܪܒܝ ܒܬܐ ܕܐܪܙܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.4.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 4:2",
      "text": "ܗܪܟܐ ܡܟܝܠ ܡܬܒܥܐ ܒܪܒܝ ܒܬܐ ܕܐܢܫ ܟܕ ܡܗܝܡܢ ܢܫܬܟܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 4:3",
      "text": "ܠܝ ܕܝܢ ܗܕܐ ܒܨܝܪܘܬܐ ܗܝ ܠܝ ܕܡܢܟܘܢ ܐܬܕܝܢ ܐܘ ܡܢ ܟܠ ܒܪ ܐܢܫ ܐܠܐ ܐܦܠܐ ܐܢܐ ܢܦܫܝ ܕܐܢ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 4:4",
      "text": "ܠܐ ܓܝܪ ܡܕܡ ܒܢܦܫܝ ܚܫܝܫ ܐܢܐ ܐܠܐ ܠܘ ܒܗܕܐ ܐܙܕܕܩܬ ܕܝܢܝ ܓܝܪ ܡܪܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 4:5",
      "text": "ܡܛܠ ܗܢܐ ܠܐ ܡܢ ܩܕܡ ܙܒܢܐ ܬܗܘܘܢ ܕܝܢܝܢ ܥܕܡܐ ܕܢܐܬܐ ܡܪܝܐ ܗܘ ܕܡܢܗܪ ܟܤܝܬܗ ܕܚܫܘܟܐ ܘܓܠܐ ܡܚܫܒܬܗܘܢ ܕܠܒܘܬܐ ܘܗܝܕܝܢ ܢܗܘܐ ܫܘܒܚܐ ܠܐܢܫ ܐܢܫ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 4:6",
      "text": "ܗܠܝܢ ܕܝܢ ܐܚܝ ܡܛܠܬܟܘܢ ܗܘ ܤܡܬ ܥܠ ܦܪܨܘܦܐ ܕܝܠܝ ܘܕܐܦܠܘ ܕܒܢ ܬܐܠܦܘܢ ܕܠܐ ܬܬܪܥܘܢ ܝܬܝܪ ܡܢ ܡܐ ܕܟܬܝܒ ܘܐܢܫ ܥܠ ܚܒܪܗ ܠܐ ܢܬܪܝܡ ܡܛܠ ܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 4:7",
      "text": "ܡܢܘ ܓܝܪ ܒܨܟ ܐܘ ܡܢܐ ܐܝܬ ܠܟ ܕܠܐ ܢܤܒܬ ܘܐܢ ܢܤܒܬ ܠܡܢܐ ܡܫܬܒܗܪ ܐܢܬ ܐܝܟ ܗܘ ܕܠܐ ܢܤܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 4:8",
      "text": "ܡܢ ܟܕܘ ܤܒܥܬܘܢ ܠܟܘܢ ܘܥܬܪܬܘܢ ܘܒܠܥܕܝܢ ܐܡܠܟܬܘܢ ܐܫܬܘܦ ܕܝܢ ܐܡܠܟܬܘܢ ܕܐܦ ܚܢܢ ܢܡܠܟ ܥܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 4:9",
      "text": "ܤܒܪ ܐܢܐ ܓܝܪ ܕܠܢ ܠܫܠܝܚܐ ܐܚܪܝܐ ܗܘ ܤܡܢ ܐܠܗܐ ܐܝܟ ܕܠܡܘܬܐ ܕܗܘܝܢ ܬܐܛܪܘܢ ܠܥܠܡܐ ܘܠܡܠܐܟܐ ܘܠܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 4:10",
      "text": "ܚܢܢ ܫܛܝܐ ܡܛܠ ܡܫܝܚܐ ܐܢܬܘܢ ܕܝܢ ܚܟܝܡܐ ܒܡܫܝܚܐ ܚܢܢ ܟܪܝܗܐ ܘܐܢܬܘܢ ܚܝܠܬܢܐ ܐܢܬܘܢ ܡܫܬܒܚܝܢ ܘܚܢܢ ܡܨܛܥܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 4:11",
      "text": "ܥܕܡܐ ܠܗܕܐ ܫܥܬܐ ܟܦܢܝܢܢ ܘܨܗܝܢܢ ܘܥܪܛܠܝܝܢܢ ܘܡܬܩܦܚܝܢܢ ܘܒܝܬ ܩܝܡܐ ܠܝܬ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 4:12",
      "text": "ܘܠܐܝܢܢ ܟܕ ܦܠܚܝܢܢ ܒܐܝܕܝܢ ܡܨܥܪܝܢ ܠܢ ܘܡܒܪܟܝܢܢ ܪܕܦܝܢ ܠܢ ܘܡܤܝܒܪܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 4:13",
      "text": "ܡܨܚܝܢ ܠܢ ܘܒܥܝܢܢ ܡܢܗܘܢ ܐܝܟ ܢܦܬܐ ܕܥܠܡܐ ܗܘܝܢ ܘܟܘܦܪܐ ܕܟܠܢܫ ܥܕܡܐ ܠܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 4:14",
      "text": "ܠܐ ܗܘܐ ܐܝܟ ܕܐܒܗܬܟܘܢ ܟܬܒ ܐܢܐ ܗܠܝܢ ܐܠܐ ܐܝܟ ܕܠܒܢܝܐ ܚܒܝܒܐ ܡܪܬܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 4:15",
      "text": "ܐܢ ܓܝܪ ܪܒܘ ܬܪܐܐ ܢܗܘܘܢ ܠܟܘܢ ܒܡܫܝܚܐ ܐܠܐ ܠܐ ܤܓܝܐܐ ܐܒܗܐ ܒܝܫܘܥ ܓܝܪ ܡܫܝܚܐ ܐܢܐ ܗܘ ܐܘܠܕܬܟܘܢ ܒܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 4:16",
      "text": "ܒܥܐ ܐܢܐ ܗܟܝܠ ܡܢܟܘܢ ܕܒܝ ܬܬܕܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.17",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 4:17",
      "text": "ܡܛܠ ܗܢܐ ܫܕܪܬ ܠܘܬܟܘܢ ܠܛܝܡܬܐܘܤ ܕܐܝܬܘܗܝ ܒܪܝ ܚܒܝܒܐ ܘܡܗܝܡܢܐ ܒܡܪܝܐ ܕܗܘ ܢܥܗܕܟܘܢ ܐܘܪܚܬܝ ܕܒܡܫܝܚܐ ܐܝܟ ܡܕܡ ܕܡܠܦ ܐܢܐ ܒܟܠܗܝܢ ܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.18",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 4:18",
      "text": "ܐܝܟ ܗܘ ܕܝܢ ܕܠܐ ܐܬܐ ܐܢܐ ܠܘܬܟܘܢ ܐܬܚܬܪܘ ܐܢܫܐ ܡܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.19",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 4:19",
      "text": "ܐܠܐ ܐܢ ܡܪܝܐ ܨܒܐ ܒܥܓܠ ܐܬܐ ܐܢܐ ܠܘܬܟܘܢ ܘܐܕܥ ܠܐ ܡܠܬܗܘܢ ܕܗܠܝܢ ܕܡܪܝܡܝܢ ܢܦܫܗܘܢ ܐܠܐ ܚܝܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.4.20",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 4:20",
      "text": "ܡܠܟܘܬܗ ܓܝܪ ܕܐܠܗܐ ܠܐ ܗܘܬ ܒܡܠܬܐ ܐܠܐ ܒܚܝܠܐ ܀",
      "paragraphStart": false
