      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 5:1",
      "text": "ܤܟܐ ܡܫܬܡܥܐ ܒܝܢܬܟܘܢ ܙܢܝܘܬܐ ܘܕܐܝܟ ܗܕܐ ܙܢܝܘܬܐ ܐܝܕܐ ܕܐܦܠܐ ܒܝܬ ܚܢܦܐ ܡܫܬܡܗܐ ܥܕܡܐ ܕܢܤܒ ܒܪܐ ܐܢܬܬ ܐܒܘܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.5.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 5:2",
      "text": "ܘܐܢܬܘܢ ܚܬܝܪܝܢ ܐܢܬܘܢ ܘܠܐ ܕܝܢ ܝܬܝܪܐܝܬ ܝܬܒܬܘܢ ܒܐܒܠܐ ܕܢܫܬܩܠ ܡܢ ܒܝܢܬܟܘܢ ܗܘ ܡܢ ܕܗܢܐ ܤܘܥܪܢܐ ܤܥܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 5:3",
      "text": "ܐܢܐ ܓܝܪ ܟܕ ܪܚܝܩ ܐܢܐ ܡܢܟܘܢ ܒܦܓܪ ܘܩܪܝܒ ܐܢܐ ܠܟܘܢ ܒܪܘܚ ܡܢ ܟܕܘ ܕܢܬ ܐܝܟ ܩܪܝܒܐ ܠܗܘ ܡܢ ܕܗܕܐ ܤܥܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 5:4",
      "text": "ܕܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܬܬܟܢܫܘܢ ܟܠܟܘܢ ܘܐܢܐ ܥܡܟܘܢ ܒܪܘܚ ܥܡ ܚܝܠܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 5:5",
      "text": "ܘܬܫܠܡܘܢܗ ܠܗܢܐ ܠܤܛܢܐ ܠܐܒܕܢܐ ܕܦܓܪܗ ܕܒܪܘܚ ܢܚܐ ܒܝܘܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 5:6",
      "text": "ܠܐ ܫܦܝܪ ܫܘܒܗܪܟܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܚܡܝܪܐ ܩܠܝܠ ܟܠܗ ܓܒܝܠܬܐ ܡܚܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 5:7",
      "text": "ܕܟܘ ܡܢܟܘܢ ܚܡܝܪܐ ܥܬܝܩܐ ܕܬܗܘܘܢ ܓܒܝܠܬܐ ܚܕܬܐ ܐܝܟܢܐ ܕܐܝܬܝܟܘܢ ܦܛܝܪܐ ܦܨܚܐ ܓܝܪ ܕܝܠܢ ܡܫܝܚܐ ܗܘ ܕܐܬܢܟܤ ܚܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 5:8",
      "text": "ܡܛܠ ܗܢܐ ܢܥܒܕ ܥܕܥܕܐ ܠܐ ܒܚܡܝܪܐ ܥܬܝܩܐ ܘܠܐ ܒܚܡܝܪܐ ܕܒܝܫܘܬܐ ܘܕܡܪܝܪܘܬܐ ܐܠܐ ܒܚܡܝܪܐ ܕܕܟܝܘܬܐ ܘܕܩܕܝܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 5:9",
      "text": "ܟܬܒܬ ܠܟܘܢ ܒܐܓܪܬܐ ܕܠܐ ܬܬܚܠܛܘܢ ܥܡ ܙܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.5.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 5:10",
      "text": "ܠܐ ܕܝܢ ܐܡܪ ܐܢܐ ܥܠ ܙܢܝܐ ܕܒܥܠܡܐ ܗܢܐ ܐܘ ܥܠ ܥܠܘܒܐ ܐܘ ܥܠ ܚܛܘܦܐ ܐܘ ܥܠ ܦܠܚܝ ܦܬܟܪܐ ܘܐܢ ܠܐ ܚܝܒܝܢ ܗܘܝܬܘܢ ܐܦ ܡܢ ܥܠܡܐ ܠܡܦܩ ܀",
      "paragraphStart": false
    },
    {
