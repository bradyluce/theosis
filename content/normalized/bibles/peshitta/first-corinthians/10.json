  },
  "verses": [
    {
      "id": "peshitta:first-corinthians.10.1",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 10:1",
      "text": "ܨܒܐ ܐܢܐ ܕܝܢ ܕܬܕܥܘܢ ܐܚܝ ܕܐܒܗܝܢ ܟܠܗܘܢ ܬܚܝܬ ܥܢܢܐ ܗܘܘ ܘܟܠܗܘܢ ܒܝܡܐ ܥܒܪܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.10.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 10:2",
      "text": "ܘܟܠܗܘܢ ܒܝܕ ܡܘܫܐ ܥܡܕܘ ܒܥܢܢܐ ܘܒܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 10:3",
      "text": "ܘܟܠܗܘܢ ܚܕܐ ܡܐܟܘܠܬܐ ܕܪܘܚܐ ܐܟܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 10:4",
      "text": "ܘܟܠܗܘܢ ܚܕ ܡܫܬܝܐ ܕܪܘܚܐ ܐܫܬܝܘ ܫܬܝܢ ܗܘܘ ܓܝܪ ܡܢ ܟܐܦܐ ܕܪܘܚܐ ܕܐܬܝܐ ܗܘܬ ܥܡܗܘܢ ܟܐܦܐ ܕܝܢ ܗܝ ܗܘ ܗܘܐ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 10:5",
      "text": "ܐܠܐ ܠܐ ܗܘܐ ܒܤܘܓܐܗܘܢ ܐܨܛܒܝ ܐܠܗܐ ܢܦܠܘ ܓܝܪ ܒܡܕܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 10:6",
      "text": "ܗܠܝܢ ܕܝܢ ܛܘܦܤܐ ܠܢ ܗܘ ܗܘܘ ܕܠܐ ܗܘܝܢ ܪܓܝܢ ܒܝܫܬܐ ܐܝܟܢܐ ܕܗܢܘܢ ܪܓܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 10:7",
      "text": "ܘܐܦܠܐ ܢܗܘܐ ܦܠܚܝ ܦܬܟܪܐ ܐܝܟܢܐ ܕܐܦ ܡܢܗܘܢ ܦܠܚܘ ܐܝܟ ܕܟܬܝܒ ܕܝܬܒ ܥܡܐ ܠܡܐܟܠ ܘܠܡܫܬܐ ܘܩܡܘ ܠܡܫܬܥܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 10:8",
      "text": "ܘܐܦܠܐ ܢܙܢܐ ܐܝܟܢܐ ܕܡܢܗܘܢ ܙܢܝܘ ܘܢܦܠܘ ܒܚܕ ܝܘܡܐ ܥܤܪܝܢ ܘܬܠܬܐ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 10:9",
      "text": "ܘܠܐ ܢܢܤܐ ܠܡܫܝܚܐ ܐܝܟܢܐ ܕܡܢܗܘܢ ܢܤܝܘ ܘܐܘܒܕܘ ܐܢܘܢ ܚܘܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 10:10",
      "text": "ܘܐܦܠܐ ܬܪܛܢܘܢ ܐܝܟܢܐ ܕܡܢܗܘܢ ܪܛܢܘ ܘܐܒܕܘ ܒܐܝܕܝ ܡܚܒܠܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 10:11",
      "text": "ܗܠܝܢ ܕܝܢ ܟܠܗܝܢ ܕܓܕܫ ܠܗܘܢ ܠܛܘܦܤܢ ܗܘܝ ܘܐܬܟܬܒ ܡܛܠ ܡܪܕܘܬܐ ܕܝܠܢ ܕܚܪܬܗܘܢ ܕܥܠܡܐ ܥܠܝܢ ܡܛܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 10:12",
      "text": "ܡܟܝܠ ܡܢ ܕܤܒܪ ܕܩܡ ܢܙܕܗܪ ܕܠܐ ܢܦܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 10:13",
      "text": "ܢܤܝܘܢܐ ܠܐ ܡܛܝܟܘܢ ܐܠܐ ܕܒܢܝܢܫܐ ܡܗܝܡܢ ܗܘ ܕܝܢ ܐܠܗܐ ܕܠܐ ܢܪܦܝܟܘܢ ܕܬܬܢܤܘܢ ܝܬܝܪ ܡܢ ܡܕܡ ܕܡܨܝܢ ܐܢܬܘܢ ܐܠܐ ܢܥܒܕ ܠܢܤܝܘܢܟܘܢ ܡܦܩܢܐ ܐܝܟܢܐ ܕܬܫܟܚܘܢ ܠܡܤܝܒܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 10:14",
      "text": "ܡܛܠ ܗܢܐ ܚܒܝܒܝ ܥܪܘܩܘ ܡܢ ܦܘܠܚܢܐ ܕܦܬܟܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 10:15",
      "text": "ܐܝܟ ܕܠܚܟܝܡܐ ܐܡܪ ܐܢܐ ܕܘܢܘ ܐܢܬܘܢ ܡܕܡ ܕܐܡܪ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.16",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "1 Corinthians 10:16",
      "text": "ܟܤܐ ܗܘ ܕܬܘܕܝܬܐ ܕܡܒܪܟܝܢܢ ܠܐ ܗܘܐ ܫܘܬܦܘܬܐ ܐܝܬܘܗܝ ܕܕܡܗ ܕܡܫܝܚܐ ܘܠܚܡܐ ܗܘ ܕܩܨܝܢܢ ܠܐ ܗܘܐ ܫܘܬܦܘܬܐ ܐܝܬܘܗܝ ܕܦܓܪܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.17",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "1 Corinthians 10:17",
      "text": "ܐܝܟܢܐ ܕܚܕ ܗܘ ܠܚܡܐ ܗܘ ܗܟܢܐ ܟܠܢ ܚܕ ܚܢܢ ܦܓܪ ܟܠܢ ܓܝܪ ܡܢ ܗܘ ܗܘ ܚܕ ܠܚܡܐ ܢܤܒܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.18",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "1 Corinthians 10:18",
      "text": "ܚܙܘ ܠܐܝܤܪܝܠ ܕܒܒܤܪ ܠܐ ܗܘܐ ܐܝܠܝܢ ܕܐܟܠܝܢ ܕܒܚܐ ܗܘܝܢ ܫܘܬܦܐ ܠܡܕܒܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.19",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "1 Corinthians 10:19",
      "text": "ܡܢܐ ܗܟܝܠ ܐܡܪ ܐܢܐ ܕܦܬܟܪܐ ܡܕܡ ܐܝܬܘܗܝ ܐܘ ܕܒܚܐ ܕܦܬܟܪܐ ܡܕܡ ܗܘ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.20",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "1 Corinthians 10:20",
      "text": "ܐܠܐ ܗܘ ܡܕܡ ܕܕܒܚܝܢ ܚܢܦܐ ܠܫܐܕܐ ܗܘ ܕܒܚܝܢ ܘܠܐ ܠܐܠܗܐ ܠܐ ܕܝܢ ܨܒܐ ܐܢܐ ܕܬܗܘܘܢ ܫܘܬܦܐ ܠܫܐܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.21",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "1 Corinthians 10:21",
      "text": "ܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܕܬܫܬܘܢ ܟܤܐ ܕܡܪܢ ܘܟܤܐ ܕܫܐܕܐ ܘܠܐ ܡܫܟܚܝܢ ܐܢܬܘܢ ܕܬܫܬܘܬܦܘܢ ܒܦܬܘܪܐ ܕܡܪܢ ܘܒܦܬܘܪܐ ܕܫܐܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.22",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "1 Corinthians 10:22",
      "text": "ܐܘ ܕܠܡܐ ܡܛܢܘ ܡܛܢܝܢܢ ܠܡܪܢ ܕܠܡܐ ܚܤܝܢܝܢܢ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.23",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "1 Corinthians 10:23",
      "text": "ܟܠ ܡܕܡ ܫܠܝܛ ܠܝ ܐܠܐ ܠܐ ܟܠ ܡܕܡ ܦܩܚ ܟܠ ܡܕܡ ܫܠܝܛ ܠܝ ܐܠܐ ܠܐ ܟܠ ܡܕܡ ܡܒܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.10.24",
