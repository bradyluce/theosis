      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 Corinthians 2:1",
      "text": "ܘܐܢܐ ܐܚܝ ܟܕ ܐܬܝܬ ܠܘܬܟܘܢ ܠܐ ܒܡܡܠܠܐ ܪܘܪܒܐ ܐܦܠܐ ܒܚܟܡܬܐ ܤܒܪܬܟܘܢ ܐܪܙܗ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-corinthians.2.2",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 Corinthians 2:2",
      "text": "ܘܠܐ ܕܢܬ ܢܦܫܝ ܒܝܢܬܟܘܢ ܐܝܟ ܕܡܕܡ ܝܕܥ ܐܢܐ ܐܠܐ ܐܢ ܠܝܫܘܥ ܡܫܝܚܐ ܐܦ ܠܗ ܟܕ ܙܩܝܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.3",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 Corinthians 2:3",
      "text": "ܘܐܢܐ ܒܕܚܠܬܐ ܤܓܝܐܬܐ ܘܒܪܬܝܬܐ ܗܘܝܬ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.4",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 Corinthians 2:4",
      "text": "ܘܡܠܬܝ ܘܟܪܘܙܘܬܝ ܠܐ ܗܘܬ ܒܡܦܝܤܢܘܬܐ ܕܡܠܐ ܕܚܟܡܬܐ ܐܠܐ ܒܬܚܘܝܬܐ ܕܪܘܚܐ ܘܕܚܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.5",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 Corinthians 2:5",
      "text": "ܕܠܐ ܬܗܘܐ ܗܝܡܢܘܬܟܘܢ ܒܚܟܡܬܐ ܕܒܢܝܢܫܐ ܐܠܐ ܒܚܝܠܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.6",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 Corinthians 2:6",
      "text": "ܚܟܡܬܐ ܕܝܢ ܡܡܠܠܝܢܢ ܒܓܡܝܪܐ ܚܟܡܬܐ ܠܐ ܕܗܢܐ ܥܠܡܐ ܐܦܠܐ ܕܫܠܝܛܢܘܗܝ ܕܥܠܡܐ ܗܢܐ ܕܡܬܒܛܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.7",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 Corinthians 2:7",
      "text": "ܐܠܐ ܡܡܠܠܝܢܢ ܚܟܡܬܐ ܕܐܠܗܐ ܒܐܪܙ ܗܝ ܕܡܟܤܝܐ ܗܘܬ ܘܩܕܡ ܗܘܐ ܦܪܫܗ ܐܠܗܐ ܡܢ ܩܕܡ ܥܠܡܐ ܠܫܘܒܚܐ ܕܝܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.8",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 Corinthians 2:8",
      "text": "ܗܝ ܕܚܕ ܡܢ ܫܠܝܛܢܐ ܕܥܠܡܐ ܗܢܐ ܠܐ ܝܕܥܗ ܐܠܘ ܓܝܪ ܝܕܥܘܗ ܠܘ ܠܡܪܗ ܕܬܫܒܘܚܬܐ ܙܩܦܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.9",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 Corinthians 2:9",
      "text": "ܐܠܐ ܐܝܟ ܕܟܬܝܒ ܕܥܝܢܐ ܠܐ ܚܙܬ ܘܐܕܢܐ ܠܐ ܫܡܥܬ ܘܥܠ ܠܒܐ ܕܒܪܢܫܐ ܠܐ ܤܠܩ ܡܕܡ ܕܛܝܒ ܐܠܗܐ ܠܐܝܠܝܢ ܕܪܚܡܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.10",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 Corinthians 2:10",
      "text": "ܠܢ ܕܝܢ ܓܠܐ ܐܠܗܐ ܒܪܘܚܗ ܪܘܚܐ ܓܝܪ ܟܠܡܕܡ ܒܨܝܐ ܐܦ ܥܘܡܩܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.11",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 Corinthians 2:11",
      "text": "ܐܝܢܐ ܗܘ ܓܝܪ ܒܪܢܫܐ ܕܝܕܥ ܕܒܒܪܢܫܐ ܐܠܐ ܐܢ ܪܘܚܐ ܕܒܪ ܕܒܗ ܗܟܢܐ ܐܦ ܕܒܐܠܗܐ ܐܢܫ ܠܐ ܝܕܥ ܐܠܐ ܐܢ ܪܘܚܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.12",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 Corinthians 2:12",
      "text": "ܚܢܢ ܕܝܢ ܠܐ ܗܘܐ ܪܘܚܐ ܕܥܠܡܐ ܢܤܒܢ ܐܠܐ ܪܘܚܐ ܕܡܢ ܐܠܗܐ ܕܢܕܥ ܡܘܗܒܬܐ ܕܡܢ ܐܠܗܐ ܐܬܝܗܒ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.13",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 Corinthians 2:13",
      "text": "ܐܝܠܝܢ ܕܐܦ ܡܡܠܠܝܢܢ ܠܐ ܗܘܐ ܒܝܘܠܦܢܐ ܕܡܠܐ ܕܚܟܡܬܐ ܕܒܢܝܢܫܐ ܐܠܐ ܒܝܘܠܦܢܐ ܕܪܘܚܐ ܘܠܪܘܚܢܐ ܪܘܚܢܝܬܐ ܡܦܚܡܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.14",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 Corinthians 2:14",
      "text": "ܒܪܢܫܐ ܓܝܪ ܕܒܢܦܫ ܗܘ ܠܐ ܡܩܒܠ ܪܘܚܢܝܬܐ ܫܛܝܘܬܐ ܐܢܝܢ ܓܝܪ ܠܗ ܘܠܐ ܡܫܟܚ ܕܢܕܥ ܕܒܪܘܚ ܡܬܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.15",
      "translationId": "peshitta",
      "bookSlug": "first-corinthians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 Corinthians 2:15",
      "text": "ܪܘܚܢܐ ܕܝܢ ܟܠ ܡܕܡ ܕܐܢ ܘܗܘ ܡܢ ܐܢܫ ܠܐ ܡܬܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-corinthians.2.16",
