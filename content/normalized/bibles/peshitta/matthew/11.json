  "verses": [
    {
      "id": "peshitta:matthew.11.1",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Matthew 11:1",
      "text": "ܘܗܘܐ ܕܟܕ ܫܠܡ ܝܫܘܥ ܠܡܦܩܕܘ ܠܬܪܥܤܪ ܬܠܡܝܕܘܗܝ ܫܢܝ ܡܢ ܬܡܢ ܠܡܠܦܘ ܘܠܡܟܪܙܘ ܒܡܕܝܢܬܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.11.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Matthew 11:2",
      "text": "ܝܘܚܢܢ ܕܝܢ ܟܕ ܫܡܥ ܒܝܬ ܐܤܝܪܐ ܥܒܕܘܗܝ ܕܡܫܝܚܐ ܫܕܪ ܒܝܕ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.11.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Matthew 11:3",
      "text": "ܘܐܡܪ ܠܗ ܐܢܬ ܗܘ ܗܘ ܕܐܬܐ ܐܘ ܠܐܚܪܝܢ ܗܘ ܡܤܟܝܢ ܐܢܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.11.4",
