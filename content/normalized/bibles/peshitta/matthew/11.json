      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Matthew 11:6",
      "text": "ܘܛܘܒܘܗܝ ܠܐܝܢܐ ܕܠܐ ܢܬܟܫܠ ܒܝ ܀",
      "paragraphStart": false
