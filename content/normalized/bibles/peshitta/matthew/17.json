      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Matthew 17:1",
      "text": "ܘܒܬܪ ܫܬܐ ܝܘܡܝܢ ܕܒܪ ܝܫܘܥ ܠܟܐܦܐ ܘܠܝܥܩܘܒ ܘܠܝܘܚܢܢ ܐܚܘܗܝ ܘܐܤܩ ܐܢܘܢ ܠܛܘܪܐ ܪܡܐ ܒܠܚܘܕܝܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.17.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Matthew 17:2",
      "text": "ܘܐܫܬܚܠܦ ܝܫܘܥ ܩܕܡܝܗܘܢ ܘܢܗܪ ܦܪܨܘܦܗ ܐܝܟ ܫܡܫܐ ܢܚܬܘܗܝ ܕܝܢ ܚܘܪܘ ܐܝܟ ܢܘܗܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.17.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Matthew 17:3",
      "text": "ܘܐܬܚܙܝܘ ܠܗܘܢ ܡܘܫܐ ܘܐܠܝܐ ܟܕ ܡܡܠܠܝܢ ܥܡܗ ܀",
      "paragraphStart": false
    },
