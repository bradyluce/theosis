      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 1,
      "referenceLabel": "Matthew 28:1",
      "text": "ܒܪܡܫܐ ܕܝܢ ܒܫܒܬܐ ܕܢܓܗ ܚܕ ܒܫܒܐ ܐܬܬ ܡܪܝܡ ܡܓܕܠܝܬܐ ܘܡܪܝܡ ܐܚܪܬܐ ܕܢܚܙܝܢ ܩܒܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.28.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 2,
      "referenceLabel": "Matthew 28:2",
      "text": "ܘܗܐ ܙܘܥܐ ܪܒܐ ܗܘܐ ܡܠܐܟܐ ܓܝܪ ܕܡܪܝܐ ܢܚܬ ܡܢ ܫܡܝܐ ܘܩܪܒ ܥܓܠ ܟܐܦܐ ܡܢ ܬܪܥܐ ܘܝܬܒ ܗܘܐ ܥܠܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 3,
      "referenceLabel": "Matthew 28:3",
      "text": "ܐܝܬܘܗܝ ܗܘܐ ܕܝܢ ܚܙܘܗ ܐܝܟ ܒܪܩܐ ܘܠܒܘܫܗ ܚܘܪ ܗܘܐ ܐܝܟ ܬܠܓܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.4",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 4,
      "referenceLabel": "Matthew 28:4",
      "text": "ܘܡܢ ܕܚܠܬܗ ܐܬܬܙܝܥܘ ܐܝܠܝܢ ܕܢܛܪܝܢ ܗܘܘ ܘܗܘܘ ܐܝܟ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.5",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 5,
      "referenceLabel": "Matthew 28:5",
      "text": "ܥܢܐ ܕܝܢ ܡܠܐܟܐ ܘܐܡܪ ܠܢܫܐ ܐܢܬܝܢ ܠܐ ܬܕܚܠܢ ܝܕܥ ܐܢܐ ܓܝܪ ܕܠܝܫܘܥ ܕܐܙܕܩܦ ܒܥܝܢ ܐܢܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.6",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 6,
      "referenceLabel": "Matthew 28:6",
      "text": "ܠܐ ܗܘܐ ܬܢܢ ܩܡ ܠܗ ܓܝܪ ܐܝܟܢܐ ܕܐܡܪ ܬܐܝܝܢ ܚܙܝܝܢ ܕܘܟܬܐ ܕܤܝܡ ܗܘܐ ܒܗ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.7",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 7,
      "referenceLabel": "Matthew 28:7",
      "text": "ܘܙܠܝܢ ܒܥܓܠ ܐܡܪܝܢ ܠܬܠܡܝܕܘܗܝ ܕܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܘܗܐ ܩܕܡ ܠܟܘܢ ܠܓܠܝܠܐ ܬܡܢ ܬܚܙܘܢܝܗܝ ܗܐ ܐܡܪܬ ܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.8",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 8,
      "referenceLabel": "Matthew 28:8",
      "text": "ܘܐܙܠ ܥܓܠ ܡܢ ܩܒܪܐ ܒܕܚܠܬܐ ܘܒܚܕܘܬܐ ܪܒܬܐ ܘܪܗܛܢ ܕܢܐܡܪܢ ܠܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.28.9",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 28,
      "verseNumber": 9,
      "referenceLabel": "Matthew 28:9",
      "text": "ܘܗܐ ܝܫܘܥ ܦܓܥ ܒܗܝܢ ܘܐܡܪ ܠܗܝܢ ܫܠܡ ܠܟܝܢ ܗܢܝܢ ܕܝܢ ܩܪܒ ܐܚܕ ܪܓܠܘܗܝ ܘܤܓܕܝܢ ܠܗ ܀",
      "paragraphStart": false
