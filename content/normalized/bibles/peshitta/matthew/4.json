      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Matthew 4:1",
      "text": "ܗܝܕܝܢ ܝܫܘܥ ܐܬܕܒܪ ܡܢ ܪܘܚܐ ܕܩܘܕܫܐ ܠܡܕܒܪܐ ܕܢܬܢܤܐ ܡܢ ܐܟܠܩܪܨܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.4.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Matthew 4:2",
      "text": "ܘܨܡ ܐܪܒܥܝܢ ܝܘܡܝܢ ܘܐܪܒܥܝܢ ܠܝܠܘܢ ܐܚܪܝܬ ܕܝܢ ܟܦܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Matthew 4:3",
      "text": "ܘܩܪܒ ܗܘ ܕܡܢܤܐ ܘܐܡܪ ܠܗ ܐܢ ܒܪܗ ܐܢܬ ܕܐܠܗܐ ܐܡܪ ܕܗܠܝܢ ܟܐܦܐ ܢܗܘܝܢ ܠܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.4",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Matthew 4:4",
      "text": "ܗܘ ܕܝܢ ܥܢܐ ܘܐܡܪ ܟܬܝܒ ܕܠܐ ܗܘܐ ܒܠܚܡܐ ܒܠܚܘܕ ܚܝܐ ܒܪܢܫܐ ܐܠܐ ܒܟܠ ܡܠܐ ܕܢܦܩܐ ܡܢ ܦܘܡܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.5",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Matthew 4:5",
      "text": "ܗܝܕܝܢ ܕܒܪܗ ܐܟܠܩܪܨܐ ܠܡܕܝܢܬ ܩܘܕܫܐ ܘܐܩܝܡܗ ܥܠ ܟܢܦܐ ܕܗܝܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.6",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Matthew 4:6",
      "text": "ܘܐܡܪ ܠܗ ܐܢ ܒܪܗ ܐܢܬ ܕܐܠܗܐ ܫܕܝ ܢܦܫܟ ܠܬܚܬ ܟܬܝܒ ܓܝܪ ܕܠܡܠܐܟܘܗܝ ܢܦܩܕ ܥܠܝܟ ܘܥܠ ܐܝܕܝܗܘܢ ܢܫܩܠܘܢܟ ܕܠܐ ܬܬܩܠ ܒܟܐܦܐ ܪܓܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.7",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Matthew 4:7",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܬܘܒ ܟܬܝܒ ܕܠܐ ܬܢܤܐ ܠܡܪܝܐ ܐܠܗܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.8",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Matthew 4:8",
      "text": "ܬܘܒ ܕܒܪܗ ܐܟܠܩܪܨܐ ܠܛܘܪܐ ܕܛܒ ܪܡ ܘܚܘܝܗ ܟܠܗܝܢ ܡܠܟܘܬܐ ܕܥܠܡܐ ܘܫܘܒܚܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.4.9",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Matthew 4:9",
      "text": "ܘܐܡܪ ܠܗ ܗܠܝܢ ܟܠܗܝܢ ܠܟ ܐܬܠ ܐܢ ܬܦܠ ܬܤܓܘܕ ܠܝ ܀",
      "paragraphStart": false
