    {
      "id": "peshitta:matthew.1.22",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Matthew 1:22",
      "text": "ܗܕܐ ܕܝܢ ܟܠܗ ܕܗܘܬ ܕܢܬܡܠܐ ܡܕܡ ܕܐܬܐܡܪ ܡܢ ܡܪܝܐ ܒܝܕ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
