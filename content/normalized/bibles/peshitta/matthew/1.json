  },
  "verses": [
    {
      "id": "peshitta:matthew.1.1",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Matthew 1:1",
      "text": "ܟܬܒܐ ܕܝܠܝܕܘܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܒܪܗ ܕܕܘܝܕ ܒܪܗ ܕܐܒܪܗܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.1.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Matthew 1:2",
      "text": "ܐܒܪܗܡ ܐܘܠܕ ܠܐܝܤܚܩ ܐܝܤܚܩ ܐܘܠܕ ܠܝܥܩܘܒ ܝܥܩܘܒ ܐܘܠܕ ܠܝܗܘܕܐ ܘܠܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Matthew 1:3",
      "text": "ܝܗܘܕܐ ܐܘܠܕ ܠܦܪܨ ܘܠܙܪܚ ܡܢ ܬܡܪ ܦܪܨ ܐܘܠܕ ܠܚܨܪܘܢ ܚܨܪܘܢ ܐܘܠܕ ܠܐܪܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.4",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Matthew 1:4",
      "text": "ܐܪܡ ܐܘܠܕ ܠܥܡܝܢܕܒ ܥܡܝܢܕܒ ܐܘܠܕ ܠܢܚܫܘܢ ܢܚܫܘܢ ܐܘܠܕ ܠܤܠܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.5",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Matthew 1:5",
      "text": "ܤܠܡܘܢ ܐܘܠܕ ܠܒܥܙ ܡܢ ܪܚܒ ܒܥܙ ܐܘܠܕ ܠܥܘܒܝܕ ܡܢ ܪܥܘܬ ܥܘܒܝܕ ܐܘܠܕ ܠܐܝܫܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.6",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Matthew 1:6",
      "text": "ܐܝܫܝ ܐܘܠܕ ܠܕܘܝܕ ܡܠܟܐ ܕܘܝܕ ܐܘܠܕ ܠܫܠܝܡܘܢ ܡܢ ܐܢܬܬܗ ܕܐܘܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.7",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Matthew 1:7",
      "text": "ܫܠܝܡܘܢ ܐܘܠܕ ܠܪܚܒܥܡ ܪܚܒܥܡ ܐܘܠܕ ܠܐܒܝܐ ܐܒܝܐ ܐܘܠܕ ܠܐܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.8",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Matthew 1:8",
      "text": "ܐܤܐ ܐܘܠܕ ܠܝܗܘܫܦܛ ܝܗܘܫܦܛ ܐܘܠܕ ܠܝܘܪܡ ܝܘܪܡ ܐܘܠܕ ܠܥܘܙܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.9",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Matthew 1:9",
      "text": "ܥܘܙܝܐ ܐܘܠܕ ܠܝܘܬܡ ܝܘܬܡ ܐܘܠܕ ܠܐܚܙ ܐܚܙ ܐܘܠܕ ܠܚܙܩܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.10",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Matthew 1:10",
      "text": "ܚܙܩܝܐ ܐܘܠܕ ܠܡܢܫܐ ܡܢܫܐ ܐܘܠܕ ܠܐܡܘܢ ܐܡܘܢ ܐܘܠܕ ܠܝܘܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.11",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Matthew 1:11",
      "text": "ܝܘܫܝܐ ܐܘܠܕ ܠܝܘܟܢܝܐ ܘܠܐܚܘܗܝ ܒܓܠܘܬܐ ܕܒܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.12",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Matthew 1:12",
      "text": "ܡܢ ܒܬܪ ܓܠܘܬܐ ܕܝܢ ܕܒܒܠ ܝܘܟܢܝܐ ܐܘܠܕ ܠܫܠܬܐܝܠ ܫܠܬܐܝܠ ܐܘܠܕ ܠܙܘܪܒܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.13",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Matthew 1:13",
      "text": "ܙܘܪܒܒܠ ܐܘܠܕ ܠܐܒܝܘܕ ܐܒܝܘܕ ܐܘܠܕ ܠܐܠܝܩܝܡ ܐܠܝܩܝܡ ܐܘܠܕ ܠܥܙܘܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.14",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Matthew 1:14",
      "text": "ܥܙܘܪ ܐܘܠܕ ܠܙܕܘܩ ܙܕܘܩ ܐܘܠܕ ܠܐܟܝܢ ܐܟܝܢ ܐܘܠܕ ܠܐܠܝܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.15",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Matthew 1:15",
      "text": "ܐܠܝܘܕ ܐܘܠܕ ܠܐܠܝܥܙܪ ܐܠܝܥܙܪ ܐܘܠܕ ܠܡܬܢ ܡܬܢ ܐܘܠܕ ܠܝܥܩܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.16",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Matthew 1:16",
      "text": "ܝܥܩܘܒ ܐܘܠܕ ܠܝܘܤܦ ܓܒܪܗ ܕܡܪܝܡ ܕܡܢܗ ܐܬܝܠܕ ܝܫܘܥ ܕܡܬܩܪܐ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.17",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Matthew 1:17",
      "text": "ܟܠܗܝܢ ܗܟܝܠ ܫܪܒܬܐ ܡܢ ܐܒܪܗܡ ܥܕܡܐ ܠܕܘܝܕ ܫܪܒܬܐ ܐܪܒܥܤܪܐ ܘܡܢ ܕܘܝܕ ܥܕܡܐ ܠܓܠܘܬܐ ܕܒܒܠ ܫܪܒܬܐ ܐܪܒܥܤܪܐ ܘܡܢ ܓܠܘܬܐ ܕܒܒܠ ܥܕܡܐ ܠܡܫܝܚܐ ܫܪܒܬܐ ܐܪܒܥܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.18",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Matthew 1:18",
      "text": "ܝܠܕܗ ܕܝܢ ܕܝܫܘܥ ܡܫܝܚܐ ܗܟܢܐ ܗܘܐ ܟܕ ܡܟܝܪܐ ܗܘܬ ܡܪܝܡ ܐܡܗ ܠܝܘܤܦ ܥܕܠܐ ܢܫܬܘܬܦܘܢ ܐܫܬܟܚܬ ܒܛܢܐ ܡܢ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.19",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Matthew 1:19",
      "text": "ܝܘܤܦ ܕܝܢ ܒܥܠܗ ܟܐܢܐ ܗܘܐ ܘܠܐ ܨܒܐ ܕܢܦܪܤܝܗ ܘܐܬܪܥܝ ܗܘܐ ܕܡܛܫܝܐܝܬ ܢܫܪܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.20",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Matthew 1:20",
      "text": "ܟܕ ܗܠܝܢ ܕܝܢ ܐܬܪܥܝ ܐܬܚܙܝ ܠܗ ܡܠܐܟܐ ܕܡܪܝܐ ܒܚܠܡܐ ܘܐܡܪ ܠܗ ܝܘܤܦ ܒܪܗ ܕܕܘܝܕ ܠܐ ܬܕܚܠ ܠܡܤܒ ܠܡܪܝܡ ܐܢܬܬܟ ܗܘ ܓܝܪ ܕܐܬܝܠܕ ܒܗ ܡܢ ܪܘܚܐ ܗܘ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.1.21",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Matthew 1:21",
      "text": "ܬܐܠܕ ܕܝܢ ܒܪܐ ܘܬܩܪܐ ܫܡܗ ܝܫܘܥ ܗܘ ܓܝܪ ܢܚܝܘܗܝ ܠܥܡܗ ܡܢ ܚܛܗܝܗܘܢ ܀",
      "paragraphStart": false
