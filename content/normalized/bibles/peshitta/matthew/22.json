    {
      "id": "peshitta:matthew.22.6",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Matthew 22:6",
      "text": "ܫܪܟܐ ܕܝܢ ܐܚܕܘ ܠܥܒܕܘܗܝ ܘܨܥܪܘ ܘܩܛܠܘ ܀",
