  "verses": [
    {
      "id": "peshitta:matthew.20.1",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Matthew 20:1",
      "text": "ܕܡܝܐ ܓܝܪ ܡܠܟܘܬܐ ܕܫܡܝܐ ܠܓܒܪܐ ܡܪܐ ܒܝܬܐ ܕܢܦܩ ܒܨܦܪܐ ܕܢܐܓܘܪ ܦܥܠܐ ܠܟܪܡܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.20.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Matthew 20:2",
      "text": "ܩܨ ܕܝܢ ܥܡ ܦܥܠܐ ܡܢ ܕܝܢܪܐ ܒܝܘܡܐ ܘܫܕܪ ܐܢܘܢ ܠܟܪܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Matthew 20:3",
      "text": "ܘܢܦܩ ܒܬܠܬ ܫܥܝܢ ܘܚܙܐ ܐܚܪܢܐ ܕܩܝܡܝܢ ܒܫܘܩܐ ܘܒܛܝܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.4",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Matthew 20:4",
      "text": "ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܐܦ ܐܢܬܘܢ ܠܟܪܡܐ ܘܡܕܡ ܕܘܠܐ ܝܗܒ ܐܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.5",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Matthew 20:5",
      "text": "ܗܢܘܢ ܕܝܢ ܐܙܠܘ ܘܢܦܩ ܬܘܒ ܒܫܬ ܘܒܬܫܥ ܫܥܝܢ ܘܥܒܕ ܗܟܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.6",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Matthew 20:6",
      "text": "ܘܠܐܦܝ ܚܕܥܤܪܐ ܫܥܝܢ ܢܦܩ ܘܐܫܟܚ ܐܚܪܢܐ ܕܩܝܡܝܢ ܘܒܛܝܠܝܢ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܩܝܡܝܢ ܐܢܬܘܢ ܝܘܡܐ ܟܠܗ ܘܒܛܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.7",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Matthew 20:7",
      "text": "ܐܡܪܝܢ ܠܗ ܕܠܐ ܐܢܫ ܐܓܪܢ ܐܡܪ ܠܗܘܢ ܙܠܘ ܐܦ ܐܢܬܘܢ ܠܟܪܡܐ ܘܡܕܡ ܕܘܠܐ ܢܤܒܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.8",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Matthew 20:8",
      "text": "ܟܕ ܗܘܐ ܕܝܢ ܪܡܫܐ ܐܡܪ ܡܪܐ ܟܪܡܐ ܠܪܒܝܬܗ ܩܪܝ ܦܥܠܐ ܘܗܒ ܠܗܘܢ ܐܓܪܗܘܢ ܘܫܪܐ ܡܢ ܐܚܪܝܐ ܘܥܕܡܐ ܠܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.9",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Matthew 20:9",
      "text": "ܘܐܬܘ ܗܢܘܢ ܕܚܕܥܤܪܐ ܫܥܝܢ ܢܤܒܘ ܕܝܢܪ ܕܝܢܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.10",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Matthew 20:10",
      "text": "ܘܟܕ ܐܬܘ ܩܕܡܝܐ ܤܒܪܘ ܕܝܬܝܪ ܫܩܠܝܢ ܘܫܩܠܘ ܕܝܢܪ ܕܝܢܪ ܐܦ ܗܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.20.11",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Matthew 20:11",
      "text": "ܘܟܕ ܫܩܠܘ ܪܛܢܘ ܥܠ ܡܪܐ ܒܝܬܐ ܀",
      "paragraphStart": false
