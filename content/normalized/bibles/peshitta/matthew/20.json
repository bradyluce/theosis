    {
      "id": "peshitta:matthew.20.12",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Matthew 20:12",
      "text": "ܘܐܡܪܝܢ ܗܠܝܢ ܐܚܪܝܐ ܚܕܐ ܫܥܐ ܥܒܕܘ ܘܐܫܘܝܬ ܐܢܘܢ ܥܡܢ ܕܫܩܠܢ ܝܘܩܪܗ ܕܝܘܡܐ ܘܚܘܡܗ ܀",
      "paragraphStart": false
    },
    {
