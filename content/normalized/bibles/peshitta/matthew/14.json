    {
      "id": "peshitta:matthew.14.12",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Matthew 14:12",
      "text": "ܘܩܪܒܘ ܬܠܡܝܕܘܗܝ ܫܩܠܘ ܫܠܕܗ ܩܒܪܘ ܘܐܬܘ ܚܘܝܘ ܠܝܫܘܥ ܀",
