      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Matthew 14:1",
      "text": "ܒܗܘ ܕܝܢ ܙܒܢܐ ܫܡܥ ܗܪܘܕܤ ܛܛܪܪܟܐ ܫܡܥܗ ܕܝܫܘܥ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:matthew.14.2",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Matthew 14:2",
      "text": "ܘܐܡܪ ܠܥܒܕܘܗܝ ܗܢܘ ܝܘܚܢܢ ܡܥܡܕܢܐ ܗܘ ܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܡܛܠ ܗܢܐ ܚܝܠܐ ܡܤܬܥܪܝܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.3",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Matthew 14:3",
      "text": "ܗܘ ܓܝܪ ܗܪܘܕܤ ܐܚܕ ܗܘܐ ܠܝܘܚܢܢ ܘܐܤܪܗ ܘܐܪܡܝܗ ܒܝܬ ܐܤܝܪܐ ܡܛܠ ܗܪܘܕܝܐ ܐܢܬܬ ܦܝܠܝܦܘܤ ܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.4",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Matthew 14:4",
      "text": "ܐܡܪ ܗܘܐ ܠܗ ܓܝܪ ܝܘܚܢܢ ܕܠܐ ܫܠܝܛ ܕܬܗܘܐ ܠܟ ܐܢܬܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.5",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Matthew 14:5",
      "text": "ܘܨܒܐ ܗܘܐ ܠܡܩܛܠܗ ܘܕܚܠ ܗܘܐ ܡܢ ܥܡܐ ܕܐܝܟ ܕܠܢܒܝܐ ܐܚܝܕܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.6",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Matthew 14:6",
      "text": "ܟܕ ܗܘܐ ܕܝܢ ܒܝܬ ܝܠܕܗ ܕܗܪܘܕܤ ܪܩܕܬ ܒܪܬܗ ܕܗܪܘܕܝܐ ܩܕܡ ܤܡܝܟܐ ܘܫܦܪܬ ܠܗ ܠܗܪܘܕܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.7",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Matthew 14:7",
      "text": "ܡܛܠ ܗܢܐ ܒܡܘܡܬܐ ܝܡܐ ܠܗ ܕܢܬܠ ܠܗ ܟܠܡܕܡ ܕܬܫܐܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.8",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Matthew 14:8",
      "text": "ܗܝ ܕܝܢ ܡܛܠ ܕܡܠܦܐ ܗܘܬ ܠܐܡܗ ܐܡܪܬ ܗܒ ܠܝ ܗܪܟܐ ܒܦܝܢܟܐ ܪܫܗ ܕܝܘܚܢܢ ܡܥܡܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.9",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Matthew 14:9",
      "text": "ܘܟܪܝܬ ܠܗ ܠܡܠܟܐ ܡܛܠ ܕܝܢ ܡܘܡܬܐ ܘܤܡܝܟܐ ܦܩܕ ܕܢܬܝܗܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.10",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Matthew 14:10",
      "text": "ܘܫܕܪ ܦܤܩܗ ܪܫܗ ܕܝܘܚܢܢ ܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:matthew.14.11",
      "translationId": "peshitta",
      "bookSlug": "matthew",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Matthew 14:11",
      "text": "ܘܐܝܬܝ ܪܫܗ ܒܦܝܢܟܐ ܘܐܬܝܗܒ ܠܛܠܝܬܐ ܘܐܝܬܝܬܗ ܠܐܡܗ ܀",
      "paragraphStart": false
