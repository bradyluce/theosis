    "bookSlug": "first-john",
    "chapterNumber": 5,
    "referenceLabel": "1 John 5",
    "summary": "Source text for 1 John 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-john.5.1",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "1 John 5:1",
      "text": "ܟܠ ܕܡܗܝܡܢ ܕܝܫܘܥ ܐܝܬܘܗܝ ܡܫܝܚܐ ܡܢ ܐܠܗܐ ܝܠܝܕ ܘܟܠ ܕܡܚܒ ܠܝܠܘܕܐ ܡܚܒ ܐܦ ܠܗܘ ܕܐܬܝܠܕ ܡܢܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-john.5.2",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "1 John 5:2",
      "text": "ܘܒܗܕܐ ܝܕܥܝܢܢ ܕܡܚܒܝܢܢ ܠܒܢܘܗܝ ܕܐܠܗܐ ܡܐ ܕܠܐܠܗܐ ܡܚܒܝܢܢ ܘܥܒܕܝܢܢ ܦܘܩܕܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.3",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "1 John 5:3",
      "text": "ܗܢܐ ܗܘ ܓܝܪ ܚܘܒܗ ܕܐܠܗܐ ܕܢܛܪ ܦܘܩܕܢܘܗܝ ܘܦܘܩܕܢܘܗܝ ܠܐ ܝܩܝܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.4",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "1 John 5:4",
      "text": "ܡܛܠ ܕܟܠ ܕܝܠܝܕ ܡܢ ܐܠܗܐ ܙܟܐ ܠܗ ܠܥܠܡܐ ܘܗܕܐ ܗܝ ܙܟܘܬܐ ܕܙܟܬܗ ܠܥܠܡܐ ܗܝܡܢܘܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.5",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "1 John 5:5",
      "text": "ܡܢܘ ܓܝܪ ܕܙܟܐ ܠܗ ܠܥܠܡܐ ܐܠܐ ܗܘ ܕܡܗܝܡܢ ܕܝܫܘܥ ܒܪܗ ܗܘ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.6",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "1 John 5:6",
      "text": "ܗܢܘ ܕܐܬܐ ܒܝܕ ܡܝܐ ܘܕܡܐ ܝܫܘܥ ܡܫܝܚܐ ܠܐ ܗܘܐ ܒܡܝܐ ܒܠܚܘܕ ܐܠܐ ܒܡܝܐ ܘܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.7",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "1 John 5:7",
      "text": "ܘܪܘܚܐ ܡܤܗܕܐ ܕܗܝ ܪܘܚܐ ܐܝܬܝܗ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.8",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "1 John 5:8",
      "text": "ܘܐܝܬܝܗܘܢ ܬܠܬܐ ܤܗܕܝܢ ܪܘܚܐ ܘܡܝܐ ܘܕܡܐ ܘܬܠܬܝܗܘܢ ܒܚܕ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.9",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "1 John 5:9",
      "text": "ܐܢ ܤܗܕܘܬܐ ܕܒܢܝܢܫܐ ܡܩܒܠܝܢܢ ܚܕ ܟܡܐ ܤܗܕܘܬܗ ܕܐܠܗܐ ܕܪܒܐ ܗܝ ܘܗܕܐ ܗܝ ܤܗܕܘܬܗ ܕܐܠܗܐ ܕܐܤܗܕ ܥܠ ܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.10",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "1 John 5:10",
      "text": "ܟܠܡܢ ܕܡܗܝܡܢ ܒܒܪܗ ܕܐܠܗܐ ܐܝܬ ܠܗ ܗܕܐ ܤܗܕܘܬܐ ܒܢܦܫܗ ܟܠ ܕܠܐ ܡܗܝܡܢ ܠܐܠܗܐ ܕܓܠܐ ܥܒܕܗ ܒܕܠܐ ܗܝܡܢ ܠܤܗܕܘܬܐ ܕܐܤܗܕ ܐܠܗܐ ܥܠ ܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.11",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "1 John 5:11",
      "text": "ܘܗܕܐ ܗܝ ܤܗܕܘܬܐ ܕܚܝܐ ܕܠܥܠܡ ܝܗܒ ܠܢ ܐܠܗܐ ܘܗܢܘܢ ܚܝܐ ܒܒܪܗ ܐܝܬܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.12",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "1 John 5:12",
      "text": "ܟܠ ܕܐܚܝܕ ܠܒܪܐ ܐܚܝܕ ܐܦ ܠܚܝܐ ܘܟܠ ܕܠܐ ܐܚܝܕ ܠܒܪܗ ܕܐܠܗܐ ܠܝܬ ܠܗ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.13",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "1 John 5:13",
      "text": "ܗܠܝܢ ܟܬܒܬ ܠܟܘܢ ܕܬܕܥܘܢ ܕܚܝܐ ܕܠܥܠܡ ܐܝܬ ܠܟܘܢ ܠܐܝܠܝܢ ܕܗܝܡܢܬܘܢ ܒܫܡܗ ܕܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.14",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "1 John 5:14",
      "text": "ܘܗܕܐ ܦܪܗܤܝܐ ܐܝܬ ܠܢ ܠܘܬܗ ܕܟܠ ܕܫܐܠܝܢܢ ܠܗ ܐܝܟ ܨܒܝܢܗ ܫܡܥ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.15",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "1 John 5:15",
      "text": "ܘܐܢ ܡܦܤܝܢܢ ܕܫܡܥ ܠܢ ܥܠ ܡܕܡ ܕܫܐܠܝܢܢ ܡܢܗ ܬܟܝܠܝܢܢ ܕܩܒܠܢ ܡܢ ܟܕܘ ܫܐܠܬܢ ܕܫܐܠܢ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.16",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "1 John 5:16",
      "text": "ܐܢ ܐܢܫ ܢܚܙܐ ܠܐܚܘܗܝ ܕܚܛܐ ܚܛܗܐ ܕܠܐ ܡܚܝܒ ܠܡܘܬܐ ܢܫܐܠ ܘܡܬܝܗܒܝܢ ܠܗ ܚܝܐ ܠܐܝܠܝܢ ܕܠܐ ܗܘܐ ܐܝܟ ܕܠܡܘܬܐ ܚܛܝܢ ܐܝܬ ܓܝܪ ܚܛܗܐ ܕܡܘܬܐ ܠܐ ܗܘܐ ܥܠ ܗܢܐ ܐܡܪ ܐܢܐ ܕܢܒܥܐ ܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.17",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "1 John 5:17",
      "text": "ܟܠ ܥܘܠܐ ܓܝܪ ܚܛܝܬܐ ܗܘ ܘܐܝܬ ܚܛܗܐ ܕܠܐ ܗܘܐ ܕܡܘܬܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.18",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "1 John 5:18",
      "text": "ܘܝܕܥܝܢܢ ܕܟܠ ܕܝܠܝܕ ܡܢ ܐܠܗܐ ܠܐ ܚܛܐ ܗܘ ܓܝܪ ܕܝܠܝܕ ܡܢ ܐܠܗܐ ܢܛܪ ܢܦܫܗ ܘܒܝܫܐ ܠܐ ܡܬܩܪܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.19",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "1 John 5:19",
      "text": "ܝܕܥܝܢܢ ܕܡܢ ܐܠܗܐ ܚܢܢ ܘܥܠܡܐ ܟܠܗ ܒܒܝܫܐ ܗܘ ܤܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.20",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "1 John 5:20",
      "text": "ܘܝܕܥܝܢܢ ܕܒܪܗ ܕܐܠܗܐ ܐܬܐ ܘܝܗܒ ܠܢ ܡܕܥܐ ܕܢܕܥ ܠܫܪܝܪܐ ܘܢܗܘܐ ܒܗ ܒܫܪܝܪܐ ܒܒܪܗ ܝܫܘܥ ܡܫܝܚܐ ܗܢܐ ܗܘ ܐܠܗܐ ܫܪܝܪܐ ܘܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.5.21",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "1 John 5:21",
      "text": "ܒܢܝ ܛܪܘ ܢܦܫܟܘܢ ܡܢ ܕܚܠܬ ܦܬܟܪܐ ܀",
      "paragraphStart": false
    }
  ]
}
