    "chapterNumber": 4,
    "referenceLabel": "1 John 4",
    "summary": "Source text for 1 John 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-john.4.1",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "1 John 4:1",
      "text": "ܚܒܝܒܝ ܠܐ ܠܟܠ ܪܘܚܝܢ ܬܗܝܡܢܘܢ ܐܠܐ ܗܘܝܬܘܢ ܦܪܫܝܢ ܪܘܚܐ ܐܢ ܡܢ ܐܠܗܐ ܐܝܬܝܗܝܢ ܡܛܠ ܕܤܓܝܐܐ ܢܒܝܐ ܕܓܠܐ ܢܦܩܘ ܒܗ ܒܥܠܡܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-john.4.2",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "1 John 4:2",
      "text": "ܒܗܕܐ ܡܬܝܕܥܐ ܪܘܚܗ ܕܐܠܗܐ ܟܠ ܪܘܚܐ ܕܡܘܕܝܢ ܕܝܫܘܥ ܡܫܝܚܐ ܐܬܐ ܒܒܤܪ ܡܢ ܐܠܗܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.3",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "1 John 4:3",
      "text": "ܘܟܠ ܪܘܚܐ ܕܠܐ ܡܘܕܝܐ ܕܝܫܘܥ ܐܬܐ ܒܒܤܪ ܠܝܬܝܗ ܡܢ ܐܠܗܐ ܐܠܐ ܗܕܐ ܡܢ ܡܫܝܚܐ ܗܝ ܕܓܠܐ ܗܘ ܕܫܡܥܬܘܢ ܕܐܬܐ ܘܗܫܐ ܒܥܠܡܐ ܐܝܬܘܗܝ ܡܢ ܟܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.4",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "1 John 4:4",
      "text": "ܐܢܬܘܢ ܕܝܢ ܡܢ ܐܠܗܐ ܐܝܬܝܟܘܢ ܒܢܝܐ ܘܙܟܝܬܘܢ ܐܢܘܢ ܡܛܠ ܕܪܒ ܗܘ ܕܒܟܘܢ ܡܢ ܗܘ ܕܒܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.5",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "1 John 4:5",
      "text": "ܘܗܠܝܢ ܡܢ ܥܠܡܐ ܐܢܘܢ ܡܛܠ ܗܢܐ ܡܢ ܥܠܡܐ ܡܡܠܠܝܢ ܘܥܠܡܐ ܠܗܘܢ ܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.6",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "1 John 4:6",
      "text": "ܚܢܢ ܕܝܢ ܡܢ ܐܠܗܐ ܚܢܢ ܘܗܘ ܕܝܕܥ ܠܐܠܗܐ ܫܡܥ ܠܢ ܘܗܘ ܕܠܐ ܐܝܬܘܗܝ ܡܢ ܐܠܗܐ ܠܐ ܫܡܥ ܠܢ ܒܗ ܒܗܕܐ ܡܤܬܟܠܝܢܢ ܠܪܘܚܐ ܕܫܪܪܐ ܘܠܪܘܚܐ ܕܡܛܥܝܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.7",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "1 John 4:7",
      "text": "ܚܒܝܒܝ ܢܚܒ ܚܕ ܠܚܕ ܡܛܠ ܕܚܘܒܐ ܡܢ ܐܠܗܐ ܗܘ ܘܟܠ ܡܢ ܕܡܚܒ ܡܢ ܐܠܗܐ ܝܠܝܕ ܘܝܕܥ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.8",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "1 John 4:8",
      "text": "ܡܛܠ ܕܐܠܗܐ ܚܘܒܐ ܗܘ ܘܟܠ ܕܠܐ ܡܚܒ ܠܐ ܝܕܥ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.9",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "1 John 4:9",
      "text": "ܒܗܕܐ ܐܬܝܕܥ ܚܘܒܗ ܕܐܠܗܐ ܕܠܘܬܢ ܕܠܒܪܗ ܝܚܝܕܝܐ ܫܕܪ ܐܠܗܐ ܠܥܠܡܐ ܕܢܚܐ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.10",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "1 John 4:10",
      "text": "ܒܗܢܐ ܐܝܬܘܗܝ ܚܘܒܐ ܠܐ ܗܘܐ ܕܚܢܢ ܐܚܒܢ ܠܐܠܗܐ ܐܠܐ ܗܘ ܐܚܒܢ ܘܫܕܪ ܠܒܪܗ ܚܘܤܝܐ ܥܠ ܐܦܝ ܚܛܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.11",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "1 John 4:11",
      "text": "ܚܒܝܒܝ ܐܢ ܗܟܢܐ ܐܚܒܢ ܐܠܗܐ ܐܦ ܚܢܢ ܚܝܒܝܢܢ ܚܕ ܠܚܕ ܠܡܚܒܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.12",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "1 John 4:12",
      "text": "ܠܐܠܗܐ ܡܡܬܘܡ ܐܢܫ ܠܐ ܚܙܝܗܝ ܐܢ ܕܝܢ ܢܚܒ ܚܕ ܠܚܕ ܐܠܗܐ ܒܢ ܡܩܘܐ ܘܚܘܒܗ ܡܫܬܡܠܐ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.13",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "1 John 4:13",
      "text": "ܘܒܗܕܐ ܝܕܥܝܢܢ ܕܒܗ ܡܩܘܝܢܢ ܘܗܘ ܡܩܘܐ ܒܢ ܕܡܢ ܪܘܚܗ ܝܗܒ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.14",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "1 John 4:14",
      "text": "ܘܚܢܢ ܚܙܝܢ ܘܡܤܗܕܝܢܢ ܕܐܒܐ ܫܕܪ ܠܒܪܗ ܦܪܘܩܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.15",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "1 John 4:15",
      "text": "ܟܠ ܕܡܘܕܐ ܒܝܫܘܥ ܕܗܘܝܘ ܒܪܗ ܕܐܠܗܐ ܐܠܗܐ ܒܗ ܡܩܘܐ ܘܗܘ ܡܩܘܐ ܒܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.16",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "1 John 4:16",
      "text": "ܘܚܢܢ ܗܝܡܢܢ ܘܝܕܥܢ ܚܘܒܐ ܕܐܝܬ ܠܗ ܠܐܠܗܐ ܨܐܕܝܢ ܐܠܗܐ ܓܝܪ ܚܘܒܐ ܗܘ ܘܟܠ ܕܡܩܘܐ ܒܚܘܒܐ ܒܐܠܗܐ ܡܩܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.17",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "1 John 4:17",
      "text": "ܘܒܗܕܐ ܡܫܬܠܡ ܚܘܒܗ ܥܡܢ ܕܓܠܝܘܬ ܐܦܐ ܬܗܘܐ ܠܢ ܒܝܘܡܐ ܕܕܝܢܐ ܡܛܠ ܕܐܝܟ ܕܗܘܐ ܗܘ ܗܟܢܐ ܐܦ ܚܢܢ ܐܝܬܝܢ ܒܗܢܐ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.18",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "1 John 4:18",
      "text": "ܕܚܠܬܐ ܒܚܘܒܐ ܠܝܬ ܐܠܐ ܚܘܒܐ ܡܫܡܠܝܐ ܠܒܪ ܫܕܐ ܠܗ ܠܕܚܠܬܐ ܡܛܠ ܕܕܚܠܬܐ ܒܩܢܛܐ ܐܝܬܝܗ ܗܘ ܕܝܢ ܕܕܚܠ ܠܐ ܡܫܡܠܝ ܒܚܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.19",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "1 John 4:19",
      "text": "ܚܢܢ ܗܟܝܠ ܢܚܒ ܠܐܠܗܐ ܡܛܠ ܕܗܘ ܩܕܡܝܬ ܐܚܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.20",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "1 John 4:20",
      "text": "ܐܢ ܕܝܢ ܐܢܫ ܢܐܡܪ ܕܡܚܒ ܐܢܐ ܠܐܠܗܐ ܘܠܐܚܘܗܝ ܤܢܐ ܕܓܠܐ ܗܘ ܗܘ ܓܝܪ ܕܠܐܚܘܗܝ ܕܡܬܚܙܐ ܠܐ ܡܚܒ ܠܐܠܗܐ ܗܘ ܕܠܐ ܡܬܚܙܐ ܐܝܟܢܐ ܡܫܟܚ ܕܢܚܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.4.21",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "1 John 4:21",
      "text": "ܘܗܢܐ ܦܘܩܕܢܐ ܩܒܠܢ ܡܢܗ ܕܟܠ ܕܡܚܒ ܠܐܠܗܐ ܢܚܒ ܐܦ ܠܐܚܘܗܝ ܀",
      "paragraphStart": false
    }
  ]
}
