{
  "chapter": {
    "id": "peshitta:first-john.2",
    "translationId": "peshitta",
    "bookSlug": "first-john",
    "chapterNumber": 2,
    "referenceLabel": "1 John 2",
    "summary": "Source text for 1 John 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-john.2.1",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "1 John 2:1",
      "text": "ܒܢܝ ܗܠܝܢ ܟܬܒ ܐܢܐ ܠܟܘܢ ܕܠܐ ܬܚܛܘܢ ܘܐܢ ܐܢܫ ܢܚܛܐ ܐܝܬ ܠܢ ܦܪܩܠܛܐ ܠܘܬ ܐܒܐ ܝܫܘܥ ܡܫܝܚܐ ܙܕܝܩܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-john.2.2",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "1 John 2:2",
      "text": "ܗܘܝܘ ܓܝܪ ܚܘܤܝܐ ܕܥܠ ܐܦܝ ܚܛܗܝܢ ܘܠܘ ܚܠܦܝܢ ܕܝܠܢ ܒܠܚܘܕ ܐܠܐ ܐܦ ܚܠܦ ܟܠܗ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.3",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "1 John 2:3",
      "text": "ܘܒܗܕܐ ܡܪܓܫܝܢܢ ܕܝܕܥܢܝܗܝ ܐܢ ܢܛܪܝܢܢ ܦܘܩܕܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.4",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "1 John 2:4",
      "text": "ܗܘ ܓܝܪ ܕܐܡܪ ܕܝܕܥܬܗ ܘܦܘܩܕܢܘܗܝ ܠܐ ܢܛܪ ܕܓܠܐ ܗܘ ܘܫܪܪܐ ܠܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.5",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "1 John 2:5",
      "text": "ܗܘ ܕܝܢ ܕܢܛܪ ܡܠܬܗ ܒܗܢܐ ܡܫܠܡ ܫܪܝܪܐܝܬ ܚܘܒܗ ܕܐܠܗܐ ܒܗܕܐ ܓܝܪ ܝܕܥܝܢܢ ܕܒܗ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.6",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "1 John 2:6",
      "text": "ܗܘ ܕܐܡܪ ܕܒܗ ܐܝܬܝ ܘܠܐ ܠܗ ܕܐܝܟ ܗܠܟܬܗ ܕܝܠܗ ܢܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.7",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "1 John 2:7",
      "text": "ܚܒܝܒܝ ܠܘ ܦܘܩܕܢܐ ܚܕܬܐ ܟܬܒ ܐܢܐ ܠܟܘܢ ܐܠܐ ܦܘܩܕܢܐ ܥܬܝܩܐ ܗܘ ܕܐܝܬ ܗܘܐ ܠܟܘܢ ܡܢ ܒܪܫܝܬ ܦܘܩܕܢܐ ܕܝܢ ܥܬܝܩܐ ܐܝܬܘܗܝ ܡܠܬܐ ܗܝ ܕܫܡܥܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.8",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "1 John 2:8",
      "text": "ܬܘܒ ܦܘܩܕܢܐ ܚܕܬܐ ܟܬܒ ܐܢܐ ܠܟܘܢ ܗܘ ܕܐܝܬܘܗܝ ܫܪܝܪܐ ܒܗ ܘܒܟܘܢ ܕܚܫܘܟܐ ܥܒܪ ܠܗ ܘܢܘܗܪܐ ܫܪܝܪܐ ܫܪܝ ܡܬܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.9",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "1 John 2:9",
      "text": "ܡܢ ܕܐܡܪ ܗܟܝܠ ܕܐܝܬܘܗܝ ܒܢܘܗܪܐ ܘܤܢܐ ܠܐܚܘܗܝ ܒܚܫܘܟܐ ܐܝܬܘܗܝ ܥܕܡܐ ܠܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.10",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "1 John 2:10",
      "text": "ܗܘ ܕܝܢ ܕܡܚܒ ܠܐܚܘܗܝ ܒܢܘܗܪܐ ܡܟܬܪ ܘܟܫܠܐ ܠܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.11",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "1 John 2:11",
      "text": "ܗܘ ܕܝܢ ܕܤܢܐ ܠܐܚܘܗܝ ܒܚܫܘܟܐ ܐܝܬܘܗܝ ܘܒܚܫܘܟܐ ܡܗܠܟ ܘܠܐ ܝܕܥ ܠܐܝܟܐ ܐܙܠ ܡܛܠ ܕܚܫܘܟܐ ܤܡܝ ܐܢܝܢ ܥܝܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.12",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "1 John 2:12",
      "text": "ܟܬܒ ܐܢܐ ܠܟܘܢ ܒܢܝܐ ܕܐܫܬܒܩܘ ܠܟܘܢ ܚܛܗܝܟܘܢ ܡܛܠ ܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.13",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "1 John 2:13",
      "text": "ܟܬܒ ܐܢܐ ܠܟܘܢ ܐܒܗܐ ܕܝܕܥܬܘܢܝܗܝ ܠܗܘ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܒܪܫܝܬ ܟܬܒ ܐܢܐ ܠܟܘܢ ܥܠܝܡܐ ܕܙܟܝܬܘܢܝܗܝ ܠܒܝܫܐ ܟܬܒܬ ܠܟܘܢ ܛܠܝܐ ܕܝܕܥܬܘܢ ܠܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.14",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "1 John 2:14",
      "text": "ܟܬܒܬ ܠܟܘܢ ܐܒܗܐ ܕܝܕܥܬܘܢ ܠܗܘ ܕܡܢ ܒܪܫܝܬ ܟܬܒܬ ܠܟܘܢ ܥܠܝܡܐ ܕܚܝܠܬܢܐ ܐܢܬܘܢ ܘܡܠܬܗ ܕܐܠܗܐ ܫܪܝܐ ܒܟܘܢ ܘܙܟܝܬܘܢܝܗܝ ܠܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.15",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "1 John 2:15",
      "text": "ܠܐ ܬܪܚܡܘܢ ܠܥܠܡܐ ܘܠܐ ܠܡܕܡ ܕܐܝܬ ܒܗ ܡܢ ܓܝܪ ܕܪܚܡ ܠܥܠܡܐ ܚܘܒܗ ܕܐܒܐ ܠܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.16",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "1 John 2:16",
      "text": "ܟܠ ܡܕܡ ܓܝܪ ܕܐܝܬ ܒܗ ܒܥܠܡܐ ܪܓܬܐ ܗܘ ܕܦܓܪܐ ܘܪܓܬܐ ܕܥܝܢܐ ܘܫܘܒܗܪܐ ܕܥܠܡܐ ܗܠܝܢ ܕܠܐ ܗܘܝ ܡܢ ܐܒܐ ܐܠܐ ܡܢܗ ܐܢܝܢ ܡܢ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.17",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "1 John 2:17",
      "text": "ܘܥܒܪ ܥܠܡܐ ܗܘ ܘܪܓܬܗ ܗܘ ܕܝܢ ܕܥܒܕ ܨܒܝܢܗ ܕܐܠܗܐ ܡܩܘܐ ܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.18",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "1 John 2:18",
      "text": "ܒܢܝ ܙܒܢܐ ܗܘ ܐܚܪܝܐ ܘܐܝܟ ܡܕܡ ܕܫܡܥܬܘܢ ܕܐܬܐ ܡܫܝܚܐ ܕܓܠܐ ܘܗܫܐ ܗܘܘ ܠܗܘܢ ܤܓܝܐܐ ܡܫܝܚܐ ܕܓܠܐ ܘܡܢ ܗܕܐ ܝܕܥܝܢܢ ܕܙܒܢܐ ܗܘ ܐܚܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.19",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "1 John 2:19",
      "text": "ܡܢܢ ܢܦܩܘ ܐܠܐ ܠܘ ܡܢܢ ܗܘܘ ܐܠܘ ܓܝܪ ܡܢܢ ܗܘܘ ܠܘܬܢ ܡܟܬܪܝܢ ܗܘܘ ܐܠܐ ܢܦܩܘ ܡܢܢ ܕܬܬܝܕܥ ܕܠܘ ܡܢܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.20",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "1 John 2:20",
      "text": "ܘܐܢܬܘܢ ܡܫܝܚܘܬܐ ܐܝܬ ܠܟܘܢ ܡܢ ܩܕܝܫܐ ܘܦܪܫܝܢ ܐܢܬܘܢ ܗܘ ܠܟܠ ܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.21",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "1 John 2:21",
      "text": "ܠܐ ܟܬܒܬ ܠܟܘܢ ܕܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܠܫܪܪܐ ܐܠܐ ܕܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܘܕܟܠܗ ܕܓܠܘܬܐ ܠܐ ܗܘܬ ܡܢܗ ܡܢ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.22",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "1 John 2:22",
      "text": "ܡܢܘ ܕܓܠܐ ܐܠܐ ܐܢ ܐܝܢܐ ܕܟܦܪ ܕܝܫܘܥ ܠܐ ܗܘܐ ܡܫܝܚܐ ܗܢܐ ܗܘ ܡܫܝܚܐ ܕܓܠܐ ܗܘ ܕܟܦܪ ܒܐܒܐ ܟܦܪ ܐܦ ܒܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.23",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "1 John 2:23",
      "text": "ܘܗܘ ܕܟܦܪ ܒܒܪܐ ܐܦܠܐ ܒܐܒܐ ܡܗܝܡܢ ܡܢ ܕܡܘܕܐ ܒܒܪܐ ܐܦ ܒܐܒܐ ܡܘܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.24",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "1 John 2:24",
      "text": "ܘܐܢܬܘܢ ܡܕܡ ܕܫܡܥܬܘܢ ܡܢ ܩܕܝܡ ܢܩܘܐ ܠܘܬܟܘܢ ܐܢ ܓܝܪ ܡܩܘܐ ܠܘܬܟܘܢ ܡܕܡ ܕܫܡܥܬܘܢ ܡܢ ܩܕܝܡ ܐܦ ܐܢܬܘܢ ܡܩܘܝܢ ܐܢܬܘܢ ܒܐܒܐ ܘܒܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.25",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "1 John 2:25",
      "text": "ܘܗܢܘ ܫܘܘܕܝܐ ܕܐܫܬܘܕܝ ܠܢ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.26",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "1 John 2:26",
      "text": "ܗܠܝܢ ܕܝܢ ܟܬܒܬ ܠܟܘܢ ܡܛܠ ܐܝܠܝܢ ܕܡܛܥܝܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.27",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "1 John 2:27",
      "text": "ܘܐܦ ܐܢܬܘܢ ܐܢ ܬܩܘܐ ܠܘܬܟܘܢ ܡܫܝܚܘܬܐ ܕܩܒܠܬܘܢ ܡܢܗ ܠܐ ܤܢܝܩܝܢ ܐܢܬܘܢ ܕܐܢܫ ܢܠܦܟܘܢ ܐܠܐ ܐܝܟ ܡܫܝܚܘܬܐ ܕܐܝܬܝܗ ܡܢ ܐܠܗܐ ܗܝ ܡܠܦܐ ܠܟܘܢ ܥܠ ܟܠܡܕܡ ܘܫܪܝܪܐ ܗܝ ܘܠܝܬ ܒܗ ܕܓܠܘܬܐ ܘܐܝܟ ܕܐܠܦܟܘܢ ܩܘܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.28",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "1 John 2:28",
      "text": "ܘܗܫܐ ܒܢܝ ܩܘܘ ܒܗ ܕܡܐ ܕܡܬܓܠܐ ܠܐ ܢܒܗܬ ܡܢܗ ܐܠܐ ܬܗܘܐ ܠܢ ܓܠܝܘܬ ܐܦܐ ܒܡܐܬܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.2.29",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "1 John 2:29",
      "text": "ܐܢ ܝܕܥܬܘܢ ܕܙܕܝܩ ܗܘ ܕܥܘ ܕܐܦ ܟܠ ܕܥܒܕ ܙܕܝܩܘܬܐ ܡܢܗ ܐܝܬܘܗܝ ܀",
      "paragraphStart": false
    }
  ]
}
