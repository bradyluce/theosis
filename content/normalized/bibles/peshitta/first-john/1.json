    "referenceLabel": "1 John 1",
    "summary": "Source text for 1 John 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-john.1.1",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "1 John 1:1",
      "text": "ܡܤܒܪܝܢܢ ܠܟܘܢ ܠܗܘ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܒܪܫܝܬ ܗܘ ܕܫܡܥܢ ܘܚܙܝܢܝܗܝ ܒܥܝܢܝܢ ܚܙܝܢ ܘܓܫܢ ܒܐܝܕܝܢ ܗܘ ܕܐܝܬܘܗܝ ܡܠܬܐ ܕܚܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-john.1.2",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "1 John 1:2",
      "text": "ܘܚܝܐ ܐܬܓܠܝܘ ܘܚܙܝܢ ܘܤܗܕܝܢܢ ܘܡܟܪܙܝܢܢ ܠܟܘܢ ܚܝܐ ܕܠܥܠܡ ܗܢܘܢ ܕܐܝܬܝܗܘܢ ܗܘܘ ܠܘܬ ܐܒܐ ܘܐܬܓܠܝܘ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.3",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "1 John 1:3",
      "text": "ܘܡܕܡ ܕܚܙܝܢ ܘܫܡܥܢ ܡܘܕܥܝܢܢ ܐܦ ܠܟܘܢ ܕܬܗܘܐ ܠܟܘܢ ܫܘܬܦܘܬܐ ܥܡܢ ܘܫܘܬܦܘܬܢ ܕܝܢ ܕܝܠܢ ܐܝܬܝܗ ܥܡ ܐܒܐ ܘܥܡ ܒܪܗ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.4",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "1 John 1:4",
      "text": "ܘܗܠܝܢ ܟܬܒܝܢܢ ܠܟܘܢ ܕܚܕܘܬܢ ܕܒܟܘܢ ܬܗܘܐ ܡܫܡܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.5",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "1 John 1:5",
      "text": "ܘܗܕܐ ܗܝ ܤܒܪܬܐ ܕܫܡܥܢ ܡܢܗ ܘܡܤܒܪܝܢܢ ܠܟܘܢ ܕܐܠܗܐ ܢܘܗܪܐ ܗܘ ܘܚܫܘܟܐ ܟܠ ܟܠܗ ܠܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.6",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "1 John 1:6",
      "text": "ܘܐܢ ܐܡܪܝܢܢ ܕܫܘܬܦܘܬܐ ܐܝܬ ܠܢ ܥܡܗ ܘܡܗܠܟܝܢܢ ܒܚܫܘܟܐ ܕܓܠܐ ܚܢܢ ܘܠܘ ܒܫܪܪܐ ܪܕܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.7",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "1 John 1:7",
      "text": "ܐܢ ܕܝܢ ܒܢܘܗܪܐ ܡܗܠܟܝܢܢ ܐܝܟ ܕܗܘ ܐܝܬܘܗܝ ܒܢܘܗܪܐ ܐܝܬ ܠܢ ܫܘܬܦܘܬܐ ܥܡ ܚܕܕܐ ܘܕܡܐ ܕܝܫܘܥ ܒܪܗ ܡܕܟܐ ܠܢ ܡܢ ܟܠܗܘܢ ܚܛܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.8",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "1 John 1:8",
      "text": "ܘܐܢ ܢܐܡܪ ܕܠܝܬ ܠܢ ܚܛܝܬܐ ܢܦܫܢ ܡܛܥܝܢܢ ܘܫܪܪܐ ܠܝܬ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.9",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "1 John 1:9",
      "text": "ܐܢ ܕܝܢ ܡܘܕܝܢܢ ܒܚܛܗܝܢ ܡܗܝܡܢ ܗܘ ܘܙܕܝܩ ܕܢܫܒܘܩ ܠܢ ܚܛܗܝܢ ܘܢܕܟܝܢ ܡܢ ܟܠܗ ܥܘܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.1.10",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "1 John 1:10",
      "text": "ܘܐܢ ܐܡܪܝܢܢ ܕܠܐ ܚܛܝܢ ܥܒܕܝܢܢ ܠܗ ܕܓܠܐ ܘܡܠܬܗ ܠܝܬ ܠܘܬܢ ܀",
      "paragraphStart": false
    }
  ]
}
