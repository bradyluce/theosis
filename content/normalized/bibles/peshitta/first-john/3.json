    "bookSlug": "first-john",
    "chapterNumber": 3,
    "referenceLabel": "1 John 3",
    "summary": "Source text for 1 John 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:first-john.3.1",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "1 John 3:1",
      "text": "ܘܚܙܘ ܕܟܡܐ ܤܓܝ ܚܘܒܗ ܕܐܒܐ ܠܘܬܢ ܕܒܢܝܐ ܩܪܢ ܐܦ ܥܒܕܢ ܡܛܠ ܗܢܐ ܥܠܡܐ ܠܐ ܝܕܥ ܠܢ ܡܛܠ ܕܐܦܠܐ ܠܗ ܝܕܥ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:first-john.3.2",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "1 John 3:2",
      "text": "ܚܒܝܒܝ ܗܫܐ ܒܢܘܗܝ ܚܢܢ ܕܐܠܗܐ ܘܠܐ ܐܬܓܠܝ ܥܕܡܐ ܠܗܫܐ ܡܢܐ ܥܬܝܕܝܢܢ ܕܢܗܘܐ ܝܕܥܝܢܢ ܕܝܢ ܕܡܐ ܕܐܬܓܠܝ ܒܕܡܘܬܗ ܗܘܝܢܢ ܘܚܙܝܢܢ ܠܗ ܐܝܟ ܡܕܡ ܕܐܝܬܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.3",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "1 John 3:3",
      "text": "ܘܟܠ ܐܝܢܐ ܕܐܝܬ ܠܗ ܥܠܘܗܝ ܗܢܐ ܤܒܪܐ ܡܕܟܐ ܢܦܫܗ ܐܝܟ ܕܗܘ ܕܟܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.4",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "1 John 3:4",
      "text": "ܡܢ ܕܝܢ ܕܥܒܕ ܚܛܝܬܐ ܥܘܠܐ ܤܥܪ ܚܛܝܬܐ ܓܝܪ ܟܠܗ ܥܘܠܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.5",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "1 John 3:5",
      "text": "ܘܝܕܥܝܢ ܐܢܬܘܢ ܕܗܘ ܕܐܬܓܠܝ ܕܢܤܒ ܚܛܗܝܢ ܘܚܛܝܬܐ ܒܗ ܠܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.6",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "1 John 3:6",
      "text": "ܘܟܠ ܕܒܗ ܡܩܘܐ ܠܐ ܚܛܐ ܘܟܠ ܕܚܛܐ ܠܐ ܚܙܝܗܝ ܘܠܐ ܝܕܥܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.7",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "1 John 3:7",
      "text": "ܒܢܝ ܠܐ ܐܢܫ ܢܛܥܝܟܘܢ ܗܘ ܕܥܒܕ ܙܕܝܩܘܬܐ ܙܕܝܩܐ ܗܘ ܐܝܟ ܕܐܦ ܗܘ ܡܫܝܚܐ ܐܝܬܘܗܝ ܙܕܝܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.8",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "1 John 3:8",
      "text": "ܗܘ ܕܤܥܪ ܚܛܝܬܐ ܡܢ ܤܛܢܐ ܗܘ ܡܛܠ ܕܡܢ ܪܫܝܬܐ ܗܘ ܤܛܢܐ ܚܛܝܐ ܗܘ ܘܡܛܠ ܗܢܐ ܐܬܚܙܝ ܒܪܗ ܕܐܠܗܐ ܕܢܫܪܐ ܥܒܕܘܗܝ ܕܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.9",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "1 John 3:9",
      "text": "ܟܠ ܕܐܬܝܠܕ ܡܢ ܐܠܗܐ ܚܛܝܬܐ ܠܐ ܥܒܕ ܡܛܠ ܕܙܪܥܗ ܒܗ ܐܝܬܘܗܝ ܘܠܐ ܡܫܟܚ ܠܡܚܛܐ ܕܡܢ ܐܠܗܐ ܐܬܝܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.10",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "1 John 3:10",
      "text": "ܒܗܕܐ ܡܬܦܪܫܝܢ ܒܢܘܗܝ ܕܐܠܗܐ ܡܢ ܒܢܘܗܝ ܕܤܛܢܐ ܟܠ ܕܠܐ ܥܒܕ ܙܕܝܩܘܬܐ ܘܠܐ ܡܚܒ ܠܐܚܘܗܝ ܠܝܬܘܗܝ ܡܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.11",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "1 John 3:11",
      "text": "ܕܗܢܘ ܦܘܩܕܢܐ ܕܫܡܥܬܘܢ ܡܢ ܩܕܝܡ ܕܬܚܒܘܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.12",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "1 John 3:12",
      "text": "ܠܘ ܐܝܟ ܩܐܝܢ ܗܘ ܕܐܝܬܘܗܝ ܗܘܐ ܡܢ ܒܝܫܐ ܘܩܛܠ ܠܐܚܘܗܝ ܘܡܛܠ ܡܢܐ ܩܛܠܗ ܐܠܐ ܡܛܠ ܕܒܝܫܝܢ ܗܘܘ ܥܒܕܘܗܝ ܘܕܐܚܘܗܝ ܙܕܝܩܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.13",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "1 John 3:13",
      "text": "ܘܠܐ ܬܬܕܡܪܘܢ ܐܚܝ ܐܢ ܤܢܐ ܠܟܘܢ ܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.14",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "1 John 3:14",
      "text": "ܚܢܢ ܝܕܥܝܢܢ ܕܫܢܝܢܢ ܡܢ ܡܘܬܐ ܠܚܝܐ ܒܗܕܐ ܕܡܚܒܝܢܢ ܠܐܚܝܢ ܗܘ ܕܠܐ ܡܚܒ ܠܐܚܘܗܝ ܡܩܘܐ ܒܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.15",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "1 John 3:15",
      "text": "ܟܠ ܓܝܪ ܕܤܢܐ ܠܐܚܘܗܝ ܩܛܠ ܐܢܫܐ ܗܘ ܘܝܕܥܝܢ ܐܢܬܘܢ ܕܟܠ ܕܩܛܠ ܐܢܫܐ ܠܐ ܡܫܟܚܝܢ ܡܩܘܝܢ ܒܗ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.16",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "1 John 3:16",
      "text": "ܒܗܕܐ ܝܕܥܝܢܢ ܚܘܒܗ ܕܠܘܬܢ ܕܗܘ ܝܗܒ ܢܦܫܗ ܚܠܦܝܢ ܘܐܦ ܚܢܢ ܙܕܩ ܠܢ ܕܥܠ ܐܦܝ ܐܚܝܢ ܢܬܠ ܢܦܫܬܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.17",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "1 John 3:17",
      "text": "ܘܐܝܢܐ ܕܐܝܬ ܠܗ ܩܢܝܢܐ ܕܥܠܡܐ ܘܢܚܙܐ ܠܐܚܘܗܝ ܕܤܢܝܩ ܘܢܐܚܘܕ ܪܚܡܘܗܝ ܡܢܗ ܐܝܟܢܐ ܐܝܬ ܒܗ ܚܘܒܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.18",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "1 John 3:18",
      "text": "ܒܢܝ ܠܐ ܢܚܒ ܚܕ ܠܚܕ ܒܡܠܐ ܘܒܠܫܢܐ ܐܠܐ ܒܥܒܕܐ ܘܒܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.19",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "1 John 3:19",
      "text": "ܘܒܗܕܐ ܡܫܬܘܕܥܝܢܢ ܕܡܢ ܫܪܪܐ ܐܝܬܝܢ ܘܩܕܡ ܕܢܐܬܐ ܗܘ ܡܦܝܤܝܢܢ ܠܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.20",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "1 John 3:20",
      "text": "ܕܐܢ ܗܘ ܠܒܢ ܒܤܪ ܠܢ ܟܡܐ ܐܠܗܐ ܕܪܒ ܡܢ ܠܒܢ ܘܝܕܥ ܟܠܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.21",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "1 John 3:21",
      "text": "ܚܒܝܒܝ ܐܢ ܠܒܢ ܠܐ ܒܤܪ ܠܢ ܓܠܝܢ ܐܢܝܢ ܐܦܝܢ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.22",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "1 John 3:22",
      "text": "ܘܟܠܡܕܡ ܕܫܐܠܝܢܢ ܢܤܒܝܢܢ ܡܢܗ ܡܛܠ ܕܢܛܪܝܢܢ ܦܘܩܕܢܘܗܝ ܘܫܦܝܪܬܐ ܤܥܪܝܢܢ ܩܕܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.23",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "1 John 3:23",
      "text": "ܘܗܢܐ ܗܘ ܦܘܩܕܢܗ ܕܢܗܝܡܢ ܒܫܡܐ ܕܒܪܗ ܝܫܘܥ ܡܫܝܚܐ ܘܢܚܒ ܚܕ ܠܚܕ ܐܝܟ ܕܦܩܕܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:first-john.3.24",
      "translationId": "peshitta",
      "bookSlug": "first-john",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "1 John 3:24",
      "text": "ܘܐܝܢܐ ܕܢܛܪ ܦܘܩܕܢܘܗܝ ܒܗ ܡܬܢܛܪ ܘܗܘ ܫܪܐ ܒܗ ܘܒܗܕܐ ܡܤܬܟܠܝܢܢ ܕܫܪܐ ܒܢ ܡܢ ܪܘܚܗ ܗܝ ܕܝܗܒ ܠܢ ܀",
      "paragraphStart": false
    }
  ]
}
