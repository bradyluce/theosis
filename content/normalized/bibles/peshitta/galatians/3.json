    "summary": "Source text for Galatians 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:galatians.3.1",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Galatians 3:1",
      "text": "ܐܘ ܚܤܝܪܝ ܪܥܝܢܐ ܓܠܛܝܐ ܡܢܘ ܚܤܡ ܒܟܘܢ ܕܗܐ ܐܝܟ ܗܘ ܕܡܨܪ ܨܝܪ ܗܘܐ ܩܕܡ ܥܝܢܝܟܘܢ ܝܫܘܥ ܡܫܝܚܐ ܟܕ ܨܠܝܒ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:galatians.3.2",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Galatians 3:2",
      "text": "ܗܕܐ ܒܠܚܘܕ ܨܒܐ ܐܢܐ ܕܐܕܥ ܡܢܟܘܢ ܡܢ ܥܒܕܐ ܕܢܡܘܤܐ ܢܤܒܬܘܢ ܪܘܚܐ ܐܘ ܡܢ ܫܡܥܐ ܕܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.3",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Galatians 3:3",
      "text": "ܗܟܢܐ ܤܟܠܝܢ ܐܢܬܘܢ ܕܫܪܝܬܘܢ ܒܪܘܚܐ ܘܗܫܐ ܒܒܤܪ ܡܫܠܡܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.4",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Galatians 3:4",
      "text": "ܗܠܝܢ ܟܠܗܝܢ ܐܝܩܐ ܤܝܒܪܬܘܢ ܘܐܫܬܘܦ ܕܝܢ ܐܝܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.5",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Galatians 3:5",
      "text": "ܗܘ ܗܟܝܠ ܕܝܗܒ ܒܟܘܢ ܪܘܚܐ ܘܤܥܪ ܒܟܘܢ ܚܝܠܐ ܡܢ ܥܒܕܐ ܕܢܡܘܤܐ ܐܘ ܡܢ ܫܡܥܐ ܕܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.6",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Galatians 3:6",
      "text": "ܐܝܟܢܐ ܕܗܝܡܢ ܐܒܪܗܡ ܠܐܠܗܐ ܘܐܬܚܫܒܬ ܠܗ ܠܙܕܝܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.7",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Galatians 3:7",
      "text": "ܕܥܘ ܗܟܝܠ ܕܐܝܠܝܢ ܕܡܢ ܗܝܡܢܘܬܐ ܐܢܘܢ ܗܢܘܢ ܐܢܘܢ ܒܢܝܐ ܕܐܒܪܗܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.8",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Galatians 3:8",
      "text": "ܡܛܠ ܓܝܪ ܕܩܕܡ ܝܕܥ ܐܠܗܐ ܕܒܗܝܡܢܘܬܐ ܗܘ ܡܙܕܕܩܝܢ ܥܡܡܐ ܩܕܡ ܤܒܪ ܠܐܒܪܗܡ ܐܝܟ ܕܐܡܪ ܟܬܒܐ ܩܕܝܫܐ ܕܒܟ ܢܬܒܪܟܘܢ ܟܠܗܘܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.9",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Galatians 3:9",
      "text": "ܡܕܝܢ ܡܗܝܡܢܐ ܗܘ ܡܬܒܪܟܝܢ ܒܐܒܪܗܡ ܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.10",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Galatians 3:10",
      "text": "ܐܝܠܝܢ ܓܝܪ ܕܡܢ ܥܒܕܐ ܐܢܘܢ ܕܢܡܘܤܐ ܬܚܝܬ ܠܘܛܬܐ ܐܢܘܢ ܟܬܝܒ ܓܝܪ ܕܠܝܛ ܗܘ ܟܠܡܢ ܕܠܐ ܢܥܒܕ ܟܠ ܕܟܬܝܒ ܒܢܡܘܤܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.11",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Galatians 3:11",
      "text": "ܕܠܐ ܕܝܢ ܡܙܕܕܩ ܐܢܫ ܒܢܡܘܤܐ ܠܘܬ ܐܠܗܐ ܗܕܐ ܓܠܝܐ ܗܝ ܡܛܠ ܕܟܬܝܒ ܕܙܕܝܩܐ ܒܗܝܡܢܘܬܐ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.12",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Galatians 3:12",
      "text": "ܢܡܘܤܐ ܕܝܢ ܠܐ ܗܘܐ ܡܢ ܗܝܡܢܘܬܐ ܐܠܐ ܡܢ ܕܢܥܒܕ ܐܝܠܝܢ ܕܟܬܝܒܢ ܒܗ ܢܚܐ ܒܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.13",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Galatians 3:13",
      "text": "ܠܢ ܕܝܢ ܡܫܝܚܐ ܙܒܢܢ ܡܢ ܠܘܛܬܐ ܕܢܡܘܤܐ ܘܗܘ ܗܘܐ ܚܠܦܝܢ ܠܘܛܬܐ ܟܬܝܒ ܓܝܪ ܕܠܝܛ ܗܘ ܟܠܡܢ ܕܡܬܬܠܐ ܒܩܝܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.14",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Galatians 3:14",
      "text": "ܕܒܥܡܡܐ ܬܗܘܐ ܒܘܪܟܬܗ ܕܐܒܪܗܡ ܒܝܫܘܥ ܡܫܝܚܐ ܘܚܢܢ ܢܤܒ ܫܘܘܕܝܐ ܕܪܘܚܐ ܒܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.15",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Galatians 3:15",
      "text": "ܐܚܝ ܐܝܟ ܕܒܝܬ ܒܢܝܢܫܐ ܐܡܪ ܐܢܐ ܕܕܝܬܩܐ ܕܒܪܢܫܐ ܕܐܫܬܪܪܬ ܐܢܫ ܠܐ ܡܤܠܐ ܐܘ ܡܫܚܠܦ ܒܗ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.16",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Galatians 3:16",
      "text": "ܠܐܒܪܗܡ ܕܝܢ ܐܬܡܠܟ ܡܘܠܟܢܐ ܘܠܙܪܥܗ ܘܠܐ ܐܡܪ ܠܗ ܕܠܙܪܥܝܟ ܐܝܟ ܕܠܤܓܝܐܐ ܐܠܐ ܠܙܪܥܟ ܐܝܟ ܕܠܚܕ ܗܘ ܕܐܝܬܘܗܝ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.17",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Galatians 3:17",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܐܢܐ ܕܕܝܬܩܐ ܕܡܢ ܩܕܝܡ ܐܫܬܪܪܬ ܡܢ ܐܠܗܐ ܒܡܫܝܚܐ ܢܡܘܤܐ ܗܘ ܕܗܘܐ ܡܢ ܒܬܪ ܐܪܒܥ ܡܐܐ ܘܬܠܬܝܢ ܫܢܝܢ ܠܐ ܡܫܟܚ ܕܢܤܠܝܗ ܘܢܒܛܠ ܡܘܠܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.18",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Galatians 3:18",
      "text": "ܐܢ ܕܝܢ ܡܢ ܢܡܘܤܐ ܗܝ ܝܪܬܘܬܐ ܡܟܝܠ ܠܐ ܗܘܬ ܡܢ ܡܘܠܟܢܐ ܠܐܒܪܗܡ ܕܝܢ ܒܡܘܠܟܢܐ ܗܘ ܝܗܒ ܠܗ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.19",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Galatians 3:19",
      "text": "ܡܢܐ ܗܟܝܠ ܢܡܘܤܐ ܡܛܠ ܡܤܛܝܢܘܬܐ ܐܬܬܘܤܦ ܥܕܡܐ ܕܢܐܬܐ ܙܪܥܐ ܗܘ ܕܠܗ ܗܘܐ ܫܘܘܕܝܐ ܘܐܬܝܗܒ ܗܘ ܢܡܘܤܐ ܒܝܕ ܡܠܐܟܐ ܒܐܝܕܐ ܕܡܨܥܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.20",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Galatians 3:20",
      "text": "ܡܨܥܝܐ ܕܝܢ ܠܐ ܗܘܐ ܕܚܕ ܐܠܗܐ ܕܝܢ ܚܕ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.21",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Galatians 3:21",
      "text": "ܢܡܘܤܐ ܗܟܝܠ ܤܩܘܒܠܐ ܗܘ ܕܡܘܠܟܢܐ ܕܐܠܗܐ ܚܤ ܐܠܘ ܓܝܪ ܐܬܝܗܒ ܗܘܐ ܢܡܘܤܐ ܐܝܢܐ ܕܡܫܟܚ ܗܘܐ ܠܡܚܝܘ ܫܪܝܪܐܝܬ ܡܢ ܢܡܘܤܐ ܗܘܝܐ ܗܘܬ ܙܕܝܩܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.22",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Galatians 3:22",
      "text": "ܐܠܐ ܚܒܫ ܟܬܒܐ ܟܠܡܕܡ ܬܚܝܬ ܚܛܝܬܐ ܕܡܘܠܟܢܐ ܒܗܝܡܢܘܬܐ ܕܝܫܘܥ ܡܫܝܚܐ ܢܬܝܗܒ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.3.23",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Galatians 3:23",
      "text": "ܥܕܠܐ ܕܝܢ ܬܐܬܐ ܗܝܡܢܘܬܐ ܢܡܘܤܐ ܢܛܪ ܗܘܐ ܠܢ ܟܕ ܚܒܝܫܝܢܢ ܠܗܝܡܢܘܬܐ ܕܥܬܝܕܐ ܗܘܬ ܠܡܬܓܠܝܘ ܀",
