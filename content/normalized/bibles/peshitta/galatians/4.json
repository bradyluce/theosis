    "bookSlug": "galatians",
    "chapterNumber": 4,
    "referenceLabel": "Galatians 4",
    "summary": "Source text for Galatians 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:galatians.4.1",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Galatians 4:1",
      "text": "ܐܡܪ ܐܢܐ ܕܝܢ ܕܟܡܐ ܙܒܢܐ ܕܝܪܬܐ ܛܠܐ ܠܐ ܦܪܝܫ ܡܢ ܥܒܕܐ ܟܕ ܡܪܐ ܗܘ ܕܟܠܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:galatians.4.2",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Galatians 4:2",
      "text": "ܐܠܐ ܬܚܝܬ ܐܦܛܪܘܦܐ ܐܝܬܘܗܝ ܘܪܒܝ ܒܬܐ ܥܕܡܐ ܠܙܒܢܐ ܕܤܡ ܐܒܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.3",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Galatians 4:3",
      "text": "ܗܟܢܐ ܐܦ ܚܢܢ ܟܕ ܝܠܘܕܐ ܗܘܝܢ ܬܚܝܬ ܐܤܛܘܟܤܘܗܝ ܕܥܠܡܐ ܡܫܥܒܕܝܢ ܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.4",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Galatians 4:4",
      "text": "ܟܕ ܡܛܐ ܕܝܢ ܫܘܠܡܗ ܕܙܒܢܐ ܫܕܪ ܐܠܗܐ ܠܒܪܗ ܘܗܘܐ ܡܢ ܐܢܬܬܐ ܘܗܘܐ ܬܚܝܬ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.5",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Galatians 4:5",
      "text": "ܕܠܐܝܠܝܢ ܕܬܚܝܬ ܢܡܘܤܐ ܐܢܘܢ ܢܙܒܢ ܘܢܩܒܠ ܤܝܡܬ ܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.6",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Galatians 4:6",
      "text": "ܘܕܐܝܬܝܟܘܢ ܕܝܢ ܒܢܝܐ ܫܕܪ ܐܠܗܐ ܪܘܚܐ ܕܒܪܗ ܠܠܒܘܬܟܘܢ ܗܝ ܕܩܪܝܐ ܐܒܐ ܐܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.7",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Galatians 4:7",
      "text": "ܡܟܝܠ ܠܐ ܗܘܝܬܘܢ ܥܒܕܐ ܐܠܐ ܒܢܝܐ ܘܐܢ ܒܢܝܐ ܐܦ ܝܪܬܐ ܕܐܠܗܐ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.8",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Galatians 4:8",
      "text": "ܗܝܕܝܢ ܓܝܪ ܟܕ ܠܐ ܝܕܥܝܢ ܗܘܝܬܘܢ ܠܐܠܗܐ ܦܠܚܬܘܢ ܠܗܢܘܢ ܕܡܢ ܟܝܢܗܘܢ ܠܐ ܗܘܘ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.9",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Galatians 4:9",
      "text": "ܗܫܐ ܕܝܢ ܕܝܕܥܬܘܢ ܠܐܠܗܐ ܘܝܬܝܪܐܝܬ ܕܐܬܝܕܥܬܘܢ ܡܢ ܐܠܗܐ ܬܘܒ ܗܦܟܬܘܢ ܠܟܘܢ ܥܠ ܗܢܘܢ ܐܤܛܘܟܤܐ ܡܪܥܐ ܘܡܤܟܢܐ ܘܡܢ ܕܪܝܫ ܨܒܝܬܘܢ ܠܡܫܬܥܒܕܘ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.10",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Galatians 4:10",
      "text": "ܝܘܡܐ ܘܝܪܚܐ ܘܙܒܢܐ ܘܫܢܝܐ ܢܛܪܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.11",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Galatians 4:11",
      "text": "ܕܚܠ ܐܢܐ ܕܠܡܐ ܤܪܝܩܐܝܬ ܠܐܝܬ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.12",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Galatians 4:12",
      "text": "ܗܘܘ ܐܟܘܬܝ ܡܛܠ ܕܐܦ ܐܢܐ ܐܟܘܬܟܘܢ ܗܘܝܬ ܐܚܝ ܒܥܐ ܐܢܐ ܡܢܟܘܢ ܠܐ ܡܕܡ ܐܤܟܠܬܘܢ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.13",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Galatians 4:13",
      "text": "ܝܕܥܝܢ ܐܢܬܘܢ ܓܝܪ ܕܒܟܪܝܗܘܬ ܒܤܪܝ ܤܒܪܬܟܘܢ ܗܘܝܬ ܡܢ ܩܕܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.14",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Galatians 4:14",
      "text": "ܘܢܤܝܘܢܐ ܕܒܤܪܝ ܠܐ ܫܛܬܘܢ ܘܠܐ ܢܕܬܘܢ ܐܠܐ ܐܝܟ ܕܠܡܠܐܟܐ ܕܐܠܗܐ ܩܒܠܬܘܢܢܝ ܘܐܝܟ ܕܠܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.15",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Galatians 4:15",
      "text": "ܐܝܟܘ ܗܟܝܠ ܛܘܒܟܘܢ ܤܗܕ ܐܢܐ ܓܝܪ ܥܠܝܟܘܢ ܕܐܠܘ ܡܫܟܚܐ ܗܘܬ ܥܝܢܝܟܘܢ ܚܨܝܢ ܗܘܝܬܘܢ ܘܝܗܒܝܢ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.16",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Galatians 4:16",
      "text": "ܕܠܡܐ ܒܥܠܕܒܒܐ ܗܘܝܬ ܠܟܘܢ ܕܐܟܪܙܬ ܠܟܘܢ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.17",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Galatians 4:17",
      "text": "ܚܤܡܝܢ ܒܟܘܢ ܠܐ ܗܘܐ ܠܫܦܝܪܬܐ ܐܠܐ ܠܡܚܒܫܟܘܢ ܗܘ ܨܒܝܢ ܕܐܢܬܘܢ ܬܗܘܘܢ ܚܤܡܝܢ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.18",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Galatians 4:18",
      "text": "ܫܦܝܪ ܗܘ ܕܝܢ ܕܬܬܚܤܡܘܢ ܒܫܦܝܪܬܐ ܒܟܠܙܒܢ ܘܠܐ ܐܡܬܝ ܕܠܘܬܟܘܢ ܐܢܐ ܒܠܚܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.19",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Galatians 4:19",
      "text": "ܒܢܝ ܐܝܠܝܢ ܕܡܢ ܕܪܝܫ ܡܚܒܠ ܐܢܐ ܥܕܡܐ ܕܢܬܬܨܝܪ ܒܟܘܢ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.20",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Galatians 4:20",
      "text": "ܨܒܐ ܗܘܝܬ ܕܝܢ ܕܐܗܘܐ ܠܘܬܟܘܢ ܗܫܐ ܘܐܫܚܠܦ ܒܪܬ ܩܠܝ ܡܛܠ ܕܬܡܝܗ ܐܢܐ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.21",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Galatians 4:21",
      "text": "ܐܡܪܘ ܠܝ ܐܢܬܘܢ ܐܝܠܝܢ ܕܨܒܝܢ ܕܢܗܘܘܢ ܬܚܝܬ ܢܡܘܤܐ ܠܗ ܠܢܡܘܤܐ ܠܐ ܫܡܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.22",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Galatians 4:22",
      "text": "ܟܬܝܒ ܓܝܪ ܕܠܐܒܪܗܡ ܬܪܝܢ ܒܢܝܢ ܗܘܘ ܠܗ ܚܕ ܡܢ ܐܡܬܐ ܘܚܕ ܡܢ ܚܐܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.23",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Galatians 4:23",
      "text": "ܐܠܐ ܗܘ ܕܡܢ ܐܡܬܐ ܒܒܤܪ ܐܬܝܠܕ ܗܘ ܕܝܢ ܕܡܢ ܚܐܪܬܐ ܒܡܘܠܟܢܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.24",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Galatians 4:24",
      "text": "ܗܠܝܢ ܕܝܢ ܐܝܬܝܗܝܢ ܦܠܐܬܐ ܕܬܪܬܝܢ ܕܝܬܩܤ ܚܕܐ ܕܡܢ ܛܘܪ ܤܝܢܝ ܝܠܕܐ ܠܥܒܕܘܬܐ ܕܐܝܬܝܗ ܗܓܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.25",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Galatians 4:25",
      "text": "ܗܓܪ ܓܝܪ ܛܘܪܐ ܗܘ ܕܤܝܢܝ ܕܒܐܪܒܝܐ ܘܫܠܡܐ ܠܗܕܐ ܐܘܪܫܠܡ ܘܦܠܚܐ ܥܒܕܘܬܐ ܗܝ ܘܒܢܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.26",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Galatians 4:26",
      "text": "ܗܝ ܕܝܢ ܐܘܪܫܠܡ ܥܠܝܬܐ ܚܐܪܬܐ ܗܝ ܕܐܝܬܝܗ ܐܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.27",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Galatians 4:27",
      "text": "ܟܬܝܒ ܓܝܪ ܕܐܬܒܤܡܝ ܥܩܪܬܐ ܗܝ ܕܠܐ ܝܠܕܐ ܘܐܬܦܨܚܝ ܘܓܥܝ ܗܝ ܕܠܐ ܡܚܒܠܐ ܡܛܠ ܕܤܓܝܘ ܒܢܝܗ ܕܨܕܝܬܐ ܝܬܝܪ ܡܢ ܒܢܝܗ ܕܒܥܝܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.28",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Galatians 4:28",
      "text": "ܚܢܢ ܕܝܢ ܐܚܝ ܐܝܟ ܐܝܤܚܩ ܒܢܝ ܡܘܠܟܢܐ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.29",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Galatians 4:29",
      "text": "ܘܐܝܟ ܕܗܝܕܝܢ ܗܘ ܕܝܠܝܕ ܗܘܐ ܒܒܤܪܐ ܪܕܦ ܗܘܐ ܠܗܘ ܕܒܪܘܚܐ ܗܟܢܐ ܐܦ ܗܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.30",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Galatians 4:30",
      "text": "ܐܠܐ ܡܢܐ ܐܡܪ ܟܬܒܐ ܐܦܩܝܗ ܠܐܡܬܐ ܘܠܒܪܗ ܡܛܠ ܕܠܐ ܢܐܪܬ ܒܪܗ ܕܐܡܬܐ ܥܡ ܒܪܗ ܕܚܐܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.4.31",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Galatians 4:31",
      "text": "ܚܢܢ ܗܟܝܠ ܐܚܝ ܠܐ ܗܘܝܢ ܒܢܝ ܐܡܬܐ ܐܠܐ ܒܢܝ ܚܐܪܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
