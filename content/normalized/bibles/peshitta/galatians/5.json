    {
      "id": "peshitta:galatians.5.20",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Galatians 5:20",
      "text": "ܦܘܠܚܢܐ ܕܦܬܟܪܐ ܚܪܫܘܬܐ ܒܥܠܕܒܒܘܬܐ ܚܪܝܢܐ ܛܢܢܐ ܚܡܬܐ ܥܨܝܢܐ ܦܠܓܘܬܐ ܤܕܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.21",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Galatians 5:21",
      "text": "ܚܤܡܐ ܩܛܠܐ ܪܘܝܘܬܐ ܙܡܪܐ ܘܟܠ ܕܠܗܠܝܢ ܕܡܝܢ ܘܐܝܠܝܢ ܕܗܠܝܢ ܤܥܪܝܢ ܐܝܟ ܕܡܢ ܠܘܩܕܡ ܐܡܪܬ ܠܟܘܢ ܐܦ ܗܫܐ ܐܡܪ ܐܢܐ ܕܡܠܟܘܬܗ ܕܐܠܗܐ ܠܐ ܝܪܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.22",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Galatians 5:22",
      "text": "ܦܐܪܐ ܕܝܢ ܕܪܘܚܐ ܐܝܬܝܗܘܢ ܚܘܒܐ ܚܕܘܬܐ ܫܠܡܐ ܡܓܪܬ ܪܘܚܐ ܒܤܝܡܘܬܐ ܛܒܘܬܐ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.23",
