    "referenceLabel": "Galatians 5",
    "summary": "Source text for Galatians 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:galatians.5.1",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Galatians 5:1",
      "text": "ܩܘܡܘ ܗܟܝܠ ܒܚܐܪܘܬܐ ܗܝ ܕܡܫܝܚܐ ܚܪܪܢ ܘܠܐ ܬܬܟܕܢܘܢ ܬܘܒ ܒܢܝܪܐ ܕܥܒܕܘܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:galatians.5.2",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Galatians 5:2",
      "text": "ܗܐ ܐܢܐ ܦܘܠܘܤ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܢ ܬܬܓܙܪܘܢ ܡܫܝܚܐ ܡܕܡ ܠܐ ܡܗܢܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.3",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Galatians 5:3",
      "text": "ܡܤܗܕ ܐܢܐ ܕܝܢ ܬܘܒ ܠܟܠ ܒܪܢܫ ܕܡܬܓܙܪ ܕܚܝܒ ܗܘ ܕܟܠܗ ܢܡܘܤܐ ܢܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.4",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Galatians 5:4",
      "text": "ܐܬܒܛܠܬܘܢ ܠܟܘܢ ܡܢ ܡܫܝܚܐ ܐܝܠܝܢ ܕܒܢܡܘܤܐ ܡܙܕܕܩܝܬܘܢ ܘܡܢ ܛܝܒܘܬܐ ܢܦܠܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.5",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Galatians 5:5",
      "text": "ܚܢܢ ܓܝܪ ܒܪܘܚܐ ܕܡܢ ܗܝܡܢܘܬܐ ܠܤܒܪܐ ܕܙܕܝܩܘܬܐ ܡܩܘܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.6",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Galatians 5:6",
      "text": "ܒܡܫܝܚܐ ܓܝܪ ܝܫܘܥ ܠܐ ܓܙܘܪܬܐ ܡܕܡ ܐܝܬܝܗ ܘܠܐ ܥܘܪܠܘܬܐ ܐܠܐ ܗܝܡܢܘܬܐ ܕܡܬܓܡܪܐ ܒܚܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.7",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Galatians 5:7",
      "text": "ܫܦܝܪ ܪܗܛܝܢ ܗܘܝܬܘܢ ܡܢܘ ܕܘܕܟܘܢ ܕܠܫܪܪܐ ܠܐ ܬܬܛܦܝܤܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.8",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Galatians 5:8",
      "text": "ܦܝܤܟܘܢ ܠܐ ܗܘܐ ܡܢ ܗܘ ܕܩܪܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.9",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Galatians 5:9",
      "text": "ܚܡܝܪܐ ܩܠܝܠ ܟܠܗ ܓܒܝܠܬܐ ܡܚܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.10",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Galatians 5:10",
      "text": "ܐܢܐ ܬܟܝܠ ܐܢܐ ܥܠܝܟܘܢ ܒܡܪܢ ܕܡܕܡ ܐܚܪܝܢ ܠܐ ܡܬܪܥܝܬܘܢ ܘܐܝܢܐ ܕܕܠܚ ܠܟܘܢ ܗܘ ܢܤܝܒܪܝܘܗܝ ܠܕܝܢܐ ܡܢ ܕܐܝܬܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.11",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Galatians 5:11",
      "text": "ܐܢܐ ܕܝܢ ܐܚܝ ܐܠܘ ܥܕܟܝܠ ܓܙܘܪܬܐ ܡܟܪܙ ܗܘܝܬ ܠܡܢܐ ܡܬܪܕܦ ܗܘܝܬ ܕܠܡܐ ܐܬܒܛܠ ܠܗ ܟܫܠܗ ܕܙܩܝܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.12",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Galatians 5:12",
      "text": "ܐܫܬܘܦ ܕܝܢ ܐܦ ܡܦܤܩ ܢܦܤܩܘܢ ܗܢܘܢ ܕܕܠܚܝܢ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.13",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Galatians 5:13",
      "text": "ܐܢܬܘܢ ܕܝܢ ܠܚܐܪܘܬܐ ܗܘ ܐܬܩܪܝܬܘܢ ܐܚܝ ܒܠܚܘܕ ܠܐ ܬܗܘܐ ܚܐܪܘܬܟܘܢ ܠܥܠܬ ܒܤܪܐ ܐܠܐ ܒܚܘܒܐ ܗܘܝܬܘܢ ܡܫܬܥܒܕܝܢ ܚܕ ܠܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.14",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Galatians 5:14",
      "text": "ܟܠܗ ܓܝܪ ܢܡܘܤܐ ܒܚܕܐ ܡܠܬܐ ܡܬܡܠܐ ܒܗܝ ܕܬܚܒ ܠܩܪܝܒܟ ܐܝܟ ܢܦܫܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.15",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Galatians 5:15",
      "text": "ܐܢ ܕܝܢ ܚܕ ܠܚܕ ܡܢܟܬܝܬܘܢ ܘܐܟܠܝܬܘܢ ܚܙܘ ܕܠܡܐ ܚܕ ܡܢ ܚܕ ܬܤܘܦܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.16",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Galatians 5:16",
      "text": "ܐܡܪ ܐܢܐ ܕܝܢ ܕܒܪܘܚܐ ܗܘܝܬܘܢ ܡܗܠܟܝܢ ܘܪܓܬܐ ܕܒܤܪܐ ܠܐ ܡܢ ܡܬܘܡ ܬܥܒܕܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.17",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Galatians 5:17",
      "text": "ܒܤܪܐ ܓܝܪ ܪܐܓ ܡܕܡ ܕܢܟܐ ܠܪܘܚܐ ܘܪܘܚܐ ܪܓܐ ܡܕܡ ܕܢܟܐ ܠܒܤܪܐ ܘܬܪܝܗܘܢ ܤܩܘܒܠܐ ܐܢܘܢ ܚܕ ܕܚܕ ܕܠܐ ܡܕܡ ܕܨܒܝܬܘܢ ܬܗܘܘܢ ܥܒܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.18",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Galatians 5:18",
      "text": "ܐܢ ܕܝܢ ܒܪܘܚܐ ܡܬܕܒܪܝܢ ܐܢܬܘܢ ܠܐ ܗܘܝܬܘܢ ܬܚܝܬ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.5.19",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Galatians 5:19",
      "text": "ܝܕܝܥܝܢ ܐܢܘܢ ܓܝܪ ܥܒܕܘܗܝ ܕܒܤܪܐ ܕܐܝܬܝܗܘܢ ܙܢܝܘܬܐ ܛܢܦܘܬܐ ܨܚܢܘܬܐ ܀",
      "paragraphStart": false
