    "referenceLabel": "Galatians 2",
    "summary": "Source text for Galatians 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:galatians.2.1",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Galatians 2:1",
      "text": "ܬܘܒ ܕܝܢ ܡܢ ܒܬܪ ܐܪܒܥܤܪܐ ܫܢܝܢ ܤܠܩܬ ܠܐܘܪܫܠܡ ܥܡ ܒܪܢܒܐ ܘܕܒܪܬ ܥܡܝ ܠܛܛܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:galatians.2.2",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Galatians 2:2",
      "text": "ܤܠܩܬ ܕܝܢ ܒܓܠܝܢܐ ܘܓܠܝܬ ܠܗܘܢ ܤܒܪܬܐ ܕܡܟܪܙ ܐܢܐ ܒܥܡܡܐ ܘܚܘܝܬܗ ܠܐܝܠܝܢ ܕܡܤܬܒܪܝܢ ܗܘܘ ܕܡܕܡ ܐܝܬܝܗܘܢ ܒܝܢܝ ܘܠܗܘܢ ܕܡ ܤܪܝܩܐܝܬ ܪܗܛܬ ܐܘ ܪܗܛ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.3",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Galatians 2:3",
      "text": "ܐܦ ܛܛܘܤ ܕܥܡܝ ܕܐܪܡܝܐ ܗܘܐ ܠܐ ܐܬܐܢܤ ܕܢܓܙܘܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.4",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Galatians 2:4",
      "text": "ܡܛܠ ܕܝܢ ܐܚܐ ܕܓܠܐ ܕܥܠܘ ܥܠܝܢ ܕܢܓܫܘܢ ܚܐܪܘܬܐ ܕܐܝܬ ܠܢ ܒܝܫܘܥ ܡܫܝܚܐ ܐܝܟܢܐ ܕܢܫܥܒܕܘܢܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.5",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Galatians 2:5",
      "text": "ܐܦܠܐ ܡܠܐ ܫܥܐ ܐܬܪܡܝܢ ܠܫܘܥܒܕܗܘܢ ܕܫܪܪܗ ܕܤܒܪܬܐ ܢܩܘܐ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.6",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Galatians 2:6",
      "text": "ܗܢܘܢ ܕܝܢ ܕܡܤܬܒܪܝܢ ܕܐܝܬܝܗܘܢ ܡܕܡ ܡܢ ܕܝܢ ܐܝܬܝܗܘܢ ܠܐ ܒܛܝܠ ܠܝ ܐܠܗܐ ܓܝܪ ܒܐܦܝ ܒܢܝܢܫܐ ܠܐ ܢܤܒ ܗܢܘܢ ܕܝܢ ܗܠܝܢ ܡܕܡ ܠܐ ܐܘܤܦܘ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.7",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Galatians 2:7",
      "text": "ܐܠܐ ܐܚܪܢܝܐܝܬ ܚܙܘ ܓܝܪ ܕܐܬܗܝܡܢܬ ܤܒܪܬܐ ܕܥܘܪܠܘܬܐ ܐܝܟ ܕܐܬܗܝܡܢ ܟܐܦܐ ܒܓܙܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.8",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Galatians 2:8",
      "text": "ܗܘ ܓܝܪ ܕܚܦܛ ܠܟܐܦܐ ܒܫܠܝܚܘܬܐ ܕܓܙܘܪܬܐ ܚܦܛ ܐܦ ܠܝ ܒܫܠܝܚܘܬܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.9",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Galatians 2:9",
      "text": "ܘܟܕ ܝܕܥܘ ܛܝܒܘܬܐ ܕܐܬܝܗܒܬ ܠܝ ܝܥܩܘܒ ܘܟܐܦܐ ܘܝܘܚܢܢ ܗܢܘܢ ܕܡܤܬܒܪܝܢ ܗܘܘ ܕܐܝܬܝܗܘܢ ܥܡܘܕܐ ܝܡܝܢܐ ܕܫܘܬܦܘܬܐ ܝܗܒܘ ܠܝ ܘܠܒܪܢܒܐ ܕܚܢܢ ܒܥܡܡܐ ܘܗܢܘܢ ܒܓܙܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.10",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Galatians 2:10",
      "text": "ܒܠܚܘܕ ܕܠܡܤܟܢܐ ܗܘܝܢ ܥܗܕܝܢܢ ܘܐܬܒܛܠ ܠܝ ܕܗܝ ܗܕܐ ܐܥܒܕܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.11",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Galatians 2:11",
      "text": "ܟܕ ܐܬܐ ܕܝܢ ܟܐܦܐ ܠܐܢܛܝܘܟܝ ܒܐܦܘܗܝ ܐܟܤܬܗ ܡܛܠ ܕܡܬܬܩܠܝܢ ܗܘܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.12",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Galatians 2:12",
      "text": "ܕܥܕܠܐ ܢܐܬܘܢ ܐܢܫܐ ܡܢ ܠܘܬ ܝܥܩܘܒ ܥܡ ܥܡܡܐ ܐܟܠ ܗܘܐ ܟܕ ܐܬܘ ܕܝܢ ܢܓܕ ܗܘܐ ܢܦܫܗ ܘܦܪܫ ܡܛܠ ܕܕܚܠ ܗܘܐ ܡܢ ܗܢܘܢ ܕܡܢ ܓܙܘܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.13",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Galatians 2:13",
      "text": "ܘܐܬܪܡܝܘ ܗܘܘ ܥܡܗ ܠܗܕܐ ܐܦ ܫܪܟܐ ܕܝܗܘܕܝܐ ܗܟܢܐ ܕܐܦ ܒܪܢܒܐ ܐܬܕܒܪ ܗܘܐ ܠܡܤܒ ܒܐܦܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.14",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Galatians 2:14",
      "text": "ܘܟܕ ܚܙܝܬ ܕܠܐ ܐܙܠܝܢ ܬܪܝܨܐܝܬ ܒܫܪܪܗ ܕܐܘܢܓܠܝܘܢ ܐܡܪܬ ܠܟܐܦܐ ܠܥܝܢ ܟܠܗܘܢ ܐܢ ܐܢܬ ܕܝܗܘܕܝܐ ܐܢܬ ܐܪܡܐܝܬ ܚܝܐ ܐܢܬ ܘܠܐ ܝܗܘܕܐܝܬ ܐܝܟܢܐ ܐܠܨ ܐܢܬ ܠܥܡܡܐ ܕܝܗܘܕܐܝܬ ܢܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.15",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Galatians 2:15",
      "text": "ܚܢܢ ܓܝܪ ܕܡܢ ܟܝܢܢ ܝܗܘܕܝܐ ܚܢܢ ܘܠܐ ܗܘܝܢ ܡܢ ܥܡܡܐ ܚܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.16",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Galatians 2:16",
      "text": "ܡܛܠ ܕܝܕܥܝܢܢ ܕܠܐ ܡܙܕܕܩ ܒܪܢܫܐ ܡܢ ܥܒܕܐ ܕܢܡܘܤܐ ܐܠܐ ܒܗܝܡܢܘܬܐ ܕܝܫܘܥ ܡܫܝܚܐ ܐܦ ܚܢܢ ܒܗ ܒܝܫܘܥ ܡܫܝܚܐ ܗܝܡܢܢ ܕܡܢ ܗܝܡܢܘܬܗ ܕܡܫܝܚܐ ܢܙܕܕܩ ܘܠܐ ܡܢ ܥܒܕܐ ܕܢܡܘܤܐ ܡܛܠ ܕܡܢ ܥܒܕܐ ܕܢܡܘܤܐ ܠܐ ܡܙܕܕܩ ܟܠ ܒܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.17",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Galatians 2:17",
      "text": "ܐܢ ܕܝܢ ܟܕ ܒܥܝܢܢ ܕܢܙܕܕܩ ܒܡܫܝܚܐ ܐܫܬܟܚܢ ܠܢ ܐܦ ܚܢܢ ܚܛܝܐ ܡܕܝܢ ܝܫܘܥ ܡܫܝܚܐ ܡܫܡܫܢܐ ܗܘ ܕܚܛܝܬܐ ܚܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.18",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Galatians 2:18",
      "text": "ܐܢ ܓܝܪ ܠܐܝܠܝܢ ܕܤܬܪܬ ܬܘܒ ܠܗܝܢ ܒܢܐ ܐܢܐ ܚܘܝܬ ܥܠ ܢܦܫܝ ܕܥܒܪ ܥܠ ܦܘܩܕܢܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.19",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Galatians 2:19",
      "text": "ܐܢܐ ܓܝܪ ܒܢܡܘܤܐ ܠܢܡܘܤܐ ܡܝܬܬ ܕܠܐܠܗܐ ܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.20",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Galatians 2:20",
      "text": "ܘܥܡ ܡܫܝܚܐ ܙܩܝܦ ܐܢܐ ܘܡܟܝܠ ܠܐ ܗܘܐ ܐܢܐ ܚܝ ܐܢܐ ܐܠܐ ܚܝ ܒܝ ܡܫܝܚܐ ܘܗܢܐ ܕܗܫܐ ܚܝ ܐܢܐ ܒܒܤܪ ܒܗܝܡܢܘܬܐ ܗܘ ܕܒܪܗ ܕܐܠܗܐ ܚܝ ܐܢܐ ܗܘ ܕܐܚܒܢ ܘܝܗܒ ܢܦܫܗ ܚܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.2.21",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Galatians 2:21",
      "text": "ܠܐ ܛܠܡ ܐܢܐ ܛܝܒܘܬܗ ܕܐܠܗܐ ܐܢ ܓܝܪ ܒܝܕ ܢܡܘܤܐ ܗܝ ܙܕܝܩܘܬܐ ܡܫܝܚܐ ܡܓܢ ܡܝܬ ܀",
      "paragraphStart": false
    }
  ]
