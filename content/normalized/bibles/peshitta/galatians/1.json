{
  "chapter": {
    "id": "peshitta:galatians.1",
    "translationId": "peshitta",
    "bookSlug": "galatians",
    "chapterNumber": 1,
    "referenceLabel": "Galatians 1",
    "summary": "Source text for Galatians 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:galatians.1.1",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Galatians 1:1",
      "text": "ܦܘܠܘܤ ܫܠܝܚܐ ܠܐ ܡܢ ܒܢܝܢܫܐ ܘܠܐ ܒܝܕ ܒܪܢܫܐ ܐܠܐ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܘܐܠܗܐ ܐܒܘܗܝ ܗܘ ܕܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:galatians.1.2",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Galatians 1:2",
      "text": "ܘܟܠܗܘܢ ܐܚܐ ܕܥܡܝ ܠܥܕܬܐ ܕܐܝܬ ܒܓܠܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.3",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Galatians 1:3",
      "text": "ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܐ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.4",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Galatians 1:4",
      "text": "ܗܘ ܕܝܗܒ ܢܦܫܗ ܚܠܦ ܚܛܗܝܢ ܕܢܦܨܝܢ ܡܢ ܥܠܡܐ ܗܢܐ ܒܝܫܐ ܐܝܟ ܨܒܝܢܗ ܕܐܠܗܐ ܐܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.5",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Galatians 1:5",
      "text": "ܕܠܗ ܫܘܒܚܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.6",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Galatians 1:6",
      "text": "ܡܬܕܡܪ ܐܢܐ ܐܝܟܢܐ ܒܥܓܠ ܡܬܗܦܟܝܢ ܐܢܬܘܢ ܡܢ ܡܫܝܚܐ ܗܘ ܕܩܪܟܘܢ ܒܛܝܒܘܬܗ ܠܐܚܪܬܐ ܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.7",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Galatians 1:7",
      "text": "ܐܝܕܐ ܕܠܐ ܐܝܬܝܗ ܐܠܐ ܐܢܫܐ ܗܘ ܐܝܬ ܕܕܠܚܝܢ ܠܟܘܢ ܘܨܒܝܢ ܕܢܫܚܠܦܘܢ ܤܒܪܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.8",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Galatians 1:8",
      "text": "ܐܦ ܐܢ ܚܢܢ ܕܝܢ ܐܘ ܡܠܐܟܐ ܡܢ ܫܡܝܐ ܢܤܒܪܟܘܢ ܠܒܪ ܡܢ ܡܐ ܕܤܒܪܢܟܘܢ ܢܗܘܐ ܚܪܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.9",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Galatians 1:9",
      "text": "ܐܝܟܢܐ ܕܡܢ ܠܘܩܕܡ ܐܡܪܬ ܘܗܫܐ ܬܘܒ ܐܡܪ ܐܢܐ ܕܐܢ ܐܢܫ ܡܤܒܪ ܠܟܘܢ ܠܒܪ ܡܢ ܡܐ ܕܩܒܠܬܘܢ ܢܗܘܐ ܚܪܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.10",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Galatians 1:10",
      "text": "ܗܫܐ ܓܝܪ ܠܒܢܝܢܫܐ ܗܘ ܡܦܝܤ ܐܢܐ ܐܘ ܠܐܠܗܐ ܐܘ ܠܒܢܝܢܫܐ ܒܥܐ ܐܢܐ ܕܐܫܦܪ ܐܠܘ ܓܝܪ ܥܕܡܐ ܠܗܫܐ ܠܒܢܝܢܫܐ ܫܦܪ ܗܘܝܬ ܥܒܕܐ ܕܡܫܝܚܐ ܠܐ ܗܘܐ ܗܘܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.11",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Galatians 1:11",
      "text": "ܡܘܕܥ ܐܢܐ ܠܟܘܢ ܕܝܢ ܐܚܝ ܕܤܒܪܬܐ ܕܐܤܬܒܪܬ ܡܢܝ ܠܐ ܗܘܬ ܡܢ ܒܪܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.12",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Galatians 1:12",
      "text": "ܐܦܠܐ ܓܝܪ ܐܢܐ ܡܢ ܒܪܢܫܐ ܩܒܠܬܗ ܘܝܠܦܬܗ ܐܠܐ ܒܓܠܝܢܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.13",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Galatians 1:13",
      "text": "ܫܡܥܬܘܢ ܓܝܪ ܗܘܦܟܝ ܕܡܢ ܩܕܝܡ ܕܒܝܗܘܕܝܘܬܐ ܕܝܬܝܪܐܝܬ ܪܕܦ ܗܘܝܬ ܥܕܬܗ ܕܐܠܗܐ ܘܚܪܒ ܗܘܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.14",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Galatians 1:14",
      "text": "ܘܡܬܝܬܪ ܗܘܝܬ ܒܝܗܘܕܝܘܬܐ ܛܒ ܡܢ ܤܓܝܐܐ ܒܢܝ ܫܢܝ ܕܐܝܬ ܗܘܐ ܒܛܘܗܡܝ ܘܝܬܝܪܐܝܬ ܛܐܢ ܗܘܝܬ ܒܝܘܠܦܢܐ ܕܐܒܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.15",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Galatians 1:15",
      "text": "ܟܕ ܨܒܐ ܕܝܢ ܗܘ ܡܢ ܕܦܪܫܢܝ ܡܢ ܟܪܤ ܐܡܝ ܘܩܪܢܝ ܒܛܝܒܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.16",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Galatians 1:16",
      "text": "ܕܢܓܠܐ ܒܪܗ ܒܝ ܕܐܤܒܪܝܘܗܝ ܒܥܡܡܐ ܒܪ ܫܥܬܗ ܠܐ ܓܠܝܬ ܠܒܤܪܐ ܘܠܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.17",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Galatians 1:17",
      "text": "ܘܠܐ ܐܙܠܬ ܠܐܘܪܫܠܡ ܠܘܬ ܫܠܝܚܐ ܕܡܢ ܩܕܡܝ ܐܠܐ ܐܙܠܬ ܠܐܪܒܝܐ ܘܬܘܒ ܗܦܟܬ ܠܕܪܡܤܘܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.18",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Galatians 1:18",
      "text": "ܘܡܢ ܒܬܪ ܬܠܬ ܫܢܝܢ ܐܙܠܬ ܠܐܘܪܫܠܡ ܕܐܚܙܐ ܠܟܐܦܐ ܘܩܘܝܬ ܠܘܬܗ ܝܘܡܬܐ ܚܡܫܬܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.19",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Galatians 1:19",
      "text": "ܠܐܚܪܝܢ ܕܝܢ ܡܢ ܫܠܝܚܐ ܠܐ ܚܙܝܬ ܐܠܐ ܐܢ ܠܝܥܩܘܒ ܐܚܘܗܝ ܕܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.20",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Galatians 1:20",
      "text": "ܗܠܝܢ ܕܝܢ ܕܟܬܒ ܐܢܐ ܠܟܘܢ ܗܐ ܩܕܡ ܐܠܗܐ ܕܠܐ ܡܟܕܒ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.21",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Galatians 1:21",
      "text": "ܡܢ ܒܬܪ ܗܠܝܢ ܐܬܝܬ ܠܐܬܪܘܬܐ ܕܤܘܪܝܐ ܘܕܩܝܠܝܩܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.22",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Galatians 1:22",
      "text": "ܘܠܐ ܝܕܥܢ ܗܘܝ ܠܝ ܒܐܦܝܢ ܥܕܬܐ ܕܒܝܗܘܕ ܗܠܝܢ ܕܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.23",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Galatians 1:23",
      "text": "ܐܠܐ ܗܕܐ ܒܠܚܘܕ ܫܡܥܝܢ ܗܘܘ ܕܗܘ ܕܡܢ ܩܕܝܡ ܪܕܦ ܗܘܐ ܠܢ ܗܫܐ ܗܐ ܡܤܒܪ ܗܝܡܢܘܬܐ ܗܝ ܕܡܢ ܩܕܡ ܙܒܢܐ ܡܤܚܦ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.1.24",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Galatians 1:24",
      "text": "ܘܡܫܒܚܝܢ ܗܘܘ ܒܝ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    }
  ]
}
