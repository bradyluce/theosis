  "verses": [
    {
      "id": "peshitta:galatians.6.1",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Galatians 6:1",
      "text": "ܐܚܝ ܐܢ ܐܢܫ ܡܢܟܘܢ ܢܬܩܕܡ ܒܤܟܠܘܬܐ ܐܢܬܘܢ ܐܝܠܝܢ ܕܒܪܘܚ ܐܢܬܘܢ ܐܬܩܢܘܗܝ ܒܪܘܚܐ ܡܟܝܟܬܐ ܘܗܘܝܬܘܢ ܙܗܝܪܝܢ ܕܕܠܡܐ ܐܦ ܐܢܬܘܢ ܬܬܢܤܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:galatians.6.2",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Galatians 6:2",
      "text": "ܘܛܥܢܘ ܝܘܩܪܐ ܕܚܕܕܐ ܕܗܟܢܐ ܡܡܠܝܬܘܢ ܢܡܘܤܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.3",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Galatians 6:3",
      "text": "ܐܢ ܓܝܪ ܐܢܫ ܤܒܪ ܕܐܝܬܘܗܝ ܡܕܡ ܟܕ ܠܐ ܐܝܬܘܗܝ ܢܦܫܗ ܡܛܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.4",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Galatians 6:4",
      "text": "ܐܠܐ ܐܢܫ ܥܒܕܗ ܢܗܘܐ ܒܩܐ ܘܗܝܕܝܢ ܒܝܢܘܗܝ ܠܢܦܫܗ ܢܗܘܐ ܫܘܒܗܪܗ ܘܠܐ ܒܐܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.5",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Galatians 6:5",
      "text": "ܟܠܢܫ ܓܝܪ ܡܘܒܠܐ ܕܢܦܫܗ ܢܫܩܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.6",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Galatians 6:6",
      "text": "ܢܫܬܘܬܦ ܕܝܢ ܗܘ ܕܫܡܥ ܡܠܬܐ ܠܗܘ ܡܢ ܕܡܫܡܥ ܠܗ ܒܟܠܗܝܢ ܛܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.7",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Galatians 6:7",
      "text": "ܠܐ ܬܛܥܘܢ ܐܠܗܐ ܠܐ ܡܬܒܙܚ ܡܕܡ ܕܙܪܥ ܓܝܪ ܒܪ ܐܢܫܐ ܗܘ ܗܘ ܚܨܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.8",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Galatians 6:8",
      "text": "ܡܢ ܕܒܒܤܪ ܙܪܥ ܡܢ ܒܤܪܐ ܚܒܠܐ ܗܘ ܚܨܕ ܘܡܢ ܕܒܪܘܚ ܙܪܥ ܡܢ ܪܘܚܐ ܚܝܐ ܕܠܥܠܡ ܢܚܨܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.9",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Galatians 6:9",
      "text": "ܘܟܕ ܥܒܕܝܢܢ ܕܛܒ ܠܐ ܗܘܬ ܡܐܢܐ ܠܢ ܢܗܘܐ ܓܝܪ ܙܒܢܐ ܕܢܚܨܘܕ ܘܠܐ ܬܡܐܢ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.10",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Galatians 6:10",
      "text": "ܗܫܐ ܗܟܝܠ ܥܕ ܙܒܢܐ ܐܝܬ ܠܢ ܢܦܠܘܚ ܛܒܬܐ ܠܘܬ ܟܠܢܫ ܝܬܝܪܐܝܬ ܠܘܬ ܒܢܝ ܒܝܬܐ ܕܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.11",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Galatians 6:11",
      "text": "ܚܙܘ ܐܝܠܝܢ ܟܬܝܒܢ ܟܬܒܬ ܠܟܘܢ ܒܐܝܕܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.12",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Galatians 6:12",
      "text": "ܐܝܠܝܢ ܕܨܒܝܢ ܕܢܫܬܒܗܪܘܢ ܒܒܤܪܐ ܗܢܘܢ ܐܠܨܝܢ ܠܟܘܢ ܕܬܬܓܙܪܘܢ ܕܒܠܚܘܕ ܒܙܩܝܦܗ ܕܡܫܝܚܐ ܠܐ ܢܬܪܕܦܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.13",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Galatians 6:13",
      "text": "ܐܦܠܐ ܓܝܪ ܗܢܘܢ ܗܠܝܢ ܕܓܙܪܝܢ ܢܛܪܝܢ ܢܡܘܤܐ ܐܠܐ ܨܒܝܢ ܕܬܬܓܙܪܘܢ ܕܒܒܤܪܟܘܢ ܕܝܠܟܘܢ ܢܫܬܒܗܪܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.14",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Galatians 6:14",
      "text": "ܠܝ ܕܝܢ ܠܐ ܢܗܘܐ ܠܝ ܕܐܫܬܒܗܪ ܐܠܐ ܒܙܩܝܦܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܒܗ ܥܠܡܐ ܙܩܝܦ ܠܝ ܘܐܢܐ ܙܩܝܦ ܐܢܐ ܠܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.15",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Galatians 6:15",
      "text": "ܠܐ ܓܝܪ ܓܙܘܪܬܐ ܐܝܬܝܗ ܡܕܡ ܘܠܐ ܥܘܪܠܘܬܐ ܐܠܐ ܒܪܝܬܐ ܚܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.16",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Galatians 6:16",
      "text": "ܘܐܝܠܝܢ ܕܠܗܢܐ ܫܒܝܠܐ ܫܠܡܝܢ ܫܠܡܐ ܢܗܘܐ ܥܠܝܗܘܢ ܘܪܚܡܐ ܘܥܠ ܐܝܤܪܝܠ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.17",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Galatians 6:17",
      "text": "ܡܟܝܠ ܠܝ ܐܢܫ ܥܡܠܐ ܠܐ ܢܪܡܐ ܐܢܐ ܓܝܪ ܟܘܬܡܬܗ ܕܡܪܢ ܝܫܘܥ ܒܦܓܪܝ ܫܩܝܠ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:galatians.6.18",
      "translationId": "peshitta",
      "bookSlug": "galatians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Galatians 6:18",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܪܘܚܟܘܢ ܐܚܝ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
