{
  "chapter": {
    "id": "peshitta:james.5",
    "translationId": "peshitta",
    "bookSlug": "james",
    "chapterNumber": 5,
    "referenceLabel": "James 5",
    "summary": "Source text for James 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:james.5.1",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "James 5:1",
      "text": "ܐܘ ܥܬܝܪܐ ܐܝܠܠܘ ܘܒܟܘ ܥܠ ܕܘܘܢܐ ܕܐܬܝܢ ܥܠܝܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:james.5.2",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "James 5:2",
      "text": "ܥܘܬܪܟܘܢ ܓܝܪ ܐܬܚܒܠ ܘܤܪܝ ܘܡܐܢܝܟܘܢ ܐܬܐܟܠܘ ܡܢ ܤܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.3",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "James 5:3",
      "text": "ܘܕܗܒܟܘܢ ܘܤܐܡܟܘܢ ܐܫܚܬ ܠܗ ܘܫܘܚܬܗܘܢ ܗܘܝܐ ܠܤܗܕܘܬܐ ܥܠܝܟܘܢ ܘܗܝ ܥܬܝܕܐ ܕܬܐܟܘܠ ܒܤܪܟܘܢ ܢܘܪܐ ܟܢܫܬܘܢ ܠܟܘܢ ܠܝܘܡܬܐ ܐܚܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.4",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "James 5:4",
      "text": "ܗܐ ܐܓܪܐ ܕܦܥܠܐ ܕܚܨܕܘ ܐܪܥܬܟܘܢ ܗܘ ܕܛܠܡܬܘܢ ܩܥܐ ܘܓܥܬܐ ܕܚܨܘܕܐ ܠܐܕܢܘܗܝ ܕܡܪܝܐ ܨܒܐܘܬ ܥܠܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.5",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "James 5:5",
      "text": "ܒܤܡܬܘܢ ܓܝܪ ܥܠ ܐܪܥܐ ܘܐܬܠܥܒܬܘܢ ܘܬܪܤܝܬܘܢ ܦܓܪܝܟܘܢ ܐܝܟ ܕܠܝܘܡܐ ܕܢܟܤܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.6",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "James 5:6",
      "text": "ܚܝܒܬܘܢ ܘܩܛܠܬܘܢ ܠܙܕܝܩܐ ܘܠܐ ܩܡ ܠܘܩܒܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.7",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "James 5:7",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܚܝ ܐܓܪܘ ܪܘܚܟܘܢ ܥܕܡܐ ܠܡܐܬܝܬܗ ܕܡܪܝܐ ܐܝܟ ܐܟܪܐ ܕܡܤܟܐ ܠܦܐܪܐ ܝܩܝܪܐ ܕܐܪܥܗ ܘܡܓܪ ܪܘܚܗ ܥܠܝܗܘܢ ܥܕܡܐ ܕܢܤܒ ܡܛܪܐ ܒܟܝܪܝܐ ܘܠܩܝܫܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.8",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "James 5:8",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܐܓܪܘ ܪܘܚܟܘܢ ܘܠܒܘܬܟܘܢ ܫܪܪܘ ܩܪܒܬ ܠܗ ܓܝܪ ܡܐܬܝܬܗ ܕܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.9",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "James 5:9",
      "text": "ܠܐ ܬܬܢܚܘܢ ܚܕ ܥܠ ܚܕ ܐܚܝ ܕܠܐ ܬܬܕܝܢܘܢ ܗܐ ܓܝܪ ܕܝܢܐ ܩܕܡ ܬܪܥܐ ܩܐܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.10",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "James 5:10",
      "text": "ܕܡܘܬܐ ܠܢܒܝܐ ܤܒܘ ܠܟܘܢ ܐܚܝ ܠܡܓܪܬ ܪܘܚܐ ܕܐܘܠܨܢܝܟܘܢ ܗܢܘܢ ܕܡܠܠܘ ܒܫܡܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.11",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "James 5:11",
      "text": "ܗܐ ܓܝܪ ܝܗܒܝܢܢ ܛܘܒܐ ܠܐܝܠܝܢ ܕܤܝܒܪܘ ܫܡܥܬܘܢ ܡܤܝܒܪܢܘܬܗ ܕܐܝܘܒ ܘܚܪܬܐ ܕܥܒܕ ܠܗ ܡܪܝܐ ܚܙܝܬܘܢ ܡܛܠ ܕܡܪܚܡܢ ܗܘ ܡܪܝܐ ܘܡܪܚܦܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.12",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "James 5:12",
      "text": "ܩܕܡ ܟܠ ܡܕܡ ܕܝܢ ܐܚܝ ܠܐ ܗܘܝܬܘܢ ܝܡܝܢ ܠܐ ܒܫܡܝܐ ܘܠܐ ܒܐܪܥܐ ܐܦܠܐ ܒܡܘܡܬܐ ܐܚܪܬܐ ܐܠܐ ܬܗܘܐ ܡܠܬܟܘܢ ܐܝܢ ܐܝܢ ܘܠܐ ܠܐ ܕܠܐ ܬܬܚܝܒܘܢ ܬܚܝܬ ܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.13",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "James 5:13",
      "text": "ܘܐܢ ܐܢܫ ܡܢܟܘܢ ܢܗܘܐ ܒܐܘܠܨܢܐ ܢܗܘܐ ܡܨܠܐ ܘܐܢ ܚܕܐ ܢܗܘܐ ܡܙܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.14",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "James 5:14",
      "text": "ܘܐܢ ܟܪܝܗ ܢܩܪܐ ܠܩܫܝܫܐ ܕܥܕܬܐ ܘܢܨܠܘܢ ܥܠܘܗܝ ܘܢܡܫܚܘܢܗ ܡܫܚܐ ܒܫܡܗ ܕܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.15",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "James 5:15",
      "text": "ܘܨܠܘܬܐ ܕܗܝܡܢܘܬܐ ܡܚܠܡܐ ܠܗ ܠܗܘ ܕܟܪܝܗ ܘܡܩܝܡ ܠܗ ܡܪܢ ܘܐܢ ܚܛܗܐ ܥܒܝܕܝܢ ܠܗ ܡܫܬܒܩܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.16",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "James 5:16",
      "text": "ܗܘܝܬܘܢ ܕܝܢ ܡܘܕܝܢ ܤܟܠܘܬܟܘܢ ܚܕ ܠܚܕ ܘܗܘܝܬܘܢ ܡܨܠܝܢ ܚܕ ܥܠ ܚܕ ܕܬܬܐܤܘܢ ܪܒ ܗܘ ܓܝܪ ܚܝܠܗ ܕܨܠܘܬܐ ܐܝܕܐ ܕܙܕܝܩܐ ܡܨܠܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.17",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "James 5:17",
      "text": "ܐܦ ܐܠܝܐ ܒܪܢܫܐ ܗܘܐ ܚܫܘܫܐ ܐܟܘܬܢ ܘܨܠܝ ܕܠܐ ܢܚܘܬ ܡܛܪܐ ܥܠ ܐܪܥܐ ܘܠܐ ܢܚܬ ܬܠܬ ܫܢܝܢ ܘܫܬܐ ܝܪܚܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.18",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "James 5:18",
      "text": "ܘܬܘܒ ܨܠܝ ܘܫܡܝܐ ܝܗܒܘ ܡܛܪܐ ܘܐܪܥܐ ܝܗܒܬ ܦܐܪܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.19",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "James 5:19",
      "text": "ܐܚܝ ܐܢ ܐܢܫ ܡܢܟܘܢ ܢܛܥܐ ܡܢ ܐܘܪܚܐ ܕܩܘܫܬܐ ܘܢܦܢܝܘܗܝ ܐܢܫ ܡܢ ܛܥܝܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.5.20",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "James 5:20",
      "text": "ܢܕܥ ܕܗܘ ܕܡܗܦܟ ܠܚܛܝܐ ܡܢ ܛܥܝܘܬܐ ܕܐܘܪܚܗ ܡܚܐ ܢܦܫܗ ܡܢ ܡܘܬܐ ܘܥܛܐ ܤܘܓܐܐ ܕܚܛܗܘܗܝ ܀",
      "paragraphStart": false
    }
  ]
}
