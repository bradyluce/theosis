{
  "chapter": {
    "id": "peshitta:james.4",
    "translationId": "peshitta",
    "bookSlug": "james",
    "chapterNumber": 4,
    "referenceLabel": "James 4",
    "summary": "Source text for James 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:james.4.1",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "James 4:1",
      "text": "ܡܢ ܐܝܟܐ ܐܝܬ ܒܟܘܢ ܩܪܒܐ ܘܡܨܘܬܐ ܠܐ ܗܘܐ ܡܢ ܪܓܝܓܬܐ ܕܡܩܪܒܢ ܒܗܕܡܝܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:james.4.2",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "James 4:2",
      "text": "ܡܬܪܓܪܓܝܢ ܐܢܬܘܢ ܘܠܝܬ ܠܟܘܢ ܘܩܛܠܝܢ ܐܢܬܘܢ ܘܛܢܝܢ ܐܢܬܘܢ ܘܠܐ ܐܬܝܐ ܒܐܝܕܝܟܘܢ ܘܢܨܝܢ ܐܢܬܘܢ ܘܩܪܒܐ ܥܒܕܝܢ ܐܢܬܘܢ ܘܠܝܬ ܠܟܘܢ ܡܛܠ ܕܠܐ ܫܐܠܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.3",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "James 4:3",
      "text": "ܫܐܠܝܢ ܐܢܬܘܢ ܘܠܐ ܢܤܒܝܢ ܐܢܬܘܢ ܡܛܠ ܕܒܝܫܐܝܬ ܫܐܠܝܢ ܐܢܬܘܢ ܐܝܟ ܕܬܬܪܤܘܢ ܪܓܝܓܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.4",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "James 4:4",
      "text": "ܓܝܪܐ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܪܚܡܬܗ ܕܥܠܡܐ ܗܢܐ ܒܥܠܕܒܒܘܬܐ ܗܝ ܕܐܠܗܐ ܐܝܢܐ ܗܟܝܠ ܕܨܒܐ ܕܢܗܘܐ ܪܚܡܐ ܕܥܠܡܐ ܗܢܐ ܒܥܠܕܒܒܐ ܗܘܐ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.5",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "James 4:5",
      "text": "ܐܘ ܕܠܡܐ ܤܪܝܩܐܝܬ ܤܒܪܝܢ ܐܢܬܘܢ ܕܐܡܪ ܟܬܒܐ ܕܒܛܢܢܐ ܪܓܐ ܪܘܚܐ ܕܥܡܪܐ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.6",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "James 4:6",
      "text": "ܛܝܒܘܬܐ ܕܝܢ ܝܬܝܪܬܐ ܝܗܒ ܠܢ ܡܪܢ ܡܛܠ ܗܕܐ ܐܡܪ ܕܐܠܗܐ ܡܡܟܟ ܠܪܡܐ ܘܠܡܟܝܟܐ ܝܗܒ ܛܝܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.7",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "James 4:7",
      "text": "ܐܫܬܥܒܕܘ ܗܟܝܠ ܠܐܠܗܐ ܘܩܘܡܘ ܠܘܩܒܠ ܤܛܢܐ ܘܥܪܩ ܡܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.8",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "James 4:8",
      "text": "ܘܩܪܘܒܘ ܠܘܬ ܐܠܗܐ ܘܢܬܩܪܒ ܠܟܘܢ ܕܟܘ ܐܝܕܝܟܘܢ ܚܛܝܐ ܩܕܫܘ ܠܒܘܬܟܘܢ ܦܠܝܓܝ ܢܦܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.9",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "James 4:9",
      "text": "ܐܬܡܟܟܘ ܘܐܬܐܒܠܘ ܘܓܘܚܟܟܘܢ ܠܐܒܠܐ ܢܬܗܦܟ ܘܚܕܘܬܟܘܢ ܠܥܩܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.10",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "James 4:10",
      "text": "ܐܬܡܟܟܘ ܩܕܡ ܡܪܝܐ ܘܢܪܡܪܡܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.11",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "James 4:11",
      "text": "ܠܐ ܬܗܘܘܢ ܡܡܠܠܝܢ ܥܠ ܚܕܕܐ ܐܚܝ ܗܘ ܓܝܪ ܕܡܡܠܠ ܥܠ ܐܚܘܗܝ ܐܘ ܕܐܢ ܠܐܚܘܗܝ ܡܡܠܠ ܥܠ ܢܡܘܤܐ ܘܕܐܢ ܠܢܡܘܤܐ ܘܐܢ ܠܢܡܘܤܐ ܕܐܢ ܐܢܬ ܠܐ ܗܘܝܬ ܥܒܘܕܗ ܕܢܡܘܤܐ ܐܠܐ ܕܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.12",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "James 4:12",
      "text": "ܚܕ ܗܘ ܤܐܡ ܢܡܘܤܐ ܘܕܝܢܐ ܕܗܘ ܡܫܟܚ ܕܢܚܐ ܘܢܘܒܕ ܐܢܬ ܕܝܢ ܡܢ ܐܢܬ ܕܕܐܢ ܐܢܬ ܠܗ ܠܩܪܝܒܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.13",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "James 4:13",
      "text": "ܡܢܐ ܕܝܢ ܢܐܡܪ ܐܦ ܥܠ ܐܝܠܝܢ ܕܐܡܪܝܢ ܕܝܘܡܢܐ ܐܘ ܡܚܪ ܐܙܠܝܢܢ ܠܡܕܝܢܬܐ ܐܝܕܐ ܕܗܝ ܘܥܒܕܝܢܢ ܬܡܢ ܫܢܬܐ ܚܕܐ ܘܡܬܬܓܪܝܢܢ ܘܝܬܪܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.14",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "James 4:14",
      "text": "ܘܠܐ ܝܕܥܝܢ ܡܢܐ ܗܘܐ ܡܚܪ ܡܢܐ ܐܢܘܢ ܓܝܪ ܚܝܝܢ ܐܠܐ ܐܢ ܠܗܓܐ ܕܩܠܝܠ ܡܬܚܙܐ ܘܛܠܩ ܘܡܘܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.15",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "James 4:15",
      "text": "ܚܠܦ ܕܢܐܡܪܘܢ ܕܐܢ ܡܪܝܐ ܢܨܒܐ ܘܢܚܐ ܥܒܕܝܢܢ ܗܕܐ ܐܘ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.16",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "James 4:16",
      "text": "ܡܫܬܒܗܪܝܢ ܒܚܬܝܪܘܬܗܘܢ ܟܠ ܫܘܒܗܪܐ ܕܐܝܟ ܗܢܐ ܒܝܫܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.4.17",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "James 4:17",
      "text": "ܘܐܝܢܐ ܕܝܕܥ ܛܒܬܐ ܘܠܐ ܥܒܕ ܠܗ ܚܛܗܐ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    }
  ]
}
