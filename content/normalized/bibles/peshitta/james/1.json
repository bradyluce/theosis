{
  "chapter": {
    "id": "peshitta:james.1",
    "translationId": "peshitta",
    "bookSlug": "james",
    "chapterNumber": 1,
    "referenceLabel": "James 1",
    "summary": "Source text for James 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:james.1.1",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "James 1:1",
      "text": "ܝܥܩܘܒ ܥܒܕܗ ܕܐܠܗܐ ܘܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܠܬܪܬܥܤܪܐ ܫܪܒܢ ܕܙܪܝܥܢ ܒܥܡܡܐ ܫܠܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:james.1.2",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "James 1:2",
      "text": "ܟܠ ܚܕܘܐ ܬܗܘܐ ܠܟܘܢ ܐܚܝ ܟܕ ܬܥܠܘܢ ܠܢܤܝܘܢܐ ܡܫܚܠܦܐ ܘܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.3",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "James 1:3",
      "text": "ܝܕܥܝܢ ܐܢܬܘܢ ܓܝܪ ܕܒܘܩܝܐ ܕܗܝܡܢܘܬܐ ܡܩܢܐ ܠܟܘܢ ܡܤܝܒܪܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.4",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "James 1:4",
      "text": "ܠܗ ܕܝܢ ܠܡܤܝܒܪܢܘܬܐ ܢܗܘܐ ܠܗ ܥܒܕܐ ܡܫܡܠܝܐ ܕܬܗܘܘܢ ܓܡܝܪܝܢ ܘܡܫܠܡܢܝܢ ܘܒܡܕܡ ܠܐ ܗܘܝܬܘܢ ܚܤܝܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.5",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "James 1:5",
      "text": "ܐܢ ܐܢܫ ܕܝܢ ܡܢܟܘܢ ܚܤܝܪ ܡܢ ܚܟܡܬܐ ܢܫܐܠ ܡܢ ܐܠܗܐ ܕܝܗܒ ܠܟܠ ܦܫܝܛܐܝܬ ܘܠܐ ܡܚܤܕ ܘܡܬܝܗܒܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.6",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "James 1:6",
      "text": "ܢܫܐܠ ܕܝܢ ܒܗܝܡܢܘܬܐ ܟܕ ܠܐ ܡܬܦܠܓ ܗܘ ܓܝܪ ܕܡܬܦܠܓ ܕܡܐ ܠܓܠܠܐ ܕܝܡܐ ܕܫܓܫܐ ܠܗܘܢ ܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.7",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "James 1:7",
      "text": "ܘܠܐ ܢܤܒܪ ܗܘ ܒܪܢܫܐ ܕܢܤܒ ܡܕܡ ܡܢ ܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.8",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "James 1:8",
      "text": "ܐܝܢܐ ܕܦܠܝܓ ܒܪܥܝܢܗ ܘܫܓܝܫ ܒܟܠܗܝܢ ܐܘܪܚܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.9",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "James 1:9",
      "text": "ܢܫܬܒܗܪ ܕܝܢ ܐܚܐ ܡܟܝܟܐ ܒܪܘܡܪܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.10",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "James 1:10",
      "text": "ܘܥܬܝܪܐ ܒܡܘܟܟܗ ܡܛܠ ܕܐܝܟ ܗܒܒܐ ܕܥܤܒܐ ܗܟܢܐ ܥܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.11",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "James 1:11",
      "text": "ܕܢܚ ܓܝܪ ܫܡܫܐ ܒܚܘܡܗ ܘܡܘܒܫ ܠܗ ܠܥܤܒܐ ܘܗܒܒܗ ܢܦܠ ܘܫܘܦܪܐ ܕܚܙܘܗ ܐܒܕ ܗܟܢܐ ܐܦ ܥܬܝܪܐ ܚܡܐ ܒܗܘܦܟܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.12",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "James 1:12",
      "text": "ܛܘܒܘܗܝ ܠܓܒܪܐ ܕܡܤܝܒܪ ܢܤܝܘܢܐ ܕܡܐ ܕܐܬܒܚܪ ܢܤܒ ܟܠܝܠܐ ܕܚܝܐ ܗܘ ܕܡܠܟ ܐܠܗܐ ܠܐܝܠܝܢ ܕܪܚܡܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.13",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "James 1:13",
      "text": "ܠܐ ܢܐܡܪ ܐܢܫ ܟܕ ܡܬܢܤܐ ܕܡܢ ܐܠܗܐ ܡܬܢܤܐ ܐܢܐ ܐܠܗܐ ܓܝܪ ܠܐ ܡܢܤܝ ܒܒܝܫܬܐ ܘܗܘ ܠܐܢܫ ܠܐ ܡܢܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.14",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "James 1:14",
      "text": "ܐܠܐ ܐܢܫ ܐܢܫ ܡܢ ܪܓܬܗ ܗܘ ܡܬܢܤܐ ܘܡܬܪܓܪܓ ܘܡܬܢܓܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.15",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "James 1:15",
      "text": "ܘܗܕܐ ܪܓܬܐ ܒܛܢܐ ܘܝܠܕܐ ܚܛܝܬܐ ܚܛܝܬܐ ܕܝܢ ܡܐ ܕܐܬܓܡܪܬ ܝܠܕܐ ܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.16",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "James 1:16",
      "text": "ܠܐ ܬܛܥܘܢ ܐܚܝ ܚܒܝܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.17",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "James 1:17",
      "text": "ܟܠ ܡܘܗܒܬܐ ܛܒܬܐ ܘܡܫܡܠܝܬܐ ܡܢ ܠܥܠ ܢܚܬܐ ܡܢ ܐܒܐ ܕܢܗܝܪܐ ܗܘ ܕܠܝܬ ܠܘܬܗ ܫܘܚܠܦܐ ܡܕܡ ܐܦܠܐ ܛܠܢܝܬܐ ܕܫܘܓܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.18",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "James 1:18",
      "text": "ܗܘܝܘ ܨܒܐ ܘܝܠܕܢ ܒܡܠܬܐ ܕܩܘܫܬܐ ܕܢܗܘܐ ܪܫܝܬܐ ܕܒܪܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.19",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "James 1:19",
      "text": "ܘܐܢܬܘܢ ܐܚܝ ܚܒܝܒܐ ܟܠܢܫ ܡܢܟܘܢ ܢܗܘܐ ܡܤܪܗܒ ܠܡܫܡܥ ܘܡܘܚܪ ܠܡܡܠܠܘ ܘܡܘܚܪ ܠܡܪܓܙ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.20",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "James 1:20",
      "text": "ܪܘܓܙܗ ܓܝܪ ܕܓܒܪܐ ܙܕܝܩܘܬܐ ܕܐܠܗܐ ܠܐ ܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.21",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "James 1:21",
      "text": "ܡܛܠ ܗܢܐ ܐܪܚܩܘ ܡܢܟܘܢ ܟܠܗ ܛܢܦܘܬܐ ܘܤܘܓܐܐ ܕܒܝܫܘܬܐ ܘܒܡܟܝܟܘܬܐ ܩܒܠܘ ܡܠܬܐ ܕܢܨܝܒܐ ܒܟܝܢܢ ܕܗܝ ܡܫܟܚܐ ܕܬܚܐ ܐܢܝܢ ܢܦܫܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.22",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "James 1:22",
      "text": "ܗܘܘ ܕܝܢ ܥܒܘܕܐ ܕܡܠܬܐ ܘܠܐ ܫܡܘܥܐ ܒܠܚܘܕ ܘܠܐ ܬܛܥܘܢ ܢܦܫܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.23",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "James 1:23",
      "text": "ܐܢ ܐܢܫ ܓܝܪ ܢܗܘܐ ܫܡܘܥܗ ܕܡܠܬܐ ܘܠܐ ܥܒܘܕܗ ܗܢܐ ܕܡܐ ܠܗܘ ܕܚܙܐ ܐܦܘܗܝ ܒܡܚܙܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.24",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "James 1:24",
      "text": "ܚܙܐ ܓܝܪ ܢܦܫܗ ܘܥܒܪ ܘܛܥܐ ܕܐܝܟܢܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.25",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "James 1:25",
      "text": "ܟܠ ܕܝܢ ܕܚܪ ܒܢܡܘܤܐ ܡܫܠܡܢܐ ܕܚܐܪܘܬܐ ܘܩܘܝ ܒܗ ܠܐ ܗܘܐ ܫܡܘܥܐ ܕܫܡܥܐ ܕܡܬܛܥܐ ܐܠܐ ܥܒܘܕܐ ܕܥܒܕܐ ܘܗܢܐ ܛܘܒܢܐ ܢܗܘܐ ܒܥܒܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.26",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "James 1:26",
      "text": "ܘܐܢ ܐܢܫ ܤܒܪ ܕܡܫܡܫ ܠܐܠܗܐ ܘܠܐ ܐܚܕ ܠܫܢܗ ܐܠܐ ܡܛܥܐ ܠܗ ܠܒܗ ܕܗܢܐ ܤܪܝܩܐ ܗܝ ܬܫܡܫܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.1.27",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "James 1:27",
      "text": "ܬܫܡܫܬܐ ܓܝܪ ܕܟܝܬܐ ܘܩܕܝܫܬܐ ܩܕܡ ܐܠܗܐ ܐܒܐ ܗܕܐ ܗܝ ܠܡܤܥܪ ܝܬܡܐ ܘܐܪܡܠܬܐ ܒܐܘܠܨܢܝܗܘܢ ܘܠܡܛܪ ܐܢܫ ܢܦܫܗ ܡܢ ܥܠܡܐ ܕܠܐ ܛܘܠܫܐ ܀",
      "paragraphStart": false
    }
  ]
}
