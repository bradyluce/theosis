    "referenceLabel": "James 3",
    "summary": "Source text for James 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:james.3.1",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "James 3:1",
      "text": "ܠܐ ܤܓܝܐܐ ܡܠܦܢܐ ܢܗܘܘܢ ܒܟܘܢ ܐܚܝ ܐܠܐ ܗܘܝܬܘܢ ܝܕܥܝܢ ܕܕܝܢܐ ܝܬܝܪܐ ܚܝܒܝܢܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:james.3.2",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "James 3:2",
      "text": "ܤܓܝܐܬܐ ܓܝܪ ܡܫܬܪܥܝܢܢ ܟܠܢ ܟܠ ܕܒܡܠܬܐ ܠܐ ܫܪܥ ܗܢܐ ܐܝܬܘܗܝ ܓܒܪܐ ܓܡܝܪܐ ܕܡܫܟܚ ܢܫܥܒܕ ܐܦ ܟܠܗ ܦܓܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.3",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "James 3:3",
      "text": "ܗܐ ܓܝܪ ܦܓܘܕܐ ܒܦܘܡܐ ܕܪܟܫܐ ܪܡܝܢܢ ܐܝܟ ܕܢܫܬܥܒܕܘܢ ܠܢ ܘܟܠܗ ܓܘܫܡܗܘܢ ܡܗܦܟܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.4",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "James 3:4",
      "text": "ܐܦ ܐܠܦܐ ܥܫܝܢܬܐ ܟܕ ܕܒܝܪܢ ܠܗܝܢ ܪܘܚܐ ܩܫܝܬܐ ܡܢ ܩܝܤܐ ܙܥܘܪܐ ܡܬܢܬܦܢ ܠܐܬܪ ܕܚܐܪ ܨܒܝܢܗ ܕܗܘ ܕܡܕܒܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.5",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "James 3:5",
      "text": "ܗܟܢܐ ܐܦ ܠܫܢܐ ܗܕܡܐ ܗܘ ܙܥܘܪܐ ܘܡܫܬܥܠܐ ܐܦ ܢܘܪܐ ܙܥܘܪܬܐ ܥܒܐ ܤܓܝܐܐ ܡܘܩܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.6",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "James 3:6",
      "text": "ܘܠܫܢܐ ܢܘܪܐ ܗܘ ܘܥܠܡܐ ܕܚܛܝܬܐ ܐܝܟ ܥܒܐ ܗܘ ܘܗܘ ܠܫܢܐ ܟܕ ܐܝܬܘܗܝ ܒܗܕܡܝܢ ܡܟܬܡ ܠܗ ܠܟܠܗ ܦܓܪܢ ܘܡܘܩܕ ܝܘܒܠܐ ܕܫܪܒܬܢ ܕܪܗܛܝܢ ܐܝܟ ܓܝܓܠܐ ܘܝܩܕ ܐܦ ܗܘ ܒܢܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.7",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "James 3:7",
      "text": "ܟܠܗܘܢ ܓܝܪ ܟܝܢܐ ܕܚܝܘܬܐ ܘܕܦܪܚܬܐ ܘܪܚܫܐ ܕܝܡܐ ܘܕܝܒܫܐ ܡܫܬܥܒܕܝܢ ܠܟܝܢܐ ܕܐܢܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.8",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "James 3:8",
      "text": "ܠܫܢܐ ܕܝܢ ܐܢܫ ܠܐ ܐܫܟܚ ܕܢܟܒܫܝܘܗܝ ܒܝܫܬܐ ܗܕܐ ܕܠܐ ܡܬܬܟܤܐ ܡܠܐ ܗܘ ܤܡܐ ܕܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.9",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "James 3:9",
      "text": "ܒܗ ܡܒܪܟܝܢܢ ܠܡܪܝܐ ܘܐܒܐ ܘܒܗ ܠܝܛܝܢܢ ܠܒܢܝܢܫܐ ܕܒܕܡܘܬܐ ܕܐܠܗܐ ܥܒܝܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.10",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "James 3:10",
      "text": "ܘܡܢܗ ܡܢ ܦܘܡܐ ܢܦܩܢ ܒܘܪܟܬܐ ܘܠܘܛܬܐ ܠܐ ܘܠܐ ܐܚܝ ܕܗܠܝܢ ܗܟܢܐ ܢܤܬܥܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.11",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "James 3:11",
      "text": "ܕܠܡܐ ܡܫܟܚܐ ܕܡܢ ܚܕ ܡܒܘܥܐ ܢܦܩܘܢ ܡܝܐ ܚܠܝܐ ܘܡܪܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.12",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "James 3:12",
      "text": "ܐܘ ܕܠܡܐ ܡܫܟܚܐ ܬܬܐ ܐܚܝ ܕܙܝܬܐ ܬܥܒܕ ܐܘ ܓܦܬܐ ܬܐܢܐ ܗܟܢܐ ܐܦ ܠܐ ܡܝܐ ܡܠܝܚܐ ܡܫܟܚܝܢ ܕܢܬܥܒܕܘܢ ܚܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.13",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "James 3:13",
      "text": "ܡܢܘ ܡܢܟܘܢ ܕܚܟܝܡ ܘܪܕܐ ܢܚܘܐ ܥܒܕܘܗܝ ܒܗܘܦܟܐ ܫܦܝܪܐ ܒܚܟܡܬܐ ܡܟܝܟܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.14",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "James 3:14",
      "text": "ܐܢ ܕܝܢ ܚܤܡܐ ܡܪܝܪܐ ܐܝܬ ܒܟܘܢ ܐܘ ܚܪܝܢܐ ܒܠܒܝܟܘܢ ܠܐ ܬܬܚܬܪܘܢ ܥܠ ܩܘܫܬܐ ܘܬܕܓܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.15",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "James 3:15",
      "text": "ܡܛܠ ܕܗܕܐ ܚܟܡܬܐ ܡܢ ܠܥܠ ܠܐ ܢܚܬܬ ܐܠܐ ܐܝܬܝܗ ܐܪܥܢܝܬܐ ܡܢ ܚܘܫܒܐ ܕܢܦܫܐ ܘܡܢ ܫܐܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.16",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "James 3:16",
      "text": "ܐܝܟܐ ܓܝܪ ܕܐܝܬ ܚܤܡܐ ܘܚܪܝܢܐ ܬܡܢ ܐܦ ܕܠܘܚܝܐ ܘܟܠܡܕܡ ܕܒܝܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.17",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "James 3:17",
      "text": "ܚܟܡܬܐ ܕܝܢ ܕܡܢ ܠܥܠ ܕܟܝܐ ܗܝ ܘܡܠܝܐ ܫܠܡܐ ܘܡܟܝܟܐ ܘܡܫܬܡܥܢܝܐ ܘܡܠܝܐ ܪܚܡܐ ܘܦܐܪܐ ܛܒܐ ܘܕܠܐ ܦܠܓܘܬܐ ܗܝ ܘܒܐܦܐ ܠܐ ܢܤܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.3.18",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "James 3:18",
      "text": "ܦܐܪܐ ܕܝܢ ܕܙܕܝܩܘܬܐ ܒܫܝܢܐ ܡܙܕܪܥܝܢ ܠܐܝܠܝܢ ܕܥܒܕܝܢ ܫܠܡܐ ܀",
      "paragraphStart": false
    }
  ]
}
