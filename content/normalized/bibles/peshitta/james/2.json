{
  "chapter": {
    "id": "peshitta:james.2",
    "translationId": "peshitta",
    "bookSlug": "james",
    "chapterNumber": 2,
    "referenceLabel": "James 2",
    "summary": "Source text for James 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:james.2.1",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "James 2:1",
      "text": "ܐܚܝ ܠܐ ܒܡܤܒ ܒܐܦܐ ܬܗܘܘܢ ܐܚܝܕܝܢ ܠܗܝܡܢܘܬܐ ܕܬܫܒܘܚܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:james.2.2",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "James 2:2",
      "text": "ܐܢ ܓܝܪ ܢܥܘܠ ܠܟܢܘܫܬܟܘܢ ܐܢܫ ܕܥܙܩܬܗ ܕܕܗܒܐ ܐܘ ܕܡܐܢܘܗܝ ܫܦܝܪܐ ܘܢܥܘܠ ܡܤܟܢܐ ܒܡܐܢܐ ܨܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.3",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "James 2:3",
      "text": "ܘܬܚܘܪܘܢ ܒܗܘ ܕܠܒܝܫ ܡܐܢܐ ܫܦܝܪܐ ܘܬܐܡܪܘܢ ܠܗ ܐܢܬ ܗܪܟܐ ܬܒ ܫܦܝܪ ܘܠܡܤܟܢܐ ܬܐܡܪܘܢ ܠܗ ܐܢܬ ܩܘܡ ܠܗܠ ܐܘ ܬܒ ܠܟ ܗܪܟܐ ܩܕܡ ܟܘܒܫܐ ܕܪܓܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.4",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "James 2:4",
      "text": "ܠܐ ܗܐ ܐܬܦܠܓܬܘܢ ܠܟܘܢ ܒܢܦܫܟܘܢ ܘܗܘܝܬܘܢ ܡܦܪܫܢܐ ܕܡܚܫܒܬܐ ܒܝܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.5",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "James 2:5",
      "text": "ܫܡܥܘ ܐܚܝ ܚܒܝܒܐ ܠܐ ܗܘܐ ܠܡܤܟܢܐ ܕܥܠܡܐ ܥܬܝܪܐ ܕܝܢ ܒܗܝܡܢܘܬܐ ܓܒܐ ܐܠܗܐ ܕܢܗܘܘܢ ܝܪܬܐ ܒܡܠܟܘܬܐ ܗܝ ܕܡܠܟ ܐܠܗܐ ܠܐܝܠܝܢ ܕܪܚܡܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.6",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "James 2:6",
      "text": "ܐܢܬܘܢ ܕܝܢ ܫܛܬܘܢܝܗܝ ܠܡܤܟܢܐ ܠܐ ܗܐ ܥܬܝܪܐ ܡܫܬܥܠܝܢ ܥܠܝܟܘܢ ܘܗܢܘܢ ܢܓܕܝܢ ܠܟܘܢ ܠܒܝܬ ܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.7",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "James 2:7",
      "text": "ܠܐ ܗܐ ܗܢܘܢ ܡܓܕܦܝܢ ܥܠ ܫܡܐ ܛܒܐ ܕܐܬܩܪܝ ܥܠܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.8",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "James 2:8",
      "text": "ܘܐܢ ܢܡܘܤܐ ܕܐܠܗܐ ܒܗܕܐ ܡܫܠܡܝܬܘܢ ܐܝܟ ܕܟܬܝܒ ܕܬܪܚܡ ܠܩܪܝܒܟ ܐܝܟ ܢܦܫܟ ܫܦܝܪ ܥܒܕܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.9",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "James 2:9",
      "text": "ܐܢ ܕܝܢ ܒܐܦܐ ܢܤܒܝܢ ܐܢܬܘܢ ܚܛܝܬܐ ܥܒܕܝܢ ܐܢܬܘܢ ܘܡܬܟܘܢܝܢ ܐܢܬܘܢ ܡܢ ܢܡܘܤܐ ܐܝܟ ܥܒܪܝ ܥܠ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.10",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "James 2:10",
      "text": "ܐܝܢܐ ܓܝܪ ܕܟܠܗ ܢܡܘܤܐ ܢܛܪ ܘܒܚܕܐ ܫܪܥ ܠܟܠܗ ܢܡܘܤܐ ܐܬܚܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.11",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "James 2:11",
      "text": "ܗܘ ܓܝܪ ܕܐܡܪ ܕܠܐ ܬܓܘܪ ܗܘ ܐܡܪ ܕܠܐ ܬܩܛܘܠ ܐܢ ܕܝܢ ܠܐ ܓܐܪ ܐܢܬ ܐܠܐ ܩܛܠ ܐܢܬ ܗܘܝܬ ܠܟ ܥܒܪ ܥܠ ܢܡܘܤܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.12",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "James 2:12",
      "text": "ܗܟܢܐ ܗܘܝܬܘܢ ܡܡܠܠܝܢ ܘܗܟܢܐ ܗܘܝܬܘܢ ܤܥܪܝܢ ܐܝܟ ܐܢܫܐ ܕܒܢܡܘܤܐ ܕܚܐܪܘܬܐ ܥܬܝܕܝܢ ܐܢܬܘܢ ܠܡܬܕܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.13",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "James 2:13",
      "text": "ܕܝܢܐ ܓܝܪ ܗܘܐ ܕܠܐ ܪܚܡܐ ܥܠ ܗܘ ܕܠܐ ܥܒܕ ܪܚܡܐ ܡܫܬܥܠܝܢ ܐܢܬܘܢ ܒܪܚܡܐ ܥܠ ܕܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.14",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "James 2:14",
      "text": "ܡܢܐ ܗܢܝܢܐ ܐܚܝ ܐܢ ܐܢܫ ܐܡܪ ܕܐܝܬ ܠܝ ܗܝܡܢܘܬܐ ܘܥܒܕܐ ܠܝܬ ܠܗ ܕܠܡܐ ܡܫܟܚܐ ܗܝܡܢܘܬܗ ܕܬܚܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.15",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "James 2:15",
      "text": "ܘܐܢ ܐܚܐ ܐܘ ܚܬܐ ܢܗܘܘܢ ܥܪܛܠܝܝܢ ܘܚܤܝܪܝܢ ܤܝܒܪܬܐ ܕܝܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.16",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "James 2:16",
      "text": "ܘܢܐܡܪ ܠܗܘܢ ܐܢܫ ܡܢܟܘܢ ܙܠܘ ܒܫܠܡܐ ܫܚܢܘ ܘܤܒܥܘ ܘܠܐ ܬܬܠܘܢ ܠܗܘܢ ܤܢܝܩܘܬܗ ܕܦܓܪܐ ܡܢܐ ܗܢܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.17",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "James 2:17",
      "text": "ܗܟܢܐ ܐܦ ܗܝܡܢܘܬܐ ܕܠܐ ܥܒܕܐ ܡܝܬܐ ܗܝ ܒܠܚܘܕܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.18",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "James 2:18",
      "text": "ܐܡܪ ܓܝܪ ܐܢܫ ܠܟ ܐܝܬ ܠܟ ܗܝܡܢܘܬܐ ܘܠܝ ܐܝܬ ܠܝ ܥܒܕܐ ܚܘܢܝ ܗܝܡܢܘܬܟ ܕܠܐ ܥܒܕܐ ܘܐܢܐ ܡܚܘܐ ܐܢܐ ܠܟ ܗܝܡܢܘܬܝ ܡܢ ܥܒܕܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.19",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "James 2:19",
      "text": "ܡܗܝܡܢ ܐܢܬ ܕܚܕ ܗܘ ܐܠܗܐ ܫܦܝܪ ܥܒܕ ܐܢܬ ܐܦ ܫܐܕܐ ܡܗܝܡܢܝܢ ܘܪܥܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.20",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "James 2:20",
      "text": "ܨܒܐ ܐܢܬ ܕܝܢ ܕܬܕܥ ܐܘ ܒܪܢܫܐ ܚܠܫܐ ܕܗܝܡܢܘܬܐ ܕܠܐ ܥܒܕܐ ܡܝܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.21",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "James 2:21",
      "text": "ܐܒܘܢ ܐܒܪܗܡ ܠܐ ܗܘܐ ܡܢ ܥܒܕܐ ܐܙܕܕܩ ܕܐܤܩ ܠܐܝܤܚܩ ܒܪܗ ܥܠ ܡܕܒܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.22",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "James 2:22",
      "text": "ܚܙܐ ܐܢܬ ܕܗܝܡܢܘܬܗ ܤܝܥܬ ܠܥܒܕܘܗܝ ܘܡܢ ܥܒܕܐ ܗܝܡܢܘܬܗ ܐܬܓܡܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.23",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "James 2:23",
      "text": "ܘܫܠܡ ܟܬܒܐ ܕܐܡܪ ܕܗܝܡܢ ܐܒܪܗܡ ܒܐܠܗܐ ܘܐܬܚܫܒܬ ܠܗ ܠܙܕܝܩܘ ܘܪܚܡܐ ܕܐܠܗܐ ܐܬܩܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.24",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "James 2:24",
      "text": "ܚܙܐ ܐܢܬ ܕܡܢ ܥܒܕܐ ܡܙܕܕܩ ܒܪܢܫܐ ܘܠܐ ܗܘܐ ܡܢ ܗܝܡܢܘܬܐ ܒܠܚܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.25",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "James 2:25",
      "text": "ܗܟܢܐ ܐܦ ܪܚܒ ܙܢܝܬܐ ܠܐ ܗܘܐ ܡܢ ܥܒܕܐ ܐܙܕܕܩܬ ܕܩܒܠܬ ܠܓܫܘܫܐ ܘܒܐܘܪܚܐ ܐܚܪܬܐ ܐܦܩܬ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:james.2.26",
      "translationId": "peshitta",
      "bookSlug": "james",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "James 2:26",
      "text": "ܐܝܟܢܐ ܕܦܓܪܐ ܕܠܐ ܪܘܚܐ ܡܝܬ ܗܘ ܗܟܢܐ ܐܦ ܗܝܡܢܘܬܐ ܕܠܐ ܥܒܕܐ ܡܝܬܐ ܗܝ ܀",
      "paragraphStart": false
    }
  ]
}
