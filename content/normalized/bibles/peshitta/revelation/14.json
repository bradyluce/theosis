{
  "chapter": {
    "id": "peshitta:revelation.14",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 14,
    "referenceLabel": "Revelation 14",
    "summary": "Source text for Revelation 14 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.14.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Revelation 14:1",
      "text": "ܘܚܙܝܬ ܘܗܐ ܐܡܪܐ ܩܐܡ ܥܠ ܛܘܪܐ ܕܨܗܝܘܢ ܘܥܡܗ ܡܐܐ ܘܐܪܒܥܝܢ ܘܐܪܒܥܐ ܐܠܦܝܢ ܕܐܝܬ ܥܠܝܗܘܢ ܫܡܗ ܘܫܡܐ ܕܐܒܘܗܝ ܟܬܝܒ ܥܠ ܒܝܬ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.14.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Revelation 14:2",
      "text": "ܘܫܡܥܬ ܩܠܐ ܡܢ ܫܡܝܐ ܐܝܟ ܩܠܐ ܕܡܝܐ ܤܓܝܐܐ ܘܐܝܟ ܩܠܐ ܕܪܥܡܐ ܪܒܐ ܩܠܐ ܐܝܢܐ ܕܫܡܥܬ ܐܝܟ ܩܝܬܪܘܕܐ ܕܢܩܫ ܒܩܝܬܪܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Revelation 14:3",
      "text": "ܘܡܫܒܚܝܢ ܐܝܟ ܬܫܒܘܚܬܐ ܚܕܬܐ ܩܕܡ ܟܘܪܤܝܐ ܘܩܕܡ ܐܪܒܥ ܚܝܘܢ ܘܩܕܡ ܩܫܝܫܐ ܘܠܐ ܐܢܫ ܐܬܡܨܝ ܠܡܐܠܦܗ ܠܬܫܒܘܚܬܐ ܐܠܐ ܐܢ ܡܐܐ ܘܐܪܒܥܝܢ ܘܐܪܒܥܐ ܐܠܦܝܢ ܙܒܝܢܝ ܡܢ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Revelation 14:4",
      "text": "ܗܠܝܢ ܐܢܘܢ ܐܝܠܝܢ ܕܥܡ ܢܫܐ ܠܐ ܐܬܛܘܫܘ ܒܬܘܠܐ ܓܝܪ ܐܝܬܝܗܘܢ ܗܠܝܢ ܕܢܩܦܘܗܝ ܠܐܡܪܐ ܟܠ ܟܪ ܕܢܐܙܠ ܗܠܝܢ ܐܙܕܒܢܘ ܡܢ ܐܢܫܐ ܪܫܝܬܐ ܠܐܠܗܐ ܘܠܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Revelation 14:5",
      "text": "ܕܒܦܘܡܗܘܢ ܠܐ ܐܫܬܟܚܬ ܕܓܠܘܬܐ ܕܠܐ ܡܘܡ ܓܝܪ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Revelation 14:6",
      "text": "ܘܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܕܦܪܚ ܡܨܥܬ ܫܡܝܐ ܘܐܝܬ ܠܗ ܥܠܘܗܝ ܤܒܪܬܐ ܕܠܥܠܡ ܠܡܤܒܪܘ ܥܠ ܝܬܒܝ ܐܪܥܐ ܘܥܠ ܟܠ ܥܡ ܘܐܡܘܢ ܘܫܪܒܢ ܘܠܫܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Revelation 14:7",
      "text": "ܠܡܐܡܪ ܒܩܠܐ ܪܒܐ ܕܚܠܘ ܡܢ ܐܠܗܐ ܘܗܒܘ ܠܗ ܬܫܒܘܚܬܐ ܡܛܠ ܕܐܬܬ ܫܥܬܐ ܕܕܝܢܗ ܘܤܓܘܕܘ ܠܕܥܒܕ ܫܡܝܐ ܘܐܪܥܐ ܘܝܡܐ ܘܥܝܢܬܐ ܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Revelation 14:8",
      "text": "ܘܐܚܪܢܐ ܕܬܪܝܢ ܢܩܝܦ ܗܘܐ ܠܗ ܘܐܡܪ ܢܦܠܬ ܢܦܠܬ ܒܒܝܠ ܪܒܬܐ ܐܝܕܐ ܕܡܢ ܚܡܬܐ ܕܙܢܝܘܬܗ ܐܫܩܝܬ ܠܟܠܗܘܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Revelation 14:9",
      "text": "ܘܐܚܪܢܐ ܡܠܐܟܐ ܕܬܠܬܐ ܢܩܦ ܠܗܘܢ ܠܡܐܡܪ ܒܩܠܐ ܪܒܐ ܐܝܢܐ ܕܤܓܕ ܠܚܝܘܬܐ ܘܠܨܠܡܗ ܘܫܩܠ ܪܘܫܡܗ ܒܝܬ ܥܝܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Revelation 14:10",
      "text": "ܐܦ ܗܘ ܢܫܬܐ ܡܢ ܚܡܪܐ ܕܚܡܬܗ ܕܡܪܝܐ ܕܡܙܝܓ ܕܠܐ ܚܠܛܐ ܒܟܤܐ ܕܪܘܓܙܗ ܘܢܫܬܢܩ ܒܢܘܪܐ ܘܟܒܪܝܬܐ ܩܕܡ ܡܠܐܟܐ ܩܕܝܫܐ ܘܩܕܡ ܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Revelation 14:11",
      "text": "ܘܬܢܢܐ ܕܬܫܢܝܩܗܘܢ ܠܥܠܡ ܥܠܡܝܢ ܢܤܩ ܘܠܝܬ ܠܗܘܢ ܢܦܐܫܐ ܐܝܡܡܐ ܘܠܠܝܐ ܐܝܠܝܢ ܕܤܓܕܝܢ ܠܚܝܘܬܐ ܘܠܨܠܡܗ ܘܠܡܢ ܕܫܩܠ ܪܘܫܡܐ ܕܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Revelation 14:12",
      "text": "ܗܪܟܐ ܐܝܬܝܗ ܡܤܝܒܪܢܘܬܐ ܕܩܕܝܫܐ ܐܝܠܝܢ ܕܢܛܪܘ ܦܘܩܕܢܘܗܝ ܕܐܠܗܐ ܘܗܝܡܢܘܬܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Revelation 14:13",
      "text": "ܘܫܡܥܬ ܩܠܐ ܡܢ ܫܡܝܐ ܕܐܡܪ ܟܬܘܒ ܛܘܒܝܗܘܢ ܠܡܝܬܐ ܐܝܠܝܢ ܕܥܢܕܘ ܒܡܪܢ ܡܢ ܗܫܐ ܐܝܢ ܐܡܪ ܪܘܚܐ ܡܛܠ ܕܢܬܬܢܝܚܘܢ ܡܢ ܥܡܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Revelation 14:14",
      "text": "ܘܗܐ ܥܢܢܐ ܚܘܪܬܐ ܘܥܠ ܥܢܢܐ ܝܬܒ ܕܡܘܬܐ ܕܒܪܢܫܐ ܘܐܝܬ ܠܗ ܥܠ ܪܫܗ ܟܠܝܠܐ ܕܕܗܒܐ ܘܥܠ ܐܝܕܗ ܡܓܠܬܐ ܚܪܝܦܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Revelation 14:15",
      "text": "ܘܐܚܪܢܐ ܡܠܐܟܐ ܢܦܩ ܡܢ ܗܝܟܠܐ ܘܩܥܐ ܒܩܠܐ ܪܒܐ ܠܕܝܬܒ ܥܠ ܥܢܢܐ ܫܕܪ ܡܓܠܬܟ ܘܚܨܘܕ ܡܛܠ ܕܐܬܬ ܫܥܬܐ ܠܡܚܨܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Revelation 14:16",
      "text": "ܘܐܪܡܝ ܗܘ ܕܝܬܒ ܥܠ ܥܢܢܐ ܡܓܠܬܗ ܥܠ ܐܪܥܐ ܘܐܬܚܨܕܬ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Revelation 14:17",
      "text": "ܘܐܚܪܢܐ ܡܠܐܟܐ ܢܦܩ ܡܢ ܗܝܟܠܐ ܕܒܫܡܝܐ ܘܥܠܘܗܝ ܐܝܬ ܡܓܠܬܐ ܚܪܝܦܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Revelation 14:18",
      "text": "ܘܐܚܪܢܐ ܡܠܐܟܐ ܢܦܩ ܡܢ ܡܕܒܚܐ ܕܐܝܬ ܠܗ ܫܘܠܛܢܐ ܥܠ ܢܘܪܐ ܘܩܥܐ ܒܩܠܐ ܪܒܐ ܠܕܐܝܬ ܠܗ ܡܓܠܬܐ ܚܪܝܦܬܐ ܫܕܪ ܐܢܬ ܡܓܠܬܟ ܚܪܝܦܬܐ ܘܩܛܘܦ ܠܤܓܘܠܐ ܕܟܪܡܗ ܕܐܪܥܐ ܡܛܠ ܕܪܒܝ ܥܢܒܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Revelation 14:19",
      "text": "ܘܐܪܡܝ ܡܠܐܟܐ ܡܓܠܬܗ ܥܠ ܐܪܥܐ ܘܩܛܦ ܠܟܪܡܗ ܕܐܪܥܐ ܘܐܪܡܝ ܒܡܥܨܪܬܐ ܪܒܬܐ ܕܚܡܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.14.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Revelation 14:20",
      "text": "ܘܐܬܬܕܝܫܬ ܡܥܨܪܬܐ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܘܢܦܩ ܕܡܐ ܡܢ ܡܥܨܪܬܐ ܥܕܡܐ ܠܦܓܘܕܐ ܕܪܟܫܐ ܥܠ ܐܠܦ ܘܡܐܬܝܢ ܐܤܛܕܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
