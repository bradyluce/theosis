{
  "chapter": {
    "id": "peshitta:revelation.17",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 17,
    "referenceLabel": "Revelation 17",
    "summary": "Source text for Revelation 17 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.17.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 1,
      "referenceLabel": "Revelation 17:1",
      "text": "ܘܐܬܐ ܚܕ ܡܢ ܫܒܥܐ ܡܠܐܟܐ ܕܐܝܬ ܥܠܝܗܘܢ ܫܒܥ ܙܒܘܪܝܢ ܘܡܠܠ ܥܡܝ ܠܡܐܡܪ ܬܐ ܒܬܪܝ ܐܚܘܝܟ ܕܝܢܐ ܕܙܢܝܬܐ ܕܝܬܒܐ ܥܠ ܡܝܐ ܤܓܝܐܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.17.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 2,
      "referenceLabel": "Revelation 17:2",
      "text": "ܕܥܡܗ ܙܢܝܘ ܡܠܟܝܗ ܕܐܪܥܐ ܘܪܘܝܘ ܟܠܗܘܢ ܥܡܘܪܝܗ ܕܐܪܥܐ ܡܢ ܚܡܪܐ ܕܙܢܝܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 3,
      "referenceLabel": "Revelation 17:3",
      "text": "ܘܐܦܩܢܝ ܠܚܘܪܒܐ ܒܪܘܚ ܘܚܙܝܬ ܐܢܬܬܐ ܕܝܬܒܐ ܥܠ ܚܝܘܬܐ ܤܘܡܩܬܐ ܕܡܠܝܐ ܫܡܗܐ ܕܓܘܕܦܐ ܕܐܝܬ ܠܗ ܪܫܐ ܫܒܥܐ ܩܪܢܬܐ ܕܝܢ ܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 4,
      "referenceLabel": "Revelation 17:4",
      "text": "ܘܐܢܬܬܐ ܐܝܬ ܗܘܐ ܕܡܥܛܦܐ ܐܪܓܘܢܐ ܘܙܚܘܪܝܬܐ ܕܡܕܗܒܢ ܒܕܗܒܐ ܘܟܐܦܐ ܛܒܬܐ ܘܡܪܓܢܝܬܐ ܘܐܝܬ ܠܗ ܟܤܐ ܕܕܗܒܐ ܥܠ ܐܝܕܗ ܘܡܠܐ ܛܡܐܘܬܐ ܘܤܘܝܒܐ ܕܙܢܝܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 5,
      "referenceLabel": "Revelation 17:5",
      "text": "ܘܥܠ ܒܝܬ ܥܝܢܝܗ ܟܬܝܒ ܐܪܙܐ ܒܒܝܠ ܪܒܬܐ ܐܡܐ ܕܙܢܝܬܐ ܘܕܤܘܝܒܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 6,
      "referenceLabel": "Revelation 17:6",
      "text": "ܘܚܙܝܬ ܐܢܬܬܐ ܕܪܘܝܐ ܡܢ ܕܡܐ ܕܩܕܝܫܐ ܘܡܢ ܕܡܐ ܕܤܗܕܘܗܝ ܕܝܫܘܥ ܘܐܬܕܡܪܬ ܕܘܡܪܐ ܪܒܐ ܟܕ ܚܙܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 7,
      "referenceLabel": "Revelation 17:7",
      "text": "ܘܐܡܪ ܠܝ ܡܠܐܟܐ ܠܡܢܐ ܐܬܕܡܪܬ ܐܢܐ ܐܡܪ ܐܢܐ ܠܟ ܪܐܙܐ ܕܐܢܬܬܐ ܘܕܚܝܘܬܐ ܕܛܥܝܢܐ ܠܗ ܕܐܝܬ ܠܗ ܫܒܥܐ ܪܫܝܢ ܘܥܤܪ ܩܪܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 8,
      "referenceLabel": "Revelation 17:8",
      "text": "ܚܝܘܬܐ ܕܚܙܝܬ ܐܝܬܝܗ ܗܘܬ ܘܠܝܬܝܗ ܥܬܝܕܐ ܕܬܤܩ ܡܢ ܝܡܐ ܘܠܐܒܕܢܐ ܐܙܠܐ ܘܢܬܕܡܪܘܢ ܥܡܪܝ ܥܠ ܐܪܥܐ ܗܢܘܢ ܕܠܐ ܟܬܝܒܝܢ ܫܡܗܝܗܘܢ ܒܤܦܪܐ ܕܚܝܐ ܡܢ ܬܪܡܝܬܗ ܕܥܠܡܐ ܕܚܙܝܢ ܚܝܘܬܐ ܕܐܝܬܝܗ ܗܘܬ ܘܠܝܬܝܗ ܘܩܪܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 9,
      "referenceLabel": "Revelation 17:9",
      "text": "ܗܪܟܐ ܗܘܢܐ ܠܕܐܝܬ ܠܗ ܚܟܡܬܐ ܫܒܥܐ ܪܫܝܢ ܫܒܥܐ ܐܢܘܢ ܛܘܪܝܢ ܐܝܟܐ ܕܝܬܒܐ ܐܢܬܬܐ ܥܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 10,
      "referenceLabel": "Revelation 17:10",
      "text": "ܘܡܠܟܐ ܫܒܥܐ ܐܢܘܢ ܚܡܫܐ ܢܦܠܘ ܘܚܕ ܐܝܬܘܗܝ ܗܘ ܐܚܪܢܐ ܠܐ ܥܕܟܝܠ ܐܬܐ ܘܡܐ ܕܐܬܐ ܩܠܝܠ ܝܗܝܒ ܠܗ ܠܡܟܬܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 11,
      "referenceLabel": "Revelation 17:11",
      "text": "ܘܬܢܝܢܐ ܘܚܝܘܬܐ ܗܝ ܕܐܝܬܝܗ ܘܠܝܬܝܗ ܘܗܝ ܕܬܡܢܝܐ ܘܡܢ ܫܒܥܐ ܗܝ ܘܠܐܒܕܢܐ ܐܙܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 12,
      "referenceLabel": "Revelation 17:12",
      "text": "ܘܥܤܪ ܩܪܢܢ ܕܚܙܝܬ ܥܤܪܐ ܡܠܟܝܢ ܐܢܘܢ ܐܝܠܝܢ ܕܡܠܟܘܬܐ ܠܐ ܥܕܟܝܠ ܢܤܒܘ ܐܠܐ ܫܘܠܛܢܐ ܐܝܟ ܡܠܟܐ ܚܕܐ ܫܥܬܐ ܫܩܠܝܢ ܥܡ ܚܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 13,
      "referenceLabel": "Revelation 17:13",
      "text": "ܗܠܝܢ ܚܕ ܨܒܝܢܐ ܐܝܬ ܠܗܘܢ ܘܚܝܠܐ ܘܫܘܠܛܢܐ ܕܝܠܗܘܢ ܠܚܝܘܬܐ ܝܗܒܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 14,
      "referenceLabel": "Revelation 17:14",
      "text": "ܗܠܝܢ ܥܡ ܐܡܪܐ ܢܩܪܒܘܢ ܘܐܡܪܐ ܢܙܟܐ ܐܢܘܢ ܡܛܠ ܕܡܪܐ ܗܘ ܕܡܪܘܬܐ ܘܡܠܟ ܡܠܟܐ ܘܕܥܡܗ ܩܪܝܐ ܘܓܒܝܐ ܘܡܗܝܡܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 15,
      "referenceLabel": "Revelation 17:15",
      "text": "ܘܐܡܪ ܠܝ ܡܝܐ ܕܚܙܝܬ ܕܥܠܝܗܘܢ ܝܬܒܐ ܙܢܝܬܐ ܥܡܡܐ ܘܟܢܫܐ ܘܐܡܘܬܐ ܘܠܫܢܐ ܐܝܬܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 16,
      "referenceLabel": "Revelation 17:16",
      "text": "ܘܥܤܪ ܩܪܢܬܐ ܕܚܙܝܬ ܠܚܝܘܬܐ ܗܠܝܢ ܢܤܢܝܢ ܠܙܢܝܬܐ ܘܚܪܒܬܐ ܘܥܪܛܠܝܬܐ ܢܥܒܕܘܢܗ ܘܒܤܪܗ ܢܐܟܠܘܢ ܘܢܘܩܕܘܢܗ ܒܢܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 17,
      "referenceLabel": "Revelation 17:17",
      "text": "ܐܠܗܐ ܓܝܪ ܝܗܒ ܒܠܒܘܬܗܘܢ ܕܢܥܒܕܘܢ ܨܒܝܢܗ ܘܢܥܒܕܘܢ ܨܒܝܢܗܘܢ ܚܕ ܘܢܬܠܘܢ ܡܠܟܘܬܗܘܢ ܠܚܝܘܬܐ ܗܝ ܥܕܡܐ ܕܢܫܬܡܠܝܢ ܡܠܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.17.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 17,
      "verseNumber": 18,
      "referenceLabel": "Revelation 17:18",
      "text": "ܘܐܢܬܬܐ ܐܝܕܐ ܕܚܙܝܬ ܡܕܝܢܬܐ ܪܒܬܐ ܐܝܕܐ ܕܐܝܬ ܠܗ ܡܠܟܘܬܐ ܥܠ ܡܠܟܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    }
  ]
}
