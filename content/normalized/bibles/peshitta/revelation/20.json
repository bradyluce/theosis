{
  "chapter": {
    "id": "peshitta:revelation.20",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 20,
    "referenceLabel": "Revelation 20",
    "summary": "Source text for Revelation 20 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.20.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 1,
      "referenceLabel": "Revelation 20:1",
      "text": "ܘܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܕܢܚܬ ܡܢ ܫܡܝܐ ܕܐܝܬ ܥܠܘܗܝ ܩܠܝܕܐ ܕܬܗܘܡܐ ܘܫܝܫܠܬܐ ܪܒܬܐ ܒܐܝܕܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.20.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 2,
      "referenceLabel": "Revelation 20:2",
      "text": "ܘܠܒܟܗ ܠܬܢܝܢܐ ܚܘܝܐ ܩܕܡܝܐ ܗܘ ܕܐܝܬܘܗܝ ܐܟܠܩܪܨܐ ܘܤܛܢܐ ܘܐܤܪܗ ܐܠܦ ܫܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 3,
      "referenceLabel": "Revelation 20:3",
      "text": "ܘܐܪܡܝܗ ܒܬܗܘܡܐ ܘܐܚܕ ܘܛܒܥ ܠܥܠ ܡܢܗ ܕܠܐ ܬܘܒ ܢܛܥܐ ܠܟܠܗܘܢ ܥܡܡܐ ܒܬܪ ܗܠܝܢ ܝܗܝܒ ܠܡܫܪܝܗ ܩܠܝܠ ܙܒܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 4,
      "referenceLabel": "Revelation 20:4",
      "text": "ܘܚܙܝܬ ܡܘܬܒܐ ܘܝܬܒܘ ܥܠܝܗܘܢ ܘܕܝܢܐ ܐܬܝܗܒ ܠܗܘܢ ܘܢܦܫܬܐ ܗܠܝܢ ܕܐܬܦܤܩ ܡܛܠ ܤܗܕܘܬܐ ܕܝܫܘܥ ܘܡܛܠ ܡܠܬܐ ܕܐܠܗܐ ܘܕܐܝܠܝܢ ܕܠܐ ܤܓܕܘ ܠܚܝܘܬܐ ܘܠܐ ܠܨܠܡܗ ܘܠܐ ܢܤܒܘ ܪܘܫܡܐ ܥܠ ܒܝܬ ܥܝܢܝܗܘܢ ܐܘ ܥܠ ܐܝܕܝܗܘܢ ܕܚܝܘ ܘܐܡܠܟܘ ܥܡ ܡܫܝܚܐ ܐܠܦ ܫܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 5,
      "referenceLabel": "Revelation 20:5",
      "text": "ܘܗܕܐ ܗܝ ܩܝܡܬܐ ܩܕܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 6,
      "referenceLabel": "Revelation 20:6",
      "text": "ܛܘܒܢܐ ܗܘ ܘܩܕܝܫܐ ܡܢ ܕܐܝܬ ܠܗ ܡܢܬܐ ܒܩܝܡܬܐ ܩܕܡܝܬܐ ܘܥܠ ܗܠܝܢ ܠܝܬ ܫܘܠܛܢܐ ܠܡܘܬܐ ܬܢܝܢܐ ܐܠܐ ܢܗܘܘܢ ܟܗܢܐ ܕܐܠܗܐ ܘܕܡܫܝܚܐ ܘܢܡܠܟܘܢ ܥܡܗ ܐܠܦ ܫܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 7,
      "referenceLabel": "Revelation 20:7",
      "text": "ܘܡܐ ܕܐܫܬܠܡ ܐܠܦ ܫܢܝܢ ܢܫܬܪܐ ܤܛܢܐ ܡܢ ܚܒܘܫܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 8,
      "referenceLabel": "Revelation 20:8",
      "text": "ܘܢܦܘܩ ܠܡܛܥܝܘ ܠܟܠܗܘܢ ܥܡܡܐ ܒܐܪܒܥ ܙܘܝܬܗ ܕܐܪܥܐ ܠܓܘܓ ܘܠܡܓܘܓ ܘܠܡܟܢܫܘ ܐܢܘܢ ܠܩܪܒܐ ܐܝܠܝܢ ܕܡܢܝܢܗܘܢ ܐܝܟ ܚܠܐ ܕܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 9,
      "referenceLabel": "Revelation 20:9",
      "text": "ܘܤܠܩܘ ܥܠ ܦܬܝܗ ܕܐܪܥܐ ܘܚܕܪܘܗ ܠܡܕܝܢܬܐ ܕܡܫܪܝܬܐ ܕܩܕܝܫܐ ܘܠܡܕܝܢܬܐ ܚܒܝܒܬܐ ܘܢܚܬܬ ܢܘܪܐ ܡܢ ܫܡܝܐ ܡܢ ܐܠܗܐ ܘܐܟܠܬ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 10,
      "referenceLabel": "Revelation 20:10",
      "text": "ܘܐܟܠܩܪܨܐ ܡܛܥܝܢܗܘܢ ܐܬܪܡܝ ܒܝܡܬܐ ܕܢܘܪܐ ܘܟܒܪܝܬܐ ܐܝܟܐ ܕܚܝܘܬܐ ܘܢܒܝܐ ܕܓܠܐ ܘܢܫܬܢܩܘܢ ܐܝܡܡܐ ܘܠܠܝܐ ܠܥܠܡ ܥܠܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 11,
      "referenceLabel": "Revelation 20:11",
      "text": "ܘܚܙܝܬ ܟܘܪܤܝܐ ܪܒܐ ܚܘܪܐ ܘܠܕܝܬܒ ܠܥܠ ܡܢܗ ܗܘ ܕܡܢ ܩܕܡ ܐܦܘܗܝ ܥܪܩܬ ܐܪܥܐ ܘܫܡܝܐ ܘܐܬܪ ܠܐ ܐܫܬܟܚ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 12,
      "referenceLabel": "Revelation 20:12",
      "text": "ܘܚܙܝܬ ܠܡܝܬܐ ܪܘܪܒܐ ܘܙܥܘܪܐ ܕܩܡܘ ܩܕܡ ܟܘܪܤܝܐ ܘܤܦܪܐ ܐܬܦܬܚܘ ܘܐܚܪܢܐ ܤܦܪܐ ܐܬܦܬܚ ܕܐܝܬܘܗܝ ܕܕܝܢܐ ܘܐܬܕܝܢܘ ܡܝܬܐ ܡܢ ܐܝܠܝܢ ܕܟܬܝܒܢ ܒܤܦܪܐ ܐܝܟ ܥܒܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 13,
      "referenceLabel": "Revelation 20:13",
      "text": "ܘܝܗܒ ܝܡܐ ܡܝܬܐ ܕܒܗ ܘܡܘܬܐ ܘܫܝܘܠ ܝܗܒܘ ܡܝܬܐ ܕܨܐܝܕܝܗܘܢ ܘܐܬܕܝܢ ܚܕ ܚܕ ܡܢܗܘܢ ܐܝܟ ܥܒܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 14,
      "referenceLabel": "Revelation 20:14",
      "text": "ܘܡܘܬܐ ܘܫܝܘܠ ܐܬܪܡܝܘ ܒܝܡܬܐ ܕܢܘܪܐ ܗܢܐ ܕܐܝܬܘܗܝ ܡܘܬܐ ܬܢܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.20.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 20,
      "verseNumber": 15,
      "referenceLabel": "Revelation 20:15",
      "text": "ܘܐܝܢܐ ܕܠܐ ܐܫܬܟܚ ܕܪܫܝܡ ܒܟܬܒܐ ܕܚܝܐ ܐܬܪܡܝ ܒܝܡܬܐ ܕܢܘܪܐ ܀",
      "paragraphStart": false
    }
  ]
}
