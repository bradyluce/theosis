{
  "chapter": {
    "id": "peshitta:revelation.3",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 3,
    "referenceLabel": "Revelation 3",
    "summary": "Source text for Revelation 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.3.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Revelation 3:1",
      "text": "ܘܠܡܠܐܟܐ ܕܒܥܕܬܐ ܕܤܪܕܝܤ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܗܘ ܕܐܝܬ ܠܗ ܫܒܥ ܪܘܚܝܢ ܕܐܠܗܐ ܘܫܒܥܐ ܟܘܟܒܐ ܝܕܥ ܐܢܐ ܥܒܕܝܟ ܘܫܡܐ ܕܐܝܬ ܠܟ ܘܕܚܝܐ ܐܢܬ ܘܕܡܝܬܐ ܐܢܬ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.3.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Revelation 3:2",
      "text": "ܘܗܘܝ ܥܝܪܐ ܘܩܝܡ ܕܫܪܟܐ ܕܐܝܠܝܢ ܕܥܬܝܕ ܗܘܝܬ ܠܡܡܬ ܠܐ ܓܝܪ ܐܫܟܚܬܟ ܕܡܫܡܠܝܢ ܥܒܕܝܟ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Revelation 3:3",
      "text": "ܐܬܕܟܪ ܐܝܟܢ ܫܡܥܬ ܘܢܤܒܬ ܐܙܕܗܪ ܘܬܘܒ ܘܐܢܕܝܢ ܠܐ ܬܬܥܝܪ ܐܬܐ ܐܢܐ ܥܠܝܟ ܐܝܟ ܓܢܒܐ ܘܠܐ ܬܕܥ ܐܝܕܐ ܫܥܬܐ ܐܬܐ ܥܠܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Revelation 3:4",
      "text": "ܐܠܐ ܐܝܬ ܠܝ ܩܠܝܠ ܫܡܗܐ ܒܤܪܕܝܤ ܐܝܠܝܢ ܕܠܐ ܛܘܫܘ ܡܐܢܝܗܘܢ ܘܡܗܠܟܝܢ ܩܕܡܝ ܒܚܘܪܐ ܘܫܘܝܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Revelation 3:5",
      "text": "ܕܙܟܐ ܗܟܢܐ ܡܬܥܛܦ ܡܐܢܐ ܚܘܪܐ ܘܠܐ ܐܠܚܐ ܫܡܗ ܡܢ ܤܦܪܐ ܕܚܝܐ ܘܐܘܕܐ ܒܫܡܗ ܩܕܡ ܐܒܝ ܘܩܕܡ ܡܠܐܟܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Revelation 3:6",
      "text": "ܐܝܢܐ ܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Revelation 3:7",
      "text": "ܘܠܡܠܐܟܐ ܕܥܕܬܐ ܕܦܝܠܕܠܦܝܐ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܩܕܝܫܐ ܫܪܝܪܐ ܗܘ ܕܐܝܬ ܠܗ ܩܠܝܕܐ ܕܕܘܝܕ ܐܝܢܐ ܕܦܬܚ ܘܠܝܬ ܕܐܚܕ ܘܐܚܕ ܘܠܝܬ ܕܦܬܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Revelation 3:8",
      "text": "ܝܕܥ ܐܢܐ ܥܒܕܝܟ ܘܗܐ ܝܗܒܬ ܩܕܡܝܟ ܬܪܥܐ ܦܬܝܚܐ ܐܝܢܐ ܕܠܐ ܐܢܫ ܡܨܐ ܠܡܐܚܕܗ ܡܛܠ ܕܩܠܝܠ ܚܝܠܐ ܐܝܬ ܠܟ ܘܡܠܬܝ ܢܛܪܬ ܘܒܫܡܝ ܠܐ ܟܦܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Revelation 3:9",
      "text": "ܘܗܐ ܝܗܒ ܐܢܐ ܡܢ ܟܢܘܫܬܐ ܕܤܛܢܐ ܡܢ ܐܝܠܝܢ ܕܐܡܪܝܢ ܥܠ ܢܦܫܗܘܢ ܕܝܗܘܕܝܐ ܐܢܘܢ ܘܠܐ ܐܝܬܝܗܘܢ ܐܠܐ ܡܕܓܠܝܢ ܗܐ ܐܥܒܕ ܠܗܘܢ ܕܢܐܬܘܢ ܘܢܤܓܕܘܢ ܩܕܡ ܪܓܠܝܟ ܘܢܕܥܘܢ ܕܐܢܐ ܐܚܒܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Revelation 3:10",
      "text": "ܥܠ ܕܢܛܪܬ ܡܠܬܐ ܕܡܤܝܒܪܢܘܬܝ ܘܐܢܐ ܐܛܪܟ ܡܢ ܢܤܝܘܢܐ ܕܥܬܝܕ ܕܢܐܬܐ ܥܠ ܟܠܗ ܬܐܒܝܠ ܕܢܢܤܐ ܠܥܡܘܪܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Revelation 3:11",
      "text": "ܐܬܐ ܐܢܐ ܡܚܕܐ ܐܚܘܕ ܗܘ ܡܐ ܕܐܝܬ ܠܟ ܕܠܐ ܐܢܫ ܢܤܒ ܟܠܝܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Revelation 3:12",
      "text": "ܘܕܙܟܐ ܐܥܒܕܗ ܥܡܘܕܐ ܒܗܝܟܠܐ ܕܐܠܗܐ ܘܠܒܪ ܠܐ ܢܦܘܩ ܬܘܒ ܘܐܟܬܘܒ ܥܠܘܗܝ ܫܡܐ ܕܐܠܗܝ ܘܫܡܐ ܕܡܕܝܢܬܐ ܚܕܬܐ ܐܘܪܫܠܡ ܐܝܕܐ ܕܢܚܬܐ ܡܢ ܐܠܗܝ ܘܫܡܐ ܕܝܠܝ ܚܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Revelation 3:13",
      "text": "ܘܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Revelation 3:14",
      "text": "ܘܠܡܠܐܟܐ ܕܥܕܬܐ ܕܠܐܝܕܝܩܝܐ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܐܡܝܢ ܤܗܕܐ ܡܗܝܡܢܐ ܘܫܪܝܪܐ ܘܪܫܝܬܐ ܕܒܪܝܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Revelation 3:15",
      "text": "ܝܕܥ ܐܢܐ ܥܒܕܝܟ ܠܐ ܩܪܝܪܐ ܐܢܬ ܘܠܐ ܚܡܝܡܐ ܕܘܠܐ ܗܘܐ ܕܐܘ ܩܪܝܪܐ ܬܗܘܐ ܐܘ ܚܡܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Revelation 3:16",
      "text": "ܘܐܝܬܝܟ ܦܫܘܪܐ ܘܠܐ ܩܪܝܪܐ ܘܠܐ ܚܡܝܡܐ ܥܬܝܕ ܐܢܐ ܠܡܬܒܘܬܟ ܡܢ ܦܘܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Revelation 3:17",
      "text": "ܡܛܠ ܕܐܡܪܬ ܕܥܬܝܪܐ ܐܢܬ ܘܥܬܪܬ ܘܥܠ ܡܕܡ ܠܐ ܤܢܝܩ ܐܢܐ ܘܠܐ ܝܕܥ ܐܢܬ ܕܐܢܬ ܗܘ ܡܚܝܠܐ ܘܕܘܝܐ ܘܡܤܟܢܐ ܘܥܪܛܠܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Revelation 3:18",
      "text": "ܡܠܟ ܐܢܐ ܠܟ ܕܬܙܒܢ ܡܢܝ ܕܗܒܐ ܕܒܚܝܪ ܡܢ ܢܘܪܐ ܕܬܥܬܪ ܘܡܐܢܐ ܚܘܪܐ ܠܡܬܥܛܦܘ ܘܠܐ ܬܬܓܠܐ ܒܗܬܬܐ ܕܥܪܛܠܝܘܬܟ ܘܫܝܦܐ ܟܚܘܠ ܕܬܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Revelation 3:19",
      "text": "ܐܢܐ ܠܐܝܠܝܢ ܕܪܚܡ ܐܢܐ ܡܟܤ ܐܢܐ ܘܪܕܐ ܐܢܐ ܛܢ ܗܟܝܠ ܘܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Revelation 3:20",
      "text": "ܗܐ ܩܡܬ ܥܠ ܬܪܥܐ ܘܐܩܘܫ ܐܢ ܐܢܫ ܫܡܥ ܒܩܠܝ ܘܢܦܬܚ ܬܪܥܐ ܘܐܥܘܠ ܘܐܚܫܡ ܥܡܗ ܘܗܘ ܥܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Revelation 3:21",
      "text": "ܘܕܙܟܐ ܐܬܠ ܠܗ ܠܡܬܒ ܥܡܝ ܥܠ ܟܘܪܤܝܐ ܕܝܠܝ ܐܝܟܢܐ ܕܐܢܐ ܙܟܝܬ ܘܝܬܒܬ ܥܡ ܐܒܝ ܥܠ ܟܘܪܤܝܐ ܕܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.3.22",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Revelation 3:22",
      "text": "ܡܢ ܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
