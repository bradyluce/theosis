{
  "chapter": {
    "id": "peshitta:revelation.19",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 19,
    "referenceLabel": "Revelation 19",
    "summary": "Source text for Revelation 19 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.19.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 1,
      "referenceLabel": "Revelation 19:1",
      "text": "ܘܡܢ ܒܬܪ ܗܠܝܢ ܫܡܥܬ ܩܠܐ ܪܒܐ ܕܟܢܫܐ ܤܓܝܐܐ ܒܫܡܝܐ ܕܐܡܪܝܢ ܗܠܠܘܝܐ ܦܘܪܩܢܐ ܘܬܫܒܘܚܬܐ ܘܚܝܠܐ ܠܐܠܗܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.19.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 2,
      "referenceLabel": "Revelation 19:2",
      "text": "ܡܛܠ ܕܫܪܝܪܝܢ ܘܟܐܢܝܢ ܕܝܢܘܗܝ ܡܛܠ ܕܕܢ ܠܙܢܝܬܐ ܪܒܬܐ ܐܝܕܐ ܕܚܒܠܬ ܠܐܪܥܐ ܒܙܢܝܘܬܗ ܘܬܒܥ ܕܡܐ ܕܥܒܕܘܗܝ ܡܢ ܐܝܕܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 3,
      "referenceLabel": "Revelation 19:3",
      "text": "ܕܬܪܬܝܢ ܐܡܪܘ ܗܠܠܘܝܐ ܘܬܢܢܗ ܤܠܩ ܠܥܠܡ ܥܠܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 4,
      "referenceLabel": "Revelation 19:4",
      "text": "ܘܢܦܠܘ ܥܤܪܝܢ ܘܐܪܒܥܐ ܩܫܝܫܝܢ ܘܐܪܒܥ ܚܝܘܢ ܘܤܓܕܘ ܠܐܠܗܢ ܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܘܐܡܪܝܢ ܐܡܝܢ ܗܠܠܘܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 5,
      "referenceLabel": "Revelation 19:5",
      "text": "ܘܩܠܐ ܡܢ ܟܘܪܤܝܐ ܕܐܡܪ ܫܒܚܘ ܠܐܠܗܢ ܟܠܗܘܢ ܥܒܕܘܗܝ ܘܕܚܠܝ ܫܡܗ ܟܠܗܘܢ ܙܥܘܪܐ ܥܡ ܪܘܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 6,
      "referenceLabel": "Revelation 19:6",
      "text": "ܘܫܡܥܬ ܩܠܐ ܐܝܟ ܕܟܢܫܐ ܤܓܝܐܐ ܘܐܝܟ ܩܠܐ ܕܡܝܐ ܤܓܝܐܐ ܘܐܝܟ ܩܠܐ ܕܪܥܡܐ ܚܝܠܬܢܐ ܕܐܡܪܝܢ ܗܠܠܘܝܐ ܡܛܠ ܕܐܡܠܟ ܡܪܝܐ ܐܠܗܐ ܐܚܝܕ ܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 7,
      "referenceLabel": "Revelation 19:7",
      "text": "ܚܕܝܢܢ ܘܡܬܦܨܚܝܢܢ ܢܬܠ ܠܗ ܬܫܒܘܚܬܐ ܡܛܠ ܕܐܬܬ ܡܫܬܘܬܗ ܕܐܡܪܐ ܘܐܢܬܬܗ ܛܝܒܬ ܢܦܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 8,
      "referenceLabel": "Revelation 19:8",
      "text": "ܘܐܬܝܗܒ ܠܗ ܕܬܬܥܛܦ ܒܘܨܐ ܕܟܝܐ ܘܢܗܝܪܐ ܒܘܨܐ ܓܝܪ ܬܪܝܨܬܐ ܐܢܝܢ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 9,
      "referenceLabel": "Revelation 19:9",
      "text": "ܘܐܡܪܘ ܠܝ ܟܬܘܒ ܛܘܒܝܗܘܢ ܠܐܝܠܝܢ ܕܠܚܫܡܝܬܐ ܕܡܫܬܘܬܗ ܕܐܡܪܐ ܐܝܬܝܗܘܢ ܩܪܝܐ ܘܐܡܪ ܠܝ ܗܠܝܢ ܡܠܐ ܕܫܪܝܪܢ ܕܐܠܗܐ ܐܝܬܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 10,
      "referenceLabel": "Revelation 19:10",
      "text": "ܘܢܦܠܬ ܩܕܡ ܪܓܠܘܗܝ ܘܤܓܕܬ ܠܗ ܘܐܡܪ ܠܝ ܠܐ ܟܢܬܟ ܐܝܬܝ ܘܕܐܚܝܟ ܗܠܝܢ ܕܐܝܬ ܠܗܘܢ ܤܗܕܘܬܐ ܕܝܫܘܥ ܠܐܠܗܐ ܤܓܘܕ ܝܬܝܪܐܝܬ ܤܗܕܘܬܐ ܓܝܪ ܕܝܫܘܥ ܐܝܬܝܗ ܪܘܚܐ ܕܢܒܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 11,
      "referenceLabel": "Revelation 19:11",
      "text": "ܘܚܙܝܬ ܫܡܝܐ ܕܦܬܝܚ ܘܗܐ ܤܘܤܝܐ ܚܘܪܐ ܘܕܝܬܒ ܥܠܘܗܝ ܡܬܩܪܐ ܡܗܝܡܢܐ ܘܫܪܝܪܐ ܘܒܟܐܢܘܬܐ ܕܐܢ ܘܡܩܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 12,
      "referenceLabel": "Revelation 19:12",
      "text": "ܥܝܢܘܗܝ ܕܝܢ ܐܝܟ ܫܠܗܒܝܬܐ ܕܢܘܪܐ ܘܥܠ ܪܝܫܗ ܬܐܓܐ ܤܓܝܐܐ ܘܐܝܬ ܠܗ ܫܡܐ ܟܬܝܒܐ ܐܝܢܐ ܕܠܐ ܝܕܥ ܐܠܐ ܐܢ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 13,
      "referenceLabel": "Revelation 19:13",
      "text": "ܘܡܥܛܦ ܡܐܢܐ ܕܙܠܝܥ ܒܕܡܐ ܘܡܬܩܪܐ ܫܡܗ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 14,
      "referenceLabel": "Revelation 19:14",
      "text": "ܘܚܝܠܘܬܐ ܕܫܡܝܐ ܢܩܝܦܝܢ ܗܘܘ ܠܗ ܥܠ ܪܟܫܐ ܚܘܪܐ ܘܠܒܝܫܝܢ ܒܘܨܐ ܚܘܪܐ ܘܕܟܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 15,
      "referenceLabel": "Revelation 19:15",
      "text": "ܘܡܢ ܦܘܡܗܘܢ ܢܦܩܐ ܚܪܒܐ ܚܪܝܦܬܐ ܕܒܗ ܢܩܛܠܘܢ ܠܥܡܡܐ ܘܗܘ ܢܪܥܐ ܐܢܘܢ ܒܫܒܛܐ ܕܦܪܙܠܐ ܘܗܘ ܕܐܫ ܡܥܨܪܬܐ ܕܪܘܓܙܗ ܕܐܠܗܐ ܐܚܝܕ ܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 16,
      "referenceLabel": "Revelation 19:16",
      "text": "ܘܐܝܬ ܠܗ ܥܠ ܡܐܢܘܗܝ ܥܠ ܥܛܡܬܗ ܫܡܐ ܟܬܝܒܐ ܡܠܟܐ ܕܡܠܟܐ ܘܡܪܐ ܕܡܪܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 17,
      "referenceLabel": "Revelation 19:17",
      "text": "ܘܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܕܩܐܡ ܒܫܡܫܐ ܘܩܥܐ ܒܩܠܐ ܪܡܐ ܘܐܡܪ ܠܦܪܚܬܐ ܕܦܪܚܐ ܡܨܥܬ ܫܡܝܐ ܐܬܟܢܫܘ ܠܚܫܡܝܬܐ ܪܒܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 18,
      "referenceLabel": "Revelation 19:18",
      "text": "ܕܬܐܟܠܘܢ ܒܤܪܐ ܕܡܠܟܐ ܘܒܤܪܐ ܕܪܫܝ ܐܠܦܐ ܘܒܤܪܐ ܕܥܫܝܢܐ ܘܒܤܪܐ ܕܪܟܫܐ ܘܕܐܝܠܝܢ ܕܝܬܒܝܢ ܥܠܝܗܘܢ ܘܒܤܪܐ ܕܚܐܪܐ ܘܕܥܒܕܐ ܘܕܙܥܘܪܐ ܘܕܪܘܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 19,
      "referenceLabel": "Revelation 19:19",
      "text": "ܘܚܙܝܬ ܠܚܝܘܬܐ ܘܠܚܝܠܘܬܗ ܘܡܠܟܐ ܕܐܪܥܐ ܘܠܦܠܚܝܗܘܢ ܕܡܟܢܫܝܢ ܠܡܥܒܕ ܩܪܒܐ ܥܡ ܗܘ ܕܝܬܒ ܥܠ ܤܘܤܝܐ ܘܥܡ ܦܠܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 20,
      "referenceLabel": "Revelation 19:20",
      "text": "ܘܐܬܬܨܝܕܬ ܚܝܘܬܐ ܘܢܒܝܐ ܕܓܠܐ ܥܡܗ ܗܘ ܕܥܒܕ ܐܬܘܬܐ ܩܕܡܝܗ ܕܒܗܝܢ ܐܛܥܝ ܠܐܝܠܝܢ ܕܢܤܒܘ ܪܘܫܡܐ ܕܚܝܘܬܐ ܘܠܐܝܠܝܢ ܕܤܓܕܘ ܠܨܠܡܗ ܘܢܚܬܘ ܬܪܝܗܘܢ ܘܐܬܪܡܝܘ ܒܝܡܬܐ ܕܢܘܪܐ ܕܝܩܕܐ ܘܕܟܒܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.19.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 19,
      "verseNumber": 21,
      "referenceLabel": "Revelation 19:21",
      "text": "ܘܕܫܪܟܐ ܕܝܢ ܐܬܩܛܠܘ ܒܚܪܒܗ ܕܗܘ ܕܝܬܒ ܥܠ ܤܘܤܝܐ ܒܐܝܕܐ ܕܢܦܩܐ ܡܢ ܦܘܡܗ ܘܟܠܗ ܛܝܪܐ ܤܒܥܬ ܡܢ ܒܤܪܗܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
