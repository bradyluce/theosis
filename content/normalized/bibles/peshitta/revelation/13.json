{
  "chapter": {
    "id": "peshitta:revelation.13",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 13,
    "referenceLabel": "Revelation 13",
    "summary": "Source text for Revelation 13 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.13.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Revelation 13:1",
      "text": "ܘܩܡܬ ܥܠ ܚܠܐ ܕܝܡܐ ܘܚܙܝܬ ܕܤܠܩܐ ܚܝܘܬܐ ܡܢ ܝܡܐ ܕܐܝܬ ܠܗ ܥܤܪ ܩܪܢܢ ܘܫܒܥ ܩܪܩܦܢ ܘܥܠ ܩܪܢܬܗ ܥܤܪܐ ܬܐܓܝܢ ܘܥܠ ܩܪܩܦܬܗ ܫܡܐ ܕܓܘܕܦܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.13.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Revelation 13:2",
      "text": "ܘܚܝܘܬܐ ܗܝ ܕܚܙܝܬ ܕܡܘܬܐ ܗܘܬ ܕܢܡܪܐ ܘܪܓܠܝܗ ܐܝܟ ܕܕܒܐ ܘܦܘܡܗ ܐܝܟ ܕܐܪܝܘܬܐ ܘܝܗܒ ܠܗ ܬܢܝܢܐ ܚܝܠܗ ܘܟܘܪܤܝܗ ܘܫܘܠܛܢܐ ܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Revelation 13:3",
      "text": "ܘܚܕܐ ܡܢ ܩܪܩܦܬܗ ܐܝܟ ܦܥܝܥܬܐ ܠܡܘܬܐ ܘܡܚܘܬܐ ܕܡܘܬܗ ܐܬܐܤܝܬ ܘܐܬܕܡܪܬ ܟܠܗ ܐܪܥܐ ܒܬܪ ܚܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Revelation 13:4",
      "text": "ܘܤܓܕܘ ܠܬܢܝܢܐ ܕܝܗܒ ܫܘܠܛܢܐ ܠܚܝܘܬܐ ܘܤܓܕܘ ܠܚܝܘܬܐ ܠܡܐܡܪ ܡܢܘ ܕܕܡܐ ܠܚܝܘܬܐ ܗܕܐ ܘܡܢܘ ܡܫܟܚ ܠܡܩܪܒܘ ܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Revelation 13:5",
      "text": "ܘܐܬܝܗܒ ܠܗ ܦܘܡܐ ܕܡܡܠܠ ܪܘܪܒܬܐ ܘܓܘܕܦܐ ܘܐܬܝܗܒ ܠܗ ܫܘܠܛܢܐ ܠܡܥܒܕ ܝܪܚܐ ܐܪܒܥܝܢ ܘܬܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Revelation 13:6",
      "text": "ܘܦܬܚܬ ܦܘܡܗ ܠܡܓܕܦܘ ܩܕܡ ܐܠܗܐ ܕܬܓܕܦܝ ܒܫܡܐ ܘܒܡܫܪܝܐ ܕܐܝܠܝܢ ܕܫܪܝܢ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Revelation 13:7",
      "text": "ܘܐܬܝܗܒ ܠܗ ܠܡܥܒܕ ܩܪܒܐ ܥܡ ܩܕܝܫܐ ܘܠܡܙܟܐ ܐܢܘܢ ܘܐܬܝܗܒ ܠܗ ܫܘܠܛܢܐ ܥܠ ܟܠܗܝܢ ܫܪܒܬܐ ܘܐܡܘܬܐ ܘܠܫܢܐ ܘܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Revelation 13:8",
      "text": "ܘܢܤܓܕܘܢ ܠܗ ܟܠܗܘܢ ܥܡܘܪܝܗ ܕܐܪܥܐ ܗܢܘܢ ܐܝܠܝܢ ܕܠܐ ܟܬܝܒܝܢ ܒܟܬܒܐ ܕܚܝܐ ܗܘ ܕܐܡܪܐ ܩܛܝܠܐ ܩܕܡ ܬܪܡܝܬܗ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Revelation 13:9",
      "text": "ܡܢ ܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Revelation 13:10",
      "text": "ܡܢ ܕܒܫܒܝܐ ܡܘܒܠ ܒܫܒܝܐ ܐܙܠ ܘܐܝܢܐ ܕܒܚܪܒܐ ܩܛܠ ܒܚܪܒܐ ܢܬܩܛܠ ܗܪܟܐ ܗܝ ܗܝܡܢܘܬܐ ܘܡܤܝܒܪܢܘܬܐ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Revelation 13:11",
      "text": "ܘܚܙܝܬ ܚܝܘܬܐ ܐܚܪܬܐ ܕܤܠܩܐ ܡܢ ܐܪܥܐ ܘܐܝܬ ܗܘܐ ܠܗ ܬܪܬܝܢ ܩܪܢܢ ܘܕܡܝܐ ܠܐܡܪܐ ܘܡܡܠܠܐ ܗܘܬ ܐܝܟ ܬܢܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Revelation 13:12",
      "text": "ܘܫܘܠܛܢܐ ܕܚܝܘܬܐ ܩܕܡܝܬܐ ܟܠܗ ܬܥܒܕ ܩܕܡܘܗܝ ܘܬܥܒܕ ܠܐܪܥܐ ܘܠܕܥܡܪܝܢ ܒܗ ܘܢܤܓܕܘܢ ܠܚܝܘܬܐ ܩܕܡܝܬܐ ܗܝ ܕܐܬܚܠܡܬ ܡܚܘܬܐ ܕܡܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Revelation 13:13",
      "text": "ܘܬܥܒܕ ܐܬܘܬܐ ܪܘܪܒܬܐ ܐܝܟܢܐ ܕܢܘܪܐ ܬܥܒܕ ܠܡܚܬ ܡܢ ܫܡܝܐ ܥܠ ܐܪܥܐ ܩܕܡ ܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Revelation 13:14",
      "text": "ܘܬܛܥܐ ܠܕܥܡܪܝܢ ܥܠ ܐܪܥܐ ܒܝܕ ܐܬܘܬܐ ܕܐܬܝܗܒ ܠܗ ܠܡܥܒܕ ܩܕܡ ܚܝܘܬܐ ܠܡܐܡܪ ܠܕܥܡܪܝܢ ܥܠ ܐܪܥܐ ܠܡܥܒܕ ܨܠܡܐ ܠܚܝܘܬܐ ܐܝܕܐ ܕܐܝܬ ܠܗ ܡܚܘܬܐ ܕܚܪܒܐ ܘܚܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Revelation 13:15",
      "text": "ܘܐܬܝܗܒ ܠܗ ܕܬܬܠ ܪܘܚܐ ܠܨܠܡܐ ܕܚܝܘܬܐ ܘܬܥܒܕ ܕܟܠ ܕܠܐ ܢܤܓܕܘܢ ܠܗ ܠܨܠܡܐ ܕܚܝܘܬܐ ܢܬܩܛܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Revelation 13:16",
      "text": "ܘܬܥܒܕ ܠܟܠܗܘܢ ܙܥܘܪܐ ܘܪܘܪܒܐ ܥܬܝܪܐ ܘܡܤܟܢܐ ܡܪܝܐ ܘܥܒܕܐ ܕܢܬܝܗܒ ܠܗܘܢ ܪܘܫܡܐ ܥܠ ܐܝܕܝܗܘܢ ܕܝܡܝܢܐ ܐܘ ܥܠ ܒܝܬ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Revelation 13:17",
      "text": "ܕܠܐ ܐܢܫ ܢܙܒܢ ܐܘ ܢܙܒܢ ܬܘܒ ܐܠܐ ܐܝܢܐ ܕܐܝܬ ܥܠܘܗܝ ܪܘܫܡܐ ܕܫܡܐ ܕܚܝܘܬܐ ܐܘ ܡܢܝܢܐ ܕܫܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.13.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Revelation 13:18",
      "text": "ܗܪܟܐ ܐܝܬܝܗ ܚܟܡܬܐ ܘܕܐܝܬ ܒܗ ܗܘܢܐ ܢܚܫܒܝܘܗܝ ܠܡܢܝܢܐ ܕܚܝܘܬܐ ܡܢܝܢܐ ܗܘ ܓܝܪ ܕܒܪܢܫܐ ܫܬܡܐܐ ܘܫܬܝܢ ܘܫܬ ܀",
      "paragraphStart": false
    }
  ]
}
