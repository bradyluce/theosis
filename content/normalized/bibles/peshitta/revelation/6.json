{
  "chapter": {
    "id": "peshitta:revelation.6",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 6,
    "referenceLabel": "Revelation 6",
    "summary": "Source text for Revelation 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.6.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Revelation 6:1",
      "text": "ܘܚܙܝܬ ܟܕ ܦܬܚ ܐܡܪܐ ܚܕ ܡܢ ܫܒܥܐ ܛܒܥܝܢ ܘܫܡܥܬ ܠܚܕܐ ܡܢ ܐܪܒܥ ܚܝܘܢ ܕܐܡܪܐ ܐܝܟ ܩܠܐ ܕܪܥܡܐ ܬܐ ܘܚܙܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.6.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Revelation 6:2",
      "text": "ܘܫܡܥܬ ܘܚܙܝܬ ܘܗܐ ܤܘܤܝܐ ܚܘܪܐ ܘܕܝܬܒ ܥܠܘܗܝ ܐܝܬ ܠܗ ܩܫܬܐ ܘܐܬܝܗܒ ܠܗ ܟܠܝܠܐ ܘܢܦܩ ܙܟܝ ܘܙܟܐ ܘܕܢܙܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Revelation 6:3",
      "text": "ܘܟܕ ܦܬܚ ܛܒܥܐ ܕܬܪܝܢ ܫܡܥܬ ܠܚܝܘܬܐ ܕܬܪܬܝܢ ܕܐܡܪܐ ܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Revelation 6:4",
      "text": "ܘܢܦܩ ܤܘܤܝܐ ܤܘܡܩܐ ܘܠܕܝܬܒ ܥܠܘܗܝ ܐܬܝܗܒ ܠܗ ܠܡܤܒ ܫܠܡܐ ܡܢ ܐܪܥܐ ܕܠܚܕܕܐ ܢܢܟܤܘܢ ܘܐܬܝܗܒܬ ܠܗ ܚܪܒܐ ܪܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Revelation 6:5",
      "text": "ܘܟܕ ܐܬܦܬܚ ܛܒܥܐ ܕܬܠܬܐ ܫܡܥܬ ܠܚܝܘܬܐ ܕܬܠܬ ܕܐܡܪܐ ܬܐ ܘܗܐ ܤܘܤܝܐ ܐܘܟܡܐ ܘܕܝܬܒ ܥܠܘܗܝ ܐܝܬ ܡܐܤܬܐ ܒܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Revelation 6:6",
      "text": "ܘܫܡܥܬ ܩܠܐ ܡܢ ܒܝܬ ܚܝܘܬܐ ܕܐܡܪ ܩܒܐ ܕܚܛܐ ܒܕܝܢܪܐ ܘܬܠܬܐ ܩܒܝܢ ܕܤܥܪܐ ܒܕܝܢܪܐ ܘܠܚܡܪܐ ܘܠܡܫܚܐ ܠܐ ܬܗܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Revelation 6:7",
      "text": "ܘܟܕ ܦܬܚ ܛܒܥܐ ܕܐܪܒܥܐ ܫܡܥܬ ܩܠܐ ܕܚܝܘܬܐ ܕܐܡܪܐ ܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Revelation 6:8",
      "text": "ܘܚܙܝܬ ܤܘܤܝܐ ܝܘܪܩܐ ܘܫܡܗ ܕܗܘ ܕܝܬܒ ܥܠܘܗܝ ܡܘܬܐ ܘܫܝܘܠ ܢܩܝܦܐ ܠܗ ܘܐܬܝܗܒ ܠܗ ܫܘܠܛܢܐ ܥܠ ܪܘܒܥܗ ܕܐܪܥܐ ܕܢܩܛܠ ܒܚܪܒܐ ܘܒܟܦܢܐ ܘܒܡܘܬܐ ܘܒܚܝܘܬܐ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Revelation 6:9",
      "text": "ܘܟܕ ܦܬܚ ܠܛܒܥܐ ܕܚܡܫܐ ܚܙܝܬ ܠܬܚܬ ܡܢ ܡܕܒܚܐ ܠܢܦܫܬܐ ܕܐܬܩܛܠ ܡܛܠ ܡܠܬܐ ܕܐܠܗܐ ܘܡܛܠ ܤܗܕܘܬܐ ܕܝܫܘܥ ܗܝ ܕܐܝܬ ܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Revelation 6:10",
      "text": "ܘܩܥܘ ܒܩܠܐ ܪܒܐ ܘܐܡܪܝܢ ܥܕܡܐ ܠܐܡܬܝ ܡܪܝܐ ܩܕܝܫܐ ܘܫܪܝܪܐ ܠܐ ܕܝܢܬ ܘܬܒܥܬ ܕܡܢ ܡܢ ܥܡܘܪܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Revelation 6:11",
      "text": "ܘܐܬܝܗܒܬ ܠܟܠܚܕ ܚܕ ܡܢܗܘܢ ܐܤܛܠܐ ܚܘܪܬܐ ܘܐܬܐܡܪ ܕܢܬܬܢܝܚܘܢ ܥܕ ܥܕܢ ܙܒܢ ܙܥܘܪ ܥܕܡܐ ܕܡܫܬܡܠܝܢ ܐܦ ܟܢܘܬܗܘܢ ܘܐܚܝܗܘܢ ܐܝܠܝܢ ܕܥܬܝܕܝܢ ܠܡܬܩܛܠܘ ܐܝܟ ܕܐܦ ܗܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Revelation 6:12",
      "text": "ܘܚܙܝܬ ܟܕ ܦܬܚ ܛܒܥܐ ܕܫܬܐ ܘܢܘܕܐ ܪܒܐ ܗܘܐ ܘܫܡܫܐ ܐܝܟ ܤܩܐ ܕܤܥܪܐ ܐܘܟܡ ܗܘܐ ܘܤܗܪܐ ܟܠܗ ܗܘܐ ܠܗ ܐܝܟ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Revelation 6:13",
      "text": "ܘܟܘܟܒܐ ܕܫܡܝܐ ܢܦܠܘ ܥܠ ܐܪܥܐ ܐܝܟ ܬܬܐ ܕܫܕܝܐ ܦܩܘܥܝܗ ܡܢ ܪܘܚܐ ܥܫܝܢܬܐ ܡܐ ܕܡܬܬܙܝܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Revelation 6:14",
      "text": "ܘܫܡܝܐ ܐܬܦܪܫ ܘܐܝܟ ܟܬܒܐ ܐܬܟܪܟܘ ܘܟܠ ܛܘܪ ܘܟܠ ܓܙܪܬܐ ܡܢ ܕܘܟܬܗܘܢ ܐܬܬܙܝܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Revelation 6:15",
      "text": "ܘܡܠܟܐ ܕܐܪܥܐ ܘܪܘܪܒܢܐ ܘܪܝܫܝ ܐܠܦܐ ܘܥܬܝܪܐ ܘܚܝܠܘܬܐ ܘܟܠ ܥܒܕܐ ܘܒܢܝ ܚܐܪܐ ܛܫܝܘ ܢܦܫܗܘܢ ܒܡܥܪܐ ܘܒܫܘܥܐ ܕܛܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Revelation 6:16",
      "text": "ܘܐܡܪܝܢ ܠܛܘܪܐ ܘܫܘܥܐ ܕܦܠܘ ܥܠܝܢ ܘܛܫܘ ܠܢ ܡܢ ܩܕܡ ܐܦܘܗܝ ܕܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.6.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Revelation 6:17",
      "text": "ܡܛܠ ܕܐܬܐ ܝܘܡܐ ܪܒܐ ܕܪܘܓܙܗܘܢ ܘܡܢܘ ܡܫܟܚ ܠܡܩܡ ܀",
      "paragraphStart": false
    }
  ]
}
