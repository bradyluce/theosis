{
  "chapter": {
    "id": "peshitta:revelation.10",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 10,
    "referenceLabel": "Revelation 10",
    "summary": "Source text for Revelation 10 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.10.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Revelation 10:1",
      "text": "ܘܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܕܢܚܬ ܡܢ ܫܡܝܐ ܘܡܥܛܦ ܥܢܢܐ ܘܩܫܬܐ ܕܫܡܝܐ ܥܠ ܪܫܗ ܘܚܙܘܗ ܐܝܟ ܫܡܫܐ ܘܪܓܠܘܗܝ ܐܝܟ ܥܡܘܕܐ ܕܢܘܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.10.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Revelation 10:2",
      "text": "ܘܐܝܬ ܠܗ ܒܐܝܕܗ ܟܬܒܘܢܐ ܦܬܝܚܐ ܘܤܡ ܪܓܠܗ ܕܝܡܝܢܐ ܥܠ ܝܡܐ ܕܤܡܠܐ ܕܝܢ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Revelation 10:3",
      "text": "ܘܩܥܐ ܒܩܠܐ ܪܡܐ ܐܝܟ ܐܪܝܐ ܕܓܤܪ ܘܟܕ ܩܥܐ ܡܠܠܘ ܫܒܥܐ ܪܥܡܝܢ ܒܩܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Revelation 10:4",
      "text": "ܘܟܕ ܡܠܠܘ ܫܒܥܐ ܪܥܡܝܢ ܡܛܝܒ ܗܘܝܬ ܠܡܟܬܒ ܘܫܡܥܬ ܩܠܐ ܡܢ ܫܡܝܐ ܕܫܒܥܐ ܕܐܡܪ ܚܬܘܡ ܗܘ ܡܐ ܕܡܠܠܘ ܫܒܥܐ ܪܥܡܝܢ ܘܠܐ ܬܟܬܒܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Revelation 10:5",
      "text": "ܘܡܠܐܟܐ ܗܘ ܕܚܙܝܬ ܕܩܐܡ ܥܠ ܝܡܐ ܘܥܠ ܝܒܫܐ ܕܐܪܝܡ ܐܝܕܗ ܠܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Revelation 10:6",
      "text": "ܘܝܡܐ ܒܗܘ ܕܚܝ ܠܥܠܡ ܥܠܡܝܢ ܗܘ ܕܒܪܗ ܠܫܡܝܐ ܘܕܒܗ ܘܠܐܪܥܐ ܘܕܒܗ ܕܬܘܒ ܙܒܢܐ ܠܐ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Revelation 10:7",
      "text": "ܐܠܐ ܒܝܘܡܬܐ ܕܡܠܐܟܐ ܕܫܒܥܐ ܡܐ ܕܥܬܝܕ ܠܡܙܥܩ ܘܐܫܬܠܡ ܐܪܙܗ ܕܐܠܗܐ ܗܘ ܕܤܒܪ ܠܥܒܕܘܗܝ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Revelation 10:8",
      "text": "ܘܩܠܐ ܫܡܥܬ ܡܢ ܫܡܝܐ ܬܘܒ ܕܡܡܠܠ ܥܡܝ ܘܐܡܪ ܙܠ ܤܒ ܠܟܬܒܘܢܐ ܕܒܐܝܕܗ ܕܡܠܐܟܐ ܕܩܐܡ ܥܠ ܐܪܥܐ ܘܥܠ ܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Revelation 10:9",
      "text": "ܘܐܙܠܬ ܠܘܬ ܡܠܐܟܐ ܟܕ ܐܡܪ ܐܢܐ ܠܗ ܠܡܬܠ ܠܝ ܠܟܬܒܘܢܐ ܘܐܡܪ ܠܝ ܤܒ ܘܐܟܘܠܝܗܝ ܘܢܡܪ ܠܟ ܟܪܤܟ ܐܠܐ ܒܦܘܡܟ ܢܗܘܐ ܐܝܟ ܕܒܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Revelation 10:10",
      "text": "ܘܢܤܒܬ ܠܟܬܒܘܢܐ ܡܢ ܐܝܕܗ ܕܡܠܐܟܐ ܘܐܟܠܬܗ ܘܐܝܬ ܗܘܐ ܒܦܘܡܝ ܐܝܟ ܕܒܫܐ ܚܠܝܐ ܘܟܕ ܐܟܠܬܗ ܡܪܬ ܟܪܤܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.10.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Revelation 10:11",
      "text": "ܘܐܡܪ ܠܝ ܝܗܝܒ ܠܟ ܬܘܒ ܙܒܢܐ ܠܡܬܢܒܝܘ ܥܠ ܥܡܡܐ ܘܐܡܘܬܐ ܘܠܫܢܐ ܘܡܠܟܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    }
  ]
}
