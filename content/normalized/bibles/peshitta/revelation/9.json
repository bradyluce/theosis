{
  "chapter": {
    "id": "peshitta:revelation.9",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 9,
    "referenceLabel": "Revelation 9",
    "summary": "Source text for Revelation 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.9.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Revelation 9:1",
      "text": "ܘܕܚܡܫܐ ܙܥܩ ܘܚܙܝܬ ܟܘܟܒܐ ܕܢܦܠ ܡܢ ܫܡܝܐ ܥܠ ܐܪܥܐ ܘܐܬܝܗܒ ܠܗ ܩܠܝܕܐ ܕܒܐܪܘܗܝ ܕܬܗܘܡܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.9.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Revelation 9:2",
      "text": "ܘܤܠܩ ܬܢܢܐ ܡܢ ܒܐܪܐ ܐܝܟ ܬܢܢܐ ܕܐܬܘܢܐ ܪܒܐ ܕܡܫܬܓܪ ܘܚܫܟ ܫܡܫܐ ܘܐܐܪ ܡܢ ܬܢܢܐ ܕܒܐܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Revelation 9:3",
      "text": "ܘܡܢ ܬܢܢܐ ܢܦܩܘ ܩܡܨܐ ܥܠ ܐܪܥܐ ܘܐܬܝܗܒ ܠܗܘܢ ܫܘܠܛܢܐ ܕܐܝܬ ܠܥܩܪܒܐ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Revelation 9:4",
      "text": "ܘܐܬܐܡܪ ܠܗܘܢ ܕܠܐ ܢܗܪܘܢ ܠܥܤܒܗ ܕܐܪܥܐ ܘܠܟܠ ܝܘܪܩ ܐܦܠܐ ܠܐܝܠܢܐ ܐܠܐ ܐܢ ܠܒܢܝܢܫܐ ܐܝܠܝܢ ܕܠܝܬ ܠܗܘܢ ܚܬܡܐ ܕܐܠܗܐ ܒܝܬ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Revelation 9:5",
      "text": "ܘܐܬܝܗܒ ܠܗܘܢ ܕܠܐ ܢܩܛܠܘܢ ܐܢܘܢ ܐܠܐ ܢܫܬܢܩܘܢ ܝܪܚܐ ܚܡܫܐ ܘܬܫܢܝܩܗܘܢ ܐܝܟ ܬܫܢܝܩܐ ܕܥܩܪܒܐ ܡܐ ܕܢܦܠܐ ܥܠ ܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Revelation 9:6",
      "text": "ܘܒܝܘܡܬܐ ܗܢܘܢ ܢܒܥܘܢ ܒܢܝܢܫܐ ܠܡܘܬܐ ܘܠܐ ܢܫܟܚܘܢܝܗܝ ܘܢܬܪܓܪܓܘܢ ܠܡܡܬ ܘܢܥܪܘܩ ܡܘܬܐ ܡܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Revelation 9:7",
      "text": "ܘܕܡܘܬܐ ܕܩܡܨܐ ܐܝܟ ܕܡܘܬܐ ܕܪܟܫܐ ܕܡܛܝܒܝܢ ܠܩܪܒܐ ܘܥܠ ܪܫܝܗܘܢ ܐܝܟ ܟܠܝܠܐ ܕܕܡܘܬܐ ܕܕܗܒܐ ܘܐܦܝܗܘܢ ܐܝܟ ܐܦܐ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Revelation 9:8",
      "text": "ܘܤܥܪܐ ܐܝܬ ܠܗܘܢ ܐܝܟ ܤܥܪܐ ܕܢܫܐ ܘܫܢܝܗܘܢ ܐܝܟ ܕܐܪܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Revelation 9:9",
      "text": "ܘܐܝܬ ܗܘܐ ܠܗܘܢ ܫܪܝܢܐ ܐܝܟ ܫܪܝܢܐ ܕܦܪܙܠܐ ܘܩܠܐ ܕܓܦܝܗܘܢ ܐܝܟ ܩܠܐ ܕܡܪܟܒܬܐ ܕܪܟܫܐ ܤܓܝܐܐ ܕܪܗܛܝܢ ܠܩܪܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Revelation 9:10",
      "text": "ܘܐܝܬ ܠܗܘܢ ܕܘܢܒܝܬܐ ܐܝܟ ܕܡܘܬܐ ܕܥܩܪܒܐ ܘܥܘܩܤܐ ܕܝܢ ܒܕܘܢܒܝܬܗܘܢ ܘܫܘܠܛܢܗܘܢ ܠܡܗܪܘ ܠܒܢܝܢܫܐ ܝܪܚܐ ܚܡܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Revelation 9:11",
      "text": "ܘܐܝܬ ܥܠܝܗܘܢ ܡܠܟܐ ܡܠܐܟܗ ܕܬܗܘܡܐ ܕܫܡܗ ܥܒܪܐܝܬ ܥܒܕܘ ܘܐܪܡܐܝܬ ܫܡܐ ܠܗ ܐܝܬ ܫܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Revelation 9:12",
      "text": "ܘܝ ܚܕ ܐܙܠ ܗܐ ܬܘܒ ܐܬܝܢ ܬܪܝܢ ܘܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Revelation 9:13",
      "text": "ܒܬܪ ܗܠܝܢ ܡܠܐܟܐ ܕܫܬܐ ܙܥܩ ܘܫܡܥܬ ܩܠܐ ܚܕ ܡܢ ܐܪܒܥ ܩܪܢܬܗ ܕܡܕܒܚܐ ܕܕܗܒܐ ܕܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Revelation 9:14",
      "text": "ܕܐܡܪ ܠܡܠܐܟܐ ܫܬܝܬܝܐ ܕܐܝܬ ܠܗ ܫܝܦܘܪܐ ܫܪܝ ܠܐܪܒܥܐ ܡܠܐܟܐ ܕܐܤܝܪܝܢ ܥܠ ܢܗܪܐ ܪܒܐ ܦܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Revelation 9:15",
      "text": "ܘܐܫܬܪܝܘ ܐܪܒܥܐ ܡܠܐܟܝܢ ܐܝܠܝܢ ܕܡܛܝܒܝܢ ܠܫܥܬܐ ܘܠܝܘܡܐ ܘܠܝܪܚܐ ܘܠܫܢܬܐ ܕܢܩܛܠܘܢ ܬܘܠܬܐ ܕܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Revelation 9:16",
      "text": "ܘܡܢܝܢܐ ܕܚܝܠܘܬܐ ܕܦܪܫܐ ܬܪܬܝܢ ܪܒܘ ܪܒܘܢ ܫܡܥܬ ܡܢܝܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Revelation 9:17",
      "text": "ܘܗܟܢܐ ܚܙܝܬ ܪܟܫܐ ܒܚܙܘܐ ܘܠܕܝܬܒܝܢ ܥܠܝܗܘܢ ܐܝܬ ܫܪܝܢܐ ܕܢܘܪܐ ܘܩܪܟܕܢܐ ܕܟܒܪܝܬܐ ܘܩܪܩܦܬܐ ܕܪܟܫܗܘܢ ܐܝܟ ܩܪܩܦܬܐ ܕܐܪܝܘܬܐ ܘܡܢ ܦܘܡܗܘܢ ܢܦܩܐ ܢܘܪܐ ܘܟܒܪܝܬܐ ܘܬܢܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Revelation 9:18",
      "text": "ܘܡܢ ܗܠܝܢ ܬܠܬ ܡܚܘܢ ܐܬܩܛܠܘ ܬܘܠܬܐ ܕܒܢܝܢܫܐ ܘܡܢ ܢܘܪܐ ܘܡܢ ܟܒܪܝܬܐ ܘܡܢ ܬܢܢܐ ܕܢܦܩ ܡܢ ܦܘܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Revelation 9:19",
      "text": "ܡܛܠ ܕܫܘܠܛܢܐ ܕܪܟܫܐ ܒܦܘܡܗܘܢ ܘܐܦ ܒܕܘܢܒܝܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Revelation 9:20",
      "text": "ܘܫܪܟܐ ܕܒܢܝܢܫܐ ܕܠܐ ܐܬܩܛܠܘ ܒܡܚܘܬܐ ܗܠܝܢ ܘܠܐ ܬܒܘ ܡܢ ܥܒܕ ܐܝܕܝܗܘܢ ܕܠܐ ܢܤܓܕܘܢ ܠܕܝܘܐ ܘܠܦܬܟܪܐ ܕܕܗܒܐ ܘܕܤܐܡܐ ܘܕܢܚܫܐ ܘܕܩܝܤܐ ܘܕܟܐܦܐ ܐܝܠܝܢ ܕܠܐ ܠܡܚܙܐ ܘܠܐ ܠܡܫܡܥ ܡܨܝܢ ܐܘ ܠܡܗܠܟܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.9.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Revelation 9:21",
      "text": "ܘܠܐ ܬܒܘ ܡܢ ܩܛܠܝܗܘܢ ܘܡܢ ܚܪܫܝܗܘܢ ܘܡܢ ܙܢܝܘܬܗܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
