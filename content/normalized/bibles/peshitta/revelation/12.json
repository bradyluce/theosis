{
  "chapter": {
    "id": "peshitta:revelation.12",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 12,
    "referenceLabel": "Revelation 12",
    "summary": "Source text for Revelation 12 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.12.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Revelation 12:1",
      "text": "ܘܐܬܐ ܪܒܬܐ ܐܬܚܙܝܬ ܒܫܡܝܐ ܐܢܬܬܐ ܕܥܛܝܦܐ ܫܡܫܐ ܘܤܗܪܐ ܬܚܝܬ ܪܓܠܝܗ ܘܟܠܝܠܐ ܕܟܘܟܒܐ ܬܪܥܤܪ ܥܠ ܪܫܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.12.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Revelation 12:2",
      "text": "ܘܒܛܢܐ ܘܩܥܝܐ ܘܡܚܒܠܢ ܐܦ ܡܫܬܢܩܐ ܕܬܐܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Revelation 12:3",
      "text": "ܘܐܬܚܙܝܬ ܐܬܐ ܐܚܪܬܐ ܒܫܡܝܐ ܘܗܐ ܬܢܝܢܐ ܪܒܐ ܕܢܘܪܐ ܕܐܝܬ ܠܗ ܫܒܥܐ ܪܫܝܢ ܘܥܤܪ ܩܪܢܬܐ ܘܥܠ ܪܫܘܗܝ ܫܒܥܐ ܬܐܓܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Revelation 12:4",
      "text": "ܘܕܘܢܒܗ ܓܪܫܐ ܠܬܘܠܬܐ ܕܟܘܟܒܐ ܕܒܫܡܝܐ ܘܐܪܡܝ ܐܢܘܢ ܥܠ ܐܪܥܐ ܘܬܢܝܢܐ ܩܐܡ ܗܘܐ ܩܕܡ ܐܢܬܬܐ ܕܥܬܝܕܐ ܕܬܐܠܕ ܕܡܐ ܕܝܠܕܬ ܢܐܟܠܝܘܗܝ ܠܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Revelation 12:5",
      "text": "ܘܝܠܕܬ ܒܪܐ ܕܟܪܐ ܗܘ ܕܥܬܝܕ ܠܡܪܥܐ ܠܟܠܗܘܢ ܥܡܡܐ ܒܫܒܛܐ ܕܦܪܙܠܐ ܘܐܬܚܛܦ ܒܪܗ ܠܘܬ ܐܠܗܐ ܘܠܘܬ ܟܘܪܤܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Revelation 12:6",
      "text": "ܘܐܢܬܬܐ ܥܪܩܬ ܠܚܘܪܒܐ ܐܬܪ ܕܐܝܬ ܗܘܐ ܠܗ ܬܡܢ ܕܘܟܬܐ ܕܡܛܝܒܐ ܡܢ ܐܠܗܐ ܕܢܬܪܤܘܢܗ ܝܘܡܝܢ ܐܠܦ ܘܡܐܬܝܢ ܘܫܬܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Revelation 12:7",
      "text": "ܘܗܘܐ ܩܪܒܐ ܒܫܡܝܐ ܡܝܟܐܝܠ ܘܡܠܐܟܘܗܝ ܡܩܪܒܝܢ ܥܡ ܬܢܝܢܐ ܘܬܢܝܢܐ ܘܡܠܐܟܘܗܝ ܐܩܪܒܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Revelation 12:8",
      "text": "ܘܠܐ ܐܬܡܨܝܘ ܘܠܐ ܐܬܪܐ ܐܫܬܟܚ ܠܗܘܢ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Revelation 12:9",
      "text": "ܘܐܬܪܡܝ ܬܢܝܢܐ ܪܒܐ ܗܘ ܚܘܝܐ ܪܫܐ ܗܘ ܕܡܬܩܪܐ ܐܟܠܩܪܨܐ ܘܤܛܢܐ ܗܘ ܕܐܛܥܝ ܠܟܠܗ ܐܪܥܐ ܘܐܬܪܡܝ ܥܠ ܐܪܥܐ ܘܡܠܐܟܘܗܝ ܥܡܗ ܐܬܪܡܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Revelation 12:10",
      "text": "ܘܫܡܥܬ ܩܠܐ ܪܒܐ ܡܢ ܫܡܝܐ ܕܐܡܪ ܗܐ ܗܘܐ ܫܘܘܙܒܐ ܘܚܝܠܐ ܘܡܠܟܘܬܐ ܕܐܠܗܢ ܕܐܬܪܡܝ ܡܤܘܪܐ ܕܐܚܝܢ ܗܘ ܕܡܤܪ ܗܘܐ ܠܗܘܢ ܠܠܝܐ ܘܐܝܡܡܐ ܩܕܡ ܐܠܗܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Revelation 12:11",
      "text": "ܘܗܢܘܢ ܙܟܘ ܒܕܡܐ ܕܐܡܪܐ ܘܒܝܕ ܡܠܬܐ ܕܤܗܕܘܬܗ ܘܠܐ ܐܚܒܘ ܢܦܫܗܘܢ ܥܕܡܐ ܠܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Revelation 12:12",
      "text": "ܡܛܠܗܢܐ ܫܡܝܐ ܐܬܦܨܚܘ ܘܐܝܠܝܢ ܕܒܗܘܢ ܫܪܝܢ ܘܝ ܠܐܪܥܐ ܘܠܝܡܐ ܥܠ ܕܢܚܬ ܐܟܠܩܪܨܐ ܠܘܬܗܘܢ ܕܐܝܬ ܠܗ ܚܡܬܐ ܪܒܬܐ ܟܕ ܝܕܥ ܕܩܠܝܠ ܙܒܢܐ ܐܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Revelation 12:13",
      "text": "ܘܟܕ ܚܙܐ ܬܢܝܢܐ ܕܐܬܪܡܝ ܥܠ ܐܪܥܐ ܪܕܦ ܠܐܢܬܬܐ ܐܝܕܐ ܕܝܠܕܬ ܕܟܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Revelation 12:14",
      "text": "ܘܐܬܝܗܒ ܠܐܢܬܬܐ ܬܪܝܢ ܓܦܝܢ ܕܢܫܪܐ ܪܒܐ ܕܬܦܪܚܝ ܠܚܘܪܒܐ ܠܕܘܟܬܗ ܠܡܬܬܪܤܝܘ ܬܡܢ ܥܕܢ ܥܕܢܝܢ ܘܦܠܓܘܬ ܥܕܢ ܡܢ ܩܕܡ ܐܦܘܗܝ ܕܚܘܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Revelation 12:15",
      "text": "ܘܐܪܡܝ ܚܘܝܐ ܡܢ ܦܘܡܗ ܒܬܪ ܐܢܬܬܐ ܡܝܐ ܐܝܟ ܢܗܪܐ ܕܫܩܝܠܬ ܡܝܐ ܢܥܒܕܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Revelation 12:16",
      "text": "ܘܥܕܪܬ ܐܪܥܐ ܠܐܢܬܬܐ ܘܦܬܚܬ ܐܪܥܐ ܦܘܡܗ ܘܒܠܥܬܗ ܠܢܗܪܐ ܗܘ ܕܐܪܡܝ ܬܢܝܢܐ ܡܢ ܦܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.12.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Revelation 12:17",
      "text": "ܘܪܓܙ ܬܢܝܢܐ ܥܠ ܐܢܬܬܐ ܘܐܙܠ ܠܡܥܒܕ ܩܪܒܐ ܥܡ ܫܪܟܐ ܕܙܪܥܗ ܗܠܝܢ ܕܢܛܪܝܢ ܦܘܩܕܢܘܗܝ ܕܐܠܗܐ ܘܐܝܬ ܠܗܘܢ ܤܗܕܘܬܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    }
  ]
}
