{
  "chapter": {
    "id": "peshitta:revelation.21",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 21,
    "referenceLabel": "Revelation 21",
    "summary": "Source text for Revelation 21 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.21.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 1,
      "referenceLabel": "Revelation 21:1",
      "text": "ܘܚܙܝܬ ܫܡܝܐ ܚܕܬܬܐ ܘܐܪܥܐ ܚܕܬܐ ܫܡܝܐ ܓܝܪ ܩܕܡܝܬܐ ܘܐܪܥܐ ܩܕܡܝܬܐ ܐܙܠܘ ܘܝܡܐ ܠܝܬܘܗܝ ܬܘܒ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.21.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 2,
      "referenceLabel": "Revelation 21:2",
      "text": "ܘܠܡܕܝܢܬܐ ܩܕܝܫܬܐ ܐܘܪܫܠܡ ܚܕܬܐ ܚܙܝܬܗ ܕܢܚܬܐ ܡܢ ܫܡܝܐ ܡܢ ܨܝܕ ܐܠܗܐ ܕܡܛܝܒܐ ܐܝܟ ܟܠܬܐ ܡܨܒܬܬܐ ܠܒܥܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 3,
      "referenceLabel": "Revelation 21:3",
      "text": "ܘܫܡܥܬ ܩܠܐ ܪܒܐ ܡܢ ܫܡܝܐ ܕܐܡܪ ܗܐ ܡܫܪܝܐ ܕܐܠܗܐ ܥܡ ܒܢܝܢܫܐ ܘܫܪܐ ܥܡܗܘܢ ܘܗܢܘܢ ܥܡܐ ܕܝܠܗ ܢܗܘܘܢ ܘܗܘ ܐܠܗܐ ܥܡܗܘܢ ܘܢܗܘܐ ܠܗܘܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 4,
      "referenceLabel": "Revelation 21:4",
      "text": "ܘܗܘ ܢܠܚܐ ܟܠ ܕܡܥܐ ܡܢ ܥܝܢܝܗܘܢ ܘܡܘܬܐ ܠܐ ܢܗܘܐ ܡܟܝܠ ܘܠܐ ܐܒܠܐ ܘܠܐ ܪܘܒܐ ܘܠܐ ܟܐܒܐ ܬܘܒ ܢܗܘܐ ܥܠ ܐܦܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 5,
      "referenceLabel": "Revelation 21:5",
      "text": "ܘܐܙܠܬ ܘܐܡܪ ܠܝ ܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܗܐ ܚܕܬܐ ܥܒܕ ܐܢܐ ܟܠ ܘܐܡܪ ܠܝ ܟܬܘܒ ܗܠܝܢ ܡܠܐ ܡܗܝܡܢܬܐ ܘܫܪܝܪܬܐ ܐܝܬܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 6,
      "referenceLabel": "Revelation 21:6",
      "text": "ܘܐܡܪ ܠܝ ܗܘܝ ܐܢܐ ܐܠܦ ܘܐܢܐ ܬܘ ܪܝܫܝܬܐ ܘܫܘܠܡܐ ܠܕܨܗܐ ܐܢܐ ܐܬܠ ܡܢ ܥܝܢܐ ܕܡܝܐ ܚܝܐ ܡܓܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 7,
      "referenceLabel": "Revelation 21:7",
      "text": "ܘܕܙܟܐ ܗܘ ܢܐܪܬ ܗܠܝܢ ܘܐܗܘܐ ܠܗ ܐܠܗܐ ܘܢܗܘܐ ܠܝ ܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 8,
      "referenceLabel": "Revelation 21:8",
      "text": "ܠܩܢܘܛܬܢܐ ܕܝܢ ܘܠܐ ܡܗܝܡܢܐ ܘܥܘܠܐ ܘܡܤܝܒܐ ܘܩܛܘܠܐ ܘܚܪܫܐ ܘܙܢܝܐ ܘܦܠܚܝ ܦܬܟܪܐ ܘܟܠܗܘܢ ܕܓܠܐ ܡܢܬܗܘܢ ܒܝܡܬܐ ܝܩܕܬܐ ܕܢܘܪܐ ܘܟܒܪܝܬܐ ܐܝܕܐ ܕܐܝܬܝܗ ܡܘܬܐ ܬܢܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 9,
      "referenceLabel": "Revelation 21:9",
      "text": "ܘܐܬܐ ܚܕ ܡܢ ܫܒܥܐ ܡܠܐܟܝܢ ܐܝܠܝܢ ܕܐܝܬ ܥܠܝܗܘܢ ܫܒܥ ܙܒܘܪܝܢ ܕܡܠܝܢ ܫܒܥ ܡܚܘܬܐ ܐܚܪܝܬܐ ܘܡܠܠ ܥܡܝ ܠܡܐܡܪ ܬܐ ܐܚܘܝܟ ܠܟܠܬܐ ܐܢܬܬܗ ܕܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 10,
      "referenceLabel": "Revelation 21:10",
      "text": "ܘܐܘܒܠܢܝ ܒܪܘܚ ܠܛܘܪܐ ܪܒܐ ܘܪܡܐ ܘܚܘܝܢܝ ܠܡܕܝܢܬܐ ܩܕܝܫܬܐ ܐܘܪܫܠܡ ܕܢܚܬܐ ܡܢ ܫܡܝܐ ܡܢ ܨܝܕ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 11,
      "referenceLabel": "Revelation 21:11",
      "text": "ܘܐܝܬ ܠܗ ܬܫܒܘܚܬܐ ܕܐܠܗܐ ܘܢܘܗܪܗ ܐܝܟ ܕܡܘܬܐ ܕܟܐܦܐ ܝܩܝܪܬܐ ܐܝܟ ܝܫܦܗ ܐܝܟ ܕܘܡܝܐ ܕܩܪܘܤܛܠܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 12,
      "referenceLabel": "Revelation 21:12",
      "text": "ܘܐܝܬ ܠܗ ܫܘܪܐ ܪܒܐ ܘܪܡܐ ܘܐܝܬ ܠܗ ܬܪܥܐ ܬܪܥܤܪ ܘܥܠ ܬܪܥܐ ܡܠܐܟܐ ܬܪܥܤܪ ܘܫܡܗܝܗܘܢ ܟܬܝܒܐ ܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܫܡܗܐ ܕܬܪܥܤܪ ܫܒܛܐ ܕܐܝܤܪܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 13,
      "referenceLabel": "Revelation 21:13",
      "text": "ܡܢ ܡܕܢܚܐ ܬܪܥܐ ܬܠܬܐ ܘܡܢ ܓܪܒܝܐ ܬܪܥܐ ܬܠܬܐ ܘܡܢ ܬܝܡܢܐ ܬܪܥܐ ܬܠܬܐ ܘܡܢ ܡܥܪܒܐ ܬܪܥܐ ܬܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 14,
      "referenceLabel": "Revelation 21:14",
      "text": "ܘܫܘܪܐ ܕܡܕܝܢܬܐ ܐܝܬ ܠܗ ܫܬܐܤܐ ܬܪܬܥܤܪܐ ܘܥܠܝܗܝܢ ܬܪܥܤܪ ܫܡܗܐ ܕܫܠܝܚܘܗܝ ܕܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 15,
      "referenceLabel": "Revelation 21:15",
      "text": "ܘܗܘ ܕܡܡܠܠ ܗܘܐ ܥܡܝ ܐܝܬ ܗܘܐ ܥܠܘܗܝ ܩܢܝܐ ܕܡܫܘܚܬܐ ܕܕܗܒܐ ܠܡܡܫܚܗ ܠܡܕܝܢܬܐ ܘܠܫܘܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 16,
      "referenceLabel": "Revelation 21:16",
      "text": "ܘܡܕܝܢܬܐ ܡܪܒܥܐܝܬ ܤܝܡܐ ܘܐܘܪܟܗ ܐܝܟ ܦܬܝܗ ܘܡܫܚܗ ܠܡܕܝܢܬܐ ܒܩܢܝܐ ܥܠ ܬܪܥܤܪ ܐܠܦܝܢ ܐܤܛܕܘܬܐ ܐܘܪܟܗ ܘܦܬܝܗ ܘܪܘܡܗ ܫܘܝܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 17,
      "referenceLabel": "Revelation 21:17",
      "text": "ܘܡܫܚܗ ܠܫܘܪܗ ܡܐܐ ܘܐܪܒܥܝܢ ܘܐܪܒܥ ܐܡܝܢ ܒܡܫܘܚܬܐ ܕܐܢܫܐ ܐܝܕܐ ܕܐܝܬܝܗ ܕܡܠܐܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 18,
      "referenceLabel": "Revelation 21:18",
      "text": "ܘܕܘܡܤܐ ܕܫܘܪܗ ܝܫܦܗ ܘܡܕܝܢܬܐ ܕܕܗܒܐ ܕܟܝܐ ܒܕܡܘܬܐ ܕܙܓܘܓܝܬܐ ܕܟܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 19,
      "referenceLabel": "Revelation 21:19",
      "text": "ܘܫܬܐܤܐ ܕܫܘܪܐ ܕܡܕܝܢܬܐ ܒܟܐܦܐ ܝܩܝܪܬܐ ܡܨܒܬܢ ܘܫܬܐܤܬܐ ܩܕܡܝܬܐ ܝܫܦܗ ܘܕܬܪܬܝܢ ܤܦܝܠܐ ܘܕܬܠܬ ܩܪܟܕܢܐ ܘܕܐܪܒܥ ܙܡܪܓܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 20,
      "referenceLabel": "Revelation 21:20",
      "text": "ܘܕܚܡܫ ܤܪܕܘܢ ܘܛܦܪܐ ܘܕܫܬ ܤܪܕܘܢ ܘܕܫܒܥ ܟܐܦ ܕܗܒܐ ܘܕܬܡܢܐ ܒܪܘܠܐ ܘܕܬܫܥ ܛܘܦܢܕܝܘܢ ܘܕܥܤܪ ܟܪܘܤܦܪܤܐ ܕܚܕܥܤܪܐ ܝܘܟܢܬܘܤ ܕܬܪܬܥܤܪܐ ܐܡܘܬܤܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 21,
      "referenceLabel": "Revelation 21:21",
      "text": "ܘܬܪܥܤܪ ܬܪܥܐ ܘܬܪܬܥܤܪܐ ܡܪܓܢܝܬܐ ܚܕܐ ܠܚܕܐ ܘܟܠܚܕ ܡܢ ܬܪܥܐ ܐܝܬ ܗܘܐ ܡܢ ܚܕܐ ܡܪܓܢܝܬܐ ܘܫܘܩܐ ܕܝܢ ܕܡܕܝܢܬܐ ܕܕܗܒܐ ܕܟܝܐ ܐܝܟ ܙܓܘܓܝܬܐ ܐܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.22",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 22,
      "referenceLabel": "Revelation 21:22",
      "text": "ܘܗܝܟܠܐ ܠܐ ܚܙܝܬ ܒܗ ܡܪܝܐ ܓܝܪ ܐܠܗܐ ܐܚܝܕ ܟܠ ܗܘ ܐܝܬܘܗܝ ܗܝܟܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.23",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 23,
      "referenceLabel": "Revelation 21:23",
      "text": "ܘܠܐܡܪܐ ܘܠܡܕܝܢܬܐ ܠܐ ܡܬܒܥܐ ܫܡܫܐ ܘܠܐ ܤܗܪܐ ܕܢܢܗܪܘܢ ܠܗ ܬܫܒܘܚܬܗ ܓܝܪ ܕܐܠܗܐ ܐܢܗܪܬܗ ܘܫܪܓܗ ܐܝܬܘܗܝ ܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.24",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 24,
      "referenceLabel": "Revelation 21:24",
      "text": "ܘܡܗܠܟܝܢ ܥܡܡܐ ܒܢܘܗܪܗ ܘܡܠܟܐ ܕܐܪܥܐ ܡܝܬܝܢ ܠܗ ܬܫܒܘܚܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.25",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 25,
      "referenceLabel": "Revelation 21:25",
      "text": "ܘܬܪܥܝܗ ܠܐ ܢܬܬܚܕܘܢ ܒܐܝܡܡܐ ܠܠܝܐ ܓܝܪ ܠܐ ܢܗܘܐ ܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.26",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 26,
      "referenceLabel": "Revelation 21:26",
      "text": "ܘܢܝܬܘܢ ܠܗ ܬܫܒܘܚܬܐ ܘܐܝܩܪܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.21.27",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 21,
      "verseNumber": 27,
      "referenceLabel": "Revelation 21:27",
      "text": "ܘܠܐ ܢܗܘܐ ܬܡܢ ܟܠ ܛܡܐ ܘܕܥܒܕ ܡܤܝܒܘܬܐ ܘܕܓܠܘܬܐ ܐܠܐ ܐܢ ܐܝܠܝܢ ܕܟܬܝܒܢ ܒܟܬܒܗ ܕܐܡܪܐ ܀",
      "paragraphStart": false
    }
  ]
}
