{
  "chapter": {
    "id": "peshitta:revelation.2",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 2,
    "referenceLabel": "Revelation 2",
    "summary": "Source text for Revelation 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.2.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Revelation 2:1",
      "text": "ܘܠܡܠܐܟܐ ܕܒܥܕܬܐ ܕܐܦܤܘܤ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܗܘ ܕܐܚܝܕ ܫܒܥܐ ܟܘܟܒܝܢ ܒܐܝܕܗ ܗܘ ܕܡܗܠܟ ܒܝܢܬ ܡܢܪܬܐ ܕܕܗܒܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.2.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Revelation 2:2",
      "text": "ܝܕܥ ܐܢܐ ܥܒܕܝܟ ܘܥܡܠܟ ܘܡܤܝܒܪܢܘܬܟ ܘܕܠܐ ܡܨܝܬ ܠܡܛܥܢ ܠܒܝܫܐ ܘܢܤܝܬ ܠܐܝܠܝܢ ܕܐܡܪܝܢ ܢܦܫܗܘܢ ܕܫܠܝܚܐ ܐܝܬܝܗܘܢ ܘܠܝܬܝܗܘܢ ܘܐܫܟܚܬ ܐܢܘܢ ܕܓܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Revelation 2:3",
      "text": "ܘܡܤܝܒܪܢܘܬܐ ܐܝܬ ܠܟ ܘܛܥܢܬ ܡܛܠ ܫܡܝ ܘܠܐ ܠܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Revelation 2:4",
      "text": "ܐܠܐ ܐܝܬ ܠܝ ܥܠܝܟ ܕܚܘܒܟ ܩܕܡܝܐ ܫܒܩܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Revelation 2:5",
      "text": "ܐܬܕܟܪ ܡܢ ܐܝܟܐ ܢܦܩܬ ܘܥܒܕ ܥܒܕܐ ܩܕܡܝܐ ܘܐܢܕܝܢ ܠܐ ܐܬܐ ܐܢܐ ܥܠܝܟ ܘܡܙܝܥ ܐܢܐ ܡܢܪܬܟ ܐܠܐ ܬܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Revelation 2:6",
      "text": "ܐܠܐ ܗܕܐ ܐܝܬ ܠܟ ܕܤܢܝܬ ܥܒܕܐ ܕܢܐܩܘܠܝܛܐ ܐܝܠܝܢ ܕܐܢܐ ܤܢܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Revelation 2:7",
      "text": "ܗܘ ܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܘܠܕܙܟܐ ܐܬܠ ܡܢ ܩܝܤܐ ܕܚܝܐ ܠܡܐܟܠ ܗܘ ܕܐܝܬܘܗܝ ܒܦܪܕܝܤܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Revelation 2:8",
      "text": "ܘܠܡܠܐܟܐ ܕܥܕܬܐ ܕܙܡܘܪܢܐ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܩܕܡܝܐ ܘܐܚܪܝܐ ܗܘ ܕܗܘܐ ܡܝܬܐ ܘܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Revelation 2:9",
      "text": "ܝܕܥ ܐܢܐ ܐܘܠܨܢܟ ܘܡܤܟܢܘܬܟ ܐܠܐ ܥܬܝܪܐ ܐܢܬ ܘܠܓܘܕܦܐ ܕܡܢ ܐܝܠܝܢ ܕܐܡܪܝܢ ܢܦܫܗܘܢ ܝܗܘܕܝܐ ܝܗܘܕܝܐ ܟܕ ܠܐ ܐܝܬܝܗܘܢ ܐܠܐ ܟܢܘܫܬܐ ܕܤܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Revelation 2:10",
      "text": "ܒܡܕܡ ܠܐ ܬܕܚܠ ܡܢ ܐܝܠܝܢ ܕܥܬܝܕ ܐܢܬ ܠܡܚܫ ܗܐ ܥܬܝܕ ܐܟܠܩܪܨܐ ܕܢܪܡܐ ܡܢܟܘܢ ܒܒܝܬ ܚܒܘܫܝܐ ܕܬܬܢܤܘܢ ܘܢܗܘܐ ܠܟܘܢ ܐܘܠܨܢܐ ܝܘܡܝܢ ܥܤܪܐ ܗܘܘ ܡܗܝܡܢܐ ܥܕܡܐ ܠܡܘܬܐ ܘܐܬܠ ܠܟܘܢ ܟܠܝܠܐ ܕܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Revelation 2:11",
      "text": "ܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܕܐܝܢܐ ܕܙܟܐ ܠܐ ܢܗܪ ܡܢ ܡܘܬܐ ܬܢܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Revelation 2:12",
      "text": "ܘܠܡܠܐܟܐ ܕܒܥܕܬܐ ܕܦܪܓܡܐ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܗܘ ܕܐܝܬ ܠܗ ܚܪܒܐ ܚܪܝܦܬܐ ܕܬܪܝܢ ܦܘܡܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Revelation 2:13",
      "text": "ܝܕܥ ܐܢܐ ܐܝܟܐ ܥܡܪܬ ܐܬܪ ܕܟܘܪܤܝܗ ܕܤܛܢܐ ܘܐܚܝܕ ܐܢܬ ܒܫܡܝ ܘܒܗܝܡܢܘܬܝ ܠܐ ܟܦܪܬ ܘܒܝܘܡܬܐ ܐܬܚܪܝܬ ܘܤܗܕܐ ܕܝܠܝ ܡܗܝܡܢܐ ܡܛܠ ܕܟܠ ܤܗܕܐ ܕܝܠܝ ܡܗܝܡܢܐ ܐܝܢܐ ܕܡܢܟܘܢ ܐܬܩܛܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Revelation 2:14",
      "text": "ܐܠܐ ܐܝܬ ܠܝ ܥܠܝܟ ܙܥܘܪܝܬܐ ܕܐܝܬ ܠܟ ܬܡܢ ܕܐܚܝܕܝܢ ܡܠܦܢܘܬܐ ܕܒܠܥܡ ܗܘ ܕܐܠܦ ܠܒܠܩ ܕܢܪܡܐ ܟܫܠܐ ܩܕܡ ܒܢܝ ܐܝܤܪܝܠ ܠܡܐܟܠ ܕܒܚܝ ܦܬܟܪܐ ܘܠܡܙܢܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Revelation 2:15",
      "text": "ܗܟܢܐ ܐܝܬ ܐܦ ܠܟ ܕܐܚܝܕܝܢ ܝܘܠܦܢܐ ܕܢܐܩܘܠܝܛܐ ܗܟܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Revelation 2:16",
      "text": "ܬܘܒ ܗܟܝܠ ܘܐܢܕܝܢ ܠܐ ܐܬܐ ܐܢܐ ܥܠܝܟ ܡܚܕܐ ܘܐܩܪܒ ܥܡܗܘܢ ܒܚܪܒܐ ܕܦܘܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Revelation 2:17",
      "text": "ܘܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܕܠܕܙܟܐ ܐܬܠ ܡܢ ܡܢܢܐ ܗܘ ܕܡܛܫܝ ܘܐܬܠ ܠܗ ܚܘܫܒܢܐ ܚܘܪܐ ܘܥܠ ܚܘܫܒܢܐ ܫܡܐ ܚܕܬܐ ܕܟܬܒܐ ܕܠܐ ܐܢܫ ܝܕܥ ܐܠܐ ܗܘ ܕܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Revelation 2:18",
      "text": "ܘܠܡܠܐܟܐ ܕܒܥܕܬܐ ܕܒܬܐܘܛܝܪܐ ܟܬܘܒ ܗܟܢܐ ܐܡܪ ܒܪܗ ܕܐܠܗܐ ܗܘ ܕܐܝܬ ܠܗ ܥܝܢܐ ܐܝܟ ܫܠܗܒܝܬܐ ܕܢܘܪܐ ܘܪܓܠܘܗܝ ܐܝܟ ܢܚܫܐ ܠܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Revelation 2:19",
      "text": "ܝܕܥ ܐܢܐ ܥܒܕܝܟ ܘܚܘܒܟ ܘܗܝܡܢܘܬܟ ܘܬܫܡܫܬܟ ܘܡܤܝܒܪܢܘܬܟ ܘܥܒܕܝܟ ܐܚܪܝܐ ܤܓܝܐܐ ܐܢܘܢ ܡܢ ܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Revelation 2:20",
      "text": "ܐܠܐ ܐܝܬ ܠܝ ܥܠܝܟ ܤܓܝ ܕܫܒܩܬ ܠܐܢܬܬܟ ܐܝܙܒܠ ܗܝ ܕܐܡܪܐ ܥܠ ܢܦܫܗ ܕܢܒܝܬܐ ܗܝ ܘܡܠܦܐ ܘܡܛܥܝܐ ܠܥܒܕܝ ܠܡܙܢܝܘ ܘܡܐܟܠ ܕܒܚܝ ܦܬܟܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Revelation 2:21",
      "text": "ܘܝܗܒܬ ܠܗ ܙܒܢܐ ܠܬܝܒܘܬܐ ܘܠܐ ܨܒܝܐ ܠܡܬܒ ܡܢ ܙܢܝܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.22",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Revelation 2:22",
      "text": "ܗܐ ܪܡܐ ܐܢܐ ܠܗ ܒܥܪܤܐ ܘܠܐܝܠܝܢ ܕܓܝܪܝܢ ܥܡܗ ܒܐܘܠܨܢܐ ܪܒܐ ܐܠܐ ܢܬܬܘܘܢ ܡܢ ܥܒܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.23",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Revelation 2:23",
      "text": "ܘܠܒܢܝܗ ܐܩܛܘܠ ܒܡܘܬܐ ܘܝܕܥܢ ܟܠܗܝܢ ܥܕܬܐ ܕܐܢܐ ܐܢܐ ܒܨܐ ܟܘܠܝܬܐ ܘܠܒܐ ܘܐܬܠ ܠܟܘܢ ܠܟܠܢܫ ܐܝܟ ܥܒܕܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.24",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Revelation 2:24",
      "text": "ܠܟܘܢ ܐܡܪ ܐܢܐ ܠܫܪܟܐ ܕܒܬܐܘܛܝܪܐ ܟܠܗܘܢ ܐܝܠܝܢ ܕܠܝܬ ܠܗܘܢ ܝܘܠܦܢܐ ܗܢܐ ܐܝܠܝܢ ܕܠܐ ܝܕܥܘ ܥܡܝܩܬܗ ܕܤܛܢܐ ܐܝܟ ܕܐܡܪܝܢ ܠܐ ܐܪܡܐ ܥܠܝܟܘܢ ܝܘܩܪܐ ܐܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.25",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Revelation 2:25",
      "text": "ܗܘ ܗܟܝܠ ܕܐܝܬ ܠܟܘܢ ܐܚܘܕܘ ܥܕܡܐ ܕܐܬܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.26",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Revelation 2:26",
      "text": "ܘܕܙܟܐ ܘܢܛܪ ܥܒܕܝ ܐܬܠ ܠܗ ܫܘܠܛܢܐ ܥܠ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.27",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Revelation 2:27",
      "text": "ܠܡܪܥܐ ܐܢܘܢ ܒܫܒܛܐ ܕܦܪܙܠܐ ܘܐܝܟ ܡܐܢܝ ܦܚܪܐ ܬܫܚܩܘܢ ܗܟܢܐ ܓܝܪ ܘܐܢܐ ܢܤܒܬ ܡܢ ܐܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.28",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Revelation 2:28",
      "text": "ܘܐܬܠ ܠܗ ܠܟܘܟܒ ܨܦܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.2.29",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 2,
      "verseNumber": 29,
      "referenceLabel": "Revelation 2:29",
      "text": "ܕܐܝܬ ܠܗ ܐܕܢܐ ܢܫܡܥ ܡܢܐ ܪܘܚܐ ܡܡܠܠ ܠܥܕܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
