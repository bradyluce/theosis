{
  "chapter": {
    "id": "peshitta:revelation.8",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 8,
    "referenceLabel": "Revelation 8",
    "summary": "Source text for Revelation 8 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.8.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Revelation 8:1",
      "text": "ܘܟܕ ܦܬܚ ܛܒܥܐ ܕܫܒܥܐ ܗܘܐ ܫܬܩܐ ܒܫܡܝܐ ܐܝܟ ܦܠܓܘܬ ܫܥܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.8.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Revelation 8:2",
      "text": "ܘܚܙܝܬ ܠܫܒܥܐ ܡܠܐܟܝܢ ܐܝܠܝܢ ܕܩܕܡ ܐܠܗܐ ܩܝܡܝܢ ܗܘܘ ܕܐܬܝܗܒܘ ܠܗܘܢ ܫܒܥܐ ܫܝܦܘܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Revelation 8:3",
      "text": "ܘܐܚܪܢܐ ܡܠܐܟܐ ܐܬܐ ܘܩܡ ܥܠ ܡܕܒܚܐ ܘܐܝܬ ܠܗ ܦܝܪܡܐ ܕܕܗܒܐ ܘܐܬܝܗܒ ܠܗ ܒܤܡܐ ܤܓܝܐܐ ܕܢܬܠ ܒܨܠܘܬܐ ܕܟܠܗܘܢ ܩܕܝܫܐ ܥܠ ܡܕܒܚܐ ܕܩܕܡ ܟܘܪܤܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Revelation 8:4",
      "text": "ܘܤܠܩ ܥܛܪܐ ܕܒܤܡܐ ܒܨܠܘܬܐ ܕܩܕܝܫܐ ܡܢ ܝܕ ܡܠܐܟܐ ܩܕܡ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Revelation 8:5",
      "text": "ܘܢܤܒ ܡܠܐܟܐ ܠܦܝܪܡܐ ܘܡܠܝܗܝ ܡܢ ܢܘܪܐ ܕܥܠ ܡܕܒܚܐ ܘܐܪܡܝ ܥܠ ܐܪܥܐ ܘܗܘܘ ܪܥܡܐ ܘܩܠܐ ܘܒܪܩܐ ܘܢܘܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Revelation 8:6",
      "text": "ܘܫܒܥܐ ܡܠܐܟܝܢ ܕܥܠܝܗܘܢ ܫܒܥܐ ܫܝܦܘܪܝܢ ܛܝܒܘ ܢܦܫܗܘܢ ܠܡܙܥܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Revelation 8:7",
      "text": "ܘܗܘ ܩܕܡܝܐ ܐܙܥܩ ܘܗܘܐ ܒܪܕܐ ܘܢܘܪܐ ܕܦܬܝܟܝܢ ܒܡܝܐ ܘܐܬܪܡܝܘ ܥܠ ܐܪܥܐ ܘܬܘܠܬܗ ܕܐܪܥܐ ܝܩܕ ܘܬܘܠܬܐ ܕܐܝܠܢܐ ܝܩܕ ܘܟܠ ܥܤܒܐ ܕܐܪܥܐ ܝܩܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Revelation 8:8",
      "text": "ܘܕܬܪܝܢ ܙܥܩ ܘܗܘܐ ܐܝܟ ܛܘܪܐ ܪܒܐ ܕܝܩܕ ܢܦܠ ܒܝܡܐ ܘܗܘܐ ܬܘܠܬܗ ܕܝܡܐ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Revelation 8:9",
      "text": "ܘܡܝܬ ܬܘܠܬܐ ܕܟܠ ܒܪܝܬܐ ܕܒܝܡܐ ܕܐܝܬ ܒܗ ܢܦܫܐ ܘܬܘܠܬܐ ܕܐܠܦܐ ܐܬܚܒܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Revelation 8:10",
      "text": "ܘܕܬܠܬܐ ܙܥܩ ܘܢܦܠ ܡܢ ܫܡܝܐ ܟܘܟܒܐ ܪܒܐ ܕܝܩܕ ܐܝܟ ܫܠܗܒܝܬܐ ܘܢܦܠ ܥܠ ܬܘܠܬܐ ܕܢܗܪܘܬܐ ܘܥܠ ܥܝܢܬܐ ܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Revelation 8:11",
      "text": "ܘܫܡܗ ܕܟܘܟܒܐ ܡܬܐܡܪ ܐܦܤܝܬܢܐ ܘܗܘܐ ܬܘܠܬܗܘܢ ܕܡܝܐ ܐܝܟ ܐܦܤܢܬܝܢ ܘܤܘܓܐܐ ܕܒܢܝܢܫܐ ܡܝܬܘ ܡܛܠ ܕܐܬܡܪܡܪܘ ܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Revelation 8:12",
      "text": "ܘܕܐܪܒܥܐ ܙܥܩ ܘܒܠܥ ܬܘܠܬܗ ܕܫܡܫܐ ܘܬܘܠܬܗ ܕܤܗܪܐ ܘܬܘܠܬܐ ܕܟܘܟܒܐ ܘܚܫܟܘ ܬܘܠܬܗܘܢ ܘܝܘܡܐ ܠܐ ܚܘܝ ܬܘܠܬܗ ܘܠܠܝܐ ܗܟܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.8.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Revelation 8:13",
      "text": "ܘܫܡܥܬ ܠܢܫܪܐ ܚܕ ܕܦܪܚ ܒܫܡܝܐ ܕܐܡܪ ܘܝ ܘܝ ܘܝ ܠܥܡܘܪܝܗ ܕܐܪܥܐ ܡܢ ܩܠܐ ܕܫܝܦܘܪܐ ܕܬܠܬܐ ܡܠܐܟܝܢ ܕܥܬܝܕܝܢ ܠܡܙܥܩܘ ܀",
      "paragraphStart": false
    }
  ]
}
