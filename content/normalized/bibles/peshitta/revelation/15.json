    "chapterNumber": 15,
    "referenceLabel": "Revelation 15",
    "summary": "Source text for Revelation 15 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.15.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Revelation 15:1",
      "text": "ܘܚܙܝܬ ܐܚܪܬܐ ܐܬܐ ܒܫܡܝܐ ܪܒܬܐ ܘܬܡܝܗܬܐ ܡܠܐܟܐ ܕܐܝܬ ܥܠܝܗܘܢ ܡܚܘܬܐ ܫܒܥ ܐܚܪܝܬܐ ܕܒܗܝܢ ܐܫܬܡܠܝܬ ܚܡܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.15.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Revelation 15:2",
      "text": "ܘܚܙܝܬ ܐܝܟ ܝܡܐ ܕܙܓܘܓܝܬܐ ܕܦܬܝܟܐ ܒܢܘܪܐ ܘܠܕܙܟܘ ܡܢ ܚܝܘܬܐ ܘܡܢ ܨܠܡܗ ܘܡܢ ܡܢܝܢܐ ܕܫܡܗ ܕܩܝܡܝܢ ܠܥܠ ܡܢ ܝܡܐ ܕܙܓܘܓܝܬܐ ܘܐܝܬ ܥܠܝܗܘܢ ܩܝܬܪܘܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.15.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Revelation 15:3",
      "text": "ܘܡܫܒܚܝܢ ܬܫܒܘܚܬܐ ܕܡܘܫܐ ܥܒܕܗ ܕܐܠܗܐ ܘܬܫܒܘܚܬܐ ܕܐܡܪܐ ܘܐܡܪܝܢ ܪܘܪܒܝܢ ܘܬܡܝܗܝܢ ܥܒܕܝܟ ܡܪܝܐ ܐܠܗܐ ܐܚܝܕ ܟܠ ܟܐܢܝܢ ܘܫܪܝܪܝܢ ܥܒܕܝܟ ܡܠܟܐ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.15.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Revelation 15:4",
      "text": "ܡܢ ܠܐ ܢܕܚܠ ܠܟ ܡܪܝܐ ܘܢܫܒܚ ܠܫܡܟ ܡܛܠ ܕܐܢܬ ܗܘ ܒܠܚܘܕ ܚܤܝܐ ܡܛܠ ܕܟܠܗܘܢ ܥܡܡܐ ܢܐܬܘܢ ܘܢܤܓܕܘܢ ܩܕܡܝܟ ܡܛܠ ܕܬܪܝܨ ܐܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.15.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Revelation 15:5",
      "text": "ܘܡܢ ܒܬܪ ܗܠܝܢ ܚܙܝܬ ܘܐܬܦܬܚ ܗܝܟܠܐ ܕܡܫܟܢܐ ܕܤܗܕܘܬܐ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.15.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Revelation 15:6",
      "text": "ܘܢܦܩܘ ܫܒܥܐ ܡܠܐܟܝܢ ܡܢ ܗܝܟܠܐ ܗܢܘܢ ܕܐܝܬ ܥܠܝܗܘܢ ܫܒܥ ܡܚܘܢ ܟܕ ܠܒܝܫܝܢ ܟܬܢܐ ܕܟܝܐ ܘܢܗܝܪܐ ܘܐܤܝܪܝܢ ܥܠ ܚܕܝܝܗܘܢ ܐܤܪܐ ܕܕܗܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.15.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Revelation 15:7",
      "text": "ܘܚܕܐ ܡܢ ܐܪܒܥ ܚܝܘܬܐ ܝܗܒܬ ܠܫܒܥܐ ܡܠܐܟܝܢ ܫܒܥ ܙܒܘܪܝܢ ܕܡܠܝܢ ܚܡܬܗ ܕܐܠܗܐ ܕܐܝܬܘܗܝ ܚܝܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.15.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Revelation 15:8",
      "text": "ܘܐܬܡܠܝ ܗܝܟܠܐ ܡܢ ܬܢܢܐ ܕܬܫܒܘܚܬܗ ܕܐܠܗܐ ܘܡܢ ܚܝܠܗ ܘܠܝܬ ܕܡܨܐ ܗܘܐ ܠܡܥܠ ܠܗܝܟܠܐ ܥܕܡܐ ܕܢܫܬܡܠܝܢ ܫܒܥ ܡܚܘܢ ܕܫܒܥܐ ܡܠܐܟܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
