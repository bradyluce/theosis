{
  "chapter": {
    "id": "peshitta:revelation.22",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 22,
    "referenceLabel": "Revelation 22",
    "summary": "Source text for Revelation 22 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.22.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 1,
      "referenceLabel": "Revelation 22:1",
      "text": "ܘܚܘܝܢܝ ܢܗܪܐ ܕܡܝܐ ܚܝܐ ܕܟܝܐ ܐܦ ܢܗܝܪܐ ܐܝܟ ܓܠܝܕܐ ܘܢܦܩ ܡܢ ܟܘܪܤܝܗ ܕܐܠܗܐ ܘܕܐܡܪܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.22.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 2,
      "referenceLabel": "Revelation 22:2",
      "text": "ܘܡܨܥܬ ܫܘܩܝܗ ܡܟܐ ܘܡܟܐ ܥܠ ܢܗܪܐ ܩܝܤܐ ܕܚܝܐ ܕܥܒܕ ܦܐܪܐ ܬܪܥܤܪ ܘܒܟܠ ܝܪܚ ܝܗܒ ܦܐܪܘܗܝ ܘܛܪܦܘܗܝ ܠܐܤܝܘܬܐ ܕܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 3,
      "referenceLabel": "Revelation 22:3",
      "text": "ܘܟܠ ܚܪܡܐ ܠܐ ܢܗܘܐ ܬܡܢ ܘܟܘܪܤܝܗ ܕܐܠܗܐ ܘܕܐܡܪܐ ܒܗ ܢܗܘܐ ܘܥܒܕܘܗܝ ܢܫܡܫܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 4,
      "referenceLabel": "Revelation 22:4",
      "text": "ܘܢܚܙܘܢ ܐܦܘܗܝ ܘܫܡܗ ܥܠ ܒܝܬ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 5,
      "referenceLabel": "Revelation 22:5",
      "text": "ܘܠܠܝܐ ܠܐ ܢܗܘܐ ܬܡܢ ܘܠܐ ܢܬܒܥܐ ܠܗܘܢ ܢܘܗܪܐ ܘܫܪܓܐ ܘܢܘܗܪܗ ܕܫܡܫܐ ܡܛܠ ܕܡܪܝܐ ܐܠܗܐ ܡܢܗܪ ܠܗܘܢ ܘܡܠܟܗܘܢ ܠܥܠܡ ܥܠܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 6,
      "referenceLabel": "Revelation 22:6",
      "text": "ܘܐܡܪ ܠܝ ܗܠܝܢ ܡܠܐ ܡܗܝܡܢܢ ܘܫܪܝܪܢ ܘܡܪܝܐ ܐܠܗܐ ܕܪܘܚܬܐ ܕܢܒܝܐ ܩܕܝܫܐ ܫܕܪ ܠܡܠܐܟܗ ܠܡܚܘܝܘ ܠܥܒܕܘܗܝ ܡܐ ܕܝܗܝܒ ܠܡܗܘܐ ܒܥܓܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 7,
      "referenceLabel": "Revelation 22:7",
      "text": "ܘܗܐ ܐܬܐ ܐܢܐ ܒܥܓܠ ܛܘܒܘܗܝ ܠܡܢ ܕܢܛܪ ܡܠܐ ܕܢܒܝܘܬܐ ܕܟܬܒܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 8,
      "referenceLabel": "Revelation 22:8",
      "text": "ܐܢܐ ܝܘܚܢܢ ܕܚܙܐ ܘܫܡܥ ܗܠܝܢ ܘܟܕ ܚܙܝܬ ܘܫܡܥܬ ܢܦܠܬ ܠܡܤܓܕ ܩܕܡ ܪܓܠܘܗܝ ܕܡܠܐܟܐ ܕܡܚܘܐ ܠܝ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 9,
      "referenceLabel": "Revelation 22:9",
      "text": "ܘܐܡܪ ܠܝ ܚܙܝ ܠܐ ܟܢܬܟ ܐܝܬܝ ܘܕܐܚܝܟ ܢܒܝܐ ܘܕܐܝܠܝܢ ܕܢܛܪܝܢ ܗܠܝܢ ܡܠܐ ܕܟܬܒܐ ܗܢܐ ܠܐܠܗܐ ܤܓܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 10,
      "referenceLabel": "Revelation 22:10",
      "text": "ܘܐܡܪ ܠܝ ܠܐ ܬܚܬܘܡ ܡܠܐ ܕܢܒܝܘܬܐ ܕܟܬܒܐ ܗܢܐ ܙܒܢܐ ܓܝܪ ܩܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 11,
      "referenceLabel": "Revelation 22:11",
      "text": "ܘܕܡܥܘܠ ܬܘܒ ܢܥܘܠ ܘܕܨܥ ܬܘܒ ܢܨܛܥܨܥ ܘܙܕܝܩܐ ܬܘܒ ܢܥܒܕ ܙܕܝܩܘܬܐ ܘܩܕܝܫܐ ܬܘܒ ܢܬܩܕܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 12,
      "referenceLabel": "Revelation 22:12",
      "text": "ܗܐ ܐܬܐ ܐܢܐ ܡܚܕܐ ܘܐܓܪܝ ܥܡܝ ܘܐܬܠ ܠܟܠܢܫ ܐܝܟ ܥܒܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 13,
      "referenceLabel": "Revelation 22:13",
      "text": "ܐܢܐ ܐܠܦ ܘܐܢܐ ܬܘ ܩܕܡܝܐ ܘܐܚܪܝܐ ܘܫܘܪܝܐ ܘܫܘܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 14,
      "referenceLabel": "Revelation 22:14",
      "text": "ܛܘܒܝܗܘܢ ܠܕܥܒܕܝܢ ܦܘܩܕܢܘܗܝ ܢܗܘܐ ܫܘܠܛܢܗܘܢ ܥܠ ܩܝܤܐ ܕܚܝܐ ܘܒܬܪܥܐ ܢܥܠܘܢ ܠܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 15,
      "referenceLabel": "Revelation 22:15",
      "text": "ܘܙܢܝܐ ܘܩܛܘܠܐ ܘܦܠܚܝ ܦܬܟܪܐ ܠܒܪ ܘܛܡܐܐ ܘܚܪܫܐ ܘܟܠ ܚܙܝܝ ܘܥܒܕܝ ܕܓܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 16,
      "referenceLabel": "Revelation 22:16",
      "text": "ܐܢܐ ܝܫܘܥ ܫܕܪܬ ܠܡܠܐܟܝ ܕܢܤܗܕ ܒܟܘܢ ܗܠܝܢ ܩܕܡ ܥܕܬܐ ܐܢܐ ܐܢܐ ܥܩܪܐ ܘܫܪܒܬܗ ܕܕܘܝܕ ܘܥܡܗ ܘܟܘܟܒ ܨܦܪܐ ܢܗܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 17,
      "referenceLabel": "Revelation 22:17",
      "text": "ܘܪܘܚܐ ܘܟܠܬܐ ܐܡܪܝܢ ܬܐ ܘܕܫܡܥ ܢܐܡܪ ܬܐ ܘܕܨܗܐ ܢܐܬܐ ܘܢܤܒ ܡܝܐ ܚܝܐ ܡܓܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 18,
      "referenceLabel": "Revelation 22:18",
      "text": "ܡܤܗܕ ܐܢܐ ܠܟܠ ܕܫܡܥ ܡܠܬܐ ܕܢܒܝܘܬܐ ܕܟܬܒܐ ܗܢܐ ܕܐܝܢܐ ܕܢܤܝܡ ܥܠܝܗܝܢ ܢܤܝܡ ܥܠܘܗܝ ܐܠܗܐ ܡܚܘܬܐ ܕܟܬܝܒܢ ܒܟܬܒܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 19,
      "referenceLabel": "Revelation 22:19",
      "text": "ܘܐܝܢܐ ܕܡܒܨܪ ܡܢ ܡܠܐ ܕܟܬܒܐ ܕܢܒܝܘܬܐ ܗܕܐ ܢܒܨܪ ܐܠܗܐ ܡܢܬܗ ܡܢ ܩܝܤܐ ܕܚܝܐ ܘܡܢ ܡܕܝܢܬܐ ܩܕܝܫܬܐ ܐܝܠܝܢ ܕܟܬܝܒܢ ܒܟܬܒܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 20,
      "referenceLabel": "Revelation 22:20",
      "text": "ܐܡܪ ܟܕ ܡܤܗܕ ܗܠܝܢ ܐܝܢ ܐܬܐ ܐܢܐ ܒܥܓܠ ܬܐ ܡܪܝܐ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.22.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 22,
      "verseNumber": 21,
      "referenceLabel": "Revelation 22:21",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܟܠܗܘܢ ܩܕܝܫܘܗܝ ܐܡܝܢ ܀܀",
      "paragraphStart": false
    }
  ]
}
