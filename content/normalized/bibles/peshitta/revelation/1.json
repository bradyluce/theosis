{
  "chapter": {
    "id": "peshitta:revelation.1",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 1,
    "referenceLabel": "Revelation 1",
    "summary": "Source text for Revelation 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.1.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Revelation 1:1",
      "text": "ܓܠܝܢܐ ܕܝܫܘܥ ܡܫܝܚܐ ܕܝܗܒ ܠܗ ܐܠܗܐ ܠܡܚܘܝܘ ܠܥܒܕܘܗܝ ܡܐ ܕܝܗܝܒ ܠܡܗܘܐ ܒܥܓܠ ܘܫܘܕܥ ܟܕ ܫܠܚ ܒܝܕ ܡܠܐܟܗ ܠܥܒܕܗ ܝܘܚܢܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.1.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Revelation 1:2",
      "text": "ܗܘ ܕܐܤܗܕ ܠܡܠܬܐ ܕܐܠܗܐ ܘܠܤܗܕܘܬܗ ܕܝܫܘܥ ܡܫܝܚܐ ܟܠ ܡܐ ܕܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Revelation 1:3",
      "text": "ܛܘܒܘܗܝ ܠܡܢ ܕܩܪܐ ܘܠܐܝܠܝܢ ܕܫܡܥܝܢ ܡܠܐ ܕܢܒܝܘܬܐ ܗܕܐ ܘܢܛܪܝܢ ܐܝܠܝܢ ܕܟܬܝܒܢ ܒܗ ܙܒܢܐ ܓܝܪ ܩܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Revelation 1:4",
      "text": "ܝܘܚܢܢ ܠܫܒܥ ܥܕܬܐ ܕܒܐܤܝܐ ܛܝܒܘܬܐ ܠܟܘܢ ܘܫܠܡܐ ܡܢ ܗܘ ܕܐܝܬܘܗܝ ܘܐܝܬܘܗܝ ܗܘܐ ܘܐܬܐ ܘܡܢ ܫܒܥ ܪܘܚܐ ܐܝܠܝܢ ܕܩܕܡ ܟܘܪܤܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Revelation 1:5",
      "text": "ܘܡܢ ܝܫܘܥ ܡܫܝܚܐ ܤܗܕܐ ܡܗܝܡܢܐ ܒܘܟܪܐ ܕܡܝܬܐ ܘܪܫܐ ܕܡܠܟܐ ܕܐܪܥܐ ܗܘ ܕܡܚܒ ܠܢ ܘܫܪܐ ܠܢ ܡܢ ܚܛܗܝܢ ܒܕܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Revelation 1:6",
      "text": "ܘܥܒܕ ܠܢ ܡܠܟܘܬܐ ܟܗܢܝܬܐ ܠܐܠܗܐ ܘܐܒܘܗܝ ܘܠܗ ܬܫܒܘܚܬܐ ܘܐܘܚܕܢܐ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Revelation 1:7",
      "text": "ܗܐ ܐܬܐ ܥܡ ܥܢܢܐ ܘܢܚܙܝܢܝܗܝ ܟܠ ܥܝܢܐ ܘܐܦ ܐܝܠܝܢ ܕܕܩܪܘܗܝ ܘܢܪܩܕܢ ܥܠܘܗܝ ܟܠ ܫܪܒܬܐ ܕܐܪܥܐ ܐܝܢ ܘܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Revelation 1:8",
      "text": "ܐܢܐ ܐܠܦ ܘܬܘ ܐܡܪ ܡܪܝܐ ܐܠܗܐ ܗܘ ܕܐܝܬܘܗܝ ܘܐܝܬܘܗܝ ܗܘܐ ܘܐܬܐ ܗܘ ܕܐܚܝܕ ܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Revelation 1:9",
      "text": "ܐܢܐ ܝܘܚܢܢ ܗܘ ܐܚܘܟܘܢ ܘܒܪ ܫܘܬܦܟܘܢ ܒܐܘܠܨܢܐ ܘܒܡܤܝܒܪܢܘܬܐ ܕܒܝܫܘܥ ܗܘܝܬ ܒܓܙܪܬܐ ܕܡܬܩܪܝܐ ܦܛܡܘܤ ܡܛܠ ܡܠܬܐ ܕܐܠܗܐ ܘܡܛܠ ܤܗܕܘܬܐ ܕܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Revelation 1:10",
      "text": "ܘܗܘܝܬ ܒܪܘܚ ܒܝܘܡܐ ܕܚܕܒܫܒܐ ܘܫܡܥܬ ܡܢ ܒܤܬܪܝ ܩܠܐ ܪܒܐ ܐܝܟ ܫܝܦܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Revelation 1:11",
      "text": "ܕܐܡܪ ܐܝܠܝܢ ܕܚܙܝܬ ܟܬܘܒ ܒܟܬܒܐ ܘܫܕܪ ܠܫܒܥ ܥܕܬܐ ܠܐܦܤܘܤ ܘܠܙܡܘܪܢܐ ܘܠܦܪܓܡܘܤ ܘܠܬܐܘܛܝܪܐ ܘܠܤܪܕܝܤ ܘܠܦܝܠܕܠܦܝܐ ܘܠܠܕܝܩܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Revelation 1:12",
      "text": "ܘܗܦܟܬ ܠܡܕܥ ܩܠܐ ܐܝܢܐ ܕܡܠܠ ܥܡܝ ܘܟܕ ܥܛܦܬ ܚܙܝܬ ܫܒܥ ܡܢܪܢ ܕܕܗܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Revelation 1:13",
      "text": "ܘܒܡܨܥܬܐ ܕܡܢܪܬܐ ܐܝܟ ܕܡܘܬܐ ܕܒܪܢܫܐ ܘܠܒܝܫ ܐܦܘܕܐ ܘܐܤܝܪ ܨܝܕ ܬܕܘܗܝ ܐܤܪܐ ܕܕܗܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Revelation 1:14",
      "text": "ܪܫܗ ܕܝܢ ܘܤܥܪܗ ܚܘܪ ܐܝܟ ܥܡܪܐ ܘܐܝܟ ܬܠܓܐ ܘܥܝܢܘܗܝ ܐܝܟ ܫܠܗܒܝܬܐ ܕܢܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Revelation 1:15",
      "text": "ܘܪܓܠܘܗܝ ܒܕܡܘܬܐ ܕܢܚܫܐ ܠܒܢܝܐ ܕܡܚܡ ܒܐܬܘܢܐ ܘܩܠܗ ܐܝܟ ܩܠܐ ܕܡܝܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Revelation 1:16",
      "text": "ܘܐܝܬ ܠܗ ܒܐܝܕܗ ܕܝܡܝܢܐ ܫܒܥܐ ܟܘܟܒܝܢ ܘܡܢ ܦܘܡܗ ܢܦܩܐ ܪܘܡܚܐ ܚܪܝܦܬܐ ܘܚܙܬܗ ܐܝܟ ܫܡܫܐ ܡܚܘܝܐ ܒܚܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Revelation 1:17",
      "text": "ܘܟܕ ܚܙܝܬܗ ܢܦܠܬ ܥܠ ܪܓܠܘܗܝ ܐܝܟ ܡܝܬܐ ܘܤܡ ܥܠܝ ܐܝܕܗ ܕܝܡܝܢܐ ܠܡܐܡܪ ܠܐ ܬܕܚܠ ܕܐܢܐ ܐܝܬܝ ܩܕܡܝܐ ܘܐܚܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Revelation 1:18",
      "text": "ܘܕܚܝ ܘܕܡܝܬܐ ܗܘܝܬ ܘܗܐ ܚܝܐ ܐܝܬܝ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܘܐܝܬ ܠܝ ܩܠܝܕܐ ܕܡܘܬܐ ܘܕܫܝܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Revelation 1:19",
      "text": "ܟܬܘܒ ܗܟܝܠ ܡܐ ܕܚܙܝܬ ܘܐܝܠܝܢ ܕܐܝܬܝܗܝܢ ܘܥܬܝܕܢ ܠܡܗܘܐ ܒܬܪ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.1.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Revelation 1:20",
      "text": "ܐܪܙܐ ܕܫܒܥܐ ܟܘܟܒܝܢ ܐܝܠܝܢ ܕܚܙܝܬ ܥܠ ܝܡܝܢܝ ܘܫܒܥ ܡܢܪܬܐ ܫܒܥܐ ܟܘܟܒܝܢ ܡܠܐܟܐ ܕܫܒܥ ܥܕܬܐ ܐܝܬܝܗܘܢ ܘܡܢܪܬܐ ܫܒܥ ܕܕܗܒܐ ܐܝܠܝܢ ܕܚܙܝܬ ܫܒܥ ܐܢܝܢ ܥܕܬܐ ܀",
      "paragraphStart": false
    }
  ]
}
