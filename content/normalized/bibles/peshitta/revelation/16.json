{
  "chapter": {
    "id": "peshitta:revelation.16",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 16,
    "referenceLabel": "Revelation 16",
    "summary": "Source text for Revelation 16 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.16.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Revelation 16:1",
      "text": "ܘܫܡܥܬ ܩܠܐ ܪܒܐ ܡܢ ܗܝܟܠܐ ܕܐܡܪ ܠܫܒܥܐ ܡܠܐܟܝܢ ܙܠܘ ܘܐܫܘܕܘ ܫܒܥ ܙܒܘܪܝܢ ܕܚܡܬܗ ܕܐܠܗܐ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.16.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Revelation 16:2",
      "text": "ܘܐܙܠ ܩܕܡܝܐ ܘܐܫܕ ܙܒܘܪܗ ܥܠ ܐܪܥܐ ܘܗܘܐ ܫܘܚܢܐ ܒܝܫܐ ܘܟܐܒܢܐ ܥܠ ܐܢܫܐ ܕܐܝܬ ܠܗܘܢ ܪܘܫܡܐ ܕܚܝܘܬܐ ܘܐܝܠܝܢ ܕܤܓܕܝܢ ܠܨܠܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Revelation 16:3",
      "text": "ܘܡܠܐܟܐ ܕܬܪܝܢ ܐܫܕ ܙܒܘܪܗ ܒܝܡܐ ܘܗܘܐ ܝܡܐ ܐܝܟ ܡܝܬܐ ܘܟܠ ܢܦܫܐ ܚܝܬܐ ܡܝܬܬ ܒܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Revelation 16:4",
      "text": "ܘܡܠܐܟܐ ܕܬܠܬܐ ܐܫܕ ܙܒܘܪܗ ܒܢܗܪܘܬܐ ܘܒܥܝܢܬܐ ܕܡܝܐ ܘܗܘܘ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Revelation 16:5",
      "text": "ܘܫܡܥܬ ܠܡܠܐܟܐ ܕܡܝܐ ܕܐܡܪ ܙܕܝܩ ܐܢܬ ܗܘ ܕܐܝܬܘܗܝ ܘܐܝܬܘܗܝ ܗܘܐ ܘܚܤܝܐ ܕܗܠܝܢ ܕܢܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Revelation 16:6",
      "text": "ܡܛܠ ܕܕܡܐ ܕܢܒܝܐ ܘܕܩܕܝܫܐ ܐܫܕܘ ܘܕܡܐ ܝܗܒܬ ܠܗܘܢ ܠܡܫܬܐ ܫܘܝܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Revelation 16:7",
      "text": "ܘܫܡܥܬ ܠܡܕܒܚܐ ܕܐܡܪ ܐܝܢ ܡܪܝܐ ܐܠܗܐ ܐܚܝܕ ܟܠ ܫܪܝܪܝܢ ܘܙܕܝܩܝܢ ܕܝܢܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Revelation 16:8",
      "text": "ܘܡܠܐܟܐ ܕܐܪܒܥܐ ܐܫܕ ܙܒܘܪܗ ܥܠ ܫܡܫܐ ܘܐܬܝܗܒ ܠܗ ܕܢܚܡ ܠܒܢܝܢܫܐ ܒܢܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Revelation 16:9",
      "text": "ܘܐܬܚܡܡܘ ܒܢܝܢܫܐ ܒܚܘܡܐ ܪܒܐ ܘܓܕܦܘ ܠܫܡܐ ܕܐܠܗܐ ܕܐܝܬ ܠܗ ܫܘܠܛܢܐ ܥܠ ܡܚܘܬܐ ܗܠܝܢ ܘܠܐ ܬܒܘ ܠܡܬܠ ܠܗ ܬܫܒܘܚܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Revelation 16:10",
      "text": "ܘܡܠܐܟܐ ܕܚܡܫܐ ܐܫܕ ܙܒܘܪܗ ܥܠ ܟܘܪܤܝܗ ܕܚܝܘܬܐ ܘܗܘܬ ܡܠܟܘܬܗ ܚܫܘܟܬܐ ܘܡܠܥܤܝܢ ܗܘܘ ܠܫܢܝܗܘܢ ܡܢ ܟܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Revelation 16:11",
      "text": "ܘܓܕܦܘ ܠܫܡܐ ܕܐܠܗܐ ܕܫܡܝܐ ܡܢ ܟܐܒܝܗܘܢ ܘܡܢ ܫܘܚܢܝܗܘܢ ܘܠܐ ܬܒܘ ܡܢ ܥܒܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Revelation 16:12",
      "text": "ܘܡܠܐܟܐ ܕܫܬܐ ܐܫܕ ܙܒܘܪܗ ܥܠ ܢܗܪܐ ܪܒܐ ܦܪܬ ܘܝܒܫܘ ܡܘܗܝ ܕܬܬܛܝܒ ܐܘܪܚܐ ܕܡܠܟܐ ܡܢ ܡܕܢܚܝ ܫܡܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Revelation 16:13",
      "text": "ܘܚܙܝܬ ܡܢ ܦܘܡܗ ܕܬܢܝܢܐ ܘܡܢ ܦܘܡܗ ܕܚܝܘܬܐ ܘܡܢ ܦܘܡܗ ܕܢܒܝܐ ܕܓܠܐ ܪܘܚܐ ܬܠܬ ܠܐ ܕܟܝܬܐ ܐܝܟ ܐܘܪܕܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Revelation 16:14",
      "text": "ܐܝܬܝܗܝܢ ܓܝܪ ܪܘܚܐ ܕܫܐܕܐ ܐܝܠܝܢ ܕܥܒܕܢ ܐܬܘܬܐ ܕܐܙܠܢ ܥܠ ܡܠܟܐ ܕܬܐܒܝܠ ܠܡܟܢܫܘ ܐܢܘܢ ܠܩܪܒܐ ܕܝܘܡܐ ܗܘ ܪܒܐ ܕܐܠܗܐ ܐܚܝܕ ܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Revelation 16:15",
      "text": "ܗܐ ܐܬܐ ܐܝܟ ܓܢܒܐ ܛܘܒܘܗܝ ܠܗܘ ܕܥܝܪ ܘܢܛܪ ܡܐܢܘܗܝ ܕܠܐ ܥܪܛܠ ܢܗܠܟ ܘܢܚܙܘܢ ܒܗܬܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Revelation 16:16",
      "text": "ܘܢܟܢܫ ܐܢܘܢ ܠܐܬܪܐ ܕܡܬܩܪܐ ܥܒܪܐܝܬ ܡܓܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Revelation 16:17",
      "text": "ܘܡܠܐܟܐ ܕܫܒܥܐ ܐܫܕ ܙܒܘܪܗ ܒܐܐܪ ܘܢܦܩ ܩܠܐ ܪܒܐ ܡܢ ܗܝܟܠܐ ܡܢ ܩܕܡ ܟܘܪܤܝܐ ܕܐܡܪ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Revelation 16:18",
      "text": "ܘܗܘܘ ܒܪܩܐ ܘܪܥܡܐ ܘܢܘܕܐ ܗܘܐ ܪܒܐ ܕܐܟܘܬܗ ܠܐ ܗܘܐ ܡܢ ܕܗܘܘ ܒܢܝܢܫܐ ܥܠ ܐܪܥܐ ܕܐܝܟ ܗܢܐ ܙܘܥܐ ܗܟܢܐ ܪܒ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Revelation 16:19",
      "text": "ܘܗܘܬ ܡܕܝܢܬܐ ܪܒܬܐ ܠܬܠܬ ܡܢܘܢ ܘܡܕܝܢܬܐ ܕܥܡܡܐ ܢܦܠܝ ܘܒܒܝܠ ܪܒܬܐ ܐܬܕܟܪܬ ܩܕܡ ܐܠܗܐ ܠܡܬܠ ܠܗ ܟܤܐ ܕܚܡܪܐ ܕܚܡܬܗ ܘܕܪܘܓܙܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Revelation 16:20",
      "text": "ܘܟܠ ܓܙܪܬܐ ܥܪܩܬ ܘܛܘܪܐ ܠܐ ܐܫܬܟܚܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.16.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 16,
      "verseNumber": 21,
      "referenceLabel": "Revelation 16:21",
      "text": "ܘܒܪܕܐ ܪܒܐ ܐܝܟ ܟܟܪܐ ܢܚܬ ܡܢ ܫܡܝܐ ܥܠ ܒܢܝܢܫܐ ܘܓܕܦܘ ܒܢܝܢܫܐ ܠܐܠܗܐ ܥܠ ܡܚܘܬܐ ܕܒܪܕܐ ܡܛܠ ܕܪܒܐ ܗܝ ܡܚܘܬܗ ܛܒ ܀",
      "paragraphStart": false
    }
  ]
}
