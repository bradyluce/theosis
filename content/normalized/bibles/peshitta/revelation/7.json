{
  "chapter": {
    "id": "peshitta:revelation.7",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 7,
    "referenceLabel": "Revelation 7",
    "summary": "Source text for Revelation 7 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.7.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Revelation 7:1",
      "text": "ܘܡܢ ܒܬܪ ܗܕܐ ܚܙܝܬ ܐܪܒܥܐ ܡܠܐܟܝܢ ܩܝܡܝܢ ܥܠ ܐܪܒܥ ܙܘܝܬܗ ܕܐܪܥܐ ܘܐܚܝܕܝܢ ܠܐܪܒܥܬ ܪܘܚܐ ܕܠܐ ܢܫܒ ܪܘܚܐ ܥܠ ܐܪܥܐ ܘܠܐ ܥܠ ܝܡܐ ܘܠܐ ܥܠ ܟܠ ܐܝܠܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.7.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Revelation 7:2",
      "text": "ܘܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܕܤܠܩ ܡܢ ܡܕܢܚܝ ܫܡܫܐ ܘܐܝܬ ܠܗ ܚܬܡܐ ܕܐܠܗܐ ܚܝܐ ܘܩܥܐ ܒܩܠܐ ܪܡܐ ܠܐܪܒܥܐ ܡܠܐܟܐ ܗܢܘܢ ܕܐܬܝܗܒ ܠܗܘܢ ܕܢܗܪܘܢ ܠܐܪܥܐ ܘܠܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Revelation 7:3",
      "text": "ܘܐܡܪ ܠܐ ܬܗܪܘܢ ܠܐܪܥܐ ܘܠܐ ܠܝܡܐ ܘܐܦܠܐ ܠܐܝܠܢܐ ܥܕܡܐ ܕܢܚܬܘܡ ܠܥܒܕܘܗܝ ܕܐܠܗܐ ܒܝܬ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Revelation 7:4",
      "text": "ܘܫܡܥܬ ܡܢܝܢܐ ܕܚܬܝܡܐ ܡܐܐ ܘܐܪܒܥܝܢ ܘܐܪܒܥܐ ܐܠܦܝܢ ܡܢ ܟܠ ܫܪܒܢ ܕܐܝܤܪܐܝܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Revelation 7:5",
      "text": "ܡܢ ܫܪܒܬܗ ܕܝܗܘܕܐ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܪܘܒܝܠ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܓܕ ܬܪܥܤܪ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Revelation 7:6",
      "text": "ܡܢ ܫܪܒܬܗ ܕܐܫܝܪ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܢܦܬܠܝ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܡܢܫܐ ܬܪܥܤܪ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Revelation 7:7",
      "text": "ܡܢ ܫܪܒܬܗ ܕܫܡܥܘܢ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܐܝܤܟܪ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܠܘܝ ܬܪܥܤܪ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Revelation 7:8",
      "text": "ܡܢ ܫܪܒܬܗ ܕܙܒܘܠܘܢ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܝܘܤܦ ܬܪܥܤܪ ܐܠܦܝܢ ܡܢ ܫܪܒܬܗ ܕܒܢܝܡܝܢ ܬܪܥܤܪ ܐܠܦܝܢ ܚܬܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Revelation 7:9",
      "text": "ܒܬܪܟܢ ܚܙܝܬ ܟܢܫܐ ܤܓܝܐܐ ܐܝܢܐ ܕܠܡܢܝܢܗ ܠܝܬ ܕܡܨܐ ܗܘܐ ܡܢ ܟܠ ܥܡ ܘܫܪܒܐ ܘܐܡܘܢ ܘܠܫܢܝܢ ܕܩܝܡܝܢ ܩܕܡ ܟܘܪܤܝܐ ܘܩܕܡܘܗܝ ܕܐܡܪܐ ܘܡܥܛܦܝܢ ܐܤܛܠܐ ܚܘܪܬܐ ܘܒܐܝܕܝܗܘܢ ܕܩܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Revelation 7:10",
      "text": "ܘܩܥܝܢ ܒܩܠܐ ܪܒܐ ܘܐܡܪܝܢ ܦܘܪܩܢܐ ܠܐܠܗܢ ܘܠܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܘܠܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Revelation 7:11",
      "text": "ܘܟܠܗܘܢ ܡܠܐܟܐ ܩܝܡܝܢ ܗܘܘ ܚܕܪܘܗܝ ܕܟܘܪܤܝܐ ܘܕܩܫܝܫܐ ܘܕܐܪܒܥ ܚܝܘܢ ܘܢܦܠܘ ܩܕܡ ܟܘܪܤܝܐ ܥܠ ܐܦܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Revelation 7:12",
      "text": "ܟܕ ܐܡܪܝܢ ܐܡܝܢ ܬܫܒܘܚܬܐ ܘܒܘܪܟܬܐ ܘܚܟܡܬܐ ܘܩܘܒܠ ܛܝܒܘܬܐ ܘܐܝܩܪܐ ܘܚܝܠܐ ܘܥܘܫܢܐ ܠܐܠܗܢ ܠܥܠܡ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Revelation 7:13",
      "text": "ܘܥܢܐ ܚܕ ܡܢ ܩܫܝܫܐ ܘܐܡܪ ܠܝ ܗܠܝܢ ܕܥܛܝܦܝܢ ܐܤܛܠܐ ܚܘܪܬܐ ܡܢ ܐܢܘܢ ܘܡܢ ܐܝܟܐ ܐܬܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Revelation 7:14",
      "text": "ܘܐܡܪܬ ܠܗ ܡܪܝ ܐܢܬ ܝܕܥ ܐܢܬ ܘܐܡܪ ܠܝ ܗܠܝܢ ܐܢܘܢ ܐܝܠܝܢ ܕܐܬܘ ܡܢ ܐܘܠܨܢܐ ܪܒܐ ܘܚܠܠܘ ܐܤܛܠܝܗܘܢ ܘܚܘܪܘ ܐܢܝܢ ܒܕܡܐ ܕܐܡܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Revelation 7:15",
      "text": "ܡܛܠ ܗܢܐ ܐܝܬܝܗܘܢ ܩܕܡ ܟܘܪܤܝܐ ܕܐܠܗܐ ܘܡܫܡܫܝܢ ܠܗ ܐܝܡܡܐ ܘܠܠܝܐ ܒܗܝܟܠܗ ܘܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܢܓܢ ܥܠܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Revelation 7:16",
      "text": "ܠܐ ܢܟܦܢܘܢ ܘܠܐ ܢܨܗܘܢ ܘܫܡܫܐ ܥܠܝܗܘܢ ܠܐ ܢܦܠ ܘܠܐ ܟܠ ܫܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.7.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Revelation 7:17",
      "text": "ܡܛܠ ܕܐܡܪܐ ܕܒܡܨܥܬ ܟܘܪܤܝܐ ܢܪܥܐ ܐܢܘܢ ܘܢܫܒܠ ܐܢܘܢ ܨܝܕ ܚܝܐ ܘܨܝܕ ܥܝܢܬܐ ܕܡܝܐ ܘܢܠܚܐ ܟܠ ܕܡܥܐ ܡܢ ܥܝܢܝܗܘܢ ܀",
      "paragraphStart": false
    }
  ]
}
