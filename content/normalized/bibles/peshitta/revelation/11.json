{
  "chapter": {
    "id": "peshitta:revelation.11",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 11,
    "referenceLabel": "Revelation 11",
    "summary": "Source text for Revelation 11 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.11.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Revelation 11:1",
      "text": "ܘܐܬܝܗܒ ܠܝ ܩܢܝܐ ܕܡܘܬܐ ܕܫܒܛܐ ܘܩܐܡ ܗܘܐ ܡܠܐܟܐ ܘܐܡܪ ܩܘܡ ܘܡܫܘܚ ܠܗܝܟܠܐ ܕܐܠܗܐ ܘܠܡܕܒܚܐ ܘܠܐܝܠܝܢ ܕܤܓܕܝܢ ܒܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.11.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Revelation 11:2",
      "text": "ܘܠܕܪܬܐ ܕܠܓܘ ܡܢ ܗܝܟܠܐ ܐܦܩ ܡܢ ܠܒܪ ܘܠܐ ܬܡܫܚܝܗ ܡܛܠ ܕܐܬܝܗܒܬ ܠܥܡܡܐ ܘܠܡܕܝܢܬܐ ܩܕܝܫܬܐ ܢܕܘܫܘܢ ܝܪܚܐ ܐܪܒܥܝܢ ܘܬܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Revelation 11:3",
      "text": "ܘܐܬܠ ܠܬܪܝܢ ܤܗܕܝ ܠܡܬܢܒܝܘ ܝܘܡܝܢ ܐܠܦ ܘܡܐܬܝܢ ܘܫܬܝܢ ܟܕ ܥܛܝܦܝܢ ܤܩܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Revelation 11:4",
      "text": "ܗܠܝܢ ܐܢܘܢ ܬܪܝܢ ܙܝܬܝܢ ܘܬܪܬܝܢ ܡܢܪܢ ܕܩܕܡ ܡܪܐ ܕܟܠܗ ܐܪܥܐ ܩܝܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Revelation 11:5",
      "text": "ܘܡܢ ܕܒܥܐ ܕܢܗܪ ܐܢܘܢ ܢܦܩܐ ܢܘܪܐ ܡܢ ܦܘܡܗܘܢ ܘܐܟܠܐ ܠܒܥܠܕܒܒܝܗܘܢ ܘܠܐܝܢܐ ܕܨܒܐ ܕܢܗܪ ܐܢܘܢ ܗܟܢ ܝܗܝܒ ܠܗܘܢ ܠܡܬܩܛܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Revelation 11:6",
      "text": "ܘܗܠܝܢ ܐܝܬ ܠܗܘܢ ܫܘܠܛܢܐ ܕܢܐܚܕܘܢ ܠܫܡܝܐ ܕܠܐ ܢܚܘܬ ܡܛܪܐ ܒܝܘܡܬܐ ܕܢܒܝܘܬܗܘܢ ܘܐܝܬ ܠܗܘܢ ܫܘܠܛܢܐ ܕܢܗܦܟܘܢ ܡܝܐ ܠܕܡܐ ܘܕܢܡܚܘܢ ܠܐܪܥܐ ܒܟܠ ܡܚܘܢ ܟܡܐ ܕܢܨܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Revelation 11:7",
      "text": "ܘܡܐ ܕܫܡܠܝܘ ܤܗܕܘܬܗܘܢ ܚܝܘܬܐ ܕܤܠܩܐ ܡܢ ܝܡܐ ܬܥܒܕ ܥܡܗܘܢ ܩܪܒܐ ܘܬܙܟܐ ܐܢܘܢ ܘܬܩܛܘܠ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Revelation 11:8",
      "text": "ܘܫܠܕܝܗܘܢ ܥܠ ܫܘܩܐ ܕܡܕܝܢܬܐ ܪܒܬܐ ܐܝܕܐ ܕܡܬܩܪܝܐ ܪܘܚܢܐܝܬ ܤܕܘܡ ܘܡܨܪܝܢ ܐܝܟܐ ܕܡܪܗܘܢ ܐܨܛܠܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Revelation 11:9",
      "text": "ܘܚܙܝܢ ܡܢ ܐܡܘܬܐ ܘܫܪܒܬܐ ܘܠܫܢܐ ܘܥܡܡܐ ܠܫܠܕܝܗܘܢ ܬܠܬܐ ܝܘܡܝܢ ܘܦܠܓܗ ܘܠܫܠܕܝܗܘܢ ܠܐ ܢܫܒܩܘܢ ܠܡܬܬܤܡܘ ܒܩܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Revelation 11:10",
      "text": "ܘܥܡܘܪܝܗ ܕܐܪܥܐ ܢܚܕܘܢ ܥܠܝܗܘܢ ܘܢܬܦܨܚܘܢ ܘܡܘܗܒܬܐ ܢܫܕܪܘܢ ܠܚܕܕܐ ܡܛܠ ܬܪܝܢ ܢܒܝܝܢ ܕܫܢܩܘ ܠܥܡܘܪܝܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Revelation 11:11",
      "text": "ܘܡܢ ܒܬܪ ܬܠܬܐ ܝܘܡܝܢ ܘܦܠܓܗ ܪܘܚܐ ܚܝܬܐ ܡܢ ܐܠܗܐ ܥܠܬ ܒܗܘܢ ܘܩܡܘ ܥܠ ܪܓܠܝܗܘܢ ܘܪܘܚܐ ܕܚܝܐ ܢܦܠܬ ܥܠܝܗܘܢ ܘܕܚܠܬܐ ܪܒܬܐ ܗܘܬ ܥܠ ܐܝܠܝܢ ܕܚܙܝܢ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Revelation 11:12",
      "text": "ܘܫܡܥܘ ܩܠܐ ܪܒܐ ܡܢ ܫܡܝܐ ܕܐܡܪ ܠܗܘܢ ܤܩܘ ܠܟܐ ܘܤܠܩܘ ܠܫܡܝܐ ܒܥܢܢܐ ܘܡܨܕܝܢ ܒܗܘܢ ܒܥܠܕܒܒܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Revelation 11:13",
      "text": "ܘܒܫܥܬܐ ܗܝ ܗܘܐ ܙܘܥܐ ܪܒܐ ܘܚܕ ܡܢ ܥܤܪܐ ܕܡܕܝܢܬܐ ܢܦܠܘ ܘܐܬܩܛܠܘ ܒܙܘܥܐ ܫܡܗܐ ܕܓܒܪܐ ܐܠܦܐ ܫܒܥܐ ܘܕܫܪܟܐ ܗܘܘ ܒܕܚܠܬܐ ܘܝܗܒܘܢ ܬܫܒܘܚܬܐ ܠܐܠܗܐ ܕܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Revelation 11:14",
      "text": "ܗܐ ܬܪܝܢ ܘܝ ܐܙܠܘ ܘܗܐ ܘܝ ܕܬܠܬܐ ܐܬܐ ܡܚܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Revelation 11:15",
      "text": "ܘܡܠܐܟܐ ܕܫܒܥܐ ܙܥܩ ܘܗܘܘ ܩܠܐ ܪܘܪܒܐ ܒܫܡܝܐ ܕܐܡܪܝܢ ܗܘܬ ܡܠܟܘܬܗ ܕܥܠܡܐ ܕܐܠܗܢ ܘܕܡܫܝܚܗ ܘܐܡܠܟ ܠܥܠܡ ܥܠܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Revelation 11:16",
      "text": "ܘܥܤܪܝܢ ܘܐܪܒܥܐ ܩܫܝܫܐ ܐܝܠܝܢ ܕܩܕܡ ܐܠܗܐ ܝܬܒܝܢ ܥܠ ܟܘܪܤܘܬܗܘܢ ܢܦܠܘ ܥܠ ܐܦܝܗܘܢ ܘܤܓܕܘ ܠܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Revelation 11:17",
      "text": "ܠܡܐܡܪ ܡܘܕܝܢܢ ܠܟ ܡܪܝܐ ܐܠܗܐ ܐܚܝܕ ܟܠ ܕܐܝܬܘܗܝ ܘܐܝܬܘܗܝ ܗܘܐ ܕܢܤܒܬ ܒܚܝܠܟ ܪܒܐ ܘܐܡܠܟܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Revelation 11:18",
      "text": "ܘܥܡܡܐ ܪܓܙܘ ܘܐܬܐ ܪܘܓܙܟ ܘܙܒܢܐ ܕܡܝܬܐ ܕܢܬܕܝܢܘܢ ܘܬܬܠ ܐܓܪܐ ܠܥܒܕܝܟ ܢܒܝܐ ܘܠܩܕܝܫܐ ܘܠܕܚܠܝ ܫܡܟ ܠܙܥܘܪܐ ܥܡ ܪܘܪܒܐ ܘܬܚܒܠ ܠܐܝܠܝܢ ܕܚܒܠܘ ܠܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.11.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Revelation 11:19",
      "text": "ܘܐܬܦܬܚ ܗܝܟܠܐ ܒܫܡܝܐ ܘܐܬܚܙܝܬ ܩܝܒܘܬܐ ܕܕܝܬܩܐ ܕܝܠܗ ܒܗܝܟܠܐ ܘܗܘܘ ܒܪܩܐ ܘܪܥܡܐ ܘܩܠܐ ܘܢܘܕܐ ܘܒܪܕܐ ܪܒܐ ܀",
      "paragraphStart": false
    }
  ]
}
