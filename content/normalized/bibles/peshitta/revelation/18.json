{
  "chapter": {
    "id": "peshitta:revelation.18",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 18,
    "referenceLabel": "Revelation 18",
    "summary": "Source text for Revelation 18 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.18.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 1,
      "referenceLabel": "Revelation 18:1",
      "text": "ܘܡܢ ܒܬܪ ܗܠܝܢ ܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܕܢܚܬ ܡܢ ܫܡܝܐ ܕܐܝܬ ܠܗ ܫܘܠܛܢܐ ܪܒܐ ܘܐܪܥܐ ܢܗܪܬ ܡܢ ܬܫܒܘܚܬܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.18.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 2,
      "referenceLabel": "Revelation 18:2",
      "text": "ܘܩܥܐ ܒܩܠܐ ܪܒܐ ܢܦܠܬ ܢܦܠܬ ܒܒܝܠ ܪܒܬܐ ܘܗܘܬ ܡܥܡܪܐ ܠܫܐܕܐ ܘܢܛܘܪܬܐ ܠܟܠ ܪܘܚܐ ܠܐ ܕܟܝܬܐ ܘܤܢܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 3,
      "referenceLabel": "Revelation 18:3",
      "text": "ܡܛܠ ܕܡܢ ܚܡܪܐ ܕܙܢܝܘܬܗ ܡܙܓܬ ܠܟܠܗܘܢ ܥܡܡܐ ܘܡܠܟܝܗ ܕܐܪܥܐ ܥܡܗ ܙܢܝܘ ܘܬܓܪܐ ܕܐܪܥܐ ܡܢ ܚܝܠܐ ܕܫܢܝܗ ܥܬܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 4,
      "referenceLabel": "Revelation 18:4",
      "text": "ܘܫܡܥܬ ܐܚܪܢܐ ܩܠܐ ܡܢ ܫܡܝܐ ܕܐܡܪ ܦܘܩܘ ܡܢ ܓܘܗ ܥܡܝ ܕܠܐ ܬܫܬܘܬܦܘܢ ܒܚܛܗܝܗ ܕܠܡܐ ܬܤܒܘܢ ܡܢ ܡܚܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 5,
      "referenceLabel": "Revelation 18:5",
      "text": "ܡܛܠ ܕܕܒܩܘ ܒܗ ܚܛܗܐ ܥܕܡܐ ܠܫܡܝܐ ܘܐܬܕܟܪ ܐܠܗܐ ܥܘܠܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 6,
      "referenceLabel": "Revelation 18:6",
      "text": "ܦܘܪܥܘܗ ܐܝܟܢܐ ܕܐܦ ܗܝ ܦܪܥܬ ܘܥܘܦܘ ܠܗ ܐܥܦܐ ܥܠ ܥܒܕܝܗ ܒܟܤܐ ܗܘ ܕܡܙܓܬ ܡܙܘܓܘ ܠܗ ܐܥܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 7,
      "referenceLabel": "Revelation 18:7",
      "text": "ܥܠ ܡܕܡ ܕܫܒܚܬ ܢܦܫܗ ܘܐܫܬܥܠܝܬ ܕܐܝܟ ܗܟܢ ܫܘܢܩܐ ܘܐܒܠܐ ܡܛܠ ܕܒܠܒܗ ܐܡܪܐ ܕܝܬܒܐ ܐܢܐ ܡܠܟܬܐ ܘܐܪܡܠܬܐ ܠܝܬܝ ܘܐܒܠܐ ܠܐ ܐܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 8,
      "referenceLabel": "Revelation 18:8",
      "text": "ܡܛܠܗܢܐ ܒܚܕ ܝܘܡܐ ܢܐܬܝܢ ܥܠܝܗ ܡܚܘܬܐ ܡܘܬܐ ܘܐܒܠܐ ܘܟܦܢܐ ܘܒܢܘܪܐ ܬܐܩܕ ܡܛܠ ܕܚܝܠܬܢ ܡܪܝܐ ܕܕܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 9,
      "referenceLabel": "Revelation 18:9",
      "text": "ܘܢܒܟܘܢܗ ܘܢܪܩܕܘܢ ܥܠܝܗ ܡܠܟܝܗ ܕܐܪܥܐ ܗܢܘܢ ܕܙܢܝܘ ܥܡܗ ܘܐܫܬܥܠܝܘ ܡܐ ܕܚܙܝܢ ܬܢܢܐ ܕܝܩܕܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 10,
      "referenceLabel": "Revelation 18:10",
      "text": "ܟܕ ܩܝܡܝܢ ܡܢ ܩܒܘܠ ܡܢ ܕܚܠܬܐ ܕܬܫܢܝܩܗ ܘܢܐܡܪܘܢ ܘܝ ܘܝ ܘܝ ܡܕܝܢܬܐ ܪܒܬܐ ܒܒܝܠ ܡܕܝܢܬܐ ܥܫܝܢܬܐ ܡܛܠ ܕܒܚܕܐ ܫܥܐ ܐܬܐ ܕܝܢܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 11,
      "referenceLabel": "Revelation 18:11",
      "text": "ܘܬܓܪܐ ܕܐܪܥܐ ܢܒܟܘܢ ܘܢܬܐܒܠܘܢ ܥܠܝܗ ܘܡܘܒܠܗܘܢ ܠܝܬ ܕܙܒܢ ܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 12,
      "referenceLabel": "Revelation 18:12",
      "text": "ܡܘܒܠܐ ܕܕܗܒܐ ܘܕܤܐܡܐ ܘܕܟܐܦܐ ܝܩܝܪܬܐ ܘܕܡܪܓܢܝܬܐ ܘܕܒܘܨܐ ܘܕܐܪܓܘܢܐ ܘܫܐܪܝܐ ܕܙܚܘܪܝܬܐ ܘܟܠ ܩܝܤ ܕܒܤܡܐ ܘܟܠ ܡܐܢ ܕܫܢܐ ܘܟܠ ܡܐܢ ܕܩܝܤܐ ܝܩܝܪܐ ܘܢܚܫܐ ܘܦܪܙܠܐ ܘܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 13,
      "referenceLabel": "Revelation 18:13",
      "text": "ܘܩܘܢܝܡܘܢ ܘܒܤܡܐ ܘܡܘܪܘܢ ܘܠܒܘܢܬܐ ܘܚܡܪܐ ܘܡܫܚܐ ܘܤܡܝܕܐ ܘܥܪܒܐ ܘܪܟܫܐ ܘܡܪܟܒܬܐ ܘܦܓܪܐ ܘܢܦܫܬܐ ܕܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 14,
      "referenceLabel": "Revelation 18:14",
      "text": "ܘܐܒܟܝ ܪܓܬܐ ܕܢܦܫܟܝ ܐܙܠ ܡܢܟܝ ܘܟܠ ܕܫܡܝܢ ܘܫܒܝܚ ܐܙܠ ܡܢܟܝ ܘܠܐ ܬܘܒ ܬܚܙܝܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.15",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 15,
      "referenceLabel": "Revelation 18:15",
      "text": "ܘܠܐ ܢܫܟܚܘܢ ܐܢܘܢ ܬܓܪܐ ܕܗܠܝܢ ܕܥܬܪܘ ܡܢܗ ܡܢ ܩܒܘܠ ܢܩܘܡܘܢ ܡܢ ܕܚܠܬܐ ܕܫܘܢܩܗ ܟܕ ܒܟܝܢ ܘܐܒܝܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.16",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 16,
      "referenceLabel": "Revelation 18:16",
      "text": "ܘܐܡܪܝܢ ܘܝ ܘܝ ܡܕܝܢܬܐ ܪܒܬܐ ܕܡܥܛܦܐ ܒܘܨܐ ܘܐܪܓܘܢܐ ܘܙܚܘܪܝܬܐ ܕܡܕܗܒܢ ܒܕܗܒܐ ܘܟܐܦܐ ܝܩܝܪܬܐ ܘܡܪܓܢܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.17",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 17,
      "referenceLabel": "Revelation 18:17",
      "text": "ܡܛܠ ܕܒܚܕܐ ܫܥܐ ܐܤܬܪܩ ܥܘܬܪܐ ܕܐܝܟ ܗܢܐ ܘܟܠ ܡܕܒܪܝ ܐܠܦܐ ܘܟܠ ܐܙܠܝ ܒܐܠܦܐ ܠܕܘܟܝܬܐ ܘܐܠܦܪܐ ܘܟܠ ܕܒܝܡܐ ܦܠܚܝܢ ܡܢ ܪܘܚܩܐ ܩܡܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.18",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 18,
      "referenceLabel": "Revelation 18:18",
      "text": "ܘܒܟܐܘܗ ܟܕ ܚܙܝܢ ܬܢܢܐ ܕܝܩܕܢܗ ܘܐܡܪܝܢ ܡܢ ܗܝ ܕܕܡܝܐ ܠܡܕܝܢܬܐ ܪܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.19",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 19,
      "referenceLabel": "Revelation 18:19",
      "text": "ܘܐܪܡܝܘ ܥܦܪܐ ܥܠ ܪܝܫܝܗܘܢ ܘܩܥܘ ܟܕ ܒܟܝܢ ܘܐܒܝܠܝܢ ܘܐܡܪܝܢ ܘܝ ܘܝ ܡܕܝܢܬܐ ܪܒܬܐ ܐܝܕܐ ܕܒܗ ܥܬܪܘ ܐܝܠܝܢ ܕܐܝܬ ܠܗܘܢ ܐܠܦܐ ܒܝܡܐ ܡܢ ܐܝܩܪܗ ܕܒܚܕܐ ܫܥܐ ܚܪܒܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.20",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 20,
      "referenceLabel": "Revelation 18:20",
      "text": "ܐܬܦܨܚܘ ܥܠܝܗ ܫܡܝܐ ܘܩܕܝܫܐ ܘܫܠܝܚܐ ܘܢܒܝܐ ܡܛܠ ܕܕܢ ܐܠܗܐ ܕܝܢܟܘܢ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.21",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 21,
      "referenceLabel": "Revelation 18:21",
      "text": "ܘܫܩܠ ܚܕ ܡܢ ܡܠܐܟܐ ܚܝܠܬܢܐ ܟܐܦܐ ܪܒܬܐ ܐܝܟ ܪܚܝܐ ܘܐܪܡܝ ܒܝܡܐ ܘܐܡܪ ܗܟܢܐ ܒܚܐܦܐ ܬܫܬܕܐ ܒܒܝܠ ܡܕܝܢܬܐ ܪܒܬܐ ܘܠܐ ܬܫܟܚ ܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.22",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 22,
      "referenceLabel": "Revelation 18:22",
      "text": "ܘܩܠܐ ܕܩܝܬܪܐ ܘܕܫܝܦܘܪܐ ܘܕܙܢܝ ܙܡܪܐ ܘܕܡܙܥܘܩܐ ܠܐ ܢܫܬܡܥ ܒܟܝ ܬܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.23",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 23,
      "referenceLabel": "Revelation 18:23",
      "text": "ܘܢܘܗܪܐ ܕܫܪܓܐ ܠܐ ܢܬܚܙܐ ܠܟܝ ܬܘܒ ܘܩܠܐ ܕܚܬܢܐ ܘܩܠܐ ܕܟܠܬܐ ܠܐ ܢܫܬܡܥ ܒܟܝ ܬܘܒ ܡܛܠ ܕܬܓܪܝܟܝ ܐܝܬ ܗܘܘ ܪܘܪܒܢܝܗ ܕܐܪܥܐ ܡܛܠ ܕܒܚܪܫܝܟܝ ܐܛܥܝܬܝ ܠܟܠܗܘܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.18.24",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 18,
      "verseNumber": 24,
      "referenceLabel": "Revelation 18:24",
      "text": "ܘܒܗ ܐܫܬܟܚ ܕܡܐ ܕܢܒܝܐ ܘܩܕܝܫܐ ܕܩܛܝܠܝܢ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    }
  ]
}
