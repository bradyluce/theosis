{
  "chapter": {
    "id": "peshitta:revelation.5",
    "translationId": "peshitta",
    "bookSlug": "revelation",
    "chapterNumber": 5,
    "referenceLabel": "Revelation 5",
    "summary": "Source text for Revelation 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:revelation.5.1",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Revelation 5:1",
      "text": "ܘܚܙܝܬ ܥܠ ܝܡܝܢܗ ܕܗܘ ܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܟܬܒܐ ܕܪܫܝܡ ܡܢ ܠܓܘ ܘܡܢ ܠܒܪ ܘܛܒܝܥ ܛܒܥܐ ܫܒܥܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:revelation.5.2",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Revelation 5:2",
      "text": "ܘܚܙܝܬ ܐܚܪܢܐ ܡܠܐܟܐ ܚܝܠܬܢܐ ܕܡܟܪܙ ܒܩܠܐ ܪܡܐ ܡܢ ܫܘܐ ܠܡܦܬܚ ܟܬܒܐ ܘܠܡܫܪܐ ܛܒܥܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.3",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Revelation 5:3",
      "text": "ܘܠܝܬ ܕܐܬܡܨܝ ܒܫܡܝܐ ܘܠܐ ܒܐܪܥܐ ܘܠܐ ܕܠܬܚܬ ܡܢ ܐܪܥܐ ܠܡܦܬܚ ܠܟܬܒܐ ܘܠܡܫܪܐ ܛܒܥܘܗܝ ܘܠܡܚܙܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.4",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Revelation 5:4",
      "text": "ܘܒܟܐ ܗܘܝܬ ܤܓܝ ܡܛܠ ܕܠܝܬ ܕܐܫܬܟܚ ܕܫܘܐ ܠܡܦܬܚ ܠܟܬܒܐ ܘܠܡܫܪܐ ܛܒܥܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.5",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Revelation 5:5",
      "text": "ܘܚܕ ܡܢ ܩܫܝܫܐ ܐܡܪ ܠܝ ܠܐ ܬܒܟܐ ܗܐ ܙܟܐ ܐܪܝܐ ܡܢ ܫܒܛܐ ܕܝܗܘܕܐ ܥܩܪܐ ܕܕܘܝܕ ܢܦܬܚ ܟܬܒܐ ܘܛܒܥܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.6",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Revelation 5:6",
      "text": "ܘܚܙܝܬ ܒܡܨܥܬ ܟܘܪܤܝܐ ܘܕܐܪܒܥ ܚܝܘܢ ܘܕܩܫܝܫܐ ܐܡܪܐ ܕܩܐܡ ܐܝܟ ܢܟܝܤܐ ܘܐܝܬ ܠܗ ܩܪܢܬܐ ܫܒܥ ܘܥܝܢܐ ܫܒܥ ܐܝܠܝܢ ܕܐܝܬܝܗܝܢ ܫܒܥ ܪܘܚܐ ܕܐܠܗܐ ܕܡܫܬܕܪܢ ܠܟܠܗ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.7",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Revelation 5:7",
      "text": "ܘܐܬܐ ܘܢܤܒ ܟܬܒܐ ܡܢ ܐܝܕܗ ܕܗܘ ܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.8",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Revelation 5:8",
      "text": "ܘܟܕ ܫܩܠܗ ܠܟܬܒܐ ܐܪܒܥ ܚܝܘܢ ܘܥܤܪܝܢ ܘܐܪܒܥܐ ܩܫܝܫܝܢ ܢܦܠܘ ܩܕܡܘܗܝ ܕܐܡܪܐ ܟܕ ܐܝܬ ܠܟܠܚܕ ܚܕ ܡܢܗܘܢ ܩܝܬܪܐ ܘܙܒܘܪܐ ܕܕܗܒܐ ܕܡܠܝܐ ܒܤܡܐ ܐܝܠܝܢ ܕܐܝܬܝܗܝܢ ܨܠܘܬܐ ܕܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.9",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Revelation 5:9",
      "text": "ܕܡܫܒܚܝܢ ܬܫܒܘܚܬܐ ܚܕܬܐ ܘܐܡܪܝܢ ܫܘܝܬ ܗܘ ܠܡܤܒܝܘܗܝ ܠܟܬܒܐ ܘܠܡܫܪܐ ܛܒܥܘܗܝ ܥܠ ܕܐܬܢܟܤܬ ܘܙܒܢܬܢ ܒܕܡܟ ܠܐܠܗܐ ܡܢ ܟܠ ܫܪܒܬܐ ܘܥܡܡܐ ܘܐܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.10",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Revelation 5:10",
      "text": "ܘܥܒܕܬ ܐܢܘܢ ܠܐܠܗܢ ܡܠܟܘܬܐ ܘܟܗܢܐ ܘܡܠܟܐ ܘܢܡܠܟܘܢ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.11",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Revelation 5:11",
      "text": "ܘܚܙܝܬ ܘܫܡܥܬ ܐܝܟ ܩܠܐ ܕܡܠܐܟܐ ܤܓܝܐܐ ܚܕܪܝ ܟܘܪܤܝܐ ܘܕܚܝܘܬܐ ܘܕܩܫܝܫܐ ܘܐܝܬܘܗܝ ܗܘܐ ܡܢܝܢܗܘܢ ܪܒܘ ܪܒܘܢ ܘܐܠܦ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.12",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Revelation 5:12",
      "text": "ܘܐܡܪܝܢ ܒܩܠܐ ܪܡܐ ܫܘܝܬ ܗܘ ܐܡܪܐ ܢܟܝܤܐ ܠܡܤܒ ܚܝܠܐ ܘܥܘܬܪܐ ܘܚܟܡܬܐ ܘܥܘܫܢܐ ܘܐܝܩܪܐ ܘܬܫܒܘܚܬܐ ܘܒܘܪܟܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.13",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Revelation 5:13",
      "text": "ܘܟܠ ܒܪܝܬܐ ܕܒܫܡܝܐ ܘܒܐܪܥܐ ܘܕܠܬܚܬ ܡܢ ܐܪܥܐ ܘܕܒܝܡܐ ܐܝܬܝܗ ܘܟܠ ܕܒܗܘܢ ܘܫܡܥܬ ܕܐܡܪܝܢ ܠܕܝܬܒ ܥܠ ܟܘܪܤܝܐ ܘܠܐܡܪܐ ܕܒܘܪܟܬܐ ܘܐܝܩܪܐ ܘܬܫܒܘܚܬܐ ܘܐܘܚܕܢܐ ܠܥܠܡ ܥܠܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:revelation.5.14",
      "translationId": "peshitta",
      "bookSlug": "revelation",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Revelation 5:14",
      "text": "ܘܐܪܒܥ ܚܝܘܢ ܕܐܡܪܢ ܐܡܝܢ ܘܩܫܝܫܐ ܢܦܠܘ ܘܤܓܕܘ ܀",
      "paragraphStart": false
    }
  ]
}
