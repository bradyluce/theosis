{
  "chapter": {
    "id": "peshitta:titus.1",
    "translationId": "peshitta",
    "bookSlug": "titus",
    "chapterNumber": 1,
    "referenceLabel": "Titus 1",
    "summary": "Source text for Titus 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:titus.1.1",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Titus 1:1",
      "text": "ܦܘܠܘܤ ܥܒܕܗ ܕܐܠܗܐ ܘܫܠܝܚܗ ܕܝܫܘܥ ܡܫܝܚܐ ܒܗܝܡܢܘܬܐ ܕܓܒܝܐ ܕܐܠܗܐ ܘܝܕܥܬܐ ܕܫܪܪܐ ܕܒܕܚܠܬ ܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:titus.1.2",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Titus 1:2",
      "text": "ܥܠ ܤܒܪܐ ܕܚܝܐ ܕܠܥܠܡ ܕܡܠܟ ܐܠܗܐ ܫܪܝܪܐ ܩܕܡ ܙܒܢܘܗܝ ܕܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.3",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Titus 1:3",
      "text": "ܘܓܠܐ ܡܠܬܗ ܒܙܒܢܗ ܒܝܕ ܟܪܘܙܘܬܢ ܗܝ ܕܐܬܗܝܡܢܬ ܐܢܐ ܒܦܘܩܕܢܐ ܕܐܠܗܐ ܡܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.4",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Titus 1:4",
      "text": "ܠܛܛܘܤ ܒܪܐ ܫܪܝܪܐ ܒܗܝܡܢܘܬܐ ܕܓܘܐ ܛܝܒܘܬܐ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܐ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܡܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.5",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Titus 1:5",
      "text": "ܡܛܠܗܢܐ ܗܘ ܫܒܩܬܟ ܗܘܝܬ ܒܩܪܛܐ ܕܐܝܠܝܢ ܕܚܤܝܪܢ ܬܬܩܢ ܘܬܩܝܡ ܩܫܝܫܐ ܒܡܕܝܢܐ ܡܕܝܢܐ ܐܝܟܢܐ ܕܦܩܕܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.6",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Titus 1:6",
      "text": "ܐܝܢܐ ܕܕܠܐ ܪܫܝܢ ܗܘ ܘܗܘܐ ܒܥܠܐ ܕܚܕܐ ܐܢܬܬܐ ܘܐܝܬ ܠܗ ܒܢܝܐ ܡܗܝܡܢܐ ܕܠܐ ܡܨܚܝܢ ܘܠܐ ܐܝܬܝܗܘܢ ܕܠܐ ܫܘܥܒܕ ܒܐܤܘܛܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.7",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Titus 1:7",
      "text": "ܚܝܒ ܗܘ ܓܝܪ ܩܫܝܫܐ ܕܢܗܘܐ ܕܠܐ ܪܫܝܢ ܐܝܟ ܪܒܝܬܐ ܕܐܠܗܐ ܘܠܐ ܢܗܘܐ ܡܬܕܒܪ ܒܪܥܝܢ ܢܦܫܗ ܘܠܐ ܢܗܘܐ ܚܡܬܢ ܘܠܐ ܢܗܘܐ ܥܒܪ ܥܠ ܚܡܪܐ ܘܠܐ ܬܗܘܐ ܪܗܛܐ ܐܝܕܗ ܠܡܡܚܐ ܘܠܐ ܢܗܘܐ ܪܚܡ ܝܘܬܪܢܐ ܛܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.8",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Titus 1:8",
      "text": "ܐܠܐ ܢܗܘܐ ܪܚܡ ܐܟܤܢܝܐ ܘܢܗܘܐ ܪܚܡ ܛܒܬܐ ܘܢܗܘܐ ܢܟܦ ܘܢܗܘܐ ܟܐܝܢ ܘܢܗܘܐ ܚܤܝܐ ܘܠܒܝܟ ܢܦܫܗ ܡܢ ܪܓܝܓܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.9",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Titus 1:9",
      "text": "ܘܒܛܝܠ ܠܗ ܥܠ ܝܘܠܦܢܐ ܕܡܠܬܐ ܕܗܝܡܢܘܬܐ ܕܢܫܟܚ ܐܦ ܠܡܒܝܐܘ ܒܝܘܠܦܢܗ ܚܠܝܡܐ ܘܠܡܟܤܘ ܠܐܝܠܝܢ ܕܡܬܚܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.10",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Titus 1:10",
      "text": "ܐܝܬ ܓܝܪ ܤܓܝܐܐ ܕܠܐ ܡܫܬܥܒܕܝܢ ܘܤܪܝܩܢ ܡܠܝܗܘܢ ܘܡܛܥܝܢ ܪܥܝܢܐ ܕܒܢܝܢܫܐ ܝܬܝܪܐܝܬ ܐܝܠܝܢ ܕܡܢ ܓܙܘܪܬܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.11",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Titus 1:11",
      "text": "ܗܢܘܢ ܕܘܠܐ ܠܡܤܟܪܘ ܦܘܡܗܘܢ ܒܬܐ ܓܝܪ ܤܓܝܐܐ ܡܚܒܠܝܢ ܘܡܠܦܝܢ ܡܕܡ ܕܠܐ ܘܠܐ ܡܛܠ ܝܘܬܪܢܐ ܛܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.12",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Titus 1:12",
      "text": "ܐܡܪ ܐܢܫ ܡܢܗܘܢ ܢܒܝܐ ܕܝܠܗܘܢ ܕܒܢܝ ܩܪܛܐ ܒܟܠܙܒܢ ܕܓܠܝܢ ܐܢܘܢ ܚܝܘܬܐ ܒܝܫܬܐ ܘܟܪܤܬܐ ܒܛܝܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.13",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Titus 1:13",
      "text": "ܘܫܪܝܪܐܝܬ ܐܝܬܝܗ ܤܗܕܘܬܐ ܗܕܐ ܡܛܠ ܗܢܐ ܩܫܝܐܝܬ ܗܘܝܬ ܡܟܤ ܠܗܘܢ ܕܢܗܘܘܢ ܚܠܝܡܝܢ ܒܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.14",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Titus 1:14",
      "text": "ܘܠܐ ܢܬܪܡܘܢ ܠܫܘܥܝܬܐ ܕܝܗܘܕܝܐ ܘܠܦܘܩܕܐ ܕܒܢܝܢܫܐ ܕܤܢܝܢ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.15",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Titus 1:15",
      "text": "ܟܠܡܕܡ ܓܝܪ ܕܟܐ ܗܘ ܠܕܟܝܐ ܠܐܝܠܝܢ ܕܝܢ ܕܡܤܝܒܝܢ ܘܠܐ ܡܗܝܡܢܝܢ ܡܕܡ ܕܕܟܐ ܠܝܬ ܠܗܘܢ ܐܠܐ ܡܤܝܒ ܗܘ ܪܥܝܢܗܘܢ ܘܬܐܪܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.1.16",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Titus 1:16",
      "text": "ܘܡܘܕܝܢ ܕܝܕܥܝܢ ܠܐܠܗܐ ܒܥܒܕܝܗܘܢ ܕܝܢ ܟܦܪܝܢ ܒܗ ܘܐܝܬܝܗܘܢ ܤܢܝܐܐ ܘܕܠܐ ܦܝܤ ܘܡܤܠܝܐ ܠܟܠ ܥܒܕ ܛܒ ܀",
      "paragraphStart": false
    }
  ]
}
