    "bookSlug": "titus",
    "chapterNumber": 3,
    "referenceLabel": "Titus 3",
    "summary": "Source text for Titus 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:titus.3.1",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Titus 3:1",
      "text": "ܘܗܘܝܬ ܡܥܗܕ ܠܗܘܢ ܕܠܪܫܐ ܘܠܫܠܝܛܢܐ ܢܫܬܡܥܘܢ ܘܢܫܬܥܒܕܘܢ ܘܕܢܗܘܘܢ ܥܬܝܕܝܢ ܠܟܠ ܥܒܕ ܛܒ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:titus.3.2",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Titus 3:2",
      "text": "ܘܥܠ ܐܢܫ ܠܐ ܢܓܕܦܘܢ ܘܠܐ ܢܗܘܘܢ ܡܬܟܬܫܝܢ ܐܠܐ ܢܗܘܘܢ ܡܟܝܟܝܢ ܘܒܟܠܡܕܡ ܢܚܘܘܢ ܒܤܝܡܘܬܗܘܢ ܠܘܬ ܟܠܗܘܢ ܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.3",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Titus 3:3",
      "text": "ܐܦ ܚܢܢ ܓܝܪ ܡܢ ܩܕܝܡ ܕܠܐ ܪܥܝܢܐ ܗܘܝܢ ܘܕܠܐ ܦܝܤܐ ܘܛܥܝܢ ܗܘܝܢ ܘܡܫܥܒܕܝܢ ܗܘܝܢ ܠܐܪܓܝܓܬܐ ܡܫܚܠܦܬܐ ܘܒܒܝܫܘܬܐ ܘܒܚܤܡܐ ܡܬܗܦܟܝܢ ܗܘܝܢ ܘܤܢܝܐܝܝܢ ܗܘܝܢ ܐܦ ܚܕ ܠܚܕ ܤܢܝܢ ܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.4",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Titus 3:4",
      "text": "ܟܕ ܕܝܢ ܐܬܓܠܝܬ ܒܤܝܡܘܬܗ ܘܡܪܚܡܢܘܬܗ ܕܐܠܗܐ ܡܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.5",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Titus 3:5",
      "text": "ܠܐ ܒܥܒܕܐ ܕܙܕܝܩܘܬܐ ܕܥܒܕܢ ܐܠܐ ܒܪܚܡܘܗܝ ܕܝܠܗ ܐܚܝܢ ܒܤܚܬܐ ܕܡܘܠܕܐ ܕܡܢ ܕܪܝܫ ܘܒܚܘܕܬܐ ܕܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.6",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Titus 3:6",
      "text": "ܗܝ ܕܐܫܕ ܥܠܝܢ ܥܬܝܪܐܝܬ ܒܝܕ ܝܫܘܥ ܡܫܝܚܐ ܡܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.7",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Titus 3:7",
      "text": "ܕܒܛܝܒܘܬܗ ܢܙܕܕܩ ܘܢܗܘܐ ܝܪܬܐ ܒܤܒܪܐ ܒܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.8",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Titus 3:8",
      "text": "ܡܗܝܡܢܐ ܗܝ ܡܠܬܐ ܘܒܗܠܝܢ ܨܒܐ ܐܢܐ ܕܐܦ ܐܢܬ ܗܘܝܬ ܡܫܪܪ ܠܗܘܢ ܕܢܬܒܛܠ ܠܗܘܢ ܠܡܦܠܚ ܥܒܕܐ ܛܒܐ ܐܝܠܝܢ ܕܗܝܡܢܘ ܒܐܠܗܐ ܗܠܝܢ ܐܢܝܢ ܛܒܢ ܘܡܘܬܪܢ ܠܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.9",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Titus 3:9",
      "text": "ܡܢ ܒܥܬܐ ܕܝܢ ܤܟܠܬܐ ܘܡܢ ܬܫܥܝܬܐ ܕܫܪܒܬܐ ܘܡܢ ܚܪܝܢܐ ܘܡܢ ܬܟܬܘܫܐ ܕܤܦܪܐ ܐܫܬܐܠ ܝܘܬܪܢ ܓܝܪ ܠܝܬ ܒܗܝܢ ܘܤܪܝܩܢ ܐܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.10",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Titus 3:10",
      "text": "ܡܢ ܓܒܪܐ ܗܪܤܝܘܛܐ ܡܢ ܒܬܪ ܚܕܐ ܙܒܢ ܘܬܪܬܝܢ ܕܡܪܬܐ ܐܢܬ ܠܗ ܐܫܬܐܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.11",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Titus 3:11",
      "text": "ܘܗܘܝܬ ܝܕܥ ܕܡܢ ܕܗܟܢܐ ܗܘ ܡܥܩܡ ܗܘ ܘܚܛܐ ܘܗܘ ܚܝܒ ܢܦܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.12",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Titus 3:12",
      "text": "ܡܐ ܕܫܕܪܬ ܠܘܬܟ ܠܐܪܛܡܐ ܐܘ ܠܛܘܟܝܩܘܤ ܢܬܒܛܠ ܠܟ ܕܬܐܬܐ ܠܘܬܝ ܠܢܝܩܦܘܠܝܤ ܬܡܢ ܓܝܪ ܤܡܬ ܒܪܥܝܢܝ ܕܐܤܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.13",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Titus 3:13",
      "text": "ܥܠ ܙܢܐ ܕܝܢ ܤܦܪܐ ܘܥܠ ܐܦܠܘ ܢܬܒܛܠ ܠܟ ܕܬܠܘܐ ܐܢܘܢ ܫܦܝܪ ܕܡܕܡ ܠܐ ܢܚܤܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.14",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Titus 3:14",
      "text": "ܘܢܐܠܦܘܢ ܐܦ ܐܝܠܝܢ ܕܕܝܠܢ ܐܢܘܢ ܕܢܗܘܘܢ ܦܠܚܝܢ ܥܒܕܐ ܛܒܐ ܒܨܒܘܬܐ ܕܐܠܨܢ ܕܠܐ ܢܗܘܘܢ ܕܠܐ ܦܐܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.3.15",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Titus 3:15",
      "text": "ܫܐܠܝܢ ܒܫܠܡܟ ܟܠܗܘܢ ܐܝܠܝܢ ܕܥܡܝ ܐܢܘܢ ܫܐܠ ܒܫܠܡܐ ܕܟܠܗܘܢ ܐܝܠܝܢ ܕܪܚܡܝܢ ܠܢ ܒܗܝܡܢܘܬܐ ܛܝܒܘܬܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
