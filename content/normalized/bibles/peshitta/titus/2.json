    "chapterNumber": 2,
    "referenceLabel": "Titus 2",
    "summary": "Source text for Titus 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:titus.2.1",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Titus 2:1",
      "text": "ܐܢܬ ܕܝܢ ܡܠܠ ܡܕܡ ܕܝܐܐ ܠܝܘܠܦܢܐ ܚܠܝܡܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:titus.2.2",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Titus 2:2",
      "text": "ܘܐܠܦ ܕܢܗܘܘܢ ܩܫܝܫܐ ܥܝܪܝܢ ܒܪܥܝܢܝܗܘܢ ܘܢܗܘܘܢ ܢܟܦܝܢ ܘܢܗܘܘܢ ܕܟܝܢ ܘܢܗܘܘܢ ܚܠܝܡܝܢ ܒܗܝܡܢܘܬܐ ܘܒܚܘܒܐ ܘܒܡܤܝܒܪܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.3",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Titus 2:3",
      "text": "ܘܐܦ ܩܫܝܫܬܐ ܗܟܢܐ ܕܢܗܘܝܢ ܒܐܤܟܡܐ ܕܝܐܐ ܠܕܚܠܬ ܐܠܗܐ ܘܠܐ ܢܗܘܝܢ ܐܟܠܢ ܩܪܨܐ ܘܠܐ ܢܗܘܝܢ ܡܫܥܒܕܢ ܠܚܡܪܐ ܤܓܝܐܐ ܘܢܗܘܝܢ ܡܠܦܢ ܫܦܝܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.4",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Titus 2:4",
      "text": "ܘܡܢܟܦܢ ܠܐܝܠܝܢ ܕܛܠܝܢ ܕܢܪܚܡܢ ܒܥܠܝܗܝܢ ܘܒܢܝܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.5",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Titus 2:5",
      "text": "ܘܢܗܘܝܢ ܢܟܦܢ ܘܩܕܝܫܢ ܘܢܗܘܝܢ ܝܨܦܢ ܫܦܝܪ ܕܒܬܝܗܝܢ ܘܡܫܬܥܒܕܢ ܠܒܥܠܝܗܝܢ ܕܠܐ ܐܢܫ ܢܓܕܦ ܥܠ ܡܠܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.6",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Titus 2:6",
      "text": "ܘܡܢ ܐܝܠܝܢ ܕܛܠܝܢ ܗܟܢܐ ܒܥܝ ܕܢܗܘܘܢ ܢܟܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.7",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Titus 2:7",
      "text": "ܒܟܠܡܕܡ ܕܝܢ ܕܡܘܬܐ ܒܢܦܫܟ ܚܘܐ ܒܟܠ ܥܒܕܐ ܛܒܐ ܘܒܡܠܦܢܘܬܟ ܬܗܘܐ ܠܟ ܡܠܬܐ ܚܠܝܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.8",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Titus 2:8",
      "text": "ܕܢܟܦܐ ܘܠܐ ܡܚܒܠܐ ܘܠܐ ܐܢܫ ܒܤܪ ܠܗ ܕܐܝܢܐ ܕܩܐܡ ܠܩܘܒܠܢ ܢܒܗܬ ܟܕ ܠܐ ܢܫܟܚ ܕܢܐܡܪ ܥܠܝܢ ܡܕܡ ܕܤܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.9",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Titus 2:9",
      "text": "ܥܒܕܐ ܠܡܪܝܗܘܢ ܢܫܬܥܒܕܘܢ ܒܟܠܡܕܡ ܘܢܫܬܦܪܘܢ ܘܠܐ ܗܘܘ ܡܥܨܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.10",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Titus 2:10",
      "text": "ܘܠܐ ܗܘܘ ܓܢܒܝܢ ܐܠܐ ܢܚܘܘܢ ܫܪܪܗܘܢ ܛܒܐ ܒܟܠܡܕܡ ܕܢܨܒܬܘܢ ܒܟܠܡܕܡ ܝܘܠܦܢܗ ܕܐܠܗܐ ܡܚܝܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.11",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Titus 2:11",
      "text": "ܐܬܓܠܝܬ ܓܝܪ ܛܝܒܘܬܗ ܕܐܠܗܐ ܡܚܝܬ ܟܠ ܠܒܢܝܢܫܐ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.12",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Titus 2:12",
      "text": "ܘܪܕܝܐ ܠܢ ܕܢܟܦܘܪ ܒܪܘܫܥܐ ܘܒܪܓܝܓܬܐ ܕܥܠܡܐ ܘܢܚܐ ܒܥܠܡܐ ܗܢܐ ܒܢܟܦܘܬܐ ܘܒܟܐܢܘܬܐ ܘܒܕܚܠܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.13",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Titus 2:13",
      "text": "ܟܕ ܡܤܟܝܢܢ ܠܤܒܪܐ ܒܪܝܟܐ ܘܠܓܠܝܢܐ ܕܬܫܒܘܚܬܗ ܕܐܠܗܐ ܪܒܐ ܘܡܚܝܢܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.14",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Titus 2:14",
      "text": "ܕܗܘ ܝܗܒ ܢܦܫܗ ܚܠܦܝܢ ܕܢܦܪܩܢ ܡܢ ܟܠ ܥܘܠܐ ܘܢܕܟܝܢ ܠܢܦܫܗ ܥܡܐ ܚܕܬܐ ܕܚܤܡ ܒܥܒܕܐ ܛܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:titus.2.15",
      "translationId": "peshitta",
      "bookSlug": "titus",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Titus 2:15",
      "text": "ܗܠܝܢ ܡܠܠ ܘܒܥܝ ܘܟܘܢ ܒܟܠ ܦܘܩܕܢ ܘܠܐ ܐܢܫ ܢܒܤܐ ܒܟ ܀",
      "paragraphStart": false
    }
  ]
}
