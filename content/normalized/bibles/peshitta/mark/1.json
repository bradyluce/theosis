{
  "chapter": {
    "id": "peshitta:mark.1",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 1,
    "referenceLabel": "Mark 1",
    "summary": "Source text for Mark 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.1.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Mark 1:1",
      "text": "ܪܫܐ ܕܐܘܢܓܠܝܘܢ ܕܝܫܘܥ ܡܫܝܚܐ ܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.1.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Mark 1:2",
      "text": "ܐܝܟ ܕܟܬܝܒ ܒܐܫܥܝܐ ܢܒܝܐ ܗܐ ܡܫܕܪ ܐܢܐ ܡܠܐܟܝ ܩܕܡ ܦܪܨܘܦܟ ܕܢܬܩܢ ܐܘܪܚܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Mark 1:3",
      "text": "ܩܠܐ ܕܩܪܐ ܒܡܕܒܪܐ ܛܝܒܘ ܐܘܪܚܗ ܕܡܪܝܐ ܘܐܫܘܘ ܫܒܝܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Mark 1:4",
      "text": "ܗܘܐ ܝܘܚܢܢ ܒܡܕܒܪܐ ܡܥܡܕ ܘܡܟܪܙ ܡܥܡܘܕܝܬܐ ܕܬܝܒܘܬܐ ܠܫܘܒܩܢܐ ܕܚܛܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Mark 1:5",
      "text": "ܘܢܦܩܐ ܗܘܬ ܠܘܬܗ ܟܠܗ ܟܘܪ ܕܝܗܘܕ ܘܟܠܗܘܢ ܒܢܝ ܐܘܪܫܠܡ ܘܡܥܡܕ ܗܘܐ ܠܗܘܢ ܒܝܘܪܕܢܢ ܟܕ ܡܘܕܝܢ ܒܚܛܗܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Mark 1:6",
      "text": "ܗܘ ܕܝܢ ܝܘܚܢܢ ܠܒܝܫ ܗܘܐ ܠܒܘܫܐ ܕܤܥܪܐ ܕܓܡܠܐ ܘܐܤܝܪ ܗܘܐ ܥܪܩܬܐ ܕܡܫܟܐ ܒܚܨܘܗܝ ܘܡܐܟܘܠܬܗ ܐܝܬܝܗ ܗܘܬ ܩܡܨܐ ܘܕܒܫܐ ܕܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Mark 1:7",
      "text": "ܘܡܟܪܙ ܗܘܐ ܘܐܡܪ ܗܐ ܐܬܐ ܒܬܪܝ ܕܚܝܠܬܢ ܡܢܝ ܗܘ ܕܠܐ ܫܘܐ ܐܢܐ ܕܐܓܗܢ ܐܫܪܐ ܥܪܩܐ ܕܡܤܢܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Mark 1:8",
      "text": "ܐܢܐ ܐܥܡܕܬܟܘܢ ܒܡܝܐ ܗܘ ܕܝܢ ܢܥܡܕܟܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Mark 1:9",
      "text": "ܘܗܘܐ ܒܝܘܡܬܐ ܗܢܘܢ ܐܬܐ ܝܫܘܥ ܡܢ ܢܨܪܬ ܕܓܠܝܠܐ ܘܐܬܥܡܕ ܒܝܘܪܕܢܢ ܡܢ ܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Mark 1:10",
      "text": "ܘܡܚܕܐ ܕܤܠܩ ܡܢ ܡܝܐ ܚܙܐ ܕܐܤܬܕܩܘ ܫܡܝܐ ܘܪܘܚܐ ܐܝܟ ܝܘܢܐ ܕܢܚܬܬ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Mark 1:11",
      "text": "ܘܩܠܐ ܗܘܐ ܡܢ ܫܡܝܐ ܐܢܬ ܗܘ ܒܪܝ ܚܒܝܒܐ ܒܟ ܐܨܛܒܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Mark 1:12",
      "text": "ܘܡܚܕܐ ܐܦܩܬܗ ܪܘܚܐ ܠܡܕܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Mark 1:13",
      "text": "ܘܗܘܐ ܬܡܢ ܒܡܕܒܪܐ ܝܘܡܬܐ ܐܪܒܥܝܢ ܟܕ ܡܬܢܤܐ ܡܢ ܤܛܢܐ ܘܐܝܬܘܗܝ ܗܘܐ ܥܡ ܚܝܘܬܐ ܘܡܫܡܫܝܢ ܗܘܘ ܠܗ ܡܠܐܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Mark 1:14",
      "text": "ܒܬܪ ܕܐܫܬܠܡ ܕܝܢ ܝܘܚܢܢ ܐܬܐ ܠܗ ܝܫܘܥ ܠܓܠܝܠܐ ܘܡܟܪܙ ܗܘܐ ܤܒܪܬܐ ܕܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Mark 1:15",
      "text": "ܘܐܡܪ ܫܠܡ ܠܗ ܙܒܢܐ ܘܡܛܬ ܡܠܟܘܬܐ ܕܐܠܗܐ ܬܘܒܘ ܘܗܝܡܢܘ ܒܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Mark 1:16",
      "text": "ܘܟܕ ܡܗܠܟ ܚܕܪܝ ܝܡܐ ܕܓܠܝܠܐ ܚܙܐ ܠܫܡܥܘܢ ܘܠܐܢܕܪܐܘܤ ܐܚܘܗܝ ܕܪܡܝܢ ܡܨܝܕܬܐ ܒܝܡܐ ܐܝܬܝܗܘܢ ܗܘܘ ܓܝܪ ܨܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Mark 1:17",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܬܘ ܒܬܪܝ ܘܐܥܒܕܟܘܢ ܨܝܕܐ ܕܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Mark 1:18",
      "text": "ܘܡܚܕܐ ܫܒܩܘ ܡܨܝܕܬܗܘܢ ܘܐܙܠܘ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Mark 1:19",
      "text": "ܘܟܕ ܥܒܪ ܩܠܝܠ ܚܙܐ ܠܝܥܩܘܒ ܒܪ ܙܒܕܝ ܘܠܝܘܚܢܢ ܐܚܘܗܝ ܘܐܦ ܠܗܘܢ ܒܤܦܝܢܬܐ ܕܡܬܩܢܝܢ ܡܨܝܕܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Mark 1:20",
      "text": "ܘܩܪܐ ܐܢܘܢ ܘܡܚܕܐ ܫܒܩܘ ܠܙܒܕܝ ܐܒܘܗܘܢ ܒܤܦܝܢܬܐ ܥܡ ܐܓܝܪܐ ܘܐܙܠܘ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Mark 1:21",
      "text": "ܘܟܕ ܥܠܘ ܠܟܦܪܢܚܘܡ ܡܚܕܐ ܡܠܦ ܗܘܐ ܒܫܒܐ ܒܟܢܘܫܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Mark 1:22",
      "text": "ܘܬܡܝܗܝܢ ܗܘܘ ܒܝܘܠܦܢܗ ܡܠܦ ܗܘܐ ܠܗܘܢ ܓܝܪ ܐܝܟ ܡܫܠܛܐ ܘܠܐ ܐܝܟ ܤܦܪܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Mark 1:23",
      "text": "ܘܐܝܬ ܗܘܐ ܒܟܢܘܫܬܗܘܢ ܓܒܪܐ ܕܐܝܬ ܒܗ ܪܘܚܐ ܛܡܐܬܐ ܘܩܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 24,
      "referenceLabel": "Mark 1:24",
      "text": "ܘܐܡܪ ܡܐ ܠܢ ܘܠܟ ܝܫܘܥ ܢܨܪܝܐ ܐܬܝܬ ܠܡܘܒܕܘܬܢ ܝܕܥ ܐܢܐ ܠܟ ܡܢ ܐܢܬ ܩܕܝܫܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 25,
      "referenceLabel": "Mark 1:25",
      "text": "ܘܟܐܐ ܒܗ ܝܫܘܥ ܘܐܡܪ ܤܟܘܪ ܦܘܡܟ ܘܦܘܩ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 26,
      "referenceLabel": "Mark 1:26",
      "text": "ܘܫܕܬܗ ܪܘܚܐ ܛܢܦܬܐ ܘܩܥܬ ܒܩܠܐ ܪܡܐ ܘܢܦܩܬ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 27,
      "referenceLabel": "Mark 1:27",
      "text": "ܘܐܬܕܡܪܘ ܟܠܗܘܢ ܘܒܥܝܢ ܗܘܘ ܚܕ ܥܡ ܚܕ ܘܐܡܪܝܢ ܕܡܢܐ ܗܝ ܗܕܐ ܘܡܢܘ ܝܘܠܦܢܐ ܗܢܐ ܚܕܬܐ ܕܒܫܘܠܛܢܐ ܘܐܦ ܠܪܘܚܐ ܛܢܦܬܐ ܦܩܕ ܘܡܫܬܡܥܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 28,
      "referenceLabel": "Mark 1:28",
      "text": "ܘܡܚܕܐ ܢܦܩ ܛܒܗ ܒܟܠܗ ܐܬܪܐ ܕܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 29,
      "referenceLabel": "Mark 1:29",
      "text": "ܘܢܦܩܘ ܡܢ ܟܢܘܫܬܐ ܘܐܬܘ ܠܒܝܬܗ ܕܫܡܥܘܢ ܘܕܐܢܕܪܐܘܤ ܥܡ ܝܥܩܘܒ ܘܝܘܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 30,
      "referenceLabel": "Mark 1:30",
      "text": "ܘܚܡܬܗ ܕܫܡܥܘܢ ܪܡܝܐ ܗܘܬ ܒܐܫܬܐ ܘܐܡܪܘ ܠܗ ܥܠܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 31,
      "referenceLabel": "Mark 1:31",
      "text": "ܘܩܪܒ ܐܚܕܗ ܒܐܝܕܗ ܘܐܩܝܡܗ ܘܡܚܕܐ ܫܒܩܬܗ ܐܫܬܗ ܘܡܫܡܫܐ ܗܘܬ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 32,
      "referenceLabel": "Mark 1:32",
      "text": "ܒܪܡܫܐ ܕܝܢ ܒܡܥܪܒܝ ܫܡܫܐ ܐܝܬܝܘ ܠܘܬܗ ܟܠܗܘܢ ܐܝܠܝܢ ܕܒܝܫܐܝܬ ܥܒܝܕܝܢ ܘܕܝܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 33,
      "referenceLabel": "Mark 1:33",
      "text": "ܘܡܕܝܢܬܐ ܟܠܗ ܟܢܝܫܐ ܗܘܬ ܥܠ ܬܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 34,
      "referenceLabel": "Mark 1:34",
      "text": "ܘܐܤܝ ܠܤܓܝܐܐ ܕܒܝܫܐܝܬ ܥܒܝܕܝܢ ܗܘܘ ܒܟܘܪܗܢܐ ܡܫܚܠܦܐ ܘܕܝܘܐ ܤܓܝܐܐ ܐܦܩ ܘܠܐ ܫܒܩ ܗܘܐ ܠܗܘܢ ܠܕܝܘܐ ܕܢܡܠܠܘܢ ܡܛܠ ܕܝܕܥܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 35,
      "referenceLabel": "Mark 1:35",
      "text": "ܘܒܨܦܪܐ ܩܕܡ ܩܡ ܛܒ ܘܐܙܠ ܠܐܬܪܐ ܚܘܪܒܐ ܘܬܡܢ ܡܨܠܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 36,
      "referenceLabel": "Mark 1:36",
      "text": "ܘܒܥܝܢ ܗܘܘ ܠܗ ܫܡܥܘܢ ܘܕܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 37,
      "referenceLabel": "Mark 1:37",
      "text": "ܘܟܕ ܐܫܟܚܘܗܝ ܐܡܪܝܢ ܠܗ ܟܠܗܘܢ ܐܢܫܐ ܒܥܝܢ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 38,
      "referenceLabel": "Mark 1:38",
      "text": "ܐܡܪ ܠܗܘܢ ܗܠܟܘ ܠܩܘܪܝܐ ܘܠܡܕܝܢܬܐ ܕܩܪܝܒܢ ܕܐܦ ܬܡܢ ܐܟܪܙ ܠܗܕܐ ܓܝܪ ܐܬܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.39",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 39,
      "referenceLabel": "Mark 1:39",
      "text": "ܘܡܟܪܙ ܗܘܐ ܒܟܠܗܝܢ ܟܢܘܫܬܗܘܢ ܒܟܠܗ ܓܠܝܠܐ ܘܡܦܩ ܫܐܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.1.40",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 1,
      "verseNumber": 40,
      "referenceLabel": "Mark 1:40",
