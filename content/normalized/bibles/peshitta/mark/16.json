{
  "chapter": {
    "id": "peshitta:mark.16",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 16,
    "referenceLabel": "Mark 16",
    "summary": "Source text for Mark 16 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.16.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 1,
      "referenceLabel": "Mark 16:1",
      "text": "ܘܟܕ ܥܒܪܬ ܫܒܬܐ ܡܪܝܡ ܡܓܕܠܝܬܐ ܘܡܪܝܡ ܕܝܥܩܘܒ ܘܫܠܘܡ ܙܒܢ ܗܪܘܡܐ ܕܢܐܬܝܢ ܢܡܫܚܢܝܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.16.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 2,
      "referenceLabel": "Mark 16:2",
      "text": "ܒܫܦܪܐ ܕܝܢ ܒܚܕ ܒܫܒܐ ܐܬܝ ܠܒܝܬ ܩܒܘܪܐ ܟܕ ܕܢܚ ܫܡܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 3,
      "referenceLabel": "Mark 16:3",
      "text": "ܘܐܡܪܢ ܗܘܝ ܒܢܦܫܗܝܢ ܡܢ ܕܝܢ ܥܓܠ ܠܢ ܟܐܦܐ ܡܢ ܬܪܥܐ ܕܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 4,
      "referenceLabel": "Mark 16:4",
      "text": "ܘܚܪ ܚܙܝ ܕܡܥܓܠܐ ܗܝ ܟܐܦܐ ܪܒܐ ܗܘܬ ܓܝܪ ܛܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 5,
      "referenceLabel": "Mark 16:5",
      "text": "ܘܥܠܝܢ ܠܒܝܬ ܩܒܘܪܐ ܘܚܙܝ ܥܠܝܡܐ ܕܝܬܒ ܡܢ ܝܡܝܢܐ ܘܥܛܝܦ ܐܤܛܠܐ ܚܘܪܬܐ ܘܬܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 6,
      "referenceLabel": "Mark 16:6",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܝܢ ܠܐ ܬܕܚܠܢ ܠܝܫܘܥ ܢܨܪܝܐ ܒܥܝܢ ܐܢܬܝܢ ܗܘ ܕܐܙܕܩܦ ܩܡ ܠܗ ܠܐ ܗܘܐ ܬܢܢ ܗܐ ܕܘܟܬܐ ܐܝܟܐ ܕܤܝܡ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 7,
      "referenceLabel": "Mark 16:7",
      "text": "ܐܠܐ ܙܠܝܢ ܐܡܪܝܢ ܠܬܠܡܝܕܘܗܝ ܘܠܟܐܦܐ ܕܗܐ ܩܕܡ ܠܟܘܢ ܠܓܠܝܠܐ ܬܡܢ ܬܚܙܘܢܝܗܝ ܐܝܟܢܐ ܕܐܡܪ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 8,
      "referenceLabel": "Mark 16:8",
      "text": "ܘܟܕ ܫܡܥ ܥܪܩ ܘܢܦܩ ܡܢ ܩܒܪܐ ܐܚܝܕ ܗܘܐ ܠܗܝܢ ܓܝܪ ܬܗܪܐ ܘܪܬܝܬܐ ܘܠܐܢܫ ܡܕܡ ܠܐ ܐܡܪܝܢ ܕܚܝܠܢ ܗܘܝ ܓܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 9,
      "referenceLabel": "Mark 16:9",
      "text": "ܒܫܦܪܐ ܕܝܢ ܒܚܕ ܒܫܒܐ ܩܡ ܘܐܬܚܙܝ ܠܘܩܕܡ ܠܡܪܝܡ ܡܓܕܠܝܬܐ ܗܝ ܕܫܒܥܐ ܫܐܕܝܢ ܐܦܩ ܗܘܐ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 10,
      "referenceLabel": "Mark 16:10",
      "text": "ܘܗܝ ܐܙܠܬ ܤܒܪܬ ܠܗܢܘܢ ܕܥܡܗ ܗܘܘ ܕܐܒܝܠܝܢ ܗܘܘ ܘܒܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 11,
      "referenceLabel": "Mark 16:11",
      "text": "ܘܗܢܘܢ ܟܕ ܫܡܥܘ ܕܐܡܪܢ ܕܚܝ ܘܐܬܚܙܝ ܠܗܝܢ ܠܐ ܗܝܡܢܘ ܐܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 12,
      "referenceLabel": "Mark 16:12",
      "text": "ܒܬܪ ܗܠܝܢ ܐܬܚܙܝ ܠܬܪܝܢ ܡܢܗܘܢ ܒܕܡܘܬܐ ܐܚܪܬܐ ܟܕ ܡܗܠܟܝܢ ܘܐܙܠܝܢ ܠܩܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 13,
      "referenceLabel": "Mark 16:13",
      "text": "ܘܗܢܘܢ ܐܙܠܘ ܐܡܪܘ ܠܫܪܟܐ ܐܦ ܠܐ ܠܗܢܘܢ ܗܝܡܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 14,
      "referenceLabel": "Mark 16:14",
      "text": "ܐܚܪܝܬ ܕܝܢ ܐܬܚܙܝ ܠܚܕܥܤܪ ܟܕ ܤܡܝܟܝܢ ܘܚܤܕ ܠܚܤܝܪܘܬ ܗܝܡܢܘܬܗܘܢ ܘܠܩܫܝܘܬ ܠܒܗܘܢ ܕܠܗܢܘܢ ܕܚܙܐܘܗܝ ܕܩܡ ܠܐ ܗܝܡܢܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 15,
      "referenceLabel": "Mark 16:15",
      "text": "ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܠܥܠܡܐ ܟܠܗ ܘܐܟܪܙܘ ܤܒܪܬܝ ܒܟܠܗ ܒܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 16,
      "referenceLabel": "Mark 16:16",
      "text": "ܐܝܢܐ ܕܡܗܝܡܢ ܘܥܡܕ ܚܝܐ ܘܐܝܢܐ ܕܠܐ ܡܗܝܡܢ ܡܬܚܝܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 17,
      "referenceLabel": "Mark 16:17",
      "text": "ܐܬܘܬܐ ܕܝܢ ܠܐܝܠܝܢ ܕܡܗܝܡܢܝܢ ܗܠܝܢ ܢܩܦܢ ܒܫܡܝ ܫܐܕܐ ܢܦܩܘܢ ܘܒܠܫܢܐ ܚܕܬܐ ܢܡܠܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 18,
      "referenceLabel": "Mark 16:18",
      "text": "ܘܚܘܘܬܐ ܢܫܩܠܘܢ ܘܐܢ ܤܡܐ ܕܡܘܬܐ ܢܫܬܘܢ ܠܐ ܢܗܪ ܐܢܘܢ ܘܐܝܕܝܗܘܢ ܢܤܝܡܘܢ ܥܠ ܟܪܝܗܐ ܘܢܬܚܠܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 19,
      "referenceLabel": "Mark 16:19",
      "text": "ܝܫܘܥ ܕܝܢ ܡܪܢ ܡܢ ܒܬܪ ܕܡܠܠ ܥܡܗܘܢ ܠܫܡܝܐ ܤܠܩ ܘܝܬܒ ܡܢ ܝܡܝܢܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.16.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 16,
      "verseNumber": 20,
      "referenceLabel": "Mark 16:20",
      "text": "ܗܢܘܢ ܕܝܢ ܢܦܩܘ ܘܐܟܪܙܘ ܒܟܠ ܕܘܟܐ ܘܡܪܢ ܡܥܕܪ ܗܘܐ ܠܗܘܢ ܘܡܫܪ ܡܠܝܗܘܢ ܒܐܬܘܬܐ ܕܥܒܕܝܢ ܗܘܘ ܀ ܀ ܀",
      "paragraphStart": false
    }
  ]
}
