{
  "chapter": {
    "id": "peshitta:mark.11",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 11,
    "referenceLabel": "Mark 11",
    "summary": "Source text for Mark 11 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.11.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 1,
      "referenceLabel": "Mark 11:1",
      "text": "ܘܟܕ ܩܪܒ ܠܐܘܪܫܠܡ ܥܠ ܓܢܒ ܒܝܬ ܦܓܐ ܘܒܝܬ ܥܢܝܐ ܠܘܬ ܛܘܪܐ ܕܙܝܬܐ ܫܕܪ ܬܪܝܢ ܡܢ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.11.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 2,
      "referenceLabel": "Mark 11:2",
      "text": "ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܠܩܪܝܬܐ ܗܝ ܕܠܩܘܒܠܢ ܘܒܪ ܫܥܬܗ ܕܥܐܠܝܢ ܐܢܬܘܢ ܠܗ ܡܫܟܚܝܢ ܐܢܬܘܢ ܥܝܠܐ ܕܐܤܝܪ ܕܐܢܫ ܡܢ ܒܢܝܢܫܐ ܠܐ ܪܟܒܗ ܫܪܘ ܐܝܬܐܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 3,
      "referenceLabel": "Mark 11:3",
      "text": "ܘܐܢ ܐܢܫ ܢܐܡܪ ܠܟܘܢ ܡܢܐ ܥܒܕܝܢ ܐܢܬܘܢ ܗܕܐ ܐܡܪܘ ܠܗ ܕܠܡܪܢ ܡܬܒܥܐ ܘܡܚܕܐ ܡܫܕܪ ܠܗ ܠܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 4,
      "referenceLabel": "Mark 11:4",
      "text": "ܘܐܙܠܘ ܐܫܟܚܘ ܥܝܠܐ ܕܐܤܝܪ ܥܠ ܬܪܥܐ ܠܒܪ ܒܫܘܩܐ ܘܟܕ ܫܪܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 5,
      "referenceLabel": "Mark 11:5",
      "text": "ܐܢܫܝܢ ܡܢ ܐܝܠܝܢ ܕܩܝܡܝܢ ܐܡܪܘ ܠܗܘܢ ܡܢܐ ܥܒܕܝܢ ܐܢܬܘܢ ܕܫܪܝܢ ܐܢܬܘܢ ܥܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 6,
      "referenceLabel": "Mark 11:6",
      "text": "ܗܢܘܢ ܕܝܢ ܐܡܪܘ ܠܗܘܢ ܐܝܟ ܕܦܩܕ ܐܢܘܢ ܝܫܘܥ ܘܫܒܩܘ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 7,
      "referenceLabel": "Mark 11:7",
      "text": "ܘܐܝܬܝܘܗܝ ܠܥܝܠܐ ܠܘܬ ܝܫܘܥ ܘܐܪܡܝܘ ܥܠܘܗܝ ܡܐܢܝܗܘܢ ܘܪܟܒ ܥܠܘܗܝ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 8,
      "referenceLabel": "Mark 11:8",
      "text": "ܤܓܝܐܐ ܕܝܢ ܡܫܘܝܢ ܗܘܘ ܢܚܬܝܗܘܢ ܒܐܘܪܚܐ ܘܐܚܪܢܐ ܦܤܩܝܢ ܗܘܘ ܤܘܟܐ ܡܢ ܐܝܠܢܐ ܘܡܫܘܝܢ ܒܐܘܪܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 9,
      "referenceLabel": "Mark 11:9",
      "text": "ܘܗܢܘܢ ܕܩܕܡܘܗܝ ܘܗܢܘܢ ܕܒܬܪܗ ܩܥܝܢ ܗܘܘ ܘܐܡܪܝܢ ܐܘܫܥܢܐ ܒܪܝܟ ܗܘ ܕܐܬܐ ܒܫܡܗ ܕܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 10,
      "referenceLabel": "Mark 11:10",
      "text": "ܘܒܪܝܟܐ ܗܝ ܡܠܟܘܬܐ ܕܐܬܝܐ ܕܐܒܘܢ ܕܘܝܕ ܐܘܫܥܢܐ ܒܡܪܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 11,
      "referenceLabel": "Mark 11:11",
      "text": "ܘܥܠ ܝܫܘܥ ܠܐܘܪܫܠܡ ܠܗܝܟܠܐ ܘܚܙܐ ܟܠܡܕܡ ܟܕ ܗܘܐ ܕܝܢ ܥܕܢܐ ܕܪܡܫܐ ܢܦܩ ܠܒܝܬ ܥܢܝܐ ܥܡ ܬܪܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 12,
      "referenceLabel": "Mark 11:12",
      "text": "ܘܠܝܘܡܐ ܐܚܪܢܐ ܟܕ ܢܦܩ ܡܢ ܒܝܬ ܥܢܝܐ ܟܦܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 13,
      "referenceLabel": "Mark 11:13",
      "text": "ܘܚܙܐ ܬܬܐ ܚܕܐ ܡܢ ܪܘܚܩܐ ܕܐܝܬ ܒܗ ܛܪܦܐ ܘܐܬܐ ܠܘܬܗ ܕܐܢ ܢܫܟܚ ܒܗ ܡܕܡ ܘܟܕ ܐܬܐ ܠܐ ܐܫܟܚ ܒܗ ܐܠܐ ܐܢ ܛܪܦܐ ܙܒܢܐ ܓܝܪ ܠܐ ܗܘܐ ܗܘܐ ܕܬܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 14,
      "referenceLabel": "Mark 11:14",
      "text": "ܘܐܡܪ ܠܗ ܡܟܝܠ ܘܠܥܠܡ ܐܢܫ ܡܢܟܝ ܦܐܪܐ ܠܐ ܢܐܟܘܠ ܘܫܡܥܘ ܬܠܡܝܕܘܗܝ ܘܐܬܘ ܠܐܘܪܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 15,
      "referenceLabel": "Mark 11:15",
      "text": "ܘܥܠ ܝܫܘܥ ܠܗܝܟܠܐ ܕܐܠܗܐ ܘܫܪܝ ܕܢܦܩ ܠܐܝܠܝܢ ܕܙܒܢܝܢ ܘܡܙܒܢܝܢ ܒܗܝܟܠܐ ܘܗܦܟ ܦܬܘܪܐ ܕܡܥܪܦܢܐ ܘܟܘܪܤܘܬܐ ܕܗܢܘܢ ܕܡܙܒܢܝܢ ܝܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 16,
      "referenceLabel": "Mark 11:16",
      "text": "ܘܠܐ ܫܒܩ ܗܘܐ ܕܐܢܫ ܢܥܒܪ ܡܐܢܐ ܒܓܘ ܗܝܟܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 17,
      "referenceLabel": "Mark 11:17",
      "text": "ܘܡܠܦ ܗܘܐ ܘܐܡܪ ܠܗܘܢ ܠܐ ܟܬܝܒ ܕܒܝܬܝ ܒܝܬ ܨܠܘܬܐ ܢܬܩܪܐ ܠܟܠܗܘܢ ܥܡܡܐ ܐܢܬܘܢ ܕܝܢ ܥܒܕܬܘܢܝܗܝ ܡܥܪܬܐ ܕܠܤܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 18,
      "referenceLabel": "Mark 11:18",
      "text": "ܘܫܡܥܘ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܒܥܝܢ ܗܘܘ ܕܐܝܟܢܐ ܢܘܒܕܘܢܝܗܝ ܕܚܠܝܢ ܗܘܘ ܓܝܪ ܡܢܗ ܡܛܠ ܕܟܠܗ ܥܡܐ ܬܡܝܗܝܢ ܗܘܘ ܒܝܘܠܦܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 19,
      "referenceLabel": "Mark 11:19",
      "text": "ܘܟܕ ܗܘܐ ܪܡܫܐ ܢܦܩܘ ܠܒܪ ܡܢ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 20,
      "referenceLabel": "Mark 11:20",
      "text": "ܘܒܨܦܪܐ ܟܕ ܥܒܪܝܢ ܚܙܘ ܬܬܐ ܗܝ ܟܕ ܝܒܝܫܐ ܡܢ ܥܩܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 21,
      "referenceLabel": "Mark 11:21",
      "text": "ܘܐܬܕܟܪ ܫܡܥܘܢ ܘܐܡܪ ܠܗ ܪܒܝ ܗܐ ܬܬܐ ܗܝ ܕܠܛܬ ܝܒܫܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 22,
      "referenceLabel": "Mark 11:22",
      "text": "ܘܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܬܗܘܐ ܒܟܘܢ ܗܝܡܢܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 23,
      "referenceLabel": "Mark 11:23",
      "text": "ܐܡܝܢ ܓܝܪ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܡܢ ܕܢܐܡܪ ܠܛܘܪܐ ܗܢܐ ܕܐܫܬܩܠ ܘܦܠ ܒܝܡܐ ܘܠܐ ܢܬܦܠܓ ܒܠܒܗ ܐܠܐ ܢܗܝܡܢ ܕܗܘܐ ܗܘ ܡܕܡ ܕܐܡܪ ܢܗܘܐ ܠܗ ܡܕܡ ܕܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 24,
      "referenceLabel": "Mark 11:24",
      "text": "ܡܛܠ ܗܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܟܠ ܡܕܡ ܕܡܨܠܝܢ ܐܢܬܘܢ ܘܫܐܠܝܢ ܐܢܬܘܢ ܗܝܡܢܘ ܕܢܤܒܝܢ ܐܢܬܘܢ ܘܢܗܘܐ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 25,
      "referenceLabel": "Mark 11:25",
      "text": "ܘܡܐ ܕܩܝܡܝܢ ܐܢܬܘܢ ܠܡܨܠܝܘ ܫܒܘܩܘ ܡܕܡ ܕܐܝܬ ܠܟܘܢ ܥܠ ܐܢܫ ܕܐܦ ܐܒܘܟܘܢ ܕܒܫܡܝܐ ܢܫܒܘܩ ܠܟܘܢ ܤܟܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 26,
      "referenceLabel": "Mark 11:26",
      "text": "ܐܢ ܕܝܢ ܐܢܬܘܢ ܠܐ ܫܒܩܝܢ ܐܢܬܘܢ ܐܦܠܐ ܐܒܘܟܘܢ ܕܒܫܡܝܐ ܢܫܒܘܩ ܠܟܘܢ ܤܟܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 27,
      "referenceLabel": "Mark 11:27",
      "text": "ܘܐܬܘ ܬܘܒ ܠܐܘܪܫܠܡ ܘܟܕ ܡܗܠܟ ܗܘܐ ܒܗܝܟܠܐ ܐܬܘ ܠܘܬܗ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 28,
      "referenceLabel": "Mark 11:28",
      "text": "ܘܐܡܪܝܢ ܠܗ ܒܐܝܢܐ ܫܘܠܛܢܐ ܗܠܝܢ ܥܒܕ ܐܢܬ ܘܡܢܘ ܝܗܒ ܠܟ ܫܘܠܛܢܐ ܗܢܐ ܕܗܠܝܢ ܬܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 29,
      "referenceLabel": "Mark 11:29",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗܘܢ ܐܫܐܠܟܘܢ ܐܦ ܐܢܐ ܡܠܬܐ ܚܕܐ ܕܬܐܡܪܘܢ ܠܝ ܘܐܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܒܐܝܢܐ ܫܘܠܛܢܐ ܗܠܝܢ ܥܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 30,
      "referenceLabel": "Mark 11:30",
      "text": "ܡܥܡܘܕܝܬܗ ܕܝܘܚܢܢ ܡܢ ܐܝܡܟܐ ܗܝ ܡܢ ܫܡܝܐ ܐܘ ܡܢ ܒܢܝ ܐܢܫܐ ܐܡܪܘ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 31,
      "referenceLabel": "Mark 11:31",
      "text": "ܘܐܬܚܫܒܘ ܒܢܦܫܗܘܢ ܘܐܡܪܘ ܕܐܢ ܢܐܡܪ ܠܗ ܕܡܢ ܫܡܝܐ ܐܡܪ ܠܢ ܘܠܡܢܐ ܠܐ ܗܝܡܢܬܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 32,
      "referenceLabel": "Mark 11:32",
      "text": "ܘܕܢܐܡܪ ܡܢ ܒܢܝ ܐܢܫܐ ܕܚܠܬܐ ܗܝ ܡܢ ܥܡܐ ܟܠܗܘܢ ܓܝܪ ܐܚܝܕܝܢ ܗܘܘ ܠܗ ܠܝܘܚܢܢ ܕܫܪܝܪܐܝܬ ܢܒܝܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.11.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 11,
      "verseNumber": 33,
      "referenceLabel": "Mark 11:33",
      "text": "ܘܥܢܘ ܘܐܡܪܝܢ ܠܗ ܠܝܫܘܥ ܠܐ ܝܕܥܝܢܢ ܐܡܪ ܠܗܘܢ ܐܦ ܠܐ ܐܢܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܒܐܝܢܐ ܫܘܠܛܢܐ ܗܠܝܢ ܥܒܕ ܐܢܐ ܀",
      "paragraphStart": false
    }
  ]
}
