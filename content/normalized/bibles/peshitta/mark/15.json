{
  "chapter": {
    "id": "peshitta:mark.15",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 15,
    "referenceLabel": "Mark 15",
    "summary": "Source text for Mark 15 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.15.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 1,
      "referenceLabel": "Mark 15:1",
      "text": "ܘܡܚܕܐ ܒܨܦܪܐ ܥܒܕܘ ܡܠܟܐ ܪܒܝ ܟܗܢܐ ܥܡ ܩܫܝܫܐ ܘܥܡ ܤܦܪܐ ܘܥܡ ܟܠܗ ܟܢܘܫܬܐ ܘܐܤܪܘ ܠܝܫܘܥ ܘܐܘܒܠܘܗܝ ܘܐܫܠܡܘܗܝ ܠܦܝܠܛܘܤ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.15.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 2,
      "referenceLabel": "Mark 15:2",
      "text": "ܘܫܐܠܗ ܦܝܠܛܘܤ ܐܢܬ ܗܘ ܡܠܟܐ ܕܝܗܘܕܝܐ ܗܘ ܕܝܢ ܥܢܐ ܘܐܡܪ ܠܗ ܐܢܬ ܐܡܪܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 3,
      "referenceLabel": "Mark 15:3",
      "text": "ܘܐܟܠܝܢ ܗܘܘ ܩܪܨܘܗܝ ܪܒܝ ܟܗܢܐ ܒܤܓܝܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 4,
      "referenceLabel": "Mark 15:4",
      "text": "ܗܘ ܕܝܢ ܦܝܠܛܘܤ ܬܘܒ ܫܐܠܗ ܘܐܡܪ ܠܗ ܠܐ ܡܦܢܐ ܐܢܬ ܦܬܓܡܐ ܚܙܝ ܟܡܐ ܡܤܗܕܝܢ ܥܠܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 5,
      "referenceLabel": "Mark 15:5",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܡܕܡ ܦܬܓܡܐ ܠܐ ܝܗܒ ܐܝܟܢܐ ܕܢܬܕܡܪ ܦܝܠܛܘܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 6,
      "referenceLabel": "Mark 15:6",
      "text": "ܡܥܕ ܗܘܐ ܕܝܢ ܒܟܠ ܥܐܕܐ ܠܡܫܪܐ ܠܗܘܢ ܐܤܝܪܐ ܚܕ ܐܝܢܐ ܕܫܐܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 7,
      "referenceLabel": "Mark 15:7",
      "text": "ܘܐܝܬ ܗܘܐ ܚܕ ܕܡܬܩܪܐ ܒܪ ܐܒܐ ܕܐܤܝܪ ܗܘܐ ܥܡ ܥܒܕܝ ܐܤܛܤܝܢ ܗܢܘܢ ܕܩܛܠܐ ܒܐܤܛܤܝܢ ܥܒܕܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 8,
      "referenceLabel": "Mark 15:8",
      "text": "ܘܩܥܘ ܥܡܐ ܘܫܪܝܘ ܠܡܫܐܠ ܐܝܟ ܕܡܥܕ ܗܘܐ ܥܒܕ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 9,
      "referenceLabel": "Mark 15:9",
      "text": "ܗܘ ܕܝܢ ܦܝܠܛܘܤ ܥܢܐ ܘܐܡܪ ܨܒܝܢ ܐܢܬܘܢ ܐܫܪܐ ܠܟܘܢ ܡܠܟܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 10,
      "referenceLabel": "Mark 15:10",
      "text": "ܝܕܥ ܗܘܐ ܓܝܪ ܦܝܠܛܘܤ ܕܡܢ ܚܤܡܐ ܐܫܠܡܘܗܝ ܪܒܝ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 11,
      "referenceLabel": "Mark 15:11",
      "text": "ܪܒܝ ܟܗܢܐ ܕܝܢ ܝܬܝܪܐܝܬ ܚܦܛܘ ܠܟܢܫܐ ܕܠܒܪ ܐܒܐ ܢܫܪܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 12,
      "referenceLabel": "Mark 15:12",
      "text": "ܗܘ ܕܝܢ ܦܝܠܛܘܤ ܐܡܪ ܠܗܘܢ ܡܢܐ ܗܟܝܠ ܨܒܝܢ ܐܢܬܘܢ ܐܥܒܕ ܠܗܢܐ ܕܩܪܝܢ ܐܢܬܘܢ ܡܠܟܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 13,
      "referenceLabel": "Mark 15:13",
      "text": "ܗܢܘܢ ܕܝܢ ܬܘܒ ܩܥܘ ܙܩܘܦܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 14,
      "referenceLabel": "Mark 15:14",
      "text": "ܗܘ ܕܝܢ ܦܝܠܛܘܤ ܐܡܪ ܠܗܘܢ ܡܢܐ ܓܝܪ ܕܒܝܫ ܥܒܕ ܘܗܢܘܢ ܝܬܝܪܐܝܬ ܩܥܝܢ ܗܘܘ ܙܩܘܦܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 15,
      "referenceLabel": "Mark 15:15",
      "text": "ܦܝܠܛܘܤ ܕܝܢ ܨܒܐ ܕܢܥܒܕ ܨܒܝܢܐ ܠܟܢܫܐ ܘܫܪܐ ܠܗܘܢ ܠܒܪ ܐܒܐ ܘܐܫܠܡ ܠܗܘܢ ܠܝܫܘܥ ܟܕ ܡܢܓܕ ܕܢܙܕܩܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 16,
      "referenceLabel": "Mark 15:16",
      "text": "ܐܤܛܪܛܝܘܛܐ ܕܝܢ ܐܘܒܠܘܗܝ ܠܓܘ ܕܪܬܐ ܕܐܝܬܝܗ ܦܪܛܘܪܝܢ ܘܩܪܘ ܠܟܠܗ ܐܤܦܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 17,
      "referenceLabel": "Mark 15:17",
      "text": "ܘܐܠܒܫܘܗܝ ܐܪܓܘܢܐ ܘܓܕܠܘ ܤܡܘ ܠܗ ܟܠܝܠܐ ܕܟܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 18,
      "referenceLabel": "Mark 15:18",
      "text": "ܘܫܪܝܘ ܠܡܫܐܠ ܒܫܠܡܗ ܫܠܡ ܡܠܟܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 19,
      "referenceLabel": "Mark 15:19",
      "text": "ܘܡܚܝܢ ܗܘܘ ܠܗ ܥܠ ܪܫܗ ܒܩܢܝܐ ܘܪܩܝܢ ܗܘܘ ܒܐܦܘܗܝ ܘܒܪܟܝܢ ܗܘܘ ܥܠ ܒܘܪܟܝܗܘܢ ܘܤܓܕܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 20,
      "referenceLabel": "Mark 15:20",
      "text": "ܘܟܕ ܒܙܚܘ ܒܗ ܐܫܠܚܘܗܝ ܐܪܓܘܢܐ ܘܐܠܒܫܘܗܝ ܡܐܢܘܗܝ ܘܐܦܩܘܗܝ ܕܢܙܩܦܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 21,
      "referenceLabel": "Mark 15:21",
      "text": "ܘܫܚܪܘ ܚܕ ܕܥܒܪ ܗܘܐ ܫܡܥܘܢ ܩܘܪܝܢܝܐ ܕܐܬܐ ܗܘܐ ܡܢ ܩܪܝܬܐ ܐܒܘܗܝ ܕܐܠܟܤܢܕܪܘܤ ܘܕܪܘܦܘܤ ܕܢܫܩܘܠ ܙܩܝܦܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 22,
      "referenceLabel": "Mark 15:22",
      "text": "ܘܐܝܬܝܘܗܝ ܠܓܓܘܠܬܐ ܕܘܟܬܐ ܕܡܬܦܫܩܐ ܩܪܩܦܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 23,
      "referenceLabel": "Mark 15:23",
      "text": "ܘܝܗܒܘ ܠܗ ܠܡܫܬܐ ܚܡܪܐ ܕܚܠܝܛ ܒܗ ܡܘܪܐ ܗܘ ܕܝܢ ܠܐ ܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 24,
      "referenceLabel": "Mark 15:24",
      "text": "ܘܟܕ ܙܩܦܘܗܝ ܦܠܓܘ ܡܐܢܘܗܝ ܘܐܪܡܝܘ ܥܠܝܗܘܢ ܦܤܐ ܡܢܘ ܡܢܐ ܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 25,
      "referenceLabel": "Mark 15:25",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܫܥܐ ܬܠܬ ܟܕ ܙܩܦܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 26,
      "referenceLabel": "Mark 15:26",
      "text": "ܘܟܬܝܒܐ ܗܘܬ ܥܠܬܐ ܕܡܘܬܗ ܒܟܬܒܐ ܗܢܐ ܗܘ ܡܠܟܐ ܕܝܗܘܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 27,
      "referenceLabel": "Mark 15:27",
      "text": "ܘܙܩܦܘ ܥܡܗ ܬܪܝܢ ܠܤܛܝܐ ܚܕ ܡܢ ܝܡܝܢܗ ܘܚܕ ܡܢ ܤܡܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 28,
      "referenceLabel": "Mark 15:28",
      "text": "ܘܫܠܡ ܟܬܒܐ ܕܐܡܪ ܕܥܡ ܥܘܠܐ ܐܬܚܫܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 29,
      "referenceLabel": "Mark 15:29",
      "text": "ܘܐܦ ܐܝܠܝܢ ܕܝܢ ܕܥܒܪܝܢ ܗܘܘ ܡܓܕܦܝܢ ܗܘܘ ܥܠܘܗܝ ܘܡܢܝܕܝܢ ܪܫܝܗܘܢ ܘܐܡܪܝܢ ܐܘܢ ܫܪܐ ܗܝܟܠܐ ܘܒܢܐ ܠܗ ܠܬܠܬܐ ܝܘܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 30,
      "referenceLabel": "Mark 15:30",
      "text": "ܦܨܐ ܢܦܫܟ ܘܚܘܬ ܡܢ ܙܩܝܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 31,
      "referenceLabel": "Mark 15:31",
      "text": "ܘܗܟܢܐ ܐܦ ܪܒܝ ܟܗܢܐ ܓܚܟܝܢ ܗܘܘ ܚܕ ܥܡ ܚܕ ܘܤܦܪܐ ܘܐܡܪܝܢ ܐܚܪܢܐ ܐܚܝ ܢܦܫܗ ܠܐ ܡܫܟܚ ܠܡܚܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 32,
      "referenceLabel": "Mark 15:32",
      "text": "ܡܫܝܚܐ ܡܠܟܗ ܕܐܝܤܪܝܠ ܢܚܘܬ ܗܫܐ ܡܢ ܙܩܝܦܐ ܕܢܚܙܐ ܘܢܗܝܡܢ ܒܗ ܘܐܦ ܗܢܘܢ ܕܝܢ ܕܙܩܝܦܝܢ ܗܘܘ ܥܡܗ ܡܚܤܕܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 33,
      "referenceLabel": "Mark 15:33",
      "text": "ܘܟܕ ܗܘܝ ܫܬ ܫܥܝܢ ܗܘܐ ܚܫܘܟܐ ܥܠ ܟܠܗ ܐܪܥܐ ܥܕܡܐ ܠܫܥܐ ܬܫܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 34,
      "referenceLabel": "Mark 15:34",
      "text": "ܘܒܬܫܥ ܫܥܝܢ ܩܥܐ ܝܫܘܥ ܒܩܠܐ ܪܡܐ ܘܐܡܪ ܐܝܠ ܐܝܠ ܠܡܢܐ ܫܒܩܬܢܝ ܕܐܝܬܝܗ ܐܠܗܝ ܐܠܗܝ ܠܡܢܐ ܫܒܩܬܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 35,
      "referenceLabel": "Mark 15:35",
      "text": "ܘܐܢܫܝܢ ܕܫܡܥܘ ܡܢ ܗܢܘܢ ܕܩܝܡܝܢ ܐܡܪܝܢ ܗܘܘ ܠܐܠܝܐ ܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 36,
      "referenceLabel": "Mark 15:36",
      "text": "ܪܗܛ ܕܝܢ ܚܕ ܘܡܠܐ ܐܤܦܘܓܐ ܚܠܐ ܘܐܤܪ ܒܩܢܝܐ ܕܢܫܩܝܘܗܝ ܘܐܡܪܘ ܫܒܘܩܘ ܢܚܙܐ ܐܢ ܐܬܐ ܐܠܝܐ ܡܚܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 37,
      "referenceLabel": "Mark 15:37",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܩܥܐ ܒܩܠܐ ܪܡܐ ܘܫܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 38,
      "referenceLabel": "Mark 15:38",
      "text": "ܘܐܦܝ ܬܪܥܐ ܕܗܝܟܠܐ ܐܨܛܪܝ ܠܬܪܝܢ ܡܢ ܠܥܠ ܥܕܡܐ ܠܬܚܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.39",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 39,
      "referenceLabel": "Mark 15:39",
      "text": "ܟܕ ܚܙܐ ܕܝܢ ܩܢܛܪܘܢܐ ܗܘ ܕܩܐܡ ܗܘܐ ܠܘܬܗ ܕܗܟܢܐ ܩܥܐ ܘܫܠܡ ܐܡܪ ܫܪܝܪܐܝܬ ܗܢܐ ܓܒܪܐ ܒܪܗ ܗܘܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.15.40",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 15,
      "verseNumber": 40,
      "referenceLabel": "Mark 15:40",
