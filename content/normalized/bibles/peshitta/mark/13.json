{
  "chapter": {
    "id": "peshitta:mark.13",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 13,
    "referenceLabel": "Mark 13",
    "summary": "Source text for Mark 13 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.13.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 1,
      "referenceLabel": "Mark 13:1",
      "text": "ܘܟܕ ܢܦܩ ܝܫܘܥ ܡܢ ܗܝܟܠܐ ܐܡܪ ܠܗ ܚܕ ܡܢ ܬܠܡܝܕܘܗܝ ܡܠܦܢܐ ܗܐ ܚܙܝ ܐܝܠܝܢ ܟܐܦܐ ܘܐܝܠܝܢ ܒܢܝܢܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.13.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 2,
      "referenceLabel": "Mark 13:2",
      "text": "ܝܫܘܥ ܕܝܢ ܐܡܪ ܠܗ ܚܙܐ ܐܢܬ ܗܠܝܢ ܒܢܝܢܐ ܪܘܪܒܐ ܠܐ ܡܫܬܒܩܐ ܗܪܟܐ ܟܐܦ ܥܠ ܟܐܦ ܕܠܐ ܡܤܬܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 3,
      "referenceLabel": "Mark 13:3",
      "text": "ܘܟܕ ܝܬܒ ܝܫܘܥ ܒܛܘܪܐ ܕܙܝܬܐ ܠܘܩܒܠ ܗܝܟܠܐ ܫܐܠܘܗܝ ܟܐܦܐ ܘܝܥܩܘܒ ܘܝܘܚܢܢ ܘܐܢܕܪܐܘܤ ܒܠܚܘܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 4,
      "referenceLabel": "Mark 13:4",
      "text": "ܐܡܪ ܠܢ ܐܡܬܝ ܗܠܝܢ ܢܗܘܝܢ ܘܡܢܐ ܐܬܐ ܡܐ ܕܩܪܝܒܢ ܗܠܝܢ ܟܠܗܝܢ ܠܡܫܬܠܡܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 5,
      "referenceLabel": "Mark 13:5",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܫܪܝ ܠܡܐܡܪ ܠܗܘܢ ܚܙܘ ܕܠܡܐ ܐܢܫ ܢܛܥܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 6,
      "referenceLabel": "Mark 13:6",
      "text": "ܤܓܝܐܐ ܓܝܪ ܢܐܬܘܢ ܒܫܡܝ ܘܢܐܡܪܘܢ ܕܐܢܐ ܐܢܐ ܘܠܤܓܝܐܐ ܢܛܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 7,
      "referenceLabel": "Mark 13:7",
      "text": "ܡܐ ܕܝܢ ܕܫܡܥܬܘܢ ܩܪܒܐ ܘܛܒܐ ܕܩܐܪܤܐ ܠܐ ܬܕܚܠܘܢ ܥܬܝܕ ܗܘ ܕܢܗܘܐ ܐܠܐ ܠܐ ܥܕܟܝܠ ܚܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 8,
      "referenceLabel": "Mark 13:8",
      "text": "ܢܩܘܡ ܓܝܪ ܥܡܐ ܥܠ ܥܡܐ ܘܡܠܟܘ ܥܠ ܡܠܟܘ ܘܢܗܘܘܢ ܙܘܥܐ ܒܕܘܟܐ ܕܘܟܐ ܘܢܗܘܘܢ ܟܦܢܐ ܘܫܓܘܫܝܐ ܗܠܝܢ ܪܫܐ ܐܢܝܢ ܕܚܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 9,
      "referenceLabel": "Mark 13:9",
      "text": "ܚܙܘ ܕܝܢ ܐܢܬܘܢ ܢܦܫܟܘܢ ܢܫܠܡܘܢܟܘܢ ܓܝܪ ܠܕܝܢܐ ܘܒܟܢܘܫܬܗܘܢ ܬܬܢܓܕܘܢ ܘܩܕܡ ܡܠܟܐ ܘܗܓܡܘܢܐ ܬܩܘܡܘܢ ܡܛܠܬܝ ܠܤܗܕܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 10,
      "referenceLabel": "Mark 13:10",
      "text": "ܠܘܩܕܡ ܕܝܢ ܥܬܝܕܐ ܕܬܬܟܪܙ ܤܒܪܬܝ ܒܟܠܗܘܢ ܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 11,
      "referenceLabel": "Mark 13:11",
      "text": "ܡܐ ܕܡܩܪܒܝܢ ܠܟܘܢ ܕܝܢ ܕܢܫܠܡܘܢܟܘܢ ܠܐ ܬܩܕܡܘܢ ܬܐܨܦܘܢ ܡܢܐ ܬܡܠܠܘܢ ܘܠܐ ܬܪܢܘܢ ܐܠܐ ܡܕܡ ܕܡܬܝܗܒ ܠܟܘܢ ܒܗܝ ܫܥܬܐ ܗܘ ܡܠܠܘ ܠܐ ܗܘܐ ܓܝܪ ܐܢܬܘܢ ܡܡܠܠܝܢ ܐܠܐ ܪܘܚܐ ܕܩܘܕܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 12,
      "referenceLabel": "Mark 13:12",
      "text": "ܢܫܠܡ ܕܝܢ ܐܚܐ ܠܐܚܘܗܝ ܠܡܘܬܐ ܘܐܒܐ ܠܒܪܗ ܘܢܩܘܡܘܢ ܒܢܝܐ ܥܠ ܐܒܗܝܗܘܢ ܘܢܡܝܬܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 13,
      "referenceLabel": "Mark 13:13",
      "text": "ܘܬܗܘܘܢ ܤܢܝܐܝܢ ܡܢ ܟܠܢܫ ܡܛܠ ܫܡܝ ܡܢ ܕܝܢ ܕܢܤܝܒܪ ܥܕܡܐ ܠܚܪܬܐ ܗܘ ܢܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 14,
      "referenceLabel": "Mark 13:14",
      "text": "ܡܐ ܕܝܢ ܕܚܙܝܬܘܢ ܐܬܐ ܛܢܦܬܐ ܕܚܘܪܒܐ ܗܝ ܕܐܡܝܪܐ ܒܕܢܝܐܝܠ ܢܒܝܐ ܕܩܝܡܐ ܐܝܟܐ ܕܠܐ ܘܠܐ ܗܘ ܕܩܪܐ ܢܤܬܟܠ ܗܝܕܝܢ ܐܝܠܝܢ ܕܒܝܗܘܕ ܐܢܘܢ ܢܥܪܩܘܢ ܠܛܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 15,
      "referenceLabel": "Mark 13:15",
      "text": "ܘܡܢ ܕܒܐܓܪܐ ܗܘ ܠܐ ܢܚܘܬ ܘܠܐ ܢܥܘܠ ܠܡܫܩܠ ܡܕܡ ܡܢ ܒܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 16,
      "referenceLabel": "Mark 13:16",
      "text": "ܘܡܢ ܕܒܚܩܠܐ ܗܘ ܠܐ ܢܬܗܦܟ ܠܒܤܬܪܗ ܕܢܫܩܘܠ ܠܒܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 17,
      "referenceLabel": "Mark 13:17",
      "text": "ܘܝ ܕܝܢ ܠܒܛܢܬܐ ܘܠܐܝܠܝܢ ܕܡܝܢܩܢ ܒܗܢܘܢ ܝܘܡܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 18,
      "referenceLabel": "Mark 13:18",
      "text": "ܨܠܘ ܕܝܢ ܕܠܐ ܢܗܘܐ ܥܪܘܩܝܟܘܢ ܒܤܬܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 19,
      "referenceLabel": "Mark 13:19",
      "text": "ܢܗܘܐ ܓܝܪ ܒܝܘܡܬܐ ܗܢܘܢ ܐܘܠܨܢܐ ܕܠܐ ܗܘܐ ܐܟܘܬܗ ܡܢ ܪܝܫ ܒܪܝܬܐ ܕܒܪܐ ܐܠܗܐ ܥܕܡܐ ܠܗܫܐ ܘܠܐ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 20,
      "referenceLabel": "Mark 13:20",
      "text": "ܘܐܠܘ ܠܐ ܡܪܝܐ ܕܟܪܝ ܝܘܡܬܐ ܗܢܘܢ ܠܐ ܚܝܐ ܗܘܐ ܟܠ ܒܤܪ ܐܠܐ ܡܛܠ ܓܒܝܐ ܕܓܒܐ ܟܪܝ ܝܘܡܬܐ ܗܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 21,
      "referenceLabel": "Mark 13:21",
      "text": "ܗܝܕܝܢ ܐܢ ܐܢܫ ܢܐܡܪ ܠܟܘܢ ܕܗܐ ܗܪܟܐ ܗܘ ܡܫܝܚܐ ܘܗܐ ܗܪܬܡܢ ܠܐ ܬܗܝܡܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 22,
      "referenceLabel": "Mark 13:22",
      "text": "ܢܩܘܡܘܢ ܓܝܪ ܡܫܝܚܐ ܕܕܓܠܘܬܐ ܘܢܒܝܐ ܕܟܕܒܘܬܐ ܘܢܬܠܘܢ ܐܬܘܬܐ ܘܬܕܡܪܬܐ ܘܢܛܥܘܢ ܐܢ ܡܫܟܚܐ ܐܦ ܠܓܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 23,
      "referenceLabel": "Mark 13:23",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܙܕܗܪܘ ܗܐ ܩܕܡܬ ܐܡܪܬ ܠܟܘܢ ܟܠ ܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 24,
      "referenceLabel": "Mark 13:24",
      "text": "ܒܗܢܘܢ ܕܝܢ ܝܘܡܬܐ ܒܬܪ ܐܘܠܨܢܐ ܗܘ ܫܡܫܐ ܢܚܫܟ ܘܤܗܪܐ ܠܐ ܢܬܠ ܢܘܗܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 25,
      "referenceLabel": "Mark 13:25",
      "text": "ܘܟܘܟܒܐ ܢܦܠܘܢ ܡܢ ܫܡܝܐ ܘܚܝܠܘܬܐ ܕܫܡܝܐ ܢܬܬܙܝܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 26,
      "referenceLabel": "Mark 13:26",
      "text": "ܘܗܝܕܝܢ ܢܚܙܘܢܝܗܝ ܠܒܪܗ ܕܐܢܫܐ ܟܕ ܐܬܐ ܒܥܢܢܐ ܥܡ ܚܝܠܐ ܪܒܐ ܘܥܡ ܫܘܒܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 27,
      "referenceLabel": "Mark 13:27",
      "text": "ܗܝܕܝܢ ܢܫܕܪ ܡܠܐܟܘܗܝ ܘܢܟܢܫ ܠܓܒܘܗܝ ܡܢ ܐܪܒܥܬܝܗܝܢ ܪܘܚܐ ܡܢ ܪܫܗ ܕܐܪܥܐ ܘܥܕܡܐ ܠܪܫܗ ܕܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 28,
      "referenceLabel": "Mark 13:28",
      "text": "ܡܢ ܬܬܐ ܕܝܢ ܝܠܦܘ ܦܠܐܬܐ ܕܡܐ ܕܪܟ ܤܘܟܝܗ ܘܦܪܥܘ ܛܪܦܝܗ ܝܕܥܝܢ ܐܢܬܘܢ ܕܡܛܐ ܩܝܛܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 29,
      "referenceLabel": "Mark 13:29",
      "text": "ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܡܐ ܕܚܙܝܬܘܢ ܗܠܝܢ ܕܗܘܝܢ ܕܥܘ ܕܩܪܝܒܐ ܗܝ ܥܠ ܬܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 30,
      "referenceLabel": "Mark 13:30",
      "text": "ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܐ ܬܥܒܪ ܫܪܒܬܐ ܗܕܐ ܥܕܡܐ ܕܗܠܝܢ ܟܠܗܝܢ ܢܗܘܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 31,
      "referenceLabel": "Mark 13:31",
      "text": "ܫܡܝܐ ܘܐܪܥܐ ܢܥܒܪܘܢ ܘܡܠܝ ܠܐ ܢܥܒܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 32,
      "referenceLabel": "Mark 13:32",
      "text": "ܥܠ ܕܝܢ ܝܘܡܐ ܗܘ ܘܥܠ ܫܥܬܐ ܗܝ ܐܢܫ ܠܐ ܝܕܥ ܐܦܠܐ ܡܠܐܟܐ ܕܫܡܝܐ ܘܠܐ ܒܪܐ ܐܠܐ ܐܢ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 33,
      "referenceLabel": "Mark 13:33",
      "text": "ܚܙܘ ܐܬܬܥܝܪܘ ܘܨܠܘ ܠܐ ܓܝܪ ܝܕܥܝܢ ܐܢܬܘܢ ܐܡܬܝ ܗܘ ܙܒܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 34,
      "referenceLabel": "Mark 13:34",
      "text": "ܐܝܟ ܓܒܪܐ ܗܘ ܓܝܪ ܕܚܙܩ ܘܫܒܩ ܒܝܬܗ ܘܝܗܒ ܫܘܠܛܢܐ ܠܥܒܕܘܗܝ ܘܠܐܢܫ ܐܢܫ ܥܒܕܗ ܘܠܬܪܥܐ ܦܩܕ ܕܢܗܘܐ ܥܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 35,
      "referenceLabel": "Mark 13:35",
      "text": "ܐܬܬܥܝܪܘ ܗܟܝܠ ܕܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܐܡܬܝ ܐܬܐ ܡܪܗ ܕܒܝܬܐ ܒܪܡܫܐ ܐܘ ܒܦܠܓܗ ܕܠܠܝܐ ܐܘ ܒܡܩܪܐ ܬܪܢܓܠܐ ܐܘ ܒܨܦܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
      "verseNumber": 36,
      "referenceLabel": "Mark 13:36",
      "text": "ܕܠܡܐ ܢܐܬܐ ܡܢ ܫܠܝܐ ܘܢܫܟܚܟܘܢ ܟܕ ܕܡܟܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.13.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 13,
