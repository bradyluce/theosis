{
  "chapter": {
    "id": "peshitta:mark.5",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 5,
    "referenceLabel": "Mark 5",
    "summary": "Source text for Mark 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.5.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Mark 5:1",
      "text": "ܘܐܬܐ ܠܥܒܪܐ ܕܝܡܐ ܠܐܬܪܐ ܕܓܕܪܝܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.5.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Mark 5:2",
      "text": "ܘܟܕ ܢܦܩ ܡܢ ܤܦܝܢܬܐ ܦܓܥ ܒܗ ܡܢ ܒܝܬ ܩܒܘܪܐ ܓܒܪܐ ܕܐܝܬ ܒܗ ܪܘܚܐ ܛܢܦܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Mark 5:3",
      "text": "ܘܥܡܪ ܗܘܐ ܒܝܬ ܩܒܘܪܐ ܘܒܫܫܠܬܐ ܐܢܫ ܠܐ ܡܫܟܚ ܗܘܐ ܠܡܐܤܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Mark 5:4",
      "text": "ܡܛܠ ܕܟܠ ܐܡܬܝ ܕܒܤܘܛܡܐ ܘܒܫܫܠܬܐ ܡܬܐܤܪ ܗܘܐ ܫܫܠܬܐ ܡܬܒܪ ܗܘܐ ܘܤܘܛܡܐ ܡܦܤܩ ܗܘܐ ܘܠܐ ܐܢܫ ܡܫܟܚ ܗܘܐ ܠܡܟܒܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Mark 5:5",
      "text": "ܘܒܟܠ ܙܒܢ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܒܒܝܬ ܩܒܘܪܐ ܘܒܛܘܪܐ ܐܝܬܘܗܝ ܗܘܐ ܘܩܥܐ ܗܘܐ ܘܡܨܠܦ ܢܦܫܗ ܒܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Mark 5:6",
      "text": "ܟܕ ܚܙܐ ܕܝܢ ܠܝܫܘܥ ܡܢ ܪܘܚܩܐ ܪܗܛ ܤܓܕ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Mark 5:7",
      "text": "ܘܩܥܐ ܒܩܠܐ ܪܡܐ ܘܐܡܪ ܡܐ ܠܝ ܘܠܟ ܝܫܘܥ ܒܪܗ ܕܐܠܗܐ ܡܪܝܡܐ ܡܘܡܐ ܐܢܐ ܠܟ ܒܐܠܗܐ ܕܠܐ ܬܫܢܩܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Mark 5:8",
      "text": "ܐܡܪ ܗܘܐ ܠܗ ܓܝܪ ܦܘܩ ܡܢ ܒܪܢܫܐ ܪܘܚܐ ܛܢܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Mark 5:9",
      "text": "ܘܫܐܠܗ ܐܝܟܢܐ ܫܡܟ ܐܡܪ ܠܗ ܠܓܝܘܢ ܫܡܢ ܡܛܠ ܕܤܓܝܐܐ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Mark 5:10",
      "text": "ܘܒܥܐ ܗܘܐ ܡܢܗ ܤܓܝ ܕܠܐ ܢܫܕܪܝܘܗܝ ܠܒܪ ܡܢ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Mark 5:11",
      "text": "ܐܝܬ ܗܘܐ ܕܝܢ ܬܡܢ ܠܘܬ ܛܘܪܐ ܒܩܪܐ ܪܒܬܐ ܕܚܙܝܪܐ ܕܪܥܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Mark 5:12",
      "text": "ܘܒܥܝܢ ܗܘܘ ܡܢܗ ܗܢܘܢ ܫܐܕܐ ܘܐܡܪܝܢ ܫܕܪܝܢ ܥܠ ܗܢܘܢ ܚܙܝܪܐ ܕܒܗܘܢ ܢܥܘܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Mark 5:13",
      "text": "ܘܐܦܤ ܠܗܘܢ ܘܢܦܩ ܪܘܚܐ ܗܠܝܢ ܛܢܦܬܐ ܘܥܠ ܒܚܙܝܪܐ ܘܪܗܛܬ ܗܝ ܒܩܪܐ ܠܫܩܝܦܐ ܘܢܦܠܬ ܒܝܡܐ ܐܝܟ ܬܪܝܢ ܐܠܦܝܢ ܘܐܬܚܢܩܘ ܒܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Mark 5:14",
      "text": "ܘܗܢܘܢ ܕܪܥܝܢ ܗܘܘ ܠܗܘܢ ܥܪܩܘ ܘܐܡܪܘ ܒܡܕܝܢܬܐ ܘܐܦ ܒܩܘܪܝܐ ܘܢܦܩܘ ܠܡܚܙܐ ܡܕܡ ܕܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Mark 5:15",
      "text": "ܘܐܬܘ ܠܘܬ ܝܫܘܥ ܘܚܙܐܘܗܝ ܠܗܘ ܕܫܐܕܘܗܝ ܟܕ ܠܒܝܫ ܘܡܢܟܦ ܘܝܬܒ ܗܘ ܕܐܝܬ ܗܘܐ ܒܗ ܠܓܝܘܢ ܘܕܚܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Mark 5:16",
      "text": "ܘܐܫܬܥܝܘ ܠܗܘܢ ܗܢܘܢ ܕܚܙܘ ܕܐܝܟܢܐ ܗܘܐ ܠܗܘ ܕܫܐܕܘܗܝ ܘܐܦ ܥܠ ܗܢܘܢ ܚܙܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Mark 5:17",
      "text": "ܘܫܪܝܘ ܒܥܝܢ ܡܢܗ ܕܢܐܙܠ ܠܗ ܡܢ ܬܚܘܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Mark 5:18",
      "text": "ܘܟܕ ܤܠܩ ܠܤܦܝܢܬܐ ܒܥܐ ܗܘܐ ܡܢܗ ܗܘ ܕܫܐܕܘܗܝ ܕܥܡܗ ܢܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Mark 5:19",
      "text": "ܘܠܐ ܫܒܩܗ ܐܠܐ ܐܡܪ ܠܗ ܙܠ ܠܒܝܬܟ ܠܘܬ ܐܢܫܝܟ ܘܐܫܬܥܐ ܠܗܘܢ ܡܕܡ ܕܥܒܕ ܠܟ ܡܪܝܐ ܘܕܐܬܪܚܡ ܥܠܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Mark 5:20",
      "text": "ܘܐܙܠ ܘܫܪܝ ܡܟܪܙ ܒܥܤܪܬ ܡܕܝܢܬܐ ܡܕܡ ܕܥܒܕ ܠܗ ܝܫܘܥ ܘܟܠܗܘܢ ܬܡܝܗܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Mark 5:21",
      "text": "ܘܟܕ ܥܒܪ ܝܫܘܥ ܒܤܦܝܢܬܐ ܠܗܘ ܥܒܪܐ ܬܘܒ ܐܬܟܢܫܘ ܥܠܘܗܝ ܟܢܫܐ ܤܓܝܐܐ ܟܕ ܐܝܬܘܗܝ ܥܠ ܝܕ ܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Mark 5:22",
      "text": "ܘܐܬܐ ܚܕ ܕܫܡܗ ܝܘܐܪܫ ܡܢ ܪܒܝ ܟܢܘܫܬܐ ܘܟܕ ܚܙܝܗܝ ܢܦܠ ܠܘܬ ܪܓܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Mark 5:23",
      "text": "ܘܒܥܐ ܗܘܐ ܡܢܗ ܤܓܝ ܘܐܡܪ ܠܗ ܒܪܬܝ ܒܝܫܐܝܬ ܥܒܝܕܐ ܬܐ ܤܝܡ ܐܝܕܟ ܥܠܝܗ ܘܬܬܚܠܡ ܘܬܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Mark 5:24",
      "text": "ܘܐܙܠ ܥܡܗ ܝܫܘܥ ܘܕܒܝܩ ܗܘܐ ܠܗ ܟܢܫܐ ܤܓܝܐܐ ܘܚܒܨܝܢ ܗܘܘ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Mark 5:25",
      "text": "ܐܢܬܬܐ ܕܝܢ ܚܕܐ ܕܐܝܬܝܗ ܗܘܬ ܒܡܪܕܝܬܐ ܕܕܡܐ ܫܢܝܢ ܬܪܬܥܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Mark 5:26",
      "text": "ܐܝܕܐ ܕܤܓܝ ܤܒܠܬ ܡܢ ܐܤܘܬܐ ܤܓܝܐܐ ܘܐܦܩܬ ܟܠ ܡܕܡ ܕܐܝܬ ܠܗ ܘܡܕܡ ܠܐ ܐܬܥܕܪܬ ܐܠܐ ܐܦ ܝܬܝܪܐܝܬ ܐܬܐܠܨܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Mark 5:27",
      "text": "ܟܕ ܫܡܥܬ ܥܠ ܝܫܘܥ ܐܬܬ ܒܚܒܨܐ ܕܟܢܫܐ ܡܢ ܒܤܬܪܗ ܩܪܒܬ ܠܠܒܘܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Mark 5:28",
      "text": "ܐܡܪܐ ܗܘܬ ܓܝܪ ܕܐܦܢ ܠܠܒܘܫܗ ܩܪܒܐ ܐܢܐ ܚܝܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Mark 5:29",
      "text": "ܘܡܚܕܐ ܝܒܫܬ ܡܥܝܢܐ ܕܕܡܗ ܘܐܪܓܫܬ ܒܦܓܪܗ ܕܐܬܐܤܝܬ ܡܢ ܡܚܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Mark 5:30",
      "text": "ܝܫܘܥ ܕܝܢ ܡܚܕܐ ܝܕܥ ܒܢܦܫܗ ܕܚܝܠܐ ܢܦܩ ܡܢܗ ܘܐܬܦܢܝ ܠܘܬ ܟܢܫܐ ܘܐܡܪ ܡܢܘ ܩܪܒ ܠܡܐܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Mark 5:31",
      "text": "ܘܐܡܪܝܢ ܠܗ ܬܠܡܝܕܘܗܝ ܚܙܐ ܐܢܬ ܠܟܢܫܐ ܕܚܒܨܝܢ ܠܟ ܘܐܡܪ ܐܢܬ ܡܢܘ ܩܪܒ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Mark 5:32",
      "text": "ܘܚܐܪ ܗܘܐ ܕܢܚܙܐ ܡܢܘ ܗܕܐ ܥܒܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Mark 5:33",
      "text": "ܗܝ ܕܝܢ ܐܢܬܬܐ ܟܕ ܕܚܝܠܐ ܘܪܬܝܬܐ ܕܝܕܥܬ ܡܐ ܕܗܘܐ ܠܗ ܐܬܬ ܢܦܠܬ ܩܕܡܘܗܝ ܘܐܡܪܬ ܠܗ ܟܠܗ ܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 34,
      "referenceLabel": "Mark 5:34",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗ ܒܪܬܝ ܗܝܡܢܘܬܟܝ ܐܚܝܬܟܝ ܙܠܝ ܒܫܠܡܐ ܘܗܘܝܬܝ ܚܠܝܡܐ ܡܢ ܡܚܘܬܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 35,
      "referenceLabel": "Mark 5:35",
      "text": "ܘܥܕ ܗܘ ܡܡܠܠ ܐܬܘ ܡܢ ܕܒܝܬ ܪܒ ܟܢܘܫܬܐ ܘܐܡܪܝܢ ܕܒܪܬܟ ܡܝܬܬ ܠܡܢܐ ܡܟܝܠ ܡܥܡܠ ܐܢܬ ܠܡܠܦܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 36,
      "referenceLabel": "Mark 5:36",
      "text": "ܝܫܘܥ ܕܝܢ ܫܡܥ ܠܡܠܬܐ ܕܐܡܪܘ ܘܐܡܪ ܠܗܘ ܪܒ ܟܢܘܫܬܐ ܠܐ ܬܕܚܠ ܒܠܚܘܕ ܗܝܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 37,
      "referenceLabel": "Mark 5:37",
      "text": "ܘܠܐ ܫܒܩ ܠܐܢܫ ܕܢܐܙܠ ܥܡܗ ܐܠܐ ܠܫܡܥܘܢ ܟܐܦܐ ܘܠܝܥܩܘܒ ܘܠܝܘܚܢܢ ܐܚܘܗܝ ܕܝܥܩܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 38,
      "referenceLabel": "Mark 5:38",
      "text": "ܘܐܬܘ ܠܒܝܬܐ ܕܗܘ ܪܒ ܟܢܘܫܬܐ ܘܚܙܐ ܕܪܗܝܒܝܢ ܘܒܟܝܢ ܘܡܝܠܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.5.39",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 5,
      "verseNumber": 39,
      "referenceLabel": "Mark 5:39",
      "text": "ܘܥܠ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܪܗܝܒܝܢ ܐܢܬܘܢ ܘܒܟܝܢ ܛܠܝܬܐ ܠܐ ܡܝܬܬ ܐܠܐ ܕܡܟܐ ܗܝ ܀",
      "paragraphStart": false
