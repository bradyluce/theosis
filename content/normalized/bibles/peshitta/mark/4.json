{
  "chapter": {
    "id": "peshitta:mark.4",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 4,
    "referenceLabel": "Mark 4",
    "summary": "Source text for Mark 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.4.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Mark 4:1",
      "text": "ܬܘܒ ܕܝܢ ܫܪܝ ܗܘܐ ܡܠܦ ܥܠ ܝܕ ܝܡܐ",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.4.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Mark 4:2",
      "text": "ܘܡܠܦ ܗܘܐ ܠܗܘܢ ܒܡܬܠܐ ܤܓܝ ܘܐܡܪ ܗܘܐ ܒܝܘܠܦܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Mark 4:3",
      "text": "ܫܡܥܘ ܗܐ ܢܦܩ ܙܪܘܥܐ ܠܡܙܪܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Mark 4:4",
      "text": "ܘܟܕ ܙܪܥ ܐܝܬ ܕܢܦܠ ܥܠ ܝܕ ܐܘܪܚܐ ܘܐܬܬ ܦܪܚܬܐ ܘܐܟܠܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Mark 4:5",
      "text": "ܐܚܪܢܐ ܕܝܢ ܢܦܠ ܥܠ ܫܘܥܐ ܐܝܟܐ ܕܠܝܬ ܐܪܥܐ ܤܓܝ ܘܒܪ ܫܥܬܗ ܒܠܨ ܡܛܠ ܕܠܝܬ ܗܘܐ ܥܘܡܩܐ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Mark 4:6",
      "text": "ܟܕ ܕܢܚ ܕܝܢ ܫܡܫܐ ܚܡܐ ܘܡܛܠ ܕܠܝܬ ܗܘܐ ܠܗ ܥܩܪܐ ܝܒܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Mark 4:7",
      "text": "ܘܐܚܪܢܐ ܢܦܠ ܒܝܬ ܟܘܒܐ ܘܤܠܩܘ ܟܘܒܐ ܘܚܢܩܘܗܝ ܘܦܐܪܐ ܠܐ ܝܗܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Mark 4:8",
      "text": "ܐܚܪܢܐ ܕܝܢ ܢܦܠ ܥܠ ܐܪܥܐ ܛܒܬܐ ܘܤܠܩ ܘܪܒܐ ܘܝܗܒ ܦܐܪܐ ܐܝܬ ܕܬܠܬܝܢ ܘܐܝܬ ܕܫܬܝܢ ܘܐܝܬ ܕܡܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Mark 4:9",
      "text": "ܘܐܡܪ ܗܘܐ ܡܢ ܕܐܝܬ ܠܗ ܐܕܢܐ ܕܢܫܡܥ ܢܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Mark 4:10",
      "text": "ܟܕ ܗܘܘ ܕܝܢ ܒܠܚܘܕܝܗܘܢ ܫܐܠܘܗܝ ܗܢܘܢ ܕܥܡܗ ܥܡ ܬܪܥܤܪܬܗ ܡܬܠܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Mark 4:11",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܟܘܢ ܝܗܝܒ ܠܡܕܥ ܐܪܙܐ ܕܡܠܟܘܬܗ ܕܐܠܗܐ ܠܒܪܝܐ ܕܝܢ ܟܠ ܡܕܡ ܒܡܬܠܐ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Mark 4:12",
      "text": "ܕܟܕ ܚܙܝܢ ܢܚܙܘܢ ܘܠܐ ܢܚܙܘܢ ܘܟܕ ܫܡܥܝܢ ܢܫܡܥܘܢ ܘܠܐ ܢܤܬܟܠܘܢ ܕܠܡܐ ܢܬܦܢܘܢ ܘܢܫܬܒܩܘܢ ܠܗܘܢ ܚܛܗܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Mark 4:13",
      "text": "ܘܐܡܪ ܠܗܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܠܗ ܠܡܬܠܐ ܗܢܐ ܘܐܝܟܢܐ ܟܠܗܘܢ ܡܬܠܐ ܬܕܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Mark 4:14",
      "text": "ܙܪܘܥܐ ܕܙܪܥ ܡܠܬܐ ܙܪܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Mark 4:15",
      "text": "ܗܠܝܢ ܕܝܢ ܕܥܠ ܝܕ ܐܘܪܚܐ ܗܠܝܢ ܐܢܘܢ ܕܡܙܕܪܥܐ ܒܗܘܢ ܡܠܬܐ ܘܡܐ ܕܫܡܥܘ ܡܚܕܐ ܐܬܐ ܤܛܢܐ ܘܫܩܠ ܠܗ ܠܡܠܬܐ ܕܙܪܝܥܐ ܒܠܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Mark 4:16",
      "text": "ܘܗܢܘܢ ܕܥܠ ܫܘܥܐ ܐܙܕܪܥܘ ܗܠܝܢ ܐܢܘܢ ܕܡܐ ܕܫܡܥܘ ܡܠܬܐ ܡܚܕܐ ܒܚܕܘܬܐ ܡܩܒܠܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Mark 4:17",
      "text": "ܘܠܝܬ ܠܗܘܢ ܥܩܪܐ ܒܢܦܫܗܘܢ ܐܠܐ ܕܙܒܢܐ ܐܢܘܢ ܘܡܐ ܕܗܘܐ ܐܘܠܨܢܐ ܐܘ ܪܕܘܦܝܐ ܡܛܠ ܡܠܬܐ ܥܓܠ ܡܬܟܫܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Mark 4:18",
      "text": "ܘܗܢܘܢ ܕܒܝܬ ܟܘܒܐ ܡܙܕܪܥܝܢ ܗܠܝܢ ܐܢܘܢ ܗܢܘܢ ܕܫܡܥܘ ܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Mark 4:19",
      "text": "ܘܪܢܝܐ ܕܥܠܡܐ ܗܢܐ ܘܛܘܥܝܝ ܕܥܘܬܪܐ ܘܫܪܟܐ ܕܪܓܝܓܬܐ ܐܚܪܢܝܬܐ ܥܐܠܢ ܚܢܩܢ ܠܗ ܠܡܠܬܐ ܘܕܠܐ ܦܐܪܐ ܗܘܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Mark 4:20",
      "text": "ܘܗܢܘܢ ܕܒܐܪܥܐ ܛܒܬܐ ܐܙܕܪܥܘ ܗܠܝܢ ܐܢܘܢ ܕܫܡܥܝܢ ܡܠܬܐ ܘܡܩܒܠܝܢ ܘܝܗܒܝܢ ܦܐܪܐ ܒܬܠܬܝܢ ܘܒܫܬܝܢ ܘܒܡܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Mark 4:21",
      "text": "ܘܐܡܪ ܠܗܘܢ ܕܠܡܐ ܐܬܐ ܫܪܓܐ ܕܬܚܝܬ ܤܐܬܐ ܢܬܬܤܝܡ ܐܘ ܬܚܝܬ ܥܪܤܐ ܠܐ ܗܘܐ ܕܥܠ ܡܢܪܬܐ ܢܬܬܤܝܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Mark 4:22",
      "text": "ܠܝܬ ܓܝܪ ܡܕܡ ܕܛܫܐ ܕܠܐ ܢܬܓܠܐ ܘܠܐ ܗܘܐ ܒܛܘܫܝܐ ܘܠܐ ܡܬܓܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Mark 4:23",
      "text": "ܐܢ ܐܢܫ ܐܝܬ ܠܗ ܐܕܢܐ ܕܢܫܡܥ ܢܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Mark 4:24",
      "text": "ܘܐܡܪ ܠܗܘܢ ܚܙܘ ܡܢܐ ܫܡܥܝܢ ܐܢܬܘܢ ܒܗܝ ܟܝܠܬܐ ܕܡܟܝܠܝܢ ܐܢܬܘܢ ܡܬܬܟܝܠ ܠܟܘܢ ܘܡܬܬܘܤܦ ܠܟܘܢ ܠܐܝܠܝܢ ܕܫܡܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Mark 4:25",
      "text": "ܡܢ ܕܐܝܬ ܠܗ ܓܝܪ ܢܬܝܗܒ ܠܗ ܘܡܢ ܕܠܝܬ ܠܗ ܐܦ ܗܘ ܕܐܝܬ ܠܗ ܢܫܬܩܠ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Mark 4:26",
      "text": "ܘܐܡܪ ܗܘܐ ܗܟܢܐ ܗܝ ܡܠܟܘܬܐ ܕܐܠܗܐ ܐܝܟ ܐܢܫ ܕܢܪܡܐ ܙܪܥܐ ܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Mark 4:27",
      "text": "ܘܢܕܡܟ ܘܢܩܘܡ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܘܙܪܥܐ ܢܪܒܐ ܘܢܐܪܟ ܟܕ ܗܘ ܠܐ ܝܕܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Mark 4:28",
      "text": "ܐܪܥܐ ܓܝܪ ܡܝܬܝܐ ܠܗ ܠܦܐܪܐ ܘܠܘܩܕܡ ܗܘܐ ܥܤܒܐ ܘܒܬܪܗ ܫܒܠܐ ܐܚܪܝܬ ܕܝܢ ܚܛܬܐ ܡܫܡܠܝܬܐ ܒܫܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Mark 4:29",
      "text": "ܡܐ ܕܫܡܢ ܕܝܢ ܦܐܪܐ ܡܚܕܐ ܐܬܝܐ ܡܓܠܐ ܕܡܛܝ ܚܨܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Mark 4:30",
      "text": "ܘܐܡܪ ܠܡܢܐ ܢܕܡܝܗ ܠܡܠܟܘܬܐ ܕܐܠܗܐ ܘܒܐܝܢܐ ܡܬܠܐ ܢܡܬܠܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Mark 4:31",
      "text": "ܐܝܟ ܦܪܕܬܐ ܗܝ ܕܚܪܕܠܐ ܗܝ ܕܡܐ ܕܐܙܕܪܥܬ ܒܐܪܥܐ ܙܥܘܪܝܐ ܗܝ ܡܢ ܟܠܗܘܢ ܙܪܥܘܢܐ ܕܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Mark 4:32",
      "text": "ܘܡܐ ܕܐܙܕܪܥܬ ܤܠܩܐ ܘܗܘܝܐ ܪܒܐ ܡܢ ܟܠܗܘܢ ܝܪܩܘܢܐ ܘܥܒܕܐ ܤܘܟܐ ܪܘܪܒܬܐ ܐܝܟ ܕܬܫܟܚ ܕܒܛܠܠܗ ܦܪܚܬܐ ܬܫܟܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 33,
      "referenceLabel": "Mark 4:33",
      "text": "ܒܡܬܠܐ ܕܐܝܟ ܗܠܝܢ ܡܡܠܠ ܗܘܐ ܝܫܘܥ ܥܡܗܘܢ ܡܬܠܐ ܐܝܟ ܕܡܫܟܚܝܢ ܗܘܘ ܠܡܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 34,
      "referenceLabel": "Mark 4:34",
      "text": "ܘܕܠܐ ܡܬܠܐ ܠܐ ܡܡܠܠ ܗܘܐ ܥܡܗܘܢ ܠܬܠܡܝܕܘܗܝ ܕܝܢ ܒܝܢܘܗܝ ܘܠܗܘܢ ܡܦܫܩ ܗܘܐ ܟܠܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 35,
      "referenceLabel": "Mark 4:35",
      "text": "ܘܐܡܪ ܠܗܘܢ ܒܗܘ ܝܘܡܐ ܒܪܡܫܐ ܢܥܒܪ ܠܢ ܠܥܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 36,
      "referenceLabel": "Mark 4:36",
      "text": "ܘܫܒܩܘ ܠܟܢܫܐ ܘܕܒܪܘܗܝ ܟܕ ܒܤܦܝܢܬܐ ܗܘ ܘܤܦܝܢܐ ܐܚܪܢܝܬܐ ܐܝܬ ܗܘܝ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 37,
      "referenceLabel": "Mark 4:37",
      "text": "ܘܗܘܬ ܥܠܥܠܐ ܪܒܬܐ ܘܪܘܚܐ ܘܓܠܠܐ ܢܦܠܝܢ ܗܘܘ ܒܤܦܝܢܬܐ ܘܩܪܝܒܐ ܗܘܬ ܕܬܬܡܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 38,
      "referenceLabel": "Mark 4:38",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܥܠ ܒܤܕܝܐ ܕܡܟ ܗܘܐ ܒܚܪܬܗ ܕܤܦܝܢܬܐ ܘܐܬܘ ܐܩܝܡܘܗܝ ܘܐܡܪܝܢ ܠܗ ܪܒܢ ܠܐ ܒܛܝܠ ܠܟ ܕܐܒܕܝܢ ܚܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.4.39",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 4,
      "verseNumber": 39,
