{
  "chapter": {
    "id": "peshitta:mark.9",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 9,
    "referenceLabel": "Mark 9",
    "summary": "Source text for Mark 9 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.9.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 1,
      "referenceLabel": "Mark 9:1",
      "text": "ܘܐܡܪ ܗܘܐ ܠܗܘܢ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܝܬ ܐܢܫܐ ܕܩܝܡܝܢ ܬܢܢ ܕܠܐ ܢܛܥܡܘܢ ܡܘܬܐ ܥܕܡܐ ܕܢܚܙܘܢ ܡܠܟܘܬܗ ܕܐܠܗܐ ܕܐܬܬ ܒܚܝܠܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.9.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 2,
      "referenceLabel": "Mark 9:2",
      "text": "ܘܒܬܪ ܫܬܐ ܝܘܡܝܢ ܕܒܪ ܝܫܘܥ ܠܟܐܦܐ ܘܠܝܥܩܘܒ ܘܠܝܘܚܢܢ ܘܐܤܩ ܐܢܘܢ ܠܛܘܪܐ ܪܡܐ ܒܠܚܘܕܝܗܘܢ ܘܐܬܚܠܦ ܠܥܢܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 3,
      "referenceLabel": "Mark 9:3",
      "text": "ܘܡܙܗܪ ܗܘܐ ܠܒܘܫܗ ܘܡܚܘܪ ܛܒ ܐܝܟ ܬܠܓܐ ܐܝܟܢܐ ܕܒܢܝ ܐܢܫܐ ܠܡܚܘܪܘ ܒܐܪܥܐ ܠܐ ܡܫܟܚܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 4,
      "referenceLabel": "Mark 9:4",
      "text": "ܘܐܬܚܙܝܘ ܠܗܘܢ ܐܠܝܐ ܘܡܘܫܐ ܟܕ ܡܡܠܠܝܢ ܥܡ ܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 5,
      "referenceLabel": "Mark 9:5",
      "text": "ܘܐܡܪ ܠܗ ܟܐܦܐ ܪܒܝ ܫܦܝܪ ܗܘ ܠܢ ܕܗܪܟܐ ܢܗܘܐ ܘܢܥܒܕ ܬܠܬ ܡܛܠܝܢ ܠܟ ܚܕܐ ܘܠܡܘܫܐ ܚܕܐ ܘܠܐܠܝܐ ܚܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 6,
      "referenceLabel": "Mark 9:6",
      "text": "ܠܐ ܕܝܢ ܝܕܥ ܗܘܐ ܡܢܐ ܐܡܪ ܐܝܬܝܗܘܢ ܗܘܘ ܓܝܪ ܒܕܚܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 7,
      "referenceLabel": "Mark 9:7",
      "text": "ܘܗܘܬ ܥܢܢܐ ܘܡܛܠܐ ܗܘܬ ܥܠܝܗܘܢ ܘܩܠܐ ܡܢ ܥܢܢܐ ܕܐܡܪ ܗܢܘ ܒܪܝ ܚܒܝܒܐ ܠܗ ܫܡܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 8,
      "referenceLabel": "Mark 9:8",
      "text": "ܘܡܢ ܫܠܝܐ ܟܕ ܚܪܘ ܬܠܡܝܕܐ ܠܐܢܫ ܠܐ ܚܙܘ ܐܠܐ ܠܝܫܘܥ ܒܠܚܘܕܘܗܝ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 9,
      "referenceLabel": "Mark 9:9",
      "text": "ܘܟܕ ܢܚܬܝܢ ܡܢ ܛܘܪܐ ܡܦܩܕ ܗܘܐ ܠܗܘܢ ܕܠܐܢܫ ܠܐ ܢܐܡܪܘܢ ܡܕܡ ܕܚܙܘ ܐܠܐ ܐܢ ܡܐ ܕܩܡ ܒܪܗ ܕܐܢܫܐ ܡܢ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 10,
      "referenceLabel": "Mark 9:10",
      "text": "ܘܐܚܕܘܗ ܠܡܠܬܐ ܒܢܦܫܗܘܢ ܘܒܥܝܢ ܗܘܘ ܕܡܢܐ ܗܝ ܗܕܐ ܡܠܬܐ ܕܡܐ ܕܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 11,
      "referenceLabel": "Mark 9:11",
      "text": "ܘܡܫܐܠܝܢ ܗܘܘ ܠܗ ܘܐܡܪܝܢ ܡܢܐ ܗܟܝܠ ܐܡܪܝܢ ܤܦܪܐ ܕܐܠܝܐ ܘܠܐ ܕܢܐܬܐ ܠܘܩܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 12,
      "referenceLabel": "Mark 9:12",
      "text": "ܐܡܪ ܠܗܘܢ ܐܠܝܐ ܐܬܐ ܠܘܩܕܡ ܕܟܠܡܕܡ ܢܬܩܢ ܘܐܝܟܢܐ ܟܬܝܒ ܥܠ ܒܪܗ ܕܐܢܫܐ ܕܤܓܝ ܢܚܫ ܘܢܤܬܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 13,
      "referenceLabel": "Mark 9:13",
      "text": "ܐܠܐ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܐܦ ܐܠܝܐ ܐܬܐ ܘܥܒܕܘ ܒܗ ܟܠ ܡܐ ܕܨܒܘ ܐܝܟܢܐ ܕܟܬܝܒ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 14,
      "referenceLabel": "Mark 9:14",
      "text": "ܘܟܕ ܐܬܐ ܠܘܬ ܬܠܡܝܕܐ ܚܙܐ ܠܘܬܗܘܢ ܟܢܫܐ ܤܓܝܐܐ ܘܤܦܪܐ ܟܕ ܕܪܫܝܢ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 15,
      "referenceLabel": "Mark 9:15",
      "text": "ܘܒܪ ܫܥܬܗ ܟܠܗ ܟܢܫܐ ܚܙܐܘܗܝ ܘܬܘܗܘ ܘܪܗܛܘ ܫܐܠܘ ܒܫܠܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 16,
      "referenceLabel": "Mark 9:16",
      "text": "ܘܡܫܐܠ ܗܘܐ ܠܤܦܪܐ ܡܢܐ ܕܪܫܝܢ ܐܢܬܘܢ ܥܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 17,
      "referenceLabel": "Mark 9:17",
      "text": "ܘܥܢܐ ܚܕ ܡܢ ܟܢܫܐ ܘܐܡܪ ܡܠܦܢܐ ܐܝܬܝܬ ܒܪܝ ܠܘܬܟ ܕܐܝܬ ܠܗ ܪܘܚܐ ܕܠܐ ܡܡܠܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 18,
      "referenceLabel": "Mark 9:18",
      "text": "ܘܐܝܟܐ ܕܡܕܪܟܐ ܠܗ ܚܒܛܐ ܠܗ ܘܡܪܥܬ ܘܡܚܪܩ ܫܢܘܗܝ ܘܝܒܫ ܘܐܡܪܬ ܠܬܠܡܝܕܝܟ ܕܢܦܩܘܢܝܗܝ ܘܠܐ ܐܫܟܚܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 19,
      "referenceLabel": "Mark 9:19",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗ ܐܘܢ ܫܪܒܬܐ ܕܠܐ ܡܗܝܡܢܐ ܥܕܡܐ ܠܐܡܬܝ ܐܗܘܐ ܠܘܬܟܘܢ ܘܥܕܡܐ ܠܐܡܬܝ ܐܤܝܒܪܟܘܢ ܐܝܬܐܘܗܝ ܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 20,
      "referenceLabel": "Mark 9:20",
      "text": "ܘܐܝܬܝܘܗܝ ܠܘܬܗ ܘܟܕ ܚܙܬܗ ܪܘܚܐ ܒܪ ܫܥܬܗ ܚܒܛܬܗ ܘܢܦܠ ܥܠ ܐܪܥܐ ܘܡܬܒܥܩ ܗܘܐ ܘܡܪܥܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 21,
      "referenceLabel": "Mark 9:21",
      "text": "ܘܫܐܠ ܝܫܘܥ ܠܐܒܘܗܝ ܕܟܡܐ ܠܗ ܙܒܢܐ ܗܐ ܡܢ ܕܗܟܢܐ ܗܘ ܐܡܪ ܠܗ ܗܐ ܡܢ ܛܠܝܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 22,
      "referenceLabel": "Mark 9:22",
      "text": "ܘܙܒܢܝܢ ܤܓܝܐܢ ܐܪܡܝܬܗ ܒܢܘܪܐ ܘܒܡܝܐ ܕܬܘܒܕܝܘܗܝ ܐܠܐ ܡܕܡ ܕܡܫܟܚ ܐܢܬ ܥܕܪܝܢܝ ܘܐܬܪܚܡ ܥܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 23,
      "referenceLabel": "Mark 9:23",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܢ ܡܫܟܚ ܐܢܬ ܕܬܗܝܡܢ ܟܠ ܡܕܡ ܡܫܟܚ ܕܢܗܘܐ ܠܡܢ ܕܡܗܝܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 24,
      "referenceLabel": "Mark 9:24",
      "text": "ܘܒܪ ܫܥܬܗ ܩܥܐ ܐܒܘܗܝ ܕܛܠܝܐ ܟܕ ܒܟܐ ܘܐܡܪ ܡܗܝܡܢ ܐܢܐ ܡܪܝ ܥܕܪ ܠܚܤܝܪܘܬ ܗܝܡܢܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 25,
      "referenceLabel": "Mark 9:25",
      "text": "ܟܕ ܚܙܐ ܕܝܢ ܝܫܘܥ ܕܪܗܛ ܥܡܐ ܘܡܬܟܢܫ ܠܘܬܗ ܟܐܐ ܒܗܝ ܪܘܚܐ ܛܢܦܬܐ ܘܐܡܪ ܠܗ ܪܘܚܐ ܚܪܫܬܐ ܕܠܐ ܡܡܠܠܐ ܐܢܐ ܦܩܕ ܐܢܐ ܠܟܝ ܦܘܩܝ ܡܢܗ ܘܬܘܒ ܠܐ ܬܥܠܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 26,
      "referenceLabel": "Mark 9:26",
      "text": "ܘܩܥܐ ܫܐܕܐ ܗܘ ܤܓܝ ܘܫܚܩܗ ܘܢܦܩ ܘܗܘܐ ܐܝܟ ܡܝܬܐ ܐܝܟ ܕܤܓܝܐܐ ܢܐܡܪܘܢ ܕܡܝܬ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 27,
      "referenceLabel": "Mark 9:27",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܚܕܗ ܒܐܝܕܗ ܘܐܩܝܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 28,
      "referenceLabel": "Mark 9:28",
      "text": "ܟܕ ܥܠ ܕܝܢ ܠܒܝܬܐ ܝܫܘܥ ܫܐܠܘܗܝ ܬܠܡܝܕܘܗܝ ܒܠܚܘܕܝܗܘܢ ܠܡܢܐ ܚܢܢ ܠܐ ܐܫܟܚܢ ܠܡܦܩܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 29,
      "referenceLabel": "Mark 9:29",
      "text": "ܐܡܪ ܠܗܘܢ ܗܢܐ ܓܢܤܐ ܒܡܕܡ ܠܐ ܡܫܟܚ ܠܡܦܩ ܐܠܐ ܒܨܘܡܐ ܘܒܨܠܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 30,
      "referenceLabel": "Mark 9:30",
      "text": "ܘܟܕ ܢܦܩ ܡܢ ܬܡܢ ܥܒܪܝܢ ܗܘܘ ܒܓܠܝܠܐ ܘܠܐ ܨܒܐ ܗܘܐ ܕܐܢܫ ܢܕܥ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 31,
      "referenceLabel": "Mark 9:31",
      "text": "ܡܠܦ ܗܘܐ ܓܝܪ ܠܬܠܡܝܕܘܗܝ ܘܐܡܪ ܠܗܘܢ ܕܒܪܗ ܕܐܢܫܐ ܡܫܬܠܡ ܒܐܝܕܝ ܐܢܫܐ ܘܢܩܛܠܘܢܝܗܝ ܘܡܐ ܕܐܬܩܛܠ ܒܝܘܡܐ ܕܬܠܬܐ ܢܩܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 32,
      "referenceLabel": "Mark 9:32",
      "text": "ܗܢܘܢ ܕܝܢ ܠܐ ܝܕܥܝܢ ܗܘܘ ܠܗ ܠܡܠܬܐ ܘܕܚܠܝܢ ܗܘܘ ܕܢܫܐܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 33,
      "referenceLabel": "Mark 9:33",
      "text": "ܘܐܬܘ ܠܟܦܪܢܚܘܡ ܘܟܕ ܥܠܘ ܠܒܝܬܐ ܡܫܐܠ ܗܘܐ ܠܗܘܢ ܕܡܢܐ ܡܬܚܫܒܝܢ ܗܘܝܬܘܢ ܒܐܘܪܚܐ ܒܝܢܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 34,
      "referenceLabel": "Mark 9:34",
      "text": "ܗܢܘܢ ܕܝܢ ܫܬܝܩܝܢ ܗܘܘ ܐܬܚܪܝܘ ܗܘܘ ܓܝܪ ܒܐܘܪܚܐ ܚܕ ܥܡ ܚܕ ܕܡܢܘ ܪܒ ܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 35,
      "referenceLabel": "Mark 9:35",
      "text": "ܘܝܬܒ ܝܫܘܥ ܘܩܪܐ ܠܬܪܥܤܪ ܘܐܡܪ ܠܗܘܢ ܡܢ ܕܨܒܐ ܕܢܗܘܐ ܩܕܡܝܐ ܢܗܘܐ ܐܚܪܝܐ ܕܟܠ ܐܢܫ ܘܡܫܡܫܢܐ ܕܟܠ ܐܢܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 36,
      "referenceLabel": "Mark 9:36",
      "text": "ܘܢܤܒ ܛܠܝܐ ܚܕ ܘܐܩܝܡܗ ܒܡܨܥܬܐ ܘܫܩܠܗ ܥܠ ܕܪܥܘܗܝ ܘܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.9.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 9,
      "verseNumber": 37,
