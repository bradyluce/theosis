{
  "chapter": {
    "id": "peshitta:mark.6",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 6,
    "referenceLabel": "Mark 6",
    "summary": "Source text for Mark 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.6.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Mark 6:1",
      "text": "ܘܢܦܩ ܡܢ ܬܡܢ ܘܐܬܐ ܠܡܕܝܢܬܗ ܘܕܒܝܩܝܢ ܗܘܘ ܠܗ ܬܠܡܝܕܘܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.6.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Mark 6:2",
      "text": "ܘܟܕ ܗܘܬ ܫܒܬܐ ܫܪܝ ܠܡܠܦܘ ܒܟܢܘܫܬܐ ܘܤܓܝܐܐ ܕܫܡܥܘ ܐܬܕܡܪܘ ܘܐܡܪܝܢ ܗܘܘ ܐܝܡܟܐ ܠܗ ܗܠܝܢ ܠܗܢܐ ܘܐܝܕܐ ܗܝ ܚܟܡܬܐ ܕܐܬܝܗܒܬ ܠܗ ܕܚܝܠܐ ܕܐܝܟ ܗܠܝܢ ܒܐܝܕܘܗܝ ܢܗܘܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Mark 6:3",
      "text": "ܠܐ ܗܘܐ ܗܢܐ ܢܓܪܐ ܒܪܗ ܕܡܪܝܡ ܘܐܚܘܗܝ ܕܝܥܩܘܒ ܘܕܝܘܤܐ ܘܕܝܗܘܕܐ ܘܕܫܡܥܘܢ ܘܠܐ ܗܐ ܐܚܘܬܗ ܬܢܢ ܠܘܬܢ ܘܡܬܟܫܠܝܢ ܗܘܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Mark 6:4",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܝܬ ܢܒܝܐ ܕܨܥܝܪ ܐܠܐ ܐܢ ܒܡܕܝܢܬܗ ܘܒܝܬ ܐܚܝܢܘܗܝ ܘܒܒܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Mark 6:5",
      "text": "ܘܠܐ ܡܫܟܚ ܗܘܐ ܕܢܥܒܕ ܬܡܢ ܐܦ ܠܐ ܚܕ ܚܝܠܐ ܐܠܐ ܐܢ ܕܥܠ ܟܪܝܗܐ ܩܠܝܠ ܤܡ ܐܝܕܗ ܘܐܤܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Mark 6:6",
      "text": "ܘܡܬܕܡܪ ܗܘܐ ܒܚܤܝܪܘܬ ܗܝܡܢܘܬܗܘܢ ܘܡܬܟܪܟ ܗܘܐ ܒܩܘܪܝܐ ܟܕ ܡܠܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Mark 6:7",
      "text": "ܘܩܪܐ ܠܬܪܥܤܪܬܗ ܘܫܪܝ ܕܢܫܕܪ ܐܢܘܢ ܬܪܝܢ ܬܪܝܢ ܘܝܗܒ ܠܗܘܢ ܫܘܠܛܢܐ ܥܠ ܪܘܚܐ ܛܢܦܬܐ ܕܢܦܩܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Mark 6:8",
      "text": "ܘܦܩܕ ܐܢܘܢ ܕܠܐ ܢܫܩܠܘܢ ܡܕܡ ܠܐܘܪܚܐ ܐܠܐ ܐܢ ܫܒܛܐ ܒܠܚܘܕ ܠܐ ܬܪܡܠܐ ܘܠܐ ܠܚܡܐ ܘܠܐ ܢܚܫܐ ܒܟܝܤܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Mark 6:9",
      "text": "ܐܠܐ ܢܤܐܢܘܢ ܛܠܪܐ ܘܠܐ ܢܠܒܫܘܢ ܬܪܬܝܢ ܟܘܬܝܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Mark 6:10",
      "text": "ܘܐܡܪ ܠܗܘܢ ܕܠܐܝܢܐ ܒܝܬܐ ܕܥܐܠܝܢ ܐܢܬܘܢ ܬܡܢ ܗܘܘ ܥܕܡܐ ܕܢܦܩܝܢ ܐܢܬܘܢ ܡܢ ܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Mark 6:11",
      "text": "ܘܟܠ ܡܢ ܕܠܐ ܢܩܒܠܘܢܟܘܢ ܘܠܐ ܢܫܡܥܘܢܟܘܢ ܡܐ ܕܢܦܩܝܢ ܐܢܬܘܢ ܡܢ ܬܡܢ ܦܨܘ ܚܠܐ ܕܒܬܚܬܝܐ ܕܪܓܠܝܟܘܢ ܠܤܗܕܘܬܗܘܢ ܘܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܢܗܘܐ ܢܝܚ ܠܤܕܘܡ ܘܠܥܡܘܪܐ ܒܝܘܡܐ ܕܕܝܢܐ ܐܘ ܠܡܕܝܢܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Mark 6:12",
      "text": "ܘܢܦܩܘ ܗܘܘ ܘܐܟܪܙܘ ܕܢܬܘܒܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Mark 6:13",
      "text": "ܘܫܐܕܐ ܤܓܝܐܐ ܡܦܩܝܢ ܗܘܘ ܘܡܫܚܝܢ ܗܘܘ ܒܡܫܚܐ ܟܪܝܗܐ ܤܓܝܐܐ ܘܡܐܤܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Mark 6:14",
      "text": "ܘܫܡܥ ܗܪܘܕܤ ܡܠܟܐ ܥܠ ܝܫܘܥ ܐܬܝܕܥ ܗܘܐ ܠܗ ܓܝܪ ܫܡܗ ܘܐܡܪ ܗܘܐ ܝܘܚܢܢ ܡܥܡܕܢܐ ܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܡܛܠ ܗܢܐ ܚܝܠܐ ܡܤܬܥܪܝܢ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Mark 6:15",
      "text": "ܐܚܪܢܐ ܐܡܪܝܢ ܗܘܘ ܕܐܠܝܐ ܗܘ ܘܐܚܪܢܐ ܕܢܒܝܐ ܗܘ ܐܝܟ ܚܕ ܡܢ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Mark 6:16",
      "text": "ܟܕ ܫܡܥ ܕܝܢ ܗܪܘܕܤ ܐܡܪ ܝܘܚܢܢ ܗܘ ܕܐܢܐ ܦܤܩܬ ܪܫܗ ܗܘ ܩܡ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Mark 6:17",
      "text": "ܗܘ ܓܝܪ ܗܪܘܕܤ ܫܕܪ ܗܘܐ ܐܚܕܗ ܠܝܘܚܢܢ ܘܐܤܪܗ ܒܝܬ ܐܤܝܪܐ ܡܛܠ ܗܪܘܕܝܐ ܐܢܬܬ ܦܝܠܝܦܘܤ ܐܚܘܗܝ ܗܝ ܕܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Mark 6:18",
      "text": "ܐܡܪ ܗܘܐ ܓܝܪ ܝܘܚܢܢ ܠܗܪܘܕܤ ܕܠܐ ܫܠܝܛ ܠܟ ܕܬܤܒ ܐܢܬܬ ܐܚܘܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Mark 6:19",
      "text": "ܗܝ ܕܝܢ ܗܪܘܕܝܐ ܠܚܝܡܐ ܗܘܬ ܠܗ ܘܨܒܝܢ ܗܘܬ ܠܡܩܛܠܗ ܘܠܐ ܡܫܟܚܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Mark 6:20",
      "text": "ܗܪܘܕܤ ܓܝܪ ܕܚܠ ܗܘܐ ܡܢ ܝܘܚܢܢ ܥܠ ܕܝܕܥ ܗܘܐ ܕܓܒܪܐ ܗܘ ܙܕܝܩܐ ܘܩܕܝܫܐ ܘܡܢܛܪ ܗܘܐ ܠܗ ܘܤܓܝܐܬܐ ܫܡܥ ܗܘܐ ܠܗ ܘܥܒܕ ܘܒܤܝܡܐܝܬ ܫܡܥ ܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Mark 6:21",
      "text": "ܘܗܘܐ ܝܘܡܐ ܝܕܝܥܐ ܟܕ ܗܪܘܕܤ ܒܒܝܬ ܝܠܕܗ ܚܫܡܝܬܐ ܥܒܕ ܗܘܐ ܠܪܘܪܒܢܘܗܝ ܘܠܟܝܠܝܪܟܐ ܘܠܪܫܐ ܕܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Mark 6:22",
      "text": "ܘܥܠܬ ܒܪܬܗ ܕܗܪܘܕܝܐ ܪܩܕܬ ܘܫܦܪܬ ܠܗ ܠܗܪܘܕܤ ܘܠܐܝܠܝܢ ܕܤܡܝܟܝܢ ܥܡܗ ܘܐܡܪ ܡܠܟܐ ܠܛܠܝܬܐ ܫܐܠܝ ܡܢܝ ܡܕܡ ܕܨܒܝܐ ܐܢܬܝ ܘܐܬܠ ܠܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Mark 6:23",
      "text": "ܘܝܡܐ ܠܗ ܕܡܕܡ ܕܬܫܐܠܝܢ ܐܬܠ ܠܟܝ ܥܕܡܐ ܠܦܠܓܗ ܕܡܠܟܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Mark 6:24",
      "text": "ܗܝ ܕܝܢ ܢܦܩܬ ܘܐܡܪܐ ܠܐܡܗ ܡܢܐ ܐܫܐܠܝܘܗܝ ܐܡܪܐ ܠܗ ܪܫܗ ܕܝܘܚܢܢ ܡܥܡܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 25,
      "referenceLabel": "Mark 6:25",
      "text": "ܘܡܚܕܐ ܥܠܬ ܒܒܛܝܠܘܬܐ ܠܘܬ ܡܠܟܐ ܘܐܡܪܐ ܠܗ ܨܒܝܐ ܐܢܐ ܒܗܕܐ ܫܥܬܐ ܕܬܬܠ ܠܝ ܥܠ ܦܝܢܟܐ ܪܫܗ ܕܝܘܚܢܢ ܡܥܡܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 26,
      "referenceLabel": "Mark 6:26",
      "text": "ܘܟܪܝܬ ܠܗ ܤܓܝ ܠܡܠܟܐ ܡܛܠ ܕܝܢ ܡܘܡܬܐ ܘܡܛܠ ܤܡܝܟܐ ܠܐ ܨܒܐ ܕܢܓܠܙܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 27,
      "referenceLabel": "Mark 6:27",
      "text": "ܐܠܐ ܡܚܕܐ ܫܕܪ ܡܠܟܐ ܐܤܦܘܩܠܛܪܐ ܘܦܩܕ ܕܢܝܬܐ ܪܫܗ ܕܝܘܚܢܢ ܘܐܙܠ ܦܤܩܗ ܪܫܗ ܕܝܘܚܢܢ ܒܝܬ ܐܤܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 28,
      "referenceLabel": "Mark 6:28",
      "text": "ܘܐܝܬܝ ܒܦܝܢܟܐ ܘܝܗܒ ܠܛܠܝܬܐ ܘܗܝ ܛܠܝܬܐ ܝܗܒܬ ܠܐܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 29,
      "referenceLabel": "Mark 6:29",
      "text": "ܘܫܡܥܘ ܬܠܡܝܕܘܗܝ ܘܐܬܘ ܫܩܠܘ ܫܠܕܗ ܘܤܡܘ ܒܒܝܬ ܩܒܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 30,
      "referenceLabel": "Mark 6:30",
      "text": "ܘܐܬܟܢܫܘ ܫܠܝܚܐ ܠܘܬ ܝܫܘܥ ܘܐܡܪܘ ܠܗ ܟܠ ܡܐ ܕܥܒܕܘ ܘܟܠ ܡܐ ܕܐܠܦܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 31,
      "referenceLabel": "Mark 6:31",
      "text": "ܘܐܡܪ ܠܗܘܢ ܬܘ ܠܟܘܢ ܢܐܙܠ ܠܕܒܪܐ ܒܠܚܘܕܝܢ ܘܐܬܬܢܝܚܘ ܩܠܝܠ ܐܝܬ ܗܘܘ ܓܝܪ ܤܓܝܐܐ ܕܐܙܠܝܢ ܘܐܬܝܢ ܘܠܝܬ ܗܘܐ ܠܗܘܢ ܐܬܪܐ ܐܦ ܠܐ ܠܡܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 32,
      "referenceLabel": "Mark 6:32",
      "text": "ܘܐܙܠܘ ܠܐܬܪܐ ܚܘܪܒܐ ܒܤܦܝܢܬܐ ܒܠܚܘܕܝܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 33,
      "referenceLabel": "Mark 6:33",
      "text": "ܘܚܙܘ ܐܢܘܢ ܤܓܝܐܐ ܟܕ ܐܙܠܝܢ ܘܐܫܬܘܕܥܘ ܐܢܘܢ ܘܒܝܒܫܐ ܪܗܛܘ ܡܢ ܟܠܗܝܢ ܡܕܝܢܬܐ ܩܕܡܘܗܝ ܠܬܡܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 34,
      "referenceLabel": "Mark 6:34",
      "text": "ܘܢܦܩ ܝܫܘܥ ܚܙܐ ܟܢܫܐ ܤܓܝܐܐ ܘܐܬܪܚܡ ܥܠܝܗܘܢ ܕܕܡܝܢ ܗܘܘ ܠܥܪܒܐ ܕܠܝܬ ܠܗܘܢ ܪܥܝܐ ܘܫܪܝ ܗܘܐ ܠܡܠܦܘ ܐܢܘܢ ܤܓܝܐܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 35,
      "referenceLabel": "Mark 6:35",
      "text": "ܘܟܕ ܗܘܐ ܥܕܢܐ ܤܓܝܐܐ ܩܪܒܘ ܠܘܬܗ ܬܠܡܝܕܘܗܝ ܘܐܡܪܝܢ ܠܗ ܕܗܢܐ ܐܬܪܐ ܚܘܪܒܐ ܗܘ ܘܥܕܢܐ ܤܓܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 36,
      "referenceLabel": "Mark 6:36",
      "text": "ܫܪܝ ܐܢܘܢ ܕܢܐܙܠܘܢ ܠܐܓܘܪܤܐ ܕܚܕܪܝܢ ܘܠܩܘܪܝܐ ܘܢܙܒܢܘܢ ܠܗܘܢ ܠܚܡܐ ܠܝܬ ܠܗܘܢ ܓܝܪ ܡܕܡ ܠܡܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 37,
      "referenceLabel": "Mark 6:37",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܗܒܘ ܠܗܘܢ ܐܢܬܘܢ ܠܡܠܥܤ ܐܡܪܝܢ ܠܗ ܢܐܙܠ ܢܙܒܢ ܕܡܐܬܝܢ ܕܝܢܪܝܢ ܠܚܡܐ ܘܢܬܠ ܠܗܘܢ ܠܥܤܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 38,
      "referenceLabel": "Mark 6:38",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܙܠܘ ܚܙܘ ܟܡܐ ܠܚܡܝܢ ܐܝܬ ܠܟܘܢ ܗܪܟܐ ܘܟܕ ܚܙܘ ܐܡܪܝܢ ܠܗ ܚܡܫܐ ܠܚܡܝܢ ܘܬܪܝܢ ܢܘܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.39",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 39,
      "referenceLabel": "Mark 6:39",
      "text": "ܘܦܩܕ ܠܗܘܢ ܕܢܤܡܟܘܢ ܠܟܠܢܫ ܤܡܟܝܢ ܤܡܟܝܢ ܥܠ ܥܤܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.40",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 40,
      "referenceLabel": "Mark 6:40",
      "text": "ܘܐܤܬܡܟܘ ܤܡܟܝܢ ܤܡܟܝܢ ܕܡܐܐ ܡܐܐ ܘܕܚܡܫܝܢ ܚܡܫܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.41",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 41,
      "referenceLabel": "Mark 6:41",
      "text": "ܘܢܤܒ ܗܢܘܢ ܚܡܫܐ ܠܚܡܝܢ ܘܬܪܝܢ ܢܘܢܝܢ ܘܚܪ ܒܫܡܝܐ ܘܒܪܟ ܘܩܨܐ ܠܚܡܐ ܘܝܗܒ ܠܬܠܡܝܕܘܗܝ ܕܢܤܝܡܘܢ ܠܗܘܢ ܘܗܢܘܢ ܬܪܝܢ ܢܘܢܝܢ ܦܠܓܘ ܠܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.42",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 42,
      "referenceLabel": "Mark 6:42",
      "text": "ܘܐܟܠܘ ܟܠܗܘܢ ܘܤܒܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.43",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 43,
      "referenceLabel": "Mark 6:43",
      "text": "ܘܫܩܠܘ ܩܨܝܐ ܬܪܥܤܪ ܩܘܦܝܢܝܢ ܟܕ ܡܠܝܢ ܘܡܢ ܢܘܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.44",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 44,
      "referenceLabel": "Mark 6:44",
      "text": "ܐܝܬܝܗܘܢ ܗܘܘ ܕܝܢ ܕܐܟܠܘ ܠܚܡܐ ܚܡܫܐ ܐܠܦܝܢ ܓܒܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.45",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 45,
      "referenceLabel": "Mark 6:45",
      "text": "ܘܡܚܕܐ ܐܠܨ ܠܬܠܡܝܕܘܗܝ ܕܢܤܩܘܢ ܠܤܦܝܢܬܐ ܘܢܐܙܠܘܢ ܩܕܡܘܗܝ ܠܥܒܪܐ ܠܒܝܬ ܨܝܕܐ ܥܕ ܫܪܐ ܗܘ ܠܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.46",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 46,
      "referenceLabel": "Mark 6:46",
      "text": "ܘܟܕ ܫܪܐ ܐܢܘܢ ܐܙܠ ܠܛܘܪܐ ܠܡܨܠܝܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.47",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 47,
      "referenceLabel": "Mark 6:47",
      "text": "ܟܕ ܗܘܐ ܕܝܢ ܪܡܫܐ ܤܦܝܢܬܐ ܐܝܬܝܗ ܗܘܬ ܡܨܥܬ ܝܡܐ ܘܗܘ ܒܠܚܘܕܘܗܝ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.48",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 48,
      "referenceLabel": "Mark 6:48",
      "text": "ܘܚܙܐ ܐܢܘܢ ܕܡܫܬܢܩܝܢ ܟܕ ܪܕܝܢ ܪܘܚܐ ܓܝܪ ܠܘܩܒܠܗܘܢ ܗܘܬ ܘܒܡܛܪܬܐ ܪܒܝܥܝܬܐ ܕܠܠܝܐ ܐܬܐ ܠܘܬܗܘܢ ܝܫܘܥ ܟܕ ܡܗܠܟ ܥܠ ܡܝܐ ܘܨܒܐ ܗܘܐ ܕܢܥܒܪ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.49",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 49,
      "referenceLabel": "Mark 6:49",
      "text": "ܗܢܘܢ ܕܝܢ ܚܙܐܘܗܝ ܕܡܗܠܟ ܥܠ ܡܝܐ ܘܤܒܪܘ ܠܗܘܢ ܕܚܙܘܐ ܗܘ ܕܓܠܐ ܘܩܥܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.50",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 50,
      "referenceLabel": "Mark 6:50",
      "text": "ܟܠܗܘܢ ܓܝܪ ܚܙܐܘܗܝ ܘܕܚܠܘ ܘܒܪ ܫܥܬܗ ܡܠܠ ܥܡܗܘܢ ܘܐܡܪ ܠܗܘܢ ܐܬܠܒܒܘ ܐܢܐ ܐܢܐ ܠܐ ܬܕܚܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.51",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 51,
      "referenceLabel": "Mark 6:51",
      "text": "ܘܤܠܩ ܠܘܬܗܘܢ ܠܤܦܝܢܬܐ ܘܫܠܝܬ ܪܘܚܐ ܘܛܒ ܡܬܕܡܪܝܢ ܗܘܘ ܘܬܗܝܪܝܢ ܒܢܦܫܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.52",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 52,
      "referenceLabel": "Mark 6:52",
      "text": "ܠܐ ܓܝܪ ܐܤܬܟܠܘ ܗܘܘ ܡܢ ܠܚܡܐ ܗܘ ܡܛܠ ܕܠܒܗܘܢ ܡܥܒܝ ܗܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.53",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 53,
      "referenceLabel": "Mark 6:53",
      "text": "ܘܟܕ ܥܒܪܘ ܥܒܪܐ ܐܬܘ ܠܐܪܥܐ ܕܓܢܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.54",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 54,
      "referenceLabel": "Mark 6:54",
      "text": "ܘܟܕ ܢܦܩܘ ܡܢ ܤܦܝܢܬܐ ܒܪ ܫܥܬܗ ܐܤܬܟܠܘܗܝ ܐܢܫܝ ܐܬܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.55",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 55,
      "referenceLabel": "Mark 6:55",
      "text": "ܘܪܗܛܘ ܒܟܠܗ ܐܪܥܐ ܗܝ ܘܫܪܝܘ ܠܡܝܬܝܘ ܠܐܝܠܝܢ ܕܒܝܫܐܝܬ ܥܒܝܕܝܢ ܟܕ ܫܩܝܠܝܢ ܠܗܘܢ ܒܥܪܤܬܐ ܠܐܝܟܐ ܕܫܡܥܝܢ ܗܘܘ ܕܐܝܬܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.6.56",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 6,
      "verseNumber": 56,
      "referenceLabel": "Mark 6:56",
      "text": "ܘܐܝܟܐ ܕܥܐܠ ܗܘܐ ܠܩܘܪܝܐ ܘܠܡܕܝܢܬܐ ܒܫܘܩܐ ܤܝܡܝܢ ܗܘܘ ܟܪܝܗܐ ܘܒܥܝܢ ܗܘܘ ܡܢܗ ܕܐܦܢ ܠܟܢܦܐ ܕܠܒܘܫܗ ܢܩܪܒܘܢ ܘܟܠܗܘܢ ܐܝܠܝܢ ܕܩܪܒܝܢ ܗܘܘ ܠܗ ܡܬܐܤܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    }
  ]
}
