{
  "chapter": {
    "id": "peshitta:mark.12",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 12,
    "referenceLabel": "Mark 12",
    "summary": "Source text for Mark 12 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.12.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 1,
      "referenceLabel": "Mark 12:1",
      "text": "ܘܫܪܝ ܕܢܡܠܠ ܥܡܗܘܢ ܒܡܬܠܐ ܓܒܪܐ ܚܕ ܢܨܒ ܟܪܡܐ ܘܐܚܕܪܗ ܤܝܓܐ ܘܚܦܪ ܒܗ ܡܥܨܪܬܐ ܘܒܢܐ ܒܗ ܡܓܕܠܐ ܘܐܘܚܕܗ ܠܦܠܚܐ ܘܚܙܩ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.12.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 2,
      "referenceLabel": "Mark 12:2",
      "text": "ܘܫܕܪ ܠܘܬ ܦܠܚܐ ܥܒܕܗ ܒܙܒܢܐ ܕܡܢ ܦܐܪܐ ܕܟܪܡܐ ܢܤܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 3,
      "referenceLabel": "Mark 12:3",
      "text": "ܗܢܘܢ ܕܝܢ ܡܚܐܘܗܝ ܘܫܕܪܘܗܝ ܟܕ ܤܦܝܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 4,
      "referenceLabel": "Mark 12:4",
      "text": "ܘܫܕܪ ܬܘܒ ܠܘܬܗܘܢ ܥܒܕܐ ܐܚܪܢܐ ܘܐܦ ܠܗܘ ܪܓܡܘܗܝ ܘܨܠܦܘܗܝ ܘܫܕܪܘܗܝ ܒܨܥܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 5,
      "referenceLabel": "Mark 12:5",
      "text": "ܘܫܕܪ ܬܘܒ ܐܚܪܢܐ ܐܦ ܠܗܘ ܩܛܠܘܗܝ ܘܠܤܓܝܐܐ ܥܒܕܐ ܐܚܪܢܐ ܫܕܪ ܘܡܢܗܘܢ ܡܚܘ ܡܢܗܘܢ ܕܝܢ ܩܛܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 6,
      "referenceLabel": "Mark 12:6",
      "text": "ܚܪܬܐ ܕܝܢ ܚܕ ܒܪܐ ܚܒܝܒܐ ܐܝܬ ܗܘܐ ܠܗ ܘܫܕܪܗ ܠܘܬܗܘܢ ܐܚܪܝܬ ܐܡܪ ܓܝܪ ܟܒܪ ܢܒܗܬܘܢ ܡܢ ܒܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 7,
      "referenceLabel": "Mark 12:7",
      "text": "ܗܢܘܢ ܕܝܢ ܦܠܚܐ ܐܡܪܘ ܒܢܦܫܗܘܢ ܗܢܘ ܝܪܬܐ ܬܘ ܢܩܛܠܝܘܗܝ ܘܬܗܘܐ ܕܝܠܢ ܝܪܬܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 8,
      "referenceLabel": "Mark 12:8",
      "text": "ܘܢܤܒܘ ܩܛܠܘܗܝ ܘܐܦܩܘܗܝ ܠܒܪ ܡܢ ܟܪܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 9,
      "referenceLabel": "Mark 12:9",
      "text": "ܡܢܐ ܗܟܝܠ ܢܥܒܕ ܡܪܐ ܟܪܡܐ ܢܐܬܐ ܢܘܒܕ ܠܗܢܘܢ ܦܠܚܐ ܘܢܬܠܝܘܗܝ ܟܪܡܐ ܠܐܚܪܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 10,
      "referenceLabel": "Mark 12:10",
      "text": "ܘܐܦܠܐ ܟܬܒܐ ܗܢܐ ܩܪܝܬܘܢ ܕܟܐܦܐ ܕܐܤܠܝܘ ܒܢܝܐ ܗܝ ܗܘܬ ܠܪܫܐ ܕܙܘܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 11,
      "referenceLabel": "Mark 12:11",
      "text": "ܡܢ ܠܘܬ ܡܪܝܐ ܗܘܬ ܗܕܐ ܘܐܝܬܝܗ ܬܕܡܘܪܬܐ ܒܥܝܢܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 12,
      "referenceLabel": "Mark 12:12",
      "text": "ܘܒܥܝܢ ܗܘܘ ܠܡܐܚܕܗ ܘܕܚܠܘ ܡܢ ܥܡܐ ܝܕܥܘ ܓܝܪ ܕܥܠܝܗܘܢ ܐܡܪ ܡܬܠܐ ܗܢܐ ܘܫܒܩܘܗܝ ܘܐܙܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 13,
      "referenceLabel": "Mark 12:13",
      "text": "ܘܫܕܪܘ ܠܘܬܗ ܐܢܫܐ ܡܢ ܤܦܪܐ ܘܡܢ ܕܒܝܬ ܗܪܘܕܤ ܕܢܨܘܕܘܢܝܗܝ ܒܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 14,
      "referenceLabel": "Mark 12:14",
      "text": "ܗܢܘܢ ܕܝܢ ܐܬܘ ܘܫܐܠܘܗܝ ܡܠܦܢܐ ܝܕܥܝܢ ܚܢܢ ܕܫܪܝܪ ܐܢܬ ܘܠܐ ܫܩܝܠ ܐܢܬ ܨܦܬܐ ܠܐܢܫ ܠܐ ܓܝܪ ܚܐܪ ܐܢܬ ܒܦܪܨܘܦܐ ܕܒܢܝ ܐܢܫܐ ܐܠܐ ܒܫܪܪܐ ܐܘܪܚܐ ܕܐܠܗܐ ܡܠܦ ܐܢܬ ܫܠܝܛ ܠܡܬܠ ܟܤܦ ܪܫܐ ܠܩܤܪ ܐܘ ܠܐ ܢܬܠ ܐܘ ܠܐ ܢܬܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 15,
      "referenceLabel": "Mark 12:15",
      "text": "ܗܘ ܕܝܢ ܝܕܥ ܢܟܠܗܘܢ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܡܢܤܝܢ ܐܢܬܘܢ ܠܝ ܐܝܬܘ ܠܝ ܕܝܢܪܐ ܐܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 16,
      "referenceLabel": "Mark 12:16",
      "text": "ܘܐܝܬܝܘ ܠܗ ܐܡܪ ܠܗܘܢ ܕܡܢܘ ܨܠܡܐ ܗܢܐ ܘܟܬܒܐ ܗܢܘܢ ܕܝܢ ܐܡܪܘ ܕܩܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 17,
      "referenceLabel": "Mark 12:17",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܕܩܤܪ ܗܒܘ ܠܩܤܪ ܘܕܐܠܗܐ ܠܐܠܗܐ ܘܬܡܗܘ ܗܘܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 18,
      "referenceLabel": "Mark 12:18",
      "text": "ܘܐܬܘ ܙܕܘܩܝܐ ܠܘܬܗ ܗܢܘܢ ܕܐܡܪܝܢ ܕܩܝܡܬܐ ܠܝܬ ܘܡܫܐܠܝܢ ܗܘܘ ܠܗ ܘܐܡܪܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 19,
      "referenceLabel": "Mark 12:19",
      "text": "ܡܠܦܢܐ ܡܘܫܐ ܟܬܒ ܠܢ ܕܐܢ ܡܐܬ ܐܚܘܗܝ ܕܐܢܫ ܘܫܒܩ ܐܢܬܬܐ ܘܒܢܝܐ ܠܐ ܫܒܩ ܢܤܒ ܐܚܘܗܝ ܐܢܬܬܗ ܘܢܩܝܡ ܙܪܥܐ ܠܐܚܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 20,
      "referenceLabel": "Mark 12:20",
      "text": "ܫܒܥܐ ܐܚܝܢ ܐܝܬ ܗܘܘ ܩܕܡܝܐ ܢܤܒ ܐܢܬܬܐ ܘܡܝܬ ܘܠܐ ܫܒܩ ܙܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 21,
      "referenceLabel": "Mark 12:21",
      "text": "ܘܕܬܪܝܢ ܢܤܒܗ ܘܡܝܬ ܟܕ ܐܦ ܠܐ ܗܘ ܫܒܩ ܙܪܥܐ ܘܕܬܠܬܐ ܗܟܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 22,
      "referenceLabel": "Mark 12:22",
      "text": "ܘܫܒܥܬܝܗܘܢ ܢܤܒܘܗ ܘܠܐ ܫܒܩܘ ܙܪܥܐ ܐܚܪܝܬ ܟܠܗܘܢ ܡܝܬܬ ܐܦ ܗܝ ܐܢܬܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 23,
      "referenceLabel": "Mark 12:23",
      "text": "ܒܩܝܡܬܐ ܗܟܝܠ ܕܐܝܢܐ ܡܢܗܘܢ ܬܗܘܐ ܐܢܬܬܐ ܫܒܥܬܝܗܘܢ ܓܝܪ ܢܤܒܘܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 24,
      "referenceLabel": "Mark 12:24",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܐ ܗܘܐ ܡܛܠ ܗܕܐ ܛܥܝܢ ܐܢܬܘܢ ܕܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܟܬܒܐ ܘܠܐ ܚܝܠܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 25,
      "referenceLabel": "Mark 12:25",
      "text": "ܡܐ ܓܝܪ ܕܩܡܘ ܡܢ ܡܝܬܐ ܠܐ ܢܤܒܝܢ ܢܫܐ ܐܦ ܠܐ ܢܫܐ ܗܘܝܢ ܠܓܒܪܐ ܐܠܐ ܐܝܬܝܗܘܢ ܐܝܟ ܡܠܐܟܐ ܕܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 26,
      "referenceLabel": "Mark 12:26",
      "text": "ܥܠ ܡܝܬܐ ܕܝܢ ܕܩܝܡܝܢ ܠܐ ܩܪܝܬܘܢ ܒܟܬܒܐ ܕܡܘܫܐ ܐܝܟܢܐ ܡܢ ܤܢܝܐ ܐܡܪ ܠܗ ܐܠܗܐ ܐܢܐ ܐܢܐ ܐܠܗܗ ܕܐܒܪܗܡ ܘܐܠܗܗ ܕܐܝܤܚܩ ܘܐܠܗܗ ܕܝܥܩܘܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 27,
      "referenceLabel": "Mark 12:27",
      "text": "ܘܠܐ ܗܘܐ ܐܠܗܐ ܕܡܝܬܐ ܐܠܐ ܕܚܝܐ ܐܢܬܘܢ ܗܟܝܠ ܤܓܝ ܛܥܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 28,
      "referenceLabel": "Mark 12:28",
      "text": "ܘܩܪܒ ܚܕ ܡܢ ܤܦܪܐ ܘܫܡܥ ܐܢܘܢ ܕܕܪܫܝܢ ܘܚܙܐ ܕܫܦܝܪ ܐܬܝܒ ܠܗܘܢ ܦܬܓܡܐ ܘܫܐܠܗ ܐܝܢܘ ܦܘܩܕܢܐ ܩܕܡܝܐ ܕܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 29,
      "referenceLabel": "Mark 12:29",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܩܕܡܝ ܡܢ ܟܠܗܘܢ ܦܘܩܕܢܐ ܫܡܥ ܐܝܤܪܝܠ ܡܪܝܐ ܐܠܗܢ ܡܪܝܐ ܚܕ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 30,
      "referenceLabel": "Mark 12:30",
      "text": "ܘܕܬܪܚܡ ܠܡܪܝܐ ܐܠܗܟ ܡܢ ܟܠܗ ܠܒܟ ܘܡܢ ܟܠܗ ܢܦܫܟ ܘܡܢ ܟܠܗ ܪܥܝܢܟ ܘܡܢ ܟܠܗ ܚܝܠܟ ܗܢܘ ܦܘܩܕܢܐ ܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 31,
      "referenceLabel": "Mark 12:31",
      "text": "ܘܕܬܪܝܢ ܕܕܡܐ ܠܗ ܕܬܚܒ ܠܩܪܝܒܟ ܐܝܟ ܢܦܫܟ ܦܘܩܕܢܐ ܐܚܪܢܐ ܕܪܒ ܡܢ ܗܠܝܢ ܠܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 32,
      "referenceLabel": "Mark 12:32",
      "text": "ܐܡܪ ܠܗ ܗܘ ܤܦܪܐ ܫܦܝܪ ܪܒܝ ܒܫܪܪܐ ܐܡܪܬ ܕܚܕ ܗܘ ܘܠܝܬ ܐܚܪܝܢ ܠܒܪ ܡܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 33,
      "referenceLabel": "Mark 12:33",
      "text": "ܘܕܢܪܚܡܝܘܗܝ ܐܢܫ ܡܢ ܟܠܗ ܠܒܐ ܘܡܢ ܟܠܗ ܪܥܝܢܐ ܘܡܢ ܟܠܗ ܢܦܫܐ ܘܡܢ ܟܠܗ ܚܝܠܐ ܘܕܢܪܚܡ ܩܪܝܒܗ ܐܝܟ ܢܦܫܗ ܝܬܝܪܐ ܗܝ ܡܢ ܟܠܗܘܢ ܝܩܕܐ ܘܕܒܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 34,
      "referenceLabel": "Mark 12:34",
      "text": "ܝܫܘܥ ܕܝܢ ܚܙܝܗܝ ܕܚܟܝܡܐܝܬ ܡܦܢܐ ܦܬܓܡܐ ܥܢܐ ܘܐܡܪ ܠܗ ܠܐ ܗܘܝܬ ܪܚܝܩ ܡܢ ܡܠܟܘܬܐ ܕܐܠܗܐ ܘܠܐ ܐܢܫ ܬܘܒ ܐܡܪܚ ܕܢܫܐܠܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 35,
      "referenceLabel": "Mark 12:35",
      "text": "ܘܥܢܐ ܝܫܘܥ ܘܐܡܪ ܟܕ ܡܠܦ ܒܗܝܟܠܐ ܐܝܟܢܐ ܐܡܪܝܢ ܤܦܪܐ ܕܡܫܝܚܐ ܒܪܗ ܗܘ ܕܕܘܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.12.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 12,
      "verseNumber": 36,
      "referenceLabel": "Mark 12:36",
      "text": "ܗܘ ܓܝܪ ܕܘܝܕ ܐܡܪ ܒܪܘܚܐ ܕܩܘܕܫܐ ܕܐܡܪ ܡܪܝܐ ܠܡܪܝ ܬܒ ܠܟ ܡܢ ܝܡܝܢܝ ܥܕܡܐ ܕܐܤܝܡ ܒܥܠܕܒܒܝܟ ܟܘܒܫܐ ܬܚܝܬ ܪܓܠܝܟ ܀",
