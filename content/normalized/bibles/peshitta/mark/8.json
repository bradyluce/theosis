{
  "chapter": {
    "id": "peshitta:mark.8",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 8,
    "referenceLabel": "Mark 8",
    "summary": "Source text for Mark 8 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.8.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 1,
      "referenceLabel": "Mark 8:1",
      "text": "ܒܗܢܘܢ ܕܝܢ ܝܘܡܬܐ ܟܕ ܟܢܫܐ ܤܓܝܐܐ ܐܝܬ ܗܘܐ ܘܠܐ ܐܝܬ ܗܘܐ ܡܕܡ ܕܢܐܟܠܘܢ ܩܪܐ ܠܬܠܡܝܕܘܗܝ ܘܐܡܪ ܠܗܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.8.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 2,
      "referenceLabel": "Mark 8:2",
      "text": "ܡܬܪܚܡ ܐܢܐ ܥܠ ܟܢܫܐ ܗܢܐ ܕܗܐ ܬܠܬܐ ܝܘܡܝܢ ܩܘܝܘ ܠܘܬܝ ܘܠܝܬ ܠܗܘܢ ܡܢܐ ܢܐܟܠܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 3,
      "referenceLabel": "Mark 8:3",
      "text": "ܘܐܢ ܗܘ ܕܫܪܐ ܐܢܐ ܠܗܘܢ ܟܕ ܨܝܡܝܢ ܠܒܬܝܗܘܢ ܥܝܦܝܢ ܒܐܘܪܚܐ ܐܢܫܐ ܓܝܪ ܡܢܗܘܢ ܡܢ ܪܘܚܩܐ ܐܬܝܐܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 4,
      "referenceLabel": "Mark 8:4",
      "text": "ܐܡܪܝܢ ܠܗ ܬܠܡܝܕܘܗܝ ܐܝܡܟܐ ܡܫܟܚ ܐܢܫ ܗܪܟܐ ܒܚܘܪܒܐ ܕܢܤܒܥ ܠܚܡܐ ܠܗܠܝܢ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 5,
      "referenceLabel": "Mark 8:5",
      "text": "ܘܫܐܠ ܐܢܘܢ ܗܘ ܟܡܐ ܠܚܡܝܢ ܐܝܬ ܠܟܘܢ ܐܡܪܝܢ ܠܗ ܫܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 6,
      "referenceLabel": "Mark 8:6",
      "text": "ܘܦܩܕ ܠܟܢܫܐ ܕܢܤܬܡܟܘܢ ܥܠ ܐܪܥܐ ܘܢܤܒ ܗܢܘܢ ܫܒܥܐ ܠܚܡܝܢ ܘܒܪܟ ܘܩܨܐ ܘܝܗܒ ܠܬܠܡܝܕܘܗܝ ܕܢܤܝܡܘܢ ܘܤܡܘ ܠܟܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 7,
      "referenceLabel": "Mark 8:7",
      "text": "ܘܐܝܬ ܗܘܘ ܢܘܢܐ ܩܠܝܠ ܘܐܦ ܥܠܝܗܘܢ ܒܪܟ ܘܐܡܪ ܕܢܤܝܡܘܢ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 8,
      "referenceLabel": "Mark 8:8",
      "text": "ܘܐܟܠܘ ܘܤܒܥܘ ܘܫܩܠܘ ܬܘܬܪܐ ܕܩܨܝܐ ܫܒܥܐ ܐܤܦܪܝܕܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 9,
      "referenceLabel": "Mark 8:9",
      "text": "ܐܝܬܝܗܘܢ ܗܘܘ ܕܝܢ ܐܢܫܐ ܕܐܟܠܘ ܐܝܟ ܐܪܒܥܐ ܐܠܦܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 10,
      "referenceLabel": "Mark 8:10",
      "text": "ܘܫܪܐ ܐܢܘܢ ܘܤܠܩ ܡܚܕܐ ܠܤܦܝܢܬܐ ܥܡ ܬܠܡܝܕܘܗܝ ܘܐܬܐ ܠܐܬܪܐ ܕܕܠܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 11,
      "referenceLabel": "Mark 8:11",
      "text": "ܘܢܦܩܘ ܦܪܝܫܐ ܘܫܪܝܘ ܠܡܒܥܐ ܥܡܗ ܘܫܐܠܝܢ ܗܘܘ ܠܗ ܐܬܐ ܡܢ ܫܡܝܐ ܟܕ ܡܢܤܝܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 12,
      "referenceLabel": "Mark 8:12",
      "text": "ܘܐܬܬܢܚ ܒܪܘܚܗ ܘܐܡܪ ܡܢܐ ܒܥܝܐ ܐܬܐ ܫܪܒܬܐ ܗܕܐ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܐ ܬܬܝܗܒ ܠܗ ܐܬܐ ܠܫܪܒܬܐ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 13,
      "referenceLabel": "Mark 8:13",
      "text": "ܘܫܒܩ ܐܢܘܢ ܘܤܠܩ ܠܤܦܝܢܬܐ ܘܐܙܠܘ ܠܗܘ ܥܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 14,
      "referenceLabel": "Mark 8:14",
      "text": "ܘܛܥܘ ܕܢܤܒܘܢ ܠܚܡܐ ܘܐܠܐ ܚܕܐ ܓܪܝܨܬܐ ܠܝܬ ܗܘܐ ܥܡܗܘܢ ܒܤܦܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 15,
      "referenceLabel": "Mark 8:15",
      "text": "ܘܦܩܕ ܐܢܘܢ ܘܐܡܪ ܠܗܘܢ ܚܙܘ ܐܙܕܗܪܘ ܡܢ ܚܡܝܪܐ ܕܦܪܝܫܐ ܘܡܢ ܚܡܝܪܗ ܕܗܪܘܕܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 16,
      "referenceLabel": "Mark 8:16",
      "text": "ܘܡܬܚܫܒܝܢ ܗܘܘ ܚܕ ܥܡ ܚܕ ܘܐܡܪܝܢ ܕܠܚܡܐ ܠܝܬ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 17,
      "referenceLabel": "Mark 8:17",
      "text": "ܝܫܘܥ ܕܝܢ ܝܕܥ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܪܢܝܢ ܐܢܬܘܢ ܕܠܚܡܐ ܠܝܬ ܠܟܘܢ ܠܐ ܥܕܡܐ ܠܗܫܐ ܝܕܥܝܢ ܐܢܬܘܢ ܘܠܐ ܡܤܬܟܠܝܢ ܐܢܬܘܢ ܥܕܟܝܠ ܠܒܐ ܩܫܝܐ ܐܝܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 18,
      "referenceLabel": "Mark 8:18",
      "text": "ܘܥܝܢܐ ܐܝܬ ܠܟܘܢ ܘܠܐ ܚܙܝܢ ܐܢܬܘܢ ܘܐܕܢܐ ܐܝܬ ܠܟܘܢ ܘܠܐ ܫܡܥܝܢ ܐܢܬܘܢ ܘܠܐ ܥܗܕܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 19,
      "referenceLabel": "Mark 8:19",
      "text": "ܟܕ ܗܠܝܢ ܚܡܫܐ ܠܚܡܝܢ ܩܨܝܬ ܠܚܡܫܐ ܐܠܦܝܢ ܟܡܐ ܩܘܦܝܢܝܢ ܕܩܨܝܐ ܟܕ ܡܠܝܢ ܫܩܠܬܘܢ ܐܡܪܝܢ ܠܗ ܬܪܥܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 20,
      "referenceLabel": "Mark 8:20",
      "text": "ܐܡܪ ܠܗܘܢ ܘܟܕ ܫܒܥܐ ܠܐܪܒܥܐ ܐܠܦܝܢ ܟܡܐ ܐܤܦܪܝܕܝܢ ܕܩܨܝܐ ܟܕ ܡܠܝܢ ܫܩܠܬܘܢ ܐܡܪܝܢ ܫܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 21,
      "referenceLabel": "Mark 8:21",
      "text": "ܐܡܪ ܠܗܘܢ ܐܝܟܘ ܠܐ ܥܕܡܐ ܠܗܫܐ ܡܤܬܟܠܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 22,
      "referenceLabel": "Mark 8:22",
      "text": "ܘܐܬܐ ܠܒܝܬ ܨܝܕܐ ܘܐܝܬܝܘ ܠܗ ܤܡܝܐ ܘܒܥܝܢ ܗܘܘ ܡܢܗ ܕܢܩܪܘܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 23,
      "referenceLabel": "Mark 8:23",
      "text": "ܘܐܚܕ ܒܐܝܕܗ ܕܤܡܝܐ ܘܐܦܩܗ ܠܒܪ ܡܢ ܩܪܝܬܐ ܘܪܩ ܒܥܝܢܘܗܝ ܘܤܡ ܐܝܕܗ ܘܫܐܠܗ ܕܡܢܐ ܚܙܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 24,
      "referenceLabel": "Mark 8:24",
      "text": "ܚܪ ܘܐܡܪ ܚܙܐ ܐܢܐ ܒܢܝ ܐܢܫܐ ܐܝܟ ܐܝܠܢܐ ܕܡܗܠܟܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 25,
      "referenceLabel": "Mark 8:25",
      "text": "ܬܘܒ ܤܡ ܐܝܕܗ ܥܠ ܥܝܢܘܗܝ ܘܬܩܢ ܘܚܙܐ ܗܘܐ ܟܠ ܡܕܡ ܢܗܝܪܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 26,
      "referenceLabel": "Mark 8:26",
      "text": "ܘܫܕܪܗ ܠܒܝܬܗ ܘܐܡܪ ܐܦ ܠܐ ܠܩܪܝܬܐ ܬܥܘܠ ܘܠܐ ܬܐܡܪ ܠܐܢܫ ܒܩܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 27,
      "referenceLabel": "Mark 8:27",
      "text": "ܘܢܦܩ ܝܫܘܥ ܘܬܠܡܝܕܘܗܝ ܠܩܘܪܝܐ ܕܩܤܪܝܐ ܕܦܝܠܝܦܘܤ ܘܡܫܐܠ ܗܘܐ ܠܬܠܡܝܕܘܗܝ ܒܐܘܪܚܐ ܘܐܡܪ ܠܗܘܢ ܡܢܘ ܐܡܪܝܢ ܥܠܝ ܐܢܫܐ ܕܐܝܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 28,
      "referenceLabel": "Mark 8:28",
      "text": "ܗܢܘܢ ܕܝܢ ܐܡܪܘ ܕܝܘܚܢܢ ܡܥܡܕܢܐ ܘܐܚܪܢܐ ܕܐܠܝܐ ܘܐܚܪܢܐ ܚܕ ܡܢ ܢܒܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 29,
      "referenceLabel": "Mark 8:29",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܐܢܬܘܢ ܕܝܢ ܡܢܘ ܐܡܪܝܢ ܐܢܬܘܢ ܥܠܝ ܕܐܝܬܝ ܥܢܐ ܫܡܥܘܢ ܘܐܡܪ ܠܗ ܐܢܬ ܗܘ ܡܫܝܚܐ ܒܪܗ ܕܐܠܗܐ ܚܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 30,
      "referenceLabel": "Mark 8:30",
      "text": "ܘܟܐܐ ܒܗܘܢ ܕܠܐܢܫ ܠܐ ܢܐܡܪܘܢ ܥܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 31,
      "referenceLabel": "Mark 8:31",
      "text": "ܘܫܪܝ ܗܘܐ ܠܡܠܦܘ ܐܢܘܢ ܕܥܬܝܕ ܗܘ ܒܪܗ ܕܐܢܫܐ ܕܢܚܫ ܤܓܝ ܘܕܢܤܬܠܐ ܡܢ ܩܫܝܫܐ ܘܡܢ ܪܒܝ ܟܗܢܐ ܘܡܢ ܤܦܪܐ ܘܢܬܩܛܠ ܘܠܬܠܬܐ ܝܘܡܝܢ ܢܩܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 32,
      "referenceLabel": "Mark 8:32",
      "text": "ܘܥܝܢ ܒܓܠܐ ܡܠܬܐ ܡܡܠܠ ܗܘܐ ܘܕܒܪܗ ܟܐܦܐ ܘܫܪܝ ܠܡܟܐܐ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 33,
      "referenceLabel": "Mark 8:33",
      "text": "ܗܘ ܕܝܢ ܐܬܦܢܝ ܘܚܪ ܒܬܠܡܝܕܘܗܝ ܘܟܐܐ ܒܫܡܥܘܢ ܘܐܡܪ ܙܠ ܠܟ ܠܒܤܬܪܝ ܤܛܢܐ ܕܠܐ ܪܢܐ ܐܢܬ ܕܐܠܗܐ ܐܠܐ ܕܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 34,
      "referenceLabel": "Mark 8:34",
      "text": "ܘܩܪܐ ܝܫܘܥ ܠܟܢܫܐ ܥܡ ܬܠܡܝܕܘܗܝ ܘܐܡܪ ܠܗܘܢ ܡܢ ܕܨܒܐ ܕܢܐܬܐ ܒܬܪܝ ܢܟܦܘܪ ܒܢܦܫܗ ܘܢܫܩܘܠ ܙܩܝܦܗ ܘܢܐܬܐ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 35,
      "referenceLabel": "Mark 8:35",
      "text": "ܟܠ ܡܢ ܕܨܒܐ ܓܝܪ ܕܢܚܐ ܢܦܫܗ ܢܘܒܕܝܗ ܘܟܠ ܕܢܘܒܕ ܢܦܫܗ ܡܛܠܬܝ ܘܡܛܠ ܤܒܪܬܝ ܢܚܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 36,
      "referenceLabel": "Mark 8:36",
      "text": "ܡܢܐ ܓܝܪ ܢܬܥܕܪ ܒܪܢܫܐ ܐܢ ܥܠܡܐ ܟܠܗ ܢܐܬܪ ܘܢܦܫܗ ܢܚܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 8,
      "verseNumber": 37,
      "referenceLabel": "Mark 8:37",
      "text": "ܐܘ ܡܢܐ ܢܬܠ ܒܪܢܫܐ ܬܚܠܘܦܐ ܕܢܦܫܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.8.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
