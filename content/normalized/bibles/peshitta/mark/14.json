{
  "chapter": {
    "id": "peshitta:mark.14",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 14,
    "referenceLabel": "Mark 14",
    "summary": "Source text for Mark 14 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.14.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 1,
      "referenceLabel": "Mark 14:1",
      "text": "ܒܬܪ ܕܝܢ ܬܪܝܢ ܝܘܡܝܢ ܗܘܐ ܗܘܐ ܦܨܚܐ ܕܦܛܝܪܐ ܘܒܥܝܢ ܗܘܘ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܐܝܟܢܐ ܒܢܟܠܐ ܢܐܚܕܘܢ ܘܢܩܛܠܘܢܝܗܝ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.14.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 2,
      "referenceLabel": "Mark 14:2",
      "text": "ܘܐܡܪܝܢ ܗܘܘ ܠܐ ܒܥܕܥܕܐ ܕܠܡܐ ܢܗܘܐ ܫܓܘܫܝܐ ܒܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 3,
      "referenceLabel": "Mark 14:3",
      "text": "ܘܟܕ ܗܘ ܐܝܬܘܗܝ ܒܒܝܬ ܥܢܝܐ ܒܒܝܬܗ ܕܫܡܥܘܢ ܓܪܒܐ ܟܕ ܤܡܝܟ ܐܬܬ ܐܢܬܬܐ ܕܐܝܬ ܥܠܝܗ ܫܛܝܦܬܐ ܕܒܤܡܐ ܕܢܪܕܝܢ ܪܫܝܐ ܤܓܝ ܕܡܝܐ ܘܦܬܚܬܗ ܘܐܫܦܥܬܗ ܥܠ ܪܫܗ ܕܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 4,
      "referenceLabel": "Mark 14:4",
      "text": "ܐܝܬ ܗܘܘ ܕܝܢ ܐܢܫܐ ܡܢ ܬܠܡܝܕܐ ܕܐܬܒܐܫ ܠܗܘܢ ܒܢܦܫܗܘܢ ܘܐܡܪܘ ܕܠܡܢܐ ܗܘܐ ܐܒܕܢܐ ܕܗܢܐ ܒܤܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 5,
      "referenceLabel": "Mark 14:5",
      "text": "ܡܫܟܚ ܗܘܐ ܓܝܪ ܠܡܙܕܒܢܘ ܝܬܝܪ ܡܢ ܬܠܬܡܐܐ ܕܝܢܪܝܢ ܘܠܡܬܝܗܒܘ ܠܡܤܟܢܐ ܘܡܙܕܥܦܝܢ ܗܘܘ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 6,
      "referenceLabel": "Mark 14:6",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܫܘܒܩܘܗ ܡܢܐ ܡܗܪܝܢ ܐܢܬܘܢ ܠܗ ܥܒܕܐ ܫܦܝܪܐ ܥܒܕܬ ܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 7,
      "referenceLabel": "Mark 14:7",
      "text": "ܒܟܠܙܒܢ ܓܝܪ ܡܤܟܢܐ ܐܝܬ ܠܟܘܢ ܥܡܟܘܢ ܘܐܡܬܝ ܕܨܒܝܢ ܐܢܬܘܢ ܡܫܟܚܝܢ ܐܢܬܘܢ ܕܬܥܒܕܘܢ ܠܗܘܢ ܕܫܦܝܪ ܐܢܐ ܕܝܢ ܠܐ ܒܟܠܙܒܢ ܐܝܬܝ ܠܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 8,
      "referenceLabel": "Mark 14:8",
      "text": "ܗܘ ܕܐܝܬ ܗܘܐ ܠܗ ܠܗܕܐ ܥܒܕܬ ܘܩܕܡܬ ܐܝܟ ܕܠܩܒܘܪܬܐ ܒܤܡܬ ܓܘܫܡܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 9,
      "referenceLabel": "Mark 14:9",
      "text": "ܘܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܟܠ ܐܝܟܐ ܕܬܬܟܪܙ ܤܒܪܬܝ ܗܕܐ ܒܟܠܗ ܥܠܡܐ ܘܐܦ ܡܕܡ ܕܥܒܕܬ ܗܕܐ ܢܬܡܠܠ ܠܕܘܟܪܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 10,
      "referenceLabel": "Mark 14:10",
      "text": "ܝܗܘܕܐ ܕܝܢ ܤܟܪܝܘܛܐ ܚܕ ܡܢ ܬܪܥܤܪ ܐܙܠ ܠܘܬ ܪܒܝ ܟܗܢܐ ܐܝܟ ܕܢܫܠܡܝܘܗܝ ܠܗܘܢ ܠܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 11,
      "referenceLabel": "Mark 14:11",
      "text": "ܗܢܘܢ ܕܝܢ ܟܕ ܫܡܥܘ ܚܕܝܘ ܘܐܫܬܘܕܝܘ ܟܤܦܐ ܕܢܬܠܘܢ ܠܗ ܘܒܥܐ ܗܘܐ ܠܗ ܦܠܥܐ ܕܢܫܠܡܝܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 12,
      "referenceLabel": "Mark 14:12",
      "text": "ܘܒܝܘܡܐ ܩܕܡܝܐ ܕܦܛܝܪܐ ܕܒܗ ܕܒܚܝܢ ܝܗܘܕܝܐ ܦܨܚܐ ܐܡܪܝܢ ܠܗ ܬܠܡܝܕܘܗܝ ܐܝܟܐ ܨܒܐ ܐܢܬ ܕܢܐܙܠ ܢܛܝܒ ܠܟ ܕܬܐܟܘܠ ܦܨܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 13,
      "referenceLabel": "Mark 14:13",
      "text": "ܘܫܕܪ ܬܪܝܢ ܡܢ ܬܠܡܝܕܘܗܝ ܘܐܡܪ ܠܗܘܢ ܙܠܘ ܠܡܕܝܢܬܐ ܘܗܐ ܦܓܥ ܒܟܘܢ ܓܒܪܐ ܕܫܩܝܠ ܡܐܢܐ ܕܡܝܐ ܙܠܘ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 14,
      "referenceLabel": "Mark 14:14",
      "text": "ܘܠܐܝܟܐ ܕܥܐܠ ܐܡܪܘ ܠܡܪܐ ܒܝܬܐ ܪܒܢ ܐܡܪ ܐܝܟܘ ܒܝܬ ܡܫܪܝܐ ܐܝܟܐ ܕܐܟܘܠ ܥܡ ܬܠܡܝܕܝ ܦܨܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 15,
      "referenceLabel": "Mark 14:15",
      "text": "ܘܗܐ ܡܚܘܐ ܠܟܘܢ ܥܠܝܬܐ ܪܒܬܐ ܕܡܫܘܝܐ ܘܡܛܝܒܐ ܬܡܢ ܬܩܢܘ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 16,
      "referenceLabel": "Mark 14:16",
      "text": "ܘܢܦܩܘ ܬܠܡܝܕܘܗܝ ܘܐܬܘ ܠܡܕܝܢܬܐ ܘܐܫܟܚܘ ܐܝܟܢܐ ܕܐܡܪ ܠܗܘܢ ܘܛܝܒܘ ܦܨܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 17,
      "referenceLabel": "Mark 14:17",
      "text": "ܘܟܕ ܗܘܐ ܪܡܫܐ ܐܬܐ ܥܡ ܬܪܥܤܪܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 18,
      "referenceLabel": "Mark 14:18",
      "text": "ܘܟܕ ܤܡܝܟܝܢ ܘܠܥܤܝܢ ܐܡܪ ܝܫܘܥ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܚܕ ܡܢܟܘܢ ܕܐܟܠ ܥܡܝ ܗܘ ܢܫܠܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 19,
      "referenceLabel": "Mark 14:19",
      "text": "ܗܢܘܢ ܕܝܢ ܫܪܝܘ ܡܬܬܥܝܩܝܢ ܘܐܡܪܝܢ ܠܗ ܚܕ ܚܕ ܠܡܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 20,
      "referenceLabel": "Mark 14:20",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܚܕ ܡܢ ܬܪܥܤܪ ܕܨܒܥ ܥܡܝ ܒܠܓܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 21,
      "referenceLabel": "Mark 14:21",
      "text": "ܘܒܪܗ ܕܐܢܫܐ ܐܙܠ ܐܝܟܢܐ ܕܟܬܝܒ ܥܠܘܗܝ ܘܝ ܕܝܢ ܠܓܒܪܐ ܗܘ ܕܒܐܝܕܗ ܡܫܬܠܡ ܒܪܗ ܕܐܢܫܐ ܦܩܚ ܗܘܐ ܠܗ ܠܓܒܪܐ ܗܘ ܐܠܘ ܠܐ ܐܬܝܠܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 22,
      "referenceLabel": "Mark 14:22",
      "text": "ܘܟܕ ܗܢܘܢ ܠܥܤܝܢ ܢܤܒ ܝܫܘܥ ܠܚܡܐ ܘܒܪܟ ܘܩܨܐ ܘܝܗܒ ܠܗܘܢ ܘܐܡܪ ܠܗܘܢ ܤܒܘ ܗܢܐ ܐܝܬܘܗܝ ܦܓܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 23,
      "referenceLabel": "Mark 14:23",
      "text": "ܘܢܤܒ ܟܤܐ ܘܐܘܕܝ ܘܒܪܟ ܘܝܗܒ ܠܗܘܢ ܘܐܫܬܝܘ ܡܢܗ ܟܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 24,
      "referenceLabel": "Mark 14:24",
      "text": "ܘܐܡܪ ܠܗܘܢ ܗܢܘ ܕܡܝ ܕܕܝܬܩܐ ܚܕܬܐ ܕܚܠܦ ܤܓܝܐܐ ܡܬܐܫܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 25,
      "referenceLabel": "Mark 14:25",
      "text": "ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܬܘܒ ܠܐ ܐܫܬܐ ܡܢ ܝܠܕܐ ܕܓܦܬܐ ܥܕܡܐ ܠܝܘܡܐ ܗܘ ܕܒܗ ܐܫܬܝܘܗܝ ܚܕܬܐܝܬ ܒܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 26,
      "referenceLabel": "Mark 14:26",
      "text": "ܘܫܒܚܘ ܘܢܦܩܘ ܠܛܘܪ ܙܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 27,
      "referenceLabel": "Mark 14:27",
      "text": "ܘܐܡܪ ܠܗܘܢ ܝܫܘܥ ܕܟܠܟܘܢ ܬܬܟܫܠܘܢ ܒܝ ܒܗܢܐ ܠܠܝܐ ܟܬܝܒ ܓܝܪ ܕܐܡܚܐ ܠܪܥܝܐ ܘܢܬܒܕܪܘܢ ܐܡܪܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 28,
      "referenceLabel": "Mark 14:28",
      "text": "ܐܠܐ ܡܐ ܕܩܡܬ ܩܕܡ ܐܢܐ ܠܟܘܢ ܠܓܠܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 29,
      "referenceLabel": "Mark 14:29",
      "text": "ܐܡܪ ܠܗ ܟܐܦܐ ܐܢ ܟܠܗܘܢ ܢܬܟܫܠܘܢ ܐܠܐ ܠܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 30,
      "referenceLabel": "Mark 14:30",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟ ܕܐܢܬ ܝܘܡܢܐ ܒܠܠܝܐ ܗܢܐ ܩܕܡ ܕܢܩܪܐ ܬܪܢܓܠܐ ܬܪܬܝܢ ܙܒܢܝܢ ܬܠܬ ܬܟܦܘܪ ܒܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 31,
      "referenceLabel": "Mark 14:31",
      "text": "ܗܘ ܕܝܢ ܝܬܝܪܐܝܬ ܐܡܪ ܗܘܐ ܕܐܢ ܢܗܘܐ ܠܝ ܠܡܡܬ ܥܡܟ ܠܐ ܐܟܦܘܪ ܒܟ ܡܪܝ ܘܐܟܘܬܗ ܐܦ ܟܠܗܘܢ ܐܡܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 32,
      "referenceLabel": "Mark 14:32",
      "text": "ܘܐܬܘ ܠܕܘܟܬܐ ܐܝܕܐ ܕܡܬܩܪܝܐ ܓܕܤܡܢ ܘܐܡܪ ܠܬܠܡܝܕܘܗܝ ܬܒܘ ܗܪܟܐ ܥܕ ܡܨܠܐ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 33,
      "referenceLabel": "Mark 14:33",
      "text": "ܘܕܒܪ ܥܡܗ ܠܟܐܦܐ ܘܠܝܥܩܘܒ ܘܠܝܘܚܢܢ ܘܫܪܝ ܠܡܬܟܡܪܘ ܘܠܡܬܬܥܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 34,
      "referenceLabel": "Mark 14:34",
      "text": "ܘܐܡܪ ܠܗܘܢ ܟܪܝܐ ܗܝ ܠܗ ܠܢܦܫܝ ܥܕܡܐ ܠܡܘܬܐ ܩܘܘ ܗܪܟܐ ܘܐܬܬܥܝܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 35,
      "referenceLabel": "Mark 14:35",
      "text": "ܘܩܪܒ ܩܠܝܠ ܘܢܦܠ ܥܠ ܐܪܥܐ ܘܡܨܠܐ ܗܘܐ ܕܐܢ ܡܫܟܚܐ ܬܥܒܪ ܡܢܗ ܫܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 36,
      "referenceLabel": "Mark 14:36",
      "text": "ܘܐܡܪ ܐܒܐ ܐܒܝ ܟܠ ܡܕܡ ܡܫܟܚ ܐܢܬ ܐܥܒܪ ܡܢܝ ܟܤܐ ܗܢܐ ܐܠܐ ܠܐ ܨܒܝܢܝ ܕܝܠܝ ܐܠܐ ܕܝܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 37,
      "referenceLabel": "Mark 14:37",
      "text": "ܘܐܬܐ ܐܫܟܚ ܐܢܘܢ ܟܕ ܕܡܟܝܢ ܘܐܡܪ ܠܟܐܦܐ ܫܡܥܘܢ ܕܡܟܬ ܠܟ ܠܐ ܐܫܟܚܬ ܚܕܐ ܫܥܐ ܠܡܬܬܥܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 38,
      "referenceLabel": "Mark 14:38",
      "text": "ܐܬܬܥܝܪܘ ܘܨܠܘ ܕܠܐ ܬܥܠܘܢ ܠܢܤܝܘܢܐ ܪܘܚܐ ܨܒܝܐ ܘܡܛܝܒܐ ܐܠܐ ܦܓܪܐ ܟܪܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.39",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 39,
      "referenceLabel": "Mark 14:39",
      "text": "ܘܐܙܠ ܬܘܒ ܨܠܝ ܘܗܝ ܡܠܬܐ ܐܡܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.40",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 40,
      "referenceLabel": "Mark 14:40",
      "text": "ܘܗܦܟ ܐܬܐ ܬܘܒ ܐܫܟܚ ܐܢܘܢ ܟܕ ܕܡܟܝܢ ܡܛܠ ܕܥܝܢܝܗܘܢ ܝܩܝܪܢ ܗܘܝ ܘܠܐ ܝܕܥܝܢ ܗܘܘ ܡܢܐ ܢܐܡܪܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.41",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 41,
      "referenceLabel": "Mark 14:41",
      "text": "ܘܐܬܐ ܕܬܠܬ ܙܒܢܝܢ ܘܐܡܪ ܠܗܘܢ ܕܡܟܘ ܡܟܝܠ ܘܐܬܬܢܝܚܘ ܡܛܬ ܚܪܬܐ ܘܐܬܬ ܫܥܬܐ ܘܗܐ ܡܫܬܠܡ ܒܪܗ ܕܐܢܫܐ ܒܐܝܕܝܗܘܢ ܕܚܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.42",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 42,
      "referenceLabel": "Mark 14:42",
      "text": "ܩܘܡܘ ܢܐܙܠ ܗܐ ܩܪܒ ܗܘ ܕܡܫܠܡ ܠܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.43",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 43,
      "referenceLabel": "Mark 14:43",
      "text": "ܘܥܕ ܗܘ ܡܡܠܠ ܐܬܐ ܝܗܘܕܐ ܤܟܪܝܘܛܐ ܚܕ ܡܢ ܬܪܥܤܪ ܘܥܡܐ ܤܓܝܐܐ ܥܡ ܤܦܤܪܐ ܘܚܘܛܪܐ ܡܢ ܠܘܬ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.44",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 44,
      "referenceLabel": "Mark 14:44",
      "text": "ܘܝܗܒ ܠܗܘܢ ܐܬܐ ܡܫܠܡܢܐ ܗܘ ܕܡܫܠܡ ܘܐܡܪ ܗܘ ܕܢܫܩ ܐܢܐ ܗܘܝܘ ܐܘܚܕܘܗܝ ܙܗܝܪܐܝܬ ܘܐܘܒܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.45",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 45,
      "referenceLabel": "Mark 14:45",
      "text": "ܘܒܪ ܫܥܬܗ ܩܪܒ ܘܐܡܪ ܠܗ ܪܒܝ ܪܒܝ ܘܢܫܩܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.46",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 46,
      "referenceLabel": "Mark 14:46",
      "text": "ܗܢܘܢ ܕܝܢ ܐܪܡܝܘ ܥܠܘܗܝ ܐܝܕܝܐ ܘܐܚܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.47",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 47,
      "referenceLabel": "Mark 14:47",
      "text": "ܚܕ ܕܝܢ ܡܢ ܗܢܘܢ ܕܩܝܡܝܢ ܫܡܛ ܤܝܦܐ ܘܡܚܝܗܝ ܠܥܒܕܗ ܕܪܒ ܟܗܢܐ ܘܫܩܠܗ ܐܕܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.48",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 48,
      "referenceLabel": "Mark 14:48",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܥܢܐ ܘܐܡܪ ܠܗܘܢ ܐܝܟ ܕܥܠ ܓܝܤܐ ܢܦܩܬܘܢ ܒܤܝܦܐ ܘܒܚܘܛܪܐ ܕܬܐܚܕܘܢܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.49",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 49,
      "referenceLabel": "Mark 14:49",
      "text": "ܟܠܝܘܡ ܠܘܬܟܘܢ ܗܘܝܬ ܟܕ ܡܠܦ ܐܢܐ ܒܗܝܟܠܐ ܘܠܐ ܐܚܕܬܘܢܢܝ ܐܠܐ ܕܢܫܠܡܘܢ ܟܬܒܐ ܗܘܬ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.50",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 50,
      "referenceLabel": "Mark 14:50",
      "text": "ܗܝܕܝܢ ܫܒܩܘܗܝ ܬܠܡܝܕܘܗܝ ܘܥܪܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.51",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 51,
      "referenceLabel": "Mark 14:51",
      "text": "ܘܥܠܝܡܐ ܚܕ ܐܬܐ ܗܘܐ ܒܬܪܗ ܘܥܛܝܦ ܤܕܘܢܐ ܥܪܛܠ ܘܐܚܕܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.52",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 52,
      "referenceLabel": "Mark 14:52",
      "text": "ܗܘ ܕܝܢ ܫܒܩ ܤܕܘܢܐ ܘܥܪܩ ܥܪܛܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.53",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 53,
      "referenceLabel": "Mark 14:53",
      "text": "ܘܐܘܒܠܘܗܝ ܠܝܫܘܥ ܠܘܬ ܩܝܦܐ ܪܒ ܟܗܢܐ ܘܐܬܟܢܫܘ ܠܘܬܗ ܟܠܗܘܢ ܪܒܝ ܟܗܢܐ ܘܤܦܪܐ ܘܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.54",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 54,
      "referenceLabel": "Mark 14:54",
      "text": "ܫܡܥܘܢ ܕܝܢ ܡܢ ܪܘܚܩܐ ܐܬܐ ܗܘܐ ܒܬܪܗ ܥܕܡܐ ܠܓܘ ܕܪܬܐ ܕܪܒ ܟܗܢܐ ܘܝܬܒ ܗܘܐ ܥܡ ܡܫܡܫܢܐ ܘܫܚܢ ܠܘܩܒܠ ܢܘܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.55",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 55,
      "referenceLabel": "Mark 14:55",
      "text": "ܪܒܝ ܟܗܢܐ ܕܝܢ ܘܟܠܗ ܟܢܫܗܘܢ ܒܥܝܢ ܗܘܘ ܥܠ ܝܫܘܥ ܤܗܕܘܬܐ ܕܢܡܝܬܘܢܝܗܝ ܘܠܐ ܐܫܟܚܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.56",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 56,
      "referenceLabel": "Mark 14:56",
      "text": "ܟܕ ܤܓܝܐܐ ܓܝܪ ܡܤܗܕܝܢ ܗܘܘ ܥܠܘܗܝ ܠܐ ܫܘܝܢ ܗܘܝ ܤܗܕܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.57",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 57,
      "referenceLabel": "Mark 14:57",
      "text": "ܐܢܫܝܢ ܕܝܢ ܩܡܘ ܥܠܘܗܝ ܤܗܕܐ ܕܫܘܩܪܐ ܘܐܡܪܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.58",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 58,
      "referenceLabel": "Mark 14:58",
      "text": "ܕܚܢܢ ܫܡܥܢܝܗܝ ܕܐܡܪ ܕܐܢܐ ܫܪܐ ܐܢܐ ܗܝܟܠܐ ܗܢܐ ܕܥܒܝܕ ܒܐܝܕܝܐ ܘܠܬܠܬܐ ܝܘܡܝܢ ܒܢܐ ܐܢܐ ܐܚܪܢܐ ܕܠܐ ܥܒܝܕ ܒܐܝܕܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.59",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 59,
      "referenceLabel": "Mark 14:59",
      "text": "ܘܐܦܠܐ ܕܝܢ ܗܟܢܐ ܫܘܝܐ ܗܘܬ ܤܗܕܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.60",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 60,
      "referenceLabel": "Mark 14:60",
      "text": "ܘܩܡ ܪܒ ܟܗܢܐ ܒܡܨܥܬܐ ܘܫܐܠܗ ܠܝܫܘܥ ܘܐܡܪ ܠܐ ܡܦܢܐ ܐܢܬ ܦܬܓܡܐ ܡܢܐ ܡܤܗܕܝܢ ܥܠܝܟ ܗܠܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.61",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 61,
      "referenceLabel": "Mark 14:61",
      "text": "ܗܘ ܕܝܢ ܫܬܝܩ ܗܘܐ ܘܡܕܡ ܠܐ ܥܢܝܗܝ ܘܬܘܒ ܫܐܠܗ ܪܒ ܟܗܢܐ ܘܐܡܪ ܐܢܬ ܗܘ ܡܫܝܚܐ ܒܪܗ ܕܡܒܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.62",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 62,
      "referenceLabel": "Mark 14:62",
      "text": "ܗܘ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗ ܐܢܐ ܐܢܐ ܘܬܚܙܘܢ ܠܒܪܗ ܕܐܢܫܐ ܕܝܬܒ ܡܢ ܝܡܝܢܐ ܕܚܝܠܐ ܘܐܬܐ ܥܠ ܥܢܢܝ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.63",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 63,
      "referenceLabel": "Mark 14:63",
      "text": "ܪܒ ܟܗܢܐ ܕܝܢ ܨܪܐ ܟܘܬܝܢܗ ܘܐܡܪ ܡܢܐ ܡܟܝܠ ܡܬܒܥܝܢ ܠܢ ܤܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.64",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 64,
      "referenceLabel": "Mark 14:64",
      "text": "ܗܐ ܡܢ ܦܘܡܗ ܫܡܥܬܘܢ ܓܘܕܦܐ ܡܢܐ ܡܬܚܙܐ ܠܟܘܢ ܗܢܘܢ ܕܝܢ ܟܠܗܘܢ ܕܢܘ ܕܚܝܒ ܗܘ ܡܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.65",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 65,
      "referenceLabel": "Mark 14:65",
      "text": "ܘܫܪܝܘ ܐܢܫܝܢ ܪܩܝܢ ܒܦܪܨܘܦܗ ܘܡܚܦܝܢ ܐܦܘܗܝ ܘܡܩܦܚܝܢ ܠܗ ܘܐܡܪܝܢ ܐܬܢܒܐ ܘܕܚܫܐ ܡܚܝܢ ܗܘܘ ܠܗ ܥܠ ܦܟܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.66",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 66,
      "referenceLabel": "Mark 14:66",
      "text": "ܘܟܕ ܫܡܥܘܢ ܠܬܚܬ ܒܕܪܬܐ ܐܬܬ ܥܠܝܡܬܐ ܚܕܐ ܕܪܒ ܟܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.67",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 67,
      "referenceLabel": "Mark 14:67",
      "text": "ܚܙܬܗ ܕܫܚܢ ܘܚܪܬ ܒܗ ܘܐܡܪܐ ܠܗ ܘܐܦ ܐܢܬ ܥܡ ܝܫܘܥ ܗܘܝܬ ܢܨܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.68",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 68,
      "referenceLabel": "Mark 14:68",
      "text": "ܗܘ ܕܝܢ ܟܦܪ ܘܐܡܪ ܠܐ ܝܕܥ ܐܢܐ ܡܢܐ ܐܡܪܐ ܐܢܬܝ ܘܢܦܩ ܠܒܪ ܠܤܦܐ ܘܩܪܐ ܬܪܢܓܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.69",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 69,
      "referenceLabel": "Mark 14:69",
      "text": "ܘܚܙܬܗ ܬܘܒ ܥܠܝܡܬܐ ܗܝ ܘܫܪܝܬ ܕܬܐܡܪ ܠܐܝܠܝܢ ܕܩܝܡܝܢ ܕܐܦ ܗܢܐ ܡܢܗܘܢ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.70",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 70,
      "referenceLabel": "Mark 14:70",
      "text": "ܗܘ ܕܝܢ ܬܘܒ ܟܦܪ ܘܒܬܪ ܩܠܝܠ ܬܘܒ ܗܢܘܢ ܕܩܝܡܝܢ ܐܡܪܘ ܠܟܐܦܐ ܫܪܝܪܐܝܬ ܡܢܗܘܢ ܐܢܬ ܐܦ ܓܝܪ ܓܠܝܠܝܐ ܐܢܬ ܘܡܡܠܠܟ ܕܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.71",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 71,
      "referenceLabel": "Mark 14:71",
      "text": "ܗܘ ܕܝܢ ܫܪܝ ܗܘܐ ܡܚܪܡ ܘܝܡܐ ܕܠܐ ܝܕܥ ܐܢܐ ܠܓܒܪܐ ܗܢܐ ܕܐܡܪܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.14.72",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 14,
      "verseNumber": 72,
      "referenceLabel": "Mark 14:72",
      "text": "ܘܒܗ ܒܫܥܬܐ ܩܪܐ ܬܪܢܓܠܐ ܕܬܪܬܝܢ ܙܒܢܝܢ ܘܐܬܕܟܪ ܫܡܥܘܢ ܡܠܬܗ ܕܝܫܘܥ ܕܐܡܪ ܗܘܐ ܠܗ ܕܩܕܡ ܕܢܩܪܐ ܬܪܢܓܠܐ ܬܪܬܝܢ ܙܒܢܝܢ ܬܠܬ ܬܟܦܘܪ ܒܝ ܘܫܪܝ ܕܢܒܟܐ ܀",
      "paragraphStart": false
    }
  ]
}
