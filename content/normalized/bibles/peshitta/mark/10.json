{
  "chapter": {
    "id": "peshitta:mark.10",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 10,
    "referenceLabel": "Mark 10",
    "summary": "Source text for Mark 10 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.10.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 1,
      "referenceLabel": "Mark 10:1",
      "text": "ܘܩܡ ܡܢ ܬܡܢ ܘܐܬܐ ܠܬܚܘܡܐ ܕܝܗܘܕ ܠܥܒܪܐ ܕܝܘܪܕܢܢ ܘܐܙܠܘ ܠܬܡܢ ܠܘܬܗ ܟܢܫܐ ܤܓܝܐܐ ܘܡܠܦ ܗܘܐ ܠܗܘܢ ܬܘܒ ܐܝܟ ܕܡܥܕ ܗܘܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.10.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 2,
      "referenceLabel": "Mark 10:2",
      "text": "ܘܩܪܒܘ ܦܪܝܫܐ ܡܢܤܝܢ ܠܗ ܘܡܫܐܠܝܢ ܕܐܢ ܫܠܝܛ ܠܓܒܪܐ ܕܢܫܒܘܩ ܐܢܬܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 3,
      "referenceLabel": "Mark 10:3",
      "text": "ܐܡܪ ܠܗܘܢ ܡܢܐ ܦܩܕܟܘܢ ܡܘܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 4,
      "referenceLabel": "Mark 10:4",
      "text": "ܗܢܘܢ ܕܝܢ ܐܡܪܝܢ ܡܘܫܐ ܐܦܤ ܠܢ ܕܢܟܬܘܒ ܟܬܒܐ ܕܫܘܒܩܢܐ ܘܢܫܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 5,
      "referenceLabel": "Mark 10:5",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܠܘܩܒܠ ܩܫܝܘܬ ܠܒܟܘܢ ܟܬܒ ܠܟܘܢ ܦܘܩܕܢܐ ܗܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 6,
      "referenceLabel": "Mark 10:6",
      "text": "ܡܢ ܒܪܫܝܬ ܕܝܢ ܕܟܪܐ ܘܢܩܒܬܐ ܥܒܕ ܐܢܘܢ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 7,
      "referenceLabel": "Mark 10:7",
      "text": "ܡܛܠ ܗܢܐ ܢܫܒܘܩ ܓܒܪܐ ܠܐܒܘܗܝ ܘܠܐܡܗ ܘܢܩܦ ܠܐܢܬܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 8,
      "referenceLabel": "Mark 10:8",
      "text": "ܘܢܗܘܘܢ ܬܪܝܗܘܢ ܚܕ ܒܤܪ ܡܟܝܠ ܠܐ ܗܘܘ ܬܪܝܢ ܐܠܐ ܚܕ ܒܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 9,
      "referenceLabel": "Mark 10:9",
      "text": "ܡܕܡ ܕܐܠܗܐ ܗܟܝܠ ܙܘܓ ܒܪܢܫܐ ܠܐ ܢܦܪܫ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 10,
      "referenceLabel": "Mark 10:10",
      "text": "ܘܫܐܠܘܗܝ ܬܘܒ ܬܠܡܝܕܘܗܝ ܒܒܝܬܐ ܥܠ ܗܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 11,
      "referenceLabel": "Mark 10:11",
      "text": "ܘܐܡܪ ܠܗܘܢ ܟܠ ܡܢ ܕܢܫܪܐ ܐܢܬܬܗ ܘܢܤܒ ܐܚܪܬܐ ܓܐܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 12,
      "referenceLabel": "Mark 10:12",
      "text": "ܘܐܢ ܐܢܬܬܐ ܬܫܪܐ ܒܥܠܗ ܘܬܗܘܐ ܠܐܚܪܢܐ ܓܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 13,
      "referenceLabel": "Mark 10:13",
      "text": "ܘܡܩܪܒܝܢ ܗܘܘ ܠܗ ܛܠܝܐ ܕܢܩܪܘܒ ܠܗܘܢ ܬܠܡܝܕܘܗܝ ܕܝܢ ܟܐܝܢ ܗܘܘ ܒܗܠܝܢ ܕܡܩܪܒܝܢ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 14,
      "referenceLabel": "Mark 10:14",
      "text": "ܝܫܘܥ ܕܝܢ ܚܙܐ ܘܐܬܒܐܫ ܠܗ ܘܐܡܪ ܠܗܘܢ ܫܒܘܩܘ ܛܠܝܐ ܐܬܝܢ ܠܘܬܝ ܘܠܐ ܬܟܠܘܢ ܐܢܘܢ ܕܕܐܝܠܝܢ ܓܝܪ ܕܐܝܟ ܗܠܝܢ ܐܢܘܢ ܐܝܬܝܗ ܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 15,
      "referenceLabel": "Mark 10:15",
      "text": "ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܟܠ ܕܠܐ ܢܩܒܠ ܡܠܟܘܬܐ ܕܐܠܗܐ ܐܝܟ ܛܠܝܐ ܠܐ ܢܥܘܠ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 16,
      "referenceLabel": "Mark 10:16",
      "text": "ܘܫܩܠ ܐܢܘܢ ܥܠ ܕܪܥܘܗܝ ܘܤܡ ܐܝܕܗ ܥܠܝܗܘܢ ܘܒܪܟ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 17,
      "referenceLabel": "Mark 10:17",
      "text": "ܘܟܕ ܪܕܐ ܒܐܘܪܚܐ ܪܗܛ ܚܕ ܢܦܠ ܥܠ ܒܘܪܟܘܗܝ ܘܡܫܐܠ ܗܘܐ ܠܗ ܘܐܡܪ ܡܠܦܢܐ ܛܒܐ ܡܢܐ ܐܥܒܕ ܕܐܬܪ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 18,
      "referenceLabel": "Mark 10:18",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܡܢܐ ܩܪܐ ܐܢܬ ܠܝ ܛܒܐ ܠܝܬ ܛܒܐ ܐܠܐ ܐܢ ܚܕ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 19,
      "referenceLabel": "Mark 10:19",
      "text": "ܦܘܩܕܢܐ ܝܕܥ ܐܢܬ ܠܐ ܬܓܘܪ ܠܐ ܬܓܢܘܒ ܠܐ ܬܩܛܘܠ ܘܠܐ ܬܤܗܕ ܤܗܕܘܬܐ ܕܓܠܬܐ ܠܐ ܬܛܠܘܡ ܝܩܪ ܠܐܒܘܟ ܘܠܐܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 20,
      "referenceLabel": "Mark 10:20",
      "text": "ܗܘ ܕܝܢ ܥܢܐ ܘܐܡܪ ܠܗ ܡܠܦܢܐ ܗܠܝܢ ܟܠܗܝܢ ܢܛܪܬ ܐܢܝܢ ܡܢ ܛܠܝܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 21,
      "referenceLabel": "Mark 10:21",
      "text": "ܝܫܘܥ ܕܝܢ ܚܪ ܒܗ ܘܐܚܒܗ ܘܐܡܪ ܠܗ ܚܕܐ ܚܤܝܪܐ ܠܟ ܙܠ ܙܒܢ ܟܠ ܡܕܡ ܕܐܝܬ ܠܟ ܘܗܒ ܠܡܤܟܢܐ ܘܬܗܘܐ ܠܟ ܤܝܡܬܐ ܒܫܡܝܐ ܘܤܒ ܨܠܝܒܐ ܘܬܐ ܒܬܪܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 22,
      "referenceLabel": "Mark 10:22",
      "text": "ܗܘ ܕܝܢ ܐܬܟܡܪ ܒܡܠܬܐ ܗܕܐ ܘܐܙܠ ܟܕ ܥܝܝܩܐ ܠܗ ܐܝܬ ܗܘܐ ܠܗ ܓܝܪ ܢܟܤܐ ܤܓܝܐܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 23,
      "referenceLabel": "Mark 10:23",
      "text": "ܚܪ ܕܝܢ ܝܫܘܥ ܒܬܠܡܝܕܘܗܝ ܘܐܡܪ ܠܗܘܢ ܟܡܐ ܥܛܠܐ ܠܐܝܠܝܢ ܕܐܝܬ ܠܗܘܢ ܢܟܤܐ ܕܢܥܠܘܢ ܠܡܠܟܘܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 24,
      "referenceLabel": "Mark 10:24",
      "text": "ܬܠܡܝܕܐ ܕܝܢ ܡܬܕܡܪܝܢ ܗܘܘ ܥܠ ܡܠܘܗܝ ܘܥܢܐ ܬܘܒ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܒܢܝ ܟܡܐ ܥܛܠܐ ܠܐܝܠܝܢ ܕܬܟܝܠܝܢ ܥܠ ܢܟܤܝܗܘܢ ܕܢܥܠܘܢ ܠܡܠܟܘܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 25,
      "referenceLabel": "Mark 10:25",
      "text": "ܦܫܝܩ ܗܘ ܠܓܡܠܐ ܕܢܥܘܠ ܒܚܪܘܪܐ ܕܡܚܛܐ ܐܘ ܥܬܝܪܐ ܠܡܠܟܘܬܗ ܕܐܠܗܐ ܠܡܥܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 26,
      "referenceLabel": "Mark 10:26",
      "text": "ܗܢܘܢ ܕܝܢ ܝܬܝܪܐܝܬ ܡܬܕܡܪܝܢ ܗܘܘ ܘܐܡܪܝܢ ܒܝܢܝܗܘܢ ܡܢܘ ܡܫܟܚ ܠܡܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 27,
      "referenceLabel": "Mark 10:27",
      "text": "ܚܪ ܕܝܢ ܒܗܘܢ ܝܫܘܥ ܘܐܡܪ ܠܗܘܢ ܠܘܬ ܒܢܝ ܐܢܫܐ ܗܕܐ ܠܐ ܡܫܟܚܐ ܐܠܐ ܠܘܬ ܐܠܗܐ ܟܠ ܡܕܡ ܓܝܪ ܡܫܟܚܐ ܠܘܬ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 28,
      "referenceLabel": "Mark 10:28",
      "text": "ܘܫܪܝ ܟܐܦܐ ܠܡܐܡܪ ܗܐ ܚܢܢ ܫܒܩܢ ܟܠ ܡܕܡ ܘܢܩܦܢܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 29,
      "referenceLabel": "Mark 10:29",
      "text": "ܥܢܐ ܝܫܘܥ ܘܐܡܪ ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܠܝܬ ܐܢܫ ܕܫܒܩ ܒܬܐ ܐܘ ܐܚܐ ܐܘ ܐܚܘܬܐ ܐܘ ܐܒܐ ܐܘ ܐܡܐ ܐܘ ܐܢܬܬܐ ܐܘ ܒܢܝܐ ܐܘ ܩܘܪܝܐ ܡܛܠܬܝ ܘܡܛܠ ܤܒܪܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 30,
      "referenceLabel": "Mark 10:30",
      "text": "ܘܠܐ ܢܩܒܠ ܚܕ ܒܡܐܐ ܗܫܐ ܒܙܒܢܐ ܗܢܐ ܒܬܐ ܘܐܚܐ ܘܐܚܘܬܐ ܘܐܡܗܬܐ ܘܒܢܝܐ ܘܩܘܪܝܐ ܥܡ ܪܕܘܦܝܐ ܘܒܥܠܡܐ ܕܐܬܐ ܚܝܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 31,
      "referenceLabel": "Mark 10:31",
      "text": "ܤܓܝܐܐ ܕܝܢ ܩܕܡܝܐ ܕܢܗܘܘܢ ܐܚܪܝܐ ܘܐܚܪܝܐ ܩܕܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 32,
      "referenceLabel": "Mark 10:32",
      "text": "ܟܕ ܤܠܩܝܢ ܗܘܘ ܕܝܢ ܒܐܘܪܚܐ ܠܐܘܪܫܠܡ ܗܘ ܝܫܘܥ ܩܕܝܡ ܗܘܐ ܠܗܘܢ ܘܡܬܬܡܗܝܢ ܗܘܘ ܘܐܙܠܝܢ ܗܘܘ ܒܬܪܗ ܟܕ ܕܚܝܠܝܢ ܘܕܒܪ ܠܬܪܥܤܪܬܗ ܘܫܪܝ ܕܢܐܡܪ ܠܗܘܢ ܡܕܡ ܕܥܬܝܕ ܕܢܗܘܐ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 33,
      "referenceLabel": "Mark 10:33",
      "text": "ܕܗܐ ܤܠܩܝܢ ܚܢܢ ܠܐܘܪܫܠܡ ܘܒܪܗ ܕܐܢܫܐ ܡܫܬܠܡ ܠܪܒܝ ܟܗܢܐ ܘܠܤܦܪܐ ܘܢܚܝܒܘܢܝܗܝ ܠܡܘܬܐ ܘܢܫܠܡܘܢܝܗܝ ܠܥܡܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 34,
      "referenceLabel": "Mark 10:34",
      "text": "ܘܢܒܙܚܘܢ ܒܗ ܘܢܢܓܕܘܢܝܗܝ ܘܢܪܩܘܢ ܒܐܦܘܗܝ ܘܢܩܛܠܘܢܝܗܝ ܘܠܝܘܡܐ ܕܬܠܬܐ ܢܩܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 35,
      "referenceLabel": "Mark 10:35",
      "text": "ܘܩܪܒܘ ܠܘܬܗ ܝܥܩܘܒ ܘܝܘܚܢܢ ܒܢܝ ܙܒܕܝ ܘܐܡܪܝܢ ܠܗ ܡܠܦܢܐ ܨܒܝܢ ܚܢܢ ܕܟܠ ܕܢܫܐܠ ܬܥܒܕ ܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 36,
      "referenceLabel": "Mark 10:36",
      "text": "ܐܡܪ ܠܗܘܢ ܡܢܐ ܨܒܝܢ ܐܢܬܘܢ ܐܥܒܕ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 37,
      "referenceLabel": "Mark 10:37",
      "text": "ܐܡܪܝܢ ܠܗ ܗܒ ܠܢ ܕܚܕ ܢܬܒ ܡܢ ܝܡܝܢܟ ܘܚܕ ܡܢ ܤܡܠܟ ܒܫܘܒܚܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.10.38",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 38,
      "referenceLabel": "Mark 10:38",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܡܢܐ ܫܐܠܝܢ ܐܢܬܘܢ ܡܫܟܚܝܢ ܐܢܬܘܢ ܕܬܫܬܘܢ ܟܤܐ ܕܐܢܐ ܫܬܐ ܐܢܐ ܘܡܥܡܘܕܝܬܐ ܕܐܢܐ ܥܡܕ ܐܢܐ ܬܥܡܕܘܢ ܀",
      "paragraphStart": false
    },
    {
