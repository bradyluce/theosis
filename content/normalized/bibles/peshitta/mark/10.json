      "bookSlug": "mark",
      "chapterNumber": 10,
      "verseNumber": 50,
      "referenceLabel": "Mark 10:50",
      "text": "ܗܘ ܕܝܢ ܤܡܝܐ ܫܕܐ ܠܒܫܗ ܘܩܡ ܐܬܐ ܠܘܬ ܝܫܘܥ ܀",
      "paragraphStart": false
