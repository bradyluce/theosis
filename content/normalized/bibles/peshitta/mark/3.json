{
  "chapter": {
    "id": "peshitta:mark.3",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 3,
    "referenceLabel": "Mark 3",
    "summary": "Source text for Mark 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.3.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Mark 3:1",
      "text": "ܘܥܠ ܬܘܒ ܝܫܘܥ ܠܟܢܘܫܬܐ ܘܐܝܬ ܗܘܐ ܬܡܢ ܓܒܪܐ ܚܕ ܕܝܒܝܫܐ ܐܝܕܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.3.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Mark 3:2",
      "text": "ܘܢܛܪܝܢ ܗܘܘ ܠܗ ܕܐܢ ܡܐܤܐ ܠܗ ܒܫܒܬܐ ܢܩܛܪܓܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Mark 3:3",
      "text": "ܘܐܡܪ ܠܗܘ ܓܒܪܐ ܕܝܒܝܫܐ ܐܝܕܗ ܩܘܡ ܒܡܨܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Mark 3:4",
      "text": "ܐܡܪ ܕܝܢ ܐܦ ܠܗܘܢ ܫܠܝܛ ܒܫܒܬܐ ܠܡܥܒܕ ܕܛܒ ܐܘ ܕܒܝܫ ܢܦܫܐ ܠܡܚܝܘ ܐܘ ܠܡܘܒܕܘ ܗܢܘܢ ܕܝܢ ܫܬܝܩܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Mark 3:5",
      "text": "ܘܚܪ ܒܗܘܢ ܒܚܡܬܐ ܟܕ ܟܪܝܐ ܠܗ ܥܠ ܩܫܝܘܬ ܠܒܗܘܢ ܘܐܡܪ ܠܗܘ ܓܒܪܐ ܦܫܘܛ ܐܝܕܟ ܘܦܫܛ ܘܬܩܢܬ ܐܝܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Mark 3:6",
      "text": "ܘܢܦܩܘ ܦܪܝܫܐ ܒܪ ܫܥܬܗ ܥܡ ܕܒܝܬ ܗܪܘܕܤ ܘܡܠܟܐ ܢܤܒܘ ܥܠܘܗܝ ܐܝܟܢܐ ܕܢܘܒܕܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Mark 3:7",
      "text": "ܘܝܫܘܥ ܥܡ ܬܠܡܝܕܘܗܝ ܐܙܠ ܠܗ ܠܘܬ ܝܡܐ ܘܥܡܐ ܤܓܝܐܐ ܡܢ ܓܠܝܠܐ ܢܩܦܗ ܗܘܐ ܘܡܢ ܝܗܘܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Mark 3:8",
      "text": "ܘܡܢ ܐܘܪܫܠܡ ܘܡܢ ܐܕܘܡ ܘܡܢ ܥܒܪܐ ܕܝܘܪܕܢܢ ܘܡܢ ܨܘܪ ܘܡܢ ܨܝܕܢ ܟܢܫܐ ܤܓܝܐܐ ܕܫܡܥܘ ܗܘܘ ܟܠ ܕܥܒܕ ܐܬܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Mark 3:9",
      "text": "ܘܐܡܪ ܠܬܠܡܝܕܘܗܝ ܕܢܩܪܒܘܢ ܠܗ ܤܦܝܢܬܐ ܡܛܠ ܟܢܫܐ ܕܠܐ ܢܚܒܨܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Mark 3:10",
      "text": "ܤܓܝܐܐ ܓܝܪ ܡܐܤܐ ܗܘܐ ܥܕܡܐ ܕܢܗܘܘܢ ܢܦܠܝܢ ܥܠܘܗܝ ܡܛܠ ܕܢܬܩܪܒܘܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Mark 3:11",
      "text": "ܘܐܝܠܝܢ ܕܐܝܬ ܗܘܝ ܠܗܘܢ ܡܚܘܬܐ ܕܪܘܚܐ ܛܢܦܬܐ ܡܐ ܕܚܙܐܘܗܝ ܢܦܠܝܢ ܗܘܘ ܘܩܥܝܢ ܘܐܡܪܝܢ ܐܢܬ ܗܘ ܒܪܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Mark 3:12",
      "text": "ܘܤܓܝ ܟܐܐ ܗܘܐ ܒܗܘܢ ܕܠܐ ܢܓܠܘܢܝܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Mark 3:13",
      "text": "ܘܤܠܩ ܠܛܘܪܐ ܘܩܪܐ ܠܐܝܠܝܢ ܕܨܒܐ ܘܐܬܘ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Mark 3:14",
      "text": "ܘܓܒܐ ܬܪܥܤܪ ܕܢܗܘܘܢ ܥܡܗ ܘܕܢܫܕܪ ܐܢܘܢ ܕܢܟܪܙܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Mark 3:15",
      "text": "ܘܕܢܗܘܘܢ ܫܠܝܛܝܢ ܕܢܐܤܘܢ ܟܪܝܗܐ ܘܢܦܩܘܢ ܕܝܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Mark 3:16",
      "text": "ܘܫܡܝ ܠܫܡܥܘܢ ܫܡܐ ܟܐܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Mark 3:17",
      "text": "ܘܠܝܥܩܘܒ ܒܪ ܙܒܕܝ ܘܠܝܘܚܢܢ ܐܚܘܗܝ ܕܝܥܩܘܒ ܤܡ ܠܗܘܢ ܫܡܐ ܒܢܝ ܪܓܫܝ ܕܐܝܬܘܗܝ ܒܢܝ ܪܥܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Mark 3:18",
      "text": "ܘܐܢܕܪܐܘܤ ܘܦܝܠܝܦܘܤ ܘܒܪ ܬܘܠܡܝ ܘܡܬܝ ܘܬܐܘܡܐ ܘܝܥܩܘܒ ܒܪ ܚܠܦܝ ܘܬܕܝ ܘܫܡܥܘܢ ܩܢܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Mark 3:19",
      "text": "ܘܝܗܘܕܐ ܤܟܪܝܘܛܐ ܗܘ ܕܐܫܠܡܗ ܘܐܬܘ ܠܒܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Mark 3:20",
      "text": "ܘܐܬܟܢܫܘ ܟܢܫܐ ܬܘܒ ܐܝܟܢܐ ܕܠܐ ܢܫܟܚܘܢ ܗܘܘ ܠܚܡܐ ܠܡܐܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Mark 3:21",
      "text": "ܘܫܡܥܘ ܐܚܝܢܘܗܝ ܘܢܦܩܘ ܠܡܐܚܕܗ ܐܡܪܝܢ ܗܘܘ ܓܝܪ ܕܡܢ ܗܘܢܗ ܢܦܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 22,
      "referenceLabel": "Mark 3:22",
      "text": "ܘܤܦܪܐ ܐܝܠܝܢ ܕܡܢ ܐܘܪܫܠܡ ܢܚܬܘ ܐܡܪܝܢ ܗܘܘ ܒܥܠܙܒܘܒ ܐܝܬ ܒܗ ܘܒܪܫܐ ܕܕܝܘܐ ܡܦܩ ܕܝܘܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 23,
      "referenceLabel": "Mark 3:23",
      "text": "ܘܩܪܐ ܐܢܘܢ ܝܫܘܥ ܘܒܡܬܠܐ ܐܡܪ ܠܗܘܢ ܐܝܟܢܐ ܡܫܟܚ ܤܛܢܐ ܠܤܛܢܐ ܠܡܦܩܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 24,
      "referenceLabel": "Mark 3:24",
      "text": "ܐܢ ܡܠܟܘܬܐ ܓܝܪ ܥܠ ܢܦܫܗ ܬܬܦܠܓ ܠܐ ܡܫܟܚܐ ܠܡܩܡ ܡܠܟܘܬܐ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 25,
      "referenceLabel": "Mark 3:25",
      "text": "ܘܐܢ ܒܝܬܐ ܥܠ ܢܦܫܗ ܢܬܦܠܓ ܠܐ ܡܫܟܚ ܒܝܬܐ ܗܘ ܠܡܩܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 26,
      "referenceLabel": "Mark 3:26",
      "text": "ܘܐܢ ܗܘ ܕܤܛܢܐ ܩܡ ܥܠ ܢܦܫܗ ܘܐܬܦܠܓ ܠܐ ܡܫܟܚ ܠܡܩܡ ܐܠܐ ܚܪܬܗ ܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 27,
      "referenceLabel": "Mark 3:27",
      "text": "ܠܐ ܐܢܫ ܡܫܟܚ ܕܢܥܘܠ ܠܒܝܬ ܚܤܝܢܐ ܘܢܚܛܘܦ ܡܐܢܘܗܝ ܐܠܐ ܐܢ ܠܘܩܕܡ ܠܚܤܝܢܐ ܢܐܤܘܪ ܘܗܝܕܝܢ ܒܝܬܗ ܢܒܘܙ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 28,
      "referenceLabel": "Mark 3:28",
      "text": "ܐܡܝܢ ܐܡܪ ܐܢܐ ܠܟܘܢ ܕܟܠܗܘܢ ܚܛܗܐ ܘܓܘܕܦܐ ܕܢܓܕܦܘܢ ܒܢܝ ܐܢܫܐ ܢܫܬܒܩܘܢ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 29,
      "referenceLabel": "Mark 3:29",
      "text": "ܡܢ ܕܝܢ ܕܢܓܕܦ ܥܠ ܪܘܚܐ ܕܩܘܕܫܐ ܠܝܬ ܠܗ ܫܘܒܩܢܐ ܠܥܠܡ ܐܠܐ ܡܚܝܒ ܗܘ ܠܕܝܢܐ ܕܠܥܠܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 30,
      "referenceLabel": "Mark 3:30",
      "text": "ܡܛܠ ܕܐܡܪܝܢ ܗܘܘ ܕܪܘܚܐ ܛܢܦܬܐ ܐܝܬ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 31,
      "referenceLabel": "Mark 3:31",
      "text": "ܘܐܬܘ ܐܡܗ ܘܐܚܘܗܝ ܩܝܡܝܢ ܠܒܪ ܘܫܕܪܘ ܕܢܩܪܘܢܝܗܝ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 32,
      "referenceLabel": "Mark 3:32",
      "text": "ܝܬܒ ܗܘܐ ܕܝܢ ܚܕܪܘܗܝ ܟܢܫܐ ܘܐܡܪܘ ܠܗ ܗܐ ܐܡܟ ܘܐܚܝܟ ܠܒܪ ܒܥܝܢ ܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 33,
      "referenceLabel": "Mark 3:33",
      "text": "ܘܥܢܐ ܘܐܡܪ ܠܗܘܢ ܡܢ ܗܝ ܐܡܝ ܘܡܢ ܐܢܘܢ ܐܚܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 34,
      "referenceLabel": "Mark 3:34",
      "text": "ܘܚܪ ܒܐܝܠܝܢ ܕܝܬܒܝܢ ܠܘܬܗ ܘܐܡܪ ܗܐ ܐܡܝ ܘܗܐ ܐܚܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.3.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 3,
      "verseNumber": 35,
      "referenceLabel": "Mark 3:35",
      "text": "ܡܢ ܕܢܥܒܕ ܓܝܪ ܨܒܝܢܗ ܕܐܠܗܐ ܗܘܝܘ ܐܚܝ ܘܚܬܝ ܘܐܡܝ ܀ ܘܐܬܟܢܫܘ ܠܘܬܗ ܟܢܫܐ ܤܓܝܐܐ ܐܝܟ ܕܢܤܩ ܢܬܒ ܠܗ ܒܤܦܝܢܬܐ ܒܝܡܐ ܘܟܠܗ ܟܢܫܐ ܩܐܡ ܗܘܐ ܥܠ ܐܪܥܐ ܥܠ ܝܕ ܝܡܐ ܀",
      "paragraphStart": false
    }
  ]
}
