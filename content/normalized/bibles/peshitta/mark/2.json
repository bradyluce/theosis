{
  "chapter": {
    "id": "peshitta:mark.2",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 2,
    "referenceLabel": "Mark 2",
    "summary": "Source text for Mark 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.2.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Mark 2:1",
      "text": "ܘܥܠ ܬܘܒ ܝܫܘܥ ܠܟܦܪܢܚܘܡ ܠܝܘܡܬܐ ܘܟܕ ܫܡܥܘ ܕܒܒܝܬܐ ܗܘ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.2.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Mark 2:2",
      "text": "ܐܬܟܢܫܘ ܤܓܝܐܐ ܐܝܟܢܐ ܕܠܐ ܐܫܟܚ ܐܚܕ ܐܢܘܢ ܐܦܠܐ ܩܕܡ ܬܪܥܐ ܘܡܡܠܠ ܗܘܐ ܥܡܗܘܢ ܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Mark 2:3",
      "text": "ܘܐܬܘ ܠܘܬܗ ܘܐܝܬܝܘ ܠܗ ܡܫܪܝܐ ܟܕ ܫܩܝܠܝܢ ܠܗ ܒܝܬ ܐܪܒܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Mark 2:4",
      "text": "ܘܕܠܐ ܐܫܟܚܘ ܠܡܬܩܪܒܘ ܠܘܬܗ ܡܛܠ ܟܢܫܐ ܤܠܩܘ ܠܗܘܢ ܠܐܓܪܐ ܘܐܪܝܡܘ ܬܛܠܝܠܐ ܕܐܬܪ ܕܐܝܬܘܗܝ ܗܘܐ ܝܫܘܥ ܘܫܒܘܗ ܥܪܤܐ ܕܪܡܐ ܗܘܐ ܒܗ ܡܫܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Mark 2:5",
      "text": "ܟܕ ܚܙܐ ܕܝܢ ܝܫܘܥ ܗܝܡܢܘܬܗܘܢ ܐܡܪ ܠܗܘ ܡܫܪܝܐ ܒܪܝ ܫܒܝܩܝܢ ܠܟ ܚܛܗܝܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Mark 2:6",
      "text": "ܐܝܬ ܗܘܘ ܕܝܢ ܬܡܢ ܡܢ ܤܦܪܐ ܘܦܪܝܫܐ ܕܝܬܒܝܢ ܘܡܬܪܥܝܢ ܗܘܘ ܒܠܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Mark 2:7",
      "text": "ܕܡܢܐ ܗܢܐ ܡܡܠܠ ܓܘܕܦܐ ܡܢܘ ܡܫܟܚ ܠܡܫܒܩ ܚܛܗܐ ܐܠܐ ܐܢ ܚܕ ܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Mark 2:8",
      "text": "ܝܫܘܥ ܕܝܢ ܝܕܥ ܒܪܘܚܗ ܕܗܠܝܢ ܡܬܪܥܝܢ ܒܢܦܫܗܘܢ ܘܐܡܪ ܠܗܘܢ ܡܢܐ ܡܬܪܥܝܢ ܐܢܬܘܢ ܗܠܝܢ ܒܠܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Mark 2:9",
      "text": "ܐܝܕܐ ܦܫܝܩܐ ܠܡܐܡܪ ܠܡܫܪܝܐ ܕܫܒܝܩܝܢ ܠܟ ܚܛܗܝܟ ܐܘ ܠܡܐܡܪ ܕܩܘܡ ܫܩܘܠ ܥܪܤܟ ܘܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Mark 2:10",
      "text": "ܕܬܕܥܘܢ ܕܝܢ ܕܫܠܝܛ ܗܘ ܒܪܗ ܕܐܢܫܐ ܒܐܪܥܐ ܠܡܫܒܩ ܚܛܗܐ ܐܡܪ ܠܡܫܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Mark 2:11",
      "text": "ܠܟ ܐܡܪ ܐܢܐ ܩܘܡ ܫܩܘܠ ܥܪܤܟ ܘܙܠ ܠܒܝܬܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Mark 2:12",
      "text": "ܘܩܡ ܒܪ ܫܥܬܗ ܘܫܩܠ ܥܪܤܗ ܘܢܦܩ ܠܥܝܢ ܟܠܗܘܢ ܐܝܟܢܐ ܕܢܬܕܡܪܘܢ ܟܠܗܘܢ ܘܢܫܒܚܘܢ ܠܐܠܗܐ ܟܕ ܐܡܪܝܢ ܕܠܐ ܡܡܬܘܡ ܚܙܝܢ ܗܟܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Mark 2:13",
      "text": "ܘܢܦܩ ܬܘܒ ܠܘܬ ܝܡܐ ܘܟܠܗ ܟܢܫܐ ܐܬܝܢ ܗܘܘ ܠܘܬܗ ܘܡܠܦ ܗܘܐ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Mark 2:14",
      "text": "ܘܟܕ ܥܒܪ ܚܙܐ ܠܠܘܝ ܒܪ ܚܠܦܝ ܕܝܬܒ ܒܝܬ ܡܟܤܐ ܘܐܡܪ ܠܗ ܬܐ ܒܬܪܝ ܘܩܡ ܐܙܠ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Mark 2:15",
      "text": "ܘܗܘܐ ܕܟܕ ܤܡܝܟ ܒܒܝܬܗ ܤܓܝܐܐ ܡܟܤܐ ܘܚܛܝܐ ܤܡܝܟܝܢ ܗܘܘ ܥܡ ܝܫܘܥ ܘܥܡ ܬܠܡܝܕܘܗܝ ܐܝܬܝܗܘܢ ܗܘܘ ܓܝܪ ܤܓܝܐܐ ܘܐܬܘ ܒܬܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Mark 2:16",
      "text": "ܘܤܦܪܐ ܘܦܪܝܫܐ ܟܕ ܚܙܐܘܗܝ ܕܠܥܤ ܥܡ ܡܟܤܐ ܘܥܡ ܚܛܝܐ ܐܡܪܘ ܠܬܠܡܝܕܘܗܝ ܡܢܘ ܥܡ ܡܟܤܐ ܘܚܛܝܐ ܐܟܠ ܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Mark 2:17",
      "text": "ܟܕ ܫܡܥ ܕܝܢ ܝܫܘܥ ܐܡܪ ܠܗܘܢ ܠܐ ܤܢܝܩܝܢ ܚܠܝܡܐ ܥܠ ܐܤܝܐ ܐܠܐ ܐܝܠܝܢ ܕܒܝܫ ܒܝܫ ܥܒܝܕܝܢ ܠܐ ܐܬܝܬ ܕܐܩܪܐ ܠܙܕܝܩܐ ܐܠܐ ܠܚܛܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Mark 2:18",
      "text": "ܬܠܡܝܕܘܗܝ ܕܝܢ ܕܝܘܚܢܢ ܘܦܪܝܫܐ ܨܝܡܝܢ ܗܘܘ ܘܐܬܘ ܘܐܡܪܝܢ ܠܗ ܠܡܢܐ ܬܠܡܝܕܘܗܝ ܕܝܘܚܢܢ ܘܕܦܪܝܫܐ ܨܝܡܝܢ ܘܬܠܡܝܕܝܟ ܕܝܠܟ ܠܐ ܨܝܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Mark 2:19",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܡܐ ܡܫܟܚܝܢ ܒܢܘܗܝ ܕܓܢܘܢܐ ܟܡܐ ܕܚܬܢܐ ܥܡܗܘܢ ܗܘ ܕܢܨܘܡܘܢ ܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Mark 2:20",
      "text": "ܢܐܬܘܢ ܕܝܢ ܝܘܡܬܐ ܕܡܐ ܕܐܫܬܩܠ ܡܢܗܘܢ ܚܬܢܐ ܗܝܕܝܢ ܢܨܘܡܘܢ ܒܗܘ ܝܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Mark 2:21",
      "text": "ܠܐ ܐܢܫ ܪܡܐ ܐܘܪܩܥܬܐ ܚܕܬܐ ܘܚܐܛ ܥܠ ܡܐܢܐ ܒܠܝܐ ܕܠܐ ܢܤܒܐ ܡܠܝܘܬܗ ܗܝ ܚܕܬܐ ܡܢ ܒܠܝܐ ܘܗܘܐ ܤܕܩܐ ܝܬܝܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Mark 2:22",
      "text": "ܘܠܐ ܐܢܫ ܪܡܐ ܚܡܪܐ ܚܕܬܐ ܒܙܩܐ ܒܠܝܬܐ ܕܠܐ ܚܡܪܐ ܡܨܪܐ ܠܙܩܐ ܘܙܩܐ ܐܒܕܢ ܘܚܡܪܐ ܡܬܐܫܕ ܐܠܐ ܪܡܝܢ ܚܡܪܐ ܚܕܬܐ ܒܙܩܐ ܚܕܬܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Mark 2:23",
      "text": "ܘܗܘܐ ܕܟܕ ܐܙܠ ܝܫܘܥ ܒܫܒܬܐ ܒܝܬ ܙܪܥܐ ܬܠܡܝܕܘܗܝ ܡܗܠܟܝܢ ܗܘܘ ܘܡܠܓܝܢ ܫܒܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 24,
      "referenceLabel": "Mark 2:24",
      "text": "ܘܐܡܪܝܢ ܠܗ ܦܪܝܫܐ ܚܙܝ ܡܢܐ ܥܒܕܝܢ ܒܫܒܬܐ ܡܕܡ ܕܠܐ ܫܠܝܛ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 25,
      "referenceLabel": "Mark 2:25",
      "text": "ܐܡܪ ܠܗܘܢ ܝܫܘܥ ܠܐ ܡܡܬܘܡ ܩܪܝܬܘܢ ܡܢܐ ܥܒܕ ܕܘܝܕ ܟܕ ܐܤܬܢܩ ܘܟܦܢ ܗܘ ܘܕܥܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 26,
      "referenceLabel": "Mark 2:26",
      "text": "ܐܝܟܢܐ ܥܠ ܠܒܝܬܗ ܕܐܠܗܐ ܟܕ ܐܒܝܬܪ ܪܒ ܟܗܢܐ ܘܠܚܡܐ ܕܦܬܘܪܗ ܕܡܪܝܐ ܐܟܠ ܗܘ ܕܠܐ ܫܠܝܛ ܠܡܐܟܠ ܐܠܐ ܐܢ ܠܟܗܢܐ ܘܝܗܒ ܐܦ ܠܐܝܠܝܢ ܕܥܡܗ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 27,
      "referenceLabel": "Mark 2:27",
      "text": "ܘܐܡܪ ܠܗܘܢ ܕܫܒܬܐ ܡܛܠ ܒܪܢܫܐ ܐܬܒܪܝܬ ܘܠܐ ܗܘܐ ܒܪܢܫܐ ܡܛܠ ܫܒܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.2.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 2,
      "verseNumber": 28,
      "referenceLabel": "Mark 2:28",
      "text": "ܡܪܗ ܗܘ ܗܟܝܠ ܘܐܦ ܕܫܒܬܐ ܒܪܗ ܕܐܢܫܐ ܀",
      "paragraphStart": false
    }
  ]
}
