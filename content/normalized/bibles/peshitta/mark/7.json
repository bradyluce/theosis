{
  "chapter": {
    "id": "peshitta:mark.7",
    "translationId": "peshitta",
    "bookSlug": "mark",
    "chapterNumber": 7,
    "referenceLabel": "Mark 7",
    "summary": "Source text for Mark 7 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:mark.7.1",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 1,
      "referenceLabel": "Mark 7:1",
      "text": "ܘܟܢܫܘ ܠܘܬܗ ܦܪܝܫܐ ܘܤܦܪܐ ܕܐܬܘ ܡܢ ܐܘܪܫܠܡ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:mark.7.2",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 2,
      "referenceLabel": "Mark 7:2",
      "text": "ܘܚܙܘ ܐܢܫܝܢ ܡܢ ܬܠܡܝܕܘܗܝ ܕܐܟܠܝܢ ܠܚܡܐ ܟܕ ܠܐ ܡܫܓܢ ܐܝܕܝܗܘܢ ܘܐܬܥܕܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.3",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 3,
      "referenceLabel": "Mark 7:3",
      "text": "ܟܠܗܘܢ ܓܝܪ ܝܗܘܕܝܐ ܘܦܪܝܫܐ ܐܢ ܗܘ ܕܒܛܝܠܐܝܬ ܠܐ ܡܫܝܓܝܢ ܐܝܕܝܗܘܢ ܠܐ ܠܥܤܝܢ ܡܛܠ ܕܐܚܝܕܝܢ ܡܫܠܡܢܘܬܐ ܕܩܫܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.4",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 4,
      "referenceLabel": "Mark 7:4",
      "text": "ܘܡܢ ܫܘܩܐ ܐܠܐ ܥܡܕܝܢ ܠܐ ܠܥܤܝܢ ܘܤܓܝܐܬܐ ܐܚܪܢܝܬܐ ܐܝܬ ܐܝܠܝܢ ܕܩܒܠܘ ܕܢܛܪܘܢ ܡܥܡܘܕܝܬܐ ܕܟܤܐ ܘܕܩܤܛܐ ܘܕܡܐܢܝ ܢܚܫܐ ܘܕܥܪܤܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.5",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 5,
      "referenceLabel": "Mark 7:5",
      "text": "ܘܫܐܠܘܗܝ ܤܦܪܐ ܘܦܪܝܫܐ ܠܡܢܐ ܬܠܡܝܕܝܟ ܠܐ ܡܗܠܟܝܢ ܐܝܟ ܡܫܠܡܢܘܬܐ ܕܩܫܝܫܐ ܐܠܐ ܟܕ ܠܐ ܡܫܓܢ ܐܝܕܝܗܘܢ ܐܟܠܝܢ ܠܚܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.6",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 6,
      "referenceLabel": "Mark 7:6",
      "text": "ܗܘ ܕܝܢ ܐܡܪ ܠܗܘܢ ܫܦܝܪ ܐܬܢܒܝ ܥܠܝܟܘܢ ܐܫܥܝܐ ܢܒܝܐ ܢܤܒܝ ܒܐܦܐ ܐܝܟ ܕܟܬܝܒ ܕܥܡܐ ܗܢܐ ܒܤܦܘܬܗ ܗܘ ܡܝܩܪ ܠܝ ܠܒܗܘܢ ܕܝܢ ܤܓܝ ܪܚܝܩ ܡܢܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.7",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 7,
      "referenceLabel": "Mark 7:7",
      "text": "ܘܤܪܝܩܐܝܬ ܕܚܠܝܢ ܠܝ ܟܕ ܡܠܦܝܢ ܝܘܠܦܢܐ ܕܦܘܩܕܢܐ ܕܒܢܝ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.8",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 8,
      "referenceLabel": "Mark 7:8",
      "text": "ܫܒܩܬܘܢ ܓܝܪ ܦܘܩܕܢܐ ܕܐܠܗܐ ܘܐܚܝܕܝܢ ܐܢܬܘܢ ܡܫܠܡܢܘܬܐ ܕܒܢܝ ܐܢܫܐ ܡܥܡܘܕܝܬܐ ܕܟܤܐ ܘܕܩܤܛܐ ܘܤܓܝܐܬܐ ܐܝܠܝܢ ܕܠܗܠܝܢ ܕܡܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.9",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 9,
      "referenceLabel": "Mark 7:9",
      "text": "ܐܡܪ ܠܗܘܢ ܫܦܝܪ ܛܠܡܝܢ ܐܢܬܘܢ ܦܘܩܕܢܐ ܕܐܠܗܐ ܕܬܩܝܡܘܢ ܡܫܠܡܢܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.10",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 10,
      "referenceLabel": "Mark 7:10",
      "text": "ܡܘܫܐ ܓܝܪ ܐܡܪ ܕܝܩܪ ܠܐܒܘܟ ܘܠܐܡܟ ܘܡܢ ܕܡܨܚܐ ܠܐܒܐ ܘܠܐܡܐ ܡܘܬܐ ܢܡܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.11",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 11,
      "referenceLabel": "Mark 7:11",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܡܪܝܢ ܐܢܬܘܢ ܐܢ ܢܐܡܪ ܓܒܪܐ ܠܐܒܘܗܝ ܐܘ ܠܐܡܗ ܩܘܪܒܢܝ ܡܕܡ ܕܡܢܝ ܬܐܬܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.12",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 12,
      "referenceLabel": "Mark 7:12",
      "text": "ܘܠܐ ܫܒܩܝܢ ܐܢܬܘܢ ܠܗ ܕܢܥܒܕ ܡܕܡ ܠܐܒܘܗܝ ܐܘ ܠܐܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.13",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 13,
      "referenceLabel": "Mark 7:13",
      "text": "ܘܡܤܠܝܢ ܐܢܬܘܢ ܡܠܬܐ ܕܐܠܗܐ ܡܛܠ ܡܫܠܡܢܘܬܐ ܕܐܫܠܡܬܘܢ ܘܕܕܡܝܢ ܠܗܠܝܢ ܤܓܝܐܬܐ ܥܒܕܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.14",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 14,
      "referenceLabel": "Mark 7:14",
      "text": "ܘܩܪܐ ܝܫܘܥ ܠܟܢܫܐ ܟܠܗ ܘܐܡܪ ܠܗܘܢ ܫܘܡܥܘܢܝ ܟܠܟܘܢ ܘܐܤܬܟܠܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.15",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 15,
      "referenceLabel": "Mark 7:15",
      "text": "ܠܝܬ ܡܕܡ ܕܠܒܪ ܡܢ ܒܪܢܫܐ ܗܘ ܘܥܐܠ ܠܗ ܕܡܫܟܚ ܡܤܝܒ ܠܗ ܐܠܐ ܡܕܡ ܕܢܦܩ ܡܢܗ ܗܘ ܗܘ ܡܤܝܒ ܠܒܪ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.16",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 16,
      "referenceLabel": "Mark 7:16",
      "text": "ܡܢ ܕܐܝܬ ܠܗ ܐܕܢܐ ܕܢܫܡܥ ܢܫܡܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.17",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 17,
      "referenceLabel": "Mark 7:17",
      "text": "ܟܕ ܕܝܢ ܥܠ ܝܫܘܥ ܠܒܝܬܐ ܡܢ ܟܢܫܐ ܫܐܠܘܗܝ ܬܠܡܝܕܘܗܝ ܥܠ ܡܬܠܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.18",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 18,
      "referenceLabel": "Mark 7:18",
      "text": "ܐܡܪ ܠܗܘܢ ܗܟܢܐ ܐܦ ܐܢܬܘܢ ܥܛܠܝܢ ܐܢܬܘܢ ܠܐ ܝܕܥܝܢ ܐܢܬܘܢ ܕܟܠ ܡܕܡ ܕܡܢ ܠܒܪ ܥܐܠ ܠܒܪ ܐܢܫܐ ܠܐ ܡܫܟܚ ܡܤܝܒ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.19",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 19,
      "referenceLabel": "Mark 7:19",
      "text": "ܕܠܐ ܗܘܐ ܠܠܒܗ ܥܐܠ ܐܠܐ ܠܟܪܤܗ ܘܡܫܬܕܐ ܒܬܕܟܝܬܐ ܕܡܕܟܝܐ ܟܠܗ ܡܐܟܘܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.20",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 20,
      "referenceLabel": "Mark 7:20",
      "text": "ܡܕܡ ܕܝܢ ܕܢܦܩ ܡܢ ܒܪܢܫܐ ܗܘ ܗܘ ܡܤܝܒ ܠܒܪ ܐܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.21",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 21,
      "referenceLabel": "Mark 7:21",
      "text": "ܡܢ ܠܓܘ ܓܝܪ ܡܢ ܠܒܐ ܕܒܢܝ ܐܢܫܐ ܢܦܩܢ ܡܚܫܒܬܐ ܒܝܫܬܐ ܓܘܪܐ ܙܢܝܘܬܐ ܓܢܒܘܬܐ ܩܛܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.22",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 22,
      "referenceLabel": "Mark 7:22",
      "text": "ܥܠܘܒܘܬܐ ܒܝܫܘܬܐ ܢܟܠܐ ܨܚܢܘܬܐ ܥܝܢܐ ܒܝܫܬܐ ܓܘܕܦܐ ܫܒܗܪܢܘܬܐ ܫܛܝܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.23",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 23,
      "referenceLabel": "Mark 7:23",
      "text": "ܗܠܝܢ ܟܠܗܝܢ ܒܝܫܬܐ ܡܢ ܠܓܘ ܗܘ ܢܦܩܢ ܘܡܤܝܒܢ ܠܗ ܠܒܪܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.24",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 24,
      "referenceLabel": "Mark 7:24",
      "text": "ܡܢ ܬܡܢ ܩܡ ܝܫܘܥ ܘܐܬܐ ܠܬܚܘܡܐ ܕܨܘܪ ܘܕܨܝܕܢ ܘܥܠ ܠܒܝܬܐ ܚܕ ܘܠܐ ܨܒܐ ܗܘܐ ܕܐܢܫ ܢܕܥ ܒܗ ܘܠܐ ܐܫܟܚ ܕܢܛܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.25",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 25,
      "referenceLabel": "Mark 7:25",
      "text": "ܡܚܕܐ ܓܝܪ ܫܡܥܬ ܐܢܬܬܐ ܚܕܐ ܡܛܠܬܗ ܕܐܝܬ ܗܘܬ ܠܒܪܬܗ ܪܘܚܐ ܛܢܦܬܐ ܘܐܬܬ ܢܦܠܬ ܩܕܡ ܪܓܠܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.26",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 26,
      "referenceLabel": "Mark 7:26",
      "text": "ܗܝ ܕܝܢ ܐܢܬܬܐ ܐܝܬܝܗ ܗܘܬ ܚܢܦܬܐ ܡܢ ܦܘܢܝܩܐ ܕܤܘܪܝܐ ܘܒܥܝܐ ܗܘܬ ܡܢܗ ܕܢܦܩ ܫܐܕܐ ܡܢ ܒܪܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.27",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 27,
      "referenceLabel": "Mark 7:27",
      "text": "ܘܐܡܪ ܠܗ ܝܫܘܥ ܫܒܘܩܝ ܠܘܩܕܡ ܕܢܤܒܥܘܢ ܒܢܝܐ ܠܐ ܗܘܬ ܓܝܪ ܫܦܝܪܐ ܕܢܤܒ ܠܚܡܐ ܕܒܢܝܐ ܘܢܪܡܐ ܠܟܠܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.28",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 28,
      "referenceLabel": "Mark 7:28",
      "text": "ܗܝ ܕܝܢ ܥܢܬ ܘܐܡܪܐ ܠܗ ܐܝܢ ܡܪܝ ܐܦ ܟܠܒܐ ܡܢ ܬܚܝܬ ܦܬܘܪܐ ܐܟܠܝܢ ܦܪܬܘܬܐ ܕܒܢܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.29",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 29,
      "referenceLabel": "Mark 7:29",
      "text": "ܐܡܪ ܠܗ ܝܫܘܥ ܙܠܝ ܡܛܠ ܗܕܐ ܡܠܬܐ ܢܦܩ ܠܗ ܫܐܕܐ ܡܢ ܒܪܬܟܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.30",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 30,
      "referenceLabel": "Mark 7:30",
      "text": "ܘܐܙܠܬ ܠܒܝܬܗ ܘܐܫܟܚܬ ܒܪܬܗ ܟܕ ܪܡܝܐ ܒܥܪܤܐ ܘܢܦܝܩ ܡܢܗ ܫܐܕܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.31",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 31,
      "referenceLabel": "Mark 7:31",
      "text": "ܬܘܒ ܢܦܩ ܝܫܘܥ ܡܢ ܬܚܘܡܐ ܕܨܘܪ ܘܕܨܝܕܢ ܘܐܬܐ ܠܝܡܐ ܕܓܠܝܠܐ ܒܬܚܘܡܐ ܕܥܤܪܬ ܡܕܝܢܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.32",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 32,
      "referenceLabel": "Mark 7:32",
      "text": "ܘܐܝܬܝܘ ܠܗ ܚܪܫܐ ܚܕ ܦܐܩܐ ܘܒܥܐ ܗܘܘ ܡܢܗ ܕܢܤܝܡ ܥܠܘܗܝ ܐܝܕܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.33",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 33,
      "referenceLabel": "Mark 7:33",
      "text": "ܘܢܓܕܗ ܡܢ ܟܢܫܐ ܒܠܚܘܕܘܗܝ ܘܐܪܡܝ ܨܒܥܬܗ ܒܐܕܢܘܗܝ ܘܪܩ ܘܩܪܒ ܠܠܫܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.34",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 34,
      "referenceLabel": "Mark 7:34",
      "text": "ܘܚܪ ܒܫܡܝܐ ܘܐܬܬܢܚ ܘܐܡܪ ܠܗ ܐܬܦܬܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.35",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 35,
      "referenceLabel": "Mark 7:35",
      "text": "ܘܒܗ ܒܫܥܬܐ ܐܬܦܬܚ ܐܕܢܘܗܝ ܘܐܫܬܪܝ ܐܤܪܐ ܕܠܫܢܗ ܘܡܠܠ ܦܫܝܩܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.36",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 36,
      "referenceLabel": "Mark 7:36",
      "text": "ܘܙܗܪ ܐܢܘܢ ܕܠܐܢܫ ܠܐ ܢܐܡܪܘܢ ܘܟܡܐ ܕܗܘ ܡܙܗܪ ܗܘܐ ܠܗܘܢ ܗܢܘܢ ܝܬܝܪ ܡܟܪܙܝܢ ܗܘܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:mark.7.37",
      "translationId": "peshitta",
      "bookSlug": "mark",
      "chapterNumber": 7,
      "verseNumber": 37,
      "referenceLabel": "Mark 7:37",
