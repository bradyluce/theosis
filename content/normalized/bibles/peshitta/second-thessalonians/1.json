      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 1:1",
      "text": "ܦܘܠܘܤ ܘܤܠܘܢܘܤ ܘܛܝܡܬܐܘܤ ܠܥܕܬܐ ܕܬܤܠܘܢܝܩܝܐ ܕܒܐܠܗܐ ܐܒܘܢ ܘܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-thessalonians.1.2",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 1:2",
      "text": "ܛܝܒܘܬܐ ܥܡܟܘܢ ܘܫܠܡܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.3",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 1:3",
      "text": "ܠܡܘܕܝܘ ܠܐܠܗܐ ܒܟܠܙܒܢ ܚܝܒܝܢܢ ܥܠܝܟܘܢ ܐܚܝ ܐܝܟ ܡܐ ܕܘܠܐ ܕܝܬܝܪܐܝܬ ܪܒܝܐ ܗܝܡܢܘܬܟܘܢ ܘܤܓܐ ܚܘܒܐ ܕܟܠܟܘܢ ܕܟܠܢܫ ܠܘܬ ܚܒܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.4",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 1:4",
      "text": "ܐܝܟ ܕܐܦ ܚܢܢ ܒܟܘܢ ܢܗܘܐ ܡܫܬܒܗܪܝܢ ܚܢܢ ܒܥܕܬܐ ܕܐܠܗܐ ܥܠ ܗܝܡܢܘܬܟܘܢ ܘܥܠ ܡܤܝܒܪܢܘܬܟܘܢ ܕܒܟܠܗ ܪܕܝܦܘܬܟܘܢ ܘܐܘܠܨܢܝܟܘܢ ܕܡܤܝܒܪܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.5",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 1:5",
      "text": "ܠܬܚܘܝܬܐ ܕܕܝܢܐ ܟܐܢܐ ܕܐܠܗܐ ܕܬܫܘܘܢ ܠܡܠܟܘܬܗ ܗܝ ܕܥܠ ܐܦܝܗ ܚܫܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.6",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 1:6",
      "text": "ܘܐܢ ܟܐܢܐ ܩܕܡ ܐܠܗܐ ܕܢܦܪܘܥ ܐܘܠܨܢܐ ܠܐܠܘܨܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.7",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 1:7",
      "text": "ܘܠܟܘܢ ܕܡܬܐܠܨܝܬܘܢ ܢܚܐ ܥܡܢ ܒܓܠܝܢܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܡܢ ܫܡܝܐ ܥܡ ܚܝܠܐ ܕܡܠܐܟܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.8",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 1:8",
      "text": "ܡܐ ܕܥܒܕ ܬܒܥܬܐ ܒܓܘܙܠܐ ܕܢܘܪܐ ܡܢ ܗܢܘܢ ܕܠܐ ܝܕܥܘ ܠܐܠܗܐ ܘܡܢ ܗܢܘܢ ܕܠܐ ܐܫܬܘܕܥܘ ܠܤܒܪܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.9",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 1:9",
      "text": "ܕܗܢܘܢ ܒܕܝܢܐ ܢܬܦܪܥܘܢ ܐܒܕܢܐ ܕܠܥܠܡ ܡܢ ܦܪܨܘܦܗ ܕܡܪܢ ܘܡܢ ܫܘܒܚܐ ܕܚܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.10",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 1:10",
      "text": "ܡܐ ܕܐܬܐ ܕܢܫܬܒܚ ܒܩܕܝܫܘܗܝ ܘܢܚܘܐ ܬܕܡܪܬܗ ܒܡܗܝܡܢܘܗܝ ܕܬܬܗܝܡܢ ܤܗܕܘܬܢ ܕܥܠܝܟܘܢ ܒܗܘ ܝܘܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.11",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 1:11",
      "text": "ܡܛܠܗܢܐ ܒܟܠܙܒܢ ܡܨܠܝܢܢ ܥܠܝܟܘܢ ܕܢܫܘܝܟܘܢ ܐܠܗܐ ܠܩܪܝܢܟܘܢ ܘܢܡܠܝܟܘܢ ܟܠܗ ܨܒܝܢܐ ܕܛܒܬܐ ܘܥܒܕܐ ܕܗܝܡܢܘܬܐ ܒܚܝܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.1.12",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 1:12",
      "text": "ܕܢܫܬܒܚ ܒܟܘܢ ܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܦ ܐܢܬܘܢ ܒܗ ܐܝܟ ܛܝܒܘܬܗ ܕܐܠܗܢ ܘܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    }
  ]
