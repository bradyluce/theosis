    "summary": "Source text for 2 Thessalonians 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-thessalonians.3.1",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 3:1",
      "text": "ܡܢ ܗܫܐ ܐܚܝܢ ܨܠܘ ܥܠܝܢ ܕܡܠܬܗ ܕܡܪܢ ܬܗܘܐ ܪܗܛܐ ܘܡܫܬܒܚܐ ܒܟܠ ܕܘܟܐ ܐܝܟ ܕܠܘܬܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-thessalonians.3.2",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 3:2",
      "text": "ܘܕܢܬܦܨܐ ܡܢ ܒܢܝܢܫܐ ܒܝܫܐ ܘܥܢܬܐ ܠܘ ܓܝܪ ܕܟܠܢܫ ܗܝ ܗܝܡܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.3",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 3:3",
      "text": "ܡܗܝܡܢ ܗܘ ܕܝܢ ܡܪܝܐ ܕܗܘ ܢܢܛܪܟܘܢ ܘܢܫܘܙܒܟܘܢ ܡܢ ܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.4",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 3:4",
      "text": "ܬܟܝܠܝܢܢ ܕܝܢ ܥܠܝܟܘܢ ܒܡܪܢ ܕܡܕܡ ܕܡܦܩܕܝܢܢ ܠܟܘܢ ܥܒܕܬܘܢ ܐܦ ܥܒܕܝܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.5",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 3:5",
      "text": "ܘܡܪܢ ܢܬܪܘܨ ܠܒܘܬܟܘܢ ܠܚܘܒܗ ܕܐܠܗܐ ܘܠܡܤܒܪܢܘܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.6",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 3:6",
      "text": "ܡܦܩܕܝܢܢ ܠܟܘܢ ܕܝܢ ܐܚܝ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܗܘܝܬܘܢ ܦܪܝܩܝܢ ܡܢ ܟܠ ܐܚܐ ܐܝܢܐ ܕܒܝܫ ܒܝܫ ܡܗܠܟ ܘܠܐ ܐܝܟ ܦܘܩܕܢܐ ܕܩܒܠܘ ܡܢܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.7",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 3:7",
      "text": "ܐܢܬܘܢ ܓܝܪ ܝܕܥܝܢ ܐܢܬܘܢ ܐܝܟܢܐ ܘܠܐ ܠܡܬܕܡܝܘ ܒܢ ܕܠܐ ܗܠܟܢ ܒܝܫ ܒܝܫ ܒܝܢܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.8",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 3:8",
      "text": "ܐܦܠܐ ܠܚܡܐ ܕܡܓܢ ܐܟܠܢ ܡܢ ܐܢܫ ܡܢܟܘܢ ܐܠܐ ܒܥܡܠܐ ܘܒܠܐܘܬܐ ܒܠܠܝܐ ܘܒܐܝܡܡܐ ܦܠܚܝܢ ܗܘܝܢ ܕܥܠ ܐܢܫ ܡܢܟܘܢ ܠܐ ܢܐܩܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.9",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 3:9",
      "text": "ܠܐ ܗܘܐ ܡܛܠ ܕܠܐ ܫܠܝܛ ܠܢ ܐܠܐ ܕܒܢܦܫܢ ܢܬܠ ܠܟܘܢ ܛܘܦܤܐ ܕܒܢ ܬܬܕܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.10",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 3:10",
      "text": "ܐܦ ܟܕ ܠܘܬܟܘܢ ܗܘܝܢ ܓܝܪ ܗܕܐ ܡܦܩܕܝܢ ܗܘܝܢ ܠܟܘܢ ܕܟܠ ܕܠܐ ܨܒܐ ܕܢܦܠܘܚ ܐܦܠܐ ܢܠܥܤ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.11",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 3:11",
      "text": "ܫܡܥܝܢܢ ܓܝܪ ܕܐܝܬ ܒܟܘܢ ܐܢܫܐ ܕܒܝܫ ܒܝܫ ܡܗܠܟܝܢ ܘܡܕܡ ܠܐ ܦܠܚܝܢ ܐܠܐ ܐܢ ܤܪܝܩܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.12",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 3:12",
      "text": "ܠܗܘܢ ܕܝܢ ܠܗܠܝܢ ܡܦܩܕܝܢܢ ܘܒܥܝܢܢ ܡܢܗܘܢ ܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܒܫܠܝܐ ܢܗܘܘܢ ܦܠܚܝܢ ܘܐܟܠܝܢ ܠܚܡܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.13",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 3:13",
      "text": "ܐܢܬܘܢ ܕܝܢ ܐܚܝ ܠܐ ܬܡܐܢ ܠܟܘܢ ܠܡܥܒܕ ܕܫܦܝܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.14",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 3:14",
      "text": "ܘܐܢ ܐܢܫ ܠܐ ܡܫܬܡܥ ܠܡܠܝܢ ܗܠܝܢ ܕܒܐܓܪܬܐ ܢܬܦܪܫ ܠܟܘܢ ܗܢܐ ܘܠܐ ܗܘܝܬܘܢ ܡܬܚܠܛܝܢ ܥܡܗ ܕܢܒܗܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.15",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 3:15",
      "text": "ܘܠܐ ܐܝܟ ܒܥܠܕܒܒܐ ܬܐܚܕܘܢܗ ܐܠܐ ܗܘܝܬܘܢ ܡܪܬܝܢ ܠܗ ܐܝܟ ܕܠܐܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.16",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 3:16",
      "text": "ܗܘ ܕܝܢ ܡܪܗ ܕܫܠܡܐ ܢܬܠ ܠܟܘܢ ܫܠܡܐ ܒܟܠܙܒܢ ܒܟܠܡܕܡ ܡܪܢ ܥܡ ܟܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.17",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 3:17",
      "text": "ܫܠܡܐ ܒܟܬܒܬ ܐܝܕܝ ܐܢܐ ܦܘܠܘܤ ܟܬܒܬ ܕܐܝܬܘܗܝ ܐܬܐ ܕܒܟܠܗܝܢ ܐܓܪܬܝ ܗܟܢܐ ܟܬܒ ܐܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.3.18",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "2 Thessalonians 3:18",
      "text": "ܛܝܒܘܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܥܡ ܟܠܟܘܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
