    "summary": "Source text for 2 Thessalonians 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:second-thessalonians.2.1",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "2 Thessalonians 2:1",
      "text": "ܒܥܝܢܢ ܕܝܢ ܡܢܟܘܢ ܐܚܝ ܥܠ ܡܐܬܝܬܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܥܠ ܟܢܘܫܝܐ ܕܝܠܢ ܕܠܘܬܗ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:second-thessalonians.2.2",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "2 Thessalonians 2:2",
      "text": "ܕܠܐ ܥܓܠ ܬܬܙܝܥܘܢ ܒܪܥܝܢܝܟܘܢ ܘܠܐ ܬܬܘܗܘܢ ܠܐ ܡܢ ܡܠܬܐ ܘܠܐ ܡܢ ܪܘܚܐ ܘܠܐ ܡܢ ܐܓܪܬܐ ܕܐܝܟ ܕܡܢ ܠܘܬܢ ܗܝ ܕܗܐ ܠܡ ܡܛܝ ܝܘܡܗ ܕܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.3",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "2 Thessalonians 2:3",
      "text": "ܠܡܐ ܐܢܫ ܢܛܥܝܟܘܢ ܒܚܕ ܡܢ ܐܤܟܡܝܢ ܡܛܠ ܕܐܢ ܠܐ ܬܐܬܐ ܠܘܩܕܡ ܡܪܘܕܘܬܐ ܘܢܬܓܠܐ ܒܪܢܫܐ ܕܚܛܝܬܐ ܒܪܗ ܕܐܒܕܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.4",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "2 Thessalonians 2:4",
      "text": "ܗܘ ܕܠܩܘܒܠܐ ܗܘ ܘܡܫܬܥܠܐ ܥܠ ܟܠ ܡܢ ܕܡܬܩܪܐ ܐܠܗ ܘܕܚܠܐ ܐܝܟܢܐ ܕܐܦ ܒܗܝܟܠܐ ܕܐܠܗܐ ܐܝܟ ܐܠܗܐ ܢܬܒ ܘܢܚܘܐ ܥܠ ܢܦܫܗ ܐܝܟ ܕܐܠܗܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.5",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "2 Thessalonians 2:5",
      "text": "ܠܐ ܥܗܕܝܬܘܢ ܕܟܕ ܠܘܬܟܘܢ ܗܘܝܬ ܗܠܝܢ ܐܡܪܬ ܗܘܝܬ ܠܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.6",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "2 Thessalonians 2:6",
      "text": "ܘܗܫܐ ܝܕܥܝܢ ܐܢܬܘܢ ܡܐ ܕܐܚܝܕ ܕܢܬܓܠܐ ܗܘ ܒܙܒܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.7",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "2 Thessalonians 2:7",
      "text": "ܐܪܙܐ ܓܝܪ ܕܥܘܠܐ ܡܢ ܟܕܘ ܫܪܝ ܠܡܬܚܦܛܘ ܒܠܚܘܕ ܐܢ ܗܘ ܡܐ ܕܗܫܐ ܐܚܝܕ ܢܫܬܩܠ ܡܢ ܡܨܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.8",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "2 Thessalonians 2:8",
      "text": "ܘܗܝܕܝܢ ܢܬܓܠܐ ܥܘܠܐ ܗܘ ܕܡܪܢ ܝܫܘܥ ܢܤܝܦܝܘܗܝ ܒܪܘܚ ܦܘܡܗ ܘܢܒܛܠܝܘܗܝ ܒܓܠܝܢܐ ܕܡܐܬܝܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.9",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "2 Thessalonians 2:9",
      "text": "ܡܐܬܝܬܗ ܓܝܪ ܕܗܘ ܒܡܥܒܕܢܘܬܐ ܗܝ ܕܤܛܢܐ ܒܟܠ ܚܝܠ ܘܐܬܘܬܐ ܘܬܕܡܪܬܐ ܕܓܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.10",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "2 Thessalonians 2:10",
      "text": "ܘܒܟܠܗ ܛܘܥܝܝ ܕܥܘܠܐ ܕܗܘܝܐ ܒܐܒܝܕܐ ܥܠ ܕܠܐ ܩܒܠܘ ܚܘܒܐ ܕܩܘܫܬܐ ܕܒܗ ܢܚܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.11",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "2 Thessalonians 2:11",
      "text": "ܡܛܠܗܢܐ ܢܫܕܪ ܠܗܘܢ ܐܠܗܐ ܡܥܒܕܢܘܬܐ ܕܛܘܥܝܝ ܕܢܗܝܡܢܘܢ ܠܫܘܩܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.12",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "2 Thessalonians 2:12",
      "text": "ܘܢܬܕܝܢܘܢ ܟܠܗܘܢ ܐܝܠܝܢ ܕܠܐ ܗܝܡܢܘ ܒܩܘܫܬܐ ܐܠܐ ܐܨܛܒܝܘ ܒܥܘܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.13",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "2 Thessalonians 2:13",
      "text": "ܚܢܢ ܕܝܢ ܚܝܒܝܢܢ ܠܡܘܕܝܘ ܠܐܠܗܐ ܒܟܠܙܒܢ ܥܠ ܐܦܝܟܘܢ ܐܚܝܢ ܚܒܝܒܘܗܝ ܕܡܪܢ ܕܓܒܟܘܢ ܐܠܗܐ ܡܢ ܪܫܝܬܐ ܠܚܝܐ ܒܩܕܝܫܘܬܐ ܕܪܘܚܐ ܘܒܗܝܡܢܘܬܐ ܕܫܪܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.14",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "2 Thessalonians 2:14",
      "text": "ܠܗܠܝܢ ܗܘ ܓܝܪ ܩܪܟܘܢ ܒܡܤܒܪܢܘܬܐ ܕܝܠܢ ܕܬܗܘܘܢ ܬܫܒܘܚܬܐ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.15",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "2 Thessalonians 2:15",
      "text": "ܡܟܝܠ ܐܚܝ ܐܬܩܝܡܘ ܘܚܡܤܢܘ ܒܦܘܩܕܢܐ ܕܝܠܦܬܘܢ ܐܢ ܒܡܠܬܐ ܘܐܢ ܒܐܓܪܬܐ ܕܝܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.16",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "2 Thessalonians 2:16",
      "text": "ܗܘ ܕܝܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܐܠܗܐ ܐܒܘܢ ܗܘ ܕܐܚܒܢ ܘܝܗܒ ܠܢ ܒܘܝܐܐ ܕܠܥܠܡ ܘܤܒܪܐ ܛܒܐ ܒܛܝܒܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:second-thessalonians.2.17",
      "translationId": "peshitta",
      "bookSlug": "second-thessalonians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "2 Thessalonians 2:17",
      "text": "ܢܒܝܐ ܠܒܘܬܟܘܢ ܘܢܩܝܡ ܒܟܠ ܡܠܐ ܘܒܟܠ ܥܒܕ ܛܒ ܀",
      "paragraphStart": false
    }
  ]
}
