{
  "chapter": {
    "id": "peshitta:ephesians.5",
    "translationId": "peshitta",
    "bookSlug": "ephesians",
    "chapterNumber": 5,
    "referenceLabel": "Ephesians 5",
    "summary": "Source text for Ephesians 5 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:ephesians.5.1",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 5:1",
      "text": "ܗܘܝܬܘܢ ܗܟܝܠ ܡܬܕܡܝܢ ܒܐܠܗܐ ܐܝܟ ܒܢܝܐ ܚܒܝܒܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:ephesians.5.2",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 5:2",
      "text": "ܘܗܠܟܘ ܒܚܘܒܐ ܐܝܟ ܕܐܦ ܡܫܝܚܐ ܐܚܒܢ ܘܐܫܠܡ ܢܦܫܗ ܥܠ ܐܦܝܢ ܩܘܪܒܢܐ ܘܕܒܚܐ ܠܐܠܗܐ ܠܪܝܚܐ ܒܤܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.3",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 5:3",
      "text": "ܙܢܝܘܬܐ ܕܝܢ ܘܟܠܗ ܛܢܦܘܬܐ ܘܥܠܘܒܘܬܐ ܐܦܠܐ ܡܫܬܡܗܘ ܬܫܬܡܗ ܒܝܢܬܟܘܢ ܐܝܟ ܕܝܐܐ ܠܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.4",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 5:4",
      "text": "ܘܠܐ ܨܘܚܝܬܐ ܘܠܐ ܡܠܐ ܕܫܛܝܘܬܐ ܐܘ ܕܒܙܚܐ ܐܘ ܕܫܥܝܐ ܗܠܝܢ ܕܠܐ ܡܬܒܥܝܢ ܐܠܐ ܚܠܦ ܗܠܝܢ ܬܘܕܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.5",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 5:5",
      "text": "ܗܕܐ ܕܝܢ ܗܘܝܬܘܢ ܝܕܥܝܢ ܕܟܠܢܫ ܕܐܝܬܘܗܝ ܙܢܝܐ ܐܘ ܛܢܦܐ ܐܘ ܥܠܘܒܐ ܕܐܝܬܘܗܝ ܦܠܚ ܦܬܟܪܐ ܠܝܬ ܠܗ ܝܪܬܘܬܐ ܒܡܠܟܘܬܗ ܕܡܫܝܚܐ ܘܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.6",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 5:6",
      "text": "ܕܠܡܐ ܐܢܫ ܢܛܥܝܟܘܢ ܒܡܠܐ ܤܪܝܩܬܐ ܡܛܠ ܗܠܝܢ ܗܘ ܓܝܪ ܐܬܐ ܪܘܓܙܗ ܕܐܠܗܐ ܥܠ ܒܢܝܐ ܕܠܐ ܡܬܛܦܝܤܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.7",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 5:7",
      "text": "ܠܐ ܗܟܝܠ ܬܗܘܘܢ ܠܗܘܢ ܫܘܬܦܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.8",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 5:8",
      "text": "ܐܝܬܝܟܘܢ ܗܘܝܬܘܢ ܓܝܪ ܡܢ ܠܘܩܕܡ ܚܫܘܟܐ ܗܫܐ ܕܝܢ ܢܘܗܪܐ ܐܢܬܘܢ ܒܡܪܢ ܐܝܟ ܒܢܝ ܢܘܗܪܐ ܗܟܝܠ ܗܟܢܐ ܗܠܟܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.9",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 5:9",
      "text": "ܦܐܪܘܗܝ ܓܝܪ ܕܢܘܗܪܐ ܒܟܠܗ ܐܢܘܢ ܛܒܘܬܐ ܘܙܕܝܩܘܬܐ ܘܩܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.10",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 5:10",
      "text": "ܘܗܘܝܬܘܢ ܦܪܫܝܢ ܡܢܐ ܫܦܝܪ ܩܕܡ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.11",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 5:11",
      "text": "ܘܠܐ ܗܘܝܬܘܢ ܡܫܬܘܬܦܝܢ ܠܘܬ ܥܒܕܐ ܕܚܫܘܟܐ ܕܦܐܪܐ ܠܝܬ ܒܗܘܢ ܐܠܐ ܗܘܝܬܘܢ ܡܟܘܢܝܢ ܠܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.12",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 5:12",
      "text": "ܡܕܡ ܓܝܪ ܕܒܛܘܫܝܝ ܥܒܕܝܢ ܢܕܝܕ ܗܘ ܐܦ ܠܡܡܠܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.13",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 5:13",
      "text": "ܟܠ ܡܕܡ ܓܝܪ ܡܬܟܘܢ ܡܢ ܢܘܗܪܐ ܘܡܬܓܠܐ ܘܟܠܡܕܡ ܕܓܠܐ ܢܘܗܪܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.14",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 5:14",
      "text": "ܡܛܠ ܗܢܐ ܐܡܝܪ ܕܐܬܬܥܝܪ ܕܡܟܐ ܘܩܘܡ ܡܢ ܒܝܬ ܡܝܬܐ ܘܢܢܗܪ ܠܟ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.15",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 5:15",
      "text": "ܚܙܘ ܗܟܝܠ ܐܝܟܢܐ ܬܗܠܟܘܢ ܙܗܝܐܝܬ ܠܐ ܐܝܟ ܤܟܠܐ ܐܠܐ ܐܝܟ ܚܟܝܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.16",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 5:16",
      "text": "ܕܙܒܢܝܢ ܩܐܪܤܗܘܢ ܡܛܠ ܕܝܘܡܬܐ ܒܝܫܐ ܐܢܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.17",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 5:17",
      "text": "ܡܛܠ ܗܢܐ ܠܐ ܬܗܘܘܢ ܚܤܝܪܝ ܪܥܝܢܐ ܐܠܐ ܐܤܬܟܠܘ ܡܢܘ ܨܒܝܢܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.18",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 5:18",
      "text": "ܘܠܐ ܗܘܝܬܘܢ ܪܘܝܢ ܒܚܡܪܐ ܕܒܗ ܐܝܬ ܐܤܘܛܘܬܐ ܐܠܐ ܐܬܡܠܘ ܒܪܘܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.19",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 5:19",
      "text": "ܘܡܠܠܘ ܥܡ ܢܦܫܟܘܢ ܒܡܙܡܘܪܐ ܘܒܬܫܒܚܬܐ ܘܒܙܡܝܪܬܐ ܕܪܘܚܐ ܗܘܝܬܘܢ ܙܡܪܝܢ ܒܠܒܘܬܟܘܢ ܠܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.20",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 5:20",
      "text": "ܘܗܘܝܬܘܢ ܡܘܕܝܢ ܒܟܠܙܒܢ ܥܠ ܐܦܝ ܟܠܢܫ ܒܫܡܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܠܐܠܗܐ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.21",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 5:21",
      "text": "ܘܗܘܝܬܘܢ ܡܫܬܥܒܕܝܢ ܚܕ ܠܚܕ ܒܚܘܒܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.22",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 5:22",
      "text": "ܢܫܐ ܗܘܝܬܝܢ ܡܫܬܥܒܕܢ ܠܒܥܠܝܟܝܢ ܐܝܟ ܕܠܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.23",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 5:23",
      "text": "ܡܛܠ ܕܓܒܪܐ ܪܫܗ ܗܘ ܕܐܢܬܬܐ ܐܝܟܢܐ ܕܐܦ ܡܫܝܚܐ ܪܫܐ ܗܘ ܕܥܕܬܐ ܘܗܘܝܘ ܡܚܝܢܐ ܕܦܓܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.24",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 5:24",
      "text": "ܐܠܐ ܐܝܟܢܐ ܕܥܕܬܐ ܡܫܬܥܒܕܐ ܠܡܫܝܚܐ ܗܟܢܐ ܐܦ ܢܫܐ ܠܒܥܠܝܗܝܢ ܒܟܠܡܕܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.25",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 5:25",
      "text": "ܓܒܪܐ ܐܚܒܘ ܢܫܝܟܘܢ ܐܝܟ ܕܐܦ ܡܫܝܚܐ ܐܚܒ ܠܥܕܬܗ ܘܢܦܫܗ ܐܫܠܡ ܥܠ ܐܦܝܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.26",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 5:26",
      "text": "ܕܢܩܕܫܝܗ ܘܢܕܟܝܗ ܒܤܚܝܐ ܕܡܝܐ ܘܒܡܠܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.27",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 5:27",
      "text": "ܘܢܩܝܡܝܗ ܥܕܬܐ ܠܢܦܫܗ ܟܕ ܡܫܒܚܐ ܘܠܝܬ ܒܗ ܛܘܠܫܐ ܘܠܐ ܩܡܛܐ ܘܠܐ ܡܕܡ ܕܠܗܠܝܢ ܕܡܐ ܐܠܐ ܬܗܘܐ ܩܕܝܫܐ ܕܠܐ ܡܘܡ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.28",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 5:28",
      "text": "ܗܟܢܐ ܘܠܐ ܠܓܒܪܐ ܕܢܚܒܘܢ ܢܫܝܗܘܢ ܐܝܟ ܕܠܦܓܪܝܗܘܢ ܡܢ ܕܠܐܢܬܬܗ ܓܝܪ ܡܚܒ ܢܦܫܗ ܗܘ ܡܚܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.29",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 5:29",
      "text": "ܠܐ ܓܝܪ ܐܢܫ ܡܡܬܘܡ ܤܢܐ ܦܓܪܗ ܐܠܐ ܡܬܪܤܐ ܠܗ ܘܝܨܦ ܕܝܠܗ ܐܝܟܢܐ ܕܐܦ ܡܫܝܚܐ ܕܥܕܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.30",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 5:30",
      "text": "ܡܛܠ ܕܗܕܡܐ ܚܢܢ ܕܦܓܪܗ ܘܡܢ ܒܤܪܗ ܚܢܢ ܘܡܢ ܓܪܡܘܗܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.31",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 5:31",
      "text": "ܡܛܠ ܗܢܐ ܢܫܒܘܩ ܓܒܪܐ ܠܐܒܘܗܝ ܘܠܐܡܗ ܘܢܩܦ ܠܐܢܬܬܗ ܘܢܗܘܘܢ ܬܪܝܗܘܢ ܚܕ ܒܤܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.32",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 5:32",
      "text": "ܗܢܐ ܐܪܙܐ ܪܒ ܗܘ ܐܢܐ ܕܝܢ ܐܡܪ ܐܢܐ ܥܠ ܡܫܝܚܐ ܘܥܠ ܥܕܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.5.33",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 5,
      "verseNumber": 33,
      "referenceLabel": "Ephesians 5:33",
      "text": "ܒܪܡ ܐܦ ܐܢܬܘܢ ܟܠ ܚܕ ܚܕ ܡܢܟܘܢ ܗܟܢܐ ܢܪܚܡ ܐܢܬܬܗ ܐܝܟ ܕܠܢܦܫܗ ܐܢܬܬܐ ܕܝܢ ܬܗܘܐ ܕܚܠܐ ܡܢ ܒܥܠܗ ܀",
      "paragraphStart": false
    }
  ]
}
