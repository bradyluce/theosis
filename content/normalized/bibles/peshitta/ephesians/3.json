{
  "chapter": {
    "id": "peshitta:ephesians.3",
    "translationId": "peshitta",
    "bookSlug": "ephesians",
    "chapterNumber": 3,
    "referenceLabel": "Ephesians 3",
    "summary": "Source text for Ephesians 3 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:ephesians.3.1",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 3:1",
      "text": "ܡܛܠ ܗܢܐ ܐܢܐ ܦܘܠܘܤ ܐܤܝܪܐ ܐܢܐ ܕܝܫܘܥ ܡܫܝܚܐ ܥܠ ܐܦܝܟܘܢ ܥܡܡܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:ephesians.3.2",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 3:2",
      "text": "ܐܢ ܫܡܥܬܘܢ ܡܕܒܪܢܘܬܐ ܕܛܝܒܘܬܗ ܕܐܠܗܐ ܕܐܬܝܗܒܬ ܠܝ ܒܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.3",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 3:3",
      "text": "ܕܒܓܠܝܢܐ ܐܬܝܕܥ ܠܝ ܐܪܙܐ ܐܝܟܢܐ ܕܟܬܒܬ ܠܟܘܢ ܒܙܥܘܪܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.4",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 3:4",
      "text": "ܐܝܟ ܡܐ ܕܡܫܟܚܝܬܘܢ ܟܕ ܩܪܝܢ ܐܢܬܘܢ ܠܡܤܬܟܠܘ ܝܕܥܬܝ ܕܒܐܪܙܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.5",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 3:5",
      "text": "ܗܘ ܕܒܕܪܐ ܐܚܪܢܐ ܠܐ ܐܬܝܕܥ ܠܒܢܝܢܫܐ ܐܝܟ ܕܗܫܐ ܐܬܓܠܝ ܠܫܠܝܚܘܗܝ ܩܕܝܫܐ ܘܠܢܒܝܘܗܝ ܒܪܘܚ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.6",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 3:6",
      "text": "ܕܢܗܘܘܢ ܥܡܡܐ ܒܢܝ ܝܪܬܘܬܗ ܘܫܘܬܦܐ ܕܦܓܪܗ ܘܕܡܘܠܟܢܐ ܕܐܬܝܗܒ ܒܗ ܒܝܕ ܐܘܢܓܠܝܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.7",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 3:7",
      "text": "ܗܘ ܕܐܢܐ ܗܘܝܬ ܡܫܡܫܢܗ ܐܝܟ ܡܘܗܒܬܐ ܕܛܝܒܘܬܗ ܕܐܠܗܐ ܕܐܬܝܗܒܬ ܠܝ ܡܢ ܡܥܒܕܢܘܬܐ ܕܚܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.8",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 3:8",
      "text": "ܠܝ ܕܙܥܘܪܐ ܐܢܐ ܕܟܠܗܘܢ ܩܕܝܫܐ ܐܬܝܗܒܬ ܛܝܒܘܬܐ ܗܕܐ ܕܐܤܒܪ ܒܥܡܡܐ ܥܘܬܪܗ ܕܡܫܝܚܐ ܗܘ ܕܠܐ ܡܬܥܩܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.9",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 3:9",
      "text": "ܘܐܢܗܪ ܠܟܠܢܫ ܐܝܕܐ ܗܝ ܡܕܒܪܢܘܬܐ ܕܐܪܙܐ ܗܘ ܕܟܤܐ ܗܘܐ ܡܢ ܥܠܡܐ ܒܐܠܗܐ ܕܟܠ ܒܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.10",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 3:10",
      "text": "ܕܒܝܕ ܥܕܬܐ ܬܬܝܕܥ ܚܟܡܬܗ ܕܐܠܗܐ ܡܠܝܬ ܦܘܪܫܢܐ ܠܐܪܟܘܤ ܘܠܫܘܠܛܢܐ ܕܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.11",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 3:11",
      "text": "ܗܝ ܕܥܬܕ ܗܘܐ ܡܢ ܥܠܡܐ ܘܥܒܕܗ ܒܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.12",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 3:12",
      "text": "ܗܘ ܕܒܗ ܐܝܬ ܠܢ ܦܪܗܤܝܐ ܘܩܪܝܒܘܬܐ ܒܬܘܟܠܢܐ ܕܗܝܡܢܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.13",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 3:13",
      "text": "ܡܛܠ ܗܢܐ ܫܐܠܢܐ ܕܠܐ ܬܡܐܢ ܠܝ ܒܐܘܠܨܢܝ ܕܥܠ ܐܦܝܟܘܢ ܕܗܕܐ ܗܝ ܬܫܒܘܚܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.14",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 3:14",
      "text": "ܘܟܐܦܢܐ ܒܘܪܟܝ ܠܘܬ ܐܒܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.15",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 3:15",
      "text": "ܗܘ ܕܡܢܗ ܡܫܬܡܗܐ ܟܠ ܐܒܗܘܬܐ ܕܒܫܡܝܐ ܘܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.16",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 3:16",
      "text": "ܕܢܬܠ ܠܟܘܢ ܐܝܟ ܥܘܬܪܐ ܕܬܫܒܘܚܬܗ ܕܒܚܝܠܐ ܬܫܬܪܪܘܢ ܒܪܘܚܗ ܕܒܒܪܢܫܟܘܢ ܕܠܓܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.17",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 3:17",
      "text": "ܢܥܡܪ ܡܫܝܚܐ ܒܗܝܡܢܘܬܐ ܘܒܠܒܘܬܟܘܢ ܒܚܘܒܐ ܟܕ ܢܗܘܐ ܫܪܝܪ ܥܩܪܟܘܢ ܘܫܬܐܤܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.18",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 3:18",
      "text": "ܕܬܫܟܚܘܢ ܠܡܕܪܟܘ ܥܡ ܟܠܗܘܢ ܩܕܝܫܐ ܡܢܘ ܪܘܡܐ ܘܥܘܡܩܐ ܘܐܘܪܟܐ ܘܦܬܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.19",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 3:19",
      "text": "ܘܬܕܥܘܢ ܪܒܘܬܐ ܕܝܕܥܬܐ ܕܚܘܒܗ ܕܡܫܝܚܐ ܘܬܬܡܠܘܢ ܒܟܠܗ ܡܘܠܝܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.20",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 3:20",
      "text": "ܠܗܘ ܕܝܢ ܕܡܨܐ ܒܚܝܠܐ ܝܬܝܪ ܡܢ ܟܠ ܠܡܥܒܕ ܠܢ ܘܝܬܝܪ ܡܢ ܡܐ ܕܫܐܠܝܢܢ ܘܪܢܝܢܢ ܐܝܟ ܚܝܠܗ ܕܡܤܬܥܪ ܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.3.21",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 3,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 3:21",
      "text": "ܠܗ ܬܫܒܘܚܬܐ ܒܥܕܬܗ ܒܝܫܘܥ ܡܫܝܚܐ ܒܟܠܗܘܢ ܕܪܐ ܕܥܠܡܝ ܥܠܡܝܢ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
