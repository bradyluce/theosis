{
  "chapter": {
    "id": "peshitta:ephesians.4",
    "translationId": "peshitta",
    "bookSlug": "ephesians",
    "chapterNumber": 4,
    "referenceLabel": "Ephesians 4",
    "summary": "Source text for Ephesians 4 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:ephesians.4.1",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 4:1",
      "text": "ܒܥܐ ܐܢܐ ܗܟܝܠ ܡܢܟܘܢ ܐܢܐ ܐܤܝܪܐ ܒܡܪܢ ܕܬܗܠܟܘܢ ܐܝܟܢܐ ܕܝܐܐ ܠܩܪܝܢܐ ܕܐܬܩܪܝܬܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:ephesians.4.2",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 4:2",
      "text": "ܒܟܠܗ ܡܟܝܟܘܬ ܪܥܝܢܐ ܘܢܝܚܘܬܐ ܘܢܓܝܪܘܬ ܪܘܚܐ ܘܗܘܝܬܘܢ ܡܤܝܒܪܝܢ ܚܕ ܠܚܕ ܒܚܘܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.3",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 4:3",
      "text": "ܘܗܘܝܬܘܢ ܚܦܝܛܝܢ ܠܡܛܪ ܐܘܝܘܬܐ ܕܪܘܚܐ ܒܚܙܩܐ ܕܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.4",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 4:4",
      "text": "ܕܬܗܘܘܢ ܒܚܕ ܦܓܪܐ ܘܒܚܕܐ ܪܘܚܐ ܐܝܟ ܡܐ ܕܐܬܩܪܝܬܘܢ ܒܚܕ ܤܒܪܐ ܕܩܪܝܢܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.5",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 4:5",
      "text": "ܚܕ ܗܘ ܓܝܪ ܡܪܝܐ ܘܚܕܐ ܗܝܡܢܘܬܐ ܘܚܕܐ ܡܥܡܘܕܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.6",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 4:6",
      "text": "ܘܚܕ ܐܠܗܐ ܐܒܐ ܕܟܠ ܘܥܠ ܟܠ ܘܒܝܕ ܟܠ ܘܒܟܠܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.7",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 4:7",
      "text": "ܠܚܕ ܚܕ ܡܢܢ ܕܝܢ ܐܬܝܗܒܬ ܛܝܒܘܬܐ ܐܝܟ ܡܫܘܚܬܐ ܕܡܘܗܒܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.8",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 4:8",
      "text": "ܡܛܠ ܗܢܐ ܐܡܝܪ ܕܤܠܩ ܠܡܪܘܡܐ ܘܫܒܐ ܫܒܝܬܐ ܘܝܗܒ ܡܘܗܒܬܐ ܠܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.9",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 4:9",
      "text": "ܕܤܠܩ ܕܝܢ ܡܢܐ ܗܝ ܐܠܐ ܐܢ ܕܐܦ ܢܚܬ ܠܘܩܕܡ ܠܬܚܬܝܬܗ ܕܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.10",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 4:10",
      "text": "ܗܘ ܕܢܚܬ ܗܘܝܘ ܗܘ ܕܐܦ ܤܠܩ ܠܥܠ ܡܢ ܟܠܗܘܢ ܫܡܝܐ ܕܢܫܠܡ ܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.11",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 4:11",
      "text": "ܘܗܘ ܝܗܒ ܐܝܬ ܕܫܠܝܚܐ ܘܐܝܬ ܕܢܒܝܐ ܘܐܝܬ ܕܡܤܒܪܢܐ ܘܐܝܬ ܕܪܥܘܬܐ ܘܐܝܬ ܕܡܠܦܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.12",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 4:12",
      "text": "ܠܓܡܪܐ ܕܩܕܝܫܐ ܠܥܒܕܐ ܕܬܫܡܫܬܐ ܠܒܢܝܢܐ ܕܦܓܪܐ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.13",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 4:13",
      "text": "ܥܕܡܐ ܕܟܠܢ ܢܗܘܐ ܚܕ ܡܕܡ ܒܗܝܡܢܘܬܐ ܘܒܝܕܥܬܐ ܕܒܪܗ ܕܐܠܗܐ ܘܚܕ ܓܒܪܐ ܓܡܝܪܐ ܒܡܫܘܚܬܐ ܕܩܘܡܬܐ ܕܫܘܡܠܝܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.14",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 4:14",
      "text": "ܘܠܐ ܢܗܘܐ ܝܠܘܕܐ ܕܡܙܕܥܙܥܝܢ ܘܡܫܬܢܝܢ ܠܟܠ ܪܘܚ ܕܝܘܠܦܢܐ ܢܟܝܠܐ ܕܒܢܝܢܫܐ ܗܢܘܢ ܕܒܚܪܥܘܬܗܘܢ ܡܨܛܢܥܝܢ ܕܢܛܥܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.15",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 4:15",
      "text": "ܐܠܐ ܗܘܝܢ ܫܪܝܪܝܢ ܒܚܘܒܢ ܕܟܘܠ ܡܕܡ ܕܝܠܢ ܢܪܒܐ ܒܡܫܝܚܐ ܕܗܘܝܘ ܪܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.16",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 4:16",
      "text": "ܘܡܢܗ ܟܠܗ ܦܓܪܐ ܡܬܪܟܒ ܘܡܬܩܛܪ ܒܟܠ ܫܪܝܢ ܐܝܟ ܡܘܗܒܬܐ ܕܡܬܝܗܒܐ ܒܡܫܘܚܬܐ ܠܟܠ ܗܕܡ ܠܬܪܒܝܬܐ ܕܝܠܗ ܕܦܓܪܐ ܕܒܚܘܒܐ ܢܫܬܠܡ ܒܢܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.17",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 4:17",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܐܢܐ ܘܡܤܗܕ ܐܢܐ ܒܡܪܝܐ ܕܡܢ ܗܫܐ ܠܐ ܬܗܘܘܢ ܡܗܠܟܝܢ ܐܝܟ ܫܪܟܐ ܕܥܡܡܐ ܕܡܗܠܟܝܢ ܒܤܪܝܩܘܬ ܪܥܝܢܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.18",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 4:18",
      "text": "ܘܚܫܘܟܝܢ ܒܡܕܥܝܗܘܢ ܘܢܘܟܪܝܝܢ ܐܢܘܢ ܡܢ ܚܝܘܗܝ ܕܐܠܗܐ ܡܛܠ ܕܠܝܬ ܒܗܘܢ ܝܕܥܬܐ ܘܡܛܠ ܥܘܝܪܘܬ ܠܒܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.19",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 4:19",
      "text": "ܗܢܘܢ ܕܦܤܩܘ ܤܒܪܗܘܢ ܘܐܫܠܡܘ ܢܦܫܗܘܢ ܠܦܚܙܘܬܐ ܘܠܦܘܠܚܢܐ ܕܟܠܗ ܛܢܦܘܬܐ ܒܝܥܢܘܬܗܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.20",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 4:20",
      "text": "ܐܢܬܘܢ ܕܝܢ ܠܐ ܗܘܐ ܗܟܢܐ ܝܠܦܬܘܢܝܗܝ ܠܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.21",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 4:21",
      "text": "ܐܢ ܫܪܝܪܐܝܬ ܫܡܥܬܘܢܝܗܝ ܘܒܗ ܝܠܦܬܘܢ ܐܝܟ ܡܐ ܕܐܝܬܘܗܝ ܩܘܫܬܐ ܒܝܫܘܥ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.22",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 4:22",
      "text": "ܐܠܐ ܕܬܢܝܚܘܢ ܡܢܟܘܢ ܗܘܦܟܝܟܘܢ ܩܕܡܝܐ ܠܒܪܢܫܐ ܗܘ ܥܬܝܩܐ ܕܡܬܚܒܠ ܒܪܓܝܓܬܐ ܕܛܘܥܝܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.23",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 4:23",
      "text": "ܘܬܬܚܕܬܘܢ ܒܪܘܚܐ ܕܡܕܥܝܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.24",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 4:24",
      "text": "ܘܬܠܒܫܘܢ ܠܒܪܢܫܐ ܚܕܬܐ ܗܘ ܕܒܐܠܗܐ ܐܬܒܪܝ ܒܙܕܝܩܘܬܐ ܘܒܚܤܝܘܬܐ ܕܩܘܫܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.25",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 25,
      "referenceLabel": "Ephesians 4:25",
      "text": "ܡܛܠ ܗܢܐ ܐܢܝܚܘ ܡܢܟܘܢ ܟܕܒܘܬܐ ܘܡܠܠܘ ܩܘܫܬܐ ܐܢܫ ܥܡ ܩܪܝܒܗ ܗܕܡܐ ܚܢܢ ܓܝܪ ܚܕ ܕܚܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.26",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 26,
      "referenceLabel": "Ephesians 4:26",
      "text": "ܪܓܙܘ ܘܠܐ ܬܚܛܘܢ ܘܫܡܫܐ ܥܠ ܪܘܓܙܟܘܢ ܠܐ ܢܥܪܒ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.27",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 27,
      "referenceLabel": "Ephesians 4:27",
      "text": "ܘܠܐ ܬܬܠܘܢ ܐܬܪܐ ܠܐܟܠ ܩܪܨܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.28",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 28,
      "referenceLabel": "Ephesians 4:28",
      "text": "ܘܐܝܢܐ ܕܓܢܒ ܗܘܐ ܡܟܝܠ ܠܐ ܢܓܢܘܒ ܐܠܐ ܢܠܐܐ ܒܐܝܕܘܗܝ ܘܢܦܠܘܚ ܛܒܬܐ ܕܢܗܘܐ ܠܗ ܠܡܬܠ ܠܡܢ ܕܤܢܝܩ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.29",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 29,
      "referenceLabel": "Ephesians 4:29",
      "text": "ܟܠ ܡܠܐ ܤܢܝܐ ܡܢ ܦܘܡܟܘܢ ܠܐ ܬܦܘܩ ܐܠܐ ܐܝܕܐ ܕܫܦܝܪܐ ܘܚܫܚܐ ܠܒܢܝܢܐ ܕܬܬܠ ܛܝܒܘܬܐ ܠܐܝܠܝܢ ܕܫܡܥܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.30",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 30,
      "referenceLabel": "Ephesians 4:30",
      "text": "ܘܠܐ ܬܗܘܘܢ ܡܥܝܩܝܢ ܠܪܘܚܐ ܩܕܝܫܬܐ ܕܐܠܗܐ ܕܐܬܚܬܡܬܘܢ ܒܗ ܠܝܘܡܐ ܕܦܘܪܩܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.31",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 31,
      "referenceLabel": "Ephesians 4:31",
      "text": "ܟܠܗ ܡܪܝܪܘܬܐ ܘܚܡܬܐ ܘܪܘܓܙܐ ܘܪܘܒܐ ܘܓܘܕܦܐ ܢܫܬܩܠܢ ܡܢܟܘܢ ܥܡ ܟܠܗ ܒܝܫܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.4.32",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 4,
      "verseNumber": 32,
      "referenceLabel": "Ephesians 4:32",
      "text": "ܘܗܘܝܬܘܢ ܒܤܝܡܝܢ ܚܕ ܠܘܬ ܚܕ ܘܡܪܚܡܢܝܢ ܘܗܘܝܬܘܢ ܫܒܩܝܢ ܚܕ ܠܚܕ ܐܝܟܢܐ ܕܐܠܗܐ ܒܡܫܝܚܐ ܫܒܩ ܠܢ ܀",
      "paragraphStart": false
    }
  ]
}
