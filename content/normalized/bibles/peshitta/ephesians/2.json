{
  "chapter": {
    "id": "peshitta:ephesians.2",
    "translationId": "peshitta",
    "bookSlug": "ephesians",
    "chapterNumber": 2,
    "referenceLabel": "Ephesians 2",
    "summary": "Source text for Ephesians 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:ephesians.2.1",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 2:1",
      "text": "ܘܐܦ ܠܟܘܢ ܕܡܝܬܝܢ ܗܘܝܬܘܢ ܒܚܛܗܝܟܘܢ ܘܒܤܟܠܘܬܟܘܢ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:ephesians.2.2",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 2:2",
      "text": "ܒܗܠܝܢ ܕܡܢ ܩܕܝܡ ܗܠܟܬܘܢ ܗܘܝܬܘܢ ܒܗܝܢ ܐܝܟ ܥܠܡܝܘܬܗ ܕܥܠܡܐ ܗܢܐ ܘܐܝܟ ܨܒܝܢܗ ܕܪܝܫ ܫܘܠܛܢܐ ܕܐܐܪ ܘܕܪܘܚܐ ܗܕܐ ܕܡܬܚܦܛܐ ܒܒܢܝܐ ܕܠܐ ܡܬܛܦܝܤܢܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.3",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 2:3",
      "text": "ܒܗܢܘܢ ܥܒܕܐ ܕܐܦ ܚܢܢ ܐܬܗܦܟܢ ܒܗܘܢ ܡܢ ܩܕܝܡ ܒܪܓܝܓܬܐ ܕܒܤܪܢ ܘܥܒܕܝܢ ܗܘܝܢ ܨܒܝܢܐ ܕܒܤܪܢ ܘܕܬܪܥܝܬܢ ܘܒܢܝܐ ܗܘܝܢ ܕܪܘܓܙܐ ܡܠܝܐܝܬ ܐܝܟ ܫܪܟܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.4",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 2:4",
      "text": "ܐܠܗܐ ܕܝܢ ܕܥܬܝܪ ܒܪܚܡܘܗܝ ܡܛܠ ܚܘܒܗ ܤܓܝܐܐ ܕܐܚܒܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.5",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 2:5",
      "text": "ܟܕ ܡܝܬܝܢ ܗܘܝܢ ܒܚܛܗܝܢ ܐܚܝܢ ܥܡ ܡܫܝܚܐ ܘܒܛܝܒܘܬܗ ܦܪܩܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.6",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 2:6",
      "text": "ܘܐܩܝܡܢ ܥܡܗ ܘܐܘܬܒܢ ܥܡܗ ܒܫܡܝܐ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.7",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 2:7",
      "text": "ܕܢܚܘܐ ܠܥܠܡܐ ܕܐܬܝܢ ܪܒܘܬܐ ܕܥܘܬܪܐ ܕܛܝܒܘܬܗ ܘܒܤܝܡܘܬܗ ܕܗܘܬ ܥܠܝܢ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.8",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 2:8",
      "text": "ܒܛܝܒܘܬܗ ܗܘ ܓܝܪ ܐܬܦܪܩܢ ܒܗܝܡܢܘܬܐ ܘܗܕܐ ܠܐ ܗܘܬ ܡܢܟܘܢ ܐܠܐ ܡܘܗܒܬܐ ܗܝ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.9",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 2:9",
      "text": "ܠܐ ܡܢ ܥܒܕܐ ܕܠܐ ܐܢܫ ܢܫܬܒܗܪ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.10",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 2:10",
      "text": "ܒܪܝܬܐ ܚܢܢ ܓܝܪ ܕܝܠܗ ܕܐܬܒܪܝܢ ܒܝܫܘܥ ܡܫܝܚܐ ܠܥܒܕܐ ܛܒܐ ܗܢܘܢ ܕܡܢ ܩܕܝܡ ܛܝܒ ܐܠܗܐ ܕܒܗܘܢ ܢܗܠܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.11",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 2:11",
      "text": "ܡܛܠ ܗܕܐ ܗܘܝܬܘܢ ܥܗܕܝܢ ܕܐܢܬܘܢ ܥܡܡܐ ܡܢ ܩܕܝܡ ܕܒܤܪ ܗܘܝܬܘܢ ܘܡܬܩܪܝܢ ܗܘܝܬܘܢ ܥܘܪܠܘܬܐ ܡܢ ܗܝ ܕܡܬܩܪܝܐ ܓܙܘܪܬܐ ܘܐܝܬܝܗ ܥܒܕ ܐܝܕܝܐ ܒܒܤܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.12",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 2:12",
      "text": "ܘܐܝܬܝܟܘܢ ܗܘܝܬܘܢ ܒܗܘ ܙܒܢܐ ܕܠܐ ܡܫܝܚܐ ܘܢܘܟܪܝܝܢ ܗܘܝܬܘܢ ܡܢ ܕܘܒܪܐ ܕܐܝܤܪܝܠ ܘܐܟܤܢܝܐ ܗܘ ܠܕܝܬܩܐ ܕܡܘܠܟܢܐ ܘܕܠܐ ܤܒܪ ܗܘܝܬܘܢ ܘܕܠܐ ܐܠܗ ܒܥܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.13",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 2:13",
      "text": "ܗܫܐ ܕܝܢ ܒܝܫܘܥ ܡܫܝܚܐ ܐܢܬܘܢ ܕܡܢ ܩܕܝܡ ܪܚܝܩܝܢ ܗܘܝܬܘܢ ܩܪܝܒܐ ܗܘܝܬܘܢ ܒܕܡܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.14",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 2:14",
      "text": "ܗܘܝܘ ܓܝܪ ܫܝܢܢ ܗܘ ܕܥܒܕ ܬܪܬܝܗܝܢ ܚܕܐ ܘܫܪܐ ܤܝܓܐ ܕܩܐܡ ܗܘܐ ܒܡܨܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.15",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 2:15",
      "text": "ܘܒܥܠܕܒܒܘܬܐ ܒܒܤܪܗ ܘܢܡܘܤܐ ܕܦܘܩܕܐ ܒܦܘܩܕܢܘܗܝ ܒܛܠ ܕܠܬܪܝܗܘܢ ܢܒܪܐ ܒܩܢܘܡܗ ܠܚܕ ܒܪܢܫܐ ܚܕܬܐ ܘܥܒܕ ܫܝܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.16",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 2:16",
      "text": "ܘܪܥܝ ܠܬܪܝܗܘܢ ܒܚܕ ܦܓܪ ܥܡ ܐܠܗܐ ܘܒܙܩܝܦܗ ܩܛܠ ܒܥܠܕܒܒܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.17",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 2:17",
      "text": "ܘܐܬܐ ܤܒܪ ܫܠܡܐ ܠܟܘܢ ܠܪܚܝܩܐ ܘܠܩܪܝܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.18",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 2:18",
      "text": "ܡܛܠ ܕܒܗ ܗܘ ܗܘܐ ܠܢ ܩܘܪܒܐ ܠܬܪܝܢ ܒܚܕܐ ܪܘܚ ܠܘܬ ܐܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.19",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 2:19",
      "text": "ܡܟܝܠ ܠܐ ܗܘܝܬܘܢ ܐܟܤܢܝܐ ܘܠܐ ܬܘܬܒܐ ܐܠܐ ܒܢܝ ܡܕܝܢܬܐ ܕܩܕܝܫܐ ܘܒܢܝ ܒܝܬܗ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.20",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 2:20",
      "text": "ܘܐܬܒܢܝܬܘܢ ܥܠ ܫܬܐܤܬܐ ܕܫܠܝܚܐ ܘܕܢܒܝܐ ܘܗܘ ܗܘܐ ܪܝܫ ܩܪܢܐ ܕܒܢܝܢܐ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.21",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 2:21",
      "text": "ܘܒܗ ܡܬܪܟܒ ܟܠܗ ܒܢܝܢܐ ܘܪܒܐ ܠܗܝܟܠܐ ܩܕܝܫܐ ܒܡܪܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.2.22",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 2:22",
      "text": "ܟܕ ܐܦ ܐܢܬܘܢ ܒܗ ܡܬܒܢܝܢ ܐܢܬܘܢ ܠܡܥܡܪܐ ܕܐܠܗܐ ܒܪܘܚ ܀",
      "paragraphStart": false
    }
  ]
}
