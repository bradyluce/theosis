{
  "chapter": {
    "id": "peshitta:ephesians.6",
    "translationId": "peshitta",
    "bookSlug": "ephesians",
    "chapterNumber": 6,
    "referenceLabel": "Ephesians 6",
    "summary": "Source text for Ephesians 6 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:ephesians.6.1",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 6:1",
      "text": "ܒܢܝܐ ܐܫܬܡܥܘ ܠܐܒܗܝܟܘܢ ܒܡܪܢ ܗܕܐ ܓܝܪ ܟܐܢܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:ephesians.6.2",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 6:2",
      "text": "ܘܗܢܘ ܦܘܩܕܢܐ ܩܕܡܝܐ ܕܡܠܝܟ ܝܩܪ ܠܐܒܘܟ ܘܠܐܡܟ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.3",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 6:3",
      "text": "ܕܢܗܘܐ ܠܟ ܕܫܦܝܪ ܘܢܐܪܟܘܢ ܚܝܝܟ ܥܠ ܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.4",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 6:4",
      "text": "ܐܒܗܐ ܠܐ ܬܪܓܙܘܢ ܒܢܝܟܘܢ ܐܠܐ ܪܒܘ ܐܢܘܢ ܒܡܪܕܘܬܐ ܘܒܝܘܠܦܢܐ ܕܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.5",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 6:5",
      "text": "ܥܒܕܐ ܐܫܬܡܥܘ ܠܡܪܝܟܘܢ ܕܒܒܤܪ ܒܕܚܠܬܐ ܘܒܪܬܝܬܐ ܘܒܦܫܝܛܘܬ ܠܒܐ ܐܝܟ ܕܠܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.6",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 6:6",
      "text": "ܠܐ ܒܡܚܙܐ ܥܝܢܐ ܐܝܟ ܗܘ ܕܠܒܢܝܢܫܐ ܫܦܪܝܢ ܐܢܬܘܢ ܐܠܐ ܐܝܟ ܥܒܕܐ ܕܡܫܝܚܐ ܕܥܒܕܝܢ ܨܒܝܢܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.7",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 6:7",
      "text": "ܘܫܡܫܘ ܐܢܘܢ ܡܢ ܟܠܗ ܢܦܫܟܘܢ ܒܚܘܒܐ ܐܝܟ ܕܠܡܪܢ ܘܠܐ ܐܝܟ ܕܠܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.8",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 6:8",
      "text": "ܟܕ ܝܕܥܝܬܘܢ ܕܗܘ ܡܕܡ ܕܥܒܕ ܐܢܫ ܕܫܦܝܪ ܗܘ ܡܬܦܪܥ ܡܢ ܡܪܢ ܐܢ ܥܒܕܐ ܗܘ ܘܐܢ ܒܪ ܚܐܪܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.9",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 6:9",
      "text": "ܐܦ ܐܢܬܘܢ ܡܪܝܐ ܗܟܢܐ ܗܘܝܬܘܢ ܥܒܕܝܢ ܠܥܒܕܝܟܘܢ ܗܘܝܬܘܢ ܫܒܩܝܢ ܠܗܘܢ ܤܟܠܘܬܐ ܡܛܠ ܕܝܕܥܝܢ ܐܢܬܘܢ ܕܐܦ ܡܪܟܘܢ ܕܝܠܟܘܢ ܐܝܬܘܗܝ ܒܫܡܝܐ ܘܡܤܒ ܒܐܦܐ ܠܝܬ ܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.10",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 6:10",
      "text": "ܡܟܝܠ ܐܚܝ ܐܬܚܝܠܘ ܒܡܪܢ ܘܒܬܘܩܦܐ ܕܚܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.11",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 6:11",
      "text": "ܘܠܒܫܘ ܟܠܗ ܙܝܢܐ ܕܐܠܗܐ ܐܝܟܢܐ ܕܬܫܟܚܘܢ ܠܡܩܡ ܠܘܩܒܠ ܨܢܥܬܗ ܕܐܟܠ ܩܪܨܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.12",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 6:12",
      "text": "ܡܛܠ ܕܬܟܬܘܫܟܘܢ ܠܐ ܗܘܐ ܥܡ ܒܤܪܐ ܘܕܡܐ ܐܠܐ ܥܡ ܐܪܟܘܤ ܘܥܡ ܫܠܝܛܢܐ ܘܥܡ ܐܚܝܕܝ ܥܠܡܐ ܕܗܢܐ ܚܫܘܟܐ ܘܥܡ ܪܘܚܐ ܒܝܫܬܐ ܕܬܚܝܬ ܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.13",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 6:13",
      "text": "ܡܛܠ ܗܢܐ ܠܒܫܘ ܟܠܗ ܙܝܢܐ ܕܐܠܗܐ ܕܬܫܟܚܘܢ ܬܐܪܥܘܢ ܒܝܫܐ ܘܟܕ ܡܥܬܕܝܢ ܐܢܬܘܢ ܒܟܠܡܕܡ ܬܩܘܡܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.14",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 6:14",
      "text": "ܩܘܡܘ ܗܟܝܠ ܘܚܙܘܩܘ ܚܨܝܟܘܢ ܒܩܘܫܬܐ ܘܠܒܫܘ ܫܪܝܢܐ ܕܙܕܝܩܘܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.15",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 6:15",
      "text": "ܘܤܐܢܘ ܒܪܓܠܝܟܘܢ ܛܘܝܒܗ ܕܐܘܢܓܠܝܘܢ ܕܫܠܡܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.16",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 6:16",
      "text": "ܘܥܡ ܗܠܝܢ ܤܒܘ ܠܟܘܢ ܤܟܪܐ ܕܗܝܡܢܘܬܐ ܕܒܗ ܬܬܡܨܘܢ ܚܝܠܐ ܠܡܕܥܟܘ ܟܠܗܘܢ ܓܐܪܘܗܝ ܝܩܕܐ ܕܒܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.17",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 6:17",
      "text": "ܘܤܝܡܘ ܤܢܘܪܬܐ ܕܦܘܪܩܢܐ ܘܐܚܘܕܘ ܤܝܦܐ ܕܪܘܚܐ ܕܐܝܬܘܗܝ ܡܠܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.18",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 6:18",
      "text": "ܘܒܟܠ ܨܠܘܢ ܘܒܟܠ ܒܥܘܢ ܨܠܘ ܒܟܠܙܒܢ ܒܪܘܚ ܘܒܗ ܒܨܠܘܬܐ ܗܘܝܬܘܢ ܫܗܪܝܢ ܒܟܠܥܕܢ ܟܕ ܡܨܠܝܬܘܢ ܐܡܝܢܐܝܬ ܘܡܬܟܫܦܝܢ ܥܠ ܐܦܝ ܟܠܗܘܢ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.19",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 6:19",
      "text": "ܐܦ ܥܠܝ ܕܬܬܝܗܒ ܠܝ ܡܠܬܐ ܒܡܦܬܚ ܦܘܡܝ ܕܥܝܢ ܒܓܠܐ ܐܟܪܙ ܐܪܙܐ ܕܤܒܪܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.20",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 6:20",
      "text": "ܗܘ ܕܐܢܐ ܐܝܙܓܕܗ ܒܫܫܠܬܐ ܕܒܦܪܗܤܝܐ ܐܡܠܠܝܘܗܝ ܐܝܟ ܕܘܠܐ ܠܝ ܠܡܡܠܠܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.21",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 6:21",
      "text": "ܕܬܕܥܘܢ ܕܝܢ ܐܦ ܐܢܬܘܢ ܡܕܡ ܕܠܘܬܝ ܘܡܕܡ ܕܤܥܪ ܐܢܐ ܗܐ ܡܘܕܥ ܠܟܘܢ ܛܘܟܝܩܘܤ ܐܚܐ ܚܒܝܒܐ ܘܡܫܡܫܢܐ ܡܗܝܡܢܐ ܒܡܪܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.22",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 6:22",
      "text": "ܕܠܗ ܫܕܪܬ ܠܘܬܟܘܢ ܥܠܝܗ ܥܠ ܗܕܐ ܕܬܕܥܘܢ ܡܐ ܕܠܘܬܝ ܘܢܒܝܐ ܠܒܘܬܟܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.23",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 6:23",
      "text": "ܫܠܡܐ ܥܡ ܐܚܝܢ ܘܚܘܒܐ ܥܡ ܗܝܡܢܘܬܐ ܡܢ ܐܠܗܐ ܐܒܐ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.6.24",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 6,
      "verseNumber": 24,
      "referenceLabel": "Ephesians 6:24",
      "text": "ܛܝܒܘܬܐ ܥܡ ܟܠܗܘܢ ܐܝܠܝܢ ܕܡܚܒܝܢ ܠܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܕܠܐ ܚܒܠ ܐܡܝܢ ܀",
      "paragraphStart": false
    }
  ]
}
