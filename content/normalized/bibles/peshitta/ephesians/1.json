{
  "chapter": {
    "id": "peshitta:ephesians.1",
    "translationId": "peshitta",
    "bookSlug": "ephesians",
    "chapterNumber": 1,
    "referenceLabel": "Ephesians 1",
    "summary": "Source text for Ephesians 1 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:ephesians.1.1",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 1,
      "referenceLabel": "Ephesians 1:1",
      "text": "ܦܘܠܘܤ ܫܠܝܚܐ ܕܝܫܘܥ ܡܫܝܚܐ ܒܨܒܝܢܗ ܕܐܠܗܐ ܠܐܝܠܝܢ ܕܐܝܬܝܗܘܢ ܒܐܦܤܘܤ ܩܕܝܫܐ ܘܡܗܝܡܢܐ ܒܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:ephesians.1.2",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 2,
      "referenceLabel": "Ephesians 1:2",
      "text": "ܫܠܡܐ ܥܡܟܘܢ ܘܛܝܒܘܬܐ ܡܢ ܐܠܗܐ ܐܒܘܢ ܘܡܢ ܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.3",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 3,
      "referenceLabel": "Ephesians 1:3",
      "text": "ܡܒܪܟ ܗܘ ܐܠܗܐ ܐܒܘܗܝ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܗܘ ܕܒܪܟܢ ܒܟܠ ܒܘܪܟܢ ܕܪܘܚ ܒܫܡܝܐ ܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.4",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 4,
      "referenceLabel": "Ephesians 1:4",
      "text": "ܐܝܟܢܐ ܕܩܕܡ ܓܒܢ ܒܗ ܡܢ ܩܕܡ ܬܪܡܝܬܗ ܕܥܠܡܐ ܕܢܗܘܐ ܩܕܝܫܐ ܘܕܠܐ ܡܘܡ ܩܕܡܘܗܝ ܘܒܚܘܒܐ ܩܕܡ ܪܫܡܢ ܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.5",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 5,
      "referenceLabel": "Ephesians 1:5",
      "text": "ܘܤܡܢ ܠܒܢܝܐ ܒܝܫܘܥ ܡܫܝܚܐ ܐܝܟ ܕܫܦܪ ܠܨܒܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.6",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 6,
      "referenceLabel": "Ephesians 1:6",
      "text": "ܕܢܫܬܒܚ ܫܘܒܚܐ ܕܛܝܒܘܬܗ ܗܘ ܕܐܫܦܥ ܥܠܝܢ ܒܝܕ ܚܒܝܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.7",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 7,
      "referenceLabel": "Ephesians 1:7",
      "text": "ܕܒܗ ܐܝܬ ܠܢ ܦܘܪܩܢܐ ܘܒܕܡܗ ܫܘܒܩܢܐ ܕܚܛܗܐ ܐܝܟ ܥܘܬܪܐ ܕܛܝܒܘܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.8",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 8,
      "referenceLabel": "Ephesians 1:8",
      "text": "ܗܝ ܕܐܬܝܬܪܬ ܒܢ ܒܟܠ ܚܟܡܐ ܘܒܟܠ ܤܘܟܠ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.9",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 9,
      "referenceLabel": "Ephesians 1:9",
      "text": "ܘܐܘܕܥܢ ܐܪܙܐ ܕܨܒܝܢܗ ܗܘ ܕܩܕܡ ܗܘܐ ܤܡ ܕܢܤܥܘܪ ܒܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.10",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 10,
      "referenceLabel": "Ephesians 1:10",
      "text": "ܠܡܕܒܪܢܘܬܐ ܕܡܘܠܝܗܘܢ ܕܙܒܢܐ ܕܟܠܡܕܡ ܡܢ ܕܪܝܫ ܢܬܚܕܬ ܒܡܫܝܚܐ ܕܒܫܡܝܐ ܘܒܐܪܥܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.11",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 11,
      "referenceLabel": "Ephesians 1:11",
      "text": "ܘܒܗ ܚܢܢ ܐܬܓܒܝܢ ܐܝܟ ܕܩܕܡ ܪܫܡܢ ܘܨܒܐ ܗܘ ܕܟܠ ܤܥܪ ܐܝܟ ܬܪܥܝܬܐ ܕܨܒܝܢܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.12",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 12,
      "referenceLabel": "Ephesians 1:12",
      "text": "ܕܢܗܘܐ ܚܢܢ ܐܝܠܝܢ ܕܩܕܡܢ ܤܒܪܢ ܒܡܫܝܚܐ ܠܗܕܪܐ ܕܬܫܒܘܚܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.13",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 13,
      "referenceLabel": "Ephesians 1:13",
      "text": "ܕܐܦ ܐܢܬܘܢ ܒܗ ܫܡܥܬܘܢ ܡܠܬܐ ܕܩܘܫܬܐ ܕܐܝܬܝܗ ܤܒܪܬܐ ܕܚܝܝܟܘܢ ܘܒܗ ܗܝܡܢܬܘܢ ܘܐܬܚܬܡܬܘܢ ܒܪܘܚܐ ܕܩܘܕܫܐ ܕܡܠܝܟܐ ܗܘܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.14",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 14,
      "referenceLabel": "Ephesians 1:14",
      "text": "ܗܝ ܕܐܝܬܝܗ ܪܗܒܘܢܐ ܕܝܪܬܘܬܢ ܠܦܘܪܩܢܐ ܕܐܝܠܝܢ ܕܚܐܝܢ ܘܠܫܘܒܚܐ ܕܐܝܩܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.15",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 15,
      "referenceLabel": "Ephesians 1:15",
      "text": "ܡܛܠ ܗܢܐ ܐܦ ܐܢܐ ܗܐ ܡܢ ܕܫܡܥܬ ܗܝܡܢܘܬܟܘܢ ܕܒܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܘܚܘܒܟܘܢ ܕܠܘܬ ܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.16",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 16,
      "referenceLabel": "Ephesians 1:16",
      "text": "ܠܐ ܡܫܬܠܐ ܐܢܐ ܠܡܘܕܝܘ ܥܠ ܐܦܝܟܘܢ ܘܠܡܥܗܕܟܘܢ ܒܨܠܘܬܝ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.17",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 17,
      "referenceLabel": "Ephesians 1:17",
      "text": "ܕܐܠܗܗ ܕܡܪܢ ܝܫܘܥ ܡܫܝܚܐ ܐܒܐ ܕܬܫܒܘܚܬܐ ܢܬܠ ܠܟܘܢ ܪܘܚܐ ܕܚܟܡܬܐ ܘܕܓܠܝܢܐ ܒܝܕܥܬܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.18",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 18,
      "referenceLabel": "Ephesians 1:18",
      "text": "ܘܢܢܗܪܢ ܥܝܢܐ ܕܠܒܘܬܟܘܢ ܕܬܕܥܘܢ ܡܢܘ ܤܒܪܐ ܕܩܪܝܢܗ ܘܡܢܘ ܥܘܬܪܐ ܕܫܘܒܚܐ ܕܝܪܬܘܬܗ ܒܩܕܝܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.19",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 19,
      "referenceLabel": "Ephesians 1:19",
      "text": "ܘܡܢܐ ܗܝ ܝܬܝܪܘܬܐ ܕܪܒܘܬܐ ܕܚܝܠܗ ܒܢ ܒܐܝܠܝܢ ܕܡܗܝܡܢܝܢܢ ܐܝܟ ܡܥܒܕܢܘܬܐ ܕܬܘܩܦܐ ܕܚܝܠܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.20",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 20,
      "referenceLabel": "Ephesians 1:20",
      "text": "ܕܥܒܕ ܒܡܫܝܚܐ ܘܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܘܐܘܬܒܗ ܡܢ ܝܡܝܢܗ ܒܫܡܝܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.21",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 21,
      "referenceLabel": "Ephesians 1:21",
      "text": "ܠܥܠ ܡܢ ܟܠܗܝܢ ܐܪܟܘܤ ܘܫܘܠܛܢܐ ܘܚܝܠܐ ܘܡܪܘܬܐ ܘܠܥܠ ܡܢ ܟܠ ܫܡ ܕܡܫܬܡܗ ܠܐ ܒܠܚܘܕ ܒܥܠܡܐ ܗܢܐ ܐܠܐ ܐܦ ܒܕܥܬܝܕ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.22",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 22,
      "referenceLabel": "Ephesians 1:22",
      "text": "ܘܫܥܒܕ ܟܠܡܕܡ ܬܚܝܬ ܪܓܠܘܗܝ ܘܠܗ ܕܐܝܬܘܗܝ ܠܥܠ ܡܢ ܟܠ ܝܗܒܗ ܪܫܐ ܠܥܕܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:ephesians.1.23",
      "translationId": "peshitta",
      "bookSlug": "ephesians",
      "chapterNumber": 1,
      "verseNumber": 23,
      "referenceLabel": "Ephesians 1:23",
      "text": "ܕܐܝܬܝܗ ܓܘܫܡܗ ܘܫܘܡܠܝܐ ܕܗܘ ܕܟܠ ܒܟܠ ܡܫܡܠܐ ܀",
      "paragraphStart": false
    }
  ]
}
