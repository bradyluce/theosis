    "bookSlug": "colossians",
    "chapterNumber": 2,
    "referenceLabel": "Colossians 2",
    "summary": "Source text for Colossians 2 in Peshitta (Syriac New Testament)."
  },
  "verses": [
    {
      "id": "peshitta:colossians.2.1",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 1,
      "referenceLabel": "Colossians 2:1",
      "text": "ܨܒܐ ܐܢܐ ܕܝܢ ܕܬܕܥܘܢ ܐܝܢܐ ܐܓܘܢܐ ܐܝܬ ܠܝ ܚܠܦܝܟܘܢ ܘܚܠܦ ܗܢܘܢ ܕܒܠܕܝܩܝܐ ܘܚܠܦ ܫܪܟܐ ܐܝܠܝܢ ܕܦܪܨܘܦܝ ܠܐ ܚܙܘ ܒܒܤܪ ܀",
      "paragraphStart": true
    },
    {
      "id": "peshitta:colossians.2.2",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 2,
      "referenceLabel": "Colossians 2:2",
      "text": "ܕܢܬܒܝܐܘܢ ܠܒܘܬܗܘܢ ܘܢܬܩܪܒܘܢ ܒܚܘܒܐ ܠܟܠܗ ܥܘܬܪܐ ܕܦܝܤܐ ܘܠܤܘܟܠܐ ܕܝܕܥܬܗ ܕܐܪܙܐ ܕܐܠܗܐ ܐܒܐ ܘܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.3",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 3,
      "referenceLabel": "Colossians 2:3",
      "text": "ܗܘ ܕܒܗ ܟܤܝܢ ܟܠܗܝܢ ܤܝܡܬܐ ܕܚܟܡܬܐ ܘܕܝܕܥܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.4",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 4,
      "referenceLabel": "Colossians 2:4",
      "text": "ܗܕܐ ܕܝܢ ܐܡܪ ܐܢܐ ܕܠܐ ܐܢܫ ܢܗܘܐ ܡܛܥܐ ܠܟܘܢ ܒܦܝܤܐ ܕܡܠܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.5",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 5,
      "referenceLabel": "Colossians 2:5",
      "text": "ܐܦܢ ܒܒܤܪ ܓܝܪ ܦܪܝܩ ܐܢܐ ܡܢܟܘܢ ܐܠܐ ܒܪܘܚ ܥܡܟܘܢ ܐܢܐ ܘܚܕܐ ܐܢܐ ܕܚܙܐ ܐܢܐ ܡܛܟܤܘܬܟܘܢ ܘܫܪܝܪܘܬܐ ܕܗܝܡܢܘܬܟܘܢ ܕܒܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.6",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 6,
      "referenceLabel": "Colossians 2:6",
      "text": "ܐܝܟܢܐ ܗܟܝܠ ܕܩܒܠܬܘܢ ܠܝܫܘܥ ܡܫܝܚܐ ܡܪܢ ܒܗ ܗܠܟܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.7",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 7,
      "referenceLabel": "Colossians 2:7",
      "text": "ܟܕ ܡܫܪܪܝܢ ܥܩܪܝܟܘܢ ܘܡܬܒܢܝܢ ܐܢܬܘܢ ܒܗ ܘܡܬܩܝܡܝܢ ܐܢܬܘܢ ܒܗܝܡܢܘܬܐ ܗܝ ܕܝܠܦܬܘܢ ܕܒܗ ܬܬܝܬܪܘܢ ܒܬܘܕܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.8",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 8,
      "referenceLabel": "Colossians 2:8",
      "text": "ܐܙܕܗܪܘ ܕܠܡܐ ܐܢܫ ܢܚܠܨܟܘܢ ܒܦܝܠܤܦܘܬܐ ܘܒܛܥܝܘܬܐ ܤܪܝܩܬܐ ܐܝܟ ܝܘܠܦܢܐ ܕܒܢܝܢܫܐ ܘܐܝܟ ܐܤܛܘܟܤܘܗܝ ܕܥܠܡܐ ܘܠܐ ܐܝܟ ܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.9",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 9,
      "referenceLabel": "Colossians 2:9",
      "text": "ܕܒܗ ܥܡܪ ܟܠܗ ܡܘܠܝܐ ܕܐܠܗܘܬܐ ܓܘܫܡܢܐܝܬ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.10",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 10,
      "referenceLabel": "Colossians 2:10",
      "text": "ܘܒܗ ܐܦ ܐܢܬܘܢ ܡܫܬܡܠܝܬܘܢ ܕܗܘ ܐܝܬܘܗܝ ܪܫܐ ܕܟܠܗܝܢ ܐܪܟܘܤ ܘܫܘܠܛܢܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.11",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 11,
      "referenceLabel": "Colossians 2:11",
      "text": "ܘܒܗ ܐܬܓܙܪܬܘܢ ܓܙܘܪܬܐ ܕܠܐ ܒܐܝܕܝܢ ܒܫܠܚ ܒܤܪܐ ܕܚܛܗܐ ܒܓܙܘܪܬܗ ܕܡܫܝܚܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.12",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 12,
      "referenceLabel": "Colossians 2:12",
      "text": "ܘܐܬܩܒܪܬܘܢ ܥܡܗ ܒܡܥܡܘܕܝܬܐ ܘܒܗ ܩܡܬܘܢ ܥܡܗ ܕܗܝܡܢܬܘܢ ܒܚܝܠܐ ܕܐܠܗܐ ܕܐܩܝܡܗ ܡܢ ܒܝܬ ܡܝܬܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.13",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 13,
      "referenceLabel": "Colossians 2:13",
      "text": "ܘܠܟܘܢ ܕܡܝܬܝܢ ܗܘܝܬܘܢ ܒܚܛܗܝܟܘܢ ܘܒܥܘܪܠܘܬ ܒܤܪܟܘܢ ܐܚܝܟܘܢ ܥܡܗ ܘܫܒܩ ܠܢ ܟܠܗܘܢ ܚܛܗܝܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.14",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 14,
      "referenceLabel": "Colossians 2:14",
      "text": "ܘܥܛܐ ܒܦܘܩܕܢܘܗܝ ܫܛܪ ܚܘܒܝܢ ܗܘ ܕܐܝܬܘܗܝ ܗܘܐ ܤܩܘܒܠܢ ܘܫܩܠܗ ܡܢ ܡܨܥܬܐ ܘܩܒܥܗ ܒܙܩܝܦܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.15",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 15,
      "referenceLabel": "Colossians 2:15",
      "text": "ܘܒܫܠܚ ܦܓܪܗ ܦܪܤܝ ܠܐܪܟܘܤ ܘܠܫܠܝܛܢܐ ܘܐܒܗܬ ܐܢܘܢ ܓܠܝܐܝܬ ܒܩܢܘܡܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.16",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 16,
      "referenceLabel": "Colossians 2:16",
      "text": "ܠܐ ܗܟܝܠ ܐܢܫ ܢܕܘܕܟܘܢ ܒܡܐܟܠܐ ܘܒܡܫܬܝܐ ܐܘ ܒܦܘܠܓܐ ܕܥܐܕܐ ܘܕܪܝܫ ܝܪܚܐ ܘܕܫܒܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.17",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 17,
      "referenceLabel": "Colossians 2:17",
      "text": "ܗܠܝܢ ܕܐܝܬܝܗܝܢ ܛܠܢܝܬܐ ܕܐܝܠܝܢ ܕܥܬܝܕܢ ܦܓܪܐ ܕܝܢ ܡܫܝܚܐ ܗܘ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.18",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 18,
      "referenceLabel": "Colossians 2:18",
      "text": "ܘܠܡܐ ܐܢܫ ܢܨܒܐ ܒܡܟܝܟܘܬ ܪܥܝܢܐ ܠܡܚܝܒܘܬܟܘܢ ܕܬܫܬܥܒܕܘܢ ܠܦܘܠܚܢܐ ܕܡܠܐܟܐ ܒܕܤܥܐ ܥܠ ܡܕܡ ܕܠܐ ܚܙܐ ܘܤܪܝܩܐܝܬ ܡܬܚܬܪ ܒܪܥܝܢܐ ܕܒܤܪܗ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.19",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 19,
      "referenceLabel": "Colossians 2:19",
      "text": "ܘܠܐ ܐܚܕ ܪܫܐ ܕܡܢܗ ܟܠܗ ܦܓܪܐ ܡܬܪܟܒ ܘܡܬܩܝܡ ܒܫܪܝܢܐ ܘܒܗܕܡܐ ܘܪܒܐ ܬܪܒܝܬܐ ܕܐܠܗܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.20",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 20,
      "referenceLabel": "Colossians 2:20",
      "text": "ܐܢ ܓܝܪ ܡܝܬܬܘܢ ܥܡ ܡܫܝܚܐ ܡܢ ܐܤܛܘܟܤܘܗܝ ܕܥܠܡܐ ܠܡܢܐ ܐܝܟ ܗܘ ܕܚܝܝܢ ܐܢܬܘܢ ܒܥܠܡܐ ܡܬܕܝܢܝܢ ܐܢܬܘܢ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.21",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 21,
      "referenceLabel": "Colossians 2:21",
      "text": "ܠܐ ܠܡ ܬܩܪܘܒ ܘܠܐ ܬܛܥܡ ܘܠܐ ܬܩܦ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.22",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 22,
      "referenceLabel": "Colossians 2:22",
      "text": "ܕܐܝܬܝܗܝܢ ܗܠܝܢ ܚܫܚܬܐ ܕܡܬܚܒܠܐ ܘܦܘܩܕܐ ܐܢܝܢ ܘܝܘܠܦܢܐ ܕܒܢܝܢܫܐ ܀",
      "paragraphStart": false
    },
    {
      "id": "peshitta:colossians.2.23",
      "translationId": "peshitta",
      "bookSlug": "colossians",
      "chapterNumber": 2,
      "verseNumber": 23,
      "referenceLabel": "Colossians 2:23",
      "text": "ܘܡܬܚܙܝܢ ܕܐܝܬ ܒܗܝܢ ܡܠܬܐ ܕܚܟܡܬܐ ܒܦܪܨܘܦ ܡܟܝܟܘܬܐ ܘܕܚܠܬ ܐܠܗܐ ܘܕܠܐ ܚܝܤܝܢ ܥܠ ܦܓܪܐ ܠܘ ܒܡܕܡ ܕܡܝܩܪ ܐܠܐ ܒܐܝܠܝܢ ܕܚܫܚܬܐ ܐܢܝܢ ܕܒܤܪܐ ܀",
      "paragraphStart": false
    }
  ]
}
